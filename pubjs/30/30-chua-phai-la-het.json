:"105961","season":1,"vote_average":7.5,"vote_count":17},"modified":"2023-04-11T19:26:31.000Z","cast":["Giang Sơ Ảnh","Đồng Dao","Mao Hiểu Đồng","Dương Lặc","Lý Trạch Phong","Edward Ma Chi-Wai","Yan Zidong"],"director":["Trương Hiểu Ba"],"cast_meta":[{"name":"Giang Sơ Ảnh","name_vi":"Giang Sơ Ảnh","name_original":"Maggie Jiang","tmdb_id":1590275,"profile":"https://image.tmdb.org/t/p/w500/luquCFWpyv8ejXYJuyWCpUPneNe.jpg","tmdb_url":"https://www.themoviedb.org/person/1590275"},{"name":"Đồng Dao","name_vi":"Đồng Dao","name_original":"Tong Yao","tmdb_id":1298729,"profile":"https://image.tmdb.org/t/p/w500/darU7n51ym1dziYRwOtD10qiljn.jpg","tmdb_url":"https://www.themoviedb.org/person/1298729"},{"name":"Mao Hiểu Đồng","name_vi":"Mao Hiểu Đồng","name_original":"Mao Xiaotong","tmdb_id":1697058,"profile":"https://image.tmdb.org/t/p/w500/zOrbXf5SInGL06eYi56Z0jxI99G.jpg","tmdb_url":"https://www.themoviedb.org/person/1697058"},{"name":"Dương Lặc","name_vi":"Dương Lặc","name_original":"Yang Le","tmdb_id":2018045,"profile":"https://image.tmdb.org/t/p/w500/6yvhf8DffccXncVffVveNKTDScz.jpg","tmdb_url":"https://www.themoviedb.org/person/2018045"},{"name":"Lý Trạch Phong","name_vi":"Lý Trạch Phong","name_original":"Li Zefeng","tmdb_id":1910069,"profile":"https://image.tmdb.org/t/p/w500/fqPhLubbymkJ8ILJSuVkTAgyaP8.jpg","tmdb_url":"https://www.themoviedb.org/person/1910069"},{"name":"Edward Ma Chi-Wai","name_vi":null,"name_original":"Edward Ma Chi-Wai","tmdb_id":1206204,"profile":"https://image.tmdb.org/t/p/w500/5Dd0gVtOetCwpvD07DT2c24L435.jpg","tmdb_url":"https://www.themoviedb.org/person/1206204"},{"name":"Yan Zidong","name_vi":null,"name_original":"Yan Zidong","tmdb_id":1850115,"profile":"https://image.tmdb.org/t/p/w500/hKO1P17mUdhNYf71Qqv9sEPw004.jpg","tmdb_url":"https://www.themoviedb.org/person/1850115"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/30/30-chua-phai-la-het.json"}