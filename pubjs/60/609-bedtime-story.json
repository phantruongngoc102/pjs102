9/index.m3u8"},{"name":"23","slug":"23","filename":"609 Bedtime Story - Tập 12---2022","link_embed":"https://vip.opstream13.com/share/2578eb9cdf020730f77793e8b58e165a","link_m3u8":"https://vip.opstream13.com/20251006/10862_2578eb9c/index.m3u8"}]}],"time":"25 phút/tập","description":"<p>Đột nhiên có một chàng trai trẻ xuất hiện trên giường ngủ của Mum - một tay ăn chơi và cũng là chủ nhân căn phòng số 609. Cả hai phát sinh quan hệ nồng cháy ngay từ lần gặp đầu tiên. Nhưng đêm đó lại trở thành \"ngày cuối cùng\" của cuộc đời Dew. Sau đó kéo theo những sự việc kỳ lạ không thể giải thích nổi. Mum lựa chọn quên đi sự nhớ nhung về lần \"đụng chạm\" với Dew bằng cách quan hệ với các cô gái khác. Nhưng điều đó chỉ càng khiến anh thêm nhớ nhung chàng trai trẻ trong mộng mà thôi. Vì vậy anh cố gắng căng não để kết nối những sự kiện và đến cuối cùng cũng anh gặp được Dew - một chàng trai trẻ được gia đình đặt nhiều kì vọng, và rồi anh đã tìm ra sự thật về kẻ đã giết Dew đêm đó.</p>","tmdb":{"type":"tv","id":"214163","season":1,"vote_average":8.4,"vote_count":8},"modified":"2025-10-06T13:45:50.000Z","cast":["Thitiwat Ritprasert","Natouch Siripongthon","Patnithi Saranwatnakul","Watcharayu Suradet","Thasorn Klinnium","Jakkrit Yompayorm"],"director":["Tanwarin Sukkhapisit"],"cast_meta":[{"name":"Thitiwat Ritprasert","name_vi":null,"name_original":"Thitiwat Ritprasert","tmdb_id":2453356,"profile":"https://image.tmdb.org/t/p/w500/tgGx0iqe4itX5mJi4fMcSIx4Dmu.jpg","tmdb_url":"https://www.themoviedb.org/person/2453356"},{"name":"Natouch Siripongthon","name_vi":null,"name_original":"Natouch Siripongthon","tmdb_id":2453348,"profile":"https://image.tmdb.org/t/p/w500/pQxpYvlSofqMU3tZMZbUSWzvnbI.jpg","tmdb_url":"https://www.themoviedb.org/person/2453348"},{"name":"Patnithi Saranwatnakul","name_vi":null,"name_original":"Patnithi Saranwatnakul","tmdb_id":1872289,"profile":"https://image.tmdb.org/t/p/w500/pD6GNEEudXFGmJqHQM3j5NfTVCh.jpg","tmdb_url":"https://www.themoviedb.org/person/1872289"},