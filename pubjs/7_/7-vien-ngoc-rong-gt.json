995_708bc296/index.m3u8"},{"name":"62","slug":"62","link_embed":"https://vip.opstream12.com/share/3dce18d1998152eeb1b5fe47ab64cf1d","link_m3u8":"https://vip.opstream12.com/20220609/17996_ec0d07d0/index.m3u8"},{"name":"63","slug":"63","link_embed":"https://vip.opstream12.com/share/e36c72761b575374e7d7e63a0333d93f","link_m3u8":"https://vip.opstream12.com/20220609/17997_4d1cfdfe/index.m3u8"},{"name":"64","slug":"64","link_embed":"https://vip.opstream12.com/share/260e47ef04cdd6f9d4989f12facd3a91","link_m3u8":"https://vip.opstream12.com/20220609/17998_e2ace683/index.m3u8"}]}],"description":"<p>Pilaf cuối cùng cũng có trong tay những viên Ngọc rồng Black Star sau nhiều năm tìm kiếm, thứ được cho là mạnh gấp đôi những viên ngọc bình thường của Trái đất. Pilaf đang chuẩn bị thực hiện ước nguyện thống trị thế giới thì bị Gokuu Son làm gián đoạn. Do đó, Pilaf từ chối điều ước của mình và vô tình biến Gokuu trở lại thành một đứa trẻ. Sau khi điều ước được thực hiện, các viên Ngọc Rồng Sao Đen phân tán khắp thiên hà. Tuy nhiên, Gokuu phát hiện ra rằng chúng sẽ khiến Trái đất nổ tung trừ khi tất cả chúng được tập hợp lại trong vòng một năm. Cùng với với cháu gái Pan và một thanh niên Trunks, Gokuu bắt đầu một cuộc phiêu lưu xuyên vũ trụ để tìm các viên Ngọc Rồng Sao Đen và cứu hành tinh của mình khỏi sự hủy diệt.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/7_/7-vien-ngoc-rong-gt.json"}