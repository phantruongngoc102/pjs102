611/19012_5299f6ac/index.m3u8"},{"name":"149","slug":"149","link_embed":"https://vip.opstream12.com/share/4839e9401ca59a31a153bfc202e3971e","link_m3u8":"https://vip.opstream12.com/20220611/19011_b92fd579/index.m3u8"},{"name":"150","slug":"150","link_embed":"https://vip.opstream12.com/share/edd6a7e04e7f4dd932a5c44f282f9b4e","link_m3u8":"https://vip.opstream12.com/20220611/19013_4a6f8f2f/index.m3u8"},{"name":"151","slug":"151","link_embed":"https://vip.opstream12.com/share/4e8f015d5644555f9723e2468c19fbe4","link_m3u8":"https://vip.opstream12.com/20220611/19014_624847a6/index.m3u8"},{"name":"152","slug":"152","link_embed":"https://vip.opstream12.com/share/a4e1d10a7a8bc2dae8f3d9936475502f","link_m3u8":"https://vip.opstream12.com/20220611/19015_87fad875/index.m3u8"},{"name":"153","slug":"153","link_embed":"https://vip.opstream12.com/share/16e12822445d7ba7d4433330dd22b91b","link_m3u8":"https://vip.opstream12.com/20220611/19016_a31085ab/index.m3u8"}]}],"description":"<p>Một cậu bé có đuôi khỉ được tìm thấy bởi một ông lão sống một mình trong rừng, ông đặt tên là Son Goku và xem đứa bé như là cháu của mình. Một ngày nọ Goku tình cờ gặp một cô gái tên là Bulma trên đường đi bắt cá về, Goku và Bulma đã cùng nhau truy tìm bảy viên ngọc rồng. Các viên ngọc rồng này chứa đựng một bí mật có thể triệu hồi một con rồng và ban điều ước cho ai sở hữu chúng. Trên cuộc hành trình dài đi tìm những viên ngọc rồng, họ gặp những người bạn (Yamcha, Krillin,Yajirobe, Thiên, Giáo tử, Oolong,...) và những đấu sĩ huyền thoại cũng như nhiều ác quỷ.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/7_/7-vien-ngoc-rong.json","tmdb_checked":false}