{"id":"6408c36752819de7fe862ce0","title":"A Place in the Sun","origin_name":"A Place in the Sun","slug":"a-place-in-the-sun","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/a_/a-place-in-the-sun.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/a_/a-place-in-the-sun.webp","year":1951,"type":"single","genre":[{"id":"620a220de0fc277084dfd16d","name":"Tình Cảm","slug":"tinh-cam"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"A Place in the Sun - Nơi Ánh Dương Soi Chiếu - 1951","link_embed":"https://vip.opstream14.com/share/ca3f6e75176256acc0e0756a3f8eccea","link_m3u8":"https://vip.opstream14.com/20230308/33514_dd8958a4/index.m3u8"}]}],"time":"122 Phút","description":"A Place in the Sun (Nơi Ánh Dương Soi Chiếu) là một bộ phim tình cảm bi kịch của Mỹ ra mắt năm 1951 dựa trên tiểu thuyết năm 1925 An American Tragedy của Theodore Dreiser và vở kịch năm 1926, cũng cùng tựa đề. Tất cả những tác phẩm này đều được lấy cảm hứng từ vụ giết hại Grace Brown ngoài đời thực của Chester Gillette vào năm 1906, và sau đó Gillette đã bị kết án tử hình và hành quyết bằng ghế điện vào năm 1908. Đạo diễn George Stevens và biên kịch Patrick Kearney đã đem lại thành công cho bộ phim cả về mặt thương mại lẫn được giới phê bình ca tụng, được đề cử 9 giải thưởng Oscar (trong đó có giải Phim hay nhất), giành chiến thắng 6 giải và là phim chiến thắng giải Quả Cầu Vàng Phim hay nhất đầu tiên của lịch sử giải thưởng này. Vào năm 1991, A Place in the Sun đã được Thư viện Quốc hội Mỹ ( Library of Congress) chọn đưa vào bảo quản trong Viện lưu trữ phim quốc gia Hoa Kỳ (United States National Film Registry) vì có ý nghĩa \"về mặt văn hóa, lịch sử, hay thẩm mỹ”.","tmdb":{"type":"movie","id":"25673","season":null,"vote_average":7.3,"vote_count":410},"modified":"2023-03-09T00:18:33.000Z","cast":["Montgomery Clift","Elizabeth Taylor","Shelley Winters","Anne Revere","Keefe Brasselle","Fred Clark","Raymond Burr","Herbert Heyes","Shepperd Strudwick","Frieda Inescort","Kathryn Givney","Walter Sande","Ted de Corsia","John Ridgely","Lois Chartrand"],"director":["George Stevens"],"cast_meta":[{"name":"Montgomery Clift","name_vi":null,"name_original":"Montgomery Clift","tmdb_id":12151,"profile":"https://image.tmdb.org/t/p/w500/9dwtVaD3ybBNciTzWiNWNqFpFVj.jpg","tmdb_url":"https://www.themoviedb.org/person/12151"},{"name":"Elizabeth Taylor","name_vi":null,"name_original":"Elizabeth Taylor","tmdb_id":3635,"profile":"https://image.tmdb.org/t/p/w500/6r5yjGdvRvMoWQy7W0CYrkbLSNZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3635"},{"name":"Shelley Winters","name_vi":null,"name_original":"Shelley Winters","tmdb_id":7632,"profile":"https://image.tmdb.org/t/p/w500/sY7LVp0M8yJgFD0o2uAIJgfLGm9.jpg","tmdb_url":"https://www.themoviedb.org/person/7632"},{"name":"Anne Revere","name_vi":null,"name_original":"Anne Revere","tmdb_id":7641,"profile":"https://image.tmdb.org/t/p/w500/mtlMi003Niqn0lv4Vemxkx5v09M.jpg","tmdb_url":"https://www.themoviedb.org/person/7641"},{"name":"Keefe Brasselle","name_vi":null,"name_original":"Keefe Brasselle","tmdb_id":119081,"profile":"https://image.tmdb.org/t/p/w500/86ghXSHrR1E6W51WbKPOKFcqROt.jpg","tmdb_url":"https://www.themoviedb.org/person/119081"},{"name":"Fred Clark","name_vi":null,"name_original":"Fred Clark","tmdb_id":8632,"profile":"https://image.tmdb.org/t/p/w500/yBjSwb6xma9ukYpbSe75C0eqNTx.jpg","tmdb_url":"https://www.themoviedb.org/person/8632"},{"name":"Raymond Burr","name_vi":null,"name_original":"Raymond Burr","tmdb_id":7685,"profile":"https