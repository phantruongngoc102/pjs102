","group therapy","supernatural","hypnosis","ohio","sequel","murder","slasher","trapped","alcoholic","mental illness","dream sequence","catholicism","disfigurement","sleepwalking","mental hospital","nightmare becomes reality","psychotherapist","supernatural horror","dreaming"],"tmdb":{"type":"movie","id":"10072","season":null,"vote_average":6.696,"vote_count":1960},"cast_meta":[{"name":"Heather Langenkamp","name_vi":null,"name_original":"Heather Langenkamp","tmdb_id":5141,"profile":"https://image.tmdb.org/t/p/w500/xI20Uddk9COIfgifaA4NRsXyZMD.jpg","tmdb_url":"https://www.themoviedb.org/person/5141"},{"name":"Patricia Arquette","name_vi":null,"name_original":"Patricia Arquette","tmdb_id":4687,"profile":"https://image.tmdb.org/t/p/w500/jeThSouMatiuRiLkjDvSBLHpmq0.jpg","tmdb_url":"https://www.themoviedb.org/person/4687"},{"name":"Craig Wasson","name_vi":null,"name_original":"Craig Wasson","tmdb_id":62893,"profile":"https://image.tmdb.org/t/p/w500/5LSJdJF6D0iyvOvy4KUfBBPg71B.jpg","tmdb_url":"https://www.themoviedb.org/person/62893"},{"name":"Robert Englund","name_vi":null,"name_original":"Robert Englund","tmdb_id":5139,"profile":"https://image.tmdb.org/t/p/w500/cjGEkiavinHa1dnetDvnEhlD2Wm.jpg","tmdb_url":"https://www.themoviedb.org/person/5139"},{"name":"Laurence Fishburne","name_vi":null,"name_original":"Laurence Fishburne","tmdb_id":2975,"profile":"https://image.tmdb.org/t/p/w500/2GbXERENPpl5MmlqOLlPVaVtifD.jpg","tmdb_url":"https://www.themoviedb.org/person/2975"},{"name":"Ken Sagoes","name_vi":null,"name_original":"Ken Sagoes","tmdb_id":63915,"profile":"https://image.tmdb.org/t/p/w500/lPFKjzCKtPApH3djcwZ9rHous86.jpg","tmdb_url":"https://www.themoviedb.org/person/63915"},{"name":"Rodney Eastman","name_vi":null,"name_original":"Rodney Eastman","tmdb_id":63916,"profile":"https://image.tmdb.org/t/p/w500/orGHxNB2n9ZZ0QHHMohyvWiNKec.jpg","tmdb_url":"https://www.themoviedb.org/person/63916"},{"name":"Jennifer Rubin","name_vi":null,"name_original":"Jennifer Rubin","tmdb_id":5