/ba036d228858d76fb89189853a5503bd","link_m3u8":"https://vip.opstream14.com/20220327/3493_4e7ec7c8/index.m3u8"},{"name":"7","slug":"7","filename":"ai-la-hung-thu-tap-7","link_embed":"https://vip.opstream14.com/share/6dbd2699e8e7ec0047de2d5d1b28a75b","link_m3u8":"https://vip.opstream14.com/20220327/3494_40a6e1cd/index.m3u8"},{"name":"8","slug":"8","filename":"ai-la-hung-thu-tap-8","link_embed":"https://vip.opstream14.com/share/8485ae387a981d783f8764e508151cd9","link_m3u8":"https://vip.opstream14.com/20220327/3495_17c982e1/index.m3u8"},{"name":"9","slug":"9","filename":"ai-la-hung-thu-tap-9","link_embed":"https://vip.opstream14.com/share/0a348ede8ac3768875037baca5de6e26","link_m3u8":"https://vip.opstream14.com/20220327/3496_5abdc0b6/index.m3u8"},{"name":"10","slug":"10","filename":"ai-la-hung-thu-tap-10","link_embed":"https://vip.opstream14.com/share/7535bbb91c8fde347ad861f293126633","link_m3u8":"https://vip.opstream14.com/20220327/3497_f56b7f30/index.m3u8"},{"name":"11","slug":"11","filename":"ai-la-hung-thu-tap-11","link_embed":"https://vip.opstream14.com/share/fd9dcf1d146272bb05c490d790b6da52","link_m3u8":"https://vip.opstream14.com/20220327/3498_75fd0897/index.m3u8"},{"name":"12","slug":"12","filename":"ai-la-hung-thu-tap-12","link_embed":"https://vip.opstream14.com/share/3ea2db50e62ceefceaf70a9d9a56a6f4","link_m3u8":"https://vip.opstream14.com/20220327/3499_9010e96e/index.m3u8"},{"name":"13","slug":"13","filename":"ai-la-hung-thu-tap-13","link_embed":"https://vip.opstream14.com/share/e2065cb56f5533494522c46a72f1dfb0","link_m3u8":"https://vip.opstream14.com/20220327/3500_839cb2c2/index.m3u8"},{"name":"14","slug":"14","filename":"ai-la-hung-thu-tap-14","link_embed":"https://vip.opstream14.com/share/d494020ff8ec181ef98ed97ac3f25453","link_m3u8":"https://vip.opstream14.com/20220327/3501_c10dcd08/index.m3u8"},{"name":"15","slug":"15","filename":"ai-la-hung-thu-tap-15","link_embed":"https://vip.opstream14.com/share/d2350a54d774001d6078e326b4488878","link_m3u8":"https://vip.opstream14.com/20220327/3502_9905a9ef/index.m3u8"},{"name":"16","slug":"16","filename":"ai-la-hung-thu-tap-16","link_embed":"https://vip.opstream14.com/share/87f7ee4fdb57bdfd52179947211b7ebb","link_m3u8":"https://vip.opstream14.com/20220327/3503_09aa9f26/index.m3u8"}]}],"time":"38M2S","description":"<p>Mùa đông năm 2001, một vụ án mạng xảy ra trong một nhà máy in ấn ở thành phố Hải Chu. Cảnh sát hình sự mới vào nghề Lãnh Tiểu Binh và đàn anh nhận được báo án liền đi tới hiện trường, ngoài ý muốn đối mặt với sát thủ của những vụ án giết người liên hoàn của thành phố Hải Chu. Lãnh Tiểu Binh nhát gan không dám nổ súng, hung thủ từ hiện trường bỏ trốn giết chết đàn anh Lý Lam. Nhân chứng khác ở hiện trường là con của người bị hại trốn dưới gầm giường, Hạ Mục. Để có thể tiếp tục ở lại đội hình sư, Lãnh Tiểu Băng che giấu việc không dám nổ súng, Hạ Mộc cũng không dám vạch trần anh ta. Còn về hung thủ lại ẩn mình, vụ án ở Hải Chu chưa được giải quyết. 16 năm sau, Hạ Mộc tới đội hình sự thực tập, nắm thóp chuyện Lãnh Tiểu Băng không dám nổ súng, ép anh ta cùng điều tra án với mình. Vài lúc hai người nghi ngờ bố của bác sĩ tâm lý Thẩm Vũ, Thẩm Vũ cũng bắt đầu kế hoạch mô phỏng tội phạm giúp chồng thoát tội. Sau đó một bộ xương với thời gian tử vong quá 16 năm làm 3 người rơi vào màn đêm sâu thẳm. Cuối cùng ba người bắt tay cùng tróc nã hung thủ.</p>","tmdb":{"type":"tv","id":"131552","season":1,"vote_average":7.444,"vote_count":9},"modified":"2022-05-26T01:59:14.000Z","cast":["Triệu Lệ Dĩnh","Tiêu Ương","Đổng Tử Kiện"],"director":["Sun Hao"],"cast_meta":[{"name":"Triệu Lệ Dĩnh","name_vi":null,"name_original":"Triệu Lệ Dĩnh"},{"name":"Tiêu Ương","name_vi":null,"name_original":"Tiêu Ương"},{"name":"Đổng Tử Kiện","name_vi":null,"name_original":"Đổng Tử Kiện"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ai/ai-la-hung-thu.json"}