k_m3u8":"https://vip.opstream14.com/20231022/40502_ede0e290/index.m3u8"}]}],"time":"15 phút/tập","description":"<p>Ám Hà, tổ chức sát thủ thần bí nhất trong giang hồ, tạo thành bởi ba gia tộc họ Tô, Tạ, Mộ, thủ lĩnh tối cao của ba nhà gọi là Đại gia trưởng. Đại gia trưởng thân trúng kỳ độc, tính mạng nguy trong sớm tối. Sau khi thế lực ba nhà Ám Hà biết được tin tức bèn nhân cơ hội nổi dậy.Tô Mộ Vũ thân là thủ lĩnh đội Chu Ảnh chuyên bảo vệ Đại gia trưởng, một bên tìm thần y Bạch Hạc Hoài của Dược Vương Cốc xin chữa bệnh cho Đại gia trưởng, một bên đối phó với sát thủ của các gia tộc bảo vệ an toàn cho Đại gia trưởng. Lúc này, bạn thân Tô Tinh Hà của hắn trong tổ chức Ám Hà lại đại diện Tô gia, gia nhập hành động ám sát Đại gia trưởng.<br>&nbsp;</p>","tmdb":{"type":"tv","id":"217626","season":1,"vote_average":8.7,"vote_count":3},"modified":"2025-03-18T11:37:00.000Z","cast":["Liu Mingyue","Tang Xiaoxi","Wei Chao","Jinwen Chen","Qiao Shiyu","Lin Qiang","Li Jiasi","Zhao Mingzhou"],"director":["Tao Zhou"],"cast_meta":[{"name":"Liu Mingyue","name_vi":null,"name_original":"Liu Mingyue","tmdb_id":2156556,"profile":"https://image.tmdb.org/t/p/w500/kqh1vBsQ35b617dvd9jtvQ2ii7l.jpg","tmdb_url":"https://www.themoviedb.org/person/2156556"},{"name":"Tang Xiaoxi","name_vi":null,"name_original":"Tang Xiaoxi","tmdb_id":2508433,"profile":"https://image.tmdb.org/t/p/w500/gsqR3dgkDYSmKUpHAF1XUPSLyS4.jpg","tmdb_url":"https://www.themoviedb.org/person/2508433"},{"name":"Wei Chao","name_vi":null,"name_original":"Wei Chao","tmdb_id":2199340,"profile":"https://image.tmdb.org/t/p/w500/aPYAEWrS1lb1UYwCFejIcJOOGSU.jpg","tmdb_url":"https://www.themoviedb.org/person/2199340"},{"name":"Jinwen Chen","name_vi":null,"name_original":"Jinwen Chen","tmdb_id":2702141,"profile":"https://image.tmdb.org/t/p/w500/hJXKRcrbVpKc2q1rIbH6DU2INPH.jpg","tmdb_url":"https://www.themoviedb.org/person/2702141"},{"name":"Qiao Shiyu","name_vi":null,"name_original":"Qiao Shiyu","tmdb_id":2199334,"profile":"https://image.