ẹn sẽ là một bộ phim phá án hài hước hấp dẫn người xem.","tmdb":{"type":"tv","id":"104544","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-22T10:38:35.000Z","cast":["Kenneth Ma Kwok-Ming","Louis Yuen Siu-Cheung","Eliza Sam","Huỳnh Thuý Như","Giang Hân Yến","Oscar Leung Lit-Wai","Jacqueline Wong","Lee Tin-Cheung","Joe Junior","Iva Law Wing-Han","Terence Tung","Vu Dương","Diêu Doanh Doanh","Lily Li","Joan Lee Wing-Yee"],"director":["Lương Tài Viễn"],"cast_meta":[{"name":"Kenneth Ma Kwok-Ming","name_vi":null,"name_original":"Kenneth Ma Kwok-Ming","tmdb_id":1232198,"profile":"https://image.tmdb.org/t/p/w500/6DejZHB8htcmosNwuOGJeDUgfJr.jpg","tmdb_url":"https://www.themoviedb.org/person/1232198"},{"name":"Louis Yuen Siu-Cheung","name_vi":null,"name_original":"Louis Yuen Siu-Cheung","tmdb_id":579496,"profile":"https://image.tmdb.org/t/p/w500/9Ws35BMwo00MUOI53vCaLPhAdZ.jpg","tmdb_url":"https://www.themoviedb.org/person/579496"},{"name":"Eliza Sam","name_vi":null,"name_original":"Eliza Sam","tmdb_id":1688880,"profile":"https://image.tmdb.org/t/p/w500/cBjklXUuITK69b75HaEVltOdwnC.jpg","tmdb_url":"https://www.themoviedb.org/person/1688880"},{"name":"Huỳnh Thuý Như","name_vi":"Huỳnh Thuý Như","name_original":"Priscilla Wong","tmdb_id":227741,"profile":"https://image.tmdb.org/t/p/w500/yjZHT5RSQunnEc1yLkyyPKLR3Lm.jpg","tmdb_url":"https://www.themoviedb.org/person/227741"},{"name":"Giang Hân Yến","name_vi":"Giang Hân Yến","name_original":"Alvina Kong Yan-Yin","tmdb_id":240927,"profile":"https://image.tmdb.org/t/p/w500/96pcgW1IxSCXyHwmghrdow6SVbn.jpg","tmdb_url":"https://www.themoviedb.org/person/240927"},{"name":"Oscar Leung Lit-Wai","name_vi":null,"name_original":"Oscar Leung Lit-Wai","tmdb_id":1143685,"profile":"https://image.tmdb.org/t/p/w500/ftnBNSi7RriYNkHarXrh5ExA74s.jpg","tmdb_url":"https://www.themoviedb.org/person/1143685"},{"name":"Jacqueline Wong","name_vi":null,"name_original":"Jacqueline Wong","tmdb_id":2064573,"profile":"https://image.tmdb.org/t/p/w500