2850ef81d52ee81dd1d7b5","link_m3u8":"https://vip.opstream11.com/20220617/31151_20110b89/index.m3u8"},{"name":"217","slug":"217","filename":"Amazing Saturday Tập 217","link_embed":"https://vip.opstream14.com/share/abdac3c2c521741e5aa11fc9c87bf7db","link_m3u8":"https://vip.opstream14.com/20220625/15650_b352693f/index.m3u8"},{"name":"218","slug":"218","filename":"Amazing Saturday Tập 218Tập 218","link_embed":"https://vip.opstream14.com/share/272dd328718e70a3379ebfa0f21d88fa","link_m3u8":"https://vip.opstream14.com/20220821/20471_97ad2f03/index.m3u8"}]}],"time":"90 Phút / Tập","description":"<p>Amazing Saturday (Hay còn gọi là Doremi Market) là một chương trình tạp kỹ của Hàn Quốc phát sóng vào thứ bảy hàng tuần lúc 19:40 (KST) trên tvN. Trong mỗi tập, một khu chợ đến từ Hàn Quốc sẽ được giới thiệu và trong đó có 3 loại thực phẩm được chọn làm đại diện. Các thành viên và khách mời phải chơi trò chơi và giành chiến thắng để có thể thưởng thức đồ ăn. Sẽ có một khái niệm chủ đề về trang phục cho các thành viên và khách mời tuân theo khi quay mỗi tập.</p>","tmdb":{"type":"tv","id":"78648","season":1,"vote_average":7.6,"vote_count":10},"modified":"2022-08-21T09:53:07.000Z","cast":["Shin Dong-yup","Park Na-rae","Kim Dong-hyun","Lee Min-ho","Moon Se-yoon","Key","Hanhae","Taeyeon","Nucksal","Pyo Ji-hoon","Kim Mi-kyung"],"director":["Lee Tae-kyeong","Jin Bo-mi"],"cast_meta":[{"name":"Shin Dong-yup","name_vi":null,"name_original":"Shin Dong-yup","tmdb_id":1350138,"profile":"https://image.tmdb.org/t/p/w500/iMzzz78MnoBpzrVyjMnG6DqkfmZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1350138"},{"name":"Park Na-rae","name_vi":null,"name_original":"Park Na-rae","tmdb_id":1703375,"profile":"https://image.tmdb.org/t/p/w500/dUqQeDICulymBkia4eqQ40LKHPa.jpg","tmdb_url":"https://www.themoviedb.org/person/1703375"},{"name":"Kim Dong-hyun","name_vi":"Kim Dong-hyun","name_original":"Kim Dong-hyun","tmdb_id":83382,"profile":"https://image.tmdb.org/t/p/w500/jDq3sZAtOczM09AG1NvCrXSsK7s.jpg","tm