14.com/share/0c7a625d5077d3baab054e3c91323a77","link_m3u8":"https://vip.opstream14.com/20220712/18047_8cf557d5/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream14.com/share/be19b5f3f1fab3af9028503f50c864db","link_m3u8":"https://vip.opstream14.com/20220720/18632_f5daeca5/index.m3u8"}]}],"description":"<p>Rốt cuộc thì Sơn Hải Kinh kể về cái gì? Nhà ẩm thực Ăn Không Uổng quay về thời kỳ của Sơn Hải Kinh thám hiểm những ngọn núi vùng biển mà Sơn Hải Kinh nhắc đến, vậy mà phát hiện ra mọi thứ lại thú vị đến vậy! Hoá ra Trung Quốc đã có người cá từ lâu nhưng căn bản không phải là chị gái xinh đẹp. Hoá ra người cổ đại cho người làm thuê ăn \"Thượng Điểu Phó Điểu\" thì người làm thuê sẽ liều mạng làm việc 996, 007. Hoá ra Tây Vương Mẫu là một bà già quái gở chứ không phải là ngự tỷ siêu cấp. Hoá ra khi Đại Vũ trị thủy đã từng đấu trí với con khỉ nước! Câu truyện thú vị nhất của Sơn Hải Kinh ngay trong \"Ăn Không Uổng Kể Sơn Hải Kinh\".</p>","tmdb_id":137910,"cast":[],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"137910","season":1,"vote_average":6,"vote_count":1},"cast_meta":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/an/an-khong-uong-ke-son-hai-kinh.json"}