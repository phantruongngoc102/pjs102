></p>","tmdb_id":122325,"cast":["Trịnh Tắc Sĩ","Lý Nhược Đồng","Nghiêm Ngật Khoan","Geng Le","Tư Cầm Cao Oa","Zhu Yan","Trịnh Quốc Lâm"],"director":["Phan Văn Kiệt"],"keywords":[],"tmdb":{"type":"tv","id":"122325","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trịnh Tắc Sĩ","name_vi":"Trịnh Tắc Sĩ","name_original":"Kent Cheng Jak-Si","tmdb_id":65966,"profile":"https://image.tmdb.org/t/p/w500/a1ebM3aLwYkPckPzc9FgfW2xTsZ.jpg","tmdb_url":"https://www.themoviedb.org/person/65966"},{"name":"Lý Nhược Đồng","name_vi":"Lý Nhược Đồng","name_original":"Carman Lee Yeuk-Tung","tmdb_id":110845,"profile":"https://image.tmdb.org/t/p/w500/pWPP7WKLLpXmPmcaZv51afrHnmt.jpg","tmdb_url":"https://www.themoviedb.org/person/110845"},{"name":"Nghiêm Ngật Khoan","name_vi":"Nghiêm Ngật Khoan","name_original":"Kevin Yan","tmdb_id":1407599,"profile":"https://image.tmdb.org/t/p/w500/oCUiTeAnwmjc0tof4SFziOExIK7.jpg","tmdb_url":"https://www.themoviedb.org/person/1407599"},{"name":"Geng Le","name_vi":null,"name_original":"Geng Le","tmdb_id":1170661,"profile":"https://image.tmdb.org/t/p/w500/tyqtorVkTRu1ZFQsnEccwMZEf4Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1170661"},{"name":"Tư Cầm Cao Oa","name_vi":"Tư Cầm Cao Oa","name_original":"Siqin Gaowa","tmdb_id":1118783,"profile":"https://image.tmdb.org/t/p/w500/j5qdKqbAtzMq2m6VQAgDsc0d7yo.jpg","tmdb_url":"https://www.themoviedb.org/person/1118783"},{"name":"Zhu Yan","name_vi":null,"name_original":"Zhu Yan","tmdb_id":3054854,"profile":"https://image.tmdb.org/t/p/w500/px011ED9qg9BwxW2TgYlbYZ6Sw7.jpg","tmdb_url":"https://www.themoviedb.org/person/3054854"},{"name":"Trịnh Quốc Lâm","name_vi":"Trịnh Quốc Lâm","name_original":"Zheng Guolin","tmdb_id":2040519,"profile":"https://image.tmdb.org/t/p/w500/fjaNpIJroswA84lyJ4lGH0xIiUO.jpg","tmdb_url":"https://www.themoviedb.org/person/2040519"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/an/an-mang-bi-an.json"}