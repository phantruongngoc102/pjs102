rt.com/share/45b4f8abe6c172cab391e43e1e0e6611","link_m3u8":"https://vip.opstream-short.com/20251105/9973_45b4f8ab/index.m3u8"},{"name":"73","slug":"73","link_embed":"https://vip.opstream-short.com/share/fced4f35799409dd854ebeaea7db546d","link_m3u8":"https://vip.opstream-short.com/20251105/9974_fced4f35/index.m3u8"},{"name":"74","slug":"74","link_embed":"https://vip.opstream-short.com/share/0197fcd95060131d9bc5e564f842ed53","link_m3u8":"https://vip.opstream-short.com/20251105/9975_0197fcd9/index.m3u8"}]}],"description":"<p>Ôn Nhuyễn là một họa sĩ minh họa có tính cách hướng nội. Tác phẩm của cô thu hút sự chú ý của Lục Thời Dự, tổng biên tập của một nhà xuất bản nổi tiếng. Lục Thời Dự rất ngưỡng mộ tài năng của Ôn Nhuyễn và thường thảo luận về ý tưởng sáng tạo với cô. Qua những lần tiếp xúc, Ôn Nhuyễn bị thu hút bởi sự dịu dàng và quan tâm của Lục Thời Dự. Cô âm thầm giấu kín tình cảm dành cho anh, và cuối cùng cả hai đều yêu nhau, bắt đầu một chuyện tình ngọt ngào.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/an/an-trom-nu-hon-tu-mat-trang-short-drama.json"}