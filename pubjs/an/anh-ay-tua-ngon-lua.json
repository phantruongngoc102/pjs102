a429bebe6","link_m3u8":"https://vip.opstream11.com/20241006/54259_cc83c174/index.m3u8"}]}],"description":"Hướng Đình Đông, người thừa kế của gia tộc y dược nổi tiếng họ Hướng tại Đường Thành đã bị thương và hôn mê trong khi tranh chấp với vị hôn thê Trình Triệt. Để cứu nhà họ Hướng, Trình Triệt tìm Diệp Nhiên, người em trai bí ẩn bị thất lạc của Hướng Đình Đông về, nhờ anh ta giả mạo Hướng Đình Đông để giúp cô vượt qua khó khăn. Cả hai hợp tác lật tẩy băng nhóm buôn thuốc phiện mà Hướng Đình Đông câu kết, và cuối cùng tiêu diệt được chúng.","tmdb_id":270503,"cast":["Phàn Trị Hân","Dương Vũ Hi","Elaine Yi","Wang Junhao"],"director":["Du Hao"],"keywords":[],"tmdb":{"type":"tv","id":"270503","season":1,"vote_average":9,"vote_count":5},"cast_meta":[{"name":"Phàn Trị Hân","name_vi":"Phàn Trị Hân","name_original":"Fan Zhixin","tmdb_id":2533329,"profile":"https://image.tmdb.org/t/p/w500/1TowSJzOOeKvWzpWpPO6RzI3cf0.jpg","tmdb_url":"https://www.themoviedb.org/person/2533329"},{"name":"Dương Vũ Hi","name_vi":"Dương Vũ Hi","name_original":"Yang Yuxi","tmdb_id":4151775,"profile":"https://image.tmdb.org/t/p/w500/iRDk9r8Vlyx8jux1TwJrIFX045i.jpg","tmdb_url":"https://www.themoviedb.org/person/4151775"},{"name":"Elaine Yi","name_vi":null,"name_original":"Elaine Yi","tmdb_id":2958048,"profile":"https://image.tmdb.org/t/p/w500/9kSsWm4DWHyEC63zul9wbbNhDyu.jpg","tmdb_url":"https://www.themoviedb.org/person/2958048"},{"name":"Wang Junhao","name_vi":null,"name_original":"Wang Junhao","tmdb_id":3688186,"profile":"https://image.tmdb.org/t/p/w500/w6Ejo8z1izHTpdCurqrdjeI0NlI.jpg","tmdb_url":"https://www.themoviedb.org/person/3688186"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/an/anh-ay-tua-ngon-lua.json"}