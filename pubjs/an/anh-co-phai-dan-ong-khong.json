121/37860_86d6a08a/index.m3u8"}]}],"description":"<p><i>Anh có phải đàn ông không? </i>là phim tâm lý xã hội của đạo diễn Trịnh Lê Phong, phát sóng trên kênh VTV3 từ tối 13/1/2022 khi <i>Mặt nạ gương</i> vừa kết thúc. Phim của Trịnh Lê Phong hứa hẹn đem tới sự mới lạ khi hoán đổi vị trí của người chồng – người vợ trong gia đình. Nếu như nhiều bộ phim khán giả bắt gặp hình ảnh người phụ nữ cam chịu, hy sinh bản thân lo toan vẹn toàn cho gia đình thì với <i>Anh có phải đàn ông không? </i>hoàn toàn ngược lại.</p>","tmdb_id":158658,"cast":["Nhan Phúc Vinh","Tuấn Tú","Hà Việt Dũng","Bùi Bài Bình","Mạnh Cường","Thanh Hương","Nguyễn Quỳnh","Đan Lê","Việt Hoa","Kiều Minh Hiếu","Jenna Anh Phương","Vũ Phong","Huyền Trang Mù Tạt","Tô Dũng","Vĩnh Xương"],"director":["Trịnh Lê Phong"],"keywords":[],"tmdb":{"type":"tv","id":"158658","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Nhan Phúc Vinh","name_vi":"Nhan Phúc Vinh","name_original":"Nhan Phúc Vinh","tmdb_id":2041122,"profile":"https://image.tmdb.org/t/p/w500/wmjgsVDOIPGX0EyWOrHkujL4Nhu.jpg","tmdb_url":"https://www.themoviedb.org/person/2041122"},{"name":"Tuấn Tú","name_vi":"Tuấn Tú","name_original":"Tuấn Tú","tmdb_id":3992348,"profile":"https://image.tmdb.org/t/p/w500/aMY4eOZy37qxZKvcfVShL7zQKm9.jpg","tmdb_url":"https://www.themoviedb.org/person/3992348"},{"name":"Hà Việt Dũng","name_vi":"Hà Việt Dũng","name_original":"Hà Việt Dũng","tmdb_id":1951241,"profile":"https://image.tmdb.org/t/p/w500/krN6ls7kIKSvKKQFfRLy2F1NoL3.jpg","tmdb_url":"https://www.themoviedb.org/person/1951241"},{"name":"Bùi Bài Bình","name_vi":"Bùi Bài Bình","name_original":"Bùi Bài Bình","tmdb_id":1597793,"profile":"https://image.tmdb.org/t/p/w500/vTnTV0hKvBe8N8KGMRd7c2RjAnw.jpg","tmdb_url":"https://www.themoviedb.org/person/1597793"},{"name":"Mạnh Cường","name_vi":"Mạnh Cường","name_original":"Mạnh Cường","tmdb_id":4122803,"profile":"https://image.tmdb.org/t/p/w500/29gOl2FLxehlLaY5T725y2i9heQ.jpg","tmdb_url":"https://www.themoviedb.org