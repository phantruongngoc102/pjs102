39","link_embed":"https://vip.opstream15.com/share/fe184ec3276a986afa6e10163a63a942","link_m3u8":"https://vip.opstream15.com/20220519/15322_39fee29b/index.m3u8"},{"name":"40","slug":"40","filename":"anh-co-thich-nuoc-my-khong-so-young-tap-40","link_embed":"https://vip.opstream15.com/share/cc6b49da231b443f29dba004aabfa807","link_m3u8":"https://vip.opstream15.com/20220519/15324_cb0cb428/index.m3u8"}]}],"time":"","description":"<p>Phim Anh Có Thích Nước Mỹ Không (2016): Là phim chuyển thể từ tác phẩm Anh Có Thích Nước Mỹ Không của nhà văn Tân Di Ổ, được xuất bản tại Việt Nam với tên “Anh Có Thích Nước Mỹ Không”. Phim xoay quanh mối tình tay ba kéo dài từ thời đại học cho đến khi trưởng thành và đi làm của Trịnh Vy – Lâm Tĩnh – Trần Hiếu Chính. Trịnh Vy ban đầu yêu Lâm Tĩnh nhưng do anh đột ngột biến mất nên đã chuyển sang theo đuổi Trần Hiếu Chính. Vốn là người tham vọng, nhiều hoài bão, vì muốn đạt được mục đích giàu sang, Trần Hiếu Chính đã bỏ lại Trịnh Vy để sang Mỹ định cư. Nhiều năm sau, khi Lâm Tĩnh và Trịnh Vy đã trở thành một cặp thì Trần Hiếu Chính đột ngột trở về. Sự oán hận, xót thương, day dứt giữa 3 người đã tạo nên một mối tình ngang trái, đầy bi kịch</p>","tmdb":{"type":"tv","id":"89615","season":1,"vote_average":5,"vote_count":2},"modified":"2022-05-20T07:37:16.000Z","cast":["Trương Đan Phong","Dương Lặc","Trần Dao","Ma Khả","Thái Văn Tịnh","Cao Lei","Dong Chunhui","Vương Tử Tuyền","Chen Jiayi","Mễ Lộ"],"director":["Dương Văn Quân"],"cast_meta":[{"name":"Trương Đan Phong","name_vi":"Trương Đan Phong","name_original":"Zhang Danfeng","tmdb_id":2080701,"profile":"https://image.tmdb.org/t/p/w500/mkdAKLWQobvc37DNLbXCwfT0jXi.jpg","tmdb_url":"https://www.themoviedb.org/person/2080701"},{"name":"Dương Lặc","name_vi":"Dương Lặc","name_original":"Yang Le","tmdb_id":2018045,"profile":"https://image.tmdb.org/t/p/w500/6yvhf8DffccXncVffVveNKTDScz.jpg","tmdb_url":"https://www.themoviedb.org/person/2018045"},{"name":"Trần Dao","name_vi":"Trần Dao","name_original":"Chen Yao","tmdb_id":1865921,"profile":"https://image.tmdb.org/t/p/w500/9sqEtFKYtPZ5InwqmfX6qVOYNKV.jpg","tmdb_url":"https://www.themoviedb.org/person/1865921"},{"name":"Ma Khả","name_vi":"Ma Khả","name_original":"Ma Ke","tmdb_id":1782299,"profile":"https://image.tmdb.org/t/p/w500/s3AUOMmN960IlVfgaAw0m53jNQA.jpg","tmdb_url":"https://www.themoviedb.org/person/1782299"},{"name":"Thái Văn Tịnh","name_vi":"Thái Văn Tịnh","name_original":"Cai Wenjing","tmdb_id":1680738,"profile":"https://image.tmdb.org/t/p/w500/gyeNAy8ktBNlNqXhzy2R6AQ6Y5l.jpg","tmdb_url":"https://www.themoviedb.org/person/1680738"},{"name":"Cao Lei","name_vi":null,"name_original":"Cao Lei","tmdb_id":1177817,"profile":"https://image.tmdb.org/t/p/w500/yCaH7zpAGhg5qkPm4BzxOCfmOMk.jpg","tmdb_url":"https://www.themoviedb.org/person/1177817"},{"name":"Dong Chunhui","name_vi":null,"name_original":"Dong Chunhui","tmdb_id":3164388,"profile":"https://image.tmdb.org/t/p/w500/oefc8GfsgrKBfB52QsOfuyDDdaf.jpg","tmdb_url":"https://www.themoviedb.org/person/3164388"},{"name":"Vương Tử Tuyền","name_vi":"Vương Tử Tuyền","name_original":"Wang Zixuan","tmdb_id":1519029,"profile":"https://image.tmdb.org/t/p/w500/4W6rNpWdUvlR690BaazYKNjifa.jpg","tmdb_url":"https://www.themoviedb.org/person/1519029"},{"name":"Chen Jiayi","name_vi":null,"name_original":"Chen Jiayi","tmdb_id":3483244,"profile":"https://image.tmdb.org/t/p/w500/yMwVJrfHm5ppwNDcTkAnu3dUNk3.jpg","tmdb_url":"https://www.themoviedb.org/person/3483244"},{"name":"Mễ Lộ","name_vi":"Mễ Lộ","name_original":"Mi Lu","tmdb_id":1502598,"profile":"https://image.tmdb.org/t/p/w500/1poySBVmWclsxZFA1hbPfO4rBAf.jpg","tmdb_url":"https://www.themoviedb.org/person/1502598"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/an/anh-co-thich-nuoc-my-khong.json"}