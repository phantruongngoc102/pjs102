p 24","link_embed":"https://vip.opstream90.com/share/0197fcd95060131d9bc5e564f842ed53","link_m3u8":"https://vip.opstream90.com/20250802/9975_0197fcd9/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Lâm Anh Đào là một cô gái có tính cách tươi sáng, hồn nhiên, lớn lên trong tình yêu thương vô bờ bến của gia đình và nhóm bạn thời niên thiếu. Tuổi thơ giản dị và hạnh phúc đó bắt đầu rẽ sang hướng khác khi thần đồng Toán học Tưởng Kiều Tây chuyển đến học cùng trường với cô. Ngay lần đầu gặp gỡ, vẻ lạnh lùng, cô độc của Kiều Tây đã thu hút sự chú ý của Anh Đào và từ đó, cuộc sống của họ cũng dần dà có sự gắn kết ngày một sâu đậm. Không chỉ xoay quanh mối quan hệ giữa Anh Đào và Kiều Tây, Anh Đào Hổ Phách còn là câu chuyện của nhiều bạn trẻ thế hệ 9x giữa những biến chuyển của thời đại.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"261128","season":1,"vote_average":8.536,"vote_count":14},"modified":"2025-08-02T16:47:46.000Z","cast":["Triệu Kim Mạch","Trương Lăng Hách","Đổng Khiết","Bao Jianfeng","Shen Jiayu","Wu Sheng","Ma Qiyue","Zuo Linjie","Hu Jiaxin"],"director":["张开宙"],"cast_meta":[{"name":"Triệu Kim Mạch","name_vi":"Triệu Kim Mạch","name_original":"Zhao Jinmai","tmdb_id":2113005,"profile":"https://image.tmdb.org/t/p/w500/hndhOhSK0GAMi1qQaacacl3aHzO.jpg","tmdb_url":"https://www.themoviedb.org/person/2113005"},{"name":"Trương Lăng Hách","name_vi":"Trương Lăng Hách","name_original":"Zhang Linghe","tmdb_id":3091887,"profile":"https://image.tmdb.org/t/p/w500/qJtnyHBnv7t7sNCei2By1CJ9hwL.jpg","tmdb_url":"https://www.themoviedb.org/person/3091887"},{"name":"Đổng Khiết","name_vi":"Đổng Khiết","name_original":"Dong Jie","tmdb_id":12676,"profile":"https://image.tmdb.org/t/p/w500/12X5p7oHzvA598NHLU8EvYsG9oh.jpg","tmdb_url":"https://www.themoviedb.org/person/12676"},{"name":"Bao Jianfeng","name_vi":null,"name_original":"Bao Jianfeng","tmdb_id":1174467,"profile":"https://image.tmdb.org/t/p/w500/uxcM72kcp4YUTic8sQz8vBSceR9.jpg","tmdb_url":"https://www.themoviedb.org/person/117