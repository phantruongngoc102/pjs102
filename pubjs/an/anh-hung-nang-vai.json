://vip.opstream11.com/20241126/58359_c469c3c2/index.m3u8"},{"name":"14","slug":"14","filename":"Anh.Hung.Nang.Vai.1996_14.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/efa29530895864c725b54695c124b906","link_m3u8":"https://vip.opstream11.com/20241126/58360_efa29530/index.m3u8"},{"name":"15","slug":"15","filename":"Anh.Hung.Nang.Vai.1996_15.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/df54e10c70fe8bf1cc9c698343fe1f14","link_m3u8":"https://vip.opstream11.com/20241126/58362_df54e10c/index.m3u8"},{"name":"16","slug":"16","filename":"Anh.Hung.Nang.Vai.1996_16.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/0f7c96124cf0e35f4428172052e91f6e","link_m3u8":"https://vip.opstream11.com/20241126/58363_0f7c9612/index.m3u8"},{"name":"17","slug":"17","filename":"Anh.Hung.Nang.Vai.1996_17.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/d4b392dfa44a0fc6f6813643066d80ad","link_m3u8":"https://vip.opstream11.com/20241126/58364_d4b392df/index.m3u8"},{"name":"18","slug":"18","filename":"Anh.Hung.Nang.Vai.1996_18.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/bb9c76532d0a28c768c3a92b3a8457ad","link_m3u8":"https://vip.opstream11.com/20241126/58365_bb9c7653/index.m3u8"},{"name":"19","slug":"19","filename":"Anh.Hung.Nang.Vai.1996_19.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/701aecbd2b7077f1aa98e72a549a2533","link_m3u8":"https://vip.opstream11.com/20241126/58366_701aecbd/index.m3u8"},{"name":"20","slug":"20","filename":"Anh.Hung.Nang.Vai.1996_20End.720p.H264_FFVN.USLT","link_embed":"https://vip.opstream11.com/share/4bb89282dc832a80f9a39e32d817b19e","link_m3u8":"https://vip.opstream11.com/20241126/58367_4bb89282/index.m3u8"}]}],"time":"47 phút/tập","description":"<p><strong>Trong ngày tỉ thí để tiếp nhận chức chưởng môn của Tam Tuyệt Trang. Mộ Dung Bạch bị kẻ gian ám hại, tẩm độc vào mũi thương, khiến Đại Sư Huynh mất một tay. Kẻ gian đó là Quân Tử Kiếm Hạ Hầu Đôn, tam sư đệ của Tam Tuyệt Trang. Hạ Hầu Đôn giết sự phụ, đổ tội cho Mộ Dung Bạch, bị đuổi đến đường cùng Mộ Dung Bạch buộc phải bỏ đứa con vừa đầy tháng xuống sông trôi theo dòng nước, nhảy xuống vực thẳm. Hạ Hầu Đôn trở thành trưởng môn.</strong><br><br><strong>Lâm đại thẩm giặt đồ bên bờ sông trông thấy đứa bé dễ thương nằm trong chiếc bồn, mang về nuôi, đặt tên là Tiểu Bồn, bà lấy miếng ngọc đứa bé đeo bên mình đeo cho đứa con trai của mình tên là Tiểu Điệp.Thời gian trôi qua, Tiểu Bồn trở thành 1 thanh niên nhiều mưu mẹo còn Tiểu Điệp thật thà chất phác, sức khỏe hơn người. Vì muốn theo đuổi Nặc Phụng, Tiểu Bồn lên Tam Tuyệt Trang bái cha của Nặc Phụng học võ công. Trong lúc này Hạ Hầu Đôn cùng 6 đại môn phái quyết tâm tiêu diệt Ác Nhân Cốc, không ngờ 20 mấy năm sau Cốc chủ Ác Nhân Cốc chính là Mộ Dung Bạch.</strong><br><br><strong>Mộ Dung Bạch gặp nạn bị thương vô tình được Tiểu Điệp hết lòng chăm sóc. Mộ Dung Bạch cảm kích, truyền võ công lại cho Tiểu Điệp. Vì chuyện này Tiểu Điệp bị người của Tam Tuyệt Trang truy đuổi, chạy vào Ác Nhân Cốc. Tại đây Tiểu Điệp mới biết thực ra những người của Ác Nhân Cốc là người tốt, sau lưng họ đều có những quá khứ bất hạnh. Đệ Nhất Dâm Phụ Long Thiên Kiều của Ác Nhân Cốc cũng thầm để ý Tiểu Điệp.</strong><br><br><strong>Hạ Hầu Đôn vì muốn tìm ra Ác Nhân Cốc sắp đặt Tiểu Bồn &amp; Nặc Phụng trở thành phản đồ, trà trộn vào Ác Nhân Cốc, cùng 6 đại môn phái đồng loạt tập kích. Khi Tiểu Bồn &amp; Nặc Phụng biết được sự thật thì đã muộn</strong></p>","tmdb":{"type":"tv","id":"109251","season":1,"vote_average":8,"vote_count":1},"modified":"2024-12-14T10:23:29.000Z","cast":["Gigi Fu Ming-Hin","Cổ Cự Cơ","Phàn Thiếu Hoàng","Trương Tuệ Nghi","Kenneth Chan","Ho Ying-Wai","Lau Kar-Wing","Mimi Chu Mai-Mai","Ling Hon","Vincent Cheung","Ho Bik-Kin","Bao Fang","La Mãng","Tăng Huệ Vân","Lau Gwai-Fong"],"director":["Dương Cẩm Tuyền"],"cast_meta":[{"name":"Gigi Fu Ming-Hin","name_vi":null,"name_original":"Gigi Fu Ming-Hin","tmdb_id":1135386,"pr