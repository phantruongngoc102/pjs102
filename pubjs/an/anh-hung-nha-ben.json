eam10.com/share/46c7cb50b373877fb2f8d5c4517bb969","link_m3u8":"https://vip.opstream10.com/20220416/7941_53f0e70e/index.m3u8"},{"name":"15","slug":"15","filename":"anh-hung-nha-ben-neighborhood-hero-tap-15","link_embed":"https://vip.opstream10.com/share/0f541eccc4dc49cc19da7ca4594fad27","link_m3u8":"https://vip.opstream10.com/20220416/7942_7ca16791/index.m3u8"},{"name":"16","slug":"16","filename":"anh-hung-nha-ben-neighborhood-hero-tap-16","link_embed":"https://vip.opstream14.com/share/28498620653e59a7e22c2b50748e2766","link_m3u8":"https://vip.opstream14.com/20220416/8153_31cd919c/index.m3u8"}]}],"time":"70 phút / tập","description":"<p>Phim Anh Hùng Nhà Bên - Neighborhood Hero 2016 nói về Baek Shi-Yoon (Park Si-Hoo) là một cựu đặc vụ bí mật. Anh ấy được đào tạo chuyên sâu về vũ khí hủy diệt con người. Che dấu quá khứ của mình, anh ta đã mua lại và quản lí quán bar có tên \"Hàng xóm\". Anh ấy trở nên thân thiết với những hàng xóm hay lui tới quán và đồng cảm với những nỗi đau của họ. Baek Shi-Yoon đã gặp một chàng nhân viên thời vụ trẻ tuổi. Chàng trai trẻ ước mơ làm cảnh sát. Baek Shi-Yoon đã huấn luyện cậu thanh niên với tư cách là một đặc vụ bí mật và hai người cùng nhau chiến đấu chống lại cái ác.</p>","tmdb":{"type":"tv","id":"64801","season":1,"vote_average":6.3,"vote_count":10},"modified":"2023-06-19T18:24:19.000Z","cast":["Park Si-hoo","Cho Seong-ha","Lee Soo-hyuk","Kwon Yu-ri","Yoon Tae-young","Jeong Man-sik","Song Jae-ho","Lee Han-wi","Ahn Suk-hwan","Kang Nam-gil","Jin Kyung","Kim Bo-mi","Ji Il-ju","Choi Byung-mo"],"director":["Kwak Jung Hwan"],"cast_meta":[{"name":"Park Si-hoo","name_vi":null,"name_original":"Park Si-hoo","tmdb_id":1112233,"profile":"https://image.tmdb.org/t/p/w500/i8vj9h5XVMag4TJ7zE0rmRSbrbv.jpg","tmdb_url":"https://www.themoviedb.org/person/1112233"},{"name":"Cho Seong-ha","name_vi":null,"name_original":"Cho Seong-ha","tmdb_id":551171,"profile":"https://image.tmdb.org/t/p/w500/rVJRXGHjDSWkC58SgBYfMbeAm1t.jpg","tmdb_url":"https://www.them