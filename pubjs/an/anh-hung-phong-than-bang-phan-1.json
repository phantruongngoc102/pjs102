k_embed":"https://vip.opstream17.com/share/dfa92d8f817e5b08fcaafb50d03763cf","link_m3u8":"https://vip.opstream17.com/20240228/1568_bbd32d07/index.m3u8"}]}],"description":"<p>Câu truyện cũ, nhưng với sự diễn xuất , cảnh quay hoành tráng hơn , bộ phim do đài loan sản xuất , với sự tham gia của nhiều diễn viên&nbsp;Trần Kiện Phong, Khương Hồng, Trương Hinh Dư, Trương Địch, Mạch Địch Na, Trịnh Diệc Đồng, Trịnh Bằng Phi, Ngô Đại Dung, Vương Tịnh Luyến, Kim Đạc. Câu chuyện nói về khương tử nhà, đã tu đạo thành tiên , tính toán như thần , và đát kỷ 1 người đẹp&nbsp;&nbsp;như tiến giáng trần bị hồ ly chín đuôi nhập hồn, con hồ ly này đã quyến rũ trụ vương, làm bao nhiêu chuyện ác, dan tình khốn khổ lầm than. Bộ phim tân bảng phong thàn này đam bảo sẽ không thua gì bản cũ.</p>","tmdb_id":68680,"cast":["Trần Kiện Phong","Zhang Di","Li Yixiao","Zheng Yitong","Madina Memet","Zhang Mingming","Andrew Wu","He Yanni","Zhang Zhuowen"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"68680","season":1,"vote_average":4.6,"vote_count":5},"cast_meta":[{"name":"Trần Kiện Phong","name_vi":"Trần Kiện Phong","name_original":"Sammul Chan","tmdb_id":1222624,"profile":"https://image.tmdb.org/t/p/w500/emuTVeFoAewmALU0EVzpDxk3dEn.jpg","tmdb_url":"https://www.themoviedb.org/person/1222624"},{"name":"Zhang Di","name_vi":null,"name_original":"Zhang Di","tmdb_id":2631743,"profile":"https://image.tmdb.org/t/p/w500/k8BueDWYsPWTrsiCmSuSKdAGD35.jpg","tmdb_url":"https://www.themoviedb.org/person/2631743"},{"name":"Li Yixiao","name_vi":null,"name_original":"Li Yixiao","tmdb_id":2180945,"profile":"https://image.tmdb.org/t/p/w500/ejGSpJfRXghXjcyhARz8EJbE2Sy.jpg","tmdb_url":"https://www.themoviedb.org/person/2180945"},{"name":"Zheng Yitong","name_vi":null,"name_original":"Zheng Yitong","tmdb_id":1175569,"profile":"https://image.tmdb.org/t/p/w500/yXzSPjXz6mn6FJTh4RCBvSPctmT.jpg","tmdb_url":"https://www.themoviedb.org/person/1175569"},{"name":"Madina Memet","name_vi":null,"name_original":"Madina Memet","t