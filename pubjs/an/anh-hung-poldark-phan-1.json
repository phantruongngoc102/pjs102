om/share/1e78e7323c18caa97a193cb00302ed8b","link_m3u8":"https://vip.opstream10.com/20220612/20174_09f3f968/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/b05edd78c294dcf6d960190bf5bde635","link_m3u8":"https://vip.opstream10.com/20220612/20175_5f9aa666/index.m3u8"}]}],"description":"<p>Được chuyển thể từ bộ tiểu thuyết cùng tên của nhà văn Winston Graham, Poldark lấy bối cảnh miền nam nước Anh vào thế kỷ 18. Để thoát khỏi giá treo cổ, Ross Poldark đã gia nhập quân đội Hoàng Gia Anh để chiến đấu trong Cách mạng Mỹ. Trở về quê hương Cornwall sau ba năm trời, anh hay tin cha anh đã qua đời, gia tài nhà anh kiệt quệ, còn người tình cũ là Elizabeth đã được gả cho người em họ Francis. Anh giải cứu một cô gái trẻ tên là Demelza khỏi một trận đòn và nhận cô vào làm chân phụ bếp. Cùng lúc đó, anh cũng ra tay giúp đỡ người dân trong làng và tìm cách bảo vệ những quặng mỏ đang bị đối thủ của anh, tên George Warleggan tham lam và ngạo mạn, lăm le chiếm lấy.</p>","tmdb_id":62084,"cast":["Aidan Turner","Eleanor Tomlinson","Jack Farthing","Luke Norris","Beatie Edney","Pip Torrens","Gabriella Wilde","Tom York","Harry Richardson","Tristan Sturrock","Sofia Oxenham","Kerri McLean","Vincent Regan","Woody Norman","Ellise Chappell"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"62084","season":1,"vote_average":7.759,"vote_count":309},"cast_meta":[{"name":"Aidan Turner","name_vi":null,"name_original":"Aidan Turner","tmdb_id":207558,"profile":"https://image.tmdb.org/t/p/w500/owWJR9RCq7FcOw9R9yX70TKNsvQ.jpg","tmdb_url":"https://www.themoviedb.org/person/207558"},{"name":"Eleanor Tomlinson","name_vi":null,"name_original":"Eleanor Tomlinson","tmdb_id":73357,"profile":"https://image.tmdb.org/t/p/w500/A2lE5kvZE3tIpKwpAtKbjsMHpf2.jpg","tmdb_url":"https://www.themoviedb.org/person/73357"},{"name":"Jack Farthing","name_vi":null,"name_original":"Jack Farthing","tmdb_id":1287084,"profile":"https://image.tmdb.org/t/p/w500/xhriXePjVXTJcF2linudLgMnsKA.jpg","tm