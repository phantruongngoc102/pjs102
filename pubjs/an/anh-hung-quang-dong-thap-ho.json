3u8"},{"name":"40","slug":"40","filename":"Anh Hung Quang Dong Thap Ho 1999-40 END","link_embed":"https://vip.opstream11.com/share/878646f069e671e4acc080af3fb1367a","link_m3u8":"https://vip.opstream11.com/20240927/53691_878646f0/index.m3u8"}]}],"time":"45 phút/tập","description":"Phim Anh Hùng Quảng Đông Thập Hổ phim kể về vào cuối đời Mãn Thanh, chính phủ hủ bại, Trung Quốc bị các cường quốc tranh giành xâu xé. Dưới cảnh nội ưu ngoại hoạn, dân chúng lầm than khổ sở. Thời thế tạo anh hùng, xuất hiện mười vị đại trượng phu trọng tình trọng nghĩa, trung can nghĩa đảm, vì quốc gia, họ chấp nhận hy sinh tất cả. Họ đã thêu dệt nên một sự tích anh hùng, trở thành câu chuyện Quảng Đông Thập Hổ được lưu truyền sau này.","tmdb":{"type":"tv","id":"101670","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-21T11:16:03.000Z","cast":["Cao Hùng","Âu Cẩm Đường","Michael Huang","Trần Vỹ","Ngô Đình Diệp","Viên Văn Kiệt","Văn Tụng Nhàn","Đỗ Vấn Trạch","Lo Lieh","Vu Vinh Quang"],"director":["Tăng Cẩm Xương"],"cast_meta":[{"name":"Cao Hùng","name_vi":"Cao Hùng","name_original":"Eddy Ko Hung","tmdb_id":612216,"profile":"https://image.tmdb.org/t/p/w500/1Zsn0zSmo5AS5p527XDaZvD0i3y.jpg","tmdb_url":"https://www.themoviedb.org/person/612216"},{"name":"Âu Cẩm Đường","name_vi":"Âu Cẩm Đường","name_original":"Stephen Au Kam-Tong","tmdb_id":987587,"profile":"https://image.tmdb.org/t/p/w500/jSONQ4UlIaC0nD9EDXfJvU8Njs0.jpg","tmdb_url":"https://www.themoviedb.org/person/987587"},{"name":"Michael Huang","name_vi":null,"name_original":"Michael Huang","tmdb_id":1447086,"profile":"https://image.tmdb.org/t/p/w500/gW3EpdR2ebmSQH8fL4lShBV90Ol.jpg","tmdb_url":"https://www.themoviedb.org/person/1447086"},{"name":"Trần Vỹ","name_vi":"Trần Vỹ","name_original":"Alice Chan Wai","tmdb_id":1021936,"profile":"https://image.tmdb.org/t/p/w500/wxRBCvpATXZ5y4ejR7JrSChmS3N.jpg","tmdb_url":"https://www.themoviedb.org/person/1021936"},{"name":"Ngô Đình Diệp","name_vi":"Ngô Đình Diệp","name_original":"Berg Ng