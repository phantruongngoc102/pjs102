p.opstream15.com/20220304/538_d0307165/index.m3u8"},{"name":"6","slug":"6","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-6","link_embed":"https://vip.opstream15.com/share/5737034557ef5b8c02c0e46513b98f90","link_m3u8":"https://vip.opstream15.com/20220304/539_2df1c733/index.m3u8"},{"name":"7","slug":"7","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-7","link_embed":"https://vip.opstream15.com/share/9b72e31dac81715466cd580a448cf823","link_m3u8":"https://vip.opstream15.com/20220304/540_a8748e8b/index.m3u8"},{"name":"8","slug":"8","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-8","link_embed":"https://vip.opstream15.com/share/16c222aa19898e5058938167c8ab6c57","link_m3u8":"https://vip.opstream15.com/20220304/541_4e85e189/index.m3u8"},{"name":"9","slug":"9","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-9","link_embed":"https://vip.opstream15.com/share/7dcd340d84f762eba80aa538b0c527f7","link_m3u8":"https://vip.opstream15.com/20220304/542_376564a9/index.m3u8"},{"name":"10","slug":"10","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-10","link_embed":"https://vip.opstream15.com/share/81448138f5f163ccdba4acc69819f280","link_m3u8":"https://vip.opstream15.com/20220304/543_9d500b57/index.m3u8"},{"name":"11","slug":"11","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-11","link_embed":"https://vip.opstream15.com/share/97e8527feaf77a97fc38f34216141515","link_m3u8":"https://vip.opstream15.com/20220304/544_7ec4ebf0/index.m3u8"},{"name":"12","slug":"12","filename":"anh-la-hiep-si-bong-dem-cua-em-tap-12","link_embed":"https://vip.opstream15.com/share/647bba344396e7c8170902bcf2e15551","link_m3u8":"https://vip.opstream15.com/20220304/545_100d8c9d/index.m3u8"}]}],"time":"1H8M35S","description":"<p>Bộ phim Hàn Quốc “Em Sẽ Trở Thành Ban Đêm Của Anh” kể về câu chuyện ngọt ngào lại hồi hộp giữa nữ bác sĩ và năm thành viên ban nhạc. Ngôi sao nổi tiếng thế giới Yoon Tae-in(Lee Jun-young thủ vai) mắc bệnh mộng du, đành phải tìm bác sĩ rởm In Yoon-joo(Jung In-sun thủ vai), mời cô ở vào ký túc xá để bí ẩn điều trị cho mình.\\nNam chính Yoon Tae-in là đội trưởng, ca sĩ chính và nhà sản xuất nhạc của ban nhạc thần tượng nổi tiếng thế giới “Luna”. Nữ chính In Yoon-joo nhờ vào tài ăn nói và sự đồng cảm mình, làm hướng dẫn viên du lịch cho các người già cô độc để nỗ lực thực hiện ước mơ mua nhà. Nhưng cô ngẫu nhiên bị cuốn vào sự kiện bất ngờ, trở thành bác sĩ rởm mạo trong ký túc xá của nhóm thần tượng “Luna”, mạo hiểm sống cùng với năm người đàn ông. Bốn thành viên khác trong ban nhạc là người chơi bass Lee Sin(Kim Jong-hyun thủ vai), Kim Yoon-chan(Yoon Ji-sung thủ vai), người út chơi keyboard Woo Ga-on(Kim Dong-hyun) và người chơi đàn ghi-ta, ca sĩ phụ Seo Woo-yeon(Jang Dong-joo thủ vai). Lee Sin là một chàng trai sốt sắng, đơn thuần, bằng lòng trả tất cả mọi thứ cho tình yêu. Chàng có cuộc đời đầy tình yêu trên mặt, nhưng thực tế chàng phiền não về tình yêu bí mật. Kim Yoon-chan coi như một người đầy dã tâm, nhưng thực ra là một chàng trai cô độc, có nhiều vết thương. Woo Ga-on tính cách kỳ lạ, là một người khó đoán, còn khiến mỗi một người sợ hãi.\\nBộ phim Hàn Quốc “Em Sẽ Trở Thành Ban Đêm Của Anh” được Lee Jun-young(thành viên nhóm U-KISS và UNB, từng xuất diễn “Kẻ Báo Thủ Buam-dong”) và Jung In-sun(từng diễn xuất “Khoa Phụ Sản” và “Han Gong-ju”) cùng thủ vai chính, được đạo diển Anh Ji-sook(“Có Điên Mới Yêu”) và nhà soạn kịch Yoo So-won(“Mưu Cầu Hạnh Phúc”) cùng sáng tác. Bộ phim này sẽ được đài truyền hình SBS Hàn Quốc trình chiếu vào mỗi chủ nhật từ ngày 07/11/2021, được IQIYI quốc tế(iq.com) trình chiếu online.</p>","tmdb":{"type":"tv","id":"134071","season":1,"vote_average":6.7,"vote_count":12},"modified":"2024-12-14T10:20:47.000Z","cast":["Jung In-sun","Lee Jun-young","Jang Dong-ju","JR","Yoon Ji-sung","Kim Dong-hyun","Seo Hye-won","Ahn Ha-young","Kwak Ja-hyung","Lee Se-chang","Park Ji-won","Seo Yi-soo","Jo Eun-seo","Park So-eun"],"director":["Ahn Ji-Sook"],"cast_meta":[{"name":"Jung In-sun","name_vi":null,"name_original":"Jung In-sun","tmdb_id":932764,"profile":"https://image.tmdb.org/t/p/w500/o2l8X5vye308pTMEzTDQ1Gx9CFz.jpg","tmdb_url":"https://www.themoviedb.org/person/932764"},{"name":"Lee Jun-young","name_vi":null,"name_original":"Lee Jun-young","tmdb_id":1904058,"profile":"https://image.tmdb.org/t/p/w500/zH8kiGox6n3FD82MKEhUq79X6gj.jpg","tmdb_url":"https://www.themoviedb.org/person/1904058"},{"name":"Jang Dong-ju","name_vi":null,"name_original":"Jang Dong-ju","tmdb_id":2485939,"profile":"https://image.tmdb.org/t/p/w500/6xk5I21Fqps9hErk48GOMmlUhXt.jpg","tmdb_url":"https://www.themoviedb.org/person/2485939"},{"name":"JR","name_vi":null,"name_original":"JR","tmdb_id":1989529,"profile":"https://image.tmdb.org/t/p/w500/zogW7tirRMu8SXEw3l21dgkEDDg.jpg","tmdb_url":"https://www.themoviedb.org/person/1989529"},{"name":"Yoon Ji-sung","name_vi":null,"name_original":"Yoon Ji-sung","tmdb_id":1901635,"profile":"https://image.tmdb.org/t/p/w500/kF8SXXxgXs33tkeaIjKGISM0ghw.jpg","tmdb_url":"https://www.themoviedb.org/person/1901635"},{"name":"Kim Dong-hyun","name_vi":null,"name_original":"Kim Dong-hyun","tmdb_id":2949423,"profile":"https://image.tmdb.org/t/p/w500/jM6d4Zaz4rfoY7ckswVtJHmO3kw.jpg","tmdb_url":"https://www.themoviedb.org/person/2949423"},{"name":"Seo Hye-won","name_vi":null,"name_original":"Seo Hye-won","tmdb_id":2285866,"profile":"https://image.tmdb.org/t/p/w500/rhAhBIlJQL0ejI7cwIIxyrESE2W.jpg","tmdb_url":"https://www.themoviedb.org/person/2285866"},{"name":"Ahn Ha-young","name_vi":null,"name_original":"Ahn Ha-young","tmdb_id":3031138,"profile":"https://image.tmdb.org/t/p/w500/a4BwdtRS1VjzARuqmCV2JWQUf43.jpg","tmdb_url":"https://www.themoviedb.org/person/3031138"},{"name":"Kwak Ja-hyung","name_vi":null,"name_original":"Kwak Ja-hyung","tmdb_id":1346900,"profile":"https://image.tmdb.org/t/p/w500/yQwDVcqxcOLNyGotJ3T46UzSPy8.jpg","tmdb_url":"https://www.themoviedb.org/person/1346900"},{"name":"Lee Se-chang","name_vi":null,"name_original":"Lee Se-chang","tmdb_id":1627827,"profile":"https://image.tmdb.org/t/p/w500/hM