84_ebf849be/index.m3u8"},{"name":"13","slug":"13","filename":"anh-muon-nghe-em-hat-thuyet-minh-i-wanna-hear-your-song-tap-13","link_embed":"https://vip.opstream10.com/share/486f06aa533267bed3c590b52db3d18d","link_m3u8":"https://vip.opstream10.com/20220509/12685_700b8136/index.m3u8"},{"name":"14","slug":"14","filename":"anh-muon-nghe-em-hat-thuyet-minh-i-wanna-hear-your-song-tap-14","link_embed":"https://vip.opstream10.com/share/ed798eec75807df6e79b0be391f720e4","link_m3u8":"https://vip.opstream10.com/20220509/12687_1260fb9f/index.m3u8"},{"name":"15","slug":"15","filename":"anh-muon-nghe-em-hat-thuyet-minh-i-wanna-hear-your-song-tap-15","link_embed":"https://vip.opstream10.com/share/9fa8671d6d5f2796100bbd67eca81450","link_m3u8":"https://vip.opstream10.com/20220509/12690_c5ecf346/index.m3u8"},{"name":"16","slug":"16","filename":"anh-muon-nghe-em-hat-thuyet-minh-i-wanna-hear-your-song-tap-16","link_embed":"https://vip.opstream10.com/share/d8a3b2dde3181c8257e2e45efbd1e8ae","link_m3u8":"https://vip.opstream10.com/20220509/12692_0e948d20/index.m3u8"}]}],"time":"","description":"<p>Anh Muốn Nghe Em Hát (I Wanna Hear Your Song) xoay quanh một vụ án mạng đã xảy ra. Hong Yi Young, người chơi lục lạc không nhớ bất cứ chuyện gì vào ngày xảy ra vụ án. Cô là người đơn giản và mắc chứng bệnh mất ngủ. Trong lúc tìm việc, cô tình cờ gặp được Jang Yoon. Anh có giọng hát rất tệ nhưng lại là một nghệ sĩ piano trong dàn nhạc. Để giúp chữa trị chứng mất ngủ của Hong Yi Young, Jang Yoon đã gọi cho cô mỗi tối. Họ cố gắng tìm ra sự thật về vụ giết người. Trong khi đó, Nam Joo Wan là nhạc trưởng của dàn nhạc. Anh là người có sức thu hút và thích thể hiện. Ha Eun Joo là một nghệ sĩ violin đầy kiêu ngạo trong dàn nhạc.</p>","tmdb":{"type":"tv","id":"90237","season":1,"vote_average":5,"vote_count":3},"modified":"2022-10-17T19:35:43.000Z","cast":["Yeon Woo-jin","Kim Se-jeong","Song Jae-rim","Park Ji-yeon","Lee Si-won","Yoon Joo-hee","A-TOM","Yoo Gun","Park Chan-hwan","Yoon Bok-in","Hong Seung-he