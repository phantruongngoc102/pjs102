anh-doi-em-o-bac-kinh-wait-in-beijing-tap-45A","link_embed":"https://vip.opstream11.com/share/24fd82394ab5c4074297d17f7847b17a","link_m3u8":"https://vip.opstream11.com/20220617/31029_7ef539f7/index.m3u8"},{"name":"45B","slug":"45b","filename":"anh-doi-em-o-bac-kinh-wait-in-beijing-tap-45B","link_embed":"https://vip.opstream11.com/share/f28dc7008533c025bedbdc88b3640ae9","link_m3u8":"https://vip.opstream11.com/20220617/31030_3b811f0b/index.m3u8"},{"name":"46A","slug":"46a","filename":"anh-doi-em-o-bac-kinh-wait-in-beijing-tap-46A","link_embed":"https://vip.opstream11.com/share/8c711b2a61cccea42c643ce986dc203a","link_m3u8":"https://vip.opstream11.com/20220617/31031_20b6ace0/index.m3u8"},{"name":"46B","slug":"46b","filename":"anh-doi-em-o-bac-kinh-wait-in-beijing-tap-46B","link_embed":"https://vip.opstream11.com/share/1ff4dc549f35ef8cbdcb51f0dc4972a8","link_m3u8":"https://vip.opstream11.com/20220617/31032_a0a39228/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Anh Ở Bắc Kinh Đợi Em kể câu chuyện xoay quanh hai con người với lối sống hoàn toàn khác nhau, những người thường xuyên cãi nhau để rồi thấy rằng họ giống nhau hơn họ nghĩ. Khi sự nghiệp của họ thăng trầm, một chuyện tình lãng mạn xảy ra.Từ Thiên (Lý Dịch Phong) là một đứa trẻ mồ côi người Mỹ gốc Hoa sống ở Brooklyn. Hàng xóm của anh đã trở thành gia đình của anh và từ khi còn nhỏ, anh luôn mơ ước trở thành một luật sư đấu tranh cho quyền lợi của người nghèo. Thịnh Hạ (Giang Sơ Ảnh) là một cô gái trẻ từ Trung Quốc đi du học ở Hoa Kỳ. Cô có đam mê thiết kế thời trang và đầy tâm huyết để thành công.Thịnh Hạ mơ ước mở một cửa hàng của riêng mình dọc Đại lộ thứ năm danh vọng ở Manhattan. Cuộc sống của họ giao nhau vì một tai nạn. Hai người có tham vọng riêng của họ đi ngang qua thành phố New York và mặc dù có sự giáo dục của Trung Quốc và Mỹ, họ trở thành trụ cột hỗ trợ lẫn nhau trong việc vượt qua những thử thách trong cuộc sống.</p>","tmdb":{"type":"tv","id":"99645","season":1,"vote_average":6,"vote_count":2},"modified":"2022-06-17T09:09:12.000Z","cast":["Lý Dịch Phong","Giang Sơ Ảnh","Hồ Vũ Uy","Tưởng Mộng Tiệp","He Dujuan","Leon Lee","Li Chun'er","Valery Gadreau","Cao Thự Quang","Zhou Chuchu"],"director":["Hsu Chao-jen"],"cast_meta":[{"name":"Lý Dịch Phong","name_vi":"Lý Dịch Phong","name_original":"Li Yifeng","tmdb_id":1377674,"profile":"https://image.tmdb.org/t/p/w500/c3ia1FsY5pqcqRQ7EskiWMMbkHc.jpg","tmdb_url":"https://www.themoviedb.org/person/1377674"},{"name":"Giang Sơ Ảnh","name_vi":"Giang Sơ Ảnh","name_original":"Maggie Jiang","tmdb_id":1590275,"profile":"https://image.tmdb.org/t/p/w500/luquCFWpyv8ejXYJuyWCpUPneNe.jpg","tmdb_url":"https://www.themoviedb.org/person/1590275"},{"name":"Hồ Vũ Uy","name_vi":"Hồ Vũ Uy","name_original":"George Hu","tmdb_id":1233857,"profile":"https://image.tmdb.org/t/p/w500/ln9uzk6422vL8jEpWmj987QPmy9.jpg","tmdb_url":"https://www.themoviedb.org/person/1233857"},{"name":"Tưởng Mộng Tiệp","name_vi":"Tưởng Mộng Tiệp","name_original":"Jiang Mengjie","tmdb_id":1716601,"profile":"https://image.tmdb.org/t/p/w500/unzuNWPGgKVT2MyD7FNWreo6uVY.jpg","tmdb_url":"https://www.themoviedb.org/person/1716601"},{"name":"He Dujuan","name_vi":null,"name_original":"He Dujuan","tmdb_id":1089632,"profile":"https://image.tmdb.org/t/p/w500/qZPZkGFcqdMZv2XX0t8vPEUKrgw.jpg","tmdb_url":"https://www.themoviedb.org/person/1089632"},{"name":"Leon Lee","name_vi":null,"name_original":"Leon Lee","tmdb_id":1602554,"profile":"https://image.tmdb.org/t/p/w500/mppExpFo272vUpw2OlbCWuKaPCu.jpg","tmdb_url":"https://www.themoviedb.org/person/1602554"},{"name":"Li Chun'er","name_vi":null,"name_original":"Li Chun'er","tmdb_id":3446419,"profile":"https://image.tmdb.org/t/p/w500/5myqW3j2QDrvVqrfWkPNuXjUot6.jpg","tmdb_url":"https://www.themoviedb.org/person/3446419"},{"name":"Valery Gadreau","name_vi":null,"name_original":"Valery Gadreau","tmdb_id":3848595,"profile":"https://image.tmdb.org/t/p/w500/gFceL8UkS4mdP5YsRh5y0HwDpRH.jpg","tmdb_url":"https://www.themoviedb.org/person/3848