c24a54d/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream-short.com/share/486fbd761bfa5400722324fdc9822adc","link_m3u8":"https://vip.opstream-short.com/20251101/6591_486fbd76/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream-short.com/share/71dd9b48ff8928e726d4d21a5af243f3","link_m3u8":"https://vip.opstream-short.com/20251101/6592_71dd9b48/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream-short.com/share/0765933456f074d2c75bbbad63af95e6","link_m3u8":"https://vip.opstream-short.com/20251101/6593_07659334/index.m3u8"}]}],"description":"Nhà thiết kế Thẩm Tinh Lạc sắp đạt đỉnh cao sự nghiệp nhưng bị Trương Hiểu Lệ có mối quan hệ thay thế ngay trước khi thăng chức. Sếp kiêm bạn trai Mạnh Tuấn Hào lạnh lùng đứng nhìn và thậm chí bí mật cấu kết với Trương Hiểu Lệ. Đau khổ, Thẩm Tinh Lạc rơi vào đáy cuộc đời cho đến khi tái ngộ với tình đầu Chu Dự An trong một con hẻm vào một đêm - nhưng anh xuất hiện với tên &quot;Chu Dự Sâm,&quot; tự xưng là em trai của Chu Dự An. Dù nghi ngờ, Thẩm Tinh Lạc vẫn bị cảm động bởi những lời nói và hành động quen thuộc. Chu Dự Sâm dần làm tan chảy sự cảnh giác của cô bằng sự dịu dàng và sự đồng hành, đứng ra bảo vệ khi Mạnh Tuấn Hào và Trương Hiểu Lệ vu khống cô, thậm chí chịu tổn thương để bảo vệ cô. Tuy nhiên, Thẩm Tinh Lạc không thể buông bỏ tình cảm với Chu Dự An, khiến sự gần gũi của Chu Dự Sâm vừa thú vị vừa đau đớn. Khi cô phát hiện Chu Dự Sâm thực chất là Chu Dự An, cơn giận và thất vọng lại tràn ngập. Chu Dự An đã rời đi nhiều năm trước để điều trị bệnh nặng ở nước ngoài, chọn biến mất thay vì làm gánh nặng cho cô. Anh trở lại với tên &quot;Chu Dự Sâm&quot; để bù đắp những gì đã qua. Khi mối quan hệ của họ đến bế tắc, Mạnh Tuấn Hào bị sa thải đã bắt cóc Thẩm Tinh Lạc để trả thù. Chu Dự An xuất hiện lần nữa để cứu cô và tỏ tình. Hiểu được cuộc đấu tranh của anh, Thẩm Tinh Lạc đã tha thứ. Nhưng hạnh phúc rất ngắn - Chu Dự An lại biến mất vào ngày hôm sau. Tuyệt vọng, cô quay về con hẻm gặp gỡ và thấy anh quỳ gối với chiếc nhẫn, cầu hôn cô. Câu chuyện tình yêu về sự lừa dối và bệnh tật, âm mưu và cứu chuộc cuối cùng tìm thấy kết thúc hoàn hảo dưới ánh đèn con hẻm.","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/an/anh-sao-van-toa-sang-short-drama.json","tmdb_checked":false}