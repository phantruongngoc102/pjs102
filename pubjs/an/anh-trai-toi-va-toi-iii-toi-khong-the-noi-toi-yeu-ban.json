 mê hoặc ngay tại chỗ. Yuma, trong thân xác Atsushi, tái nhợt đi. Hai người buộc phải sống như thế này một thời gian...</p>","tmdb_id":1341335,"cast":["Ryo Kuraki","Yusuke Sakamoto","Takami Kazumasa","Teruo Oka","Shôichi Yokosuka","Kazu Itsuki","Kyôko Kazama"],"director":["加藤義一"],"keywords":["body-swap","softcore","pink film","gay theme"],"tmdb":{"type":"movie","id":"1341335","season":null,"vote_average":2,"vote_count":1},"cast_meta":[{"name":"Ryo Kuraki","name_vi":null,"name_original":"Ryo Kuraki","tmdb_id":4651544,"profile":"https://image.tmdb.org/t/p/w500/i58XagCgHiwJQ2YH6KramjkAm2a.jpg","tmdb_url":"https://www.themoviedb.org/person/4651544"},{"name":"Yusuke Sakamoto","name_vi":null,"name_original":"Yusuke Sakamoto","tmdb_id":4607686,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4607686"},{"name":"Takami Kazumasa","name_vi":null,"name_original":"Takami Kazumasa","tmdb_id":3647161,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3647161"},{"name":"Teruo Oka","name_vi":null,"name_original":"Teruo Oka","tmdb_id":1600993,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1600993"},{"name":"Shôichi Yokosuka","name_vi":null,"name_original":"Shôichi Yokosuka","tmdb_id":2751115,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2751115"},{"name":"Kazu Itsuki","name_vi":null,"name_original":"Kazu Itsuki","tmdb_id":1108216,"profile":"https://image.tmdb.org/t/p/w500/xhpkDNKsEUnVQiJ03flfH47sm9l.jpg","tmdb_url":"https://www.themoviedb.org/person/1108216"},{"name":"Kyôko Kazama","name_vi":null,"name_original":"Kyôko Kazama","tmdb_id":239521,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/239521"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/an/anh-trai-toi-va-toi-iii-toi-khong-the-noi-toi-yeu-ban.json"}