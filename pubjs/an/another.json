ng bức ảnh...</p>","tmdb":{"type":"tv","id":"42589","season":1,"vote_average":8.3,"vote_count":1023},"modified":"2025-08-21T13:04:29.000Z","cast":["Atsushi Abe","Natsumi Takamori","Madoka Yonezawa","Tomoaki Maeno","Kazutomi Yamamoto"],"director":[],"cast_meta":[{"name":"Atsushi Abe","name_vi":null,"name_original":"Atsushi Abe","tmdb_id":1154449,"profile":"https://image.tmdb.org/t/p/w500/b59PickRsrhT6kaUKN2dD8c7ip.jpg","tmdb_url":"https://www.themoviedb.org/person/1154449"},{"name":"Natsumi Takamori","name_vi":null,"name_original":"Natsumi Takamori","tmdb_id":1255699,"profile":"https://image.tmdb.org/t/p/w500/lmoEgs5x8NchMlsXqmU4ZYsC8ey.jpg","tmdb_url":"https://www.themoviedb.org/person/1255699"},{"name":"Madoka Yonezawa","name_vi":null,"name_original":"Madoka Yonezawa","tmdb_id":1072777,"profile":"https://image.tmdb.org/t/p/w500/qAQfi2h2Lz2UTmGk3IMIxSHJcIo.jpg","tmdb_url":"https://www.themoviedb.org/person/1072777"},{"name":"Tomoaki Maeno","name_vi":null,"name_original":"Tomoaki Maeno","tmdb_id":1249235,"profile":"https://image.tmdb.org/t/p/w500/w3lEuXSbEyzzNyO3YnxsF6wm2N5.jpg","tmdb_url":"https://www.themoviedb.org/person/1249235"},{"name":"Kazutomi Yamamoto","name_vi":null,"name_original":"Kazutomi Yamamoto","tmdb_id":1256906,"profile":"https://image.tmdb.org/t/p/w500/4rRICK0YXcneKmPzV7nv3BKGliB.jpg","tmdb_url":"https://www.themoviedb.org/person/1256906"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/an/another.json"}