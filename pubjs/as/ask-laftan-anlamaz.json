ip.opstream10.com/share/89ada874a8dffb56920a557a3909f827","link_m3u8":"https://vip.opstream10.com/20221003/25114_9fd86c78/index.m3u8"},{"name":"26","slug":"26","filename":"Laftan26-muxed","link_embed":"https://vip.opstream10.com/share/83820a0bd8a43216b004880317ae6ecf","link_m3u8":"https://vip.opstream10.com/20221008/25192_e387ae2b/index.m3u8"},{"name":"27","slug":"27","filename":"Laftan27-muxed","link_embed":"https://vip.opstream10.com/share/353b78669dd07c3d95ea4acbe7130488","link_m3u8":"https://vip.opstream10.com/20221013/25242_6026916e/index.m3u8"},{"name":"28","slug":"28","filename":"Laftan28-muxed","link_embed":"https://vip.opstream10.com/share/40547606fba6796b5cded9cf8f7b6062","link_m3u8":"https://vip.opstream10.com/20221020/25275_5c3cb42a/index.m3u8"},{"name":"29","slug":"29","filename":"Laftan29-muxed","link_embed":"https://vip.opstream10.com/share/07c4e1bc5b4228901136e90dad3209a2","link_m3u8":"https://vip.opstream10.com/20221027/25311_87e3c19f/index.m3u8"},{"name":"30","slug":"30","filename":"Laftan30-muxed","link_embed":"https://vip.opstream10.com/share/b8fd187b3f6b41d95bbc6c831075f367","link_m3u8":"https://vip.opstream10.com/20221029/25323_4cfcb0de/index.m3u8"},{"name":"31","slug":"31","filename":"Laftan31-muxed","link_embed":"https://vip.opstream10.com/share/ee9a1fc09b64d5cdd17ba7b7f6640409","link_m3u8":"https://vip.opstream10.com/20221101/25344_6d322d82/index.m3u8"}]}],"time":"2h00p/tập","description":"<p>&nbsp;</p><p>Hayat là một cô gái trẻ sống ở Istanbul cùng với hai người bạn là Asli và Ipek. Cô muốn có một cuộc sống hạnh phúc ở Istanbul mà không có sự kiểm soát của gia đình. Tuy nhiên, theo yêu cầu của cha cô, Hayat phải tìm một công việc tốt càng sớm càng tốt, nếu không sẽ phải trở về quê và sống chung với bố mẹ.</p><p>&nbsp;</p><p>Hayat biết rằng cô ấy phải cố gắng hết sức trong lần phỏng vấn xin việc tiếp theo cho một công ty dệt may đa quốc gia, Sarte. Nếu được nhận, cô biết rằng mình có thể thuyết phục bố mẹ và tiếp tục sống ở Istanbul. Trong cuộc phỏng vấn, Hayat bị nhầm là Suna, con gái của bạn thân của chủ công ty. Trong sự tuyệt vọng với công việc, Hayat không giải quyết được hiểu lầm này và hành động như thể cô là Suna và nhận công việc: trở thành trợ lý của Murat Sarsılmaz, người thừa kế của Sarte.</p><p>&nbsp;</p><p>Hayat không tiết lộ danh tính thật của mình và bắt đầu hợp tác với Murat. Dù suốt ngày tranh cãi nhưng họ ngày càng thân thiết hơn. Hayat thiếu kiên nhẫn, máu nóng và vụng về trong khi Murat kiên định, điềm tĩnh và kiêu ngạo. Hai người có tính cách hoàn toàn khác nhau nhưng lại dần có tình cảm với nhau.</p><p>&nbsp;</p><p>Điều gì sẽ xảy ra khi Murat biết được danh tính thực sự của Hayat? Liệu Murat và Hayat có thể hạnh phúc mãi mãi về sau?</p><p>&nbsp;</p><p>Hãy cùng chờ đón sự phát sóng của Ask Laftan Anlamaz Vietsub Full trên Ophim.TV để tìm kiếm lời giải đáp nha cả nhà!!</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"67570","season":1,"vote_average":8.4,"vote_count":37},"modified":"2022-12-11T15:21:03.000Z","cast":["Hande Erçel","Burak Deniz","Özcan Tekdemir","Merve Çağıran","Oğuzhan Karbi","Demet Gül","Süleyman Felek","Betül Çobanoğlu","Sultan Köroğlu Kılıç","Evren Duyal","Gözde Kocaoğlu","Nazan Diper","Elçin Afacan"],"director":["Burak Sağyaşar","Müge Uğurlar"],"cast_meta":[{"name":"Hande Erçel","name_vi":null,"name_original":"Hande Erçel","tmdb_id":1522703,"profile":"https://image.tmdb.org/t/p/w500/jrUvWNqOpfDm3D0KhbuRwQOy8Nu.jpg","tmdb_url":"https://www.themoviedb.org/person/1522703"},{"name":"Burak Deniz","name_vi":null,"name_original":"Burak Deniz","tmdb_id":1577490,"profile":"https://image.tmdb.org/t/p/w500/mKrCdU2slmRR3FiiSfk9uzp99AA.jpg","tmdb_url":"https://www.themoviedb.org/person/1577490"},{"name":"Özcan Tekdemir","name_vi":null,"name_original":"Özcan Tekdemir","tmdb_id":1999014,"profile":"https://image.tmdb.org/t/p/w500/mvgri7obv2CfrvcuR8BhceJpa18.jpg","tmdb_url":"https://www.themoviedb.org/person/1999014"},{"name":"Merve Çağıran","name_vi":null,"name_origin