514_41ed6698/index.m3u8"},{"name":"35","slug":"35","filename":"Uc Kiz Kardes 51","link_embed":"https://vip.opstream13.com/share/1c383cd30b7c298ab50293adfecb7b18","link_m3u8":"https://vip.opstream13.com/20230607/35_613745ab/index.m3u8"},{"name":"36","slug":"36","filename":"Uc Kiz Kardes 52","link_embed":"https://vip.opstream13.com/share/ed3d2c21991e3bef5e069713af9fa6ca","link_m3u8":"https://vip.opstream13.com/20230615/98_9b29c167/index.m3u8"},{"name":"37","slug":"37","filename":"Uc Kiz Kardes 53","link_embed":"https://vip.opstream13.com/share/091d584fced301b442654dd8c23b3fc9","link_m3u8":"https://vip.opstream13.com/20230622/208_3d1558e1/index.m3u8"}]}],"time":"2h30p/tập","description":"<p>Ngày xửa ngày xưa ở một đất nước xinh đẹp nhưng bí ẩn, có ba chị em gái tên là Türkan, Dönüş và Derya. Là một gia đình gắn bó, họ sẽ mơ về một tương lai đầy hứa hẹn mỗi đêm. Có lẽ một cách dạy dỗ như vậy, tương tự như một câu chuyện cổ tích trên những con đường đầy mùi thông của Ayvalık, đã không chuẩn bị cho họ trước thực tế nghiệt ngã của tuổi trưởng thành. Theo thời gian, chị em phát hiện ra rằng cuộc sống và những lựa chọn đi kèm với nó không hề dễ dàng như họ tưởng. Những bí mật không thể ngờ tới có thể bị che giấu ngay cả với những người được tin tưởng nhất và những căn bệnh khủng khiếp có thể dẫn đến sự sống lại của quá khứ. Điều này dẫn họ đến câu hỏi: Có thứ gì trên đời mà thời gian không thể chữa lành?</p>","tmdb":{"type":"tv","id":"158339","season":1,"vote_average":6.8,"vote_count":10},"modified":"2025-04-11T09:46:58.000Z","cast":["İclal Aydın","Reha Özcan","Almila Ada","Berker Güven","Benian Dönmez","Nazlı Senem Ünal","Hakan Atalay","Vural Şahanoğlu","Emre Kıvılcım","Veda Yurtsever","Serhan Süsler","Özgü Kaya","Demircan Kaçel","Melisa Berberoğlu","Murat Çidamlı"],"director":["Eda Teksoz"],"cast_meta":[{"name":"İclal Aydın","name_vi":null,"name_original":"İclal Aydın","tmdb_id":1953639,"profile":"https://image.tmdb.org/t/p/w500/uMGVUAcSAOfeKc40EdRZnRUkQSt.jpg","tmdb_url":