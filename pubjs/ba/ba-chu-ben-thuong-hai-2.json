ip.opstream12.com/20251115/30067_25f25816/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Tiếp nối phần đầu, phim kể về thời kỳ hỗn loạn khi thế lực mới nổi lên tranh giành quyền kiểm soát Thượng Hải. Sau khi thoát khỏi những biến cố trong quá khứ, Trương Chí Cường trở lại giang hồ với mong muốn thiết lập trật tự và gìn giữ danh dự xưa. Tuy nhiên, sự phản bội, mưu mô cùng những mối thù chưa dứt khiến anh một lần nữa rơi vào vòng xoáy sinh tử. Bộ phim khắc họa rõ nét bi kịch của những con người sống giữa danh vọng, tình nghĩa và định mệnh không thể thoát.</p>","tmdb":{"type":"tv","id":"109054","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-16T20:58:49.000Z","cast":["Ray Lui (Lữ Lương Vỹ)","Kathy Chow (Châu Huệ Mẫn)","Kent Tong (Đường Trí Lâm)","Simon Yam (Nhậm Đạt Hoa)","Wu Qihua (Ngô Khải Hoa)"],"director":["Wong Wai Keung (Hoàng Vỹ Cường)"],"cast_meta":[{"name":"Ray Lui (Lữ Lương Vỹ)","name_vi":null,"name_original":"Ray Lui (Lữ Lương Vỹ)"},{"name":"Kathy Chow (Châu Huệ Mẫn)","name_vi":null,"name_original":"Kathy Chow (Châu Huệ Mẫn)"},{"name":"Kent Tong (Đường Trí Lâm)","name_vi":null,"name_original":"Kent Tong (Đường Trí Lâm)"},{"name":"Simon Yam (Nhậm Đạt Hoa)","name_vi":null,"name_original":"Simon Yam (Nhậm Đạt Hoa)"},{"name":"Wu Qihua (Ngô Khải Hoa)","name_vi":null,"name_original":"Wu Qihua (Ngô Khải Hoa)"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/ba-chu-ben-thuong-hai-2.json"}