ong-tieng-modern-matchmaker-tap-38","link_embed":"https://vip.opstream10.com/share/68e4593563e1b425a7717504bca103d6","link_m3u8":"https://vip.opstream10.com/20220520/15688_519556bb/index.m3u8"},{"name":"39","slug":"39","filename":"ba-mai-lam-loi-long-tieng-modern-matchmaker-tap-39","link_embed":"https://vip.opstream10.com/share/13d8efdc6a5cb721fe7031be062b9b74","link_m3u8":"https://vip.opstream10.com/20220520/15693_782fe105/index.m3u8"},{"name":"40","slug":"40","filename":"ba-mai-lam-loi-long-tieng-modern-matchmaker-tap-40","link_embed":"https://vip.opstream10.com/share/86ff096395a37c9d2d4361c2e002f7f9","link_m3u8":"https://vip.opstream10.com/20220520/15696_9c54dd31/index.m3u8"},{"name":"41","slug":"41","filename":"ba-mai-lam-loi-long-tieng-modern-matchmaker-tap-41","link_embed":"https://vip.opstream10.com/share/a20806b3c15ea015afefcf7e0800e978","link_m3u8":"https://vip.opstream10.com/20220520/15697_a97a21af/index.m3u8"},{"name":"42","slug":"42","filename":"ba-mai-lam-loi-long-tieng-modern-matchmaker-tap-42","link_embed":"https://vip.opstream10.com/share/01cc1da1d5e00d6c7fb60943b4b03f68","link_m3u8":"https://vip.opstream10.com/20220520/15701_762405ba/index.m3u8"}]}],"time":"","description":"<p>Câu chuyện về Đô Hiểu Hiểu luôn thích Cao Văn Bác – anh bạn hàng xóm quen từ nhỏ – nhưng không dám bày tỏ. Cao Văn Bác vì bị phản bội nên không còn tin tưởng vào tình yêu. Mẹ Văn Bác là Lưu Diễm Bình quyết định tìm bạn gái cho con trai, giúp con trai thoát khỏi nỗi đau khổ thất tình. Đón xem phim Trung Quốc Bà mai lắm lời trên Tình cờ, Đô Hiểu Hiểu thay thế cô bạn thân làm bà mai, cô phải giới thiệu bạn gái cho Cao Văn Bác. Đô Hiểu Hiểu thật lòng không muốn giới thiệu La Tiểu San cho người mình yêu. Chuyện Đô Hiểu Hiểu làm bà mai thay cho bạn bị nơi cô làm việc phát hiện. Đô Hiểu Hiểu bị sa thải. La Tiểu San che giấu việc cô là mẹ đơn thân, vì muốn tìm cha cho con nên mới đi coi mắt. Cao Văn Bác biết chuyện và quyết định trở thành bố tạm thời, cùng Đô Hiểu Hiểu, La Tiểu San chăm sóc đứa bé. Thế nhưng càng ngày Đô Hiểu Hiểu càng không thể che giấu tình cảm của mình nên đã bày tỏ với Cao Văn Bác. Cuối cùng, hai người đã đến bên nhau, sống một cuộc sống hạnh phúc.</p>","tmdb":{"type":"tv","id":"136758","season":1,"vote_average":0,"vote_count":0},"modified":"2022-05-24T10:12:43.000Z","cast":["Trương Lệ","Yang Shuo","Trương Đan Phong","Khương Triều","Bai Fan","Sun Jia Lu","Erica Xia-Hou","Đồ Tùng Nham","Wang Liyun"],"director":["Vương Tiểu Khang"],"cast_meta":[{"name":"Trương Lệ","name_vi":"Trương Lệ","name_original":"Zhang Li","tmdb_id":1993060,"profile":"https://image.tmdb.org/t/p/w500/eEvYNGg8NnyQlH1wWUcXdWvDEMB.jpg","tmdb_url":"https://www.themoviedb.org/person/1993060"},{"name":"Yang Shuo","name_vi":null,"name_original":"Yang Shuo","tmdb_id":1924106,"profile":"https://image.tmdb.org/t/p/w500/bUCUr6k7noDNyMWC637xg1lnRPx.jpg","tmdb_url":"https://www.themoviedb.org/person/1924106"},{"name":"Trương Đan Phong","name_vi":"Trương Đan Phong","name_original":"Zhang Danfeng","tmdb_id":2080701,"profile":"https://image.tmdb.org/t/p/w500/mkdAKLWQobvc37DNLbXCwfT0jXi.jpg","tmdb_url":"https://www.themoviedb.org/person/2080701"},{"name":"Khương Triều","name_vi":"Khương Triều","name_original":"Jiang Chao","tmdb_id":235521,"profile":"https://image.tmdb.org/t/p/w500/q7Y4kNRkIK1GrfCZSuP7GqRKw85.jpg","tmdb_url":"https://www.themoviedb.org/person/235521"},{"name":"Bai Fan","name_vi":null,"name_original":"Bai Fan","tmdb_id":1637225,"profile":"https://image.tmdb.org/t/p/w500/dWFg6bwXRcCzBsO1tjsM1T549uI.jpg","tmdb_url":"https://www.themoviedb.org/person/1637225"},{"name":"Sun Jia Lu","name_vi":null,"name_original":"Sun Jia Lu","tmdb_id":3066721,"profile":"https://image.tmdb.org/t/p/w500/5k2ocPfECve4f8CnaWEVFmcVLpB.jpg","tmdb_url":"https://www.themoviedb.org/person/3066721"},{"name":"Erica Xia-Hou","name_vi":null,"name_original":"Erica Xia-Hou","tmdb_id":2312623,"profile":"https://image.tmdb.org/t/p/w500/edH7aCvQwNbPBI6wfUFiANuziwW.jpg","tmdb_url":"https://www.the