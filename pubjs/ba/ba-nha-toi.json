m/20250901/5660_fa1839c5/index.m3u8"},{"name":"20","slug":"20","filename":"Bà Nhà Tôi (Just Love) 20#20 # Tuyên Huyên, Trần Cẩm Hồng, Lý Tư Tiệp # TVB 2005","link_embed":"https://vip.opstream13.com/share/0c4b1eeb45c90b52bfb9d07943d855ab","link_m3u8":"https://vip.opstream13.com/20250901/5661_0c4b1eeb/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Just Love (Yêu Là Yêu) là bộ phim truyền hình hiện đại của TVB phát sóng vào tháng 5 năm 2005. Phim được phát sóng trên kênh truyền hình MediaCorp TV Channel 8 của Singapore vào năm 2007. Bộ phim xoay quanh bối cảnh gia đình, chủ yếu xoay quanh mối quan hệ vợ chồng, sự tin tưởng và hỗ trợ lẫn nhau. Công việc và cuộc sống đa dạng, lại thêm việc chăm sóc con cái khó khăn vì cha mẹ phải đối mặt với những cảm xúc lẫn lộn trong gia đình... Phần tiếp theo, Just Love II, được sản xuất và phát hành vào năm 2009, tiếp tục với sự tham gia của Tuyên Huyên, Trần Tuệ Minh, Đường Thi Vịnh, Đường Yên, Đường Thi Vịnh và Lý Nhã Kỳ, cùng với Đường Thi Vịnh.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"15949","season":1,"vote_average":7.5,"vote_count":2},"modified":"2025-09-03T17:09:35.000Z","cast":["Tuyên Huyên","Trần Cẩm Hồng","Natalie Tong","Selena Lee","Patrick Tang Kin-Wang","Vương Kiệt","Johnson Lee Sze-Chit","Fiona Yuen Choi-Wan"],"director":[],"cast_meta":[{"name":"Tuyên Huyên","name_vi":"Tuyên Huyên","name_original":"Jessica Hsuan","tmdb_id":230777,"profile":"https://image.tmdb.org/t/p/w500/3hp9D2B1Y7L7imPUHCpHiNgxSY.jpg","tmdb_url":"https://www.themoviedb.org/person/230777"},{"name":"Trần Cẩm Hồng","name_vi":"Trần Cẩm Hồng","name_original":"Sunny Chan Kam-Hung","tmdb_id":548050,"profile":"https://image.tmdb.org/t/p/w500/pUMJUtdpFutN7uHk7yPw11iwAbh.jpg","tmdb_url":"https://www.themoviedb.org/person/548050"},{"name":"Natalie Tong","name_vi":null,"name_original":"Natalie Tong","tmdb_id":1237978,"profile":"https://image.tmdb.org/t/p/w500/jZHpp0BOnVW3M0NqH3TVpj0oGo6.jpg","tmdb_url":"https://www.themoviedb.org/person/1237978"},{"nam