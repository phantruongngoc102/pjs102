stream17.com/20240611/11418_a30a17cf/index.m3u8"},{"name":"16","slug":"16","filename":"BacDauSongHung.16","link_embed":"https://vip.opstream17.com/share/1487987e862c44b91a0296cf3866387e","link_m3u8":"https://vip.opstream17.com/20240611/11417_d51335f6/index.m3u8"},{"name":"17","slug":"17","filename":"BacDauSongHung.17","link_embed":"https://vip.opstream17.com/share/2f64bf56821bc84ff5418577e2dc48d9","link_m3u8":"https://vip.opstream17.com/20240611/11416_314e67d3/index.m3u8"},{"name":"18","slug":"18","filename":"BacDauSongHung.18","link_embed":"https://vip.opstream17.com/share/54e0e46b6647aa736c13ef9d09eab432","link_m3u8":"https://vip.opstream17.com/20240611/11415_6397a555/index.m3u8"},{"name":"19","slug":"19","filename":"BacDauSongHung.19","link_embed":"https://vip.opstream17.com/share/292795f5daad46256799bba38938423e","link_m3u8":"https://vip.opstream17.com/20240611/11414_c9bc5d61/index.m3u8"},{"name":"20","slug":"20","filename":"BacDauSongHung.20End","link_embed":"https://vip.opstream17.com/share/79b6245ff93841eb8c120cec9bf8be14","link_m3u8":"https://vip.opstream17.com/20240611/11413_0c251561/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Vu Phàm là một diễn viên đóng thế, tính tình phóng khoáng, nhiều chuyện, là người không có kế hoạch cho tương lai của mình. Ước mơ lớn nhất của Vu Phàm là trở thành một ngôi sao của Hồng Kông. Giang Hạo Văn hoàn toàn trái ngược với Vu Phàm, Văn là người trầm tính, nhút nhát là một nhân viên văn phòng của một công ty tư vấn nhỏ. Văn thường bị ông chủ của mình chèn ép, đánh cắp ý tưởng. Bất mãn, Văn nộp đơn xin từ chức trở thành người thất nghiệp. Hai người tính tình hoàn toàn trái ngược nhau, do hoàn cảnh đưa đẩy cuối cùng trở thành người sống cùng trong một ngôi nhà. Phàm luôn thấy Văn là kẻ nhàm chán và ngược lại Văn cũng khó chịu với lối sống của Phàm. Sau những hiểu lầm, hai người dần dần xích lại nhau, giúp đỡ nhau trong lúc khó khăn và trở thành tri kỷ. Giang Hạo Văn nhờ sự động viên của Vu Phàm đã trở thành nhân viên xã hội, giúp đỡ các thanh niên sa ngã quay trở lại con đường chân chính. Do công việc, một lần Hạo Văn bị dính vào một tổ chức ma túy, vô tình phá vỡ một vụ làm ăn của tổ chức này khiến Phàm và Văn bị sát thủ Tống Ba truy sát. Phàm và Văn đã hiệp lực cùng nhau thoát khỏi tay Ba, phá vỡ tổ chức ma túy để rồi nổi tiếng, trong một đêm cả hai trở thành thần tượng của giới trẻ Hồng Kông.</i></p>","tmdb":{"type":"tv","id":"52118","season":1,"vote_average":0,"vote_count":0},"modified":"2024-09-05T10:59:03.000Z","cast":["Lương Triều Vỹ","Châu Nhuận Phát","Nhậm Đạt Hoa","Rebecca Chan","Yiu Wai","Quách Phong","Chan On-ying","Lỗ Chấn Thuận","Liu Chun-Hung","Châu Tinh Trì","Âu Dương Chấn Hoa","Ngô Quân Như"],"director":["Lý Đình Luân"],"cast_meta":[{"name":"Lương Triều Vỹ","name_vi":"Lương Triều Vỹ","name_original":"Tony Leung Chiu-wai","tmdb_id":1337,"profile":"https://image.tmdb.org/t/p/w500/nQbSQAws5BdakPEB5MtiqWVeaMV.jpg","tmdb_url":"https://www.themoviedb.org/person/1337"},{"name":"Châu Nhuận Phát","name_vi":"Châu Nhuận Phát","name_original":"Chow Yun-Fat","tmdb_id":1619,"profile":"https://image.tmdb.org/t/p/w500/uDPYSiZrW7OZ79qgcgkWefALlXY.jpg","tmdb_url":"https://www.themoviedb.org/person/1619"},{"name":"Nhậm Đạt Hoa","name_vi":"Nhậm Đạt Hoa","name_original":"Simon Yam","tmdb_id":20519,"profile":"https://image.tmdb.org/t/p/w500/eilxjMhfobctnzZ0kBcFmnqtFyd.jpg","tmdb_url":"https://www.themoviedb.org/person/20519"},{"name":"Rebecca Chan","name_vi":null,"name_original":"Rebecca Chan","tmdb_id":1318187,"profile":"https://image.tmdb.org/t/p/w500/fnb4rwgd7lGdtSVHcz7YCGakj5E.jpg","tmdb_url":"https://www.themoviedb.org/person/1318187"},{"name":"Yiu Wai","name_vi":null,"name_original":"Yiu Wai","tmdb_id":1402734,"profile":"https://image.tmdb.org/t/p/w500/gHGuf6gsQws8TIPrqqM3UaPL1pz.jpg","tmdb_url":"https://www.themoviedb.org/person/1402734"},{"name":"Quách Phong","name_vi":"Quách Phong","name_original":"Samuel Kwok Fung","tmdb_id":1416065,"profile":"https://image.tmdb.org/t/p/