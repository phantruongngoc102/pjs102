{"id":"66a31624a6cdbc7539dda9ba","title":"Bắc Minh Có Cá Côn","origin_name":"Kun in the Distant Ocean","slug":"bac-minh-co-ca-con","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ba/bac-minh-co-ca-con.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ba/bac-minh-co-ca-con.webp","year":2024,"type":"single","genre":[{"id":"620a2293e0fc277084dfd489","name":"Phiêu Lưu","slug":"phieu-luu"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"is_ai":false,"server_name":"Vietsub #1","server_data":[{"name":"Full","slug":"full","filename":"Kun.in.the.Distant.Ocean.2024.ViE.AI.2160p.HQ.WEB-DL.H265.60fps.DDP2.0-DreamHD(1)(1)(1)(1)","link_embed":"https://vip.opstream90.com/share/674bfc5f6b72706fb769f5e93667bd23","link_m3u8":"https://vip.opstream90.com/20240726/1343_674bfc5f/index.m3u8"}]}],"time":"74 Phút","description":"Hải thần cưới vợ, các thiếu nữ loài người đua nhau chủ động hiến tế. Linh Vũ, con gái một gia đình ngư dân vô tình bước vào cấm địa của tộc Hải thần, gặp một hoàng tử thật và một hoàng tử giả, một xấu một đẹp và rất nhiều cô dâu thây ma trong quan tài băng vô cùng đáng sợ. Hải thần vì cứu người vợ yêu dấu của mình mà bị yêu ma hãm hại, hai vợ chồng bị đóng băng trong địa cung. Hoàng tử Hải thần vì cha mẹ mình đã dũng cảm đột nhập vào Rừng Rắn Đen, nhưng lại vô tình mở phong ấn khiến Xà Yêu khổng lồ xuất hiện trở lại. Vào thời khắc nguy nan, những người thân xung quanh lại ngấm ngầm nổi ý định giết người, quay lưng lại với nhau khiến hoàng tử rơi vào bước đường cùng! Cá lớn bay lên không trung và nuốt chửng con người bằng cái miệng khổng lồ, trận quyết chiến giữa các thần thú kinh thiên động địa. Liệu hoàng tử trẻ có thể chiến thắng ác ma, giải cứu cha mẹ mình khỏi hàng loạt âm mưu và từ cá Côn biến thành thần hay không?","tmdb":{"type":"movie","id":"1244556","season":null,"vote_average":0,"vote_count":0},"modified":"2025-01-02T11:18:48.000Z","cast":["June Wu","Zhu Shengyi","Xiao Xiangfei","Carrie Wang","Rinchen Namu","Xu Shaoze","Hoàng Đào","Ren Chenxi"],"director":["曹国莉"],"cast_meta":[{"name":"June Wu","name_vi":null,"name_original":"June Wu","tmdb_id":1842337,"profile":"https://image.tmdb.org/t/p/w500/wNLFI18YOnOKjOsiVDi7mSwVTWK.jpg","tmdb_url":"https://www.themoviedb.org/person/1842337"},{"name":"Zhu Shengyi","name_vi":null,"name_original":"Zhu Shengyi","tmdb_id":1709634,"profile":"https://image.tmdb.org/t/p/w500/Ad42ezyIr7mZxRt6SVhEe4mTmmd.jpg","tmdb_url":"https://www.themoviedb.org/person/1709634"},{"name":"Xiao Xiangfei","name_vi":null,"name_original":"Xiao Xiangfei","tmdb_id":2719785,"profile":"https://image.tmdb.org/t/p/w500/uStR9kCNvzpXWVj8q39yirSRFWa.jpg","tmdb_url":"https://www.themoviedb.org/person/2719785"},{"name":"Carrie Wang","name_vi":null,"name_original":"Carrie Wang","tmdb_id":3666935,"profile":"https://image.tmdb.org/t/p/w500/ft6vcHJbtes7XvD378TCmRymUKV.jpg","tmdb_url":"https://www.themoviedb.org/person/3666935"},{"name":"Rinchen Namu","name_vi":null,"name_original":"Rinchen Namu","tmdb_id":4890787,"profile":"https://image.tmdb.org/t/p/w500/jS6KbimY7RCK6erBEPIjqEbGnxh.jpg","tmdb_url":"https://www.themoviedb.org/person/4890787"},{"name":"Xu Shaoze","name_vi":null,"name_original":"Xu Shaoze","tmdb_id":2782172,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2782172"},{"name":"Hoàng Đào","name_vi":"Hoàng Đào","name_original":"Huang Tao","tmdb_id":2950162,"profile":"https://image.tmdb.org/t/p/w500/hdDvTSyrQN95uRuq0AgcoCDJuDc.jpg","tmdb_url":"https://www.themoviedb.org/person/2950162"},{"name":"Ren Chenxi","name_vi":null,"name_original":"Ren Chenxi","tmdb_id":4890781,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4890781"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/