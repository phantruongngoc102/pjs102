uất và chỉ đạo thí điểm. Bộ phim công chiếu lần đầu trên kênh NBC ngày 04 Tháng Tư năm 2013.</p>","tmdb_id":40008,"cast":[],"director":[],"keywords":[],"tmdb":{"id":40008},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bac-si-an-thit-nguoi-phan-1.json"}