.com/20240218/726_519442d3/index.m3u8"},{"name":"23","slug":"23","filename":"Bác sĩ House_S05E23_Dưới vẻ bề ngoài","link_embed":"https://vip.opstream17.com/share/d4c2e4a3297fe25a71d030b67eb83bfc","link_m3u8":"https://vip.opstream17.com/20240218/728_6515859b/index.m3u8"},{"name":"24","slug":"24","filename":"Bác sĩ House_S05E24_Cả hai bên","link_embed":"https://vip.opstream17.com/share/5751ec3e9a4feab575962e78e006250d","link_m3u8":"https://vip.opstream17.com/20240218/729_6f259905/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Trong phần cuối của Phần 4, sau một vụ tai nạn xe buýt lớn khiến House không còn nhớ gì về vụ tai nạn, anh và nhóm đã ghép các mảnh ký ức của mình lại với nhau và phát hiện ra bạn gái của Wilson là Amber đang ở trên xe buýt với anh và bị thương nặng. Wilson phải đối mặt với sự thật kinh hoàng rằng House có liên quan đến cái chết của Amber. Khi Phần 5 mở đầu, khi tình bạn của anh với Wilson tan vỡ, House phải xác định xem liệu anh có phải chịu trách nhiệm về cái chết của Amber hay không và Wilson phải quyết định xem liệu House có phải là thế lực hủy diệt cuộc đời anh hay không trong khi Cuddy cố gắng thúc đẩy sự hòa giải giữa hai người họ.</p>","tmdb":{"type":"tv","id":"1408","season":5,"vote_average":8.578,"vote_count":7308},"modified":"2024-02-18T19:12:25.000Z","cast":["Hugh Laurie","Robert Sean Leonard","Omar Epps","Jesse Spencer","Odette Annable","Peter Jacobson","Lo Mutuc"],"director":[],"cast_meta":[{"name":"Hugh Laurie","name_vi":null,"name_original":"Hugh Laurie","tmdb_id":41419,"profile":"https://image.tmdb.org/t/p/w500/akArncggHnusP5jxzMBKmJDRrMo.jpg","tmdb_url":"https://www.themoviedb.org/person/41419"},{"name":"Robert Sean Leonard","name_vi":null,"name_original":"Robert Sean Leonard","tmdb_id":2692,"profile":"https://image.tmdb.org/t/p/w500/jXehZM0AWLJ2OIz4o0jFtHEzcMI.jpg","tmdb_url":"https://www.themoviedb.org/person/2692"},{"name":"Omar Epps","name_vi":null,"name_original":"Omar Epps","tmdb_id":4987,"profile":"ht