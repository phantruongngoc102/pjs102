.opstream17.com/20240218/748_8e625b95/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/8d317bdcf4aafcfc22149d77babee96d","link_m3u8":"https://vip.opstream17.com/20240218/747_284adc68/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/b137fdd1f79d56c7edf3365fea7520f2","link_m3u8":"https://vip.opstream17.com/20240218/750_55d780fd/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/b056eb1587586b71e2da9acfe4fbd19e","link_m3u8":"https://vip.opstream17.com/20240218/749_fc040b07/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/912d2b1c7b2826caf99687388d2e8f7c","link_m3u8":"https://vip.opstream17.com/20240218/751_5d5a9a95/index.m3u8"}]}],"description":"<p>Khi mùa giải trước kết thúc, House buộc phải thừa nhận rằng anh đã không còn nắm bắt được thực tế và không thể hành nghề y được nữa. Không còn lựa chọn nào khác, anh ta tự mình vào bệnh viện tâm thần. Phần 6 sẽ khám phá con đường hồi phục dài và ngoằn ngoèo của House: Liệu anh ấy có thể tìm thấy phiên bản nào đó của sự tỉnh táo và bình thường không? Liệu anh có thể tránh xa nơi làm việc được cho là đã khiến anh bất ổn về tinh thần nhưng cũng là chỗ dựa ổn định duy nhất trong cuộc đời anh? Princeton-Plainsboro có thể tiếp tục Khoa Chẩn đoán nổi tiếng mà không có anh ấy không? Mối quan hệ của Cuddy với House sẽ thay đổi như thế nào khi mối tình tưởng tượng của họ đã bị lộ?</p>","tmdb_id":1408,"cast":["Hugh Laurie","Robert Sean Leonard","Omar Epps","Jesse Spencer","Odette Annable","Peter Jacobson","Lo Mutuc"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"1408","season":6,"vote_average":8.578,"vote_count":7308},"cast_meta":[{"name":"Hugh Laurie","name_vi":null,"name_original":"Hugh Laurie","tmdb_id":41419,"profile":"https://image.tmdb.org/t/p/w500/akArncggHnusP5jxzMBKmJDRrMo.jpg","tmdb_url":"https://www.themoviedb.org/person/41419"},{"name":"Robert Sean Leonard","name_vi":null,"nam