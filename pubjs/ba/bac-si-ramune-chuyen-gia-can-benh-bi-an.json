":"https://vip.opstream11.com/share/dbd3aefb04bc8f0da565968b2dd29fb6","link_m3u8":"https://vip.opstream11.com/20220728/35191_00f74ef9/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Chỉ cần trái tim còn đập thì sẽ vẫn có những ưu phiền. Một căn bệnh lạ mà những thứ kì lạ xâm nhập vào và gây ra những triệu chứng lạ cho cơ thể. Ramune, một bác sĩ đã cùng các đệ tử chống lại căn bệnh mà y học hiện đại cũng phải bó tay. Anh ta có bộ dạng chẳng giống bác sĩ chút nào, lúc nào cũng cư xử tuỳ tiện thậm chí còn cái mồm lẻo mép. Tuy nhiên, một khi đối mặt với một căn bệnh lạ đó, bác sĩ ngay lập tức đi tìm nguyên nhân của những lo lắng mà bệnh nhân giấu kín trong lòng, rồi điều trị.</p>","tmdb":{"type":"tv","id":"108952","season":1,"vote_average":5.5,"vote_count":10},"modified":"2025-06-05T15:54:37.000Z","cast":["Takuma Nagatsuka","Yuma Uchida","Nobuhiko Okamoto","Kana Ueda","Junichi Suwabe"],"director":[],"cast_meta":[{"name":"Takuma Nagatsuka","name_vi":null,"name_original":"Takuma Nagatsuka","tmdb_id":1613381,"profile":"https://image.tmdb.org/t/p/w500/5IdSSkG5qDJ36MPX3R6oLPk557K.jpg","tmdb_url":"https://www.themoviedb.org/person/1613381"},{"name":"Yuma Uchida","name_vi":null,"name_original":"Yuma Uchida","tmdb_id":1492992,"profile":"https://image.tmdb.org/t/p/w500/2otstbLfQ7MXuFt1X8MFOb4OIgd.jpg","tmdb_url":"https://www.themoviedb.org/person/1492992"},{"name":"Nobuhiko Okamoto","name_vi":null,"name_original":"Nobuhiko Okamoto","tmdb_id":1245094,"profile":"https://image.tmdb.org/t/p/w500/7s1K2yQVF5iIWILaOfG7QrMZkXA.jpg","tmdb_url":"https://www.themoviedb.org/person/1245094"},{"name":"Kana Ueda","name_vi":null,"name_original":"Kana Ueda","tmdb_id":230471,"profile":"https://image.tmdb.org/t/p/w500/us6FMwXCeSUR2YyByxVcgOUjiIA.jpg","tmdb_url":"https://www.themoviedb.org/person/230471"},{"name":"Junichi Suwabe","name_vi":null,"name_original":"Junichi Suwabe","tmdb_id":9721,"profile":"https://image.tmdb.org/t/p/w500/4S7c3n3r07A83HvkLrnWZGVhiHg.jpg","tmdb_url":"https://www.t