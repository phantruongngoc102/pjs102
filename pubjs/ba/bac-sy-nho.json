lename":"bac-sy-nho-tap-35","link_embed":"https://vip.opstream10.com/share/3147da8ab4a0437c15ef51a5cc7f2dc4","link_m3u8":"https://vip.opstream10.com/20220327/2244_bcd69d48/index.m3u8"},{"name":"36","slug":"36","filename":"bac-sy-nho-tap-36","link_embed":"https://vip.opstream10.com/share/10907813b97e249163587e6246612e21","link_m3u8":"https://vip.opstream10.com/20220327/2245_67e9f3fa/index.m3u8"},{"name":"37","slug":"37","filename":"bac-sy-nho-tap-37","link_embed":"https://vip.opstream10.com/share/758a06618c69880a6cee5314ee42d52f","link_m3u8":"https://vip.opstream10.com/20220327/2246_b9a9c5ff/index.m3u8"},{"name":"38","slug":"38","filename":"bac-sy-nho-tap-38","link_embed":"https://vip.opstream10.com/share/df1f1d20ee86704251795841e6a9405a","link_m3u8":"https://vip.opstream10.com/20220327/2247_ec703da5/index.m3u8"},{"name":"39","slug":"39","filename":"bac-sy-nho-tap-39","link_embed":"https://vip.opstream10.com/share/be6c7b094f88532b6c6b35bbcd525ee8","link_m3u8":"https://vip.opstream10.com/20220327/2248_232c4469/index.m3u8"},{"name":"40","slug":"40","filename":"bac-sy-nho-tap-40","link_embed":"https://vip.opstream10.com/share/243facb29564e7b448834a7c9d901201","link_m3u8":"https://vip.opstream10.com/20220327/2249_a21785db/index.m3u8"}]}],"time":"45M34S","description":"<p>Bác sỹ khoa sản Quách Tĩnh luôn thích nghiêm cứu, suy đoán, phân tích rõ ràng mọi việc, anh cũng là bác sỹ lâm sàng tuyến đầu ở bệnh viện. Anh chàng bác sỹ vùng ven bị lãnh đạo đánh giá là “chuyên gia bỏ bê công việc” này lại muốn theo đuổi cô nàng chủ nhiệm Hoàng Dung, người trẻ tuổi xinh đẹp nhất bệnh viện, còn từng giành được giấy khen cấp chính phủ. Lãnh đạo trực tiếp của Quách Tĩnh, chủ nhiệm Hoàng Thái Vân của khoa sản lại chính là chị gái của Hoàng Dung. Cô nhất quyết không muốn em gái lấy một người chồng như vậy, nên luôn ngăn cản, khó dễ Quách Tĩnh. Bản thân chỉ là một bác sỹ bé nhỏ, Quách Tĩnh luôn cẩn thận từng tí cả trong cuộc sống lẫn công việc, đã phát hiện ra khó khăn của Hoàng Dung, anh bèn không ngừng cố gắng và dẫn dắt, tận tâm bảo vệ, cuối cùng đã giúp Hoàng Dung có được cuộc sống vui vẻ hạnh phúc.</p>","tmdb":{"type":"tv","id":"110961","season":1,"vote_average":0,"vote_count":0},"modified":"2023-04-23T19:47:55.000Z","cast":["Đổng Tử Kiện","Zhang Jiani","Lưu Mẫn Đào","Lý Lập Quần","Wang Zhener","Li Tai","Qi Kui","Fang Zibin","Gao Ruifeier","Wang Wanjuan","Jiuyi Zhao","Vương Tư Duẫn","Chen Bing","Liu Jie","Wen Li"],"director":["Lenseng Lou"],"cast_meta":[{"name":"Đổng Tử Kiện","name_vi":"Đổng Tử Kiện","name_original":"Dong Zijian","tmdb_id":1353695,"profile":"https://image.tmdb.org/t/p/w500/cSaRGUAjFWsfYakGTfCuRghIkhW.jpg","tmdb_url":"https://www.themoviedb.org/person/1353695"},{"name":"Zhang Jiani","name_vi":null,"name_original":"Zhang Jiani","tmdb_id":2035421,"profile":"https://image.tmdb.org/t/p/w500/cwb9IVbU2stIDl2XyWI38cAFs57.jpg","tmdb_url":"https://www.themoviedb.org/person/2035421"},{"name":"Lưu Mẫn Đào","name_vi":"Lưu Mẫn Đào","name_original":"Liu Mintao","tmdb_id":1079119,"profile":"https://image.tmdb.org/t/p/w500/32bnuj7u6P3LGs7iEAUax3JSW6E.jpg","tmdb_url":"https://www.themoviedb.org/person/1079119"},{"name":"Lý Lập Quần","name_vi":"Lý Lập Quần","name_original":"Lee Li-Chun","tmdb_id":545292,"profile":"https://image.tmdb.org/t/p/w500/xk05iTNkFuRz1Qd8hmfgNestpcR.jpg","tmdb_url":"https://www.themoviedb.org/person/545292"},{"name":"Wang Zhener","name_vi":null,"name_original":"Wang Zhener","tmdb_id":2227999,"profile":"https://image.tmdb.org/t/p/w500/83e4Dk51l1U2dxz7viU2VVvJIzm.jpg","tmdb_url":"https://www.themoviedb.org/person/2227999"},{"name":"Li Tai","name_vi":null,"name_original":"Li Tai","tmdb_id":1860531,"profile":"https://image.tmdb.org/t/p/w500/yizVEmsvv1Z8JfiyzrFRigZVN4h.jpg","tmdb_url":"https://www.themoviedb.org/person/1860531"},{"name":"Qi Kui","name_vi":null,"name_original":"Qi Kui","tmdb_id":2035974,"profile":"https://image.tmdb.org/t/p/w500/49WnrOUSJVbCpWPTZEh9i76ugcP.jpg","tmdb_url":"https://www.themoviedb.org/person/2035974