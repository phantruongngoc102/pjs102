ột phần của sáu chúa tể hắc ám đã tiến hành một cuộc chiến khiến nhân loại đứng trước bờ vực diệt vong. Niềm hy vọng cuối cùng của nhân loại, sáu anh hùng, đã cứu thế giới bằng cách lần lượt hạ gục sáu chúa tể hắc ám cho đến khi Leonis phong ấn bản thân bằng một câu thần chú mạnh mẽ. Anh ta thề sẽ sống lại sau một nghìn năm và chinh phục nhân loại, một sứ mệnh được trao cho anh ta bởi Nữ thần Nổi loạn. Hiện tại, một cô gái trẻ tên là Riselia Ray Crystalia đã vô tình hóa giải phong ấn của anh ta và đưa anh ta về nhà chăm sóc. Anh tham gia cuộc chiến của nhân loại chống lại những sinh vật bí ẩn tên là Voids, những kẻ có thể có liên hệ với quá khứ của anh.","tmdb":{"type":"tv","id":"136840","season":12,"vote_average":6.865,"vote_count":26},"modified":"2024-12-26T17:17:53.000Z","cast":["Marina Inoue","Yui Ishikawa","Aya Suzaki","Hiromi Igarashi","Honoka Kuroki","Arisa Nakada","Tomofumi Ikezoe","Ai Kakuma","Daisuke Hirakawa"],"director":[],"cast_meta":[{"name":"Marina Inoue","name_vi":null,"name_original":"Marina Inoue","tmdb_id":90135,"profile":"https://image.tmdb.org/t/p/w500/nQ7a3krkbea6ukw9KGvvTpMma96.jpg","tmdb_url":"https://www.themoviedb.org/person/90135"},{"name":"Yui Ishikawa","name_vi":null,"name_original":"Yui Ishikawa","tmdb_id":1224288,"profile":"https://image.tmdb.org/t/p/w500/2y1y1W4q8UIR0Vbs4NNvc7722XT.jpg","tmdb_url":"https://www.themoviedb.org/person/1224288"},{"name":"Aya Suzaki","name_vi":null,"name_original":"Aya Suzaki","tmdb_id":1258548,"profile":"https://image.tmdb.org/t/p/w500/eCbCtnzFqr4aTpe3arDeRGazP5K.jpg","tmdb_url":"https://www.themoviedb.org/person/1258548"},{"name":"Hiromi Igarashi","name_vi":null,"name_original":"Hiromi Igarashi","tmdb_id":1255652,"profile":"https://image.tmdb.org/t/p/w500/rVQfafFKUWZMNxqGYlHc2EPyNhc.jpg","tmdb_url":"https://www.themoviedb.org/person/1255652"},{"name":"Honoka Kuroki","name_vi":null,"name_original":"Honoka Kuroki","tmdb_id":1814182,"profile":"https://image.tmdb.org/t/p/w500/8DpcbNpSuE5IMHjztmj1YfO6nMn.jpg"