{"id":"64f6b544900f1649a92f9a83","title":"Bạch Hồ: Tình Duyên","origin_name":"White Fox","slug":"bach-ho-tinh-duyen","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/ba/bach-ho-tinh-duyen.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/ba/bach-ho-tinh-duyen.webp","year":2023,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a220de0fc277084dfd16d","name":"Tình Cảm","slug":"tinh-cam"},{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Bạch Hồ_ Tình Duyên (2023)","link_embed":"https://vip.opstream15.com/share/f01343d174b6dbc8cd10add58111dfa7","link_m3u8":"https://vip.opstream15.com/20230905/42163_893fe44b/index.m3u8"}]}],"time":"69 Phút","description":"Vụ Sơn Phái và Yêu Tộc vì ân oán từ hàng trăm năm trước mà không ngừng xung đột. Bạch Hồ Tố Tố được giao nhiệm vụ xâm nhập vào Vụ Sơn Phái để cướp lấy viên Đan Luyện Yêu mà Chưởng môn Vụ Sơn Phái An Xích Tiêu đã nỗ lực nghiên cứu để tẩy sạch yêu khí. Tuy nhiên, tai nạn bất ngờ ập tới, Tố Tố đã hấp thụ viên Đan Luyện Yêu, sức mạnh trong cơ thể bị loạn lạc, đánh mất trí nhớ. Cô được thần y Vô Ưu Trại là Hà An Sinh cứu sống. Trong hành trình tìm kiếm danh tính và ký ức, Hà Anh Sinh hiền lành thật thà và cô nương thân thế bí ẩn là Tiểu Bạch (Tố Tố) dần phải lòng nhau. Trong khi đó, viên Đan Luyện Yêu trong cơ thể Tố Tố lại đang tiến tới ranh giới mất kiểm soát. Liệu danh tính thực sự của Tố Tố sẽ bị tiết lộ? Người và yêu có thể đi chung một con đường? Và liệu sau hàng nghìn năm xa cách, giữa người và yêu có được hòa bình chăng?","tmdb":{"type":"movie","id":"1162216","season":null,"vote_average":4,"vote_count":1},"modified":"2025-03-20T13:32:07.000Z","cast":["Jiang Kaitong","Chen Yelin","Lý Manh Manh","Benson Wang","Gao Shuyao","Ye Xiangming","Shang Siqi","Zhang Yuxuan"],"director":["Huang Yi"],"cast_meta":[{"name":"Jiang Kaitong","name_vi":null,"name_original":"Jiang Kaitong","tmdb_id":1486438,"profile":"https://image.tmdb.org/t/p/w500/sNUBnFNJMEWDgC9ZLxfaoJ8ufnq.jpg","tmdb_url":"https://www.themoviedb.org/person/1486438"},{"name":"Chen Yelin","name_vi":null,"name_original":"Chen Yelin","tmdb_id":2192621,"profile":"https://image.tmdb.org/t/p/w500/y0tJqfOLkgG7TgtgFjdX6VIPHaH.jpg","tmdb_url":"https://www.themoviedb.org/person/2192621"},{"name":"Lý Manh Manh","name_vi":"Lý Manh Manh","name_original":"Li Mengmeng","tmdb_id":1815899,"profile":"https://image.tmdb.org/t/p/w500/bdYZXqFVTQrvyeX9razbhBI38FU.jpg","tmdb_url":"https://www.themoviedb.org/person/1815899"},{"name":"Benson Wang","name_vi":null,"name_original":"Benson Wang","tmdb_id":3579879,"profile":"https://image.tmdb.org/t/p/w500/32bHvGHZqplUSTjVwtZbyvxRDoK.jpg","tmdb_url":"https://www.themoviedb.org/person/3579879"},{"name":"Gao Shuyao","name_vi":null,"name_original":"Gao Shuyao","tmdb_id":4204719,"profile":"https://image.tmdb.org/t/p/w500/wQYxD1xxYHrUKUj1R0Lrn6TptUR.jpg","tmdb_url":"https://www.themoviedb.org/person/4204719"},{"name":"Ye Xiangming","name_vi":null,"name_original":"Ye Xiangming","tmdb_id":2022209,"profile":"https://image.tmdb.org/t/p/w500/qtCHmgDwomqAkzm1y72uN350PlP.jpg","tmdb_url":"https://www.themoviedb.org/person/2022209"},{"name":"Shang Siqi","name_vi":null,"name_original":"Shang Siqi","tmdb_id":3716407,"profile":"https://image.tmdb.org/t/p/w500/huvx52VXelBQpbD7kwE3z2pqDmI.jpg","tmdb_url":"https://www.themoviedb.org/person/3716407"},{"name":"Zhang Yuxuan","name_vi":null,"name_original":"Zhang Yuxuan","tmdb_id":2699942,"profile":"https://image.tmdb.org/t/p/w500/8vFYWSSWPIe8z48TD5jXenk4Vdy.jpg",