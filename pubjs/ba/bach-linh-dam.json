3u8"},{"name":"30","slug":"30","filename":"Bách Linh Đàm - Bai Ling Tan (Phát Song Song) - Tập 30","link_embed":"https://vip.opstream12.com/share/753a043674f0193523abc1bbce678686","link_m3u8":"https://vip.opstream12.com/20220419/11252_8282cc10/index.m3u8"},{"name":"31","slug":"31","filename":"Bách Linh Đàm - Bai Ling Tan (Phát Song Song) - Tập 31","link_embed":"https://vip.opstream12.com/share/ddfa8a1fa86914072eb6e3e55c253856","link_m3u8":"https://vip.opstream12.com/20220419/11253_eb0790db/index.m3u8"},{"name":"32","slug":"32","filename":"Bách Linh Đàm - Bai Ling Tan (Phát Song Song) - Tập 32","link_embed":"https://vip.opstream12.com/share/6cb993c8fa82ad11ff71fad64d213a72","link_m3u8":"https://vip.opstream12.com/20220419/11251_7b14b884/index.m3u8"}]}],"time":"34 phút/tập","description":"<p>Bách Linh Đàm - Bai Ling Tan kể câu chuyện của vua quỷ và công chúa xui xẻo. Họ bị lôi kéo về quá khứ trong bộ sưu tập sách. Chun Yao là người bất tử, anh có nhiệm vụ canh gác lũ quái vật tại Wangchuan, nhưng vì mắc sai lầm mà bị trục xuất khỏi thiên đường và trở thành vua của những loài quái vật ở hồ Hundred Spirits. Khi công chúa Han Sheng của Vương quốc Bailu xuống hồ, cô phát hiện ra mình đã mang theo cuốn sách mà chỉ quái vật mới có quyền sở hữu. Cô gặp Chun Yao, con người kiêu ngạo này không có cách nào giải quyết được nên chỉ có thể kéo nàng công chúa tham gia vào hành trình lật mở những điều bí mật trong cuốn sách.</p>","tmdb":{"type":"tv","id":"127973","season":1,"vote_average":6.1,"vote_count":7},"modified":"2022-05-21T08:48:31.000Z","cast":["Quách Tuấn Thần","Khang Ninh"],"director":["Huang Chun"],"cast_meta":[{"name":"Quách Tuấn Thần","name_vi":null,"name_original":"Quách Tuấn Thần"},{"name":"Khang Ninh","name_vi":null,"name_original":"Khang Ninh"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bach-linh-dam.json"}