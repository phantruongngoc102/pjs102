dex.m3u8"},{"name":"29","slug":"29","filename":"bach-ngoc-nho-vo-ha-love-like-white-jade-tap-29","link_embed":"https://vip.opstream12.com/share/3f98e3391365916c44c062a3f90d3a70","link_m3u8":"https://vip.opstream12.com/20220623/21446_80857a51/index.m3u8"},{"name":"30","slug":"30","filename":"bach-ngoc-nho-vo-ha-love-like-white-jade-tap-30","link_embed":"https://vip.opstream12.com/share/e6ad1286b0fd7a04c6aca2fa83a39d49","link_m3u8":"https://vip.opstream12.com/20220623/21447_7cb618ce/index.m3u8"},{"name":"31","slug":"31","filename":"bach-ngoc-nho-vo-ha-love-like-white-jade-tap-31","link_embed":"https://vip.opstream12.com/share/d9db2bba49b1f97833bd51b102e9a790","link_m3u8":"https://vip.opstream12.com/20220623/21448_a9807e9c/index.m3u8"},{"name":"32","slug":"32","filename":"bach-ngoc-nho-vo-ha-love-like-white-jade-tap-32","link_embed":"https://vip.opstream12.com/share/81d7409c8053a78b7582a482aa61ef99","link_m3u8":"https://vip.opstream12.com/20220623/21449_3832337b/index.m3u8"}]}],"time":"","description":"<p>Bạch Ngọc Tư Vô Hà là câu chuyện kể về công tử Giang Bạch Ngọc sống tại Giang phủ giàu có, anh sống với mục đích tìm ra chứng cứ nguyên nhân cái chết của phụ thân. Nhưng vốn là công tử yếu ớt nên anh mời Thủy Vô Hà đến để nâng cao việc học văn luyện võ. Thủy Vô Hà lớn lên tại Lang gia, là người có tính khí cao ngạo, phóng đãng nhưng lại rất ngang ngạnh và không muốn bị trói buộc của Giang Bạch Ngọc. Mục đích đồng ý đến Giang phủ của cô là tìm vị huynh ruột thất lạc, một khi đối mặt với Giang Bạch Ngọc cả hai như lửa với nước bất dung, nhưng giữa hai người cũng có những bí mật không muốn bại lộ. Bạch Ngọc Tư Vô Hà chính là hành trình đi tìm sự thật của cả hai, thế nhưng chẳng ai ngờ khi chân tướng sự việc lại hiện ra trên mặt nước. Cái chết của phụ thân Giang công tử do thúc phục Giang Hổ sát hại, còn huynh ruột của Thủy Vô Hà bị bỏ giam cùng cái chết của phụ thân Giang Bạch Ngọc. Sau đó, cả hai quyết tâm đối mặt với những khó khăn, nguy hiểm và khiến cho âm mưu của Giang Hổ bị lật đổ, sau khi trải qua chuỗi thăng trầm, cả hai cảm nhận được tình cảm của mình dành cho đối phương và quyết định chung sống với nhau suốt đời suốt kiếp.</p>","tmdb":{"type":"tv","id":"123128","season":1,"vote_average":7.1,"vote_count":22},"modified":"2022-06-23T08:42:23.000Z","cast":["Vạn Bằng","Trương Diệu","Liu Yuhan","Yu Ting'er","Ye Ke'er","Yun Xiang","Zhu Tingchen","Wang Jiayu","An Dong"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Vạn Bằng","name_vi":"Vạn Bằng","name_original":"Wan Peng","tmdb_id":2187124,"profile":"https://image.tmdb.org/t/p/w500/swgC6JHDJbvmTl4JoRdbfqf2hF.jpg","tmdb_url":"https://www.themoviedb.org/person/2187124"},{"name":"Trương Diệu","name_vi":"Trương Diệu","name_original":"Zhang Yao","tmdb_id":2190492,"profile":"https://image.tmdb.org/t/p/w500/wN5MRp4HvC5k4wYdYToXAjd0DRM.jpg","tmdb_url":"https://www.themoviedb.org/person/2190492"},{"name":"Liu Yuhan","name_vi":null,"name_original":"Liu Yuhan","tmdb_id":2446963,"profile":"https://image.tmdb.org/t/p/w500/2Bn7lKujjWNMAxPf7T6MWLTo7CG.jpg","tmdb_url":"https://www.themoviedb.org/person/2446963"},{"name":"Yu Ting'er","name_vi":null,"name_original":"Yu Ting'er","tmdb_id":2887207,"profile":"https://image.tmdb.org/t/p/w500/wkyaRLDdsDl8mmmVwEd0DhEHOsg.jpg","tmdb_url":"https://www.themoviedb.org/person/2887207"},{"name":"Ye Ke'er","name_vi":null,"name_original":"Ye Ke'er","tmdb_id":3093347,"profile":"https://image.tmdb.org/t/p/w500/y197UlXjcBk5mUdICywXSvSQ2C.jpg","tmdb_url":"https://www.themoviedb.org/person/3093347"},{"name":"Yun Xiang","name_vi":null,"name_original":"Yun Xiang","tmdb_id":3093349,"profile":"https://image.tmdb.org/t/p/w500/g717Uc66uRuq0gqWPCLiNamn4jm.jpg","tmdb_url":"https://www.themoviedb.org/person/3093349"},{"name":"Zhu Tingchen","name_vi":null,"name_original":"Zhu Tingchen","tmdb_id":3456917,"profile":"https://image.tmdb.org/t/p/w500/uP6e0PCMy99kZIc6ZWp9KJ8fIlT.jpg","tmdb_url":"https://www.themoviedb.org/person/3456917"},{"name":"Wang Jiayu","name_vi":null,"n