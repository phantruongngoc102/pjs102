kiếm tiên nhân, cô vô tình cứu sống Phạn Việt - yêu vương của yêu tộc. Từ sự gặp gỡ không ngờ, họ trải qua nhiều thăng trầm, từ lợi dụng lẫn nhau đến nảy sinh tình cảm, và cuối cùng là câu chuyện tình lãng mạn nhưng không kém phần đau thương khi cả hai đối diện với những khó khăn và chia cách. Dù có những khó khăn, tình yêu đó vẫn đủ mạnh mẽ để vượt qua mọi thử thách, ôm trọn lấy tình cảm chân thật nhất.</p><p>&nbsp;</p>","tmdb_id":238680,"cast":["Bạch Lộc","Ngao Thụy Bằng","Đại Lộ Oa","Thường Hoa Sâm","Trương Hâm","Trình Đào","Toàn Y Luân"],"director":["Chu Yui-bun"],"keywords":[],"tmdb":{"type":"tv","id":"238680","season":1,"vote_average":8.5,"vote_count":23},"cast_meta":[{"name":"Bạch Lộc","name_vi":"Bạch Lộc","name_original":"Bai Lu","tmdb_id":1879666,"profile":"https://image.tmdb.org/t/p/w500/aRcUVDRO2wewQe0NXJ0RfzSgvUa.jpg","tmdb_url":"https://www.themoviedb.org/person/1879666"},{"name":"Ngao Thụy Bằng","name_vi":"Ngao Thụy Bằng","name_original":"Ao Ruipeng","tmdb_id":2798208,"profile":"https://image.tmdb.org/t/p/w500/ixekaZD5T0rkc518UZtadioBX9z.jpg","tmdb_url":"https://www.themoviedb.org/person/2798208"},{"name":"Đại Lộ Oa","name_vi":"Đại Lộ Oa","name_original":"Dai Luwa","tmdb_id":2190499,"profile":"https://image.tmdb.org/t/p/w500/4yJZSb5RAUprTdS2dW5TdiVAWp4.jpg","tmdb_url":"https://www.themoviedb.org/person/2190499"},{"name":"Thường Hoa Sâm","name_vi":"Thường Hoa Sâm","name_original":"Chang Huasen","tmdb_id":2683711,"profile":"https://image.tmdb.org/t/p/w500/6F0qlEZS0xqgxU5lQlRqS2SiUYL.jpg","tmdb_url":"https://www.themoviedb.org/person/2683711"},{"name":"Trương Hâm","name_vi":"Trương Hâm","name_original":"Zhang Xin","tmdb_id":2486282,"profile":"https://image.tmdb.org/t/p/w500/oeYVgeHcSp9nmeu2wsNNounmopq.jpg","tmdb_url":"https://www.themoviedb.org/person/2486282"},{"name":"Trình Đào","name_vi":"Trình Đào","name_original":"Cheng Tao","tmdb_id":3216967,"profile":"https://image.tmdb.org/t/p/w500/vP4YA9oJer0hsJ5VsYlMDvkY6ok.jpg","tmdb_url":"https://www.themoviedb.org/person/3216967"},{"name":"Toàn Y Luân","name_vi":"Toàn Y Luân","name_original":"Quan Yilun","tmdb_id":4147552,"profile":"https://image.tmdb.org/t/p/w500/sg2QgHDX51EERbfN4eOmUn8djmH.jpg","tmdb_url":"https://www.themoviedb.org/person/4147552"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bach-nguyet-phan-tinh.json"}