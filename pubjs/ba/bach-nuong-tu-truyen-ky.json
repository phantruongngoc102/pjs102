re/291925ddbc6e2d194d0c22d268e0f865","link_m3u8":"https://vip.opstream17.com/20240711/14735_a3593cfb/index.m3u8"},{"name":"50","slug":"50","filename":"Bach Nuong Tu Truyen Ky 1992.50end","link_embed":"https://vip.opstream17.com/share/548bada0dbbcaf6d92cc76c5b773e7b9","link_m3u8":"https://vip.opstream17.com/20240711/14734_54082706/index.m3u8"}]}],"time":"50 phút/tập","description":"<p><i>Tân Bạch Nương Tử Truyền Kỳ phiên bản truyền hình của Triệu Nhã Chi được xem là phiên bản kinh điển, tiêu biểu và gây được ấn tượng sâu đậm trong lòng khán giả nhất. Sự đoan trang đại lượng, cao quý dịu dàng của Triệu Nhã Chi đã tạo nên hình ảnh một Bạch Xà được khán giả yêu thích nhất, đây cũng là phiên bản được phát sóng lại nhiều nhất trên truyền hình, một phiên bản bất hủ luôn được khán giả đón nhận.</i></p>","tmdb":{"type":"tv","id":"68301","season":1,"vote_average":8.6,"vote_count":16},"modified":"2024-07-11T20:40:37.000Z","cast":["Angie Chiu Nga-Chi","Diệp Đồng","Maggie Chan Mei-Kei","Chien Te-Men","Pauline Yin","江明"],"director":[],"cast_meta":[{"name":"Angie Chiu Nga-Chi","name_vi":null,"name_original":"Angie Chiu Nga-Chi","tmdb_id":327585,"profile":"https://image.tmdb.org/t/p/w500/tCaMjfyoDronfODreMxusKfQyj.jpg","tmdb_url":"https://www.themoviedb.org/person/327585"},{"name":"Diệp Đồng","name_vi":"Diệp Đồng","name_original":"Cecilia Yip Tung","tmdb_id":83696,"profile":"https://image.tmdb.org/t/p/w500/hsmFXHiHqQH2NWjdP1dZC5ItU1v.jpg","tmdb_url":"https://www.themoviedb.org/person/83696"},{"name":"Maggie Chan Mei-Kei","name_vi":null,"name_original":"Maggie Chan Mei-Kei","tmdb_id":1365929,"profile":"https://image.tmdb.org/t/p/w500/af09cDffB6EP7ZqWwuxdCi7RIsr.jpg","tmdb_url":"https://www.themoviedb.org/person/1365929"},{"name":"Chien Te-Men","name_vi":null,"name_original":"Chien Te-Men","tmdb_id":1429508,"profile":"https://image.tmdb.org/t/p/w500/3F0HShgxroe4wgTcQ5w5yKo3JjE.jpg","tmdb_url":"https://www.themoviedb.org/person/1429508"},{"name":"Pauline Yin","name_vi":null,"name_