a6e7e3f/index.m3u8"},{"name":"41","slug":"41","filename":"Bản Án Lương Tâm - Surgeons - Tập 41","link_embed":"https://vip.opstream11.com/share/bfc89c3ee67d881255f8b097c4ed2d67","link_m3u8":"https://vip.opstream11.com/20220403/8946_3d857ed8/index.m3u8"},{"name":"42","slug":"42","filename":"Bản Án Lương Tâm - Surgeons - Tập 42","link_embed":"https://vip.opstream11.com/share/d0f82e1046ccbd597c7f2a7bfba9e7dd","link_m3u8":"https://vip.opstream11.com/20220403/8947_59cf8926/index.m3u8"},{"name":"43","slug":"43","filename":"Bản Án Lương Tâm - Surgeons - Tập 43","link_embed":"https://vip.opstream11.com/share/9c58da3f0418ebdb53c02615f9ab7282","link_m3u8":"https://vip.opstream11.com/20220403/8948_a5b7cbab/index.m3u8"},{"name":"44","slug":"44","filename":"Bản Án Lương Tâm - Surgeons - Tập 44","link_embed":"https://vip.opstream11.com/share/49afa3a1bba5280af6c4bf2fb5ea7669","link_m3u8":"https://vip.opstream11.com/20220403/8949_0548faf7/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Phim nói về câu chuyện phức tạp xuất phát từ “tai nạn” của 29 năm trước đã thay đổi vận mệnh của hai thế hệ tại một bệnh viện đang trên đà hiện đại hóa - Bệnh viện Nhân Hợp Tân Thành. Một ca cấp cứu tai nạn giao thông đã thành công nhưng lại xuất hiện phản ứng dị ứng thuốc mà tử vong, dẫn đến nhiều nghi vấn; y tá phụ trách đêm đó là Trương Thục Mai vì bị nghi ngờ nên đã bị buộc phải nghỉ việc. Cô con gái 4 tuổi của Trương Thục Mai là Oánh Oánh (chính là Lâm Hoan sau này do Cao Lộ thủ vai) vì không tin vào những lời dèm pha về mẹ mình mà đánh nhau nên bị phạt, trên đường chạy về nhà đã bị bắt cóc. Trương Thục Mai mải miết đi tìm con gái đến suy sụp tinh thần, 2 năm sau đã tử vong trong một vụ tai nạn giao thông.</p>","tmdb":{"type":"tv","id":"71272","season":1,"vote_average":6.5,"vote_count":2},"modified":"2023-07-13T10:32:52.000Z","cast":["Zhou Le","Jin Zehao","Lý Giai Hàng","Jin Dong","Bạch Bách Hà","Lưu Dịch Quân","Hu Ge","Ninh Văn Đồng","Wang Yinan","Geng Le","Feng Hui","Cao Lộ","Kim Sĩ Kiệt