am10.com/share/4f7146f3ccda08de84a2fc8b92305691","link_m3u8":"https://vip.opstream10.com/20260110/32267_4f7146f3/index.m3u8"}]}],"time":"80 phút/tập","description":"<p>Một trong những MC giỏi nhất đất nước, Yoo Jae-suk, thường hỏi về cách những người khác chơi vào ngày nghỉ của họ. Anh ấy đã nói điều này theo thói quen. Câu nói này của anh ấy đã khơi dậy một ý tưởng trong đầu Kim Tae-ho. Anh ấy nảy ra ý tưởng quay phim những người nổi tiếng vào ngày nghỉ của họ bằng máy quay tiếp sức. Vì vậy, Tae-ho đã đưa cho Jae-suk một chiếc máy quay nhỏ và di động. Tae-ho chỉ để Jae-suk một mình sau khi đưa cho anh ấy một chiếc máy quay. Lúc đầu, Jae-suk đã rất ngạc nhiên nhưng vẫn đồng ý với ý tưởng này. Bắt đầu với Jae-suk, những người nổi tiếng được trao một chiếc máy quay để quay lại lối sống hàng ngày của họ. Một số người có thể tập luyện để có được vóc dáng cân đối, một số người có thể chỉ đơn giản là nghỉ ngơi sau lịch trình mệt mỏi của họ, và những người khác có thể gặp gỡ những người bạn mà họ không có thời gian. Từ những diễn viên hài nổi tiếng đến những siêu sao toàn cầu, máy quay tiếp sức ghi lại những câu chuyện bất ngờ và độc đáo. Hãy xem những người nổi tiếng đang làm gì vào ngày nghỉ của họ và khám phá điều gì đó mới mẻ về họ.</p>","tmdb":{"type":"tv","id":"91121","season":1,"vote_average":7.7,"vote_count":20},"modified":"2026-01-10T16:27:37.000Z","cast":["Yoo Jae-suk"],"director":["김태호","Chae Hyun-seok"],"cast_meta":[{"name":"Yoo Jae-suk","name_vi":"Yoo Jae-suk","name_original":"Yoo Jae-suk","tmdb_id":1239240,"profile":"https://image.tmdb.org/t/p/w500/1uktAM7R2Hgc3dynIXvzfACOmnW.jpg","tmdb_url":"https://www.themoviedb.org/person/1239240"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/ban-choi-the-nao.json"}