97b19bcc1a3eda1ac864","link_m3u8":"https://vip.opstream15.com/20221019/27490_86f330b7/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/d2d26584b4ffbf0de1af4a7e9ecf3b68","link_m3u8":"https://vip.opstream15.com/20221020/27505_d5bc4bd6/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/63c94b74065fc62f96c334f08c534843","link_m3u8":"https://vip.opstream15.com/20221020/27503_66bb61fe/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/779146e5712cfe402503e06a5184bd69","link_m3u8":"https://vip.opstream15.com/20221021/27534_19dad317/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/6cc1137b9d0a4ca7f85032e38705655c","link_m3u8":"https://vip.opstream15.com/20221021/27535_4a4530b5/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream16.com/share/40a8e50752d27a50d1aed5747991505f","link_m3u8":"https://vip.opstream16.com/20221022/24582_f2e8538c/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream15.com/share/d012c46243d7e2391b64b221dfcc18e3","link_m3u8":"https://vip.opstream15.com/20221022/27537_f3d52759/index.m3u8"}]}],"description":"<p>Xoay quanh câu chuyện về luật sư tài năng Kha Chấn Vũ khi anh trải qua sự tuột dốc của sự nghiệp và sau đó chuyển đến sống tại một căn hộ cũ. Với một cơ duyên thần bí nào đó, anh chàng gặp được nữ phóng viên Trình Gia Lạc vô tình xuyên không đến nơi đây. Cô nàng nói rằng mình là người đến từ thời điểm bốn tháng trước và giờ đây họ bị buộc trở thành bạn cùng phòng của nhau. Do sự hợp nhất giữa thời gian và không gian trong 46 phút mỗi đêm, câu chuyện của cặp đôi trong bộ phim Bạn Cùng Phòng Bí Mật Của Tôi đã bắt đầu và tạo ra một tình yêu du hành xuyên thời gian và không gian kỳ lạ và lãng mạn.</p>","tmdb_id":212231,"cast":[],"director":[],"keywords":[],"tmdb":{"id":212231},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/