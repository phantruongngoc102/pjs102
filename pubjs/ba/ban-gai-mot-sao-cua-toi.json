bcb020b8d1994192dda6d97e3","link_m3u8":"https://vip.opstream15.com/20250328/51207_e357bafb/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/d125042b7551a5f2034940f7238d7a7b","link_m3u8":"https://vip.opstream15.com/20250329/51252_d125042b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/8c04d578efdc12dd6e347154a1e08bce","link_m3u8":"https://vip.opstream15.com/20250330/51293_8c04d578/index.m3u8"}]}],"description":"<p>Một lần tình cờ, Dịch Nhiên, người sống nhờ đủ loại công việc bán thời gian, trở thành người đánh giá khách sạn năm sao, đồng thời quen biết Tiêu Mục Thừa trong tình huống trớ trêu. Không ngờ Tiêu Mục Thừa lại là giám đốc khách sạn, cấp trên trực tiếp của Dịch Nhiên. Trong công việc thường ngày ở khách sạn, hai người gặp phải đủ loại khách hàng cũng như những khó khăn trong việc quản lý khách sạn. Dịch Nhiên và Tiêu Mục Thừa cùng nhau hợp tác để giải quyết những khủng hoảng đó. Hai con người thuộc hai thế giới khác nhau, dù liên tục xảy ra mâu thuẫn trong cuộc sống thường ngày, nhưng họ không nhận ra rằng mình lại vô tình xích gần nhau hơn...</p><p>&nbsp;</p>","tmdb_id":272030,"cast":["Hình Chiêu Lâm","Lư Dương Dương","Jeffrey Tung","Sita Huang","Bao Lining","Bai Xuhan"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"272030","season":1,"vote_average":6.8,"vote_count":3},"cast_meta":[{"name":"Hình Chiêu Lâm","name_vi":"Hình Chiêu Lâm","name_original":"Xing Zhaolin","tmdb_id":1855299,"profile":"https://image.tmdb.org/t/p/w500/8UPCvdZggQhuzCGkXvSOJ8EMqdI.jpg","tmdb_url":"https://www.themoviedb.org/person/1855299"},{"name":"Lư Dương Dương","name_vi":"Lư Dương Dương","name_original":"Lu Yangyang","tmdb_id":2295780,"profile":"https://image.tmdb.org/t/p/w500/hwcIF6awLZPiQI2UU9YCo4Ubuli.jpg","tmdb_url":"https://www.themoviedb.org/person/2295780"},{"name":"Jeffrey Tung","name_vi":"Jeffrey Tung","name_original":"Jeffrey Dong","tmdb_id":2397757,"profile":"https://image.tmdb.org/t/p/w500/6