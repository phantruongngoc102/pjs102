8ec1e34a4aeedecddc8","link_m3u8":"https://vip.opstream-short.com/20251031/3302_6fab6e3a/index.m3u8"}]}],"time":"2 phút/tập","description":"Lâm Tiểu Mộng, xuất thân từ gia đình nghèo, gặp Lâm Thiên Tường tại một bữa tiệc và nhầm anh là sinh viên đại học bình thường. Hai người nhanh chóng yêu nhau. Trong quá trình hẹn hò, Lâm Tiểu Mộng tình cờ phát hiện Lâm Thiên Tường thực chất là con trai của gia tộc giàu nhất, đồng thời cô cũng khám phá ra danh tính thật của mình là &quot;tiểu thư nhà giàu sa sút,&quot; khiến cô lo lắng về khoảng cách địa vị xã hội. Tuy nhiên, Lâm Thiên Tường đã biết tất cả từ đầu và trân trọng sự chân thành, tốt bụng của cô, luôn bảo vệ cô. Cả hai cùng nhau vượt qua những nghi ngờ từ bên ngoài và trở ngại từ gia đình. Với sự hỗ trợ của Lâm Thiên Tường, Lâm Tiểu Mộng thích nghi với danh tính mới và cuối cùng thu được tình yêu hoàn hảo cùng cuộc sống hạnh phúc.","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-06T10:09:47.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ba/ban-gai-ngheo-hoa-ra-la-tieu-thu-nha-giau-short-drama.json","keywords":[],"tmdb_checked":false}