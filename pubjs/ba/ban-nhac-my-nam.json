":"15","slug":"15","filename":"ban-nhac-my-nam-tap-15","link_embed":"https://vip.opstream12.com/share/d814f4e3dcf9e6f473e213232b9ba115","link_m3u8":"https://vip.opstream12.com/20220324/5166_c9d45383/index.m3u8"},{"name":"16","slug":"16","filename":"ban-nhac-my-nam-tap-16","link_embed":"https://vip.opstream12.com/share/8c4f839b287d8a4d311eeaad4f8ceb97","link_m3u8":"https://vip.opstream12.com/20220324/5167_83fee7f0/index.m3u8"}]}],"time":"44M54S","description":"<p>Đây là bộ phim mới xoay quanh đề tài về một band nhạc rock, vậy nên đã chọn ra những gương mặt hoàn toàn mới để tham gia diễn xuất. Tên của bộ phim là \\\"Ban Nhạc Mỹ Nam\\\" kể câu chuyện về tình bạn, niềm đam mê âm nhạc, và tình yêu xoay quanh ban nhạc gồm những anh chàng học sinh trung học đẹp trai, có tâm hồn tự do, phóng khoáng : Ji Hyuk, Hyun Soo, Ha Jin, Do Il, Kyung Jong. Dù chỉ là những nam sinh còn ngồi trên ghế nhà trường, nhưng cả năm chàng trai luôn có cùng một đam mê cháy bỏng với âm nhạc, họ thành lập ban nhạc rock underground Eye Candy và mong muốn sẽ trở nên nổi tiếng.</p>","tmdb":{"type":"tv","id":"44787","season":1,"vote_average":6,"vote_count":12},"modified":"2023-08-07T15:45:56.000Z","cast":["Sung Joon","L","Lee Hyun-jae","Kim Min-seok","Yoo Min-kyu","Cho Bo-ah","Jung Eui-chul","Kim Jung-min","Lim Kim","Kim In-seo","Kwak Jung-wook","Kim Hyun-joon","Jung Jin-an","Dong Hyun-bae","Yum Jung-ah"],"director":["Li Quan"],"cast_meta":[{"name":"Sung Joon","name_vi":null,"name_original":"Sung Joon","tmdb_id":1254579,"profile":"https://image.tmdb.org/t/p/w500/375rx6041ov9kLc6G36CGf4kwx4.jpg","tmdb_url":"https://www.themoviedb.org/person/1254579"},{"name":"L","name_vi":null,"name_original":"L","tmdb_id":1256345,"profile":"https://image.tmdb.org/t/p/w500/iOL7wp1qvjfvAUnHVGMUNnIRZaY.jpg","tmdb_url":"https://www.themoviedb.org/person/1256345"},{"name":"Lee Hyun-jae","name_vi":null,"name_original":"Lee Hyun-jae","tmdb_id":1256346,"profile":"https://image.tmdb.org/t/p/w500/nkzqHwm4IDd1F2NAWVGuXEctdEK.jpg