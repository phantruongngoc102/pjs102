g, tay nghề ngày càng tăng tiếc rằng Quang quá ham danh lợi đã mờ mắt mà bán rẻ đi người bạn của mình và cũng để mất đi mối tình với Hiền…</i></p>","tmdb":{"type":"tv","id":"108088","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-03T15:38:20.000Z","cast":["Huỳnh Nhật Hoa","Kit-wah Leung","Eugina Lau Mei-Guen","Anthony Tang Ho-Kwong","Ngô Mạnh Đạt","Lạc Ứng Quân","Debbie Chui","La Lan","Ricky Wong Chung-Tsu","Tony Leung Hung-Wah","Tam Bing-Man","Pak Yan","Jeng Gwan-Chi","Au Ngok","Keith Ng Shui-Ting"],"director":["Vương Tâm Ủy"],"cast_meta":[{"name":"Huỳnh Nhật Hoa","name_vi":"Huỳnh Nhật Hoa","name_original":"Felix Wong Yat-Wah","tmdb_id":71655,"profile":"https://image.tmdb.org/t/p/w500/9HooA3aF764XKYU8GUxO4P7v5gZ.jpg","tmdb_url":"https://www.themoviedb.org/person/71655"},{"name":"Kit-wah Leung","name_vi":null,"name_original":"Kit-wah Leung","tmdb_id":3971206,"profile":"https://image.tmdb.org/t/p/w500/40FpOBZTXP8g0lhujARoZNZr4Iv.jpg","tmdb_url":"https://www.themoviedb.org/person/3971206"},{"name":"Eugina Lau Mei-Guen","name_vi":null,"name_original":"Eugina Lau Mei-Guen","tmdb_id":1395293,"profile":"https://image.tmdb.org/t/p/w500/pp8u5ab5FKgBn6Ie4bhRO3AVkjK.jpg","tmdb_url":"https://www.themoviedb.org/person/1395293"},{"name":"Anthony Tang Ho-Kwong","name_vi":null,"name_original":"Anthony Tang Ho-Kwong","tmdb_id":1402393,"profile":"https://image.tmdb.org/t/p/w500/h24HzZ6L9cuoYsba9ZWQba4P9Eg.jpg","tmdb_url":"https://www.themoviedb.org/person/1402393"},{"name":"Ngô Mạnh Đạt","name_vi":"Ngô Mạnh Đạt","name_original":"Richard Ng Man-Tat","tmdb_id":70437,"profile":"https://image.tmdb.org/t/p/w500/l8Sfi9pT0YcyzGy0bt7XwY8OEBo.jpg","tmdb_url":"https://www.themoviedb.org/person/70437"},{"name":"Lạc Ứng Quân","name_vi":"Lạc Ứng Quân","name_original":"Felix Lok Ying-Kwan","tmdb_id":127436,"profile":"https://image.tmdb.org/t/p/w500/4tVJDVbhH9LNiubcGJ8qDYiQznh.jpg","tmdb_url":"https://www.themoviedb.org/person/127436"},{"name":"Debbie Chui","name_vi":null,"name_ori