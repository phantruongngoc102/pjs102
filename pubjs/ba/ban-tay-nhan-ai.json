45 phút/tập","description":"<p>\"Bàn tay nhân ái\" phản ánh chân thực cuộc sống của những người trẻ có học thức trong xã hội đương đại. Bộ phim xoay quanh câu chuyện của một nhóm bác sĩ có tên là Nhân Ái. Trình Chí Mỹ (do Ngô Khải Hoa đóng) là bác sĩ hàng đầu của khoa ngoại não. Anh luôn được bạn bè ngưỡng mộ không chỉ ở thái độ làm việc nghiêm túc, hết lòng với bệnh nhân mà còn bởi anh có một gia đình hạnh phúc. Thế nhưng, vì tận tụy trong công việc, anh đã vô tình để vợ mình chịu đựng nỗi cô đơn trong nhiều năm. Cuộc hôn nhân của họ tan vỡ.</p>","tmdb":{"type":"tv","id":"20464","season":1,"vote_average":7.6,"vote_count":7},"modified":"2023-02-17T20:29:28.000Z","cast":["Ngô Khải Hoa","Lâm Bảo Di","Trần Hào","Lê Tư","Melissa Ng Mei-Heng","Thiệu Mỹ Kỳ","Claire Yiu","Tào Vĩnh Liêm","Liêu Bích Nhi","Đường Văn Long","Timothy Cheng Chi-Sing","Huỳnh Đức Bân","Sam Chan","Lạc Ứng Quân","Joseph Yeung"],"director":["loading"],"cast_meta":[{"name":"Ngô Khải Hoa","name_vi":"Ngô Khải Hoa","name_original":"Lawrence Ng Kai-Wah","tmdb_id":122818,"profile":"https://image.tmdb.org/t/p/w500/nOgwDEg0QSavgTo9mscVSkKTpLa.jpg","tmdb_url":"https://www.themoviedb.org/person/122818"},{"name":"Lâm Bảo Di","name_vi":"Lâm Bảo Di","name_original":"Bowie Lam Bo-Yee","tmdb_id":552084,"profile":"https://image.tmdb.org/t/p/w500/7scIX24RyIlibdyeXljnEPjXeKO.jpg","tmdb_url":"https://www.themoviedb.org/person/552084"},{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Lê Tư","name_vi":"Lê Tư","name_original":"Gigi Lai Chi","tmdb_id":67224,"profile":"https://image.tmdb.org/t/p/w500/1lAKx9141UsF506bXGRLEaDztjO.jpg","tmdb_url":"https://www.themoviedb.org/person/67224"},{"name":"Melissa Ng Mei-Heng","name_vi":null,"name_original":"Melissa Ng Mei-Heng","tmdb_id":1254988,"profile":"https://image.tmdb.org/t/p/w500/pppZuVpAI9diCIwzo6Jdp