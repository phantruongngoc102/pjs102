embed":"https://vip.opstream12.com/share/07a9d3fed4c5ea6b17e80258dee231fa","link_m3u8":"https://vip.opstream12.com/20220303/2448_b2192bfd/index.m3u8"},{"name":"40","slug":"40","filename":"Bản Tình Ca Mùa Đông - Winter Sonata - Tập 40","link_embed":"https://vip.opstream12.com/share/61d77652c97ef636343742fc3dcf3ba9","link_m3u8":"https://vip.opstream12.com/20220303/2449_171a35f8/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>\"Phim mở đầu tại Chuncheon, Hàn Quốc với đôi bạn thân Jung Yu-Jin và Kim Sang-Hyuk. Hai người là bạn thân từ nhỏ với nhau, hơn nữa Sang-Hyuk lại có tình cảm đặc biệt dành cho Yu-Jin nhưng không được đáp lại. Một lần đi học trên xe bus, Yu-Jin ngồi cạnh một nam sinh là Kang Joon-Sang, người mới chuyển trường từ Seoul đến, cả hai đã có một ấn tượng mạnh mẽ với nhau ngay từ đầu. Kang Joon-Sang là nam sinh điển trai, ưu tú, gây được sự chú ý của nhiều người, trong đó có Oh Chae-rin là bạn của Yu-Jin và Sang-Hyuk. Oh Chae-rin có ý định theo đuổi Joon-Sang nhưng lại bị vẻ lạnh lùng của anh làm cho thất vọng.</p>","tmdb":{"type":"tv","id":"12539","season":1,"vote_average":8.315,"vote_count":149},"modified":"2023-07-19T08:19:47.000Z","cast":["Bae Yong-jun","Choi Ji-woo","Park Yong-ha","Park Sol-mi","Lee Hae-eun","Ryu Seung-su","Song Ok-suk","Jeong Dong-hwan","Kim Hae-sook","Jang Hang-seon","Jung Won-joong","Ha Jae-yeong","Lee Hyo-choon"],"director":["Lee Hyung-min","Yoon Seok-ho"],"cast_meta":[{"name":"Bae Yong-jun","name_vi":null,"name_original":"Bae Yong-jun","tmdb_id":307481,"profile":"https://image.tmdb.org/t/p/w500/d3NZRKhnh3rqWQyUioMmXufbnqR.jpg","tmdb_url":"https://www.themoviedb.org/person/307481"},{"name":"Choi Ji-woo","name_vi":null,"name_original":"Choi Ji-woo","tmdb_id":62333,"profile":"https://image.tmdb.org/t/p/w500/ysPp0U285rWrCBlo0AfKFbpwoOH.jpg","tmdb_url":"https://www.themoviedb.org/person/62333"},{"name":"Park Yong-ha","name_vi":null,"name_original":"Park Yong-ha","tmdb_id":84784,"profile":"https://image.tmdb.org/t/p/w500/ndywBX