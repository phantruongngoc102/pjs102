e7ffcf7d","link_m3u8":"https://vip.opstream15.com/20221016/27389_48dd722f/index.m3u8"},{"name":"23","slug":"23","filename":"ban-trai-phan-dien-cua-toi-mr-bad-tap-23","link_embed":"https://vip.opstream15.com/share/27a1e0e31bf1a18797d26f7796f1ae4e","link_m3u8":"https://vip.opstream15.com/20221017/27443_5d843c13/index.m3u8"},{"name":"24","slug":"24","filename":"ban-trai-phan-dien-cua-toi-mr-bad-tap-24","link_embed":"https://vip.opstream15.com/share/a49477811ea58f8124ba7af69931ffa6","link_m3u8":"https://vip.opstream15.com/20221017/27444_4ab4ebf6/index.m3u8"}]}],"time":"42 phút/tập","description":"<p>Là bộ phim tình yêu hài hước với tình tiết đặc biệt do Lý Thanh Dung đạo diễn, với sự tham gia của các diễn viên Trần Triết Viễn, Thẩm Nguyệt, Đổng Tuyền, Thiệu Phong, Vương Tự Kiện. Nam Tinh (do Thẩm Nguyệt thủ vai) là một cô gái có sở thích viết tiểu thuyết, trong lúc cầu nguyện đã vô tình triệu hồi nhân vật phản diện Tiêu Vô Địch (do Trần Triết Viễn thủ vai) trong cuốn tiểu thuyết của cô. Tiêu Vô Địch thông minh và xảo quyệt vừa mới đến thế giới này, đã đe dọa Nam Tinh và sống cạnh nhà cô ấy, hai người họ bắt đầu một cuộc sống tranh giành và bất đồng.</p>","tmdb":{"type":"tv","id":"210732","season":1,"vote_average":7.8,"vote_count":18},"modified":"2025-04-26T12:57:03.000Z","cast":["Trần Triết Viễn","Thẩm Nguyệt","Lạc Minh Cật","Qu Jingjing","Đổng Huyền","Thiệu Phong","Zhao Simei"],"director":["Li Qing Rong"],"cast_meta":[{"name":"Trần Triết Viễn","name_vi":"Trần Triết Viễn","name_original":"Chen Zheyuan","tmdb_id":2439184,"profile":"https://image.tmdb.org/t/p/w500/uOEqq05ghCxZXn7w92nriHu0T5A.jpg","tmdb_url":"https://www.themoviedb.org/person/2439184"},{"name":"Thẩm Nguyệt","name_vi":"Thẩm Nguyệt","name_original":"Shen Yue","tmdb_id":1922808,"profile":"https://image.tmdb.org/t/p/w500/za5X2mJ8Q38jjo07ON0l3bP96AR.jpg","tmdb_url":"https://www.themoviedb.org/person/1922808"},{"name":"Lạc Minh Cật","name_vi":"Lạc Minh Cật","name_original":"Luo Mingjie","tmdb_id":2359338,"profil