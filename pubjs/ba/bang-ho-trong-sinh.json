ột mối quan hệ gắn bó sâu sắc giữa hai người. Tuy nhiên, khi tham vọng xung đột và lòng tin bị phản bội, Chu Qiao thấy mình bị cuốn vào những cuộc đấu tranh quyền lực và hành trình tìm kiếm công lý. Giữa những biến động chính trị và sự hy sinh cá nhân, cô vươn lên như một biểu tượng của hy vọng, chiến đấu để bảo vệ người dân và quê hương mình.</p>","tmdb_id":278894,"cast":["Lý Quân Nhuệ","Hoàng Dương Điền Điềm","Zhang Kangle","Hí Dương","Li Xiaoqian"],"director":["侣皓吉吉"],"keywords":[],"tmdb":{"type":"tv","id":"278894","season":1,"vote_average":7.5,"vote_count":2},"cast_meta":[{"name":"Lý Quân Nhuệ","name_vi":"Lý Quân Nhuệ","name_original":"Li Yunrui","tmdb_id":2306608,"profile":"https://image.tmdb.org/t/p/w500/lmWu3qwmdwGv9qmcS3vbjj5Bkao.jpg","tmdb_url":"https://www.themoviedb.org/person/2306608"},{"name":"Hoàng Dương Điền Điềm","name_vi":"Hoàng Dương Điền Điềm","name_original":"Huangyang Tiantian","tmdb_id":3369916,"profile":"https://image.tmdb.org/t/p/w500/iRLjxCAWVjJTcmwt6dIG92zkItC.jpg","tmdb_url":"https://www.themoviedb.org/person/3369916"},{"name":"Zhang Kangle","name_vi":null,"name_original":"Zhang Kangle","tmdb_id":3503858,"profile":"https://image.tmdb.org/t/p/w500/uU9xZH9CEuHt4ZK6CS3VlSbI1Vz.jpg","tmdb_url":"https://www.themoviedb.org/person/3503858"},{"name":"Hí Dương","name_vi":"Hí Dương","name_original":"Xia Meng","tmdb_id":3091307,"profile":"https://image.tmdb.org/t/p/w500/svkFlNuk3WwKn7AdnfRx5W7yF56.jpg","tmdb_url":"https://www.themoviedb.org/person/3091307"},{"name":"Li Xiaoqian","name_vi":null,"name_original":"Li Xiaoqian","tmdb_id":3190362,"profile":"https://image.tmdb.org/t/p/w500/72w17dAwQOLwbcs9bI7nW13ZeMT.jpg","tmdb_url":"https://www.themoviedb.org/person/3190362"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bang-ho-trong-sinh.json"}