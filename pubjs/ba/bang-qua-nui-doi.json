43","link_embed":"https://vip.opstream10.com/share/47810f956e3d8fb8a32fb276448b464d","link_m3u8":"https://vip.opstream10.com/20220327/2292_2349342f/index.m3u8"},{"name":"44","slug":"44","filename":"bang-qua-nui-doi-tap-44","link_embed":"https://vip.opstream10.com/share/5f6371c9126149517d9ba475def53139","link_m3u8":"https://vip.opstream10.com/20220327/2293_fe6fa485/index.m3u8"}]}],"time":"45M1S","description":"<p>Âu Dương Hạ Lan (Trương Lệ đóng) là một người điều tra thương nghiệp, trong một lần chấp hành nhiệm vụ đã vô tình gặp được Bành Việt (Cao Hãn Vũ đóng) con trai thứ hai của tập đoàn Thiên Quan, người sáng lập tổ chức nghiên cứu và phát triển hãng xe hơi “Băng Qua Núi Đồi”. Hai người cùng trải qua những biến cố, vượt qua muôn vàn khó khăn cuối cùng hợp tác gây dựng cho thế giới thấy được những thành tựu của Trung Quốc trong lĩnh vực xe hơi năng lượng mới.</p>","tmdb":{"type":"tv","id":"111465","season":1,"vote_average":2,"vote_count":1},"modified":"2023-04-23T19:48:16.000Z","cast":["Trương Lệ","Cao Hãn Vũ","Zhou Qiqi","Jiang Bing","Liu Xiaohai","Zhang Yangzhizi","Khấu Chấn Hải","Ning Li","Wang Gang","Bai Jingjing","Yan Jingyao","Li Honglei","Zhao Yutong"],"director":["Shen Yu Jie"],"cast_meta":[{"name":"Trương Lệ","name_vi":"Trương Lệ","name_original":"Zhang Li","tmdb_id":1993060,"profile":"https://image.tmdb.org/t/p/w500/eEvYNGg8NnyQlH1wWUcXdWvDEMB.jpg","tmdb_url":"https://www.themoviedb.org/person/1993060"},{"name":"Cao Hãn Vũ","name_vi":"Cao Hãn Vũ","name_original":"Gao Hanyu","tmdb_id":1803094,"profile":"https://image.tmdb.org/t/p/w500/n6eL09UQJWmonGXPDYIkCNpr8ay.jpg","tmdb_url":"https://www.themoviedb.org/person/1803094"},{"name":"Zhou Qiqi","name_vi":null,"name_original":"Zhou Qiqi","tmdb_id":543160,"profile":"https://image.tmdb.org/t/p/w500/2Sob9mjw8LJCDrfTES9tGu1GZM5.jpg","tmdb_url":"https://www.themoviedb.org/person/543160"},{"name":"Jiang Bing","name_vi":null,"name_original":"Jiang Bing","tmdb_id":3473663,"profile":"https://image.tmdb.org/t/p/w500/eo