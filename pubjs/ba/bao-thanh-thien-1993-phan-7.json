":"22","filename":"bao-thanh-thien-1993-phan-7-justice-bao-7-tap-22","link_embed":"https://vip.opstream15.com/share/ab24cd2b811ee48a416fc7a833d736a9","link_m3u8":"https://vip.opstream15.com/20220415/4114_4da29889/index.m3u8"},{"name":"23","slug":"23","filename":"bao-thanh-thien-1993-phan-7-justice-bao-7-tap-23","link_embed":"https://vip.opstream15.com/share/a5ff5d4b0a0d7b3e4d64147037d8c344","link_m3u8":"https://vip.opstream15.com/20220415/4115_849855bf/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phủ Khai Phong có Bao Thanh Thiên, thiết diện vô tư xử ngay gian, nghĩa hiệp Triển Chiêu đến trợ giúp, Vương Triều Mã Hán ở cạnh bên. Nhắc đến Bao Thanh Thiên là nhắc đến vị quan mặt sắt đen sì, mà lòng sáng như gương, thanh liêm chính trực, chí công vô tư, không sợ cường quyền, sẵn sàng vì dân kêu oan, ngày xử án dương gian, đêm xử án âm phủ. Những câu chuyện kể về Bao Thanh Thiên luôn là những câu chuyện kể hoài không hết, luôn làm say mê lòng người.</p>","tmdb":{"type":"tv","id":"51821","season":7,"vote_average":8.4,"vote_count":12},"modified":"2023-07-04T18:28:43.000Z","cast":["Kim Siêu Quần","Phạm Hồng Hiên","Hà Gia Kính","Kao Nien Kuo","Jianyu Xu","Liu Yue-Ti","Yang Hsiung","Changsen Shao","Lung Lung","Tu Man-Sheng","Tsao Chien","Sun Peng","Wang Chung-huang","Shi Yu","Tseng Ya-chun"],"director":["Tô Nguyên Phong","Đặng Dục Khánh"],"cast_meta":[{"name":"Kim Siêu Quần","name_vi":"Kim Siêu Quần","name_original":"Jin Chao-Chun","tmdb_id":1260190,"profile":"https://image.tmdb.org/t/p/w500/e6EkRZzVLsjRaAVKv4MTaLiiTlB.jpg","tmdb_url":"https://www.themoviedb.org/person/1260190"},{"name":"Phạm Hồng Hiên","name_vi":"Phạm Hồng Hiên","name_original":"Hung-Hsuan Fan","tmdb_id":3105961,"profile":"https://image.tmdb.org/t/p/w500/gC2ay19TdkzpgyRIW7E6UtxbTIU.jpg","tmdb_url":"https://www.themoviedb.org/person/3105961"},{"name":"Hà Gia Kính","name_vi":"Hà Gia Kính","name_original":"Kenny Ho Ka-King","tmdb_id":109506,"profile":"https://image.tmdb.org/t/p/w500/6gQZYCr0ts1NAfCDNb