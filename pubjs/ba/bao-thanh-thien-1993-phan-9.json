.com/share/0ef037ce94ff9b7930d095a7e2ffee1f","link_m3u8":"https://vip.opstream10.com/20220415/7863_4c42a17a/index.m3u8"},{"name":"22","slug":"22","filename":"bao-thanh-thien-1993-phan-9-justice-bao-9-tap-22","link_embed":"https://vip.opstream10.com/share/1963bd5135521d623f6c29e6b1174975","link_m3u8":"https://vip.opstream10.com/20220415/7866_c35798eb/index.m3u8"},{"name":"23","slug":"23","filename":"bao-thanh-thien-1993-phan-9-justice-bao-9-tap-23","link_embed":"https://vip.opstream10.com/share/10fb6cfa4c990d2bad5ddef4f70e8ba2","link_m3u8":"https://vip.opstream10.com/20220415/7867_4f7bf2b1/index.m3u8"},{"name":"24","slug":"24","filename":"bao-thanh-thien-1993-phan-9-justice-bao-9-tap-24","link_embed":"https://vip.opstream10.com/share/2b8501af7b64d1aaae7dd832805f0709","link_m3u8":"https://vip.opstream10.com/20220415/7868_a8e37dbd/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phủ Khai Phong có Bao Thanh Thiên, thiết diện vô tư xử ngay gian, nghĩa hiệp Triển Chiêu đến trợ giúp, Vương Triều Mã Hán ở cạnh bên. Nhắc đến Bao Thanh Thiên là nhắc đến vị quan mặt sắt đen sì, mà lòng sáng như gương, thanh liêm chính trực, chí công vô tư, không sợ cường quyền, sẵn sàng vì dân kêu oan, ngày xử án dương gian, đêm xử án âm phủ. Những câu chuyện kể về Bao Thanh Thiên luôn là những câu chuyện kể hoài không hết, luôn làm say mê lòng người.</p>","tmdb":{"type":"tv","id":"51821","season":9,"vote_average":8.4,"vote_count":12},"modified":"2023-07-05T20:18:04.000Z","cast":["Kim Siêu Quần","Phạm Hồng Hiên","Hà Gia Kính","Kao Nien Kuo","Jianyu Xu","Liu Yue-Ti","Yang Hsiung","Changsen Shao","Lung Lung","Tu Man-Sheng","Tsao Chien","Sun Peng","Wang Chung-huang","Shi Yu","Tseng Ya-chun"],"director":["Tô Nguyên Phong","Đặng Dục Khánh"],"cast_meta":[{"name":"Kim Siêu Quần","name_vi":"Kim Siêu Quần","name_original":"Jin Chao-Chun","tmdb_id":1260190,"profile":"https://image.tmdb.org/t/p/w500/e6EkRZzVLsjRaAVKv4MTaLiiTlB.jpg","tmdb_url":"https://www.themoviedb.org/person/1260190"},{"name":"Ph