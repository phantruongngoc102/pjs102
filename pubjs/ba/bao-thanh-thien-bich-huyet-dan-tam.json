ttps://vip.opstream17.com/share/197e211074370064b2aff27ac8fd441d","link_m3u8":"https://vip.opstream17.com/20240813/16699_2ea2f0a7/index.m3u8"},{"name":"39","slug":"39","filename":"Bao Thanh Thiên - Bích Huyết Đan Tâm - Tập 39","link_embed":"https://vip.opstream17.com/share/29282505fa1675d9c26d7ad4868b8727","link_m3u8":"https://vip.opstream17.com/20240813/16700_62a1ab78/index.m3u8"},{"name":"40","slug":"40","filename":"Bao Thanh Thiên - Bích Huyết Đan Tâm - Tập 40","link_embed":"https://vip.opstream17.com/share/cea64a883d35e5409c4bc81bdaedd55e","link_m3u8":"https://vip.opstream17.com/20240813/16701_187fe745/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Bao Thanh Thiên Bích Huyết Đan Tâm - Justice Bao: Arbiter of Loyalty Unto Death - phần này, Bao Thanh Thiên sẽ nhận những nhiệm vụ và khiêu chiến mới, giang sơn Đại Tống với nguy cơ. Bao Công vì trừ gian diệt ác mà bị người ám hại, bị lôi kéo sâu cuộc đấu tranh trong triều đình. Triển Chiêu và Công Tôn Sách tính mạng khó giữ. Bích Huyết Đan Tâm sẽ tiếp nối phiên bản năm 1993, là bộ đầu tiên sau đó có kịch bản hoàn toàn mới, mang theo phong cách vốn có của phim Bao Thanh Thiên, gia tăng thêm hiệu ứng 3D, để khán giả thấy được rõ hơn hình ảnh một giang sơn Đại Tống 1000 năm trước.</i></p>","tmdb":{"type":"tv","id":"138383","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-20T10:34:51.000Z","cast":["Hà Gia Kính","Kim Siêu Quần","Phạm Hồng Hiên"],"director":["Đào Đông Hân","Đường Hạo"],"cast_meta":[{"name":"Hà Gia Kính","name_vi":null,"name_original":"Hà Gia Kính"},{"name":"Kim Siêu Quần","name_vi":null,"name_original":"Kim Siêu Quần"},{"name":"Phạm Hồng Hiên","name_vi":null,"name_original":"Phạm Hồng Hiên"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ba/bao-thanh-thien-bich-huyet-dan-tam.json"}