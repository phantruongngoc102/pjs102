link_m3u8":"https://vip.opstream10.com/20241023/28090_0fe47dbb/index.m3u8"},{"name":"16","slug":"16","filename":"Báo Thủ Seoul - Tập 16","link_embed":"https://vip.opstream10.com/share/068bcdad6accbee0b2adc53cb82eb533","link_m3u8":"https://vip.opstream10.com/20241023/28091_068bcdad/index.m3u8"},{"name":"17","slug":"17","filename":"Báo Thủ Seoul - Tập 17","link_embed":"https://vip.opstream10.com/share/4a86e0b353f9f27b4e0f00842a67eced","link_m3u8":"https://vip.opstream10.com/20241030/28146_4a86e0b3/index.m3u8"},{"name":"18","slug":"18","filename":"Báo Thủ Seoul - Tập 18","link_embed":"https://vip.opstream10.com/share/3f5f9a41006acf1175710899e6ebe758","link_m3u8":"https://vip.opstream10.com/20241030/28145_3f5f9a41/index.m3u8"},{"name":"19","slug":"19","filename":"Báo Thủ Seoul - Tập 19","link_embed":"https://vip.opstream10.com/share/70ba980356d834b5d3ca215040c64e2f","link_m3u8":"https://vip.opstream10.com/20241030/28147_70ba9803/index.m3u8"},{"name":"20","slug":"20","filename":"Báo Thủ Seoul - Tập 20","link_embed":"https://vip.opstream10.com/share/3eb1c847b742640fd6c2ae1853d0e313","link_m3u8":"https://vip.opstream10.com/20241030/28148_3eb1c847/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Dongbang Yu Bin, một người đàn ông cao ráo, thông minh và thể thao, trở thành trưởng nhóm điều tra án mạng tại đồn cảnh sát Songwon. Anh từng được đề nghị làm giáo sư thường trực tại một trường đại học nổi tiếng ở nước ngoài nhưng bất ngờ quay về Hàn Quốc và tình nguyện trở thành trưởng nhóm của Đội 2 Điều tra Án Mạng tại Songwon, đội có tỷ lệ bắt giữ thấp nhất cả nước. Yu Bin quyết tâm thay đổi tình hình, nhưng ngay lập tức anh đối mặt với một loạt thách thức. Đội của anh được xem là “những kẻ phá hoại” do lối làm việc không theo quy chuẩn và những phương pháp điều tra độc đáo nhưng kém hiệu quả. Để chứng minh giá trị của mình, Yu Bin và đội của mình phải giải quyết một vụ án liên hoàn phức tạp mà không một đội nào khác dám nhận. Trong quá trình điều tra, Yu Bin hợp tác với một thủ lĩnh đội điều tra án mạng hàng đầu với phương pháp làm việc hoàn toàn trái ngược. Mối quan hệ giữa hai người từ căng thẳng ban đầu dần trở nên ăn ý hơn qua từng vụ án.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"239005","season":1,"vote_average":8.4,"vote_count":17},"modified":"2024-10-30T19:30:40.000Z","cast":["Kim Dong-wook","Park Ji-hwan","Seo Hyun-woo","Park Se-wan","Lee Seung-woo","Son Eun-seo","Kim Seung-hwa","Kim Ra-on","金希京","Choi Gwang-il","Ahn Sang-woo","Kim Si-gyeong","Choi Sia"],"director":["Ahn Jong-yeon","Shin Joong-hoon"],"cast_meta":[{"name":"Kim Dong-wook","name_vi":null,"name_original":"Kim Dong-wook","tmdb_id":118976,"profile":"https://image.tmdb.org/t/p/w500/zN4UoEuFIbjuzkgvtvQtziG7Rtq.jpg","tmdb_url":"https://www.themoviedb.org/person/118976"},{"name":"Park Ji-hwan","name_vi":null,"name_original":"Park Ji-hwan","tmdb_id":1078674,"profile":"https://image.tmdb.org/t/p/w500/jgydG4s0GsZ2YR5lmjd8T9aawBy.jpg","tmdb_url":"https://www.themoviedb.org/person/1078674"},{"name":"Seo Hyun-woo","name_vi":null,"name_original":"Seo Hyun-woo","tmdb_id":1591370,"profile":"https://image.tmdb.org/t/p/w500/i5HP0n06Y5GIZfpsbibFQWAcUjV.jpg","tmdb_url":"https://www.themoviedb.org/person/1591370"},{"name":"Park Se-wan","name_vi":null,"name_original":"Park Se-wan","tmdb_id":1834243,"profile":"https://image.tmdb.org/t/p/w500/yRaB00ZVVQ6DMjJmictDEaNf6t8.jpg","tmdb_url":"https://www.themoviedb.org/person/1834243"},{"name":"Lee Seung-woo","name_vi":null,"name_original":"Lee Seung-woo","tmdb_id":4365677,"profile":"https://image.tmdb.org/t/p/w500/Ail0c4xZ2gwfVmlayIh28TFUSqn.jpg","tmdb_url":"https://www.themoviedb.org/person/4365677"},{"name":"Son Eun-seo","name_vi":null,"name_original":"Son Eun-seo","tmdb_id":1255410,"profile":"https://image.tmdb.org/t/p/w500/pn3O2zXu7pOYrD0EiMQ9WfXp1JS.jpg","tmdb_url":"https://www.themoviedb.org/person/1255410"},{"name":"Kim Seung-hwa","name_vi":null,"name_original":"Kim Seung-hwa","tmdb_id":4096966,"profile":"https://image.tmdb.org/t/