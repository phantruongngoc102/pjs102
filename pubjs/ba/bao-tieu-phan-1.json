4","link_m3u8":"https://vip.opstream17.com/20240624/13338_ed0642ae/index.m3u8"},{"name":"25","slug":"25","filename":"Vo Lam Bao Ngoc 25","link_embed":"https://vip.opstream17.com/share/f1a2987a8ae3620ed2ed5462e0e80f5e","link_m3u8":"https://vip.opstream17.com/20240624/13337_4c64fc7f/index.m3u8"},{"name":"26","slug":"26","filename":"Vo Lam Bao Ngoc 26","link_embed":"https://vip.opstream17.com/share/ca3445d71de0ef386033037868c58d92","link_m3u8":"https://vip.opstream17.com/20240624/13336_026fd780/index.m3u8"},{"name":"27","slug":"27","filename":"Vo Lam Bao Ngoc 27","link_embed":"https://vip.opstream17.com/share/82d7f56432e27700a4f968ccc1d65038","link_m3u8":"https://vip.opstream17.com/20240624/13335_a7b30348/index.m3u8"},{"name":"28","slug":"28","filename":"Vo Lam Bao Ngoc 28","link_embed":"https://vip.opstream17.com/share/5bf30c6aad7adf06445803878d854044","link_m3u8":"https://vip.opstream17.com/20240624/13334_2ac35a02/index.m3u8"},{"name":"29","slug":"29","filename":"Vo Lam Bao Ngoc 29","link_embed":"https://vip.opstream17.com/share/03bd9b02ba7c3138715a5c3fd05ff6d7","link_m3u8":"https://vip.opstream17.com/20240624/13333_8266af0a/index.m3u8"},{"name":"30","slug":"30","filename":"Vo Lam Bao Ngoc 30end","link_embed":"https://vip.opstream17.com/share/8110eaeb55d8f5ed7aa18842dc0ceacd","link_m3u8":"https://vip.opstream17.com/20240624/13332_c30f6cf9/index.m3u8z"}]}],"time":"45 phút/tập","description":"<p><i>Bảo Tiêu - Võ Lâm Bảo Ngọc chứa đựng tuyệt học võ công tái xuất giang hồ, tạo nên một trận ác chiến tranh đoạt. Vì muốn mượn y học bảo điển được ghi chép trong Búp Bê Phỉ Thúy để chửa trị cho Ngũ thiếu gia của Vân Gia Trang, thiếu chủ Quách Húc của Trường Phong tiêu cục nhận mạo hiểm, cùng Tân Lực, Phong Bình và hai huynh muội Trình Thiết Y, Trình Thái Ngọc vận chuyển Búp Bê Phỉ Thúy đến Vân gia trang. Trên đường bảo tiêu, họ gặp phải Ông Thái Bắc chỉ huy Cẩm y vệ, các danh môn chính phái Thiếu Lâm, Hoa Sơn, Thanh Thành và các thế lực tà ác tấn công nhằm chiếm đoạt Búp Bê Phỉ Thúy. Điều khiến công việc càng trở nên khó khăn thêm nữa là người yêu của chàng cũng đứng trong hàng ngũ tranh đoạt. Liệu chàng thiếu hiệp phong lưu đa tình đa nghĩa Quách Húc có thể hoàn thành chuyến bảo tiêu này không? Hay bảo vật sẽ rơi vào tay ai?\"</i></p>","tmdb":{"type":"tv","id":"109579","season":1,"vote_average":6,"vote_count":1},"modified":"2025-01-07T19:06:36.000Z","cast":["Hà Gia Kính","Diệp Đồng","Tiffany Lau Yuk-Ting","Anita Lee Yuen-Wah","Chen Hung-Lieh","Trịnh Hạo Nam","Cố Quán Trung","Shen Meng-Sheng","Lý Tiểu Nhiễm","Xin Liu"],"director":["Châu Lệnh Cương"],"cast_meta":[{"name":"Hà Gia Kính","name_vi":"Hà Gia Kính","name_original":"Kenny Ho Ka-King","tmdb_id":109506,"profile":"https://image.tmdb.org/t/p/w500/6gQZYCr0ts1NAfCDNboxkNCA0L6.jpg","tmdb_url":"https://www.themoviedb.org/person/109506"},{"name":"Diệp Đồng","name_vi":"Diệp Đồng","name_original":"Cecilia Yip Tung","tmdb_id":83696,"profile":"https://image.tmdb.org/t/p/w500/hsmFXHiHqQH2NWjdP1dZC5ItU1v.jpg","tmdb_url":"https://www.themoviedb.org/person/83696"},{"name":"Tiffany Lau Yuk-Ting","name_vi":null,"name_original":"Tiffany Lau Yuk-Ting","tmdb_id":1358812,"profile":"https://image.tmdb.org/t/p/w500/zi7jiT5rpqnhwJRjx8TMnyV0zA7.jpg","tmdb_url":"https://www.themoviedb.org/person/1358812"},{"name":"Anita Lee Yuen-Wah","name_vi":null,"name_original":"Anita Lee Yuen-Wah","tmdb_id":1171386,"profile":"https://image.tmdb.org/t/p/w500/qhewnFSse7fTMzBfy3dOoN6sCDw.jpg","tmdb_url":"https://www.themoviedb.org/person/1171386"},{"name":"Chen Hung-Lieh","name_vi":null,"name_original":"Chen Hung-Lieh","tmdb_id":936716,"profile":"https://image.tmdb.org/t/p/w500/vkvx5xUAIDIbKHtWxVyJJ0qT2aW.jpg","tmdb_url":"https://www.themoviedb.org/person/936716"},{"name":"Trịnh Hạo Nam","name_vi":"Trịnh Hạo Nam","name_original":"Mark Cheng Ho-Nam","tmdb_id":65197,"profile":"https://image.tmdb.org/t/p/w500/bBL0SIcLDoytkoLCoMAUH2aBEf.jpg","tmdb_url":"https://www.themoviedb.org/person/65197"},{"name":"Cố Quán Trung","name_vi