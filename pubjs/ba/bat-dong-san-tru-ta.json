ed":"https://vip.opstream14.com/share/74f6f6dc23eea28e966cbe049bf71cbc","link_m3u8":"https://vip.opstream14.com/20221102/27332_274e6df3/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream14.com/share/752a6fc94c80ba4f8b2dc8506fcc87f3","link_m3u8":"https://vip.opstream14.com/20221102/27333_9819a83c/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/58a2819da7144df30bfb364e9bd53453","link_m3u8":"https://vip.opstream14.com/20221102/27334_828bd081/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream14.com/share/e2b78d72a53028927d9d40b3daacdf40","link_m3u8":"https://vip.opstream14.com/20221102/27335_d135783b/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream14.com/share/70933ed510f3c50e1ebf98ef8c6625c2","link_m3u8":"https://vip.opstream14.com/20221102/27336_407531b1/index.m3u8"}]}],"description":"<p>Bộ phim với chủ đề siêu nhiên này kể về câu chuyện của Hong Ji-a (Jang Na-ra đóng), một thầy trừ tà những lại điều hành một công ty bất động sản. Không phải là người môi giới thông thường, nhân vật này chuyên giải bùa ếm, giúp các khu đất trở nên \"an toàn\" để tiện buôn bán. Tuy nhiên, Hong Ji-a có một nỗi ám ảnh mà cô không thể tự giải quyết, đó là cái chết bí ẩn của mẹ cô 20 năm trước. Người có thể giúp Hong Ji-a tìm hiểu tận gốc vấn đề của cô là Oh In-beom (do Jung Yong-hwa – thành viên nhóm nhạc CNBlue thủ vai), thực chất lại là một kẻ chuyên đi lừa đảo.</p>","tmdb_id":121695,"cast":["Jang Na-ra","Jung Yong-hwa","Kang Mal-geum","Kang Hong-suk","An Kil-kang","Heo Dong-won","Baek Ji-won","Lee Chae-kyung","Choi Woo-sung","Park Han-sol","Baek Eun-hae"],"director":["Park Jin Suk"],"keywords":[],"tmdb":{"type":"tv","id":"121695","season":1,"vote_average":7.06,"vote_count":50},"cast_meta":[{"name":"Jang Na-ra","name_vi":null,"name_original":"Jang Na-ra","tmdb_id":1234280,"profile":"https://image.tmdb.org/t/p/w500/uIIShNFO8torFMbPqbjs6VXVqD8.jpg","tmdb_url":"https://www.themoviedb.org