8":"https://vip.opstream11.com/20220326/5203_9e620778/index.m3u8"},{"name":"39","slug":"39","filename":"Bắt Gặp Hạnh Phúc - When We Are Together - Tập 39","link_embed":"https://vip.opstream11.com/share/2e6d9c6052e99fcdfa61d9b9da273ca2","link_m3u8":"https://vip.opstream11.com/20220326/5204_846cc35c/index.m3u8"},{"name":"40","slug":"40","filename":"Bắt Gặp Hạnh Phúc - When We Are Together - Tập 40","link_embed":"https://vip.opstream11.com/share/fea16e782bc1b1240e4b3c797012e289","link_m3u8":"https://vip.opstream11.com/20220326/5205_30af0293/index.m3u8"},{"name":"41","slug":"41","filename":"Bắt Gặp Hạnh Phúc - When We Are Together - Tập 41","link_embed":"https://vip.opstream11.com/share/922073b18844540f8fe447c3e93a25b7","link_m3u8":"https://vip.opstream11.com/20220326/5206_f9aebf53/index.m3u8"},{"name":"42","slug":"42","filename":"Bắt Gặp Hạnh Phúc - When We Are Together - Tập 42","link_embed":"https://vip.opstream11.com/share/246a3c5544feb054f3ea718f61adfa16","link_m3u8":"https://vip.opstream11.com/20220326/5207_cfd98c45/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Chân Khai Phóng, Tiêu Tinh, Âu Dương Nghiêm đều sinh ra và lớn lên ở vùng nông thôn nghèo, từ nhỏ bố mẹ là bạn thân nên cũng trở nên thân thiết, kí ức tuổi thơ của họ gắn liền với nhau cùng nhau chia sẻ như anh em ruột thịt cảm giác không thể chia lìa. Thế nhưng thời gian thấm thoắt thoi đưa, 30 năm sau gặp khi mỗi người có một cuộc sống riêng, có sự nghiệp riêng họ lại trở thành những người xa lạ. Sau đó, do sự xuất hiện của các ông bố, ba người bạn thân lúc nhỏ bắt đầu liên lạc lại. Lúc này, Chân Khai Phóng vừa ly hôn vừa thất nghiệp, trở thành mẹ đơn thân; Tiêu Tinh lại rơi vào \"trận chiến\" khủng hoảng với cô con gái mới vào đại học của mình. Còn Âu Dương Nghiêm thắng từ vạch xuất phát bỗng dưng từ chức, khiến gia đình sốc nặng. Khi ba người bạn đối mặt với các vấn đề hôn nhân, giáo dục và sự nghiệp, với các nguy cơ tuổi trung niên bất ngờ ập đến, họ đã chọn cách nương tựa và yêu thương lẫn nhau, cùng tìm kiếm bước đột phá cuộc đời - Âu Dương Nghiêm bắt đầu một công việc mới, Tiêu Tinh thì phát hiện con gái đã gánh vác mọi thứ thay mình, mà Chân Khai Phóng cũng tìm kiếm bến đỗ tình yêu cho bản thân. Nơi thành phố huyên náo, cuối cùng, ba người bạn trung niên đã tìm được ước mơ thuở ban đầu, bắt đầu tin tưởng và hy vọng vào một cuộc sống tốt đẹp hơn.</p>","tmdb":{"type":"tv","id":"92652","season":1,"vote_average":6,"vote_count":1},"modified":"2023-07-12T09:29:10.000Z","cast":["Tưởng Hân","Quách Kinh Phi","Liu Zi","Lý Quang Khiết"],"director":["Mộng Kế"],"cast_meta":[{"name":"Tưởng Hân","name_vi":"Tưởng Hân","name_original":"Jiang Xin","tmdb_id":1241445,"profile":"https://image.tmdb.org/t/p/w500/jwUQ7B22K0rlRtAMegnkMR2O2t5.jpg","tmdb_url":"https://www.themoviedb.org/person/1241445"},{"name":"Quách Kinh Phi","name_vi":"Quách Kinh Phi","name_original":"Guo Jingfei","tmdb_id":1353688,"profile":"https://image.tmdb.org/t/p/w500/xNyi4uOHKAqCgW7JhV5MPn5BG88.jpg","tmdb_url":"https://www.themoviedb.org/person/1353688"},{"name":"Liu Zi","name_vi":null,"name_original":"Liu Zi","tmdb_id":237818,"profile":"https://image.tmdb.org/t/p/w500/CMZilq6KCabtatogMkjzbxtZX1.jpg","tmdb_url":"https://www.themoviedb.org/person/237818"},{"name":"Lý Quang Khiết","name_vi":"Lý Quang Khiết","name_original":"Li Guangjie","tmdb_id":565344,"profile":"https://image.tmdb.org/t/p/w500/snTfuCkX8Q1GHJJwB3UHQJt7KZs.jpg","tmdb_url":"https://www.themoviedb.org/person/565344"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bat-gap-hanh-phuc.json"}