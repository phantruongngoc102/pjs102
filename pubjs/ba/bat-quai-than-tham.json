are/68ef436ae9a785541beefdeacb8433b2","link_m3u8":"https://vip.opstream16.com/20231106/36838_107565df/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/055f874129cf0ecff352455ece0b8209","link_m3u8":"https://vip.opstream16.com/20231106/36837_979ae70e/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/00aa1503c1bbdb597c450f6b0d941fbd","link_m3u8":"https://vip.opstream16.com/20231106/36836_2bb0fe47/index.m3u8"}]}],"description":"<p>Bộ phim xoay quanh câu chuyện của hai cảnh sát điều tra đặc biệt là Phi và Nhân. Phi là một cô nàng thám tử tài giỏi luôn biết vận dụng những kiến thức khoa học có sẵn để áp dụng vào công tác điều tra còn Nhân lại là anh chàng cảnh sát mê tín chuyên dùng bùa ngải và các vấn đề tâm linh để phá án. Trong phim Thám Tử Thần Toán - Officer Geomancer ban đầu Phi vẫn còn dè dặt với đồng nghiệp kì lạ có phần cổ quái này, tuy nhiên ngay sau đó cô đã hoàn toàn thay đổi ý định khi mà chứng kiến Nhân phá một vụ án khó khăn ngoạn mục.</p>","tmdb_id":96583,"cast":["Joey Man Yee-Man","Johnson Lee Sze-Chit","Oscar Leung Lit-Wai","La Lạc Lâm","Rebecca Zhu Chenli","Harriet Yeung Sze-Man","Fred Cheng Chun-Hung","La Lan","William Chak","Mimi Chu Mai-Mai","Mak Ling-Ling","Trần Vinh Tuấn","Parkman Wong Pak-Man","Trình Khả Vi","Lâm Tử Thiện"],"director":["Johnson Lee Sze-Chit"],"keywords":[],"tmdb":{"type":"tv","id":"96583","season":1,"vote_average":6.5,"vote_count":2},"cast_meta":[{"name":"Joey Man Yee-Man","name_vi":null,"name_original":"Joey Man Yee-Man","tmdb_id":1191930,"profile":"https://image.tmdb.org/t/p/w500/xX8YV5x5aEFSU9aGxwXNElFwAoZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1191930"},{"name":"Johnson Lee Sze-Chit","name_vi":null,"name_original":"Johnson Lee Sze-Chit","tmdb_id":232771,"profile":"https://image.tmdb.org/t/p/w500/dIOWv7s4lgyBe4DxNx9gs7E6Kpz.jpg","tmdb_url":"https://www.themoviedb.org/person/232771"},{"name":"Oscar Leung Lit-Wai","name_vi":null,"name_original":"Os