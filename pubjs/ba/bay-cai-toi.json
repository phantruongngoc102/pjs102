eaaa288d32","link_m3u8":"https://vip.opstream15.com/20220517/14983_10ec01db/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/a2bb46e362d70a83673a822206f5062e","link_m3u8":"https://vip.opstream15.com/20220517/14986_b6c468ab/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/0b49b88c68f7ecbdb73f50496c084a1e","link_m3u8":"https://vip.opstream15.com/20220517/14989_1177a0f3/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream15.com/share/88f64d69018af616abf977934ec8226c","link_m3u8":"https://vip.opstream15.com/20220517/14992_ca37c7c8/index.m3u8"}]}],"description":"<p>Phim Bảy Cái Tôi (Thuyết Minh) 2017: Thẩm Diệc Trăn vì một tuổi thơ không mấy vui vẻ mà mất đi một phần kí ức đồng thời hình thành thiếu sót tâm lý, từ nhỏ đã bị người nhà đưa tới Mỹ du học và âm thầm ở chỗ của một chuyên gia tâm lý học chữa trị. Bố của anh ta Thẩm Thuần vẫn luôn trong tình trạng bệnh tật không thể tiếp nhận vị trí chủ tịch. Bà nội Kim Tuệ Trân trong tình trạng bất đắc dĩ phải gọi Thẩm Diệc Trăn 28 tuổi về nước, để anh tiếp nhận nghiệp vụ của tập đoàn. Ở sân bay, Thẩm Diệc Trăn gặp được Bạch Hân Hân và anh trai sinh đôi của cô là Bạch Hướng Vinh. Sau khi biết được Bạch Hân Hân là bác sĩ chuyên khoa tâm lý thần kinh, Thẩm Diệc Trăn bảo cô lấy thân phận bác sĩ chữa trị chính bí ở lại bên cạnh anh.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bay-cai-toi.json"}