bed":"https://vip.opstream12.com/share/076023edc9187cf1ac1f1163470e479a","link_m3u8":"https://vip.opstream12.com/20220227/1583_53190faa/index.m3u8"}]}],"time":"30 phút / tập","description":"<p>Dream High miêu tả về quá trình làm thế nào 6 sinh viên mới từ những môi trường khác nhau đã đến đây và đạt được cùng một ước mơ - trở thành ngôi sao. Đó là anh chàng “nhà quê” Sam Dong (Kim Soo Hyun), người sinh ra với một giọng hát tuyệt vời, là Jin Guk (Ok Taec Yeon) một vũ công nổi loạn nhưng đầy tài năng rực rỡ, là cô nàng Hye Mi (Bae Suzy) người đã từng mơ ước trở thành một ca sỹ lớn có giọng nữ cao, là Baek Hee (Ham Eun Jung), người cố gắng để thoát khỏi sự tự ti của bản thân mình trước Hye Mi, là Jason (Jang Woo Young) một vũ công điêu luyện vừa từ nước ngoài trở về và là Pil Sook (IU) người có ngoại hình xấu xí nhưng lại có giọng hát rất tuyệt.</p>","tmdb":{"type":"tv","id":"37722","season":1,"vote_average":6.823,"vote_count":82},"modified":"2023-07-20T09:33:32.000Z","cast":["Suzy","IU","Park Jin-young","Kang So-ra","Jeong Jin-woon","Park Ji-yeon","Im Jae-beom","Hyolyn","Park Seo-jun","Yoo So-young","Ailee","Jinyoung","Jeong Yeon-joo","Kim Jung-tae"],"director":["Lee Eung Bok","Kim Seong Yoon"],"cast_meta":[{"name":"Suzy","name_vi":null,"name_original":"Suzy","tmdb_id":1014784,"profile":"https://image.tmdb.org/t/p/w500/xdmQeM0UuwVGyZucc3eLhynlb7b.jpg","tmdb_url":"https://www.themoviedb.org/person/1014784"},{"name":"IU","name_vi":"IU","name_original":"IU","tmdb_id":1252318,"profile":"https://image.tmdb.org/t/p/w500/uNhKOO9lIAFXF11LM6gjCrX2CJz.jpg","tmdb_url":"https://www.themoviedb.org/person/1252318"},{"name":"Park Jin-young","name_vi":null,"name_original":"Park Jin-young","tmdb_id":1108066,"profile":"https://image.tmdb.org/t/p/w500/xhtivPqiCNIXkOzaJfL6CDhpRNV.jpg","tmdb_url":"https://www.themoviedb.org/person/1108066"},{"name":"Kang So-ra","name_vi":null,"name_original":"Kang So-ra","tmdb_id":1295457,"profile":"https://image.tmdb.org/t/p/w500/hGIvcS0fqrmXwTXhU9yIi9Wd