index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/88a199611ac2b85bd3f76e8ee7e55650","link_m3u8":"https://vip.opstream12.com/20220227/1581_1facf381/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/b710915795b9e9c02cf10d6d2bdb688c","link_m3u8":"https://vip.opstream12.com/20220227/1582_33a03f1e/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/076023edc9187cf1ac1f1163470e479a","link_m3u8":"https://vip.opstream12.com/20220227/1583_53190faa/index.m3u8"}]}],"description":"<p>Dream High miêu tả về quá trình làm thế nào 6 sinh viên mới từ những môi trường khác nhau đã đến đây và đạt được cùng một ước mơ - trở thành ngôi sao. Đó là anh chàng “nhà quê” Sam Dong (Kim Soo Hyun), người sinh ra với một giọng hát tuyệt vời, là Jin Guk (Ok Taec Yeon) một vũ công nổi loạn nhưng đầy tài năng rực rỡ, là cô nàng Hye Mi (Bae Suzy) người đã từng mơ ước trở thành một ca sỹ lớn có giọng nữ cao, là Baek Hee (Ham Eun Jung), người cố gắng để thoát khỏi sự tự ti của bản thân mình trước Hye Mi, là Jason (Jang Woo Young) một vũ công điêu luyện vừa từ nước ngoài trở về và là Pil Sook (IU) người có ngoại hình xấu xí nhưng lại có giọng hát rất tuyệt.</p>","tmdb_id":37722,"cast":[],"director":[],"keywords":[],"tmdb":{"id":37722},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ba/bay-cao-uoc-mo.json"}