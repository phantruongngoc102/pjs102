 còn rối tung. Cả hai bị Nguyệt lão phạt lịch kiếp xuống trần, trải qua đủ 7 lần tình kiếp mới được trở về tiên giới. Và những câu chuyện thú vị bắt đầu xảy ra từ đây.","tmdb":{"type":"tv","id":"169593","season":1,"vote_average":9.1,"vote_count":12},"modified":"2025-04-11T09:43:55.000Z","cast":["Dương Siêu Việt","Đinh Vũ Hề","Xing Ze","Zhang Xuehan","Lâm Bách Duệ","Lư Dục Hiểu","Zhai Xiangyang","Zhang Xiaochen","Xiao Tianren","Wang Xiaoyunzi"],"director":["Li Nan","杜林"],"cast_meta":[{"name":"Dương Siêu Việt","name_vi":"Dương Siêu Việt","name_original":"Yang Chaoyue","tmdb_id":2396870,"profile":"https://image.tmdb.org/t/p/w500/fIqlPh8S13ttFRTnHC2XZnmGc4C.jpg","tmdb_url":"https://www.themoviedb.org/person/2396870"},{"name":"Đinh Vũ Hề","name_vi":"Đinh Vũ Hề","name_original":"Ding Yuxi","tmdb_id":2493492,"profile":"https://image.tmdb.org/t/p/w500/ellcOuCs2mo1Oh9zO2Qhb0OoZ4d.jpg","tmdb_url":"https://www.themoviedb.org/person/2493492"},{"name":"Xing Ze","name_vi":null,"name_original":"Xing Ze","tmdb_id":4203778,"profile":"https://image.tmdb.org/t/p/w500/sxJvehuEfLZ7f3O7sdnR36YfyL1.jpg","tmdb_url":"https://www.themoviedb.org/person/4203778"},{"name":"Zhang Xuehan","name_vi":null,"name_original":"Zhang Xuehan","tmdb_id":3217776,"profile":"https://image.tmdb.org/t/p/w500/aXfoQ1d203yKGIcFNYxWxXaktg7.jpg","tmdb_url":"https://www.themoviedb.org/person/3217776"},{"name":"Lâm Bách Duệ","name_vi":"Lâm Bách Duệ","name_original":"Charles Lin","tmdb_id":1948457,"profile":"https://image.tmdb.org/t/p/w500/gElc8LDQuuliquIIwRGJfsNV4bA.jpg","tmdb_url":"https://www.themoviedb.org/person/1948457"},{"name":"Lư Dục Hiểu","name_vi":"Lư Dục Hiểu","name_original":"Lu Yuxiao","tmdb_id":3503861,"profile":"https://image.tmdb.org/t/p/w500/42fcXOMXCts1iEfJJpOBFPVwMLW.jpg","tmdb_url":"https://www.themoviedb.org/person/3503861"},{"name":"Zhai Xiangyang","name_vi":null,"name_original":"Zhai Xiangyang","tmdb_id":4203784,"profile":"https://image.tmdb.org/t/p/w500/kDpZ7DGMUuKCM0WbvIg5pfO5nGx.jpg","tmdb_ur