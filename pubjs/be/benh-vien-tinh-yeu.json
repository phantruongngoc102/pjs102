ame":"Bệnh Viện Tình Yêu - Tập 63","link_embed":"https://vip.opstream11.com/share/3af3d94fb6259a153cde3f009b02a81a","link_m3u8":"https://vip.opstream11.com/20220413/14088_3352cc5b/index.m3u8"},{"name":"64","slug":"64","filename":"Bệnh Viện Tình Yêu - Tập 64","link_embed":"https://vip.opstream11.com/share/f13b8707a8ea1da23e10c93b67bec70f","link_m3u8":"https://vip.opstream11.com/20220413/14089_d3deb7ba/index.m3u8"},{"name":"65","slug":"65","filename":"Bệnh Viện Tình Yêu - Tập 65","link_embed":"https://vip.opstream11.com/share/7884205c412107bdfe1dd6d1356c1d56","link_m3u8":"https://vip.opstream11.com/20220413/14090_0ff2f2d1/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Sinan là một bác sĩ trẻ thành công, làm việc trong phòng cấp cứu của bệnh viện. Anh sống một mình và tận hưởng sự tự do. Một sáng sớm, anh bị tỉnh giấc bởi tiếng động của một cô gái đang cố chuyển đồ vào căn hộ mới. Cô gái đó cũng đồng thời làm hỏng xe của Sinan. Sinan nghĩ rằng thật là một ngày tồi tệ, và anh không muốn gặp lại cô gái kia, cho đến khi anh biết rằng cô gái đó chính là phụ tá bác sĩ mới của anh, Nisan. Họ làm việc cùng nhau và bắt đầu quý mến nhau...</p>","tmdb":{"type":"tv","id":"69268","season":1,"vote_average":8.571,"vote_count":7},"modified":"2023-07-07T19:55:33.000Z","cast":["Serhat Teoman","Duygu Yetiş","Rojda Demirer","Tamer Tıraşoğlu","Gökhan Soylu","Sinem Uçar","Serkan Öztürk","Sedef Şahin"],"director":["Baris Kirimselioglu"],"cast_meta":[{"name":"Serhat Teoman","name_vi":null,"name_original":"Serhat Teoman","tmdb_id":1728612,"profile":"https://image.tmdb.org/t/p/w500/1cKnptoa8uPq2p8f4CpK4ar5dii.jpg","tmdb_url":"https://www.themoviedb.org/person/1728612"},{"name":"Duygu Yetiş","name_vi":null,"name_original":"Duygu Yetiş","tmdb_id":1728613,"profile":"https://image.tmdb.org/t/p/w500/ox9Ni5hqvftDETyKlobRTA0IiCU.jpg","tmdb_url":"https://www.themoviedb.org/person/1728613"},{"name":"Rojda Demirer","name_vi":null,"name_original":"Rojda Demirer","tmdb_id":1064541,"profile":"https