{"id":"62a8a8207a956fb5db108f6c","title":"Bí Ẩn Kim Tự Tháp","origin_name":"The Pyramid","slug":"bi-an-kim-tu-thap","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/bi/bi-an-kim-tu-thap.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/bi/bi-an-kim-tu-thap.webp","year":2014,"type":"single","genre":[{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"bi-an-kim-tu-thap-the-pyramid","link_embed":"https://vip.opstream12.com/share/ef8ff9dcba0ea0f66f02b9d355fb860c","link_m3u8":"https://vip.opstream12.com/20220614/19657_8c405387/index.m3u8"}]}],"time":"","description":"<p>Bí Ẩn Kim Tự Tháp - The Pyramid là bộ phim kinh dị Mỹ 2014 của đạo diễn Grégory Levasseur. Kim tự tháp, nơi luôn xảy ra những câu chuyện quái gỡ, không có lối thoát, không có đáp án. Bộ phim xoay quanh nhóm thám hiểm khai quật 1 kim tử tháp 3 cạnh. Với họ đó là điều hết sức thú vị, nhưng mọi thứ không dừng lại ở đó. Mỗi người trong số họ lần lượt trả giá cho việc làm liều lĩnh của mình. Cái giá ấy có phải là quá đắt? Đây là 1 bộ phim hết sức kinh dị, gây cấn, hồi hộp đến ngẹt thở.</p>","tmdb":{"type":"movie","id":"282813","season":null,"vote_average":5.299,"vote_count":1139},"modified":"2022-06-14T15:24:16.000Z","cast":["Ashley Hinshaw","Denis O'Hare","James Buckley","Amir K","Christa Nicola","Joseph Beddelem","Faycal Attougui","Philip Shelley","Omar Benbrahim","Chakir El Faaiz","Ait Hamou Amine"],"director":["Grégory Levasseur"],"cast_meta":[{"name":"Ashley Hinshaw","name_vi":null,"name_original":"Ashley Hinshaw","tmdb_id":589098,"profile":"https://image.tmdb.org/t/p/w500/19Bk7d