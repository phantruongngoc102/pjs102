15.com/20220305/759_abb0418c/index.m3u8"},{"name":"15","slug":"15","filename":"bi-an-nui-jiri-jirisan-tap-15","link_embed":"https://vip.opstream15.com/share/2ca65f58e35d9ad45bf7f3ae5cfd08f1","link_m3u8":"https://vip.opstream15.com/20220305/760_9af1790c/index.m3u8"},{"name":"16","slug":"16","filename":"bi-an-nui-jiri-jirisan-tap-16","link_embed":"https://vip.opstream15.com/share/88ae6372cfdc5df69a976e893f4d554b","link_m3u8":"https://vip.opstream15.com/20220305/761_a3aa2a5e/index.m3u8"}]}],"time":"1H12M21S","description":"<p>Bộ phim Hàn Quốc “Bí Ẩn Núi Jiri” (2021) do Jun Ji Hyun (“Vì Sao Đưa Anh Tới”, “Huyền Thoại Biển Xanh”) và Joo Ji Hoon (“Vương Triều Xác Sống”, “Hoàng Cung”) diễn chính, đạo diễn Lee Eung Bok (“Yêu Tinh”, “Hậu Duệ Mặt Trời”) và biên kịch Kim Eun Hee (“Vương Triều Xác Sống”) hợp tác sản xuất, đây là bộ phim dài tập cuối tuần trong kế hoạch đặc biệt kỷ niệm 15 năm phát sóng từ ngày 23 tháng 10 năm 2021 của đài tvN Hàn Quốc, phim này sẽ do kênh iQIYI Quốc tế phát sóng độc quyền. Bí Ẩn Núi Jiri (Jirisan) kể về quá trình kiểm lâm Kang Hyun Jo (Joo Ji Hoon đóng) của Vườn quốc gia núi Jiri phát hiện mình nhìn thấy các hồn ma qua đời vì gặp nạn trên núi, vì thế đã cùng tiền bối Seo Yi Kang (Jun Ji Hyun đóng) bắt tay giải đáp những câu chuyện chưa biết này.\\n\\nNữ chính Seo Yi Kang là kiểm lâm giỏi nhất của Vườn quốc gia núi Jiri. Nam chính Kang Hyun Jo tích cực cầu tiến, yêu cuộc sống, là cộng sự làm việc của Seo Yi Kang. Dù là đường đất, vách đá hay vách núi, Seo Yi Kang đều biết cách vượt qua như bản năng, chỉ cần một chiếc lá trên ba lô người gặp nạn là phán đoán được địa điểm gặp nạn, hơn nữa còn cực kỳ thông thuộc về khí hậu, thảm thực vật, tính chất đất đai. Tuy bị đồng nghiệp gọi là “Thần rừng”, “Seo ác quỷ”, nhưng Seo Yi Kang say mê công tác cứu nạn hơn bất cứ ai, đó là vì nguyện vọng của cô, giành giật thời gian với thần chết, cứu giúp người gặp nạn. Kang Hyun Jo, đại úy lục quân đương nhiệm gặp tai nạn lúc hành quân huấn luyện trong núi Jiri, chiến hữu vì thế mà bỏ mình. Sau này, anh ấy bắt đầu nhìn thấy hồn ma của những người gặp nạn trong núi Jiri. Kang Hyun Ho cho rằng đây là món quà cứu giúp con người của ngọn núi, vì thế anh ấy trở về núi Jiri, cùng nhau cứu giúp người gặp nạn với tư cách là cộng sự của Seo Yi Kang. Dần đần, bí mật đáng sợ ẩn giấu đằng sau ngọn núi Jiri xinh đẹp cũng từ từ hé lộ…</p>","tmdb":{"type":"tv","id":"110533","season":1,"vote_average":8.088,"vote_count":80},"modified":"2025-06-06T11:21:35.000Z","cast":["Gianna Jun","Ju Ji-hoon","Sung Dong-il","Oh Jung-se","Joo Min-kyung","Cho Han-cheul","Go Min-si","Lee Ga-sub","Jun Suk-ho","Kim Yeong-ok","Park Hwan-Hee","Kim Guk-hee","Ju Jin-mo","Yun Ji-on","Han Dong-ho"],"director":["Lee Eung-bok"],"cast_meta":[{"name":"Gianna Jun","name_vi":null,"name_original":"Gianna Jun","tmdb_id":63436,"profile":"https://image.tmdb.org/t/p/w500/qejOQBdIzN18e69yRcsiD0JQi4c.jpg","tmdb_url":"https://www.themoviedb.org/person/63436"},{"name":"Ju Ji-hoon","name_vi":null,"name_original":"Ju Ji-hoon","tmdb_id":150125,"profile":"https://image.tmdb.org/t/p/w500/7PYfUrBBXhYv5PIsTalJhjbRteg.jpg","tmdb_url":"https://www.themoviedb.org/person/150125"},{"name":"Sung Dong-il","name_vi":null,"name_original":"Sung Dong-il","tmdb_id":1020859,"profile":"https://image.tmdb.org/t/p/w500/9VLRIvOyQSHkpJaeaBcmHzcEUQn.jpg","tmdb_url":"https://www.themoviedb.org/person/1020859"},{"name":"Oh Jung-se","name_vi":null,"name_original":"Oh Jung-se","tmdb_id":998412,"profile":"https://image.tmdb.org/t/p/w500/oIqRAdI5e777odhOJl6e4Jc9ADj.jpg","tmdb_url":"https://www.themoviedb.org/person/998412"},{"name":"Joo Min-kyung","name_vi":null,"name_original":"Joo Min-kyung","tmdb_id":2011082,"profile":"https://image.tmdb.org/t/p/w500/w9M3K295SPKvXWem4Ox8M9o4ONm.jpg","tmdb_url":"https://www.themoviedb.org/person/2011082"},{"name":"Cho Han-cheul","name_vi":null,"name_original":"Cho Han-cheul","tmdb_id":1203792,"profile":"https://image.tmdb.org/t/p/w500/58DGEXFyWfaFdqL7yKKW0VdEg3R.jpg","tmdb_url"