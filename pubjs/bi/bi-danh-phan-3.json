m/20220413/7773_e6709118/index.m3u8"}]}],"time":"50 phút/tập","description":"<p>\"Alias\" là bộ phim hành động kịch tính, bí ẩn của đạo diễn Ken Olin và Lawrence Trilling. Phim xoay quanh nhận vật chính là Sydney Bristow là 1 điệp viên, nội gián của cảnh sát, có nhiệm vụ giả dạng để đột nhập vào các tổ chức mafia trên thế giới. Mỗi tập phim là 1 nhiệm vụ khác nhau của cô và các đồng nghiệp, tuy nhiệm vụ khác nhau nhưng đều có điểm chung đó là rất nguy hiểm, luôn đe dọa tính mạng Sydney và đòi hỏi cô phải hết sức khéo léo, mưu trí để thoát chết và hoàn thành nhiệm vụ.</p>","tmdb":{"type":"tv","id":"2046","season":3,"vote_average":6.773,"vote_count":685},"modified":"2023-07-07T19:49:58.000Z","cast":["Jennifer Garner","Victor Garber","Ron Rifkin","Carl Lumbly","Kevin Weisman","Rachel Nichols","Amy Acker","Balthazar Getty"],"director":[],"cast_meta":[{"name":"Jennifer Garner","name_vi":null,"name_original":"Jennifer Garner","tmdb_id":9278,"profile":"https://image.tmdb.org/t/p/w500/ftymEXqdTnXfaI6dGd9qrJoFOSE.jpg","tmdb_url":"https://www.themoviedb.org/person/9278"},{"name":"Victor Garber","name_vi":null,"name_original":"Victor Garber","tmdb_id":8536,"profile":"https://image.tmdb.org/t/p/w500/FdhXl8qxsKgj22Ip99SRM9jUx1.jpg","tmdb_url":"https://www.themoviedb.org/person/8536"},{"name":"Ron Rifkin","name_vi":null,"name_original":"Ron Rifkin","tmdb_id":12122,"profile":"https://image.tmdb.org/t/p/w500/fj2u4t6nG0HGYFtRVDUTNbUtEtl.jpg","tmdb_url":"https://www.themoviedb.org/person/12122"},{"name":"Carl Lumbly","name_vi":null,"name_original":"Carl Lumbly","tmdb_id":29382,"profile":"https://image.tmdb.org/t/p/w500/ew1URcenWNl1Uclsz9ADiRb0uBD.jpg","tmdb_url":"https://www.themoviedb.org/person/29382"},{"name":"Kevin Weisman","name_vi":null,"name_original":"Kevin Weisman","tmdb_id":149670,"profile":"https://image.tmdb.org/t/p/w500/c0YWHu02cHGynufhOM7eNtIQ5ze.jpg","tmdb_url":"https://www.themoviedb.org/person/149670"},{"name":"Rachel Nichols","name_vi":null,"name_original":"Rachel N