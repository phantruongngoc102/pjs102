ủa cô, và mang cho cô cảm giác của tình yêu mất đi đã lâu. Vào lúc Tô Mạn đang khó khăn trong việc lựa chọn giữa tình yêu và con gái, một âm mưu khác được hé lộ. Diệp Tinh với vẻ ngoài ngây thơ lại âm mưu với tiểu tam để bòn rút tài sản của chồng cũ, cuộc hôn nhân của họ bị đổ vỡ chính là một phần trong kế hoạch của hai người. Nhưng tất cả, cũng chỉ là một góc nhỏ. Hai vợ chồng họ bị cuốn vào vòng xoáy báo thù không thể thoát thân, sẽ là liều chết phản kháng hay là thỏa hiệp rồi tự tìm đường sống riêng, tất cả đều do cô quyết định...","tmdb_id":241530,"cast":["Zhang Muchen","Hoàng Tinh"],"director":["Liang Ce"],"keywords":[],"tmdb":{"type":"tv","id":"241530","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Zhang Muchen","name_vi":null,"name_original":"Zhang Muchen","tmdb_id":3122566,"profile":"https://image.tmdb.org/t/p/w500/q0A4jemw9tDKlfNBxPbabppsCc4.jpg","tmdb_url":"https://www.themoviedb.org/person/3122566"},{"name":"Hoàng Tinh","name_vi":"Hoàng Tinh","name_original":"Qiu Dingjie","tmdb_id":4686489,"profile":"https://image.tmdb.org/t/p/w500/6rooUc3EjJTQBA6a73G6XPtPdDH.jpg","tmdb_url":"https://www.themoviedb.org/person/4686489"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/bi/bi-mat-cua-anh-ay-va-co-ay.json"}