m/share/3b5baa4288a1ba4f0ce32ab6f6350603","link_m3u8":"https://vip.opstream11.com/20220605/28570_977868dc/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bỉ Ngạn Hoa - bom tấn được chuyển thể từ tiểu thuyết cùng tên của tác giả An Ny Bảo Bối, được Viettel Media phát hành và phân phối độc quyền tại Việt Nam. Phát song song 21h thứ 2, thứ 6-CN hàng tuần. Bộ phim là câu truyện về tình yêu của chàng trai Hòa Bình (Tống Uy Long) và cô nàng Kiều Mạn (Lâm Duẫn), họ đã có những năm tháng bên nhau, cùng nhau trưởng thành. Thế nhưng, Hòa Bình đã không thể cùng Kiều Mạn đi đến cuối cuộc đời. Chuyện tình của họ giống như đóa hoa bỉ ngạn, một khi nở rộ thì sẽ không có lá, khi đã có lá thì sẽ không nở hoa, hoa lá muôn đời sẽ không thể gặp được nhau...</p>","tmdb":{"type":"tv","id":"89891","season":1,"vote_average":6.3,"vote_count":3},"modified":"2023-04-11T19:24:25.000Z","cast":["Lâm Duẫn","Tống Uy Long","Hà Nhuận Đông","David Wang","Lý Tâm Ngải","Tạ Bân Bân","Liu Yuqi","Feng Yunzhi"],"director":["Wang Jing Ru"],"cast_meta":[{"name":"Lâm Duẫn","name_vi":"Lâm Duẫn","name_original":"Lin Yun","tmdb_id":1574909,"profile":"https://image.tmdb.org/t/p/w500/9ZxXUlMAH6gylhswGHOGO1YAQPJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1574909"},{"name":"Tống Uy Long","name_vi":"Tống Uy Long","name_original":"Song Weilong","tmdb_id":1982522,"profile":"https://image.tmdb.org/t/p/w500/91EBpDeOvBRQ4Kh6p15LQwWshdR.jpg","tmdb_url":"https://www.themoviedb.org/person/1982522"},{"name":"Hà Nhuận Đông","name_vi":"Hà Nhuận Đông","name_original":"Peter Ho","tmdb_id":2337443,"profile":"https://image.tmdb.org/t/p/w500/7zXa53TqSE0jU5HWeF3K8iweC19.jpg","tmdb_url":"https://www.themoviedb.org/person/2337443"},{"name":"David Wang","name_vi":null,"name_original":"David Wang","tmdb_id":1623136,"profile":"https://image.tmdb.org/t/p/w500/uDOia8x3GyqhRnQs7Akgqytui7Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1623136"},{"name":"Lý Tâm Ngải","name_vi":"Lý Tâm Ngải","name_original":"Li Xinai","tmdb_