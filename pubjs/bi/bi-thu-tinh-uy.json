8244_52a1b568/index.m3u8"},{"name":"44","slug":"44","filename":"BiThuTinhuyS01E44","link_embed":"https://vip.opstream13.com/share/d09260384253eef3eb4e94f9beb869b4","link_m3u8":"https://vip.opstream13.com/20251120/18245_d0926038/index.m3u8"},{"name":"45","slug":"45","filename":"BiThuTinhuyS01E45","link_embed":"https://vip.opstream13.com/share/c0ef730f5d58968ab89957d008952474","link_m3u8":"https://vip.opstream13.com/20251120/18246_c0ef730f/index.m3u8"},{"name":"46","slug":"46","filename":"BiThuTinhuyS01E46","link_embed":"https://vip.opstream13.com/share/0a117f2c94a8e5fa07208abbbe46083f","link_m3u8":"https://vip.opstream13.com/20251120/18247_0a117f2c/index.m3u8"},{"name":"47","slug":"47","filename":"BiThuTinhuyS01E47","link_embed":"https://vip.opstream13.com/share/83756b985266168d0d29c6c9a146db50","link_m3u8":"https://vip.opstream13.com/20251120/18248_83756b98/index.m3u8"},{"name":"48","slug":"48","filename":"BiThuTinhuyS01E48","link_embed":"https://vip.opstream13.com/share/e743a091199384909e62fdb62d701810","link_m3u8":"https://vip.opstream13.com/20251120/18249_e743a091/index.m3u8"},{"name":"49","slug":"49","filename":"BiThuTinhuyS01E49","link_embed":"https://vip.opstream13.com/share/d40c4b6c8105a36bbe7f46b2375446e6","link_m3u8":"https://vip.opstream13.com/20251120/18250_d40c4b6c/index.m3u8"},{"name":"50","slug":"50","filename":"BiThuTinhuyS01E50","link_embed":"https://vip.opstream13.com/share/009d4a3d23853b06a1a169aa01dfb703","link_m3u8":"https://vip.opstream13.com/20251120/18251_009d4a3d/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim dài 50 tập, lấy cảm hứng từ cuộc đời và sự nghiệp của <strong>cố Bí thư Tỉnh ủy Vĩnh Phúc Kim Ngọc</strong> - người được mệnh danh là \"cha đẻ của khoán 10\" (khoán sản phẩm trong nông nghiệp). Phim tái hiện bối cảnh xã hội Việt Nam trong giai đoạn khó khăn, khi nền kinh tế tập thể đang gặp nhiều vướng mắc. Nhân vật chính, với tư duy đổi mới, sáng tạo và lòng dũng cảm, đã đề ra những quyết sách táo bạo, đi ngược lại với đường lối chung thời bấy giờ nhằm cải thiện đời sống của người dân Vĩnh Phúc. Những quyết định này đã gây ra nhiều tranh cãi, thậm chí bị coi là \"đi ngược với đường lối của Đảng và Nhà nước\" lúc bấy giờ, nhưng cuối cùng đã mang lại hiệu quả rõ rệt và được nhân dân đồng tình ủng hộ.</p>","tmdb":{"type":"tv","id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2025-11-22T14:29:00.000Z","cast":["Lê Dũng Nhi","NSND Minh Châu","NSND Mai Hoa","NSND Đức Trung"],"director":["Trần Quốc Trọng","Trần Trọng Khôi"],"cast_meta":[{"name":"Lê Dũng Nhi","name_vi":null,"name_original":"Lê Dũng Nhi"},{"name":"NSND Minh Châu","name_vi":null,"name_original":"NSND Minh Châu"},{"name":"NSND Mai Hoa","name_vi":null,"name_original":"NSND Mai Hoa"},{"name":"NSND Đức Trung","name_vi":null,"name_original":"NSND Đức Trung"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/bi/bi-thu-tinh-uy.json","keywords":[],"tmdb_checked":false}