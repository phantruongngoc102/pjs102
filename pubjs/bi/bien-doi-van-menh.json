/54720_26d6a19a/index.m3u8"},{"name":"15","slug":"15","filename":"BienDoiVanMenh1995.720P.H264_15","link_embed":"https://vip.opstream11.com/share/13b1fb5c2f28899abc18c6cc53f4f7ee","link_m3u8":"https://vip.opstream11.com/20241012/54721_13b1fb5c/index.m3u8"},{"name":"16","slug":"16","filename":"BienDoiVanMenh1995.720P.H264_16","link_embed":"https://vip.opstream11.com/share/437ca08327dbd2c8a8f0809ea2beeceb","link_m3u8":"https://vip.opstream11.com/20241012/54722_437ca083/index.m3u8"},{"name":"17","slug":"17","filename":"BienDoiVanMenh1995.720P.H264_17","link_embed":"https://vip.opstream11.com/share/e5598f16dee1c365bc9b9e64474d5b5e","link_m3u8":"https://vip.opstream11.com/20241012/54723_e5598f16/index.m3u8"},{"name":"18","slug":"18","filename":"BienDoiVanMenh1995.720P.H264_18","link_embed":"https://vip.opstream11.com/share/f72855c32b22b0be76a473edb8db3218","link_m3u8":"https://vip.opstream11.com/20241012/54724_f72855c3/index.m3u8"},{"name":"19","slug":"19","filename":"BienDoiVanMenh1995.720P.H264_19","link_embed":"https://vip.opstream11.com/share/626ff89ce0d82c4b413dc580c9eeedcb","link_m3u8":"https://vip.opstream11.com/20241012/54725_626ff89c/index.m3u8"},{"name":"20","slug":"20","filename":"BienDoiVanMenh1995.720P.H264_20End","link_embed":"https://vip.opstream11.com/share/64466becac41b1675c3dde8b65fdf659","link_m3u8":"https://vip.opstream11.com/20241012/54726_64466bec/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Số phận con người định mệnh đã an bài hay do sức mình gây dựng? Sức người có thể thắng trời chăng? Huyền Cơ Tử người liệu sư như thần tiên đoán Côn đã hết thời. sẽ bị 1 trong ba người đàn em tên Võ , Chánh và Đạt thay thế. Rốt cuộc Chánh vì tự vệ nên đã giết Côn trở thành phú hào trong thập niên 90 và cũng từ đó y cáng tin tưởng địa lý bói số. Trong dịp tình cờ Chánh kết bạn vong niên với Nhiên người đang yêu với con gái y tên Hoa. Một chuyện đáng buồn là Huyền Cơ Tử cũng từng tiên đoán người kế vị Côn cũng sẽ gặp tao ngộ như Côn, bị con cháu của bạn thân thay thế. Nhiên chính là con của Võ. Chánh sợ chuyện xưa tái diễn. đành mượn tà thuật ép bức Nhiên. Mặt khác Nhiên tự biết không thể kết duyên với Hoa, thề chống chọi với số phận…</i></p>","tmdb":{"type":"tv","id":"99801","season":1,"vote_average":10,"vote_count":1},"modified":"2024-12-20T10:34:38.000Z","cast":["Timmy Ho Bo-Sang","Lưu Đan","Gigi Fu Ming-Hin","Mạch Trường Thanh","Trương Quốc Cường","Bao Fang","Chang Yi","Teresa Mak Ka-Kei","Wong Ching"],"director":["Trương Càn Văn"],"cast_meta":[{"name":"Timmy Ho Bo-Sang","name_vi":null,"name_original":"Timmy Ho Bo-Sang","tmdb_id":65942,"profile":"https://image.tmdb.org/t/p/w500/4JGlBuDQ7dch94TcAgxcOjz527P.jpg","tmdb_url":"https://www.themoviedb.org/person/65942"},{"name":"Lưu Đan","name_vi":"Lưu Đan","name_original":"Danny Lau Dan","tmdb_id":1133980,"profile":"https://image.tmdb.org/t/p/w500/gEmCCnMg9GvskUPSuGQA3ae8irk.jpg","tmdb_url":"https://www.themoviedb.org/person/1133980"},{"name":"Gigi Fu Ming-Hin","name_vi":null,"name_original":"Gigi Fu Ming-Hin","tmdb_id":1135386,"profile":"https://image.tmdb.org/t/p/w500/qe8fEAyxC7xFT9yukhWwNXBFyOg.jpg","tmdb_url":"https://www.themoviedb.org/person/1135386"},{"name":"Mạch Trường Thanh","name_vi":"Mạch Trường Thanh","name_original":"Evergreen Mak Cheung-Ching","tmdb_id":985094,"profile":"https://image.tmdb.org/t/p/w500/u1lUv0JR4v0gNXjUWtfPJ43I8SA.jpg","tmdb_url":"https://www.themoviedb.org/person/985094"},{"name":"Trương Quốc Cường","name_vi":"Trương Quốc Cường","name_original":"Cheung Kwok-Keung","tmdb_id":1266162,"profile":"https://image.tmdb.org/t/p/w500/jsauufq9uAPZPoaJQhzgkSlTOZQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1266162"},{"name":"Bao Fang","name_vi":null,"name_original":"Bao Fang","tmdb_id":1191925,"profile":"https://image.tmdb.org/t/p/w500/rWbJLwyjpWm4eQPgso798ia3Kpj.jpg","tmdb_url":"https://www.themoviedb.org/person/1191925"},{"name":"Chang Yi","name_vi":null,"name_original":"Chang Yi","tmdb_id":126831,"profile":"https://image.tmdb.org/t/p/w