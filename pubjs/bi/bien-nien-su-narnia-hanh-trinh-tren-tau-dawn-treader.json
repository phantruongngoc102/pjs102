Reepicheep và những người đàn ông trung thành của anh ta. Chẳng mấy chốc, họ phát hiện ra rằng một dạng sương mù màu xanh lá cây đang đe dọa Narnia và anh chị em và anh họ của họ tham gia Caspian trong một nhiệm vụ để lấy bảy thanh kiếm của bảy lãnh chúa telmar để cứu Narnia khỏi cái ác.</p>","tmdb_id":10140,"cast":["Georgie Henley","Skandar Keynes","Ben Barnes","Will Poulter","Anna Popplewell","Tilda Swinton","William Moseley","Simon Pegg","Liam Neeson","Laura Brent","Gary Sweet","Terry Norris","Bruce Spence","Bille Brown","Colin Moody"],"director":["Michael Apted"],"keywords":["based on novel or book","magic","christianity","allegory","lion","anthropomorphism","dragon","king","turns into animal","christ allegory","fantasy world","snowing","sea voyage","quest","high fantasy","isekai","christ figure","father son relationship","brother sister relationship","based on young adult novel","anxious","good versus evil","christian allegory","adoring"],"tmdb":{"type":"movie","id":"10140","season":null,"vote_average":6.4,"vote_count":5804},"cast_meta":[{"name":"Georgie Henley","name_vi":null,"name_original":"Georgie Henley","tmdb_id":5526,"profile":"https://image.tmdb.org/t/p/w500/dW7ZQfrm2A4rVtZrIPbWOUXNvsJ.jpg","tmdb_url":"https://www.themoviedb.org/person/5526"},{"name":"Skandar Keynes","name_vi":null,"name_original":"Skandar Keynes","tmdb_id":5527,"profile":"https://image.tmdb.org/t/p/w500/pIdgY16c6AzmCD31pXlCR9SjLlM.jpg","tmdb_url":"https://www.themoviedb.org/person/5527"},{"name":"Ben Barnes","name_vi":null,"name_original":"Ben Barnes","tmdb_id":25130,"profile":"https://image.tmdb.org/t/p/w500/k0tAM9XK0s4n0VQq1jX5cGf9uAa.jpg","tmdb_url":"https://www.themoviedb.org/person/25130"},{"name":"Will Poulter","name_vi":null,"name_original":"Will Poulter","tmdb_id":93491,"profile":"https://image.tmdb.org/t/p/w500/9blYMaj79VGC6BHTLmJp3V5S8r3.jpg","tmdb_url":"https://www.themoviedb.org/person/93491"},{"name":"Anna Popplewell","name_vi":null,"name_original":"Anna Popplewell","tmdb_