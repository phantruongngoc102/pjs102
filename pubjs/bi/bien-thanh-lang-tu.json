/17338_7d2a9769/index.m3u8"},{"name":"15","slug":"15","filename":"Bien Thanh Lang Tu 15","link_embed":"https://vip.opstream17.com/share/169ea72d893b7bfe6a36b531a78b48af","link_m3u8":"https://vip.opstream17.com/20240820/17339_56488629/index.m3u8"},{"name":"16","slug":"16","filename":"Bien Thanh Lang Tu 16","link_embed":"https://vip.opstream17.com/share/7295b8c846b35dfe7da45330e57d3f61","link_m3u8":"https://vip.opstream17.com/20240820/17340_39db5ec4/index.m3u8"},{"name":"17","slug":"17","filename":"Bien Thanh Lang Tu 17","link_embed":"https://vip.opstream17.com/share/c9dcf2529a5f4bf66234540fbe60b74e","link_m3u8":"https://vip.opstream17.com/20240820/17341_d3b3489f/index.m3u8"},{"name":"18","slug":"18","filename":"Bien Thanh Lang Tu 18","link_embed":"https://vip.opstream17.com/share/f7df51ba7df696f03c9037d67fabd286","link_m3u8":"https://vip.opstream17.com/20240820/17342_f986f6ba/index.m3u8"},{"name":"19","slug":"19","filename":"Bien Thanh Lang Tu 19","link_embed":"https://vip.opstream17.com/share/474cb9e0d31ee15a396d30623feeea71","link_m3u8":"https://vip.opstream17.com/20240820/17343_863bcf4d/index.m3u8"},{"name":"20","slug":"20","filename":"Bien Thanh Lang Tu 20 END","link_embed":"https://vip.opstream17.com/share/d1aa227de516e4617cc72ab9cf456380","link_m3u8":"https://vip.opstream17.com/20240820/17344_6a5bf0c9/index.m3u8"}]}],"time":"44 phút/tập","description":"<p><i>20 năm trước, thần đao Bạch Thiên Vũ ngồi uống rượu ngắm tuyết rơi cùng Mã Không Quần tại Mai Hoa Âm bị nhóm sát thủ bịt mặt tập kích mà chết. 20 năm sau nhận lệnh của mẹ, Phó Hồng Tuyết lên đường đến Biên Thành tìm kiếm hung thủ trả thù cho Bạch Thiên Vũ.Diệp Khai là là anh hùng thiếu niên cơ trí nhanh nhẹn nhưng không biết về thân thế mình, Diệp Khai chỉ biết cha mình có liên quan đến cây đao màu đen.Đến Biên Thành, Diệp Khai gặp Phó Hồng Tuyết đeo cây đao màu đen không rời nên bám sát Phó Hồng Tuyết. Diệp Khai quen biết với Mã Phương Linh con gái của Mã Không Quần, tiểu nữ của gia trang Vạn Mã Đường thế lực nhất Biên Thành. Diệp Khai vốn tính lãng tử khó xử đứng giữa 2 hồng nhan Mã Phương Linh &amp; người bạn thân Đinh Lan Lâm.Biên Thành có hai giai nhân xinh đẹp nhất, ngoài Mã Phương Linh còn có kỳ nữ Thúy Long. Thúy Long thật ra vì nợ ân tình nên làm người liên lạc giúp Phó Hồng Tuyết. Thúy Long &amp; Phó Hồng Tuyết thật lòng yêu nhau nhưng Phó Hồng Tuyết luôn mặc cảm chân bị què, trong lòng chỉ có hận thù phải trả, nhiều lần bỏ rơi Thúy Long. Đến Biên Thành Phó Hồng Tuýêt &amp; Diệp Khai lần lượt bị cuốn vào nhiều sự kiện kỳ lạ, nhiều người chết đều có liên quan đến vụ án năm xưa. Mã Không Quần biết Phó Hồng Tuyết tìm đến trả thù nên mướn sát thủ Lộ Tiểu Giai giết Phó Hồng Tuyết nhưng không thành. Mã Không Quần bỏ trốn. Phó Hồng Tuyết lần lượt tìm đến thanh toán nợ máu với 8 người năm xưa có phần tham gia trong vụ ‟Mai Hoa Âm‟. Đến gia đình cuối cùng lại chính là Đinh Gia Trang của Đinh Lan Lâm…</i></p>","tmdb":{"type":"tv","id":"109865","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-29T10:32:18.000Z","cast":["Trương Triệu Huy","Ngô Đại Dung","Tăng Hoa Thiên","Tse Ning","Lương Nghệ Linh","Âu Thụy Vỹ","Mao Sze Kao","Lê Diệu Tường","Kwan Ching","Tần Bái","Charlie Ng Kai-Ming","Lý Gia Thanh","Chu Tit-Wo","Amy Wu Mei-Yee","Helen Ma Hoi-Lun"],"director":["Vương Thiên Lâm"],"cast_meta":[{"name":"Trương Triệu Huy","name_vi":"Trương Triệu Huy","name_original":"Eddie Cheung Siu-Fai","tmdb_id":72732,"profile":"https://image.tmdb.org/t/p/w500/jTrBt3y43LsO8XYsQnWg8bdwsP2.jpg","tmdb_url":"https://www.themoviedb.org/person/72732"},{"name":"Ngô Đại Dung","name_vi":"Ngô Đại Dung","name_original":"Hugo Ng Doi-Yung","tmdb_id":1187932,"profile":"https://image.tmdb.org/t/p/w500/1FNy7eOKdfjQcKT1aIjv6G0akTs.jpg","tmdb_url":"https://www.themoviedb.org/person/1187932"},{"name":"Tăng Hoa Thiên","name_vi":"Tăng Hoa Thiên","name_original":"Margie Tsang Wah-Sin","tmdb_id":1174084,"profile":"https://image.tmdb.org/t/p/w500/fJFfwhX7YBabeHkyvqOKfUmXqia.jpg","tmdb_url":"https: