 bị ghẻ lạnh của Carol, hiện là S.A.B.E.R. phi hành gia thuyền trưởng Monica Rambeau. Cùng với nhau, bộ ba kỳ lạ này phải hợp tác và học cách phối hợp với nhau để cứu vũ trụ.</p>","tmdb":{"type":"movie","id":"609681","season":null,"vote_average":5.95,"vote_count":3229},"modified":"2024-01-17T14:01:46.000Z","cast":["Brie Larson","Teyonah Parris","Iman Vellani","Samuel L. Jackson","Zawe Ashton","Gary Lewis","Park Seo-jun","Zenobia Shroff","Mohan Kapur","Saagar Shaikh","Leila Farzad","Abraham Popoola","Lashana Lynch","Tessa Thompson","Daniel Ings"],"director":["Nia DaCosta"],"cast_meta":[{"name":"Brie Larson","name_vi":null,"name_original":"Brie Larson","tmdb_id":60073,"profile":"https://image.tmdb.org/t/p/w500/rlbQbpu3tkMAikPWM53VElMUnzR.jpg","tmdb_url":"https://www.themoviedb.org/person/60073"},{"name":"Teyonah Parris","name_vi":null,"name_original":"Teyonah Parris","tmdb_id":970219,"profile":"https://image.tmdb.org/t/p/w500/iGvBTOi0y2fbBVwgnBRXgY0IXDY.jpg","tmdb_url":"https://www.themoviedb.org/person/970219"},{"name":"Iman Vellani","name_vi":null,"name_original":"Iman Vellani","tmdb_id":2798462,"profile":"https://image.tmdb.org/t/p/w500/jD2TNIyJQmdqijGTzhvdiYabYix.jpg","tmdb_url":"https://www.themoviedb.org/person/2798462"},{"name":"Samuel L. Jackson","name_vi":null,"name_original":"Samuel L. Jackson","tmdb_id":2231,"profile":"https://image.tmdb.org/t/p/w500/AiAYAqwpM5xmiFrAIeQvUXDCVvo.jpg","tmdb_url":"https://www.themoviedb.org/person/2231"},{"name":"Zawe Ashton","name_vi":null,"name_original":"Zawe Ashton","tmdb_id":118034,"profile":"https://image.tmdb.org/t/p/w500/zbxVfvhPhCfgpgmWTdtHWurNqYu.jpg","tmdb_url":"https://www.themoviedb.org/person/118034"},{"name":"Gary Lewis","name_vi":null,"name_original":"Gary Lewis","tmdb_id":480,"profile":"https://image.tmdb.org/t/p/w500/cOaibfAluUeWPtcSOjedfGXn9ym.jpg","tmdb_url":"https://www.themoviedb.org/person/480"},{"name":"Park Seo-jun","name_vi":null,"name_original":"Park Seo-jun","tmdb_id":1347525,"profile":"https://imag