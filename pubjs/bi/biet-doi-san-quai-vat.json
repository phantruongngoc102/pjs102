 vừa phải học vừa phải chiến đấu với đủ loại quái vật kỳ dị (từ sâu khổng lồ, yêu tinh, người sói, đến sinh vật ăn não). Bộ phim kết hợp hài hước tuổi teen kiểu Nickelodeon, hành động vui nhộn và chút yếu tố kinh dị nhẹ nhàng, rất được khán giả nhí và thanh thiếu niên yêu thích thời 2009-2011.</p>","tmdb_id":19169,"cast":["Nicholas Purcell","John Marshall Jones","Gage Golightly","Melise"],"director":["Pat Williams","Peter Lauer","Adam Weissman"],"keywords":[],"tmdb":{"type":"tv","id":"19169","season":1,"vote_average":7.7,"vote_count":19},"cast_meta":[{"name":"Nicholas Purcell","name_vi":null,"name_original":"Nicholas Purcell","tmdb_id":1271859,"profile":"https://image.tmdb.org/t/p/w500/61bUU6mfIfhEMYs2o2OeeGOb8mo.jpg","tmdb_url":"https://www.themoviedb.org/person/1271859"},{"name":"John Marshall Jones","name_vi":null,"name_original":"John Marshall Jones","tmdb_id":1194347,"profile":"https://image.tmdb.org/t/p/w500/8aQ8qxVOeUx23Jw89ouj9gOwy1W.jpg","tmdb_url":"https://www.themoviedb.org/person/1194347"},{"name":"Gage Golightly","name_vi":null,"name_original":"Gage Golightly","tmdb_id":145814,"profile":"https://image.tmdb.org/t/p/w500/htAji9G6V5YrDXYmm136K7a3lxc.jpg","tmdb_url":"https://www.themoviedb.org/person/145814"},{"name":"Melise","name_vi":null,"name_original":"Melise","tmdb_id":118544,"profile":"https://image.tmdb.org/t/p/w500/1USFrxT2872quJ0KGUUs2Zur3fl.jpg","tmdb_url":"https://www.themoviedb.org/person/118544"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/bi/biet-doi-san-quai-vat.json"}