rùm lên bầu trời của thành Lâm Hải đợi ngày bùng phát.</p>","tmdb_id":154681,"cast":["Zhang He"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"154681","season":1,"vote_average":7,"vote_count":2},"cast_meta":[{"name":"Zhang He","name_vi":null,"name_original":"Zhang He","tmdb_id":2974840,"profile":"https://image.tmdb.org/t/p/w500/3jY6ROHfcbFbYfEMEGT5ddeCqhv.jpg","tmdb_url":"https://www.themoviedb.org/person/2974840"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/bi/binh-chu-ky-hon.json"}