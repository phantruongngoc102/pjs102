7cc9709996dd1","link_m3u8":"https://vip.opstream14.com/20220517/12112_1a6a661d/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream14.com/share/e7d81336a1915eff69e6eb7f32cf1e77","link_m3u8":"https://vip.opstream14.com/20220517/12113_4c19f74f/index.m3u8"}]}],"description":"<p>Yang Guang, người dẫn chương trình chuyên mục tâm sự tình cảm, đã từ chối giao tiếp chân thành với mọi người cả trong công việc và cuộc sống vì bị bóng đen tâm lý từ thuở ấu thơ. Cho đến khi một chương trình mới hot thay thế vị trí chính của chuyên mục Dương Quang. Trước sức ép, Dương Quảng quyết định sửa đổi chuyên mục, từ nghe trực tuyến sang hòa giải ngoại tuyến, và hòa giải các tranh chấp có thể gây nóng mạng xã hội. Chuyên mục nhận được sự chú ý vì điều này, và nó cũng khiến Yang Guang lần đầu tiên đối mặt với vấn đề của chính mình.</p>","tmdb_id":199908,"cast":["Trần Hiểu","Vương Hiểu Thần","David Wang","Tăng Lê","Lai Nghệ","Wang Sisi","Khổng Lâm","Tu Ling","Wei Qing","Nghê Đại Hồng","Wang Zhifei","Feng Yunzhi","Wang Zizi","Zhang Guangbei"],"director":[],"keywords":[],"cast_meta":[{"name":"Trần Hiểu","name_vi":"Trần Hiểu","name_original":"Chen Xiao","tmdb_id":1192909,"profile":"https://image.tmdb.org/t/p/w500/6D4YFXfukHzD03IlHtUN67yTwHF.jpg","tmdb_url":"https://www.themoviedb.org/person/1192909"},{"name":"Vương Hiểu Thần","name_vi":"Vương Hiểu Thần","name_original":"Wang Xiaochen","tmdb_id":1135172,"profile":"https://image.tmdb.org/t/p/w500/4CcEIYCJGsnlonoaNWynM1Fgyvl.jpg","tmdb_url":"https://www.themoviedb.org/person/1135172"},{"name":"David Wang","name_vi":null,"name_original":"David Wang","tmdb_id":1623136,"profile":"https://image.tmdb.org/t/p/w500/uDOia8x3GyqhRnQs7Akgqytui7Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1623136"},{"name":"Tăng Lê","name_vi":"Tăng Lê","name_original":"Zeng Li","tmdb_id":2308991,"profile":"https://image.tmdb.org/t/p/w500/zE2j5wq5X8R6ymkj6CHhbNOHUpg.jpg","tmdb_url":"https://www.themoviedb.org/person/2308991"},{"name":"Lai Nghệ","n