_25772dc4/index.m3u8"},{"name":"34","slug":"34","filename":"Bình Tĩnh Nói - Tập 34","link_embed":"https://vip.opstream14.com/share/a8e5a72192378802318bf51063153729","link_m3u8":"https://vip.opstream14.com/20220514/11876_104207a6/index.m3u8"},{"name":"35","slug":"35","filename":"Bình Tĩnh Nói - Tập 35","link_embed":"https://vip.opstream14.com/share/0cc24cb7c26586310cc95c8cb1a81cbc","link_m3u8":"https://vip.opstream14.com/20220514/11877_4419c5fd/index.m3u8"},{"name":"36","slug":"36","filename":"Bình Tĩnh Nói - Tập 36","link_embed":"https://vip.opstream14.com/share/b32a29fd7425fb6b46049bf9e240cda1","link_m3u8":"https://vip.opstream14.com/20220514/11878_e7ecb415/index.m3u8"},{"name":"37","slug":"37","filename":"Bình Tĩnh Nói - Tập 37","link_embed":"https://vip.opstream14.com/share/5226ac4e0683ad4f37000ec897761687","link_m3u8":"https://vip.opstream14.com/20220514/11879_3bc0df6a/index.m3u8"},{"name":"38","slug":"38","filename":"Bình Tĩnh Nói - Tập 38","link_embed":"https://vip.opstream14.com/share/6e171103e852992b0d83f35dbb0d358e","link_m3u8":"https://vip.opstream14.com/20220514/11880_e7c31e04/index.m3u8"},{"name":"39","slug":"39","filename":"Bình Tĩnh Nói - Tập 39","link_embed":"https://vip.opstream14.com/share/e022c20ad33354cbec77cc9709996dd1","link_m3u8":"https://vip.opstream14.com/20220517/12112_1a6a661d/index.m3u8"},{"name":"40","slug":"40","filename":"Bình Tĩnh Nói - Tập 40","link_embed":"https://vip.opstream14.com/share/e7d81336a1915eff69e6eb7f32cf1e77","link_m3u8":"https://vip.opstream14.com/20220517/12113_4c19f74f/index.m3u8"}]}],"time":"45:38","description":"<p>Yang Guang, người dẫn chương trình chuyên mục tâm sự tình cảm, đã từ chối giao tiếp chân thành với mọi người cả trong công việc và cuộc sống vì bị bóng đen tâm lý từ thuở ấu thơ. Cho đến khi một chương trình mới hot thay thế vị trí chính của chuyên mục Dương Quang. Trước sức ép, Dương Quảng quyết định sửa đổi chuyên mục, từ nghe trực tuyến sang hòa giải ngoại tuyến, và hòa giải các tranh chấp có thể gây nóng mạng xã hội. Chuyên mục nhận được sự chú ý vì điều này, và nó cũng khiến Yang Guang lần đầu tiên đối mặt với vấn đề của chính mình.</p>","tmdb":{"type":"tv","id":"199908","season":1,"vote_average":5,"vote_count":2},"modified":"2022-05-17T19:48:59.000Z","cast":["Chen Xiao","Wang Xiaochen","Wang Yaoqing","Zeng Li"],"director":["Dương Đông"],"cast_meta":[{"name":"Chen Xiao","name_vi":null,"name_original":"Chen Xiao"},{"name":"Wang Xiaochen","name_vi":null,"name_original":"Wang Xiaochen"},{"name":"Wang Yaoqing","name_vi":null,"name_original":"Wang Yaoqing"},{"name":"Zeng Li","name_vi":null,"name_original":"Zeng Li"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/bi/binh-tinh-noi.json"}