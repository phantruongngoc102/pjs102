{"id":"6235b3e63d016a3b6717bb9a","title":"Blade II","origin_name":"Blade II","slug":"blade-ii","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/bl/blade-ii.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/bl/blade-ii.webp","year":2002,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"},{"id":"620a229be0fc277084dfd4dd","name":"Khoa Học","slug":"khoa-hoc"},{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620e0e8fd9648f114cde77f7","name":"Đức","slug":"duc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Blade II","link_embed":"https://vip.opstream14.com/share/7bd28f15a49d5e5848d6ec70e584e625","link_m3u8":"https://vip.opstream14.com/20220318/1571_8e95c1a7/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Một đột biến hiếm gặp đã xảy ra trong cộng đồng ma cà rồng. Máy gặt. Một ma cà rồng được tiêu thụ với một ngụm máu vô độ mà họ săn mồi trên ma cà rồng cũng như con người, biến đổi nạn nhân đủ may mắn để sống sót thành những người gặt. Bây giờ họ nhanh chóng mở rộng dân số đe dọa sự tồn tại của ma cà rồng, và sẽ sớm không có đủ con người trên thế giới để đáp ứng sự đổ máu của họ. Blade, Whistler và một chuyên gia Armory tên Scud được giới thiệu tò mò bởi Hội đồng Shadow. Hội đồng miễn cưỡng thừa nhận rằng họ đang ở trong một tình huống thảm khuất và họ cần sự giúp đỡ của Blade. Lưỡi dao sau đó kéo dài vào một liên minh với Bloodpack, một nhóm ma cà rồng ưu tú được đào tạo trong tất cả các chế độ chiến đấu để đánh bại mối đe dọa Reaper. Đội của Blade và Bloodpack là dòng hàng phòng ngự duy nhất có thể ngăn chặn dân số Reaper quét sạch ma cà rồng và quần thể người.</p>","tmdb":{"type":"movie","id":"36586","season":null,"vote_average":6.556,"vote_count":5083},"modified":"2024-10-20T14:33:44.000Z","cast":["Wesley Snipes","Kris Kristofferson","Ron Perlman","Leonor Varela","Norman Reedus","Thomas Kretschmann","Luke Goss","Matt Schulze","Danny John-Jules","Chân Tử Đan","Karel Roden","Marit Velle Kile","Tony Curran","Daz Crawford","Santiago Segura"],"director":["Guillermo del Toro"],"cast_meta":[{"name":"Wesley Snipes","name_vi":null,"name_original":"Wesley Snipes","tmdb_id":10814,"profile":"https://image.tmdb.org/t/p/w500/iDmPuZXAGheRMbMyB80acMWYJ2s.jpg","tmdb_url":"https://www.themoviedb.org/person/10814"},{"name":"Kris Kristofferson","name_vi":null,"name_original":"Kris Kristofferson","tmdb_id":10823,"profile":"https://image.tmdb.org/t/p/w500/efD2Uu8QYBN7ZWSFa79mm3Pkk4L.jpg","tmdb_url":"https://www.themoviedb.org/person/10823"},{"name":"Ron Perlman","name_vi":null,"name_original":"Ron Perlman","tmdb_id":2372,"profile":"https://image.tmdb.org/t/p/w500/pOgMRdJhbBsvwGLRFXPRASTfcay.jpg","tmdb_url":"https://www.themoviedb.org/person/2372"},{"name":"Leonor Varela","name_vi":null,"name_original":"Leonor Varela","tmdb_id":10839,"profile":"https://image.tmdb.org/t/p/w500/ooZQvMganzssNGoTKaIgFXM38U7.jpg","tmdb_url":"https://www.themoviedb.org/person/10839"},{"name":"Norman Reedus","name_vi":null,"name_original":"Norman Reedus","tmdb_id":4886,"profile":"https://image.tmdb.org/t/p/w500/ozHPdO5jAt7ozzdZUgyRAMNPSDW.jpg","tmdb_url":"https://www.themoviedb.org/person/4886"},{"name":"Thomas Kretschmann","name_vi":null,"name_original":"Thomas Kretschmann","tmdb_id":3491,"profile":"https://image.tmdb.org/t/p/w500/kBnPu1KREhckuPpnAUppm24kkVX.jpg","tmdb_url":"https://www.themoviedb.org/person/3491"},{"name":"Luke Goss","name_vi":null,"name_original":"Luke Goss","tmdb_id":10843,"profile":"https://image.tmdb.org/t/p/w500/bHdc67gZFz