 đặc nhiệm XAT, Xenogenesis Assault Team-chuyên săn lùng các Demoniacs. Cuộc chiến giữa họ và các Demoniacs đã mở ra những bí mật kinh khủng liên quan đến sự ra đời của Demoniacs và sự xuất hiện của Blassreiter- Demoniac mạnh nhất và thống lĩnh các Demoniacs khác.</p>","tmdb":{"type":"tv","id":"34216","season":1,"vote_average":5.6,"vote_count":13},"modified":"2023-07-29T09:34:44.000Z","cast":["Masaya Matsukaze","Kenta Miyake","Kana Hanazawa","Junko Minagawa","Unsho Ishizuka","Nakamura Yuichi","Shizuka Itoh","Unsho Ishizuka","Junichi Suwabe","Fumihiko Tachiki","Nobuyuki Hiyama","Aya Endo","Atsushi Ono","Hitomi Nabatame","Hiroyuki Kinoshita"],"director":[],"cast_meta":[{"name":"Masaya Matsukaze","name_vi":null,"name_original":"Masaya Matsukaze","tmdb_id":934841,"profile":"https://image.tmdb.org/t/p/w500/tUd3ybETFz4hBGLnaqt3VreGeDJ.jpg","tmdb_url":"https://www.themoviedb.org/person/934841"},{"name":"Kenta Miyake","name_vi":null,"name_original":"Kenta Miyake","tmdb_id":225603,"profile":"https://image.tmdb.org/t/p/w500/7YL8vM2KYzPMeQqTpHWmNj6s1AP.jpg","tmdb_url":"https://www.themoviedb.org/person/225603"},{"name":"Kana Hanazawa","name_vi":null,"name_original":"Kana Hanazawa","tmdb_id":119143,"profile":"https://image.tmdb.org/t/p/w500/9UTBlNRopSOKyoWnCm74tyHOfR1.jpg","tmdb_url":"https://www.themoviedb.org/person/119143"},{"name":"Junko Minagawa","name_vi":null,"name_original":"Junko Minagawa","tmdb_id":228234,"profile":"https://image.tmdb.org/t/p/w500/vylNOlXVmYFW8TJgq3Dvgoq1dy5.jpg","tmdb_url":"https://www.themoviedb.org/person/228234"},{"name":"Unsho Ishizuka","name_vi":null,"name_original":"Unsho Ishizuka","tmdb_id":68916,"profile":"https://image.tmdb.org/t/p/w500/nmj1vTrJc0zvuUYqxSyWXmIGBlP.jpg","tmdb_url":"https://www.themoviedb.org/person/68916"},{"name":"Nakamura Yuichi","name_vi":"Nakamura Yuichi","name_original":"Yuichi Nakamura","tmdb_id":1221114,"profile":"https://image.tmdb.org/t/p/w500/wb8behVKjBHX9XXrEydvNINCYwH.jpg","tmdb_url":"https://www.themoviedb.org/pe