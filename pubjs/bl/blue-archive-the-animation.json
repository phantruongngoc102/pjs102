oại thông minh! Hãy trải nghiệm những tình tiết hành động gay cấn, tình yêu và tình bạn mà Blue Archive The Animation mang lại)","tmdb_id":218833,"cast":["Yui Ogura","Yumiri Hanamori","Ayaka Ohashi","Chiyuki Miura","Sayaka Harada","Reina Kondo","Yukiyo Fujii","Erika Ishitobi","Rumi Okubo","Ryo Hirohashi","Marika Kouno","Ayane Sakura","Haruka Kouzuki","Kaede Hondo","Konomi Kohara"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"218833","season":1,"vote_average":6.9,"vote_count":13},"cast_meta":[{"name":"Yui Ogura","name_vi":null,"name_original":"Yui Ogura","tmdb_id":1057990,"profile":"https://image.tmdb.org/t/p/w500/vUuyLWde2CEd5G0oqeEzzFE6qqA.jpg","tmdb_url":"https://www.themoviedb.org/person/1057990"},{"name":"Yumiri Hanamori","name_vi":null,"name_original":"Yumiri Hanamori","tmdb_id":1565358,"profile":"https://image.tmdb.org/t/p/w500/zXVwGxsxwEvL1f6wxzTYtxytjDn.jpg","tmdb_url":"https://www.themoviedb.org/person/1565358"},{"name":"Ayaka Ohashi","name_vi":null,"name_original":"Ayaka Ohashi","tmdb_id":1256547,"profile":"https://image.tmdb.org/t/p/w500/2nvtejsD4sc6QNlPhGedKvr3VS1.jpg","tmdb_url":"https://www.themoviedb.org/person/1256547"},{"name":"Chiyuki Miura","name_vi":null,"name_original":"Chiyuki Miura","tmdb_id":2394448,"profile":"https://image.tmdb.org/t/p/w500/nEqBGUvmAiDFPCfqgVkPOo092Nj.jpg","tmdb_url":"https://www.themoviedb.org/person/2394448"},{"name":"Sayaka Harada","name_vi":null,"name_original":"Sayaka Harada","tmdb_id":1503522,"profile":"https://image.tmdb.org/t/p/w500/w7yVocz9zVPlfxpegYIPiDdAUac.jpg","tmdb_url":"https://www.themoviedb.org/person/1503522"},{"name":"Reina Kondo","name_vi":null,"name_original":"Reina Kondo","tmdb_id":1922614,"profile":"https://image.tmdb.org/t/p/w500/yxxLyu5Ya8NftpY5NVR7uy1tzau.jpg","tmdb_url":"https://www.themoviedb.org/person/1922614"},{"name":"Yukiyo Fujii","name_vi":null,"name_original":"Yukiyo Fujii","tmdb_id":1287794,"profile":"https://image.tmdb.org/t/p/w500/tLG4K1iix3QNHFexf98mrZ25jT6.jpg","tmdb_url":"htt