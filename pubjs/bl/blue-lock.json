":"https://vip.opstream11.com/share/6150bf474f35cfe72d60c24f46a991fc","link_m3u8":"https://vip.opstream11.com/20230326/43143_33f8e6b5/index.m3u8"},{"name":"24","slug":"24","filename":"Blue Lock Tập 24 - Thời khắc đã điểmTập 24","link_embed":"https://vip.opstream11.com/share/525a12095ee281d7f23e073acee75040","link_m3u8":"https://vip.opstream11.com/20230326/43139_5c1f0c7b/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Nhật Bản gặp khó khăn trở lại đường đua sau thảm họa World Cup 2018. nhưng liên tục cảm thấy như thể thiếu một cái gì đó? Vâng, họ có một tiền đạo không thể đánh bại, người có thể giúp họ giành chiến thắng. JFA cam kết sản xuất một tiền đạo khao khát cả mục tiêu và chiến thắng để anh ta có thể trở thành thành phần quan trọng trong việc phục hồi sau các trận thua. 300 cầu thủ xuất sắc nhất Nhật Bản và cầu thủ trẻ tài năng nhất đã được tập hợp cho mục đích này. Ai sẽ trở thành thành viên hàng đầu của nhóm lãnh đạo? Liệu họ có thể vượt qua được bắp tay và cái tôi của mọi người cản đường họ?</p>","tmdb":{"type":"tv","id":"131041","season":1,"vote_average":8.214,"vote_count":528},"modified":"2025-04-14T11:59:56.000Z","cast":["Kazuki Ura","Tasuku Kaito","Yuki Ono","Soma Saito","Junichi Suwabe","Nobunaga Shimazaki","Yoshitsugu Matsuoka"],"director":[],"cast_meta":[{"name":"Kazuki Ura","name_vi":null,"name_original":"Kazuki Ura","tmdb_id":2534630,"profile":"https://image.tmdb.org/t/p/w500/7eUgENWREmWSMnLPUFCQhvUSpdI.jpg","tmdb_url":"https://www.themoviedb.org/person/2534630"},{"name":"Tasuku Kaito","name_vi":null,"name_original":"Tasuku Kaito","tmdb_id":3195937,"profile":"https://image.tmdb.org/t/p/w500/eDtru6RxBnCtuYtU2mIXidKekJv.jpg","tmdb_url":"https://www.themoviedb.org/person/3195937"},{"name":"Yuki Ono","name_vi":null,"name_original":"Yuki Ono","tmdb_id":1206317,"profile":"https://image.tmdb.org/t/p/w500/oEx13CbNLsHzURdYafkFJYXDjfm.jpg","tmdb_url":"https://www.themoviedb.org/person/1206317"},{"name":"Soma Saito","name_vi":null,"name_original":"Soma