15.com/share/861f8aa2598860c0023f399e992eb747","link_m3u8":"https://vip.opstream15.com/20220502/10639_444afe42/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/924d312b3b6128ecf9a73549fab9baca","link_m3u8":"https://vip.opstream15.com/20220502/10642_c2ae2f67/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/c76e4b2fa54f8506719a5c0dc14c2eb9","link_m3u8":"https://vip.opstream15.com/20220502/10644_81750802/index.m3u8"}]}],"description":"<p>Bộ Đôi Công Lý xoay quanh Park Tae Yong và Park Sam Soo, 2 nhân vật sẵn sàng đấu tranh đến cùng cho những nạn nhân bị vu oan. Park Tae Yong là một luật sư công. Xuất thân bình thường nhưng lại đi theo con đường không bình thường để trở thành luật sư. Sau khi tốt nghiệp trung học, anh không học lên đại học mà cố gắng vượt qua khóa đào tạo cấp chứng chỉ hành nghề và trở thành luật sư. Vốn là một người đề cao công lý và có sự đồng cảm với người khác nên anh ta luôn ra sức bảo vệ tất cả dù là phạm tội nhẹ nhất. Một bước ngoặt lớn trong sự nghiệp của Tae Yong là khi anh là luật sư công đầu tiên cãi thắng vụ án hình sự tái thẩm. Park Sam Soo là một phóng viên dễ rơi nước mắt và mềm lòng. Sau khi tốt nghiệp đại học, anh là nhân viên không cố định, nhờ khả năng viết lách tuyệt vời mà anh ta đã trở thành phóng viên. Sam Soo thường theo đuổi những câu chuyện mà các phóng viên khác phớt lờ hoặc bỏ qua.</p>","tmdb_id":112322,"cast":["Kwon Sang-woo","Kim Joo-hyun","Jung Woong-in","Kim Eung-soo","Cho Seong-ha","Kim Kap-soo","Lee Won-jong","Park Ji-il","Lee Soon-won","Kim Hye-hwa","An Si-ha"],"director":["Kwak Jung Hwan"],"keywords":[],"tmdb":{"type":"tv","id":"112322","season":1,"vote_average":6.5,"vote_count":11},"cast_meta":[{"name":"Kwon Sang-woo","name_vi":null,"name_original":"Kwon Sang-woo","tmdb_id":1233094,"profile":"https://image.tmdb.org/t/p/w500/sXWZ82ph4ZPPG9kv2x6nXha1Kk4.jpg","tmdb_url":"https://www.themoviedb.org/person/1233094"},{"name":"Kim Joo-hyun","name_vi":nu