4081_52602e9a/index.m3u8"},{"name":"5","slug":"5","link_embed":"https://vip.opstream11.com/share/e09baed818bb105cc3f3451d6aa93f2d","link_m3u8":"https://vip.opstream11.com/20220510/24082_2b60687e/index.m3u8"},{"name":"5","slug":"5","link_embed":"https://vip.opstream11.com/share/e09baed818bb105cc3f3451d6aa93f2d","link_m3u8":"https://vip.opstream11.com/20220510/24082_2b60687e/index.m3u8"},{"name":"6","slug":"6","link_embed":"https://vip.opstream11.com/share/fbcb037387e821a6b1898467b076c0d5","link_m3u8":"https://vip.opstream11.com/20220510/24083_95558029/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream11.com/share/7a6cf796456b6d7c4c2bde93dd17c682","link_m3u8":"https://vip.opstream11.com/20220510/24084_65d51707/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream11.com/share/623073121ba44a854dde0a3b362e32f0","link_m3u8":"https://vip.opstream11.com/20220510/24085_2810b78c/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream11.com/share/4a55dbdc6c16615070050599ef141d44","link_m3u8":"https://vip.opstream11.com/20220510/24086_a07539ca/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream11.com/share/5859953a451c4084472660061581b8cc","link_m3u8":"https://vip.opstream11.com/20220510/24087_a5de6eb4/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream11.com/share/f01a350709f093f9fd1440329470e701","link_m3u8":"https://vip.opstream11.com/20220510/24088_2064129b/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream11.com/share/9d01f88c4721c244674284dbfc79ab77","link_m3u8":"https://vip.opstream11.com/20220510/24089_32a1d5ca/index.m3u8"}]}],"description":"<p>Một nhóm ưu tú được gọi là Owl phục vụ hoàng đế của Nhật Bản. Với một mục đích nhất định trong đầu, họ bí mật tìm kiếm mười bảo vật thiêng liêng nằm rải rác khắp đất nước. Đôi khi chúng thậm chí còn được gọi là sát thủ, do sức tàn phá khủng khiếp của chúng. Anh em nhà Tachibana, được nhiều người biết đến là những chiến binh mạnh nhất trong Owl, hiện đang tiến về khu bảo tồn ở Kumano. Trong khi đó, ở tỉnh Kii, nơi đã thoát khỏi cuộc chiến với Hideyoshi, nhóm lính đánh thuê Saika Ikki đang cố gắng chuyển đến một ngôi làng nằm sâu trong núi của Miền Kishu. Fujishiro, lãnh đạo của tỉnh Kii, cũng đang hướng đến thánh địa ở Kumano, cùng với ba người sử dụng áo giáp - Tsurukubi, Kokuhyo và Ageha. Anh ta định yêu cầu thần làng của họ được chào đón vào đền thờ Kumano Shrine. Các sinh vật ở thế giới khác cũng đang tiến về khu bảo tồn, để mắt đến những kho báu thiêng liêng. Trong chốc lát, tiếng nước vang lên. Khu bảo tồn lựa chọn những người thực hiện điều ước với các vị thần và yêu cầu họ phải trải qua một cuộc thử thách thanh tẩy. Giữa tất cả những điều này, một \"cuộc hội ngộ\" bất ngờ diễn ra. Một lần nữa, những chiếc áo giáp rỉ sét đang di chuyển, và con cú trên bầu trời xanh đang dang rộng đôi cánh của mình.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/bo/bo-giap-ri-set-binh-minh.json"}