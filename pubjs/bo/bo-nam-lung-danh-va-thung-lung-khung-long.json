ung lũng Khủng long.</p>","tmdb":{"type":"movie","id":"485371","season":null,"vote_average":6,"vote_count":38},"modified":"2022-12-02T14:57:20.000Z","cast":["Allegra Tinnefeld","Marinus Hohmann","Ron Antony Renzenbrink","Amelie Lammers","Jacob Matschenz","Peter Prager","Melika Foroutan","Dirk Borchardt","Jürgen Tarrach","Dagmar Sachse","Manuel Cortez","Milan Peschel","Bernadette Heerwagen","Ruby O. Fee","David Baalcke"],"director":["Mike Marzuk"],"cast_meta":[{"name":"Allegra Tinnefeld","name_vi":null,"name_original":"Allegra Tinnefeld","tmdb_id":1616760,"profile":"https://image.tmdb.org/t/p/w500/oEPdkZt2ddWVr1gEdcoVipFoKxu.jpg","tmdb_url":"https://www.themoviedb.org/person/1616760"},{"name":"Marinus Hohmann","name_vi":null,"name_original":"Marinus Hohmann","tmdb_id":1721983,"profile":"https://image.tmdb.org/t/p/w500/j66QbZBX9GoGoz8iF2kjrSjG8wx.jpg","tmdb_url":"https://www.themoviedb.org/person/1721983"},{"name":"Ron Antony Renzenbrink","name_vi":null,"name_original":"Ron Antony Renzenbrink","tmdb_id":1792431,"profile":"https://image.tmdb.org/t/p/w500/2siAmXNqDVA3xdP64rJGXb3qgBR.jpg","tmdb_url":"https://www.themoviedb.org/person/1792431"},{"name":"Amelie Lammers","name_vi":null,"name_original":"Amelie Lammers","tmdb_id":1966956,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1966956"},{"name":"Jacob Matschenz","name_vi":null,"name_original":"Jacob Matschenz","tmdb_id":52722,"profile":"https://image.tmdb.org/t/p/w500/15AzdlqD13Bw0pLZC5pEItDFx0T.jpg","tmdb_url":"https://www.themoviedb.org/person/52722"},{"name":"Peter Prager","name_vi":null,"name_original":"Peter Prager","tmdb_id":36755,"profile":"https://image.tmdb.org/t/p/w500/6m9J6Quf648k6s9pDSPh46wB6pC.jpg","tmdb_url":"https://www.themoviedb.org/person/36755"},{"name":"Melika Foroutan","name_vi":null,"name_original":"Melika Foroutan","tmdb_id":57064,"profile":"https://image.tmdb.org/t/p/w500/nlXZFeqhXGbR5KePkO4UCcEUfg4.jpg","tmdb_url":"https://www.themoviedb.org/person/57064"},{"name":"Dirk Borchardt"