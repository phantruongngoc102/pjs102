5/index.m3u8"},{"name":"79","slug":"79","filename":"Bố Tôi Là Người Giàu Nhất - Tập 79---2025","link_embed":"https://vip.opstream-short.com/share/bb64c74f463ee92e6f877c47a130d645","link_m3u8":"https://vip.opstream-short.com/20251118/33588_bb64c74f/index.m3u8"},{"name":"80","slug":"80","filename":"Bố Tôi Là Người Giàu Nhất - Tập 80---2025","link_embed":"https://vip.opstream-short.com/share/ee1d01930813d9f10858db96fd9d58b1","link_m3u8":"https://vip.opstream-short.com/20251118/33589_ee1d0193/index.m3u8"}]}],"time":"2 phút/tập","description":"<p>Một người đàn ông bị tách khỏi gia đình từ nhỏ trở thành trẻ mồ côi và được gia đình Hà nhận nuôi. Anh ta kết hôn vào gia đình nhưng phải đối mặt với sự sỉ nhục liên tục. Khi bán rau, anh gặp cha ruột của mình, nhưng mẹ vợ hiểu lầm tình huống. Khi anh về nhà để chia sẻ tin vui với vợ, anh phát hiện vợ ngoại tình. Anh cắt đứt quan hệ với gia đình Hà và biết được danh tính thật của cha mình là một doanh nhân giàu có. Cha anh muốn trả thù gia đình Hà, nhưng con trai ngăn cản và chọn thành công bằng khả năng của mình. Anh gặp nữ chính và giúp cô thoát khỏi cuộc hôn nhân sắp đặt, được cô yêu nhưng cũng tạo ra kẻ thù. Không biết rằng cha anh đã bí mật mua lại công ty nơi anh làm việc. Ngày đầu tiên, có người giả mạo anh, nhưng anh sử dụng cơ hội này để phơi bày tham nhũng trong công ty. Khi gia đình nữ chính tìm đến anh, anh không tiết lộ danh tính. Sau đó khi công ty của cha anh đối mặt với sự trả thù từ kẻ thù, anh cứu cả công ty và nữ chính, chiếm được trái tim cô. Họ cùng nhau chọn sống lặng lẽ sau hậu trường.</p>","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-25T13:05:25.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/bo/bo-toi-la-nguoi-giau-nhat-short-drama.json","keywords":[],"tmdb_checked":false}