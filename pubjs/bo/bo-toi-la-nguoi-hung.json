.com/share/5aaffbae8a48fc24f114ee4dcd9c6171","link_m3u8":"https://vip.opstream11.com/20220402/8640_88cb8d8e/index.m3u8"},{"name":"39","slug":"39","filename":"Bố Tôi Là Người Hùng - My Hero,My Daddy - Tập 39","link_embed":"https://vip.opstream11.com/share/51fd081fb2f037078fc8a4e037daabe4","link_m3u8":"https://vip.opstream11.com/20220402/8641_a2a3c791/index.m3u8"},{"name":"40","slug":"40","filename":"Bố Tôi Là Người Hùng - My Hero,My Daddy - Tập 40","link_embed":"https://vip.opstream11.com/share/0912d0f15f1394268c66639e39b26215","link_m3u8":"https://vip.opstream11.com/20220402/8642_8b291a17/index.m3u8"},{"name":"41","slug":"41","filename":"Bố Tôi Là Người Hùng - My Hero,My Daddy - Tập 41","link_embed":"https://vip.opstream11.com/share/c85b2ea9a678e74fdc8bafe5d0707c31","link_m3u8":"https://vip.opstream11.com/20220402/8643_695e9b76/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bố Tôi Là Người Hùng - My Hero,My Daddy là bộ phim ngôn tình hay nhất, xoay quanh câu chuyện về gia đình Sư Phụ Hoàng – một nhà thiết kế vest lâu đời cho một thương hiệu thời trang nam nổi tiếng ở Đại Lục. Ông có 3 cô con gái với ba tính cách vô cùng khác nhau. Tình yêu quá lớn của người cha dành cho các cô con gái đã đẩy ông vào cuộc chiến với các chàng rể trong chính gia đình mình. Ba cô con gái của ông với 3 tính cách khác nhau nhưng tựu chung lại đều rất mạnh mẽ, sống tình cảm và có chính kiến, chính vì vậy chuyện tình cảm của mỗi người con gái luôn khiến ông lo lắng không yên.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-06-04T18:40:21.000Z","cast":["Châu Hiếu An","Châu Hiểu Âu","Tsai Chen-nan"],"director":["Lý Khổng Úy"],"cast_meta":[{"name":"Châu Hiếu An","name_vi":null,"name_original":"Châu Hiếu An"},{"name":"Châu Hiểu Âu","name_vi":null,"name_original":"Châu Hiểu Âu"},{"name":"Tsai Chen-nan","name_vi":null,"name_original":"Tsai Chen-nan"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/bo/bo-toi-la-