.opstream15.com/20230501/38552_d19543da/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream15.com/share/3457c20de13ee504e33b7e6a9ec92e8a","link_m3u8":"https://vip.opstream15.com/20230501/38553_80a73009/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/2f1227c50fcdddb18e869bfdeae65a06","link_m3u8":"https://vip.opstream15.com/20230501/38554_714c98f0/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream15.com/share/923ccbcec867ebc5588386df7c370c55","link_m3u8":"https://vip.opstream15.com/20230501/38555_1f2968b4/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream15.com/share/554bd98734fa2d47c08f446562f3ba4d","link_m3u8":"https://vip.opstream15.com/20230501/38556_25f559cb/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream15.com/share/9b03bd15cd9675565205c882ded07ef6","link_m3u8":"https://vip.opstream15.com/20230501/38558_526a085c/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream15.com/share/5779285408aab2cf0ae3355162da7cf6","link_m3u8":"https://vip.opstream15.com/20230501/38573_5d1e98c1/index.m3u8"}]}],"description":"<p>Trong khu rừng bạch dương của một thị trấn nhỏ, vào thời điểm này, Wang Xiang, một tài xế taxi, không bao giờ có thể mong đợi gặp được người mà anh ta muốn gặp nhất hoặc sợ hãi nhất trong cuộc đời mình. Anh ta là kẻ thù hay bạn bè? Vì anh ấy đã gặp anh ấy, anh ấy phải đóng cửa. Không chỉ cho anh ấy, mà còn cho con trai anh ấy. Trong khu rừng bạch dương của một thị trấn nhỏ, vào thời điểm đó, Wang Xiang, một người lái tàu, tràn đầy sức sống và sức sống vì anh ta đang điều khiển một con quái vật bằng thép với hai mươi toa tàu. Nhưng một mặt, anh thất bại trong việc điều hành một gia đình nhỏ gồm ba người với đầy những vấn đề tầm thường. Mặt khác, anh ta bị mắc kẹt trong một nhà máy đang lụi tàn với một cuộc khủng hoảng rình rập từ mọi ngóc ngách. Một gói các bộ phận cơ thể không xác định được thả trong rừng bạch dương, giống như một viên đá rơi xuống mặt nước yên tĩnh. Trong hai mươi năm qua, Wang Xiang không bao giờ có thể ngừng nghĩ về gói đó, ngay cả khi những chiếc lá chuyển sang màu vàng vào mùa thu. Một người cha đã mất, một người yêu đã chết và những người bạn cũ gặp lại nhau bị mắc kẹt ở ba thời đại khác nhau vì một bí ẩn chưa được giải quyết. Tất cả những gì họ muốn là tìm ra một sự thật xuyên suốt quá khứ, hiện tại và tương lai. Khi bí ẩn được hé lộ, chỉ còn lại sự bi tráng của số phận và thời đại trong trường đoạn dài với thời gian và không gian đan xen vào nhau.</p>","tmdb_id":225008,"cast":["Phạm Vỹ","Qin Hao","Chen Minghao","Lý Canh Hy","Liu Yitie","Jiang Qiming","Lưu Lâm","Shi Pengyuan","Hou Yansong","Diana Lin Xiaojie","Wang Jiajia","Yang Yiwei","Đường Tằng","Wang Yidi","Lin Peng"],"director":["Xin Shuang"],"keywords":[],"tmdb":{"type":"tv","id":"225008","season":1,"vote_average":8.858,"vote_count":106},"cast_meta":[{"name":"Phạm Vỹ","name_vi":"Phạm Vỹ","name_original":"Fan Wei","tmdb_id":134029,"profile":"https://image.tmdb.org/t/p/w500/tcnzgvuFW8SkE2OGD2Vve12kNSo.jpg","tmdb_url":"https://www.themoviedb.org/person/134029"},{"name":"Qin Hao","name_vi":null,"name_original":"Qin Hao","tmdb_id":1016315,"profile":"https://image.tmdb.org/t/p/w500/nBlIPKKCj5x4hBPLAKGacwTUdlQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1016315"},{"name":"Chen Minghao","name_vi":null,"name_original":"Chen Minghao","tmdb_id":124993,"profile":"https://image.tmdb.org/t/p/w500/ksWDHeCd9Tbhtj4Zbh10EbT58CM.jpg","tmdb_url":"https://www.themoviedb.org/person/124993"},{"name":"Lý Canh Hy","name_vi":"Lý Canh Hy","name_original":"Li Gengxi","tmdb_id":81128,"profile":"https://image.tmdb.org/t/p/w500/ztPbA2F07VCFHSAaHMTID49klTH.jpg","tmdb_url":"https://www.themoviedb.org/person/81128"},{"name":"Liu Yitie","name_vi":null,"name_original":"Liu Yitie","tmdb_id":3480427,"profile":"https://image.tmdb.org/t/p/w500/ptHoNnFwmzJryRi1TS6CPka6bvp.jpg","tmdb_url":"https://www.themoviedb.org/person/3480427"},{"nam