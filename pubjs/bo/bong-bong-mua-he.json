3u8":"https://vip.opstream16.com/20220227/320_1b674916/index.m3u8"},{"name":"34","slug":"34","filename":"Bong Bóng Mùa Hè - Tập 34","link_embed":"https://vip.opstream16.com/share/caf1a3dfb505ffed0d024130f58c5cfa","link_m3u8":"https://vip.opstream16.com/20220227/321_059d0764/index.m3u8"},{"name":"35","slug":"35","filename":"Bong Bóng Mùa Hè - Tập 35","link_embed":"https://vip.opstream16.com/share/5737c6ec2e0716f3d8a7a5c4e0de0d9a","link_m3u8":"https://vip.opstream16.com/20220227/322_5feb3246/index.m3u8"},{"name":"36","slug":"36","filename":"Bong Bóng Mùa Hè - Tập 36","link_embed":"https://vip.opstream16.com/share/bc6dc48b743dc5d013b1abaebd2faed2","link_m3u8":"https://vip.opstream16.com/20220227/323_3e55f8dc/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim xoay quanh câu chuyện về cô tiểu thư nhà giàu Hạ Mạt. Khi còn nhỏ, Hạ Mạt cực kỳ có cảm tình với Âu Thần - anh chàng \"hot boy\" trong trường. Năm Hạ Mạt 15 tuổi, gia đình cô nhận nuôi một bé trai lầm lì ít nói tên Lạc Hi. Cô và Lạc Hi trở thành bạn thân của nhau. Những tưởng cuộc sống của Hạ Mạt sẽ không có gì thay đổi cho tới một ngày, cha mẹ cô qua đời vì tai nạn, còn Lạc Hi bị gửi sang Anh. Một mình Hạ Mạt phải gánh vác gia đình và nuôi đứa em nhỏ. Năm năm sau, Lạc Hi trở về nhà và thành ngôi sao nổi tiếng. Hạ Mạt cũng bước chân vào làng giải trí. Cả hai đã gặp nhau và câu chuyện tình tay ba giữa Hạ Mạt, Lạc Hi và Âu Thần trở nên phức tạp.</p>","tmdb":{"type":"tv","id":"79573","season":1,"vote_average":5.5,"vote_count":2},"modified":"2023-07-20T09:31:05.000Z","cast":["Trương Tuyết Nghênh","Tần Tuấn Kiệt","Hoàng Thánh Trì","Trần Hân Dư","Madina Memet","Hồ Ý Hoàn","Zhu Xiangyang"],"director":["Yu Zhongzhong"],"cast_meta":[{"name":"Trương Tuyết Nghênh","name_vi":"Trương Tuyết Nghênh","name_original":"Sophie Zhang","tmdb_id":1258373,"profile":"https://image.tmdb.org/t/p/w500/ccpdJNXgcDG0nrrYgEqP9fllrVY.jpg","tmdb_url":"https://www.themoviedb.org/person/1258373"},{"name":"Tần Tuấn Kiệt","name_vi":"Tần Tuấn 