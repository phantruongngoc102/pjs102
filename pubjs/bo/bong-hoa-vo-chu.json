1_bcd95a35/index.m3u8"}]}],"time":"11 phút/tập","description":"<p>Sau khi Lin Yue'er, con gái của một vị tướng, biết được thất bại của cha cô Lin Haotian ở thành phố Shuozhou có những bí mật ẩn giấu, cô đổi tên thành \"Ting Wu\" và vào Guo Mansion với tư cách là một ca sĩ để điều tra sự thật. khó khăn và nguy hiểm, sự nghi ngờ của Quách Thư Thành và sự cám dỗ của Quách Phong, sự hoang tưởng của Triệu Định Hồng, vụ ám sát của Tùy Nhược An... Lin Yue'er đã từng bước sử dụng trí tuệ của mình để tìm kiếm công lý cho hàng vạn linh hồn trung thành của quân đội nhà Lin.</p>","tmdb":{"type":"tv","id":"260669","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-30T11:06:49.000Z","cast":["Triệu Gia Mẫn","Lương Học Phong","Gao Xiaoyu","Xu Nuoyan","Wu Yijia","Gao Kai","Wen Sheng"],"director":["Kong Li Da"],"cast_meta":[{"name":"Triệu Gia Mẫn","name_vi":"Triệu Gia Mẫn","name_original":"Zhao Jiamin","tmdb_id":4280942,"profile":"https://image.tmdb.org/t/p/w500/aNEoa4wVDqa5gMzXxC55DX2SaMW.jpg","tmdb_url":"https://www.themoviedb.org/person/4280942"},{"name":"Lương Học Phong","name_vi":"Lương Học Phong","name_original":"Liang Xuefeng","tmdb_id":1833171,"profile":"https://image.tmdb.org/t/p/w500/3dgADHw7jICRB9ivJbCE2mJFLC7.jpg","tmdb_url":"https://www.themoviedb.org/person/1833171"},{"name":"Gao Xiaoyu","name_vi":null,"name_original":"Gao Xiaoyu","tmdb_id":4862352,"profile":"https://image.tmdb.org/t/p/w500/bWriz6gYZfzryioqQ1yCtijYAsp.jpg","tmdb_url":"https://www.themoviedb.org/person/4862352"},{"name":"Xu Nuoyan","name_vi":null,"name_original":"Xu Nuoyan","tmdb_id":4841249,"profile":"https://image.tmdb.org/t/p/w500/6CRREsj17vD0s0BukU9Lxr6RHGo.jpg","tmdb_url":"https://www.themoviedb.org/person/4841249"},{"name":"Wu Yijia","name_vi":null,"name_original":"Wu Yijia","tmdb_id":2398471,"profile":"https://image.tmdb.org/t/p/w500/96RKCvLtSh9UM9JNN3Jo4bGRh3K.jpg","tmdb_url":"https://www.themoviedb.org/person/2398471"},{"name":"Gao Kai","name_vi":null,"name_original":"Gao Kai","tmdb