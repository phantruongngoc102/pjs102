am14.com/20230503/36028_47c4f1aa/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream14.com/share/04112144566d77d75f935b26101dd71d","link_m3u8":"https://vip.opstream14.com/20230504/36065_d617b271/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream14.com/share/9ba2c76cf4e1f1ce6701481c13964f20","link_m3u8":"https://vip.opstream14.com/20230511/36391_78bb120e/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream14.com/share/c2f9146157dc8da9e4a20f9cd28889fd","link_m3u8":"https://vip.opstream14.com/20230511/36396_88706f9d/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream14.com/share/70208552d6df6cd23fb368feac7ac5ba","link_m3u8":"https://vip.opstream14.com/20230517/36560_633f2a00/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream14.com/share/edcf8899baa331c4008eaf6a7de9f08b","link_m3u8":"https://vip.opstream14.com/20230519/36586_7dc9a875/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream14.com/share/12e8bc147311e2f5bf7ba36fd0039a59","link_m3u8":"https://vip.opstream14.com/20230525/36794_be4db6c7/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream14.com/share/4c1c58fb02a71eed1ab630821df3bf5a","link_m3u8":"https://vip.opstream14.com/20230526/36832_6914b8f1/index.m3u8"}]}],"description":"<p>Phim kể về cuộc hành trình lãng mạn của Yeon Bo Ra, một huấn luyện viên tình yêu nổi tiếng và là tác giả thành công của tiểu thuyết lãng mạn, và Lee Soo Hyuk, một người đàn ông quyến rũ, vật lộn với những vấn đề của trái tim.</p><p>Là một nhà lập kế hoạch xuất bản sáng suốt, Soo Hyuk không dễ bị ấn tượng và ban đầu có ấn tượng tiêu cực về Bo Ra. Tuy nhiên, cuộc sống của họ bất ngờ vướng vào nhau, và anh ngày càng bị cô thu hút.</p><p>Trong khi đó, Han Sang Jin, bạn và đối tác kinh doanh của Soo Hyuk, đứng đầu công ty xuất bản sách Jinri, anh ta là một người thích lối sống tự do hơn là một mối quan hệ sâu sắc hay lãng mạn đi chăng nữa.</p>","tmdb_id":210586,"cast":[],"director":[],"keywords":[],"tmdb":{"id":210586},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/bo/bora-deborah.json"}