":"https://vip.opstream16.com/share/1a042e38b6cad7c50aafe731b44212a4","link_m3u8":"https://vip.opstream16.com/20220803/21144_eec47edc/index.m3u8"},{"name":"24","slug":"24","filename":"buc-thu-tinh-mau-trang--eps-tap-24","link_embed":"https://vip.opstream16.com/share/307d1094c1f5857935838964f2ae4db4","link_m3u8":"https://vip.opstream16.com/20220803/21145_2769e7dc/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Quải Cư, Thành Mĩ, Cù Thủ và Tinh Hoa là những người bạn quen biết nhau từ hội sinh viên ở trường đại học. Vì tình yêu, họ đều đã nếm trải cay đắng khổ đau. Từ khi còn là sinh viên đến lúc đã tốt nghiệp bước vào đời, bọn họ phải đối mặt và xoay sở với những trở ngại xung quanh mình. Từ mối quan hệ đồng giới, bắt nạt nơi công sở, tính tự chủ của phụ nữ, ngoại tình... làm thế nào để họ duy trì tình bạn và giải quyết mọi thách thức nảy sinh từ cuộc sống và tình yêu?</p>","tmdb":{"type":"tv","id":"87797","season":1,"vote_average":8,"vote_count":1},"modified":"2022-08-03T11:57:39.000Z","cast":["Vương Tịnh","Zhang Ting-hu","Edison Song","Sylvia Hsieh","Andy Wu"],"director":["Lý Vân Thiền","Lâm Quân Dương"],"cast_meta":[{"name":"Vương Tịnh","name_vi":"Vương Tịnh","name_original":"Gingle Wang","tmdb_id":2270252,"profile":"https://image.tmdb.org/t/p/w500/cKBSigATU0e3IUcAeYHvuAS2EFU.jpg","tmdb_url":"https://www.themoviedb.org/person/2270252"},{"name":"Zhang Ting-hu","name_vi":null,"name_original":"Zhang Ting-hu","tmdb_id":1587299,"profile":"https://image.tmdb.org/t/p/w500/an7aYMidu6Vvh1cDvPXvMD6sz0C.jpg","tmdb_url":"https://www.themoviedb.org/person/1587299"},{"name":"Edison Song","name_vi":null,"name_original":"Edison Song","tmdb_id":1833062,"profile":"https://image.tmdb.org/t/p/w500/izKmpDRsCg54cYjpgZMeht2lOe1.jpg","tmdb_url":"https://www.themoviedb.org/person/1833062"},{"name":"Sylvia Hsieh","name_vi":null,"name_original":"Sylvia Hsieh","tmdb_id":1794459,"profile":"https://image.tmdb.org/t/p/w500/7w2xnCQNIcjLbF9NZkvriOGyZUE.jpg","tmdb_url":"https://www.themovie