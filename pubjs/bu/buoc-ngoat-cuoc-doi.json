index.m3u8"},{"name":"44","slug":"","filename":"Buoc.Ngoat.Cuoc.Doi.E44","link_embed":"https://vip.opstream16.com/share/030e8a2348d594ac99363e3cd06da704","link_m3u8":"https://vip.opstream16.com/20231201/38438_f4ed03c6/index.m3u8"},{"name":"45-End","slug":"","filename":"Buoc.Ngoat.Cuoc.Doi.E45","link_embed":"https://vip.opstream16.com/share/69573e0fbe6e2c4b7409ce92e366d865","link_m3u8":"https://vip.opstream16.com/20231201/38437_95e59a5c/index.m3u8"}]}],"time":"45 phút/tập","description":"Đinh Thiện Bản (do La Gia Lương đóng) từ lúc 6 tuổi trong một cơn bão đã lạc mất gia đình. Anh được Đinh Vinh Bang (do Tần Bái đóng) nhận làm con nuôi. Trong một lần sang Úc công tác, anh quen biết với Trình Thiên Lam (do Tuyên Huyên đóng) - một nữ công tố tính tình ngay thẳng. Khi trở về Hồng Kông, vì giúp cha nuôi mà Thiện Bản đánh mất tình cảm với Thiên Lam. Anh dính líu vào một vụ án và người thụ lý vụ án này lại là em trai thất lạc Chung Thủ Khang (do Ôn Triệu Luân đóng).\n\nCon trai ruột của Đinh Vinh Bang là Đinh Thiện Hành (do Lâm Phong đóng) du học trở về, sau bị chú ba xúi giục đã xem Thiện Bản như là kẻ thù và tìm mọi cách chiếm đoạt tài sản sau khi cha Vinh Bang qua đời.","tmdb":{"type":"tv","id":"5712","season":1,"vote_average":8.8,"vote_count":4},"modified":"2023-12-02T08:16:50.000Z","cast":["La Gia Lương","Tuyên Huyên","Ôn Triệu Luân","Lâm Phong","Diệp Tuyền","Tần Bái","Hồ Hạnh Nhi","Hứa Thiệu Hùng","Jay Lau Kam-Ling","Quách Phong","Kwan Ching","Ngải Uy","Thạch Tu","Hướng Hải Lam","Gigi Wong"],"director":[],"cast_meta":[{"name":"La Gia Lương","name_vi":"La Gia Lương","name_original":"Gallen Lo Ka-Leung","tmdb_id":1223043,"profile":"https://image.tmdb.org/t/p/w500/6ZCTOMeRktYL7iTEz7lg7N3XXPc.jpg","tmdb_url":"https://www.themoviedb.org/person/1223043"},{"name":"Tuyên Huyên","name_vi":"Tuyên Huyên","name_original":"Jessica Hsuan","tmdb_id":230777,"profile":"https://image.tmdb.org/t/p/w500/3hp9D2B1Y7L7imPUHCpHiNgxSY.jpg","tmdb_url":"https://www.themoviedb.org/person/230777