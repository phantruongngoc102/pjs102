m/share/ce81f8e75a87b17708d10a0684fbe1ec","link_m3u8":"https://vip.opstream10.com/20220510/13322_da04c91a/index.m3u8"},{"name":"36","slug":"36","filename":"truy-hoi-cong-ly-thuyet-minh-burning-2020-tap-36","link_embed":"https://vip.opstream10.com/share/977cf54e52109b5b2795406737cf36d4","link_m3u8":"https://vip.opstream10.com/20220510/13324_76009be3/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Là bác sĩ pháp y, ông nội Cao Tứ Hải của anh, luôn kiên định với các nguyên tắc của mình cố gắng tìm ra manh mối cho chân tướng vụ án. Nhưng ông lại bị người vu hãm, gây ra kết quả sai sót trong quá trình kiểm nghiệm. Ba mươi năm mang tiếng xấu, cũng vì thế mà phải từ bỏ công việc pháp y yêu dấu, cuối cùng mắc bệnh Alzheimer. Mà Cao Kiến Thiết, phó đội trưởng đội cảnh sát hình sự, đã anh dũng hy sinh trong một vụ án điều tra cách đây hai mươi năm vì vụ án đó không được giải quyết. Vụ án này đã được giải quyết, nhưng hôm nay bị hoài nghi là một vụ án oan, hình tượng liệt sĩ gặp phải sụp đổ. Cháu trai Cao Phong, người đang chuẩn bị rời khỏi đội cảnh sát, bởi vì một vụ án ngẫu nhiên mà bị cuốn vào vụ án lâu năm có liên quan đến danh dự của ông nội và cha của mình, để điều tra rõ chân tướng sự thật, cháu trai từ bỏ tất cả, cùng cảnh sát vượt qua muôn trùng khó khăn. Dưới áp lực nặng nề, cuối cùng anh đã lật lại vụ án kéo dài đã nhận định là đắp chiếu. Bảo vệ công bằng và chính nghĩa của pháp luật, khôi phục lại chân tướng của sự thật, cũng đem tội phạm trốn ra ngoài ba mươi năm truy bắt về quy án. Cuối cùng cũng an ủi linh hồn của ông nội và cha ở trên trời.</p>","tmdb":{"type":"tv","id":"104085","season":1,"vote_average":7,"vote_count":1},"modified":"2022-12-09T16:43:56.000Z","cast":["Kinh Siêu","Trương Giai Ninh","Đàm Khải","Hề Mỹ Quyên","Ô Quân Mai","Lưu Mẫn Đào","Zhang Zhijian","Phùng Lỗi","Du Zhiguo","Michael Tong Chun-Chung","Zhang Yan","Zhang Junming"],"director":["Chen Yu Xin"],"cast_meta":[{"name":"Kinh Siêu","name_vi":"Kinh Siêu","name_original":"Jing Chao","tmd