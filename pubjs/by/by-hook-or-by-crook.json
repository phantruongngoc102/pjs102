yên thệ và cùng nhau tìm kiếm \"A Flower\".</p>","tmdb":{"type":"movie","id":"214415","season":null,"vote_average":5.111,"vote_count":9},"modified":"2023-09-04T11:46:00.000Z","cast":["Hồng Kim Bảo","Mã Vũ","Karl Maka","Dean Shek Tin","Chung Phát","Tang Ching","Lâm Chánh Anh","Tăng Chí Vĩ","Yolande Yau Pui-Ling","Tai San","Hon Kwok-Choi","Johnny Cheung Wa","Pan Yung-Sheng","Ha Kwok-Wing","Ho Pak-Kwong"],"director":["Karl Maka"],"cast_meta":[{"name":"Hồng Kim Bảo","name_vi":"Hồng Kim Bảo","name_original":"Sammo Hung Kam-Bo","tmdb_id":62410,"profile":"https://image.tmdb.org/t/p/w500/89keYn2aBaxLXWMEbQVHHIh86ri.jpg","tmdb_url":"https://www.themoviedb.org/person/62410"},{"name":"Mã Vũ","name_vi":"Mã Vũ","name_original":"Wu Ma","tmdb_id":134704,"profile":"https://image.tmdb.org/t/p/w500/fIwXNGnXsK881iLEI9R8XUbBnKg.jpg","tmdb_url":"https://www.themoviedb.org/person/134704"},{"name":"Karl Maka","name_vi":null,"name_original":"Karl Maka","tmdb_id":26726,"profile":"https://image.tmdb.org/t/p/w500/thI2IhMQlJskBG8EToYjftW8H8V.jpg","tmdb_url":"https://www.themoviedb.org/person/26726"},{"name":"Dean Shek Tin","name_vi":null,"name_original":"Dean Shek Tin","tmdb_id":26727,"profile":"https://image.tmdb.org/t/p/w500/f8u4H51lZl3xzbREHepikjXsZu0.jpg","tmdb_url":"https://www.themoviedb.org/person/26727"},{"name":"Chung Phát","name_vi":"Chung Phát","name_original":"Paul Chung Fat","tmdb_id":119460,"profile":"https://image.tmdb.org/t/p/w500/7Y9GWoTvoEwAkKVCrli4CXrvfWw.jpg","tmdb_url":"https://www.themoviedb.org/person/119460"},{"name":"Tang Ching","name_vi":null,"name_original":"Tang Ching","tmdb_id":955641,"profile":"https://image.tmdb.org/t/p/w500/cumSILGZvBftrSSMmHnfRo8wTQ4.jpg","tmdb_url":"https://www.themoviedb.org/person/955641"},{"name":"Lâm Chánh Anh","name_vi":"Lâm Chánh Anh","name_original":"Lam Ching-Ying","tmdb_id":62423,"profile":"https://image.tmdb.org/t/p/w500/7pheGOKN9qh2bjn68Wh7LZ3jS5u.jpg","tmdb_url":"https://www.themoviedb.org/person/62423"},{"name":"Tăng Chí Vĩ","name