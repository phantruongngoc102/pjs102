s://vip.opstream10.com/share/0c7a625d5077d3baab054e3c91323a77","link_m3u8":"https://vip.opstream10.com/20220531/18047_7a9b0e75/index.m3u8"}]}],"description":"<p>Đỗ Ngãi Sa Là một át chủ bài trong thế giới tiếp thị, Đỗ Ngãi Sa dành toàn bộ sự nghiệp của mình để chiến đấu trên con đường vươn tới đỉnh cao. Tập Trung vào những mục tiêu phía trước, cô được biết đến với sự kiên trì và quyết tâm không ngừng. Không bao giờ cho phép mình bị lép vế trước bất cứ điều gì có thể xảy đến với mình, Ngãi Sa sử dụng bất cứ cách nào cần thiết để hoàn thành công việc. Làm việc cùng với Ngãi Sa là Dịch Phi Dương, một người làm marketing khác, người luôn có câu trả lời cho mọi vấn đề và có khả năng kỳ lạ để giành được lợi thế, bất kể tình huống nào. Hoàn toàn khác nhau trong cách tiếp cận công việc và cuộc sống, Ngãi Sa và Dịch Phi Dương đã phát triển sự cạnh tranh gay gắt tại nơi làm việc, khi họ cố gắng trở thành người giỏi nhất trong doanh nghiệp.</p>","tmdb_id":108743,"cast":["Aviis Zhong","Chin-Lan Chang","Chou Yiao-Tzong","Jack Lee","Xuan Chen","Wes Lo"],"director":["Ker Choon Hooi"],"keywords":[],"tmdb":{"type":"tv","id":"108743","season":1,"vote_average":10,"vote_count":1},"cast_meta":[{"name":"Aviis Zhong","name_vi":null,"name_original":"Aviis Zhong","tmdb_id":1552828,"profile":"https://image.tmdb.org/t/p/w500/4uPgeO9S70e7FJ3Opy1VZ7qyGcR.jpg","tmdb_url":"https://www.themoviedb.org/person/1552828"},{"name":"Chin-Lan Chang","name_vi":null,"name_original":"Chin-Lan Chang","tmdb_id":2857170,"profile":"https://image.tmdb.org/t/p/w500/vtnLnTRvBwR5gFPdBOdAMt0Wklt.jpg","tmdb_url":"https://www.themoviedb.org/person/2857170"},{"name":"Chou Yiao-Tzong","name_vi":null,"name_original":"Chou Yiao-Tzong","tmdb_id":1630651,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1630651"},{"name":"Jack Lee","name_vi":null,"name_original":"Jack Lee","tmdb_id":1365765,"profile":"https://image.tmdb.org/t/p/w500/3qAqBk4wxjtFrfmOckdhsf11ztE.jpg","tmdb_url":"https://www.themoviedb.org/person/136