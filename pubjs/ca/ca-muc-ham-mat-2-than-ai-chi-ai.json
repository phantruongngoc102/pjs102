âu. Dù lạnh lùng, trầm tính kiệm lời đến đâu nhưng khi đứng trước Ngãi Tình anh trở thành một người hoàn toàn khác. Vì thần tượng Ngãi Tình từ lâu, Ngô Bạch đã nỗ lực không ngừng để gia nhập đội tuyển của Hàn Thương Ngôn, đi theo con đường Esports. Còn Ngãi Tình luôn đồng hành cùng Ngô Bạch trong những cuộc thi chế tạo robot cũng như những giải đấu lớn mang tầm quốc tế. Hai người cùng sát cánh bên nhau vượt qua không ít những khó khăn, trở ngại trên con đường làm tuyển thủ chuyên nghiệp.","tmdb_id":116133,"cast":["Hồ Nhất Thiên","Lý Nhất Đồng","Vương An Vũ","Lý Minh Đức","Xu Lexiao","Pang Hanchen","Wang Keru","Xu Yao","Liu Haoyu","Chai Junzhe","Huang Xingyuan","Xu Yang","Ji Xiaofei","Yao Bo Lan","Shi Yu"],"director":["Yu Zhong Zhong"],"keywords":[],"tmdb":{"type":"tv","id":"116133","season":1,"vote_average":6.8,"vote_count":9},"cast_meta":[{"name":"Hồ Nhất Thiên","name_vi":"Hồ Nhất Thiên","name_original":"Hu Yitian","tmdb_id":1922807,"profile":"https://image.tmdb.org/t/p/w500/3TdSv9FWbImvJO65I2z8GEcU791.jpg","tmdb_url":"https://www.themoviedb.org/person/1922807"},{"name":"Lý Nhất Đồng","name_vi":"Lý Nhất Đồng","name_original":"Li Yitong","tmdb_id":1736257,"profile":"https://image.tmdb.org/t/p/w500/jfostFmHde0D1Wj9F57GWHEVzmO.jpg","tmdb_url":"https://www.themoviedb.org/person/1736257"},{"name":"Vương An Vũ","name_vi":"Vương An Vũ","name_original":"Wang Anyu","tmdb_id":2482605,"profile":"https://image.tmdb.org/t/p/w500/7ai55C0CoOdzOlkAOpfatW5xuh.jpg","tmdb_url":"https://www.themoviedb.org/person/2482605"},{"name":"Lý Minh Đức","name_vi":"Lý Minh Đức","name_original":"Li Mingde","tmdb_id":2727869,"profile":"https://image.tmdb.org/t/p/w500/chyIdYAmXBBHjC2f9GyNVhtNVkV.jpg","tmdb_url":"https://www.themoviedb.org/person/2727869"},{"name":"Xu Lexiao","name_vi":null,"name_original":"Xu Lexiao","tmdb_id":2773636,"profile":"https://image.tmdb.org/t/p/w500/byyzF0QeZr2UDQKXloEq9KSc4Og.jpg","tmdb_url":"https://www.themoviedb.org/person/2773636"},{"name":"Pang Hanchen","name_vi":n