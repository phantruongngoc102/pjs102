0220314/3502_e8b39f06/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream12.com/share/87f7ee4fdb57bdfd52179947211b7ebb","link_m3u8":"https://vip.opstream12.com/20220314/3503_ad7b09ca/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream12.com/share/73231e53eeef362c814c8522f5257286","link_m3u8":"https://vip.opstream12.com/20220314/3504_bf5ea6e7/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream12.com/share/2a3d6d6cc4b5e77238c1fc1bb6cdd681","link_m3u8":"https://vip.opstream12.com/20220314/3505_863ba60c/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream12.com/share/e0126439e08ddfbdf4faa952dc910590","link_m3u8":"https://vip.opstream12.com/20220314/3506_b30648b8/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream12.com/share/0e7c7d6c41c76b9ee6445ae01cc0181d","link_m3u8":"https://vip.opstream12.com/20220314/3507_51d429c3/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream12.com/share/7d2be41b1bde6ff8fe45150c37488ebb","link_m3u8":"https://vip.opstream12.com/20220314/3508_dedf023c/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream12.com/share/0141a8aedb1b53970fac7c81dac79fbe","link_m3u8":"https://vip.opstream12.com/20220314/3509_54496d92/index.m3u8"}]}],"description":"<p>“Các Tế Bào Của Yumi” là bộ phim đầu tiên kết hợp giữa truyện tranh và người thật của Hàn Quốc, cải biên từ bộ truyện tranh nổi tiếng cùng tên tại Hàn Quốc “Các Tế Bào Của Yumi”. Kim Go Eun (Goblin) đóng vai nữ chính Yumi, là một cô gái bình dị nơi công sở không giỏi thể hiện tình cảm. Ahn Bo Hyun (Itaewon Class) đóng vai nam chính Ku Woong, Lee Yu Bi đóng vai đồng nghiệp dịu dàng Ruby, thành viên GOT7 Park Jin Young đóng vai Yoo Ba-bi. Ngoài ra thành viên của Shinee Min Ho cũng đặc biệt tham gia diễn xuất.\\nYumi 31 tuổi là một cô gái bình thường sống ở Seoul, làm nhân viên kế toán ở một công ty mỳ sợi. Cuộc sống của cô vô cùng đơn điệu, không hề có gợn sóng. Nhưng mà, Ku Woong lại xông vào thế giới yên bình của Yumi, khiến các tế bào trong người cô hoàn toàn trở nên hỗn loạn. Mọt sách Ku Woong là người bắt đầu trò chơi, là một anh chàng đẹp trai trông bề ngoài như một người rất hướng nội, lạnh lùng với tất cả mọi chuyện, trên thực tế lại là một chàng trai vô cùng thuần khiết. Yumi bị sự hài hước và đơ thuần của Ku Woong thu hút, “tế bào tình yêu” của hai người mở lòng với nhau, một câu chuyện tình yêu ngọt ngào cứ thế bắt đầu.\\n“Các Tế Bào Của Yumi” do đạo diễn Lee Sang-yeobcủa “Người Vợ Thân Quen”, “Em là một nửa đời anh” và biên kịch Song Jae-jeong của “W- Hai Thế giới” và “Ký ức Alhambra” cùng biên kịch Kim Yoon-joocủa “Tìm Em Trong Hồi Ức”cùng hợp tác tạp nên. “Các Tế Bào Của Yumi”xoay quanh cuộc sống của nữ chính Yumi tại thành phố, thông qua các tế bào não của nhân vật chính Yumi, miêu cả công việc, tình yêu, mơ ước của người nhân viên bình thường tuổi 30, từ đó thu hút sự cộng hưởng của mỗi một người sống tại nơi đô thị.</p>","tmdb_id":128995,"cast":["Kim Go-eun","Kim Jae-won","Jun Suk-ho","Choi Daniel","Cho Hye-jeong","Mi Ram","Park Se-in","Sung Ji-ru","Lee Yu-bi"],"director":[],"keywords":[],"cast_meta":[{"name":"Kim Go-eun","name_vi":null,"name_original":"Kim Go-eun","tmdb_id":1067849,"profile":"https://image.tmdb.org/t/p/w500/p7wuD6eX0YcZ5LXWhx0XjvEYZKz.jpg","tmdb_url":"https://www.themoviedb.org/person/1067849"},{"name":"Kim Jae-won","name_vi":null,"name_original":"Kim Jae-won","tmdb_id":3244773,"profile":"https://image.tmdb.org/t/p/w500/diEPTDk0ngXGje4RGmoMaCd0TWe.jpg","tmdb_url":"https://www.themoviedb.org/person/3244773"},{"name":"Jun Suk-ho","name_vi":null,"name_original":"Jun Suk-ho","tmdb_id":1199744,"profile":"https://image.tmdb.org/t/p/w500/xMUCuermXrjVNOWDV3gIfpP5yhF.jpg","tmdb_url":"https://www.themoviedb.org/person/1199744"},{"name":"Choi Daniel","name_vi":null,"name_original":"Choi Daniel","tmdb_id":1252369,"profile":"https://image.tmdb.org/t/p/w500/gv9qWPVRid5ij0Fkv3qYzEbZ9lh.jpg","tmdb_url":"https: