33b","filename":"cai-gia-cua-tham-vong-money-flower-tap-33B","link_embed":"https://vip.opstream11.com/share/85fa59ac8a893137b2777551335631ed","link_m3u8":"https://vip.opstream11.com/20220602/27868_79835de7/index.m3u8"},{"name":"34A","slug":"34a","filename":"cai-gia-cua-tham-vong-money-flower-tap-34A","link_embed":"https://vip.opstream11.com/share/d697311aad4f58ad2c5d4286fc22980d","link_m3u8":"https://vip.opstream11.com/20220602/27869_425a7561/index.m3u8"},{"name":"34B","slug":"34b","filename":"cai-gia-cua-tham-vong-money-flower-tap-34B","link_embed":"https://vip.opstream11.com/share/a28477d0c57129b93d95baf171634582","link_m3u8":"https://vip.opstream11.com/20220602/27870_570b029a/index.m3u8"},{"name":"35A","slug":"35a","filename":"cai-gia-cua-tham-vong-money-flower-tap-35A","link_embed":"https://vip.opstream11.com/share/7cefdcbff0ddf29c3bbaeec362015c30","link_m3u8":"https://vip.opstream11.com/20220602/27871_4746a524/index.m3u8"},{"name":"35B","slug":"35b","filename":"cai-gia-cua-tham-vong-money-flower-tap-35B","link_embed":"https://vip.opstream11.com/share/0f4ec68d74cefd79fc0f45d3921c14b7","link_m3u8":"https://vip.opstream11.com/20220602/27872_02090798/index.m3u8"},{"name":"36A","slug":"36a","filename":"cai-gia-cua-tham-vong-money-flower-tap-36A","link_embed":"https://vip.opstream11.com/share/f2f25c1b2ea4636e7cf2190a36677f98","link_m3u8":"https://vip.opstream11.com/20220602/27873_23eb7763/index.m3u8"},{"name":"36B","slug":"36b","filename":"cai-gia-cua-tham-vong-money-flower-tap-36B","link_embed":"https://vip.opstream11.com/share/f190c7c5af3db9c194e4b1a0f7326cdc","link_m3u8":"https://vip.opstream11.com/20220602/27874_4c49d642/index.m3u8"}]}],"time":"60 phút","description":"<p>Cái Giá Của Tham Vọng - Money Flower là một bức tranh sống động khắc họa rõ nét chuỗi bi kịch luẩn quẩn ở những con người ngạo mạn tin rằng họ có thể kiểm soát tất cả mọi thứ bằng tiền, mà không hề nhận ra rằng lòng tham sẽ che mờ sáng suốt. Kể cả việc lợi dụng người khác trở thành công cụ để đạt được mục đích cá nhân được xoay quanh âm mưu trả thù của luật sư Kang Pil Joo (Jang Hyuk) - người lớn lên ở trại trẻ mồ côi và hiện đang làm giám đốc điều hành một bộ phận của một công ty. Anh ta được công nhận nhờ sự thông minh và tinh thần làm việc gương mẫu. Một số đồng nghiệp ghen tị với anh ta. Trong khi đó, Na Mo Hyun (Park Se Young) - con gái của ủy viên quốc hội Na Gi-chul, là một nhà hoạt động môi trường và là một giáo viên khoa học tại trường trung học. Cô là một người biết lắng nghe, cười nhiều và mơ ước có được một câu chuyện tình yêu do định mệnh sắp đặt. Pil Joo đã âm thầm lên kế hoạch sắp xếp cho Na Mo Hyun có một cuộc “hôn nhân trao đổi” với người thừa kế tập đoàn là Jang Boo Cheon (Jang Seung Jo). Trớ trêu thay trong quá trình tiếp cận Mo Hyun, trái tim Pil Joo đã loạn nhịp vì không biết mình đã yêu cô từ lúc nào.</p>","tmdb":{"type":"tv","id":"74887","season":1,"vote_average":6.763,"vote_count":19},"modified":"2022-06-02T13:19:18.000Z","cast":["Jang Hyuk","Park Se-young","Jang Seung-jo","Lee Mi-sook","Lee Soon-jae","Han So-hee","Sunwoo Jae-duk","Park Ji-il","Park Jeong-hak","Moon Soo-bin","Cho Byeong-kyu"],"director":["Kim Hee Won"],"cast_meta":[{"name":"Jang Hyuk","name_vi":null,"name_original":"Jang Hyuk","tmdb_id":63438,"profile":"https://image.tmdb.org/t/p/w500/wOGbzgmlogfpPUvXTWVSROVTUYf.jpg","tmdb_url":"https://www.themoviedb.org/person/63438"},{"name":"Park Se-young","name_vi":null,"name_original":"Park Se-young","tmdb_id":1255414,"profile":"https://image.tmdb.org/t/p/w500/2PefaowfnJYgEcGj3afolLlXpeg.jpg","tmdb_url":"https://www.themoviedb.org/person/1255414"},{"name":"Jang Seung-jo","name_vi":null,"name_original":"Jang Seung-jo","tmdb_id":1487428,"profile":"https://image.tmdb.org/t/p/w500/eNuDu7SIBqgDRbaKajs3C5JXj2B.jpg","tmdb_url":"https://www.themoviedb.org/person/1487428"},{"name":"Lee Mi-sook","name_vi":null,"name_original":"Lee Mi-sook","tmdb_id":16288,"profile":"https://image.tmdb.org/t/p/w500/t1ezO6OG00qC6imqcUv36pAZXnv.jpg","tmdb_u