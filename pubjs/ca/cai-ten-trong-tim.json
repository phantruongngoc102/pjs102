ột người đàn ông kiên định, lạnh lùng và trưởng thành. Khi bí ẩn dần dần sáng tỏ, mối quan hệ giữa hai người va chạm lại bùng lên trong sự đẩy và kéo. Một người phụ nữ tên Tô Tinh đột nhiên xông vào...","tmdb":{"type":"tv","id":"230547","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-28T16:49:25.000Z","cast":["Jin Jiayu","Zhao Sitong"],"director":["Chen Jiajie"],"cast_meta":[{"name":"Jin Jiayu","name_vi":null,"name_original":"Jin Jiayu","tmdb_id":3650067,"profile":"https://image.tmdb.org/t/p/w500/pYGhby24IaA4qFjGqpFSJ6EyoAL.jpg","tmdb_url":"https://www.themoviedb.org/person/3650067"},{"name":"Zhao Sitong","name_vi":null,"name_original":"Zhao Sitong","tmdb_id":4643374,"profile":"https://image.tmdb.org/t/p/w500/vCayUW3jvC0hxby4kpqgm3t3LIB.jpg","tmdb_url":"https://www.themoviedb.org/person/4643374"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ca/cai-ten-trong-tim.json"}