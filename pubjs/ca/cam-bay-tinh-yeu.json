09a8d601/index.m3u8"},{"name":"36","slug":"36","filename":"Afili 36","link_embed":"https://vip.opstream10.com/share/ccd9cd148bbec8a9c3bfea662aef81ce","link_m3u8":"https://vip.opstream10.com/20230121/26156_85e35b54/index.m3u8"},{"name":"37","slug":"37","filename":"Afili 37","link_embed":"https://vip.opstream10.com/share/4b8cdf66647df5b1d9549039eca7819e","link_m3u8":"https://vip.opstream10.com/20230124/26169_029c0a2b/index.m3u8"},{"name":"38","slug":"38","filename":"Afili 38","link_embed":"https://vip.opstream10.com/share/019059823f48e01d3dc9e864a371605f","link_m3u8":"https://vip.opstream10.com/20230124/26170_0cb5a35a/index.m3u8"}]}],"time":"2h30p/tập","description":"<p>Kerem là con trai của gia đình Yigiter, một trong những gia đình giàu có nhất của Istanbul có nhà máy dệt. Kerem thông minh, đẹp trai nhưng cũng là một tay chơi, không bao giờ có thể nhận được sự đồng ý của cha mình. Ayse là một cô gái nghèo làm việc trong nhà máy của gia đình Yigiter. Cô có một trái tim nhân hậu nhưng cũng có 2 người anh lớn kiểm soát cuộc sống của cô. Cách duy nhất của cô để thoát khỏi tầm kiểm soát của họ là kết hôn với bạn trai là Berk, nhưng anh trai của họ cố gắng để cô kết hôn với một chàng trai giàu có trong khu phố Sabri. Berk, người sợ hãi các anh trai của mình và cũng vì hôn nhân mà mất đi điều tốt đẹp. Sau cuộc chạy trốn của Berk, lần đầu tiên trong đời Ayse quyết định làm điều gì đó tốt cho bản thân, nhưng lại làm điều gì đó xấu xa cho Kerem. Cô lập một âm mưu và buộc anh ta phải cưới cô. Cuộc hôn nhân này sẽ ràng buộc họ mãi mãi và không bao giờ buông tha cho họ.</p>","tmdb":{"type":"tv","id":"89671","season":1,"vote_average":7,"vote_count":16},"modified":"2023-01-24T20:29:52.000Z","cast":["Burcu Özberk","Çağlar Ertuğrul","Altan Erkekli","Neşe Beykent","Ozan Dağgez","Asena Tuğal","Serkay Tütüncü","Öner Ateş","Uğur Uzunel","Beril Pozam"],"director":["Serdar Gozelli"],"cast_meta":[{"name":"Burcu Özberk","name_vi":null,"name_original":"Burcu Özberk","tmdb_id":1522700,"profil