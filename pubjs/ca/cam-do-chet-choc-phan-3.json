ong khi đó, những căng thẳng âm ỉ giữa Jacob, Leonard và Vuyo lại bùng lên, khơi lại những mối thù cũ và mở lại những vết thương khó lành. Trong Fatal Seduction mùa 3, không ai vô tội. Và ai cũng có điều gì đó để che giấu.</p>","tmdb":{"type":"tv","id":"227975","season":3,"vote_average":6.5,"vote_count":86},"modified":"2026-03-29T20:39:48.000Z","cast":["Kgomotso Christopher","Nathaniel Ramabulana","Prince Grootboom","Thapelo Mokoena","Ngele Ramulondi","Frances Sholto-Douglas","Thando Thabethe","Lorcia Cooper Khumalo","Hope Mbhele","Kevin Smith"],"director":[],"cast_meta":[{"name":"Kgomotso Christopher","name_vi":null,"name_original":"Kgomotso Christopher","tmdb_id":4098839,"profile":"https://image.tmdb.org/t/p/w500/mu6byP6FnkzMRiJyKCLxGKTnIJr.jpg","tmdb_url":"https://www.themoviedb.org/person/4098839"},{"name":"Nathaniel Ramabulana","name_vi":null,"name_original":"Nathaniel Ramabulana","tmdb_id":1073479,"profile":"https://image.tmdb.org/t/p/w500/jOHix5tIjpvX3sY2ridPoQRJbVn.jpg","tmdb_url":"https://www.themoviedb.org/person/1073479"},{"name":"Prince Grootboom","name_vi":null,"name_original":"Prince Grootboom","tmdb_id":4098844,"profile":"https://image.tmdb.org/t/p/w500/q0mimF5YqWzROTbEc0y9WZPQeLT.jpg","tmdb_url":"https://www.themoviedb.org/person/4098844"},{"name":"Thapelo Mokoena","name_vi":null,"name_original":"Thapelo Mokoena","tmdb_id":229640,"profile":"https://image.tmdb.org/t/p/w500/sBo11FFBXfhtGL4Dgbx0jnjKQ81.jpg","tmdb_url":"https://www.themoviedb.org/person/229640"},{"name":"Ngele Ramulondi","name_vi":null,"name_original":"Ngele Ramulondi","tmdb_id":4098846,"profile":"https://image.tmdb.org/t/p/w500/o5Id8Xjd4ijx3aZakRURop4aAaw.jpg","tmdb_url":"https://www.themoviedb.org/person/4098846"},{"name":"Frances Sholto-Douglas","name_vi":null,"name_original":"Frances Sholto-Douglas","tmdb_id":1883295,"profile":"https://image.tmdb.org/t/p/w500/VHKIiSjKyfcRFz1VbL35C6hC4r.jpg","tmdb_url":"https://www.themoviedb.org/person/1883295"},{"name":"Thando Thabethe","name_vi":nu