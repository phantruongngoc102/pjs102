{"id":"64587b3ee8012b52ca4cbbc2","title":"Cảm Ơn Niềm Hạnh Phúc","origin_name":"Happythankyoumoreplease","slug":"cam-on-niem-hanh-phuc","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/ca/cam-on-niem-hanh-phuc.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/ca/cam-on-niem-hanh-phuc.webp","year":2011,"type":"single","genre":[{"id":"620a220de0fc277084dfd16d","name":"Tình Cảm","slug":"tinh-cam"},{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Happythankyoumoreplease - Cảm Ơn Niềm Hạnh Phúc - 2010","link_embed":"https://vip.opstream14.com/share/e215cf1fde5a2baed63faa06643fe120","link_m3u8":"https://vip.opstream14.com/20230508/36241_51d7b076/index.m3u8"}]}],"time":"100 Phút","description":"Ghi lại khoảnh khắc mang tính thế hệ - những người trẻ tuổi đang trên đà trưởng thành thực sự, mệt mỏi với tính hoài nghi theo phản xạ của họ, mỗi người theo cách riêng của mình đấu tranh để kết nối và xác định ý nghĩa của việc yêu và được yêu. Sáu người New York tung hứng tình yêu, tình bạn và bóng ma thách thức sâu sắc của tuổi trưởng thành. Sam Wexler là một nhà văn đang gặp khó khăn và đang có một ngày đặc biệt tồi tệ. Khi một cậu bé bị tách khỏi gia đình trên tàu điện ngầm, Sam đã đưa ra một quyết định đáng ngờ là đưa cậu bé trở về căn hộ của mình và từ đó bắt đầu một tình bạn bổ ích nhưng phức tạp. Cuộc sống của Sam xoay quanh những người bạn của anh ấy - Annie, người có hình ảnh bản thân khiến cô ấy không cam kết; Charlie và Mary Catherine, một cặp đôi có thể chuyển đến Los Angeles để kiểm tra mối quan hệ của họ; và Mississippi, một ca sĩ quán rượu lọt vào mắt xanh của Sam.","tmdb":{"type":"movie","id":"47218","season":null,"vote_average":6.465,"vote_count":296},"modified":"2023-05-08T11:31:59.000Z","cast":["Josh Radnor","Malin Åkerman","Kate Mara","Zoe Kazan","Pablo Schreiber","Tony Hale","Michael Algieri","Jakob Appelman","Dana Barron","Richard Jenkins","Bram Barouh","Sunah Bilsted","Jimmy Gary Jr.","Marna Kohn","Maria Elena Ramirez"],"director":["Josh Radnor"],"cast_meta":[{"name":"Josh Radnor","name_vi":null,"name_original":"Josh Radnor","tmdb_id":144009,"profile":"https://image.tmdb.org/t/p/w500/rHx4D70iRUkka5kl9064kOvmSQs.jpg","tmdb_url":"https://www.themoviedb.org/person/144009"},{"name":"Malin Åkerman","name_vi":null,"name_original":"Malin Åkerman","tmdb_id":50463,"profile":"https://image.tmdb.org/t/p/w500/u38qRcCAiO3SZdFKJKx3fncDyef.jpg","tmdb_url":"https://www.themoviedb.org/person/50463"},{"name":"Kate Mara","name_vi":null,"name_original":"Kate Mara","tmdb_id":51072,"profile":"https://image.tmdb.org/t/p/w500/oKnhaekgHUQqL7uVa7yn6alySgB.jpg","tmdb_url":"https://www.themoviedb.org/person/51072"},{"name":"Zoe Kazan","name_vi":null,"name_original":"Zoe Kazan","tmdb_id":35028,"profile":"https://image.tmdb.org/t/p/w500/rCJxFVtkyNUVTVCWYd6chx2Q19g.jpg","tmdb_url":"https://www.themoviedb.org/person/35028"},{"name":"Pablo Schreiber","name_vi":null,"name_original":"Pablo Schreiber","tmdb_id":59254,"profile":"https://image.tmdb.org/t/p/w500/trKW3kwhwx4UeCNZg43A1x1h4Uv.jpg","tmdb_url":"https://www.themoviedb.org/person/59254"},{"name":"Tony Hale","name_vi":null,"name_original":"Tony Hale","tmdb_id":25147,"profile":"https://image.tmdb.org/t/p/w500/ar4uapp4w5wMkThZcqWUNMSTO8z.jpg","tmdb_url":"https://www.themoviedb.org/person/25147"},{"name":"Michael Algieri","name_vi":null,"name_original":"Michael Algieri","tmdb_id":149969,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/149969"},{"name":"Jakob Appelman","name