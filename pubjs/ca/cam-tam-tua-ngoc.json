p.opstream16.com/share/1921e14349820cc66e19220da2839247","link_m3u8":"https://vip.opstream16.com/20230423/34207_cfe63eb7/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream16.com/share/be5ebf2a77cde6f3cea317989a3c2de5","link_m3u8":"https://vip.opstream16.com/20230423/34208_4d0b0acd/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream16.com/share/460d5587441bf82dbf2acd8a7f56ef86","link_m3u8":"https://vip.opstream16.com/20230423/34209_b7292520/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream16.com/share/f2162f0713c4aa4c3c9a843febf03e56","link_m3u8":"https://vip.opstream16.com/20230423/34210_ebf39924/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream16.com/share/a331c27331682da1666f6f230fce79d8","link_m3u8":"https://vip.opstream16.com/20230423/34211_a248666d/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream16.com/share/65b2bc9eb35261e785fdb1a9bc02b6b1","link_m3u8":"https://vip.opstream16.com/20230423/34212_eec222be/index.m3u8"}]}],"description":"<p>Thập Nhất Nương (Đàm Tùng Vận thủ vai) một tiểu thư trâm anh đài các nhưng không may bị gả vào nhà của vương gia Từ Lệnh Nghi. Hai người cưới nhau vì nghĩa vụ với gia tộc chứ không hề có chút tình cảm gì với nhau. Thế nhưng vì sự đáng yêu, ngay thẳng chính trực của Thập Nhất Nương mà dần dần Từ Lệnh Nghi (Chung Hán Lương đảm nhận) nảy sinh tình cảm với cô lúc nào không hay. Với sự quan tâm đầy ôn nhu của phu quân nàng Thập Nhất Nương cũng dần bị cảm hóa và từ đó cả hai chia sẻ tình cảm cho nhau nhiều hơn. Hạnh phúc chưa được bao lâu thì Từ Lệnh Nghi nghe theo lệnh triều định phải rời xa nhà, bỏ lại Thập Nhất Nương một mình. Ngoài việc ngóng trông phu quân trở về nàng còn phải đối diện với các thành viên Từ gia khi họ liên tiếp gây khó dễ cho cô. Cho tới khi Từ gia gặp biến cố lớn, cả nhà đều bị bắt giam còn Thập Nhất Nương lại bị tuyên án tử. Lúc này Từ Lệnh Nghi sẽ làm gì để cứu thê tử cũng như gia đình của mình?</p>","tmdb_id":119099,"cast":["Chung Hán Lương","Đàm Tùng Vận","Hà Hoằng San","Đường Hiểu Thiên","Chen Qianduo"],"director":["De-Guang Wen"],"keywords":[],"tmdb":{"type":"tv","id":"119099","season":1,"vote_average":5,"vote_count":5},"cast_meta":[{"name":"Chung Hán Lương","name_vi":"Chung Hán Lương","name_original":"Wallace Chung","tmdb_id":1183233,"profile":"https://image.tmdb.org/t/p/w500/mDJQSyCQdPW2lJDbY46udu0161n.jpg","tmdb_url":"https://www.themoviedb.org/person/1183233"},{"name":"Đàm Tùng Vận","name_vi":"Đàm Tùng Vận","name_original":"Tan Songyun","tmdb_id":1614218,"profile":"https://image.tmdb.org/t/p/w500/yYMnfaIix23U51z21EJhznq3DHN.jpg","tmdb_url":"https://www.themoviedb.org/person/1614218"},{"name":"Hà Hoằng San","name_vi":"Hà Hoằng San","name_original":"He Hongshan","tmdb_id":1613347,"profile":"https://image.tmdb.org/t/p/w500/3D38zuXKzqmj7TegdDvhh8Bow1K.jpg","tmdb_url":"https://www.themoviedb.org/person/1613347"},{"name":"Đường Hiểu Thiên","name_vi":"Đường Hiểu Thiên","name_original":"Tang Xiaotian","tmdb_id":2312401,"profile":"https://image.tmdb.org/t/p/w500/84NlC4nbZqwUJXH0tSNw9O6o3Um.jpg","tmdb_url":"https://www.themoviedb.org/person/2312401"},{"name":"Chen Qianduo","name_vi":null,"name_original":"Chen Qianduo","tmdb_id":2506107,"profile":"https://image.tmdb.org/t/p/w500/DgdJQePgclDIsL0Y9puhNjvr3U.jpg","tmdb_url":"https://www.themoviedb.org/person/2506107"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ca/cam-tam-tua-ngoc.json"}