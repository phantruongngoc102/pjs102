5 phút/tập","description":"<p>Cán Cân Công Lý - Black Light House là bộ phim xoay quanh cuộc sống của những con người làm việc trong tòa án và những vụ án hiểm hóc, nguy hiểm. Mỗi tập phim là hành trình phá án với đầy rẫy những nghi vấn, bí mật đang dần được sáng tỏ. Vấn đề pháp luật khô khan nhưng được xem lẫn với yếu tố tình cảm nên càng thu hút người xem.</p>","tmdb":{"type":"tv","id":"111900","season":1,"vote_average":10,"vote_count":1},"modified":"2023-05-20T18:06:43.000Z","cast":["Ngô Thiến","Dương Lặc","Zheng Yawen","Dai Xu","Jiang Kai","Cai Yida","Zhong Qi","Yang Yuting","Du Zhiguo","Liu Yang","Lin Peng","Jin Chong","Thư Á Tín","Chen Hui-Ling"],"director":["Sử Hách Nhiên"],"cast_meta":[{"name":"Ngô Thiến","name_vi":"Ngô Thiến","name_original":"Janice Wu","tmdb_id":1677008,"profile":"https://image.tmdb.org/t/p/w500/zNw2OQbHC343epJkSgR3FUHGWmA.jpg","tmdb_url":"https://www.themoviedb.org/person/1677008"},{"name":"Dương Lặc","name_vi":"Dương Lặc","name_original":"Yang Le","tmdb_id":2018045,"profile":"https://image.tmdb.org/t/p/w500/6yvhf8DffccXncVffVveNKTDScz.jpg","tmdb_url":"https://www.themoviedb.org/person/2018045"},{"name":"Zheng Yawen","name_vi":null,"name_original":"Zheng Yawen","tmdb_id":2456788,"profile":"https://image.tmdb.org/t/p/w500/xlRohPjNfcuDZlO8NVDikQeZfCb.jpg","tmdb_url":"https://www.themoviedb.org/person/2456788"},{"name":"Dai Xu","name_vi":null,"name_original":"Dai Xu","tmdb_id":1872331,"profile":"https://image.tmdb.org/t/p/w500/3tJyYJ71YJPYTaRQpg68ezLryhW.jpg","tmdb_url":"https://www.themoviedb.org/person/1872331"},{"name":"Jiang Kai","name_vi":null,"name_original":"Jiang Kai","tmdb_id":2309098,"profile":"https://image.tmdb.org/t/p/w500/2afhFUkvyhzH3rbpvPqLUHSTsKU.jpg","tmdb_url":"https://www.themoviedb.org/person/2309098"},{"name":"Cai Yida","name_vi":null,"name_original":"Cai Yida","tmdb_id":2959148,"profile":"https://image.tmdb.org/t/p/w500/7QsKjdxGgkoTxOK9DM8THIQuQ1W.jpg","tmdb_url":"https://www.themoviedb.org/person/2959148"},{"name":"Zh