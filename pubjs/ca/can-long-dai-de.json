371aff945535baebb","link_m3u8":"https://vip.opstream13.com/20250906/6347_bc1ad6e8/index.m3u8"}]}],"description":"Hoàng đế Ung Chính quyết định truyền ngôi lại cho tứ hoàng tử Hoằng Lịch. Tam hoàng tử Hoằng Chú biết chuyện đã âm mưu cấu kết với người ngoài bắt cóc Hoằng Lịch. Ung Chính nhờ đến kiếm khách Tang Tịnh giúp đõ cho Hoằng Lịch lên ngôi. Trong lúc gặp nạn, Hoằng Lịch đã yêu dân nữ Tiểu Ngọc, hậu nhân trung thần đã bị Ung Chính giết chết. Nhờ có Tang Tịnh, Hoằng Lịch có thể diệt loạn Hoằng Chú, an toàn lên ngôi vua là Càn Long. Càn Long đưa Tiểu Ngọc vào cung làm phi tử, nhưng Tiểu Ngọc không được lòng của Thái hậu. Sau khi làm vua, Càn Long muốn tiêu diệt thế lực phản Thanh ngoài cung và Tang Tịnh. Vì không cách nào khuyên can chồng, Tiểu Ngọc quyết định tự thiêu để tạ tội thay cho Càn Long trước cái chết của Tang Tịnh.","tmdb_id":100327,"cast":["Timmy Ho Bo-Sang","Khương Đại Vệ","Danny Summer","Cổ Thiên Lạc","Ông Hồng","La Lạc Lâm","Derek Kwok Jing-Hung","Bonnie Ngai Chau-Wah","Teresa Mak Ka-Kei","Sidney Yim","Lạc Ứng Quân","Wai-Lam Wong","Lau Gwai-Fong","Cheng Ka-Sang","Ngai Wai-Man"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"100327","season":1,"vote_average":6,"vote_count":1},"cast_meta":[{"name":"Timmy Ho Bo-Sang","name_vi":null,"name_original":"Timmy Ho Bo-Sang","tmdb_id":65942,"profile":"https://image.tmdb.org/t/p/w500/4JGlBuDQ7dch94TcAgxcOjz527P.jpg","tmdb_url":"https://www.themoviedb.org/person/65942"},{"name":"Khương Đại Vệ","name_vi":"Khương Đại Vệ","name_original":"David Chiang Da-Wei","tmdb_id":65986,"profile":"https://image.tmdb.org/t/p/w500/7Wwna95s5U3g7T3z4s7uD51ZAXX.jpg","tmdb_url":"https://www.themoviedb.org/person/65986"},{"name":"Danny Summer","name_vi":null,"name_original":"Danny Summer","tmdb_id":1063337,"profile":"https://image.tmdb.org/t/p/w500/25mCV4wYdvtH97qGqK1WtZKsTGR.jpg","tmdb_url":"https://www.themoviedb.org/person/1063337"},{"name":"Cổ Thiên Lạc","name_vi":"Cổ Thiên Lạc","name_original":"Louis Koo","tmdb_id":78875,"