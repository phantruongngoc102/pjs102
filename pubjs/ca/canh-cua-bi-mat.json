esteryear is drawn into this mess.</p>","tmdb":{"type":"tv","id":"226198","season":1,"vote_average":9,"vote_count":1},"modified":"2025-03-19T11:29:54.000Z","cast":["Trần Triển Bằng","Mandy Wong","Roxanne Tong","Ngô Đại Dung","Lưu Bội Nguyệt","Nguyễn Hạo Tông","Angelina Lo","Lỗ Chấn Thuận","Hugo Wong","Trương Quốc Cường","Edith Au","Aurora Li","Jerry Leung Ho-Kai","Frankie Choi","Kelvin Yuen"],"director":["Sum-Wai Wong"],"cast_meta":[{"name":"Trần Triển Bằng","name_vi":"Trần Triển Bằng","name_original":"Ruco Chan","tmdb_id":1238985,"profile":"https://image.tmdb.org/t/p/w500/jD9jx5wiF3Y0XYzvcCNC2oRBrvT.jpg","tmdb_url":"https://www.themoviedb.org/person/1238985"},{"name":"Mandy Wong","name_vi":null,"name_original":"Mandy Wong","tmdb_id":1255464,"profile":"https://image.tmdb.org/t/p/w500/hK69LsDU6G1EHtiwPEpf7BYV0e.jpg","tmdb_url":"https://www.themoviedb.org/person/1255464"},{"name":"Roxanne Tong","name_vi":null,"name_original":"Roxanne Tong","tmdb_id":1967121,"profile":"https://image.tmdb.org/t/p/w500/zLbZGXfvhKbJpReSEECiedarfeg.jpg","tmdb_url":"https://www.themoviedb.org/person/1967121"},{"name":"Ngô Đại Dung","name_vi":"Ngô Đại Dung","name_original":"Hugo Ng Doi-Yung","tmdb_id":1187932,"profile":"https://image.tmdb.org/t/p/w500/1FNy7eOKdfjQcKT1aIjv6G0akTs.jpg","tmdb_url":"https://www.themoviedb.org/person/1187932"},{"name":"Lưu Bội Nguyệt","name_vi":"Lưu Bội Nguyệt","name_original":"Moon Lau","tmdb_id":2363302,"profile":"https://image.tmdb.org/t/p/w500/7gTQNEtJqNfsb7703Jr8Bgn5Ebb.jpg","tmdb_url":"https://www.themoviedb.org/person/2363302"},{"name":"Nguyễn Hạo Tông","name_vi":"Nguyễn Hạo Tông","name_original":"Nicholas Yuen","tmdb_id":2985584,"profile":"https://image.tmdb.org/t/p/w500/jYRVfFP2tUa2qNJa1QRbxwS2TOy.jpg","tmdb_url":"https://www.themoviedb.org/person/2985584"},{"name":"Angelina Lo","name_vi":null,"name_original":"Angelina Lo","tmdb_id":1395247,"profile":"https://image.tmdb.org/t/p/w500/i3xgUygPWn3TTFRpFwqTDmxM8T7.jpg","tmdb_url":"https://www.themoviedb.org/