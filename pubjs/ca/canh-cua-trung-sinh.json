76_57950ac8/index.m3u8"},{"name":"23","slug":"23","filename":"Trùng Sinh Chi Môn Tập 23 VietSub - Thuyết Minh","link_embed":"https://vip.opstream14.com/share/4ba731e0a0b4158a18be3f0eb9047f17","link_m3u8":"https://vip.opstream14.com/20220523/12377_30f5ad8d/index.m3u8"},{"name":"24","slug":"24","filename":"Trùng Sinh Chi Môn Tập 24 VietSub - Thuyết Minh","link_embed":"https://vip.opstream14.com/share/d325c14493d4d39e4591e65600ac5423","link_m3u8":"https://vip.opstream14.com/20220523/12378_d2ac3276/index.m3u8"},{"name":"25","slug":"25","filename":"Trùng Sinh Chi Môn Tập 25 VietSub - Thuyết Minh","link_embed":"https://vip.opstream14.com/share/066f182b787111ed4cb65ed437f0855b","link_m3u8":"https://vip.opstream14.com/20220523/12379_18ee7eb5/index.m3u8"},{"name":"26","slug":"26","filename":"Trùng Sinh Chi Môn Tập 26 - Tập cuối VietSub - Thuyết Minh","link_embed":"https://vip.opstream14.com/share/ab9a3f4c92c0f50204a1fe6dbf2e1d0a","link_m3u8":"https://vip.opstream14.com/20220523/12380_868af179/index.m3u8"}]}],"time":"45 phút/ tập","description":"<p>La Kiên là một vị cảnh sát điều tra dày dạn kinh nghiệm, năng lực trinh sát rất mạnh. Trang Văn Kiệt một sinh viên Luật năm 3 thiên tài lạnh lùng, nhà có truyền thống trộm cắp, với truyền thống từ ông nội và cha, cậu có thể nắm rõ được những mánh khóe tinh vi trong kỹ thuật trộm.</p><p>Một lần bức tranh “Hoa Súng” bị đánh cắp xảy ra trong trường học mà cảnh sát La Kiên và cậu sinh viên Trang Văn Kiệt gặp gỡ, hai con người với hai tính cách và hoàn cảnh sống khác biệt, từ vụ án “Hoa Súng” đến những vụ án kì lạ khác xảy ra, từ ngờ vực lẫn nhau đến tin tưởng kề vai chiến đấu, cuối cùng cả hai vẫn kiên định với ánh sáng công lý và truyền tải năng lượng tích cực cho bộ phim.</p>","tmdb":{"type":"tv","id":"200737","season":1,"vote_average":6.714,"vote_count":7},"modified":"2022-05-23T06:00:17.000Z","cast":["Zhang Yi","Karry Wang"],"director":["Yang Dong"],"cast_meta":[{"name":"Zhang Yi","name_vi":null,"name_original":"Zhang Yi"},{"name":