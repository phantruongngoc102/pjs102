3u8":"https://vip.opstream10.com/20220603/18654_19095e54/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/e6b69a6732af1fbd1e8d4c63165205e9","link_m3u8":"https://vip.opstream10.com/20220603/18655_8be66f5e/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/bf0c0d36a5a3f240ccbc590fca184a7f","link_m3u8":"https://vip.opstream10.com/20220603/18656_06e814ef/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/570938f00c1f30c59530b15fc930dd0f","link_m3u8":"https://vip.opstream10.com/20220603/18657_06880998/index.m3u8"}]}],"description":"<p>Vào cái ngày có tân Cảnh Trưởng tới nhậm chức ở đồn Kitamachi, các cán bộ nơi đây đang chuẩn bị chào đón anh. Thì lúc đó, một chiếc xe buýt bị một người đàn ông có dao cướp và uy hiếp các hành khách trên xe. Lính mới Aikawa Minori bị một hành khách đá ra ngoài khi cô gắng lên chuyến xe buýt đó.Cô bám theo chiếc xe buýt bằng taxi, nhưng chiếc xe buýt lại hướng thẳng về phía đồn Kitamachi. Vì một lý do kỳ lạ gì mà tên cướp đã tự tới đồn trình diện. Sau đó Minori đã còng tay người cản trở mình thi hành công vụ. Nhưng người đàn ông mà cô còng tay đó, lại chính là tân Cảnh Trưởng, Toyama Kinshiro.</p>","tmdb_id":71255,"cast":["Hiroshi Tamaki","Masahiro Takashima","Miori Takimoto","Shingo Yanagisawa","Kazuaki Hankai","Kurara Chibana","Jin Shirasu","Yusuke Hirayama"],"director":[],"keywords":[],"cast_meta":[{"name":"Hiroshi Tamaki","name_vi":null,"name_original":"Hiroshi Tamaki","tmdb_id":117974,"profile":"https://image.tmdb.org/t/p/w500/euG0zAX261rVHkOStXEiDc7XSfM.jpg","tmdb_url":"https://www.themoviedb.org/person/117974"},{"name":"Masahiro Takashima","name_vi":null,"name_original":"Masahiro Takashima","tmdb_id":50653,"profile":"https://image.tmdb.org/t/p/w500/rvq7e2oeDXTXLPnxcPhe34KTbA8.jpg","tmdb_url":"https://www.themoviedb.org/person/50653"},{"name":"Miori Takimoto","name_vi":null,"name_original":"Miori Takimoto","tmdb_id":227612,"profile":"htt