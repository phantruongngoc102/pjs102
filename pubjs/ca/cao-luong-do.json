/share/ab541d874c7bc19ab77642849e02b89f","link_m3u8":"https://vip.opstream12.com/20220226/1482_890b935c/index.m3u8"},{"name":"50","slug":"50","filename":"Cao Lương Đỏ - Red Sorghum - Tập 50","link_embed":"https://vip.opstream12.com/share/83cdcec08fbf90370fcf53bdd56604ff","link_m3u8":"https://vip.opstream12.com/20220226/1478_ee0503c4/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Cao Lương Đỏ - Red Sorghum được chuyển thể từ tiểu thuyết của nhà văn từng đoạt giải Nobel Mạc Ngôn. Vào những năm 1920 tại miền quê Cao, cô gái trẻ tên Cửu Nhi bị gả cho một người đàn ông mắc bệnh phong. Ngày lên kiệu hoa, cô phải lòng người phu kiệu tên Dư Chiêm Ngao. Ba ngày hạnh phúc cùng người mình yêu trong rừng đã đem lại cho Cửu Nhi một đứa con trai. 14 năm sau, cậu con trai tham gia vào đoàn quân của tư lệnh Dư Chiêm Ngao để lên đường kháng chiến chống Nhật.</p>","tmdb":{"type":"tv","id":"61718","season":1,"vote_average":7.8,"vote_count":4},"modified":"2023-06-23T19:26:38.000Z","cast":["Châu Tấn","Chu Á Văn","Hoàng Hiên","Vu Vinh Quang","Tần Hải Lộ","Alvin Cao","Hàn Đồng Sinh","Lan Wang","Ryu Kohata","Chi Peng","Song Jialun"],"director":["Trương Nghệ Mưu"],"cast_meta":[{"name":"Châu Tấn","name_vi":"Châu Tấn","name_original":"Zhou Xun","tmdb_id":71057,"profile":"https://image.tmdb.org/t/p/w500/oXpUBTfcOafc4wD54Qa2uItAok9.jpg","tmdb_url":"https://www.themoviedb.org/person/71057"},{"name":"Chu Á Văn","name_vi":"Chu Á Văn","name_original":"Zhu Yawen","tmdb_id":1376105,"profile":"https://image.tmdb.org/t/p/w500/ihNzfo88inSx0TFzOgEyIiszXTD.jpg","tmdb_url":"https://www.themoviedb.org/person/1376105"},{"name":"Hoàng Hiên","name_vi":"Hoàng Hiên","name_original":"Huang Xuan","tmdb_id":1376106,"profile":"https://image.tmdb.org/t/p/w500/dedh0tG92cerVlFOJRX3YRBI3Lk.jpg","tmdb_url":"https://www.themoviedb.org/person/1376106"},{"name":"Vu Vinh Quang","name_vi":"Vu Vinh Quang","name_original":"Yu Rongguang","tmdb_id":120725,"profile":"https://image.tmdb.org/t/p/w500/qRPhrqPLYvca6Wdv9lMxwEm7