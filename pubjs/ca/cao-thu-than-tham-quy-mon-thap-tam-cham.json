à thật hay giả, rốt cuộc kẻ sát nhân thật sự là ai?</p>","tmdb":{"type":"movie","id":"868948","season":null,"vote_average":0,"vote_count":0},"modified":"2022-05-24T03:00:29.000Z","cast":["He Gang","Chengjun Bo","Zhang Xin Lei","Shen Xian Yu","Yang zhenning","Shi Yan"],"director":["Jason"],"cast_meta":[{"name":"He Gang","name_vi":null,"name_original":"He Gang"},{"name":"Chengjun Bo","name_vi":null,"name_original":"Chengjun Bo"},{"name":"Zhang Xin Lei","name_vi":null,"name_original":"Zhang Xin Lei"},{"name":"Shen Xian Yu","name_vi":null,"name_original":"Shen Xian Yu"},{"name":"Yang zhenning","name_vi":null,"name_original":"Yang zhenning"},{"name":"Shi Yan","name_vi":null,"name_original":"Shi Yan"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ca/cao-thu-than-tham-quy-mon-thap-tam-cham.json"}