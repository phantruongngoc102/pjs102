nk_m3u8":"https://vip.opstream90.com/20251114/17572_a7c20df2/index.m3u8"}]}],"time":"30 phút/tập","description":"<p>Phần hai bắt đầu vào năm 2162, khi Josh, Wolf và Tiger phát hiện ra nhiệm vụ ngăn chặn thuốc giải thoát của họ ở phần một đã thất bại. Trong dòng thời gian này, Stu Camillo giờ đây đã nắm quyền, tạo ra thuốc giải và khởi động kế hoạch di dời nhân loại lên sao Hỏa. Một tổ chức bí ẩn mang tên Pointed Circle tìm cách chiêu mộ Josh để hạ gục Stu – nhưng liệu họ là người tốt, hay Stu mới là người tốt? Trong khi Wolf nhanh chóng thích nghi với những phong tục kỳ lạ của thời đại này, Tiger chật vật với khám phá mới và tìm cách trốn thoát.</p>","tmdb":{"type":"tv","id":"73157","season":2,"vote_average":7.153,"vote_count":540},"modified":"2025-11-14T11:52:56.000Z","cast":["Josh Hutcherson","Eliza Coupe","Derek Wilson"],"director":[],"cast_meta":[{"name":"Josh Hutcherson","name_vi":null,"name_original":"Josh Hutcherson","tmdb_id":27972,"profile":"https://image.tmdb.org/t/p/w500/f0eosZ1Fx0VBUyspq8K2f8sUSBn.jpg","tmdb_url":"https://www.themoviedb.org/person/27972"},{"name":"Eliza Coupe","name_vi":null,"name_original":"Eliza Coupe","tmdb_id":210050,"profile":"https://image.tmdb.org/t/p/w500/uscVJ5XW8pA74wPaT29OlIx1Fy5.jpg","tmdb_url":"https://www.themoviedb.org/person/210050"},{"name":"Derek Wilson","name_vi":null,"name_original":"Derek Wilson","tmdb_id":1633357,"profile":"https://image.tmdb.org/t/p/w500/m0IuJRaOeSwC5Tbnu0PhGYp53zO.jpg","tmdb_url":"https://www.themoviedb.org/person/1633357"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ca/cao-thu-tuong-lai-phan-2.json"}