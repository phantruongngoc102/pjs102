8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream12.com/share/c64c7085e3ecb77c60caf49560a1ea67","link_m3u8":"https://vip.opstream12.com/20250222/25277_c64c7085/index.m3u8"}]}],"description":"<p><i>Cát Tường Thiên Bảo là tác phẩm truyền hình cổ trang lấy bối cảnh thời nhà Minh, phim kể về câu chuyện tranh chấp quyền lực, địa vị và tình yêu giữa 2 cậu con trai của Kiến Hưng Vương là Chu Thiên Bảo (Kim Ki Bum) và Chu Thiên Tường (Chu Tử Kiêu). Mối duyên Thiên Bảo – Tiểu Điệp sẽ được xây dựng theo mô-típ chuyện tình oan gia. Cả hai ban đầu đều chẳng ưa gì đối phương, hễ gặp mặt là gây gổ ầm ĩ, đấu cả võ chân tay lẫn võ mồm. Nhưng rồi, họ lại dần cảm nắng nhau lúc nào không hay. Chu Thiên Bảo là con trai út của vương gia Kiến Hưng, vì luôn được yêu thương chiều chuộng nên khiến anh cả Chu Thiên Tường nảy lòng ghen ghét, trong một lần ngao du bị Chu Thiên Tường hãm hại, sau đó mất trí nhớ được dân nữ Mạnh Tiểu Điệp tương trợ. Dưới sự giúp sức của Mạnh Tiểu Điệp, anh đã trở thành một thầy cãi giúp đỡ dân chúng, cuối cùng được diện kiến thánh thượng. Vô tình Chu Thiên Bảo phát hiện âm mưu to lớn của Chu Thiên Tường, sau khi vạch trần thì trở thành công thần của hoàng thượng. Nhưng anh từ chối chức quan và bổng lộc, chỉ xin hoàng thượng ban tước vương gia cửu phẩm, từ đó tiêu dao giữa dân gian.</i></p>","tmdb_id":195609,"cast":["Kim Ki-bum","Triệu Lệ Dĩnh","Zhu Zixiao","Chen Yulin","Wong Hei","Nguyên Hoa","Liêu Bích Nhi","Xu Ke","Meng Rui"],"director":["Nguyên Đức"],"keywords":[],"tmdb":{"type":"tv","id":"195609","season":1,"vote_average":9,"vote_count":1},"cast_meta":[{"name":"Kim Ki-bum","name_vi":null,"name_original":"Kim Ki-bum","tmdb_id":1246904,"profile":"https://image.tmdb.org/t/p/w500/m9wdJPqeSVKF2wH3uDYgxlYPRqQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1246904"},{"name":"Triệu Lệ Dĩnh","name_vi":"Triệu Lệ Dĩnh","name_original":"Zhao Liying","tmdb_id":1260868,"profile":"https://image.tmdb.org/t/p/w500/lDkliS0cwOFO0QA7epHYZJWNttG.jpg","tmdb_url"