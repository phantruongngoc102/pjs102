stream14.com/share/8b43e1b8dd88fb9f6c99eb66f448a04c","link_m3u8":"https://vip.opstream14.com/20220701/16648_9e6ead47/index.m3u8"},{"name":"22","slug":"22","filename":"Cậu Đúng Là Một Thiên Tài Tập 22 - Lần đầu gặp đồng môn","link_embed":"https://vip.opstream14.com/share/e9cde247132ad24f2a476a6d7a9dbd16","link_m3u8":"https://vip.opstream14.com/20220704/17107_607d057e/index.m3u8"},{"name":"23","slug":"23","filename":"Cậu Đúng Là Một Thiên Tài Tập 23 - Ma chủng truyền kỳ","link_embed":"https://vip.opstream14.com/share/2407dc29cf2ab352752d288c15d812b2","link_m3u8":"https://vip.opstream14.com/20220708/17791_c95a3835/index.m3u8"},{"name":"24","slug":"24","filename":"Cậu Đúng Là Một Thiên Tài Tập 24 - Phát huy phi thường","link_embed":"https://vip.opstream14.com/share/84e9f7f4ff1920227cbdf05cb52f0ae7","link_m3u8":"https://vip.opstream14.com/20220711/17894_ba7c93ab/index.m3u8"}]}],"time":"10 phút/tập","description":"<p>Bạch Kiêu chàng trai của bộ lạc Tuyết Sơn vì để giải trừ lời nguyền của người yêu là Thanh Nguyệt bị ép phải rời đi. Thế giới xa cách nhau nghìn dặm cùng với người yêu bị mất trí nhớ cũng không thể ngăn cản bước chân của Bạch Kiêu. Cậu ấy mang theo vô số bảo vật một mình đi tới đại lục phía nam, mở ra hành trình tìm kiếm người yêu. Người con trai được định sẵn sẽ trở thành thiên tài này với thiên phú và tài trí hơn người của mình đã làm trấn kinh toàn bộ đế quốc. Con đường tu hành ma đạo của cậu ấy sẽ đi theo hướng nào? Cậu ấy liệu có thể một lần nữa giành được trái tim của Thanh Nguyệt hay không?</p>","tmdb":{"type":"tv","id":"199361","season":1,"vote_average":7,"vote_count":1},"modified":"2025-05-30T10:01:29.000Z","cast":["He Yuxiang","Qiuxiang Shen","Tao Wu"],"director":[],"cast_meta":[{"name":"He Yuxiang","name_vi":null,"name_original":"He Yuxiang","tmdb_id":3523565,"profile":"https://image.tmdb.org/t/p/w500/ftyBCAgwqIUXIrGuGLxfGrRrPIf.jpg","tmdb_url":"https://www.themoviedb.org/person/3523565"},{"name":"Qiuxiang Shen","name_vi":null,"name_original":"Qiuxiang Shen","tmdb_id":2165995,"profile":"https://image.tmdb.org/t/p/w500/iIPbklLu2SHQbVJ603pCNv2GaT7.jpg","tmdb_url":"https://www.themoviedb.org/person/2165995"},{"name":"Tao Wu","name_vi":null,"name_original":"Tao Wu","tmdb_id":4837258,"profile":"https://image.tmdb.org/t/p/w500/vrlB9U7yULRl2TsifiYzzoqm0pJ.jpg","tmdb_url":"https://www.themoviedb.org/person/4837258"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ca/cau-dung-la-mot-thien-tai.json"}