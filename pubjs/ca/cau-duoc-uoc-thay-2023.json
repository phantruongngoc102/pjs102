vip.opstream11.com/20231005/48072_21760062/index.m3u8"},{"name":"34","slug":"34","filename":"Cầu Được Ước Thấy Tập 34","link_embed":"https://vip.opstream11.com/share/077720fbbf60d0bb8f68b93d003db66a","link_m3u8":"https://vip.opstream11.com/20231005/48073_99c5b3c5/index.m3u8"},{"name":"35","slug":"35","filename":"Cau Duoc Uoc Thay E35","link_embed":"https://vip.opstream16.com/share/3f7df51fd92a282d6080ad4fe333eb1a","link_m3u8":"https://vip.opstream16.com/20230326/33441_28d07f71/index.m3u8"},{"name":"36","slug":"36","filename":"Cau Duoc Uoc Thay E36","link_embed":"https://vip.opstream16.com/share/be4dfce0bd450fdd57fda1bd637ad712","link_m3u8":"https://vip.opstream16.com/20230326/33442_c98c3fb2/index.m3u8"}]}],"time":"46 phút/tập","description":"Tôn Tâm và Tôn Tưởng, một người dám chiến đấu và đột phá, người kia ấm áp như nước. Người chị Tôn Tâm xinh đẹp và hào phóng, theo đuổi tự do và dám chiến đấu hết mình. Cô em gái Tôn Tưởng, trong sáng và tốt bụng, luôn nói cười vui vẻ. Tính cách quá khác biệt khiến hai chị em bước vào những quỹ đạo cuộc đời hoàn toàn khác nhau. Người chị đang làm ăn phát đạt trong một công ty Internet, trải qua bao thăng trầm; em gái phát hiện ra thế mạnh của bản thân và trở thành một blogger ẩm thực, ăn ngon sống nhàn. Trong 8 năm từ 2012 đến 2020, cuộc sống của họ ngày càng khấm khá, dù trải qua nhiều nhưng họ luôn tràn đầy niềm tin vào tương lai.Cuộc sống muôn màu, bình thản hạnh phúc, phấn đấu thiết thực đều lại những “vị” cơ bản. Mỗi gia đình là một đất nước nhỏ thì quốc gia là hàng vạn gia đình. Chính vì có hàng ngàn người bình thường như chị em nhà họ Tôn siêng năng, tốt bụng và không ngừng theo đuổi ước mơ của mình mà xã hội tràn đầy sức sống và thịnh vượng, và \\\"xã hội thịnh vượng vừa phải\\\" đã trở thành hiện thực sống động xung quanh người Trung Quốc.","tmdb":{"type":"tv","id":"221708","season":1,"vote_average":5.7,"vote_count":3},"modified":"2024-11-14T15:42:34.000Z","cast":["Mao Hiểu Đồng","Trương Lệ","Lý Trạch Phong",