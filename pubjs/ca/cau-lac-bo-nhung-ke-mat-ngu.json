nk_m3u8":"https://vip.opstream11.com/20230814/46488_7221e3f7/index.m3u8"}]}],"time":"24 phút/tập","description":"Nakami là một học sinh trung học siêng năng nhưng luôn cáu kỉnh và chống đối xã hội. Tuy nhiên, thái độ tồi tệ ấy của cậu xuất phát từ việc bị rối loạn giấc ngủ và thường xuyên thức trắng đêm. Một ngày nọ, cậu được nhờ đến đài quan sát thiên văn của trường để lấy đồ, một nơi được cho là bị ma ám. Cũng tại đây, cậu tình cờ phát hiện người bạn cùng lớp là Magari Isaki cũng đang mượn nơi này để chợp mắt. Hai con người giống nhau, cùng che giấu những vấn đề về chứng mất ngủ đã tìm đến đài quan sát như một chốn để bù đắp cho những đêm dài thao thức... Liệu họ có tìm thấy sự an yên mà bấy lâu nay vẫn kiếm tìm?","tmdb":{"type":"tv","id":"155440","season":1,"vote_average":7.663,"vote_count":49},"modified":"2023-08-14T16:19:43.000Z","cast":["Gen Sato","Konomi Tamura"],"director":[],"cast_meta":[{"name":"Gen Sato","name_vi":null,"name_original":"Gen Sato","tmdb_id":2410694,"profile":"https://image.tmdb.org/t/p/w500/gdKxR84xGgU19eqWlPKEGZsiID6.jpg","tmdb_url":"https://www.themoviedb.org/person/2410694"},{"name":"Konomi Tamura","name_vi":null,"name_original":"Konomi Tamura","tmdb_id":3433732,"profile":"https://image.tmdb.org/t/p/w500/y0MSKRPSWuCyi1tUlcOL1YmsYnw.jpg","tmdb_url":"https://www.themoviedb.org/person/3433732"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ca/cau-lac-bo-nhung-ke-mat-ngu.json"}