stream13.com/share/7d62228d788292ee693d12fd549e7745","link_m3u8":"https://vip.opstream13.com/20251121/18291_7d62228d/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream13.com/share/d805f6b15edb8bceaf116526fad1609c","link_m3u8":"https://vip.opstream13.com/20251121/18292_d805f6b1/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream13.com/share/d64295c7aa041a80e7d99b7aee97a920","link_m3u8":"https://vip.opstream13.com/20251121/18293_d64295c7/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream13.com/share/b1b207a09a44e6a5528fb4c90ae85143","link_m3u8":"https://vip.opstream13.com/20251121/18294_b1b207a0/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream13.com/share/dd3765ac4f23d2cc861b8dbff12de05e","link_m3u8":"https://vip.opstream13.com/20251121/18295_dd3765ac/index.m3u8"}]}],"description":"<p>Bộ phim kể về câu chuyện của hai người cha đơn thân - ông Bình (<a href=\"https://vi.wikipedia.org/wiki/Th%C3%A1i_S%C6%A1n_(ngh%E1%BB%87_s%C4%A9)\">Trần Thái Sơn)</a> và ông Chính (<a href=\"https://vi.wikipedia.org/wiki/B%C3%B9i_Nh%C6%B0_Lai\">Bùi Như Lai</a>), những người đã cùng nhau nuôi dưỡng ba đứa trẻ: Trần Khôi Nguyên (<a href=\"https://vi.wikipedia.org/wiki/Tr%E1%BA%A7n_Ngh%C4%A9a_(di%E1%BB%85n_vi%C3%AAn)\">Trần Nghĩa</a>), Vũ Quốc Việt (Thái Vũ) và Lê Hà An (Nguyễn Hoàng Ngọc Huyền) như anh em một nhà. Dù không cùng huyết thống, các con vẫn lớn lên trong tình yêu thương trọn vẹn. Tuy nhiên, khi trưởng thành, Nguyên và Việt buộc phải rời xa gia đình vì ràng buộc máu mủ. Sau 6 năm xa cách, khi đoàn tụ, những tổn thương và hiểu lầm dần được hàn gắn, khẳng định rằng dù cuộc đời có đổi thay thế nào, những người cha vẫn luôn là điểm tựa vững chắc cho con cái.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/cha-toi-nguoi-o-lai.json"}