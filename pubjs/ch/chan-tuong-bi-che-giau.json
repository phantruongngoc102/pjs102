úc mã lại bị bắt cóc, kẻ đứng sau sự việc này lại là...</p><p>&nbsp;</p>","tmdb_id":313056,"cast":["Đinh Quán Sâm","Yin Xiaotian","Huang Tingting","Quách Phẩm Siêu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"313056","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Đinh Quán Sâm","name_vi":"Đinh Quán Sâm","name_original":"Ding Guansen","tmdb_id":1780717,"profile":"https://image.tmdb.org/t/p/w500/iuf2pu3drbiYMsqW3DEIbpxaPt8.jpg","tmdb_url":"https://www.themoviedb.org/person/1780717"},{"name":"Yin Xiaotian","name_vi":null,"name_original":"Yin Xiaotian","tmdb_id":1297343,"profile":"https://image.tmdb.org/t/p/w500/jQlemnuEu5C1XxHI6t2Z1vtVju8.jpg","tmdb_url":"https://www.themoviedb.org/person/1297343"},{"name":"Huang Tingting","name_vi":null,"name_original":"Huang Tingting","tmdb_id":2407260,"profile":"https://image.tmdb.org/t/p/w500/zRU1ji0kfo5DW6uCLMePSpI9gdm.jpg","tmdb_url":"https://www.themoviedb.org/person/2407260"},{"name":"Quách Phẩm Siêu","name_vi":"Quách Phẩm Siêu","name_original":"Dylan Kuo","tmdb_id":128040,"profile":"https://image.tmdb.org/t/p/w500/qQxjcDG5qJhn7Ril2JVEcEN1Wej.jpg","tmdb_url":"https://www.themoviedb.org/person/128040"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chan-tuong-bi-che-giau.json"}