 của chắp cánh ước mơ sẽ có mặt, để hiện thực hóa những ý tưởng trong mơ của các bạn nhỏ thành những không gian vô cùng ấn tượng, không gian riêng tư thật sự đặc biệt</p>","tmdb":{"type":"tv","id":"110618","season":1,"vote_average":0,"vote_count":0},"modified":"2022-06-24T12:16:01.000Z","cast":["Meryl Fernandes","Joe Swash"],"director":["Ian Birchall"],"cast_meta":[{"name":"Meryl Fernandes","name_vi":null,"name_original":"Meryl Fernandes","tmdb_id":3390960,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3390960"},{"name":"Joe Swash","name_vi":null,"name_original":"Joe Swash","tmdb_id":1216031,"profile":"https://image.tmdb.org/t/p/w500/rsbSomNCuK8idjVvi3hUMA9DM9w.jpg","tmdb_url":"https://www.themoviedb.org/person/1216031"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ch/chap-canh-uoc-mo.json"}