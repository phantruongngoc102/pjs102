au còn có mưu đồ tày trời, có liên quan chặt chẽ tới tung tích của Hải Nhâm.","tmdb_id":238806,"cast":["Wang Yajia","Chương Thời An"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"238806","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Wang Yajia","name_vi":null,"name_original":"Wang Yajia","tmdb_id":4120132,"profile":"https://image.tmdb.org/t/p/w500/lmSbBxbedHZFLDpCRpEzm4ntzqq.jpg","tmdb_url":"https://www.themoviedb.org/person/4120132"},{"name":"Chương Thời An","name_vi":"Chương Thời An","name_original":"Shawn Zhang","tmdb_id":4410137,"profile":"https://image.tmdb.org/t/p/w500/fUSaGNMEc0OBSYYP4ywPx1ncDXq.jpg","tmdb_url":"https://www.themoviedb.org/person/4410137"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ch/chau-tinh-ky.json"}