ream90.com/share/ededc7e1ce8f57bb859089b9360ed86f","link_m3u8":"https://vip.opstream90.com/20260220/25452_ededc7e1/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream90.com/share/8d6e401410acccfbd1e77b322cfb6e88","link_m3u8":"https://vip.opstream90.com/20260226/25964_8d6e4014/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream90.com/share/8ddc98fe6483c3ecddcb687eb2d30d37","link_m3u8":"https://vip.opstream90.com/20260306/26563_8ddc98fe/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream90.com/share/df343f6b84a0ed60c40db9e2cede73c1","link_m3u8":"https://vip.opstream90.com/20260313/27032_df343f6b/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream90.com/share/41890b3543c53ed353b9febcf47a2cc0","link_m3u8":"https://vip.opstream90.com/20260319/27572_41890b35/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream90.com/share/79aadfd37377569522c12e25d973b68e","link_m3u8":"https://vip.opstream90.com/20260326/28044_79aadfd3/index.m3u8"}]}],"description":"<p>Giữa thế giới quý tộc đầy dối trá và tham vọng, gia tộc Grail là ngoại lệ hiếm hoi khi luôn tôn thờ sự thật và liêm chính, và Constance Grail cũng lớn lên với niềm tin ấy. Nhưng lý tưởng của cô sụp đổ khi bị vị hôn phu phản bội và vu oan, còn \"công lý\" thì hoàn toàn ngoảnh mặt làm ngơ. Trong khoảnh khắc tuyệt vọng, linh hồn của Scarlet Castiel - ác nữ khét tiếng từng bị xử tử - xuất hiện và nhập vào Constance để lật ngược tình thế. Scarlet bị kết tội ám sát công chúa mười năm trước, nhưng sự thật đằng sau đó là một âm mưu tinh vi nhằm hãm hại cô. Đổi lấy sự trợ giúp, Scarlet yêu cầu Constance cùng mình vạch trần sự thật và trả thù những kẻ đã đẩy cô vào cái chết oan nghiệt.</p>","tmdb_id":283891,"cast":["Kana Ichinose","Sayumi Suzushiro","Yohei Azakami","Mao Ichimichi","Maaya Uchida","Hanae Natsuki","Jun Fukuyama"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"283891","season":1,"vote_average":7.7,"vote_count":7},"ca