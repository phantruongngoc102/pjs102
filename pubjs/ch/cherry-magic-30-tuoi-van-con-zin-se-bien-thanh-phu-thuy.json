hiến anh không thích những nơi đông đúc.\n\nTrên đường đi làm, Adachi gặp đồng nghiệp xinh đẹp và được mọi người yêu mến, Yuuichi Kurosawa. Bị hấp dẫn bởi tính cách của Kurosawa, anh lén chạm vào Kurosawa và liếc nhìn vào tâm hồn anh ta, chỉ để phát hiện ra rằng người đàn ông này mang trong mình ước mơ lãng mạn với một đồng nghiệp ở văn phòng. Adachi cố gắng liên kết các thông tin, nhưng sớm thôi, ảo tưởng của Kurosawa được phơi bày - suy nghĩ không trong sạch của đồng nghiệp dành cho anh ta! Mặc dù cố gắng hết sức để tập trung, anh giờ đây gần như không thể tập trung khi có Kurosawa ở gần.","tmdb":{"type":"tv","id":"237045","season":30,"vote_average":7.717,"vote_count":23},"modified":"2024-03-28T00:12:01.000Z","cast":["Chiaki Kobayashi","Ryota Suzuki","Makoto Furukawa","Gen Sato"],"director":[],"cast_meta":[{"name":"Chiaki Kobayashi","name_vi":null,"name_original":"Chiaki Kobayashi","tmdb_id":2279389,"profile":"https://image.tmdb.org/t/p/w500/o0XZFXc50z28ICUpvfZ1QcTL2Yt.jpg","tmdb_url":"https://www.themoviedb.org/person/2279389"},{"name":"Ryota Suzuki","name_vi":null,"name_original":"Ryota Suzuki","tmdb_id":2138291,"profile":"https://image.tmdb.org/t/p/w500/4Xq18mQttuW2yfRCflnWoU7UqQ5.jpg","tmdb_url":"https://www.themoviedb.org/person/2138291"},{"name":"Makoto Furukawa","name_vi":null,"name_original":"Makoto Furukawa","tmdb_id":1319218,"profile":"https://image.tmdb.org/t/p/w500/inLmBZhrqXeE9wlViyK28ocKJSw.jpg","tmdb_url":"https://www.themoviedb.org/person/1319218"},{"name":"Gen Sato","name_vi":null,"name_original":"Gen Sato","tmdb_id":2410694,"profile":"https://image.tmdb.org/t/p/w500/gdKxR84xGgU19eqWlPKEGZsiID6.jpg","tmdb_url":"https://www.themoviedb.org/person/2410694"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/cherry-magic-30-tuoi-van-con-zin-se-bien-thanh-phu-thuy.json"}