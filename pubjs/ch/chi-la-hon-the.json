c1b6","link_m3u8":"https://vip.opstream13.com/20251011/11849_2fa8af07/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/971436431aef6875a9b7997990809a5f","link_m3u8":"https://vip.opstream13.com/20251011/11850_97143643/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/b1b3cc561955829adb6f980b2c3eb885","link_m3u8":"https://vip.opstream13.com/20251011/11851_b1b3cc56/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream13.com/share/ba67e777107290283dcc9adaed9459e1","link_m3u8":"https://vip.opstream13.com/20251011/11852_ba67e777/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream13.com/share/bf38bc61db12651d4c95b9dd9f4691ae","link_m3u8":"https://vip.opstream13.com/20251011/11853_bf38bc61/index.m3u8"}]}],"description":"<p>Ông nội của Sử Vũ định gài Tô Vũ cùng với Gu Mãn, hy vọng hai người trẻ sẽ yêu nhau. Nhưng Su Yu nói với Gu Manman rằng ông chỉ mong muốn theo đuổi tình yêu đích thực và không thể chấp nhận một cuộc hôn nhân mà không có tình yêu. Sau khi nghe tin này, Gu Manman bỏ đi mà không nói một lời nào. Sáu tháng sau khi Gu Manman ra đi, ông nội của Su Yu bất ngờ bị bệnh nặng và ông đã đưa ra một yêu cầu cuối cùng với cháu trai của mình: tìm hiểu Su Manman ở đâu càng sớm càng tốt. Trong một lần gặp gỡ cơ hội, Su Yu gặp Kiều Mai, một cô gái làm việc trong một cửa hàng tiện lợi trông y hệt Gu Manman. Bằng cách nào đó ông nội của Sử Vũ đã nhầm Kiều Mai với Gu Manman. Kết quả là Sử Vũ yêu cầu Kiều Mai làm cho ông một ân huệ: mmeethis ông nội và perspersuade để được điều trị y tế. Và do đó bắt đầu một câu chuyện về sự lãng mạn giả dối.</p>","tmdb_id":197895,"cast":["Lin Ke Han","Lu Yuan"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"197895","season":1,"vote_average":6.5,"vote_count":2},"cast_meta":[{"name":"Lin Ke Han","name_vi":null,"name_original":"Lin Ke Han","tmdb_id":3947991,"profile":"https://image.tmdb.org/t/p/w500/mxeuPkZxGgfRikZqAtqP88WPmSQ.jpg