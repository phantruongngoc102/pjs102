{"id":"68de83d754722ad3b855a39d","title":"Chị Ngã Em Nâng","origin_name":"Lift Me Up","slug":"chi-nga-em-nang","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ch/chi-nga-em-nang.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ch/chi-nga-em-nang.webp","year":"2025","type":"single","genre":[{"name":"Hài Hước","slug":"hai-huoc"},{"name":"Gia Đình","slug":"gia-dinh"},{"name":"Chính kịch","slug":"chinh-kich"}],"country":[{"name":"Việt Nam","slug":"viet-nam"}],"lang_key":"Vietsub","episode_current":"Trailer","quality":"HD","modified":"2025-10-02T20:53:29.000Z","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[],"description":"Chị Ngã Em Nâng là câu chuyện cảm động xoay quanh hai chị em Thương và Lực – lớn lên trong một gia đình gắn bó với nghề làm nhang truyền thống. Biến cố xảy ra từ sớm khiến Thương trở thành chỗ dựa duy nhất cho em trai, vừa làm chị, vừa gánh vai trò của cha mẹ. Lớn lên trong điều kiện không đủ đầy, nhưng với bản lĩnh cùng những lời dạy ăn sâu vào tâm thức mà cha mẹ dành cho Thương, cô đã kiên trì đầy nghị lực để quyết tâm thay đổi cuộc sống. Thương thành công và kỳ vọng em trai đi theo con đường mình đã lựa chọn. Tuy nhiên, sự áp đặt vô tình tạo nên rạn nứt, đẩy hai chị em vào những mâu thuẫn sâu sắc – thậm chí đến mức đối mặt sinh tử.","tmdb_id":1554020,"cast":["Lê Khánh","Thuận Nguyễn","Quốc Trường","Uyển Ân","Hoài Linh","Đinh Y Nhung","Thanh Thức","Ngô Phạm Hạnh Thúy","Tạ Lâm","Linh Barbie","Phương Lan","Như Vân","Lâm Bảo Châu"],"director":["NSƯT Vũ Thành Vinh"],"keywords":[],"tmdb":{"type":"movie","id":"1554020","season":null,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lê Khánh","name_vi":"Lê Khánh","name_original":"Lê Khánh","tmdb_id":1601903,"profile":"https://image.tmdb.org/t/p/w500/fR3E6MpOKDP9b6sOPltYyqFv58H.jpg","tmdb_url":"https://www.themoviedb.org/person/1601903"},{"name":"Thuận Nguyễn","name_vi