tream90.com/share/4466f2c1e7eed04c491b8620b142ff72","link_m3u8":"https://vip.opstream90.com/20260304/26457_4466f2c1/index.m3u8"},{"name":"96","slug":"96","link_embed":"https://vip.opstream90.com/share/f82b2a73a3f905eb4679a24495a79ee3","link_m3u8":"https://vip.opstream90.com/20260304/26458_f82b2a73/index.m3u8"}]}],"description":"<p>Gặp gỡ Maruko, một nữ sinh ngọt ngào với tính tò mò cao độ (và đôi khi cũng hơi lười biếng!). Cô bé sống cuộc sống êm đềm ở một thị trấn ấm cúng bên cạnh bố mẹ, ông bà và em gái yêu thương của mình. Maruko có một nhóm bạn trung thành, trong đó có người bạn thân nhất, Tama-chan, nhưng người ông vui tính và yêu thương hết mực của cô bé mới là trung tâm của tất cả. Cuộc sống không bao giờ nhàm chán trong loạt phim đáng yêu này.</p>","tmdb_id":57775,"cast":["TARAKO","Yusaku Yara","Teiyu Ichiryusai","Yuko Mizutani","Yuko Sasaki","Takeshi Aono","Naoko Watanabe","Masami Kikuchi","Nobuo Tobita","Keiko Yamamoto","Megumi Urawa","Ai Orikasa","Miki Narahashi","Chafurin","Keaton Yamada"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"57775","season":1,"vote_average":7.9,"vote_count":22},"cast_meta":[{"name":"TARAKO","name_vi":null,"name_original":"TARAKO","tmdb_id":100127,"profile":"https://image.tmdb.org/t/p/w500/dIju4JSkZem6Yaep5RYLWfTmp1P.jpg","tmdb_url":"https://www.themoviedb.org/person/100127"},{"name":"Yusaku Yara","name_vi":null,"name_original":"Yusaku Yara","tmdb_id":547982,"profile":"https://image.tmdb.org/t/p/w500/73cpMM1uWJiiZ1u4BymUQmTb22j.jpg","tmdb_url":"https://www.themoviedb.org/person/547982"},{"name":"Teiyu Ichiryusai","name_vi":null,"name_original":"Teiyu Ichiryusai","tmdb_id":85289,"profile":"https://image.tmdb.org/t/p/w500/23NrErvp0tFXWJxKMumfDKhR0Ms.jpg","tmdb_url":"https://www.themoviedb.org/person/85289"},{"name":"Yuko Mizutani","name_vi":null,"name_original":"Yuko Mizutani","tmdb_id":112138,"profile":"https://image.tmdb.org/t/p/w500/wjuj1u5aqjHEGqDo6FMScwWFKqP.jpg","tmdb_url":"https://www.themoviedb.org/person/112138"},