{"id":"64827fc40fba73ffd2e9e3a8","title":"Chiến Binh Lồng Đèn Xanh: Hiệp Sĩ Ngọc Bích","origin_name":"Green Lantern: Emerald Knights","slug":"chien-binh-long-den-xanh-hiep-si-ngoc-bich","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/ch/chien-binh-long-den-xanh-hiep-si-ngoc-bich.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/ch/chien-binh-long-den-xanh-hiep-si-ngoc-bich.webp","year":"2011","type":"hoathinh","genre":[{"name":"Hành Động","slug":"hanh-dong"},{"name":"Viễn Tưởng","slug":"vien-tuong"},{"name":"Phiêu Lưu","slug":"phieu-luu"},{"name":"Chính kịch","slug":"chinh-kich"}],"country":[{"name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","modified":"2023-06-09T08:26:30.000Z","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"name":"Vietsub #1","slug":"vietsub-1","server_name":"Vietsub #1","server_data":[{"name":"1","slug":"1","link_embed":"https://vip.opstream14.com/share/362e9af44622f13487a36597032bc546","link_m3u8":"https://vip.opstream14.com/20230609/37408_881f747a/index.m3u8"}]}],"description":"Green Lantern: Emerald Knights trong vũ trụ mênh mông mang theo những điều huyền bí to lớn có một lực lượng tuy nhỏ nhưng rất hùng mạnh đã tồn tại qua hàng thế kỉ. Là những người bảo vệ hòa bình và công lý, họ được gọi là quân đoàn Green Lantern. Những chiến binh Green Lantern đã thề rằng phải giữ được trật tự và bình yên trong dải ngân hà này, nên mỗi người đeo một chiếc nhẫn chứa đựng siêu quyền năng. Nhưng khi Parallax, kẻ thù mới của họ, đe dọa sẽ phá hủy sự cân bằng quyền năng trong vũ trụ, định mệnh của họ và số phận của Trái đất nằm trong tay thành viên mới nhất của quân đoàn, con người đầu tiên được lựa chọn: Hal Jordan. Hal mặc dù là một viên phi công tự phụ nhưng anh thực sự có tài năng, nhưng quân đoàn Green Lantern có rất ít sự tôn trọng đối với loài người, những người chưa bao giờ được chiếc nhẫn quyền năng ban cho sức mạnh vô biên.","tmdb_id":65291,"cast":["Jenna Ortega","Isaak Presley","Ariana Greenblatt","Kayla Maisonet","Nicolas Bechtel","Malachi Barton","Joe Nieves","Cerina Vincent"],"director":["Jay Oliva","Lauren Montgomery","Christopher Berkeley"],"keywords":[],"tmdb":{"type":"movie","id":"65291","season":null,"vote_average":6.647,"vote_count":534},"cast_meta":[{"name":"Jenna Ortega","name_vi":null,"name_original":"Jenna Ortega","tmdb_id":974169,"profile":"https://image.tmdb.org/t/p/w500/cV4x7jNmsGLdKZn5I6xVF3Ltnmg.jpg","tmdb_url":"https://www.themoviedb.org/person/974169"},{"name":"Isaak Presley","name_vi":null,"name_original":"Isaak Presley","tmdb_id":1567591,"profile":"https://image.tmdb.org/t/p/w500/2xobBdhlKEgCiFxuxcdz5Fgp7hM.jpg","tmdb_url":"https://www.themoviedb.org/person/1567591"},{"name":"Ariana Greenblatt","name_vi":null,"name_original":"Ariana Greenblatt","tmdb_id":1767250,"profile":"https://image.tmdb.org/t/p/w500/kTUuyjwc0sSiOGQkNhbmpmqMt5a.jpg","tmdb_url":"https://www.themoviedb.org/person/1767250"},{"name":"Kayla Maisonet","name_vi":null,"name_original":"Kayla Maisonet","tmdb_id":1767252,"profile":"https://image.tmdb.org/t/p/w500/6E1trYDMjFeLLYozBVqXLxnD27C.jpg","tmdb_url":"https://www.themoviedb.org/person/1767252"},{"name":"Nicolas Bechtel","name_vi":null,"name_original":"Nicolas Bechtel","tmdb_id":1440058,"profile":"https://image.tmdb.org/t/p/w500/5s5liiNXUCyPeMRxPdc97XtrbAP.jpg","tmdb_url":"https://www.themoviedb.org/person/1440058"},{"name":"Malachi Barton","name_vi":null,"name_original":"Malachi Barton","tmdb_id":1836114,"profile":"https://image.tmdb.org/t/p/w500/lmV6ParCZkniV1OQO71xxfjFjaG.jpg","tmdb_url":"https://www.themoviedb.org/person/1836114"},{"name":"Joe Nieves","name_vi":null,"name_original":"Joe Nieves","tmdb_id":1222174,"profile":"https://image.tmdb.org/t/p/w500/nlMyiX4EPLdjjc1IZyiIr7cRtKv.jpg","tmdb_url":"https://www.themoviedb.org/person/1222174"},{"name":"Cerina Vincent","name_vi":nu