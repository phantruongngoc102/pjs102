ùng...</p>","tmdb":{"type":"movie","id":"9349","season":null,"vote_average":6.333,"vote_count":1807},"modified":"2023-04-16T19:58:06.000Z","cast":["Jean-Claude Van Damme","Dolph Lundgren","Ally Walker","Ed O'Ross","Ralf Moeller","Jerry Orbach","Leon Rippy","Tico Wells","Robert Trebor","Tommy Lister Jr.","Simon Rhee","Rance Howard","Lilyan Chauvin","Thomas Rosales Jr.","Ned Bellamy"],"director":["Roland Emmerich"],"cast_meta":[{"name":"Jean-Claude Van Damme","name_vi":null,"name_original":"Jean-Claude Van Damme","tmdb_id":15111,"profile":"https://image.tmdb.org/t/p/w500/7DP3bm3MS0qa0L8tBLHGebbCu6H.jpg","tmdb_url":"https://www.themoviedb.org/person/15111"},{"name":"Dolph Lundgren","name_vi":null,"name_original":"Dolph Lundgren","tmdb_id":16644,"profile":"https://image.tmdb.org/t/p/w500/fB1tOws6Gav0xE8LYlELEb82hJt.jpg","tmdb_url":"https://www.themoviedb.org/person/16644"},{"name":"Ally Walker","name_vi":null,"name_original":"Ally Walker","tmdb_id":18316,"profile":"https://image.tmdb.org/t/p/w500/kuR6HUF1D0Xk5o5nShgWDBMV2gx.jpg","tmdb_url":"https://www.themoviedb.org/person/18316"},{"name":"Ed O'Ross","name_vi":null,"name_original":"Ed O'Ross","tmdb_id":8658,"profile":"https://image.tmdb.org/t/p/w500/6hzovUAs5hFcrZvPdk84NR3KcHU.jpg","tmdb_url":"https://www.themoviedb.org/person/8658"},{"name":"Ralf Moeller","name_vi":null,"name_original":"Ralf Moeller","tmdb_id":942,"profile":"https://image.tmdb.org/t/p/w500/lfx7pAL0einahCePvn10SmMCfoU.jpg","tmdb_url":"https://www.themoviedb.org/person/942"},{"name":"Jerry Orbach","name_vi":null,"name_original":"Jerry Orbach","tmdb_id":725,"profile":"https://image.tmdb.org/t/p/w500/36Bsh8VKClXn6diVnEbDLgniBF4.jpg","tmdb_url":"https://www.themoviedb.org/person/725"},{"name":"Leon Rippy","name_vi":null,"name_original":"Leon Rippy","tmdb_id":15374,"profile":"https://image.tmdb.org/t/p/w500/jJfrzZ5BlJoWyU8JHbdnPxyGGf8.jpg","tmdb_url":"https://www.themoviedb.org/person/15374"},{"name":"Tico Wells","name_vi":null,"name_original":"Tico Wells",