ream10.com/20220502/11299_55354480/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream10.com/share/8c460674cd61bf189e62b4da4bd9d7c1","link_m3u8":"https://vip.opstream10.com/20220502/11308_4df3ad18/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream10.com/share/263138a8b987787df892aaafe081a2d6","link_m3u8":"https://vip.opstream10.com/20220502/11309_c82eabed/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream10.com/share/435d43e52666cd74203c69c2bfe2caa7","link_m3u8":"https://vip.opstream10.com/20220502/11310_c8661c11/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream10.com/share/1a47e38c424a51aba827f45d77a438b1","link_m3u8":"https://vip.opstream10.com/20220502/11314_deacc56c/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream10.com/share/92c3d054835eff3d5a7f7ed731d2a3db","link_m3u8":"https://vip.opstream10.com/20220502/11315_ab4108de/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream10.com/share/d9aa7942219d9b762ba1b832214e5a7a","link_m3u8":"https://vip.opstream10.com/20220502/11319_163e6b15/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream10.com/share/684fa3de91be141a2bc896fa5870aed7","link_m3u8":"https://vip.opstream10.com/20220502/11318_b01b1678/index.m3u8"},{"name":"47","slug":"47","link_embed":"https://vip.opstream10.com/share/813b6a28cc4ac72d244266161e3e2eb4","link_m3u8":"https://vip.opstream10.com/20220502/11320_f6a6855b/index.m3u8"},{"name":"48","slug":"48","link_embed":"https://vip.opstream10.com/share/fe09f091f5c661afdf1f5069a4136735","link_m3u8":"https://vip.opstream10.com/20220502/11321_e1dfd1f0/index.m3u8"}]}],"description":"<p>Loạt phim Super Sentai (siêu chiến đội) thứ 4 về loài khủng long. Tương truyền 65 triệu năm về trước, Druidon - bộ tộc sở hữu sức mạnh cực lớn thống trị trái đất, đã rời khỏi địa cầu sau khi thiên thạch tiêu diệt loài khủng long. Bộ lạc Ryusoul đã quyết định ở lại trái đất, họ truyền lại sức mạnh vào những thanh kiếm chiến đấu. Năm vị Kỵ Sĩ Long được chọn tự phong ấn bản thân vào các thần điện nằm rải rác trên thế giới. Thời gian trôi qua, tộc Druidon xấu xa muốn lần nữa trở về đe dọa an nguy của Trái Đất. Các Kỵ Sĩ Long Ryusoulger năm xưa linh cảm được nguy hiểm nên đã tự giải ấn, lần lượt thức tỉnh. Năm thanh kiếm phụng sự chính nghĩa được nắm giữa bởi các Kỵ Sĩ Long, lần nữa đồng lòng cùng nhau diệt trừ thế lực xấu xa bảo vệ hòa bình trái đất.</p>","tmdb_id":120409,"cast":["Hayate Ichinose","Keito Tsuna","Ichika Osaki","Yuito Obara","Tatsuya Kishida","Katsumi Hyodo","Mana Kinjou","Sora Tamaki","Mitsuru Fukikoshi","Masaki Terasoma","Ryota Takeuchi","Jouji Nakata","Ryoko Shiraishi","Hikaru Midorikawa","Tetsu Inada"],"director":["Kamihoriuchi Kazuya"],"keywords":[],"tmdb":{"type":"tv","id":"120409","season":1,"vote_average":8.1,"vote_count":10},"cast_meta":[{"name":"Hayate Ichinose","name_vi":null,"name_original":"Hayate Ichinose","tmdb_id":2238821,"profile":"https://image.tmdb.org/t/p/w500/bbwWWZ8M67GP6prcjilZCum7xCM.jpg","tmdb_url":"https://www.themoviedb.org/person/2238821"},{"name":"Keito Tsuna","name_vi":null,"name_original":"Keito Tsuna","tmdb_id":2238822,"profile":"https://image.tmdb.org/t/p/w500/6pdirixI897dHILW6BiUqks8wSd.jpg","tmdb_url":"https://www.themoviedb.org/person/2238822"},{"name":"Ichika Osaki","name_vi":null,"name_original":"Ichika Osaki","tmdb_id":2189469,"profile":"https://image.tmdb.org/t/p/w500/2yPqsjF4ns9A5dx3oxdhDvmuBf6.jpg","tmdb_url":"https://www.themoviedb.org/person/2189469"},{"name":"Yuito Obara","name_vi":null,"name_original":"Yuito Obara","tmdb_id":2238824,"profile":"https://image.tmdb.org/t/p/w500/fS6sNwzf9Q9kdtemjQDYZTZoy8I.jpg","tmdb_url":"https://www.themoviedb.org/person/2238824"},{"name":"Tatsuya Kishida","name_vi":null,"name_original":"Tatsuya Kishida","tmdb_id":1718002,"profile":"https://image.tmdb.org/t/p/w500/rSKwoDKB5L01TeK2YG1FbsKHx3b.jpg","tmdb_url":"https://www.themoviedb.org/person/1718002"},{"nam