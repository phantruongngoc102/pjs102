ện ra rằng virus đã “nhảy qua các vương quốc” và hiện đang lây nhiễm các loại cây lương thực trên thế giới, đưa nhân loại đến bờ vực của nạn đói toàn cầu. Khi con tàu đi qua Địa Trung Hải để tìm kiếm một giải pháp có thể tiết kiệm nguồn cung lương thực của thế giới, Chandler chạm trán với kẻ thù của chính mình ở Hy Lạp. “Cuộc hành trình của anh hùng” của anh ấy trở thành một câu chuyện kể lại về Odyssey của Homer thời hiện đại.</p>","tmdb":{"type":"tv","id":"60802","season":4,"vote_average":6.84,"vote_count":990},"modified":"2023-04-29T08:39:17.000Z","cast":["Eric Dane","Adam Baldwin","Charles Parnell","Travis Van Winkle","Marissa Neitling","Christina Elmore","Jocko Sims","Kevin Michael Martin","Bridget Regan","Bren Foster","Jodie Turner-Smith","Emerson Brooks"],"director":[],"cast_meta":[{"name":"Eric Dane","name_vi":null,"name_original":"Eric Dane","tmdb_id":58115,"profile":"https://image.tmdb.org/t/p/w500/4PsLKBKN4e0zRT2oS4BjE8Xu1un.jpg","tmdb_url":"https://www.themoviedb.org/person/58115"},{"name":"Adam Baldwin","name_vi":null,"name_original":"Adam Baldwin","tmdb_id":2059,"profile":"https://image.tmdb.org/t/p/w500/lfbyJWNWGbiYfU0Yr1tjn6Trd2V.jpg","tmdb_url":"https://www.themoviedb.org/person/2059"},{"name":"Charles Parnell","name_vi":null,"name_original":"Charles Parnell","tmdb_id":124112,"profile":"https://image.tmdb.org/t/p/w500/wLywO5xtR97YKtkYb57hXEFpL7j.jpg","tmdb_url":"https://www.themoviedb.org/person/124112"},{"name":"Travis Van Winkle","name_vi":null,"name_original":"Travis Van Winkle","tmdb_id":74290,"profile":"https://image.tmdb.org/t/p/w500/t1hkmekr1WcaNq9C0Ou0Lf3rSZy.jpg","tmdb_url":"https://www.themoviedb.org/person/74290"},{"name":"Marissa Neitling","name_vi":null,"name_original":"Marissa Neitling","tmdb_id":1295289,"profile":"https://image.tmdb.org/t/p/w500/y0Cgv9pvF40j85roTcZ4E6UpYnz.jpg","tmdb_url":"https://www.themoviedb.org/person/1295289"},{"name":"Christina Elmore","name_vi":null,"name_original":"Christina Elmore","tmdb_id":1295290,"profile