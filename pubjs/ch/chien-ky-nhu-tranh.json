7d7703b","link_m3u8":"https://vip.opstream90.com/20260403/28704_89bdedf8/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/82bdd6d74c304d5130239833c88d2f18","link_m3u8":"https://vip.opstream90.com/20260403/28705_82bdd6d7/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream90.com/share/382c43c484ddee6d1c699d2fd5980d32","link_m3u8":"https://vip.opstream90.com/20260403/28706_382c43c4/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream90.com/share/a401bed218424c069af5121745e2c46f","link_m3u8":"https://vip.opstream90.com/20260403/28707_a401bed2/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream90.com/share/94397fe878869449f866b64722a0b7c9","link_m3u8":"https://vip.opstream90.com/20260403/28708_94397fe8/index.m3u8"}]}],"description":"<p>Năm 1950, Ngụy Chính Hoa mạo danh Trịnh Hùng Tài tham gia chiến trường Triều Tiên. Dù liên tiếp lập được nhiều chiến công, anh phải trải qua muôn vàn thử thách sinh tử, đau đớn chứng kiến cảnh anh em ly tán, người thân và bạn bè lần lượt ngã xuống. Anh cùng các chiến hữu đã vào sinh ra tử, chiến đấu đẫm máu để đập tan các âm mưu cũng như cuộc chiến tranh vi khuẩn của quân Mỹ, và cuối cùng giành được thắng lợi trong trận quyết chiến. Năm 1953, hiệp định đình chiến được ký kết. 70 năm sau, người lính Ngụy Chính Hoa nay đã mái đầu bạc trắng, một lần nữa dang rộng lá cờ năm xưa để tưởng nhớ anh linh những đồng đội đã khuất và tri ân hòa bình.</p>","tmdb_id":317895,"cast":["Zhang Tong","Su Qing","Mã Tô","Liu Tianzuo"],"director":[],"keywords":[],"time":"45 phút/tập","tmdb":{"type":"tv","id":"317895","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Zhang Tong","name_vi":null,"name_original":"Zhang Tong","tmdb_id":2779011,"profile":"https://image.tmdb.org/t/p/w500/gr8XbaufNjXqO1oygxMECvAgjDI.jpg","tmdb_url":"https://www.themoviedb.org/person/2779011"},{"name":"Su Qing","name_vi":null,"name_original":"Su Qing","tmdb_id":2250335,"profi