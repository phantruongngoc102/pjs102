{"id":"62481f0dc78eb57bbfe3b3e8","title":"Chiến Thắng Biển Sâu","origin_name":"The Deep","slug":"chien-thang-bien-sau","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/ch/chien-thang-bien-sau.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/ch/chien-thang-bien-sau.webp","year":2012,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"chien-thang-bien-sau-the-deep","link_embed":"https://vip.opstream15.com/share/9407c826d8e3c07ad37cb2d13d1cb641","link_m3u8":"https://vip.opstream15.com/20220402/2525_de284cec/index.m3u8"}]}],"time":"95 phút","description":"<p>Một ngư dân tên Gulli đã sống sót sau một vụ chìm tàu và phải tìm cách quay lại đất liền. Trong khi hầu hết mọi người không thể cầm cự được lâu, Gulli đã tìm cách xoay xở trên biển Bắc Đại Tây Dương trong sáu tiếng và đi bộ trên những hòn đá nhọn thêm hai tiếng nữa. Ông nói chuyện với lũ mòng biển và bắt đầu nhớ lại về cuộc đời mình, cũng như những nghĩ về những gì ông sẽ làm khi ông sống sót. Đây là một bộ phim về sự bền bỉ và dũng cảm, được thể hiện qua cuộc đấu tranh sinh tồn của Gulli trên biển và cuộc sống của ông sau khi trở về đất liền.</p>","tmdb":{"type":"movie","id":"127913","season":null,"vote_average":6.3,"vote_count":124},"modified":"2023-09-13T10:16:55.000Z","cast":["Ólafur Darri Ólafsson","Joi Johannsson","Þorbjörg Helga Þorgilsdóttir","Theodór Júlíusson","María Sigurðardóttir","Björn Thors","Stefán Hallur Stefánsson","Þröstur Leó Gunnarsson","Guðjón Pedersen"],"director":["Baltasar Kormákur"],"cast_meta":[{"name":"Ólafur Darri Ólaf