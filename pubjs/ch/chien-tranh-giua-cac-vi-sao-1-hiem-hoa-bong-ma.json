ực sự cô ấy nói cô ấy là ai? Và những gì đặc biệt về cậu bé này?</p>","tmdb_id":1893,"cast":["Liam Neeson","Ewan McGregor","Natalie Portman","Jake Lloyd","Ian McDiarmid","Pernilla August","Oliver Ford Davies","Hugh Quarshie","Ahmed Best","Anthony Daniels","Kenny Baker","Frank Oz","Terence Stamp","Brian Blessed","Andy Secombe"],"director":["George Lucas"],"keywords":["galaxy","senate","taskmaster","prophecy","queen","apprentice","taxes","prequel","space opera","tuwaderalit"],"tmdb":{"type":"movie","id":"1893","season":null,"vote_average":6.569,"vote_count":15520},"cast_meta":[{"name":"Liam Neeson","name_vi":null,"name_original":"Liam Neeson","tmdb_id":3896,"profile":"https://image.tmdb.org/t/p/w500/g0iIEyt9ILiKTG0g8K69US5VtLy.jpg","tmdb_url":"https://www.themoviedb.org/person/3896"},{"name":"Ewan McGregor","name_vi":null,"name_original":"Ewan McGregor","tmdb_id":3061,"profile":"https://image.tmdb.org/t/p/w500/q2UDxfwWnmXTB7khOUF3J9puBVP.jpg","tmdb_url":"https://www.themoviedb.org/person/3061"},{"name":"Natalie Portman","name_vi":null,"name_original":"Natalie Portman","tmdb_id":524,"profile":"https://image.tmdb.org/t/p/w500/edPU5HxncLWa1YkgRPNkSd68ONG.jpg","tmdb_url":"https://www.themoviedb.org/person/524"},{"name":"Jake Lloyd","name_vi":null,"name_original":"Jake Lloyd","tmdb_id":33196,"profile":"https://image.tmdb.org/t/p/w500/tp5PRiy8Ip8Vs70pUY1jeHbk2wH.jpg","tmdb_url":"https://www.themoviedb.org/person/33196"},{"name":"Ian McDiarmid","name_vi":null,"name_original":"Ian McDiarmid","tmdb_id":27762,"profile":"https://image.tmdb.org/t/p/w500/cqEAblt0KJRIGyMXhj5OM5WJ9SN.jpg","tmdb_url":"https://www.themoviedb.org/person/27762"},{"name":"Pernilla August","name_vi":null,"name_original":"Pernilla August","tmdb_id":33190,"profile":"https://image.tmdb.org/t/p/w500/zICu2ItUmKh0dUcWtee49KpNDMq.jpg","tmdb_url":"https://www.themoviedb.org/person/33190"},{"name":"Oliver Ford Davies","name_vi":null,"name_original":"Oliver Ford Davies","tmdb_id":31923,"profile":"https://image.tmdb