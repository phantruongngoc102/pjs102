ủa Jedi đưa anh vào sâu hơn những bí ẩn của Thần lực, nơi những gì anh phát hiện ra có thể thay đổi mãi mãi cán cân quyền lực trong thiên hà.</p>","tmdb_id":4194,"cast":["Ashley Eckstein","Matt Lanter","James Arnold Taylor","Dee Bradley Baker","Tom Kane"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"4194","season":6,"vote_average":8.5,"vote_count":2262},"cast_meta":[{"name":"Ashley Eckstein","name_vi":null,"name_original":"Ashley Eckstein","tmdb_id":41345,"profile":"https://image.tmdb.org/t/p/w500/jdzSL5AJePycTs1KQpYzm6I55qC.jpg","tmdb_url":"https://www.themoviedb.org/person/41345"},{"name":"Matt Lanter","name_vi":null,"name_original":"Matt Lanter","tmdb_id":34202,"profile":"https://image.tmdb.org/t/p/w500/2ms8DR9n4wh9ZU6lIuqsE58LPT9.jpg","tmdb_url":"https://www.themoviedb.org/person/34202"},{"name":"James Arnold Taylor","name_vi":null,"name_original":"James Arnold Taylor","tmdb_id":19506,"profile":"https://image.tmdb.org/t/p/w500/xP7SNjPMhZ2m4aVuYboPa8W1RlB.jpg","tmdb_url":"https://www.themoviedb.org/person/19506"},{"name":"Dee Bradley Baker","name_vi":null,"name_original":"Dee Bradley Baker","tmdb_id":23680,"profile":"https://image.tmdb.org/t/p/w500/9oFnToDZWp0I484s7Ua1EzNQQ2m.jpg","tmdb_url":"https://www.themoviedb.org/person/23680"},{"name":"Tom Kane","name_vi":null,"name_original":"Tom Kane","tmdb_id":71535,"profile":"https://image.tmdb.org/t/p/w500/sq49aVP56G50Nr5kCL7Ove6Z9jE.jpg","tmdb_url":"https://www.themoviedb.org/person/71535"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chien-tranh-giua-cac-vi-sao-cuoc-chien-vo-tinh-phan-6.json"}