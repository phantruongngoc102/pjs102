,"link_m3u8":"https://vip.opstream17.com/20240307/2041_5d970007/index.m3u8"},{"name":"03","slug":"03","link_embed":"https://vip.opstream17.com/share/4c144c47ecba6f8318128703ca9e2601","link_m3u8":"https://vip.opstream17.com/20240307/2040_58afe85e/index.m3u8"},{"name":"02","slug":"02","link_embed":"https://vip.opstream17.com/share/a48564053b3c7b54800246348c7fa4a0","link_m3u8":"https://vip.opstream17.com/20240307/2039_5f5ff816/index.m3u8"},{"name":"01","slug":"01","link_embed":"https://vip.opstream17.com/share/2557911c1bf75c2b643afb4ecbfc8ec2","link_m3u8":"https://vip.opstream17.com/20240307/2038_ffbfee53/index.m3u8"}]}],"description":"CHIẾN TRANH VIỆT NAM kể về câu chuyện sử thi về một trong những sự kiện gây chia rẽ và gây tranh cãi nhất trong lịch sử Hoa Kỳ vì nó chưa từng được kể trên phim. Loạt phim khám phá các khía cạnh con người của cuộc chiến thông qua lời khai mặc khải của gần 80 nhân chứng từ mọi phía — những người Mỹ đã chiến đấu trong cuộc chiến và những người khác phản đối nó, cũng như các chiến binh và dân thường từ miền Bắc và miền Nam Việt Nam. Mười năm thực hiện, loạt phim bao gồm các cảnh quay lưu trữ hiếm thấy và được làm chủ kỹ thuật số từ các nguồn trên toàn cầu, các bức ảnh được chụp bởi một số phóng viên ảnh nổi tiếng nhất của thế kỷ 20, các chương trình truyền hình lịch sử, phim gia đình đầy sức gợi và các bản ghi âm bí mật từ bên trong Kennedy, Johnson, và chính quyền Nixon. THE VIETNAM WAR có hơn 100 bản thu âm nhạc mang tính biểu tượng của các nghệ sĩ vĩ đại nhất thời đại và bản nhạc gốc đầy ám ảnh của Trent Reznor và Atticus Ross cũng như Silk Road Ensemble với Yo-Yo Ma.","tmdb_id":46434,"cast":["Peter Coyote"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"46434","season":1,"vote_average":8.232,"vote_count":207},"cast_meta":[{"name":"Peter Coyote","name_vi":null,"name_original":"Peter Coyote","tmdb_id":9979,"profile":"https://image.tmdb.org/t/p/w500/AglpxXP9wBM567UMGL9DAMbid1V.jpg","tmdb_url":"https://www.themoviedb.org/person/9979"