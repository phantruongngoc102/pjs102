0220425/12490_e69a175d/index.m3u8"},{"name":"53A","slug":"53a","link_embed":"https://vip.opstream12.com/share/1d0d0d9770e958dd76149a68e579d4f3","link_m3u8":"https://vip.opstream12.com/20220425/12491_ed29cb65/index.m3u8"},{"name":"53B","slug":"53b","link_embed":"https://vip.opstream12.com/share/c9772667ba6122896327f5856ff8224f","link_m3u8":"https://vip.opstream12.com/20220425/12492_f5aa8136/index.m3u8"},{"name":"54A","slug":"54a","link_embed":"https://vip.opstream12.com/share/5ba6a3726dd462084373f54a217a9162","link_m3u8":"https://vip.opstream12.com/20220425/12493_5f6e8e2b/index.m3u8"},{"name":"54B","slug":"54b","link_embed":"https://vip.opstream12.com/share/89f8f214774c7ec55bdbf7912c9ee04a","link_m3u8":"https://vip.opstream12.com/20220425/12494_d5f6b9e1/index.m3u8"},{"name":"55A","slug":"55a","link_embed":"https://vip.opstream12.com/share/631ceaa1abe4dcc8659f7477bbe1f4bf","link_m3u8":"https://vip.opstream12.com/20220425/12496_7dea20ef/index.m3u8"},{"name":"55B","slug":"55b","link_embed":"https://vip.opstream12.com/share/62d2979f157a3c2c0631a51982fd34f1","link_m3u8":"https://vip.opstream12.com/20220425/12495_fb30dbfd/index.m3u8"}]}],"description":"<p>Chiêu Diêu xoay quanh Nữ ma đầu Lộ Chiêu Diêu (Bạch Lộc) là môn chủ của Vạn Lộ Môn. Lúc sống nàng ta hoành hành ngang ngược khiến hai giới tiên ma vừa nghe tên đã khiếp sợ. Trong một lần xuống núi Chiêu Diêu cứu được tiểu tử Mặc Thanh (Hứa Khải). Trong lúc nàng sắp lấy được ma khí thượng cổ Kiếm Vạn Quân thì bị Mặc Thanh vô tình sát hại.Bản thân Chiêu Diêu lúc sống thì tự cao tự đại vang danh giang hồ, đến khi chết lại chết trong tay kẻ mình đã cứu trở thành một hồn ma nghèo kiết xác không ai ngó ngàng. Những năm đó cũng chỉ có mình Mặc Thanh đến thăm mộ nàng, còn mang cho nàng không ít hoa quả tươi. Nhưng trong lòng Chiêu Diêu vẫn mang mối hận sát thân do Mặc Thanh gây ra.Năm năm sau, tình cờ một người con gái tên Cầm Chỉ Yên (Tiêu Yến) - là đệ tử Tông Môn vô tình té ngã đập đầu vào mộ của Lộ Chiêu Diêu. Lộ Chiêu Diêu mượn thân xác Cẩm Chỉ Yên trọng sinh, nhưng trớ trêu nàng chỉ nhập được vào người Cầm Chỉ Yên buổi tối. Sau khi trọng sinh trở về, Lộ Chiêu Diêu phát hiện Mặc Thanh đã làm cho Vạn Lộ Môn càng ngày càng lớn mạnh hơn.Lộ Chiêu Diêu bèn dùng thân xác của Chỉ Yên che giấu thân phận, lợi dụng tình cảm của Mặc Thanh, một mặt báo thù hắn, mặt khác lại xúi giục hắn làm nhiều chuyện độc ác nguy hiểm đến tính mạng. Thế nhưng đối diện với tình cảm của Mặc Thanh, nàng dần dần dao động mục đích ban đầu.</p>","tmdb_id":86291,"cast":["Bạch Lộc","Hứa Khải","Dai Xu","Tiêu Yến","Mễ Lộ","Fu Jia","Liu Yuqiao","Yang Ze","Lý Tử Phong","Trương Hâm","Yin Yuhang","Ye Siwei"],"director":["Trịnh Vĩ Văn"],"keywords":[],"tmdb":{"type":"tv","id":"86291","season":1,"vote_average":8.3,"vote_count":18},"cast_meta":[{"name":"Bạch Lộc","name_vi":"Bạch Lộc","name_original":"Bai Lu","tmdb_id":1879666,"profile":"https://image.tmdb.org/t/p/w500/aRcUVDRO2wewQe0NXJ0RfzSgvUa.jpg","tmdb_url":"https://www.themoviedb.org/person/1879666"},{"name":"Hứa Khải","name_vi":"Hứa Khải","name_original":"Xu Kai","tmdb_id":2091759,"profile":"https://image.tmdb.org/t/p/w500/wEfatQWa3v9tNtmgr5LOOmFSSJj.jpg","tmdb_url":"https://www.themoviedb.org/person/2091759"},{"name":"Dai Xu","name_vi":null,"name_original":"Dai Xu","tmdb_id":1872331,"profile":"https://image.tmdb.org/t/p/w500/3tJyYJ71YJPYTaRQpg68ezLryhW.jpg","tmdb_url":"https://www.themoviedb.org/person/1872331"},{"name":"Tiêu Yến","name_vi":"Tiêu Yến","name_original":"Xiao Yan","tmdb_id":2229742,"profile":"https://image.tmdb.org/t/p/w500/h5PFW2h56ZVS8P0b61sU1mwGXSr.jpg","tmdb_url":"https://www.themoviedb.org/person/2229742"},{"name":"Mễ Lộ","name_vi":"Mễ Lộ","name_original":"Mi Lu","tmdb_id":1502598,"profile":"https://image.tmdb.org/t/p/w500/1poySBVmWclsxZFA1hbPfO4rBAf.jpg","tmdb_url":"https://www.themoviedb.org/person/1502598"},{"name":"Fu Jia","name_vi":null,"name_original":"Fu Jia","tmdb_id":3302918,"profile":"https://image.tmdb.org/t/p/w500/9VzIEZI4InFO7wBh5g0A5EryfzU.j