3b560f/index.m3u8"},{"name":"24","slug":"","filename":"Chiều Ngang Qua Phố Cũ S01E24","link_embed":"https://vip.opstream16.com/share/1c7e19555c747737c9064d29ea238f27","link_m3u8":"https://vip.opstream16.com/20231124/38027_00713810/index.m3u8"}]}],"time":"40 phút/tập","description":"<p><i>Chiều ngang qua phố cũ</i> xoay quanh câu chuyện về một đại gia đình <a href=\"https://vi.wikipedia.org/wiki/H%C3%A0_N%E1%BB%99i\">Hà Nội</a> gốc với bốn người con là: Hà (NSND Bùi Bài Bình), Thành (NSND Anh Tú), Thanh (Xuân Trường), Lịch (NSƯT Hoa Thúy). Khi cuộc sống của bốn gia đình với những nàng dâu, chàng rể êm đềm trôi qua trong quan hệ huyết thống bền chặt thì chỉ từ lời phán bởi một ông thầy phong thủy về mộ phần của dòng họ, những biến cố đã bắt đầu xảy đến. Trước thực tế cuộc sống khó khăn ấy khiến những người con buộc lòng phải rao bán căn nhà cổ do cha mẹ để lại. Trước số tài sản lớn, một cuộc chiến đòi quyền lợi bùng nổ, mối quan hệ vợ chồng, anh em cũng bị chia rẽ tưởng như không thể hàn gắn…</p>","tmdb":{"type":"tv","id":"252496","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-24T15:27:52.000Z","cast":["Bùi Bài Bình","Anh Tú","Xuân Trường","Hoa Thúy","Nguyễn Minh Trang","Hoàng Lan","Công Lý","Thanh Sơn","Trần Nghĩa","Đỗ Hà Anh","Huyền Thạch","Trần Vân","Hồng Minh","Vinh Kiên","Huyền Trang"],"director":["Trịnh Lê Phong"],"cast_meta":[{"name":"Bùi Bài Bình","name_vi":"Bùi Bài Bình","name_original":"Bùi Bài Bình","tmdb_id":1597793,"profile":"https://image.tmdb.org/t/p/w500/vTnTV0hKvBe8N8KGMRd7c2RjAnw.jpg","tmdb_url":"https://www.themoviedb.org/person/1597793"},{"name":"Anh Tú","name_vi":"Anh Tú","name_original":"Anh Tú","tmdb_id":4668781,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4668781"},{"name":"Xuân Trường","name_vi":"Xuân Trường","name_original":"Xuân Trường","tmdb_id":4609900,"profile":"https://image.tmdb.org/t/p/w500/yqYZ0V8mtQ9If4UxaGNTjsUBFHn.jpg","tmdb_url":"https://www.themoviedb.org/person/4609900"},{"name":"Hoa Thúy","name_