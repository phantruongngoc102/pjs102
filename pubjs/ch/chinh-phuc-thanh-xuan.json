re/96b8ee525c85be84c2536bd86564a585","link_m3u8":"https://vip.opstream15.com/20220524/16396_d1f6782e/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/5939cbe46f1512291125700ee2e7236a","link_m3u8":"https://vip.opstream15.com/20220524/16398_74d96be6/index.m3u8"}]}],"description":"<p>Chinh Phục Thanh Xuân nói về bộ môn nhảy cầu của trường Đại học Lộc Đảo đang đối mặt với nguy cơ giải tán. Sau đó Huấn luyện viên Vu Phong tìm được “viên ngọc quý” trong làng nhảy cầu là Giang Bạch Long, cậu du học sinh từng là vận động viên trong bộ môn nhảy cầu Wit, tuyển thủ mới vào nghề Lục Hạo Nhiên cùng với người bạn lâu năm của mình là Điền Lâm. Bốn chàng trai trẻ này sẽ đại diện cho trường Đại học Lộc Đảo để tham gia thi đấu.</p>","tmdb_id":94962,"cast":[],"director":[],"keywords":[],"tmdb":{"id":94962},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chinh-phuc-thanh-xuan.json"}