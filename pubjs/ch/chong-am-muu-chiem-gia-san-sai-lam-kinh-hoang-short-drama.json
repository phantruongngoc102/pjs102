 kẻ bạc tình và người phụ nữ thâm độc, đồng thời sử dụng trí tuệ để tạo liên minh mạnh mẽ khiến những kẻ phản diện mất tất cả.","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-08T10:20:09.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ch/chong-am-muu-chiem-gia-san-sai-lam-kinh-hoang-short-drama.json","keywords":[],"tmdb_checked":false}