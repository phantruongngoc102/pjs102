{"id":"649bc46f9f4442ce4d29f3a5","title":"Chốt Kiểm Soát","origin_name":"Check Point","slug":"chot-kiem-soat","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ch/chot-kiem-soat.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ch/chot-kiem-soat.webp","year":2017,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2253e0fc277084dfd339","name":"Chiến Tranh","slug":"chien-tranh"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Check Point - Chốt Kiểm Soát - 2017","link_embed":"https://vip.opstream14.com/share/72b594d9fc6ee0533fd902bc31096851","link_m3u8":"https://vip.opstream14.com/20230627/38280_568d0df5/index.m3u8"}]}],"time":"97 Phút","description":"Port City North Carolina: Trong một buổi cắm trại thường lệ, một người lang thang địa phương phát hiện ra kế hoạch xâm lược nước Mỹ. Khi anh ta cố gắng thông báo cho Cảnh sát trưởng địa phương về phát hiện của mình, Cảnh sát trưởng bác bỏ yêu cầu của anh ta và nhốt anh ta vì tội lảng vảng. Khi Cảnh sát trưởng nhận thấy những tương tác kỳ lạ với người dân ở các thị trấn khác, anh ta bắt đầu xem xét yêu sách của những người lang thang về một phòng giam ngủ giữa những người dân địa phương trong thị trấn nhỏ này. Sau khi bằng chứng về một vụ chặt đầu được phơi bày, những người khác bắt đầu lo sợ rằng quân nổi dậy sẽ tấn công quê hương Hoa Kỳ. Các câu hỏi và tâm trạng bắt đầu tăng lên. Tại sao cộng đồng bãi biển nhỏ này với lối sống của Norman Rockwell? Một thị trấn nơi mọi người đều biết nhau... hoặc họ nghĩ vậy. Khi sự thật mù mịt và công lý dường như đã mất, Nó sẽ đưa một đội quân gồm năm anh hùng không có khả năng hợp tác với nhau để thâm nhập vào quân nổi dậy và phá vỡ kế hoạch xâm lược của chúng.","tmdb":{"type":"movie","id":"442094","season":null,"vote_average":6.1,"vote_count":63},"modified":"2023-06-28T12:26:09.000Z","cast":["William Forsythe","Kenny Johnson","Kane Hodder","Mindy Robinson","Tyler Mane","Bill Goldberg","Fred Williamson","Michelle Lee","Stephen Geoffreys","Ricky Harris","John Lewis","Krista Grotte Saxon","Mel Novak","Olga Safari","David Schifter"],"director":["Thomas J. Churchill"],"cast_meta":[{"name":"William Forsythe","name_vi":null,"name_original":"William Forsythe","tmdb_id":4520,"profile":"https://image.tmdb.org/t/p/w500/35BXHugSG931iVPbHn6W9SNXNY1.jpg","tmdb_url":"https://www.themoviedb.org/person/4520"},{"name":"Kenny Johnson","name_vi":null,"name_original":"Kenny Johnson","tmdb_id":42191,"profile":"https://image.tmdb.org/t/p/w500/oFjEvGUEync0f2uiyGxMbinQkEl.jpg","tmdb_url":"https://www.themoviedb.org/person/42191"},{"name":"Kane Hodder","name_vi":null,"name_original":"Kane Hodder","tmdb_id":62596,"profile":"https://image.tmdb.org/t/p/w500/avMGd9rA2ys1pJok1EGOa46MEQX.jpg","tmdb_url":"https://www.themoviedb.org/person/62596"},{"name":"Mindy Robinson","name_vi":null,"name_original":"Mindy Robinson","tmdb_id":1072882,"profile":"https://image.tmdb.org/t/p/w500/wRStB9kFS531TAtjP3UoR8ODd9S.jpg","tmdb_url":"https://www.themoviedb.org/person/1072882"},{"name":"Tyler Mane","name_vi":null,"name_original":"Tyler Mane","tmdb_id":9832,"profile":"https://image.tmdb.org/t/p/w500/3M8oXR5bBsnOJX29SGrQ1vx9L7R.jpg","tmdb_url":"https://www.themoviedb.org/person/9832"},{"name":"Bill Goldberg","name_vi":null,"name_original":"Bill Goldberg","tmdb_id":65236,"profile":"https://image.tmdb.org/t/p/w500/cymPEmQ8WwAqHPwGFBJjpHN0Sck.jpg","tmdb_url":"https://www.themoviedb.org/person/65236"},{"name":"Fred Williamson","name_vi":null,"name_original":"Fred Williamson","tmdb_id":9811,"profile":"https://image.