 mình, Satoru Furuya.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chu-bai-kim-cuong-ii-phan-1.json","tmdb_checked":false}