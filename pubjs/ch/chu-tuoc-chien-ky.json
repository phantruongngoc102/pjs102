hản diệt Jedi, và bắt đầu trận chiến thế kỷ với nhóm Ron về số phận của loài người, Yi Ni cũng hóa thân thành một siêu cường với hiệu quả chiến đấu vượt trội \"Dark Phoenix\".</p>","tmdb_id":945724,"cast":["Han Congcong","Jiang Zhenhao","Shuxian Zheng","Mei Aoxue"],"director":["Ji Zhizhong"],"keywords":[],"tmdb":{"type":"movie","id":"945724","season":null,"vote_average":6,"vote_count":2},"cast_meta":[{"name":"Han Congcong","name_vi":null,"name_original":"Han Congcong","tmdb_id":2739220,"profile":"https://image.tmdb.org/t/p/w500/kjkvWQpxdP6ZMLJanPwJIBjuawa.jpg","tmdb_url":"https://www.themoviedb.org/person/2739220"},{"name":"Jiang Zhenhao","name_vi":null,"name_original":"Jiang Zhenhao","tmdb_id":1675260,"profile":"https://image.tmdb.org/t/p/w500/sxwVqg0e9XNu19JojZgKTRKq9J2.jpg","tmdb_url":"https://www.themoviedb.org/person/1675260"},{"name":"Shuxian Zheng","name_vi":null,"name_original":"Shuxian Zheng","tmdb_id":3451694,"profile":"https://image.tmdb.org/t/p/w500/p5IBg0jW1MBoqK7NxcywAAOh4gY.jpg","tmdb_url":"https://www.themoviedb.org/person/3451694"},{"name":"Mei Aoxue","name_vi":null,"name_original":"Mei Aoxue","tmdb_id":4314425,"profile":"https://image.tmdb.org/t/p/w500/q5OPP0LG2hNNEAo524wWBoMxnY0.jpg","tmdb_url":"https://www.themoviedb.org/person/4314425"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ch/chu-tuoc-chien-ky.json"}