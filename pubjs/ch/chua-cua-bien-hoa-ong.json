úng.</p>","tmdb_id":69464,"cast":["Lữ Lương Vỹ","Trịnh Tắc Sĩ","Từ Cẩm Giang","Diệp Đồng","Lưu Gia Linh","Tư Cầm Cao Oa","Thang Chấn Nghiệp","Miêu Kiều Vỹ","Kelvin Wong Siu","Lâm Uy","William Ho","Ronny Ching Siu-Lung","Che Pooi-Si"],"director":["Man Kit Poon"],"keywords":[],"tmdb":{"type":"movie","id":"69464","season":null,"vote_average":7.9,"vote_count":10},"cast_meta":[{"name":"Lữ Lương Vỹ","name_vi":"Lữ Lương Vỹ","name_original":"Ray Lui","tmdb_id":78877,"profile":"https://image.tmdb.org/t/p/w500/vAWHhBCWZwBKLsujgEKusfMLmCO.jpg","tmdb_url":"https://www.themoviedb.org/person/78877"},{"name":"Trịnh Tắc Sĩ","name_vi":"Trịnh Tắc Sĩ","name_original":"Kent Cheng Jak-Si","tmdb_id":65966,"profile":"https://image.tmdb.org/t/p/w500/a1ebM3aLwYkPckPzc9FgfW2xTsZ.jpg","tmdb_url":"https://www.themoviedb.org/person/65966"},{"name":"Từ Cẩm Giang","name_vi":"Từ Cẩm Giang","name_original":"Elvis Tsui Kam-Kong","tmdb_id":83631,"profile":"https://image.tmdb.org/t/p/w500/x110WbXYXMQjVNoPjEMoPo7qEKi.jpg","tmdb_url":"https://www.themoviedb.org/person/83631"},{"name":"Diệp Đồng","name_vi":"Diệp Đồng","name_original":"Cecilia Yip Tung","tmdb_id":83696,"profile":"https://image.tmdb.org/t/p/w500/hsmFXHiHqQH2NWjdP1dZC5ItU1v.jpg","tmdb_url":"https://www.themoviedb.org/person/83696"},{"name":"Lưu Gia Linh","name_vi":"Lưu Gia Linh","name_original":"Carina Lau","tmdb_id":12672,"profile":"https://image.tmdb.org/t/p/w500/5Va4jk69gkdAcABtkTtcUz85RLA.jpg","tmdb_url":"https://www.themoviedb.org/person/12672"},{"name":"Tư Cầm Cao Oa","name_vi":"Tư Cầm Cao Oa","name_original":"Siqin Gaowa","tmdb_id":1118783,"profile":"https://image.tmdb.org/t/p/w500/j5qdKqbAtzMq2m6VQAgDsc0d7yo.jpg","tmdb_url":"https://www.themoviedb.org/person/1118783"},{"name":"Thang Chấn Nghiệp","name_vi":"Thang Chấn Nghiệp","name_original":"Kent Tong Chun-Yip","tmdb_id":1254216,"profile":"https://image.tmdb.org/t/p/w500/r6p6QSyynm0b1WZ5H9PCh5jR9sy.jpg","tmdb_url":"https://www.themoviedb.org/person/1254216"},{"name":"Miêu Kiều Vỹ","