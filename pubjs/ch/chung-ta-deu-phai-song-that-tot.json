9/21565_6fce13a5/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream10.com/share/45734394a69e424c7cd1c76383233976","link_m3u8":"https://vip.opstream10.com/20220619/21570_62635cd3/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream10.com/share/5bc33927ca8779dcd219b9dfaa1195a5","link_m3u8":"https://vip.opstream10.com/20220619/21574_a760b5c3/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream10.com/share/0174a6d48b2b6c3d8c1928c759583f40","link_m3u8":"https://vip.opstream10.com/20220619/21577_15178993/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream10.com/share/45101f00279424b821e70a003a05203a","link_m3u8":"https://vip.opstream10.com/20220619/21578_b917ef21/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream10.com/share/571dea3eb9d4d24c6194ef17c91cda79","link_m3u8":"https://vip.opstream10.com/20220619/21582_311c01cd/index.m3u8"}]}],"description":"<p>Tạm Khuyết - một phụ nữ gia đình kiểu mẫu, vì áp lực quá lớn mà mắc chứng bệnh trầm cảm nghiêm trọng. Cuộc hôn nhân của cô với người chồng đại gia Hướng Tiền cũng liên tục gặp phải trục trặc do những bất đồng trong quan điểm về con cái. Lâu dần, bệnh tình của Tạm Khuyết đến bên bờ vực không thể cứu vãn, cô không còn khả năng chăm sóc con cái và chính bản thân mình. Không thể chịu đựng nổi điều đó, Tạm Khuyết quyết định bỏ nhà ra đi để tìm lại chính mình. Trong quá trình điều trị bệnh, tiếp xúc với nhiều người nhiều việc khác nhau, cô dần tái sinh và trở nên cứng rắn, trưởng thành hơn. Về phần Hướng Tiền, là một doanh nhân thành đạt, anh có vợ đẹp, con khôn, gia tài bạc triệu; nhưng ông trời cứ mãi trêu người khi biến tình yêu và cuộc sống hôn nhân của anh trở thành địa ngục với những hiểu lầm. Công việc cũng dần gặp khó khăn khi anh bị kẻ xấu ghen ghét, đố kỵ. Vợ bỏ đi, kinh doanh thất bại, mất nhà, mất xe, mất công việc, Hướng Tiền chỉ còn lại đứa con trai nhỏ Hảo Hán là sợi dây cuối cùng níu giữ anh với sự sống. Vì con trai, anh gồng mình chống đỡ, bắt đầu lại từ đầu. Tạm Khuyết và Hướng Tiền đều mắc phải sai lầm nhưng sâu thẳm trong tim, họ vẫn dành cho nhau một tình cảm không thể xóa mờ. Chỉ là cuộc sống hiện đại với những con người và guồng quay tiền tài, danh vọng dần cuốn họ vào những thế giới khác. Để rồi khi có những người mới xuất hiện tại vị trí họ vốn dành cho đối phương, với sự quan tâm, yêu thương ấy, họ có thể không bị rung động và sẵn sàng trở lại bên nhau?</p>","tmdb_id":89864,"cast":["Lưu Đào","Yang Shuo","Kim Thần","Lưu Đoan Đoan"],"director":["Lưu Tùng Tuyết"],"keywords":[],"tmdb":{"type":"tv","id":"89864","season":1,"vote_average":6.667,"vote_count":3},"cast_meta":[{"name":"Lưu Đào","name_vi":"Lưu Đào","name_original":"Liu Tao","tmdb_id":1236264,"profile":"https://image.tmdb.org/t/p/w500/gcaeonDiNJyZ9bLIh23ds3TAzeA.jpg","tmdb_url":"https://www.themoviedb.org/person/1236264"},{"name":"Yang Shuo","name_vi":null,"name_original":"Yang Shuo","tmdb_id":1924106,"profile":"https://image.tmdb.org/t/p/w500/bUCUr6k7noDNyMWC637xg1lnRPx.jpg","tmdb_url":"https://www.themoviedb.org/person/1924106"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Lưu Đoan Đoan","name_vi":"Lưu Đoan Đoan","name_original":"Liu Duanduan","tmdb_id":2610694,"profile":"https://image.tmdb.org/t/p/w500/9f839TXRckHQnMckQuZbxej77go.jpg","tmdb_url":"https://www.themoviedb.org/person/2610694"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chung-ta-deu-phai-song-that-tot.json"}