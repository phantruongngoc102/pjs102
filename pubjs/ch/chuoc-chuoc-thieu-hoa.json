f0e13db6","link_m3u8":"https://vip.opstream90.com/20250928/13277_1dbb1c25/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/edbdd777879cbb165a94951e6a425b3f","link_m3u8":"https://vip.opstream90.com/20250928/13278_edbdd777/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream90.com/share/2808e33b0ef26bac248b17936f0f1938","link_m3u8":"https://vip.opstream90.com/20250928/13279_2808e33b/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream90.com/share/a2d22c3252eb5505ba9b1899cda9dad2","link_m3u8":"https://vip.opstream90.com/20250929/13317_a2d22c32/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream90.com/share/631e08b59d01b18c9d5477a62647e03b","link_m3u8":"https://vip.opstream90.com/20250929/13318_631e08b5/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream90.com/share/27e5b67fd10a082a605ee7d995f69eca","link_m3u8":"https://vip.opstream90.com/20250929/13319_27e5b67f/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream90.com/share/f73f9ab6a0f3235ab7c4554ea19e09b7","link_m3u8":"https://vip.opstream90.com/20251002/13548_f73f9ab6/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream90.com/share/cdcfb1c07205f7057b0a305eb21e72d5","link_m3u8":"https://vip.opstream90.com/20251002/13569_cdcfb1c0/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream90.com/share/34d2379317fb3635602ad19abbabf397","link_m3u8":"https://vip.opstream90.com/20251002/13571_34d23793/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream90.com/share/282ed79347cfc23fc4a700154d671e05","link_m3u8":"https://vip.opstream90.com/20251002/13570_282ed793/index.m3u8"}]}],"description":"<p>Năm 1916, để cứu anh trai là Chử Thiều Trung, Chử Thiều Hoa đã gả cho Trần Đại Thuận – cậu cả của hiệu thuốc Trần Ký. Bằng sự thành tín và tài năng kinh doanh xuất sắc, cô đã nhận được sự coi trọng của cha chồng và trở thành người quản lý hiệu thuốc. Sau khi cha chồng và Trần Đại Thuận bất ngờ qua đời, Trần Nhị Thuận kế thừa hiệu thuốc nhưng đã phung phí hết gia sản, khiến hiệu thuốc rơi vào cảnh khốn cùng. Chử Thiều Hoa đã gắng gượng vượt qua gian khổ, mở hiệu thuốc Hoa Thuận để nuôi sống cả gia đình. Cô quyết định cùng mối tình đầu Hạ Sơ bắt đầu một cuộc sống mới, nhưng lại bị Trần Nhị Thuận và mẹ chồng ngăn cản. Sau đó, nhà họ Trần bị thổ phỉ cướp sạch, trong kiếp nạn này, Chử Thiều Hoa cũng mất đi con gái, đau lòng tột độ, cô một mình đến Thượng Hải. Tại Thượng Hải, Chử Thiều Hoa đạt thành tích xuất sắc ở bách hóa Vĩnh Tân, được thương nhân kỳ tài Văn Tri Thu mời hợp tác lập nghiệp. Dần dần, cô trưởng thành, trở thành một nữ thương nhân dũng cảm, có tầm nhìn xa và luôn giữ chữ tín.</p><p>&nbsp;</p>","tmdb_id":254488,"cast":["Trình Viên Viên","Dương Hựu Ninh","Mao Tử Tuấn","Đường Tằng","Chai Biyun","Xuan Yan","Zhang Jiayue"],"director":["Ding Yu"],"keywords":[],"tmdb":{"type":"tv","id":"254488","season":1,"vote_average":10,"vote_count":1},"cast_meta":[{"name":"Trình Viên Viên","name_vi":"Trình Viên Viên","name_original":"Rayzha Alimjan","tmdb_id":1882287,"profile":"https://image.tmdb.org/t/p/w500/1p78v9DB2LTqWy2j2qcniQRyOdq.jpg","tmdb_url":"https://www.themoviedb.org/person/1882287"},{"name":"Dương Hựu Ninh","name_vi":"Dương Hựu Ninh","name_original":"Tony Yang","tmdb_id":96958,"profile":"https://image.tmdb.org/t/p/w500/d0C8Dp9itcFV4Q8bLRISguGJmPR.jpg","tmdb_url":"https://www.themoviedb.org/person/96958"},{"name":"Mao Tử Tuấn","name_vi":"Mao Tử Tuấn","name_original":"Mao Zijun","tmdb_id":1176004,"profile":"https://image.tmdb.org/t/p/w500/cqugMweL96ERGdE98D2z3Cza5JY.jpg","tmdb_url":"https://www.themoviedb.org/person/1176004"},{"name":"Đường Tằng","name_vi":"Đường Tằng","name_original":"Tang Zeng","tmdb_id":3131747,"profile":"https://image.tmdb.org/t/p/w500/dPWJl8mZ7KWyUbd1HlgigKTLZDe.jpg","tmdb_url":"https://www.themoviedb.org/person/3131747"},{"name":"Chai Biyun","name_vi":null,"name_original":"Chai Biy