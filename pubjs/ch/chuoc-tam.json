ption":"Kiều Ngôn trở thành trẻ mồ côi sau cái chết đột ngột của cha mẹ và quay trở lại nhà họ Cố để điều tra vụ việc. Cô tiếp cận Cố Tĩnh Uyên, con nuôi của ông nội, bằng cách giả vờ yếu đuối, nhưng anh vẫn lạnh lùng và thông minh, dẫn đến cuộc đấu trí giữa hai người. Khi anh liều mạng cứu cô khỏi đám cháy và bày tỏ mong muốn bảo vệ cô và gia tộc, tình cảm nảy sinh. Mối tình cấm kỵ của họ đối mặt với âm mưu và thử thách, buộc họ phải giấu kín trái tim và bảo vệ nhau bằng mọi giá giữa sóng gió và nguy hiểm.","tmdb":{"type":"tv","id":"288596","season":1,"vote_average":9,"vote_count":1},"modified":"2025-08-20T18:08:45.000Z","cast":["Phàn Trị Hân","Lý Mộc Thần","Gu Landi","Wang Ting","Cai Xinyang","Wu Chunyi","Lý Nghệ Đồng"],"director":["信鹏"],"cast_meta":[{"name":"Phàn Trị Hân","name_vi":"Phàn Trị Hân","name_original":"Fan Zhixin","tmdb_id":2533329,"profile":"https://image.tmdb.org/t/p/w500/1TowSJzOOeKvWzpWpPO6RzI3cf0.jpg","tmdb_url":"https://www.themoviedb.org/person/2533329"},{"name":"Lý Mộc Thần","name_vi":"Lý Mộc Thần","name_original":"Daisy Li","tmdb_id":1747503,"profile":"https://image.tmdb.org/t/p/w500/5rsbbbPLKtkGGX0v8MT1oivpGhS.jpg","tmdb_url":"https://www.themoviedb.org/person/1747503"},{"name":"Gu Landi","name_vi":null,"name_original":"Gu Landi","tmdb_id":3912350,"profile":"https://image.tmdb.org/t/p/w500/tkJ6Cs6jcVNi1TZQwGwSpSU2Y5g.jpg","tmdb_url":"https://www.themoviedb.org/person/3912350"},{"name":"Wang Ting","name_vi":null,"name_original":"Wang Ting","tmdb_id":1484353,"profile":"https://image.tmdb.org/t/p/w500/p0c9TZN2kzRS2BFSbqWyTPb5Htr.jpg","tmdb_url":"https://www.themoviedb.org/person/1484353"},{"name":"Cai Xinyang","name_vi":null,"name_original":"Cai Xinyang","tmdb_id":4154714,"profile":"https://image.tmdb.org/t/p/w500/wkREVwxOqnuytowfMjnkUbqlXGU.jpg","tmdb_url":"https://www.themoviedb.org/person/4154714"},{"name":"Wu Chunyi","name_vi":null,"name_original":"Wu Chunyi","tmdb_id":5099920,"profile":"https://image.tmdb.org/t/p/w500/45JduXSCOWjEAEYLPJffPv