m/share/3d3f298f60a4333ec4c3916bf59aad87","link_m3u8":"https://vip.opstream14.com/20230307/33417_da4d58bc/index.m3u8"},{"name":"25","slug":"25","filename":"Chuỗi Vòng Quỷ Ám E25","link_embed":"https://vip.opstream14.com/share/f027bfaeb72367e4f6c0522e2cd9f008","link_m3u8":"https://vip.opstream14.com/20230314/33686_304a40ef/index.m3u8"},{"name":"26","slug":"26","filename":"Chuỗi Vòng Quỷ Ám E26","link_embed":"https://vip.opstream14.com/share/81e2e0ba9d2d6634849095fa6a997eae","link_m3u8":"https://vip.opstream14.com/20230314/33687_35200810/index.m3u8"},{"name":"27","slug":"27","filename":"Chuỗi Vòng Quỷ Ám E27","link_embed":"https://vip.opstream14.com/share/5409b229df3e46a0a6d20b2751fbe705","link_m3u8":"https://vip.opstream14.com/20230314/33688_c0abc505/index.m3u8"},{"name":"28","slug":"28","filename":"Chuỗi Vòng Quỷ Ám E28","link_embed":"https://vip.opstream14.com/share/302626eb160bcd2ff5b9e4a0578e021b","link_m3u8":"https://vip.opstream14.com/20230314/33689_390121a6/index.m3u8"},{"name":"29","slug":"29","filename":"Chuỗi Vòng Quỷ Ám E29","link_embed":"https://vip.opstream14.com/share/95814964b0c42ce64d51e38d917d7fd3","link_m3u8":"https://vip.opstream14.com/20230315/33701_bf073457/index.m3u8"},{"name":"30","slug":"30","filename":"Chuỗi Vòng Quỷ Ám E30","link_embed":"https://vip.opstream14.com/share/b26a828a1b8d319c2c51c7f536ead80d","link_m3u8":"https://vip.opstream14.com/20230315/33702_077559af/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>Chuỗi Vòng Quỷ Ám - The Stone of Affectio xoay quanh tam giác tình yêu giữa Mookda, Pailin và Pruek. Mookda, Pailin cùng yêu Pruek nhưng Pruek chọn đến với Pailin. Điều này khiến Mookda chìm trong đau khổ nên đã tìm đến với ma thuật hắc ám. Về phía Pruek, anh ta vô tình bị điều khiển bởi bùa chú của pháp sư nên đã dùng con dao găm để giết chết Mookda. Sau đó linh hồn của Mookda bị giam giữ trong viên ngọc trai đá, chờ ngày báo thù. 100 năm trôi qua, Phumin (kiếp sau của Pruek) được giao nhiệm vụ điều tra một trường hợp tử vong trong một hang động và tình cờ hóa giải phép thuật đã giam cầm Mookda. Mookda hồi sinh với sự cuồng nộ trong 100 năm và tiếp tục hành trình săn lùng Ployrung (kiếp sau của Pailin), gây ra hàng loạt tội ác. Để ngăn chặn Mookda, Phum và Ployrung phải tìm ra câu chuyện có thật trong quá khứ và tìm cách tiêu diệt con quái vật bên trong Mookda.</p>","tmdb":{"type":"tv","id":"220879","season":1,"vote_average":9,"vote_count":1},"modified":"2025-04-08T13:15:05.000Z","cast":["Thitipoom Techa-apaikhun","Nalinthip Sakulongumpai","Raviyanun Takerd","Chopin Noochintra","Sananthachat Thanapatpisal","Sarut Vichitrananda","Arisara Wongchalee","Puri Hiranprueck","Pympan Chalayanacupt","Prima Ratchata","Uthumporn Silaphan"],"director":["Bunjong Sinthanamongkolkul"],"cast_meta":[{"name":"Thitipoom Techa-apaikhun","name_vi":null,"name_original":"Thitipoom Techa-apaikhun","tmdb_id":1796474,"profile":"https://image.tmdb.org/t/p/w500/xyMicGnTTwfmxaWFVznJr4Ucprw.jpg","tmdb_url":"https://www.themoviedb.org/person/1796474"},{"name":"Nalinthip Sakulongumpai","name_vi":null,"name_original":"Nalinthip Sakulongumpai","tmdb_id":2395334,"profile":"https://image.tmdb.org/t/p/w500/A6P2TE1t1QolD9dCCRgprfYz7W5.jpg","tmdb_url":"https://www.themoviedb.org/person/2395334"},{"name":"Raviyanun Takerd","name_vi":"Raviyanun Takerd","name_original":"Raviyanun Takerd","tmdb_id":2937494,"profile":"https://image.tmdb.org/t/p/w500/7UslnRA7pVkelzKvPwoDfFbDykN.jpg","tmdb_url":"https://www.themoviedb.org/person/2937494"},{"name":"Chopin Noochintra","name_vi":null,"name_original":"Chopin Noochintra","tmdb_id":3325245,"profile":"https://image.tmdb.org/t/p/w500/gbUuGBzVQDK51pmChKwhvsDNOLr.jpg","tmdb_url":"https://www.themoviedb.org/person/3325245"},{"name":"Sananthachat Thanapatpisal","name_vi":null,"name_original":"Sananthachat Thanapatpisal","tmdb_id":1664325,"profile":"https://image.tmdb.org/t/p/w500/mZA5s9gWldECvQ1bqy4ptdEWKIK.jpg","tmdb_url":"https://www.themoviedb.org/person/1664325"},{"name":"Sarut Vichitranan