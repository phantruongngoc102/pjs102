eam13.com/share/e2c420d928d4bf8ce0ff2ec19b371514","link_m3u8":"https://vip.opstream13.com/20230613/71_23124f9f/index.m3u8"},{"name":"36","slug":"36","filename":"Bir Kucuk Gun Isigi 36","link_embed":"https://vip.opstream13.com/share/82161242827b703e6acf9c726942a1e4","link_m3u8":"https://vip.opstream13.com/20230620/175_9baa28bb/index.m3u8"}]}],"time":"2h/tập","description":"<p>Elif rất yêu Hakan. Điều duy nhất còn thiếu trong cuộc hôn nhân của họ là một đứa trẻ. Trong khi Elif đang xem xét bắt đầu thủ tục nhận con nuôi, cô ấy biết rằng Hakan đã gặp tai nạn. Và cuộc sống của anh bắt đầu thay đổi không thể đảo ngược. Mặt khác, Fırat tìm thấy dấu vết của anh trai Dila, người đã mất tích nhiều năm và đưa anh ta trở về nhà. Fırat bị giằng xé giữa người mẹ độc tài và áp bức Ümran và người anh trai nổi loạn và phù phiếm Dila. Khi cuộc sống của Elif bị đảo lộn, Fırat không hề hay biết về mạng lưới mà số phận đã dệt nên cho cô. Con đường của Elif và Fırat giao nhau theo cách mà họ sẽ không bao giờ chia tay nữa.</p>","tmdb":{"type":"tv","id":"209544","season":1,"vote_average":6,"vote_count":2},"modified":"2025-04-11T09:44:49.000Z","cast":["Seray Kaya","Berk Oktay","Esra Dermancıoğlu","Tuğçe Açıkgöz","Şeyma Korkmaz","Yilmaz Bayraktar","Güneş Hayat","Gizem Ünsal","Beran Kotan","Yiğit Yapıcı","Süleyman İvenç"],"director":["Emre Kabakusak"],"cast_meta":[{"name":"Seray Kaya","name_vi":null,"name_original":"Seray Kaya","tmdb_id":1987247,"profile":"https://image.tmdb.org/t/p/w500/vonxi1y7pUDcbeOantOqYrBSizx.jpg","tmdb_url":"https://www.themoviedb.org/person/1987247"},{"name":"Berk Oktay","name_vi":null,"name_original":"Berk Oktay","tmdb_id":1252194,"profile":"https://image.tmdb.org/t/p/w500/3cSANctrgz0o9P9xFfrdg8fSEeH.jpg","tmdb_url":"https://www.themoviedb.org/person/1252194"},{"name":"Esra Dermancıoğlu","name_vi":null,"name_original":"Esra Dermancıoğlu","tmdb_id":1256373,"profile":"https://image.tmdb.org/t/p/w500/d8GubeGUpIqFMnpEGaZ3dlhBCZq.jpg","tmdb_url":"https://www.themoviedb.or