":[],"keywords":[],"tmdb":{"type":"tv","id":"209604","season":1,"vote_average":7.1,"vote_count":27},"cast_meta":[{"name":"Sumire Uesaka","name_vi":null,"name_original":"Sumire Uesaka","tmdb_id":1368254,"profile":"https://image.tmdb.org/t/p/w500/AbouCe2WVBHvMlBm9NnG7GHyJpa.jpg","tmdb_url":"https://www.themoviedb.org/person/1368254"},{"name":"Tomori Kusunoki","name_vi":null,"name_original":"Tomori Kusunoki","tmdb_id":2004086,"profile":"https://image.tmdb.org/t/p/w500/t5aBzyYiJZDE6DWeTcGMrcQpiI5.jpg","tmdb_url":"https://www.themoviedb.org/person/2004086"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chuyen-de-quoc-tearmoon.json"}