://vip.opstream15.com/share/ff16d86ffe81cfaa7f6e627ed1679c1b","link_m3u8":"https://vip.opstream15.com/20230831/41841_a78ec873/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/29ef8c120a1b5783630e8bbe933d9db4","link_m3u8":"https://vip.opstream15.com/20230831/41842_927eba9b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/beab831c783550ad003eddaed2d0849d","link_m3u8":"https://vip.opstream15.com/20230831/41843_0682e808/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/13349a1d2d1c176d5fa2124ce62d35a2","link_m3u8":"https://vip.opstream15.com/20230831/41844_50efba63/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/088d797fa104e7734c0262933e6e73d3","link_m3u8":"https://vip.opstream15.com/20230831/41845_74df2461/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream15.com/share/56909081ae58f1af0eee5d6d29c26672","link_m3u8":"https://vip.opstream15.com/20230831/41846_ea182619/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream15.com/share/9f0360dd974d7989d73f9ed4243822e6","link_m3u8":"https://vip.opstream15.com/20230831/41847_d4e9951e/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream15.com/share/fec811f65549e5a2e40fb98120bc2ab2","link_m3u8":"https://vip.opstream15.com/20230831/41848_1b38f7bd/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream15.com/share/3d506847947985f1615169e670d9ec3d","link_m3u8":"https://vip.opstream15.com/20230831/41849_d7d4691c/index.m3u8"},{"name":"27","slug":"27","link_embed":"https://vip.opstream15.com/share/8a656f0148f907092ae68a6ecce73610","link_m3u8":"https://vip.opstream15.com/20230831/41850_c567e008/index.m3u8"}]}],"description":"<p>Thập niên 70, La Nhất Đồng, đầu bếp món Tây ở Hồng Kông Trung Quốc và bạn tốt Lý Cao Sơn, Lao Kim kết duyên nhờ tiệm ăn \"Thích Người\", bắt đầu quãng thời gian cùng nhau phấn đấu; mà \"phu nhân Hồng Kông Trung Quốc xinh đẹp\" Chân Thiến Mỹ, \"dân nhập cư mới\" từ Quảng Đông - Lương Hoan và cô gái Bắc Kinh - Hạ Lôi cũng do duyên phận đưa đẩy mà định cư tại Hồng Kông Trung Quốc, soi sáng cuộc sống của nhau. Những \"nhân vật nhỏ bé\" này và gia đình của họ đã trải qua mấy chục năm vang bóng với sự kiện trao trả Hồng Kông Trung Quốc, khủng hoảng tài chính, xin quyền đăng cai Olympic thành công, dịch SARS, khủng hoảng tài chính toàn cầu,... cùng viết nên hành trình phấn đấu của hai lớp người. Tiệm ăn nhỏ bé như một cỗ máy thời gian, bầu bạn cùng mấy lớp người Hồng Kông Trung Quốc chinh phục nghịch cảnh, chờ cầu vồng ló dạng sau cơn mưa, cũng chứng kiến biến đổi lớn của thời đại, khi mà \"hòn ngọc phương Đông\" Hồng Kông Trung Quốc được trao trả, hướng đến cuộc sống phồn vinh yên bình, cuối cùng hòa vào Vùng Vịnh Lớn để rồi xuất phát lại lần nữa.</p>","tmdb_id":204028,"cast":["Huang Jue","Hồ Hạnh Nhi","Lý Trị Đình","Tạ Quân Hào","Ngô Thiên Ngữ","Amy Fan","Châu Bách Hào","Hứa Nhã Đình","Liang Jingkang","Trần Gia Lạc","Dương Mẫn Na","Hùng Đại Lâm","Nhiếp Viễn","Ông Hồng","Đàm Diệu Văn"],"director":["Ng Gam Yuen"],"keywords":[],"tmdb":{"type":"tv","id":"204028","season":1,"vote_average":9,"vote_count":1},"cast_meta":[{"name":"Huang Jue","name_vi":null,"name_original":"Huang Jue","tmdb_id":106581,"profile":"https://image.tmdb.org/t/p/w500/nM34PRe6anyLwedKkoOcC4JNVIz.jpg","tmdb_url":"https://www.themoviedb.org/person/106581"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/938251"},{"name":"Lý Trị Đình","name_vi":"Lý Trị Đình","name_original":"Aarif Rahman","tmdb_id":148881,"profile":"https://image.tmdb.org/t/p/w500/qRA9oEDweIFhN0yZ4YTynJjkMdz.jpg","tmdb_url":"https://www.themoviedb.org/person/148881"},{"name":"Tạ Quân Hào","name_vi":"Tạ Quân Hào","name_original":"Gardner Tse Kwan-Ho","tmdb_id"