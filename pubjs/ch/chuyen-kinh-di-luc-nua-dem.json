{"id":"623720873d016a3b6717f50f","title":"Chuyện Kinh Dị Lúc Nửa Đêm","origin_name":"Scary Stories to Tell in the Dark","slug":"chuyen-kinh-di-luc-nua-dem","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ch/chuyen-kinh-di-luc-nua-dem.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ch/chuyen-kinh-di-luc-nua-dem.webp","year":2019,"type":"single","genre":[{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"},{"id":"6218eb66a2d0f024a9de48d4","name":"Kinh Điển","slug":"kinh-dien"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620a2381e0fc277084dfd9c6","name":"Canada","slug":"canada"},{"id":"6212611d1f1609c9d93466cc","name":"Mexico","slug":"mexico"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Chuyện Kinh Dị Lúc Nửa Đêm","link_embed":"https://vip.opstream14.com/share/6e79ed05baec2754e25b4eac73a332d2","link_m3u8":"https://vip.opstream14.com/20220319/1810_287aaabc/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Đó là năm 1968 ở Mỹ. Thay đổi đang thổi trong gió ... nhưng dường như xa khỏi sự bất ổn ở các thành phố là thị trấn nhỏ của Thung lũng Mill nơi dành cho nhiều thế hệ, bóng của gia đình Bellows đã lờ mờ lớn. Đó là trong biệt thự của họ ở rìa thị trấn mà Sarah, một cô gái trẻ với những bí mật khủng khiếp, biến cuộc sống bị tra tấn của mình thành một loạt những câu chuyện đáng sợ, được viết trong một cuốn sách đã vượt qua những câu chuyện về thời gian có cách trở thành một cách quá thực tế Đối với một nhóm thanh thiếu niên khám phá ngôi mộ đáng sợ của Sarah.</p>","tmdb":{"type":"movie","id":"417384","season":null,"vote_average":6.495,"vote_count":2777},"modified":"2024-11-16T07:15:11.000Z","cast":["Zoe Colletti","Dea