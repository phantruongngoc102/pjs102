90.com/share/5bb352aa0983fe81d1ab84a49b7a902f","link_m3u8":"https://vip.opstream90.com/20260131/23554_5bb352aa/index.m3u8"}]}],"description":"<p>Để thúc đẩy phát triển kinh tế, huyện Bình Xuyên quyết định thành lập trấn Nguyệt Hải. Hai cán bộ trẻ có năng lực và cá tính nổi bật là Lý Thu Bình và Trịnh Đức Thành, kiên trì lý tưởng \"thành phố của nhân dân do nhân dân xây dựng\", đã tận dụng chính sách cải cách và Văn kiện số 1 Trung ương Đảng Cộng sản Trung Quốc để tìm ra con đường đột phá. Không sử dụng ngân sách nhà nước, họ dẫn dắt hàng chục nghìn nông dân góp vốn, liên doanh, từng bước xây dựng một đô thị hiện đại trên vùng bãi bồi hoang vu. Đây được mô tả như một kỳ tích \"từ con số không\", không chỉ làm thay đổi diện mạo vùng đất nghèo mà còn xoay chuyển vận mệnh của hàng trăm nghìn người nông dân Trung Quốc. Lý Thu Bình, Trịnh Đức Thành, Giải Xuân Lai, Cao Tuyết Mai cùng những người kiến tạo thành phố dám nghĩ dám làm, tiên phong đổi mới, đã viết nên một chương rực rỡ dưới ánh nắng chói chang của thập niên 1980.</p><p>&nbsp;</p>","tmdb_id":279593,"cast":["Triệu Lệ Dĩnh","Huỳnh Hiểu Minh","Tần Tuấn Kiệt","Chen Minghao","Zhu Yuanyuan","Geng Le","Dư Ngai Lỗi","Li Jiuxiao","Zhang Weiyi","Wang Yiyao","Dong Kefei","Zhu Chaoyi","Chen Haoming"],"director":["孙皓"],"keywords":[],"tmdb":{"type":"tv","id":"279593","season":1,"vote_average":8.2,"vote_count":5},"cast_meta":[{"name":"Triệu Lệ Dĩnh","name_vi":"Triệu Lệ Dĩnh","name_original":"Zhao Liying","tmdb_id":1260868,"profile":"https://image.tmdb.org/t/p/w500/lDkliS0cwOFO0QA7epHYZJWNttG.jpg","tmdb_url":"https://www.themoviedb.org/person/1260868"},{"name":"Huỳnh Hiểu Minh","name_vi":"Huỳnh Hiểu Minh","name_original":"Huang Xiaoming","tmdb_id":109434,"profile":"https://image.tmdb.org/t/p/w500/pnSbq1pNDb0uLkzGOJ8zy7piBvb.jpg","tmdb_url":"https://www.themoviedb.org/person/109434"},{"name":"Tần Tuấn Kiệt","name_vi":"Tần Tuấn Kiệt","name_original":"Qin Junjie","tmdb_id":17385,"profile":"https://image.tmdb.org/t/p/w500/iYdwWhvd4