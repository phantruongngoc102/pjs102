{"id":"649a431dfc04611a05528331","title":"Chuyện Mai Sau","origin_name":"Things to Come","slug":"chuyen-mai-sau","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ch/chuyen-mai-sau.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ch/chuyen-mai-sau.webp","year":2016,"type":"single","genre":[{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a2378e0fc277084dfd972","name":"Pháp","slug":"phap"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Things to Come - Chuyện Mai Sau - 2016","link_embed":"https://vip.opstream14.com/share/fdee0805723599ea8d13cc0cc72d81e4","link_m3u8":"https://vip.opstream14.com/20230626/38260_7d3da9f0/index.m3u8"}]}],"time":"102 Phút","description":"Nathalie dạy triết học tại một trường trung học ở Paris. Cô ấy đam mê công việc của mình và đặc biệt thích truyền lại niềm vui khi được suy nghĩ. Đã kết hôn và có hai con, cô chia thời gian của mình cho gia đình, học sinh cũ và người mẹ rất chiếm hữu của mình. Một ngày nọ, chồng của Nathalie thông báo rằng anh ấy sẽ bỏ cô để theo một người phụ nữ khác. Với sự tự do ập đến, Nathalie phải làm lại cuộc đời mình.","tmdb":{"type":"movie","id":"374465","season":null,"vote_average":6.509,"vote_count":334},"modified":"2023-06-27T09:02:07.000Z","cast":["Isabelle Huppert","André Marcon","Roman Kolinka","Édith Scob","Sarah Le Picard","Solal Forte","Élise Lhomeau","Lionel Dray","Yves Heck","Grégoire Montana-Haroche","Lina Benzerti","Guy-Patrick Sainderichin","Rachel Arditi","Charline Bourgeois-Tacquet","Linus Westheuser"],"director":["Mia Hansen-Løve"],"cast_meta":[{"name":"Isabelle Huppert","name_vi":null,"name_original":"Isabelle Huppert","tmdb_id":17882,"profile":"https://image.t