ream11.com/share/c526837ad41a5fab7c87fe6cedcdb584","link_m3u8":"https://vip.opstream11.com/20221124/37761_c5ba5a91/index.m3u8"},{"name":"14","slug":"14","filename":"love-is-for-suckers-love-that-will-freeze-to-death-tap-14","link_embed":"https://vip.opstream11.com/share/62a5a1b5c98bf0e46e76dbfe74c403f0","link_m3u8":"https://vip.opstream11.com/20221125/37791_dd84c0e9/index.m3u8"},{"name":"15","slug":"15","filename":"love-is-for-suckers-love-that-will-freeze-to-death-tap-15","link_embed":"https://vip.opstream11.com/share/53be5037beb270a5e1a29e6e3d915272","link_m3u8":"https://vip.opstream11.com/20221202/38579_c415b1f4/index.m3u8"},{"name":"16","slug":"16","filename":"love-is-for-suckers-love-that-will-freeze-to-death-tap-16","link_embed":"https://vip.opstream11.com/share/a49759174cc1b87887edcced9cd486c7","link_m3u8":"https://vip.opstream11.com/20221202/38580_5613120f/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Kể về Gu Yeo-Reum (Lee Da-Hee) làm giám đốc cho các chương trình truyền hình. Cô ấy đã làm việc với tư cách là một PD trong 10 năm qua, nhưng cô ấy đang gặp khủng hoảng do các buổi diễn của cô ấy bị hủy bỏ. Dự án tiếp theo của cô là chương trình truyền hình thực tế \"Kingdom of Love\". Cô ấy làm việc chăm chỉ để làm cho buổi biểu diễn đó thành công. Trong cuộc sống cá nhân của riêng mình, Gu Yeo-Reum là bạn tốt của Park Jae-Hun (Choi Si-Won). Họ đã là bạn hơn 20 năm và họ cũng là hàng xóm của nhau. Park Jae-Hun là một bác sĩ và anh ấy làm việc cho một phòng khám phẫu thuật thẩm mỹ. Anh ấy đã không còn hứng thú với công việc của mình và việc tìm kiếm một đối tác lãng mạn. Để giúp đỡ người bạn Gu Yeo-Reum, anh quyết định tham gia chương trình truyền hình thực tế \"Kingdom of Love\" của cô với tư cách là một diễn viên bình thường. Trong khi làm việc cùng nhau với tư cách là một PD và thành viên diễn viên, họ đã bất ngờ nảy sinh tình cảm với nhau.</p>","tmdb":{"type":"tv","id":"197073","season":1,"vote_average":5.1,"vote_count":23},"modified":"2025-05-09T1