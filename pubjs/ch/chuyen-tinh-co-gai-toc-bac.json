ename":"Chuyen_Tinh_Co_Gai_Toc_Bac_14","link_embed":"https://vip.opstream17.com/share/7b806e466d358875191619d70dfe2091","link_m3u8":"https://vip.opstream17.com/20240723/15535_70f0ca04/index.m3u8"},{"name":"15","slug":"15","filename":"Chuyen_Tinh_Co_Gai_Toc_Bac_15","link_embed":"https://vip.opstream17.com/share/dbe1a0a2c9bd9241b3499318bf96f756","link_m3u8":"https://vip.opstream17.com/20240723/15536_18ce6344/index.m3u8"},{"name":"16","slug":"16","filename":"Chuyen_Tinh_Co_Gai_Toc_Bac_16","link_embed":"https://vip.opstream17.com/share/ebbb5ccb88b2cd2e2224917a325f903b","link_m3u8":"https://vip.opstream17.com/20240723/15537_7f67154d/index.m3u8"},{"name":"17","slug":"17","filename":"Chuyen_Tinh_Co_Gai_Toc_Bac_17","link_embed":"https://vip.opstream17.com/share/2a3c550cc7e86e943696ee0529620811","link_m3u8":"https://vip.opstream17.com/20240723/15538_8f1c0141/index.m3u8"},{"name":"18","slug":"18","filename":"Chuyen_Tinh_Co_Gai_Toc_Bac_18","link_embed":"https://vip.opstream17.com/share/9fc36fa768a74fa93d3ee7bf57b1392c","link_m3u8":"https://vip.opstream17.com/20240723/15539_13ae2128/index.m3u8"},{"name":"19","slug":"19","filename":"Chuyen_Tinh_Co_Gai_Toc_Bac_19","link_embed":"https://vip.opstream17.com/share/0c6ba56676353996dff5efb2b7789e1e","link_m3u8":"https://vip.opstream17.com/20240723/15540_bd22378d/index.m3u8"},{"name":"20","slug":"20","filename":"Chuyen_Tinh_Co_Gai_Toc_Bac_20End","link_embed":"https://vip.opstream17.com/share/8f646834ef1adefaef52d74d5ea8329d","link_m3u8":"https://vip.opstream17.com/20240723/15541_da782b1b/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Chuyện Tình Cô Gái Tóc Bạc là một tác phẩm kiếm hiệp vào loại nổi tiếng nhất của Lương Vũ Sinh, bằng chứng là nó đã được chuyển thể thành phim điện ảnh và truyền hình rất nhiều lần ... Trác Nhất Hàng là đại đệ tử của phái Võ Đang với tài nghệ vào loại hàng đầu trong Bát đại môn phái. Anh là niềm hy vọng của cả phái Võ Đang và giang hồ trong cảnh loạn lạc cuối đời nhà Minh. Tuy nhiên Nhất Hàng lại chẳng màng chức vị hay danh tiếng, anh chỉ thích đối tửu cùng người bạn lâu năm Ngô Tam Quế và tơ tưởng tới người trong mộng của anh - Ngọc La Sát xinh đẹp, đệ nhất sát thủ của Thần Cung giáo - kẻ địch của Bát đại môn phái. Và rồi Nhất Hàng cùng Ngọc La Sát cũng đến được với nhau, Nhất Hàng đặt tên cho người yêu của mình là Luyện Nghê Thường, còn nàng Nghê Thường bắt người yêu phải thề rằng anh sẽ luôn tin tưởng vào cô bất kể chuyện gì xảy ra. Và tất nhiên với một mối tình ngang trái kiểu Romeo và Juliette thì sẽ có rất nhiều thứ ập đến với Nhất Hàng và Nghê Thường, đó là sự ngăn cản từ phía phái Võ Đang với Nhất Hàng, từ phía Cơ Vô Song giáo chủ Thần Cung giáo, đó là sự kiện nhà Thanh xâm chiếm Trung Quốc nhờ sự tiếp tay của Ngô Tam Quế. Kết quả thì như tất cả những ai yêu kiếm hiệp đều đã biết, nàng Nghê Thường biến thành Bạch phát ma nữ với mái tóc trắng xóa, còn Nhất Hàng suốt phần đời còn lại đứng canh trên đỉnh núi tuyết trắng để tìm thứ thảo dược giúp hồi sinh mái tóc của nàng Nghê Thường. Nhưng cái người xem quan tâm là bi kịch nào đã đẩy Nghê Thường và Nhất Hàng tới số phận đau khổ như vậy.</i></p>","tmdb":{"type":"tv","id":"109994","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-02T11:17:45.000Z","cast":["Thái Thiếu Phân","Timmy Ho Bo-Sang","Joanna Chan Pui-San","Trần Gia Huy","Jason Pai Piao","Bao Fang","Cheng Ka-Sang","Mạch Tử Vân","Lý Thành Xương","Brian Wong","Jessica Chau Ching","Tam Yat-Ching","Tam Chuen-Hing","Joe Ma Tak-Chung","Johnny Siu Juen Dang"],"director":["Lưu Gia Hào"],"cast_meta":[{"name":"Thái Thiếu Phân","name_vi":"Thái Thiếu Phân","name_original":"Ada Choi Siu-Fan","tmdb_id":87948,"profile":"https://image.tmdb.org/t/p/w500/z1EVQ4junnBDj5ySqwq9nqogXq1.jpg","tmdb_url":"https://www.themoviedb.org/person/87948"},{"name":"Timmy Ho Bo-Sang","name_vi":null,"name_original":"Timmy Ho Bo-Sang","tmdb_id":65942,"profile":"https://image.tmdb.org/t/p/w500/4JGlBuDQ7dch94TcAgxcOjz527P.jpg","tmdb_url":"https://www.themoviedb.org/person/