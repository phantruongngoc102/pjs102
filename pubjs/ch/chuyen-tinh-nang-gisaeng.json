embed":"https://vip.opstream11.com/share/024677efb8e4aee2eaeef17b54695bbe","link_m3u8":"https://vip.opstream11.com/20220327/5729_2044bf70/index.m3u8"},{"name":"62","slug":"62","filename":"Chuyện Tình Nàng Gisaeng - New Tales Of Gisaeng - Tập 62","link_embed":"https://vip.opstream11.com/share/3ce257b311e5acf849992f5a675188e8","link_m3u8":"https://vip.opstream11.com/20220327/5730_0f24352e/index.m3u8"},{"name":"63","slug":"63","filename":"Chuyện Tình Nàng Gisaeng - New Tales Of Gisaeng - Tập 63","link_embed":"https://vip.opstream11.com/share/c19af480c40e343bbac3e2c01967b09f","link_m3u8":"https://vip.opstream11.com/20220327/5732_46276181/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Gisaeng (Kỹ sinh) là những nghệ sĩ kỹ nữ chuyên biểu diễn ca múa cho vương thất và các gia đình quý tộc. Bộ phim kể về câu chuyện của một nhóm Gisaeng của xã hội Hàn Quốc hiện đại làm thế nào để sinh tồn trong thời đại mới. Bộ phim muốn một lần nữa thử xem xét lại vai trò của những kỹ sinh với niềm tự hào mang đầy tính văn hóa mà hiện nay đã biến mất. Trong bộ phim, giả định tồn tại một kỹ viện cao cấp nhất, chỉ tiếp những VVIP (very very important person) bậc nhất trong nước, nơi gìn giữ truyền thống của một kỹ sinh bậc nhất luôn khiêm nhường cùng với nghệ thuật và sự giáo dưỡng tốt nhất. Bộ phim xoay quanh nỗi đau, ái, ố và tình yêu của những con người xung quanh kỹ viện này.</p>","tmdb":{"type":"tv","id":"46578","season":1,"vote_average":4,"vote_count":1},"modified":"2023-07-17T07:11:50.000Z","cast":["Im Soo-hyang","Sung Hoon","Han Hye-rin","Han Jin-hee","Seo Woo-rim","Lee Dae-ro","Kim Bo-yeon","Choi Sun-ja"],"director":[],"cast_meta":[{"name":"Im Soo-hyang","name_vi":null,"name_original":"Im Soo-hyang","tmdb_id":139502,"profile":"https://image.tmdb.org/t/p/w500/cj7d9lpRtXdo3udHBOQayGgygfP.jpg","tmdb_url":"https://www.themoviedb.org/person/139502"},{"name":"Sung Hoon","name_vi":null,"name_original":"Sung Hoon","tmdb_id":1256390,"profile":"https://image.tmdb.org/t/p/w500/wGNCbshSo