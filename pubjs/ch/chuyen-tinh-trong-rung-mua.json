ng lão nơi đó. Từ đây, họ bắt đầu hành trình dây dưa đầy thú vị, cưới trước yêu sau, và con đường chinh phục trái tim qua những màn truy đuổi lẫn nhau.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"270723","season":1,"vote_average":7.2,"vote_count":6},"modified":"2025-01-10T13:42:29.000Z","cast":["Đại Cao Chính","Zheng Miao","Yuan Dasen","Quan Dinuo","Zhang Yue","Yu Xi"],"director":["袁雪凯"],"cast_meta":[{"name":"Đại Cao Chính","name_vi":"Đại Cao Chính","name_original":"Dai Gaozheng","tmdb_id":3693678,"profile":"https://image.tmdb.org/t/p/w500/yku8OmgfaJDVkEKH8laynjU54um.jpg","tmdb_url":"https://www.themoviedb.org/person/3693678"},{"name":"Zheng Miao","name_vi":null,"name_original":"Zheng Miao","tmdb_id":2646418,"profile":"https://image.tmdb.org/t/p/w500/kxDiAN0R1UYs76pgCuUQUusvRfa.jpg","tmdb_url":"https://www.themoviedb.org/person/2646418"},{"name":"Yuan Dasen","name_vi":null,"name_original":"Yuan Dasen","tmdb_id":4859097,"profile":"https://image.tmdb.org/t/p/w500/39R8r7MhYDgccDqmHrT3BRIetvl.jpg","tmdb_url":"https://www.themoviedb.org/person/4859097"},{"name":"Quan Dinuo","name_vi":null,"name_original":"Quan Dinuo","tmdb_id":4895017,"profile":"https://image.tmdb.org/t/p/w500/oEdZjubUug08WmlQBfBWy7bj6nT.jpg","tmdb_url":"https://www.themoviedb.org/person/4895017"},{"name":"Zhang Yue","name_vi":null,"name_original":"Zhang Yue","tmdb_id":4928220,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4928220"},{"name":"Yu Xi","name_vi":null,"name_original":"Yu Xi","tmdb_id":4515683,"profile":"https://image.tmdb.org/t/p/w500/rEQOIEPM8sWYVm4jlTBxtlfwe3L.jpg","tmdb_url":"https://www.themoviedb.org/person/4515683"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chuyen-tinh-trong-rung-mua.json"}