{"id":"64d4c4ad6f63d8738af28466","title":"Chuyện Tôi Và Ma Quỷ Thành Người Một Nhà","origin_name":"Marry My Dead Body","slug":"chuyen-toi-va-ma-quy-thanh-nguoi-mot-nha","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/ch/chuyen-toi-va-ma-quy-thanh-nguoi-mot-nha.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/ch/chuyen-toi-va-ma-quy-thanh-nguoi-mot-nha.webp","year":2023,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"620a2335e0fc277084dfd822","name":"Đài Loan","slug":"dai-loan"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":true,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Chuyện tôi và ma quỷ thành người một nhà","link_embed":"https://vip.opstream15.com/share/f2e624030d1505c3aabc60d22dc1022a","link_m3u8":"https://vip.opstream15.com/20230810/41085_cfba030e/index.m3u8"}]}],"time":"130 Phút","description":"Ming-Han là một cảnh sát nhiệt huyết. Một ngày nọ, trong quá trình truy bắt tội phạm cùng người đồng nghiệp xinh đẹp Zi-Qing, Ming-Han vô tình nhặt được một phong bao màu đỏ, và một nhóm người bất ngờ nhảy ra gọi anh là \"con rể\". Họ yêu cầu anh ta kết hôn với đứa con đã chết của họ. Ming-Han không thể chấp nhận quyết định này. Tuy nhiên, anh ấy sau đó anh ta gặp phải vô số sự cố xui xẻo. Điều đáng sợ hơn nữa là anh ta bắt đầu nhìn thấy người chồng ma Mao-Mao của mình. Vì vậy, Ming-Han đã tìm đến thầy để tìm cách. Để thoát khỏi Mao-Mao, Ming-Han không còn cách nào khác ngoài việc giúp anh ta thực hiện mọi mong muốn của mình. Nếu không, Mao-Mao sẽ theo anh ta mãi mãi.Đồng thời, Mao-Mao cũng đóng vai trò là đối tác của Ming-Han để giúp anh ta điều tra vụ buôn lậu ma túy. Một cuộc hành trình giả tưởng đầy tiếng cười và nước mắt giữa một người đàn ông thẳng thắn và một con ma đồng tính đã bắt đầu.","tmdb":{"type":"movie","id":"983883","season":null,"vote_average":6.989,"vote_count":188},"modified":"2023-08-10T20:56:19.000Z","cast":["Hứa Quang Hán","Austin Lin","Vương Tịnh","Tsai Chen-nan","Vương Mãn Kiều","Tou Tsung-hua","Ma Nien-Hsien","Aaron Yan","Lưu Quán Đình","Dean Tong","Flower Chen","Emma Lin","Wang Jun","He Zhong-Jun","Liao Qiu-kun"],"director":["Cheng Wei-Hao"],"cast_meta":[{"name":"Hứa Quang Hán","name_vi":"Hứa Quang Hán","name_original":"Greg Hsu","tmdb_id":1868413,"profile":"https://image.tmdb.org/t/p/w500/ddSiH7Ae5AyoxbuvXrh2S2t3LQb.jpg","tmdb_url":"https://www.themoviedb.org/person/1868413"},{"name":"Austin Lin","name_vi":null,"name_original":"Austin Lin","tmdb_id":1266721,"profile":"https://image.tmdb.org/t/p/w500/ab0t5eYYEWWDtMwN6R4VTfbSz3Q.jpg","tmdb_url":"https://www.themoviedb.org/person/1266721"},{"name":"Vương Tịnh","name_vi":"Vương Tịnh","name_original":"Gingle Wang","tmdb_id":2270252,"profile":"https://image.tmdb.org/t/p/w500/cKBSigATU0e3IUcAeYHvuAS2EFU.jpg","tmdb_url":"https://www.themoviedb.org/person/2270252"},{"name":"Tsai Chen-nan","name_vi":null,"name_original":"Tsai Chen-nan","tmdb_id":131290,"profile":"https://image.tmdb.org/t/p/w500/w4qQ44FvLmtqOtSvqurKWFjVL6H.jpg","tmdb_url":"https://www.themoviedb.org/person/131290"},{"name":"Vương Mãn Kiều","name_vi":"Vương Mãn Kiều","name_original":"Wang Man-chiao","tmdb_id":1905358,"profile":"https://image.tmdb.org/t/p/w500/ovpxjwUK7sqilD12zNuO6hnWeWE.jpg","tmdb_url":"https://www.themoviedb.org/person/1905358"},{"name":"Tou Tsung-hua","name_vi":null,"name_original":"Tou Tsung-hua","tmdb_id":1366128,"profile":"https://image.tmdb.org/t/p/w500/jfq3haXek8D4zORUy7kIO6JMsuk.jpg","tmdb_url":"https://www.themoviedb.org/person/1366128"},{"name":"Ma Nien-Hsien","name_vi":null,"name_original":"Ma Nien-Hsien","tmdb_id"