u8":"https://vip.opstream11.com/20230926/47780_9ee32b9f/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/66001333a39ce8f12be9fcf323a1a5fb","link_m3u8":"https://vip.opstream11.com/20230926/47781_273f73da/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/06d51ce32ccfc3f27c53c96c7cc67734","link_m3u8":"https://vip.opstream11.com/20230927/47806_444206f6/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/d238f0c1fbf6fccb32a3f8efcf03e3b8","link_m3u8":"https://vip.opstream11.com/20230927/47807_10ef7dcd/index.m3u8"}]}],"description":"<p>Lâm Thẩm Du là sinh viên xuất sắc của một trường đại học hàng đầu, cuối cùng lại trở thành một bà mẹ toàn thời gian. Nhưng cô đã bị phản bội và phải quay trở lại lực lượng lao động để đấu tranh giành quyền nuôi con. Trong tâm trạng nhếch nhác, cô gặp Cố Húc, bạn học cũ và hiện là một tài năng hải ngoại. Cô đối mặt với thử thách với Jiang Xi và Gu Xu, biến thành một người nội trợ chuyên nghiệp và yêu Gu Xu. Lin Shuang và Jiang Xi trải qua quá trình trưởng thành cá nhân, mở ra cuộc sống mới của riêng họ.</p>","tmdb_id":231646,"cast":["Zhang Xiaofei","Huỳnh Hiểu Minh","Zhang Jiani","Lý Trạch Phong","Zhao Xin"],"director":["Teng Huatao"],"keywords":[],"tmdb":{"type":"tv","id":"231646","season":1,"vote_average":7.3,"vote_count":3},"cast_meta":[{"name":"Zhang Xiaofei","name_vi":null,"name_original":"Zhang Xiaofei","tmdb_id":1993057,"profile":"https://image.tmdb.org/t/p/w500/9PNUlzUS7bn5p6OsRnkSCzUI1FV.jpg","tmdb_url":"https://www.themoviedb.org/person/1993057"},{"name":"Huỳnh Hiểu Minh","name_vi":"Huỳnh Hiểu Minh","name_original":"Huang Xiaoming","tmdb_id":109434,"profile":"https://image.tmdb.org/t/p/w500/pnSbq1pNDb0uLkzGOJ8zy7piBvb.jpg","tmdb_url":"https://www.themoviedb.org/person/109434"},{"name":"Zhang Jiani","name_vi":null,"name_original":"Zhang Jiani","tmdb_id":2035421,"profile":"https://image.tmdb.org/t/p/w500/cwb9IVbU2stIDl2XyWI38cAFs57.