h huống hài hước.</p><p>&nbsp;</p>","tmdb_id":233953,"cast":["Trương Vân Long","Tống Y Nhân","Zhou Yanchen","Mao Lâm Lâm","Zhou Dawei","Li Jiajie","Jing Yanjun","Chen Shuai","Lin Junyi","Lu Senbao","Zhao Zi Hui"],"director":["Song Yang"],"keywords":[],"tmdb":{"type":"tv","id":"233953","season":1,"vote_average":10,"vote_count":1},"cast_meta":[{"name":"Trương Vân Long","name_vi":"Trương Vân Long","name_original":"Leon Zhang","tmdb_id":1785826,"profile":"https://image.tmdb.org/t/p/w500/tebbwxd5F9CdDG3YzYZQJ2jC8bY.jpg","tmdb_url":"https://www.themoviedb.org/person/1785826"},{"name":"Tống Y Nhân","name_vi":"Tống Y Nhân","name_original":"Ireine Song","tmdb_id":2164942,"profile":"https://image.tmdb.org/t/p/w500/cayBhEvWshu2wXcSPPCyvNuid8s.jpg","tmdb_url":"https://www.themoviedb.org/person/2164942"},{"name":"Zhou Yanchen","name_vi":null,"name_original":"Zhou Yanchen","tmdb_id":2082540,"profile":"https://image.tmdb.org/t/p/w500/tO6R8vx3jJsaOhCRPE7PvGUWsU9.jpg","tmdb_url":"https://www.themoviedb.org/person/2082540"},{"name":"Mao Lâm Lâm","name_vi":"Mao Lâm Lâm","name_original":"Nikita Mao","tmdb_id":1518223,"profile":"https://image.tmdb.org/t/p/w500/3dAutF22fOmde3BZag3VbRWTodi.jpg","tmdb_url":"https://www.themoviedb.org/person/1518223"},{"name":"Zhou Dawei","name_vi":null,"name_original":"Zhou Dawei","tmdb_id":3154482,"profile":"https://image.tmdb.org/t/p/w500/2YZsLDUdW7plnLLogi8ijRcRSt.jpg","tmdb_url":"https://www.themoviedb.org/person/3154482"},{"name":"Li Jiajie","name_vi":null,"name_original":"Li Jiajie","tmdb_id":3216736,"profile":"https://image.tmdb.org/t/p/w500/6Sx3OqGPM1yzLgasOPbPPD3I4wl.jpg","tmdb_url":"https://www.themoviedb.org/person/3216736"},{"name":"Jing Yanjun","name_vi":null,"name_original":"Jing Yanjun","tmdb_id":2318558,"profile":"https://image.tmdb.org/t/p/w500/pxYjuRTvAUepSXBm1GGiqhJ52rW.jpg","tmdb_url":"https://www.themoviedb.org/person/2318558"},{"name":"Chen Shuai","name_vi":null,"name_original":"Chen Shuai","tmdb_id":2849862,"profile":"https://image.t