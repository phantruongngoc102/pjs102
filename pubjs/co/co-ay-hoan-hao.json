 chuyển tình thế.","tmdb":{"type":"tv","id":"252221","season":1,"vote_average":5,"vote_count":1},"modified":"2025-01-09T11:51:03.000Z","cast":["La Chính","Từ Nghệ Dương","Đỗ Vũ Thần","Dương Binh Trác","Song Yixing","Huang Xiaoge","Zhang Zhuowen","Nie Jiayue","Cao Haijun","Zhang Naitian"],"director":["Shen Wen Shuai"],"cast_meta":[{"name":"La Chính","name_vi":"La Chính","name_original":"Luo Zheng","tmdb_id":2364800,"profile":"https://image.tmdb.org/t/p/w500/ubLHizRd9jDhjfp2wD0me0EwCE7.jpg","tmdb_url":"https://www.themoviedb.org/person/2364800"},{"name":"Từ Nghệ Dương","name_vi":"Từ Nghệ Dương","name_original":"Xu Yiyang","tmdb_id":3172419,"profile":"https://image.tmdb.org/t/p/w500/yRgNafX3IvoewWl3GeVTX2kITjb.jpg","tmdb_url":"https://www.themoviedb.org/person/3172419"},{"name":"Đỗ Vũ Thần","name_vi":"Đỗ Vũ Thần","name_original":"Du Yuchen","tmdb_id":2787677,"profile":"https://image.tmdb.org/t/p/w500/eLfjLmnyohzJ1Eio5jb6INDtaGC.jpg","tmdb_url":"https://www.themoviedb.org/person/2787677"},{"name":"Dương Binh Trác","name_vi":"Dương Binh Trác","name_original":"Yang Bingzhuo","tmdb_id":3163127,"profile":"https://image.tmdb.org/t/p/w500/4Iopwzhp3W8QIiOdTHz7NC1vQ4G.jpg","tmdb_url":"https://www.themoviedb.org/person/3163127"},{"name":"Song Yixing","name_vi":null,"name_original":"Song Yixing","tmdb_id":2513786,"profile":"https://image.tmdb.org/t/p/w500/awrzaNLJ2T9ltQ4q4xUUiOzKRm.jpg","tmdb_url":"https://www.themoviedb.org/person/2513786"},{"name":"Huang Xiaoge","name_vi":null,"name_original":"Huang Xiaoge","tmdb_id":3286611,"profile":"https://image.tmdb.org/t/p/w500/4g4FqokxbWVJolIRdSZ3LYGSmgH.jpg","tmdb_url":"https://www.themoviedb.org/person/3286611"},{"name":"Zhang Zhuowen","name_vi":null,"name_original":"Zhang Zhuowen","tmdb_id":2062752,"profile":"https://image.tmdb.org/t/p/w500/b7xRQWwt4oCkxJdIU5Eh6TSB0Ph.jpg","tmdb_url":"https://www.themoviedb.org/person/2062752"},{"name":"Nie Jiayue","name_vi":null,"name_original":"Nie Jiayue","tmdb_id":5408163,"profile":null,"tmdb_url"