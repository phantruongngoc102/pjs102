pstream15.com/share/33b5450d73826812cafc8a866624da7a","link_m3u8":"https://vip.opstream15.com/20220505/11281_2575fe51/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/f152516615efd05cf4b4903b03d4a45d","link_m3u8":"https://vip.opstream15.com/20220505/11283_75b24670/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/f657fe6129962ac0a912607080db1d2c","link_m3u8":"https://vip.opstream15.com/20220505/11286_fecf5b63/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/ae4954bd7d1f28d4b124063731338ae0","link_m3u8":"https://vip.opstream15.com/20220505/11287_2fe8d423/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/99ef8a644d84701c79bad8f4c3a7b4d7","link_m3u8":"https://vip.opstream15.com/20220505/11290_b69e375f/index.m3u8"}]}],"description":"<p>Trên thế gian này có rất nhiều chủng tộc mà con người không biết đến, ngoại trừ nhân loại và những động vật thường gặp có thể thấy ở mọi nơi. Còn có những loài như “thần”, tinh linh, thành thú hay dị thú được con người coi là thần thoại, ma tộc, yêu quái, khiến con người cảm thấy sợ hãi, và còn có nhiều loại linh thể vô cùng kỳ lạ khác. \"Nhân loại\" là loài yếu đuối nhất, dễ gặp tổn thương nhất trong hệ thống này, nhưng lại loài có sức sống ngoan cường nhất. Loài người phân ra hai loại, loại thứ nhất chính là những người bình thường có năng lực cực kỳ bình thường. Loại thứ hai là những người lính, sát thủ, những tên côn đồ đã trải qua sự huấn luyện đặc biệt, nhưng vẫn còn một loại người thứ ba nữa mà không ai biết...</p>","tmdb_id":101141,"cast":["Châu Tấn","Huang Jue","Huệ Anh Hồng","Angie Chiu Nga-Chi","Chen Si-Nuo","Kim Sĩ Kiệt","Đồng Dao","Qu Gaowei","Elaine Cai","Chiang Yun-Lin","Zeng Yixuan","Sheng Gangshuai"],"director":["Lưu Biểu"],"keywords":[],"tmdb":{"type":"tv","id":"101141","season":1,"vote_average":7.3,"vote_count":3},"cast_meta":[{"name":"Châu Tấn","name_vi":"Châu Tấn","name_original