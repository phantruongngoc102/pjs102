230619/156_4548ed0f/index.m3u8"},{"name":"16","slug":"16","filename":"Co Ay Va Loi Noi Doi 16","link_embed":"https://vip.opstream13.com/share/82aa4b0af34c2313a562076992e50aa3","link_m3u8":"https://vip.opstream13.com/20230619/162_c9307a16/index.m3u8"},{"name":"17","slug":"17","filename":"Co Ay Va Loi Noi Doi 17","link_embed":"https://vip.opstream13.com/share/bd4c9ab730f5513206b999ec0d90d1fb","link_m3u8":"https://vip.opstream13.com/20230619/161_dc2d00e7/index.m3u8"},{"name":"18","slug":"18","filename":"Co Ay Va Loi Noi Doi 18","link_embed":"https://vip.opstream13.com/share/b73ce398c39f506af761d2277d853a92","link_m3u8":"https://vip.opstream13.com/20230619/160_c00b9722/index.m3u8"},{"name":"19","slug":"19","filename":"Co Ay Va Loi Noi Doi 19","link_embed":"https://vip.opstream13.com/share/0777d5c17d4066b82ab86dff8a46af6f","link_m3u8":"https://vip.opstream13.com/20230619/163_327329c6/index.m3u8"},{"name":"20","slug":"20","filename":"Co Ay Va Loi Noi Doi 20","link_embed":"https://vip.opstream13.com/share/0e65972dce68dad4d52d063967f0a705","link_m3u8":"https://vip.opstream13.com/20230622/198_750d2801/index.m3u8"}]}],"time":"10 phút/ tập","description":"<p>Zheng Xue Er, một phụ nữ mạnh mẽ với sự nghiệp thành công, không có kế hoạch kết hôn. Tuy nhiên, mẹ cô bị bệnh nặng, và để trấn an bà rằng bà sẽ tìm được một người chồng tử tế, Xue Er quyết định hạ thấp tiêu chuẩn chọn bạn đời và tìm một người lương thiện ổn định để kết hôn và sinh con càng sớm càng tốt. Dưới sự giới thiệu của người bạn thân Mi Li Li, cô gặp Tống Hạo Thiên và kết hôn với anh trong chớp nhoáng.</p><p>Chẳng mấy chốc, mẹ cô qua đời và Zheng Xue Er nỗ lực để đạt được hạnh phúc trong gia đình nhỏ mới của mình. Sau khi kết hôn, Zheng Xue Er bị vô sinh vì lý do thể chất và mẹ chồng cô vô cùng không hài lòng về điều này. Nhưng kể cả khi cô mang thai thành công nhờ công nghệ ống nghiệm, thái độ của mẹ chồng đối với cô vẫn không hề cải thiện. Vẫn chưa đủ, phụ nữ sớm phát hiện ra rằng Hao Tian, người thích công khai yêu vợ, đã lừa dối cô với bạn của cô và cả hai lên kế hoạch chiếm đoạt tài sản của cô.</p><p>Ban đầu, chỉ muốn bí mật điều tra chồng ngoại tình, Zheng Xue Er, khi biết rằng cái chết của mẹ cô cũng liên quan đến chồng cô, bị ám ảnh bởi sự cần thiết phải trả thù cho bà và trả giá cho tất cả những điều độc ác, hai người này đã làm đến cô, cô bắt đầu kế hoạch trả thù của mình.</p>","tmdb":{"type":"tv","id":"229079","season":1,"vote_average":0,"vote_count":0},"modified":"2023-06-22T15:28:54.000Z","cast":["Feng Xi Yao","Hu Wei","Yu Yi Fu"],"director":[],"cast_meta":[{"name":"Feng Xi Yao","name_vi":null,"name_original":"Feng Xi Yao"},{"name":"Hu Wei","name_vi":null,"name_original":"Hu Wei"},{"name":"Yu Yi Fu","name_vi":null,"name_original":"Yu Yi Fu"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-ay-va-loi-noi-doi.json"}