.com/20220523/16041_180a211d/index.m3u8"},{"name":"22","slug":"22","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-22","link_embed":"https://vip.opstream15.com/share/b1f391b61183d032ea38054238ee092a","link_m3u8":"https://vip.opstream15.com/20220523/16044_05114924/index.m3u8"},{"name":"23","slug":"23","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-23","link_embed":"https://vip.opstream15.com/share/1e56fad414ee7e1760cb0dc170db7436","link_m3u8":"https://vip.opstream15.com/20220523/16048_b4d53420/index.m3u8"},{"name":"24","slug":"24","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-24","link_embed":"https://vip.opstream15.com/share/ccda428c489a0d3bf7a1b8c432b535cf","link_m3u8":"https://vip.opstream15.com/20220523/16052_d599495c/index.m3u8"},{"name":"25","slug":"25","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-25","link_embed":"https://vip.opstream15.com/share/55a85e71b468ef171a7d4509b3f35f36","link_m3u8":"https://vip.opstream15.com/20220523/16056_254970bc/index.m3u8"},{"name":"26","slug":"26","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-26","link_embed":"https://vip.opstream15.com/share/6daff3d43615b65709577a08c6adab4e","link_m3u8":"https://vip.opstream15.com/20220523/16059_33b387d7/index.m3u8"},{"name":"27","slug":"27","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-27","link_embed":"https://vip.opstream15.com/share/bbeca2458adc54f3a17a309729c167fa","link_m3u8":"https://vip.opstream15.com/20220523/16063_455971e1/index.m3u8"},{"name":"28","slug":"28","filename":"co-ban-gai-toi-khong-the-yeu-miss-unlovable-tap-28","link_embed":"https://vip.opstream15.com/share/40e244ce06f98f84c452989ca388b8a2","link_m3u8":"https://vip.opstream15.com/20220523/16067_069efac2/index.m3u8"}]}],"time":"","description":"<p>Năm 15 tuổi, bởi một vụ hiểu lầm trời ơi đất hỡi mà Đinh Tiểu Nhu bị một người phụ nữ mang thai đến bắt gian “nguyền rủa” cô cả đời này sẽ không có được hạnh phúc. Không ngờ điều đó lại thành sự thật, và trong vòng 10 năm qua cô đã 'bị đá' 30 lần. Càng quá đáng hơn nữa là, người yêu cũ đều sẽ nhanh chóng tìm được tình yêu đích thực sau khi chia tay. Đinh Tiểu Nhu nản lòng và đến tham dự buổi chia sẻ ở quán cà phê 'Không thể yêu đương', tại đây cô gặp được Trì Tín, một anh chàng đạo diễn không tin vào lời nguyền. Trì Tín nhờ Tiểu Nhu hẹn hò với bạn thân của mình để 'giải ế' anh chàng. Tuy nhiên, không lâu sau đó, bạn thân của Trì Tín tìm được tình yêu đích thực và kết hôn, còn Trì Tín thì không biết đã 'đổ' cô nàng Tiểu Nhu từ lúc nào.</p>","tmdb":{"type":"tv","id":"94453","season":1,"vote_average":7,"vote_count":4},"modified":"2022-05-27T19:12:02.000Z","cast":["Timmy Xu","Qiao Xin","Zhou Yixuan","Wang Jianing","Jill Hsu","Tang Zhen","Peggy Ji","Hao Shuang"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Timmy Xu","name_vi":null,"name_original":"Timmy Xu","tmdb_id":1591362,"profile":"https://image.tmdb.org/t/p/w500/mntBCVt07NMqVafuBKOc9kCFl9U.jpg","tmdb_url":"https://www.themoviedb.org/person/1591362"},{"name":"Qiao Xin","name_vi":null,"name_original":"Qiao Xin","tmdb_id":1696484,"profile":"https://image.tmdb.org/t/p/w500/eM3uFeHsfXzRJq2V13R7qrN7tXh.jpg","tmdb_url":"https://www.themoviedb.org/person/1696484"},{"name":"Zhou Yixuan","name_vi":null,"name_original":"Zhou Yixuan","tmdb_id":1594629,"profile":"https://image.tmdb.org/t/p/w500/fKNMpUhZjAgrYcmES8MCHfo39V6.jpg","tmdb_url":"https://www.themoviedb.org/person/1594629"},{"name":"Wang Jianing","name_vi":null,"name_original":"Wang Jianing","tmdb_id":2091144,"profile":"https://image.tmdb.org/t/p/w500/fqUDREqhxuOS2xHIuUE9z7ryWUl.jpg","tmdb_url":"https://www.themoviedb.org/person/2091144"},{"name":"Jill Hsu","name_vi":null,"name_original":"Jill Hsu","tmdb_id":1626670,"profile":"https://image.tmdb.org/t/p/w500/dAwKWkYPtkwXqfA15OhDsHklDtJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1626670"},{"name":"Tang Zhen","name_vi":null,"name_original":"Tang Zhen","tmdb_id":3469723,"profile":"https://image.tmdb.org/