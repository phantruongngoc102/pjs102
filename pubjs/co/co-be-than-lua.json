{"id":"62791a5e3a2c0c6289c09b3a","title":"Cô Bé Thần Lửa","origin_name":"Firestarter","slug":"co-be-than-lua","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/co/co-be-than-lua.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/co/co-be-than-lua.webp","year":1984,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"},{"id":"620a2293e0fc277084dfd489","name":"Phiêu Lưu","slug":"phieu-luu"},{"id":"620a229be0fc277084dfd4dd","name":"Khoa Học","slug":"khoa-hoc"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"co-be-than-lua-firestarter","link_embed":"https://vip.opstream12.com/share/0b49b88c68f7ecbdb73f50496c084a1e","link_m3u8":"https://vip.opstream12.com/20220509/14989_db8f0c24/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Andrew và Vicky McGee đã gặp gỡ nhau khi tham gia vào một cuộc thí nghiệm nhằm kiếm tiền nuôi thân. Đây là cuộc thí nghiệm được tiến hành bằng cách thử khâm liệm con người để tìm ra thế giới bí mật của tâm linh. Sau đó, cả hai tổ chức đám cưới và sinh ra một bé gái xinh xắn, Charile. Kết quả của cuộc thí nghiệm đã ảnh hưởng đến Charile, khiến cô bé có khả năng đốt cháy mọi thứ chỉ bằng một ý nghĩ. Andy cũng phát hiện ra khả năng kỳ lạ của mình bằng cách biến mọi người xung quanh phải làm theo mong muốn của cô. Gia đình đặc biệt này một lần nữa lại rơi vào tầm ngắm của tiến sĩ Joseph Wanless, ông dự tính sẽ tiếp tục đem họ làm thí nghiệm trước khi giết họ.</p>","tmdb":{"type":"movie","id":"11495","season":null,"vote_average":6.255,"vote_count":743},"modified":"2023-0