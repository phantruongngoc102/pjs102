n xâm nhập vào phe đối lập Nhật Bản và sau nhiều khó khăn cuối cùng trở thành một đặc vụ ngầm trong đội ngũ tình báo Đảng ở Gia Tây. i Nhật Bản, Cận Đường Lợi Nam, để phát hiện ra kẻ phản bội thật sự trong Đảng, và loại bỏ hắn.","tmdb_id":251599,"cast":["Tăng Thuấn Hy","Trương Tụng Văn","Trần Đô Linh","Vương Ngọc Văn","Trương Phong Nghị","Chu Nhất Vi"],"director":["Lin Lisheng"],"keywords":[],"tmdb":{"type":"tv","id":"251599","season":1,"vote_average":6.3,"vote_count":3},"cast_meta":[{"name":"Tăng Thuấn Hy","name_vi":"Tăng Thuấn Hy","name_original":"Joseph Zeng","tmdb_id":1803092,"profile":"https://image.tmdb.org/t/p/w500/hfMNwzZv7SxJ6d8gk8rhPZdg4C8.jpg","tmdb_url":"https://www.themoviedb.org/person/1803092"},{"name":"Trương Tụng Văn","name_vi":"Trương Tụng Văn","name_original":"Zhang Songwen","tmdb_id":1086250,"profile":"https://image.tmdb.org/t/p/w500/rz1mKSiuV5LuY0l0Y6HRGJGBeED.jpg","tmdb_url":"https://www.themoviedb.org/person/1086250"},{"name":"Trần Đô Linh","name_vi":"Trần Đô Linh","name_original":"Chen Duling","tmdb_id":1476992,"profile":"https://image.tmdb.org/t/p/w500/awVbnhkLiGuv6h6axIb5oNgRJGT.jpg","tmdb_url":"https://www.themoviedb.org/person/1476992"},{"name":"Vương Ngọc Văn","name_vi":"Vương Ngọc Văn","name_original":"Wang Yuwen","tmdb_id":1836775,"profile":"https://image.tmdb.org/t/p/w500/lVmpKpml6evG5gWciRELbgdhvII.jpg","tmdb_url":"https://www.themoviedb.org/person/1836775"},{"name":"Trương Phong Nghị","name_vi":"Trương Phong Nghị","name_original":"Zhang Fengyi","tmdb_id":65277,"profile":"https://image.tmdb.org/t/p/w500/l3PtQzEU84l7B9XA6SitAGIIJqH.jpg","tmdb_url":"https://www.themoviedb.org/person/65277"},{"name":"Chu Nhất Vi","name_vi":"Chu Nhất Vi","name_original":"Zhou Yiwei","tmdb_id":1174685,"profile":"https://image.tmdb.org/t/p/w500/vvHVmjIhMIS7baQsmj5z0cy7hz1.jpg","tmdb_url":"https://www.themoviedb.org/person/1174685"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/co/co-chau.json"}