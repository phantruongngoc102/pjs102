p tức phải lòng anh mặc dù chưa hề thấy mặt. Sau đó, cô biết được rằng chàng trai đó chính là Kwon Hyuk Jun (Lee Dong Gun) - một công tố viên, người mà cô đã được ông nội hứa hôn cho. Mặc dù nhỏ hơn anh đến 10 tuổi nhưng Jung Suk vẫn quyết định sẽ kết hôn với anh, trở thành một bà nội trợ đảm đang thay vì vào đại học. Tuy nhiên, sự khác nhau về tuổi tác và suy nghĩ giữa hai người đã gây ra nhiều phen dở khóc dở cười. Hơn nữa, cuộc hôn nhân của họ còn gặp không ít trắc trở khi mối tình đầu của Hyuk Jun trở về và quyết giành lại anh từ tay Jung Suk.","tmdb_id":14023,"cast":["Lee Dong-gun","Han Ji-hye","Lee In","Kim Hae-sook","Lee Da-hee","Lee Eun-ju","Jung Kyung-ho","Ko Kyu-pil"],"director":["Kim Myung-wook"],"keywords":[],"tmdb":{"type":"tv","id":"14023","season":1,"vote_average":6.3,"vote_count":7},"cast_meta":[{"name":"Lee Dong-gun","name_vi":null,"name_original":"Lee Dong-gun","tmdb_id":1233804,"profile":"https://image.tmdb.org/t/p/w500/55TYoEXAusUOSnZYh8Qy8MN6dPa.jpg","tmdb_url":"https://www.themoviedb.org/person/1233804"},{"name":"Han Ji-hye","name_vi":null,"name_original":"Han Ji-hye","tmdb_id":127710,"profile":"https://image.tmdb.org/t/p/w500/z93b2rusGoTrqJnIPAREXX1tHvk.jpg","tmdb_url":"https://www.themoviedb.org/person/127710"},{"name":"Lee In","name_vi":null,"name_original":"Lee In","tmdb_id":1510533,"profile":"https://image.tmdb.org/t/p/w500/yjvG9Q9bSv222p96m0WScZRFviB.jpg","tmdb_url":"https://www.themoviedb.org/person/1510533"},{"name":"Kim Hae-sook","name_vi":null,"name_original":"Kim Hae-sook","tmdb_id":93252,"profile":"https://image.tmdb.org/t/p/w500/dt5bmKeG7qbvDwHrxFZFxiGc9fZ.jpg","tmdb_url":"https://www.themoviedb.org/person/93252"},{"name":"Lee Da-hee","name_vi":null,"name_original":"Lee Da-hee","tmdb_id":123807,"profile":"https://image.tmdb.org/t/p/w500/uaZ0kMQOEKxxtfH9IWecBZ8c4DI.jpg","tmdb_url":"https://www.themoviedb.org/person/123807"},{"name":"Lee Eun-ju","name_vi":null,"name_original":"Lee Eun-ju","tmdb_id":70337,"profile":"https://image.tmdb