a0/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/5fcc629edc0cfa360016263112fe8058","link_m3u8":"https://vip.opstream14.com/20220426/9762_9ffa8aea/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/e720a515b9da87288d569caa68f42bc1","link_m3u8":"https://vip.opstream14.com/20220426/9767_37c69d92/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream14.com/share/0aa2ebf701adab64a123a01be6dcc018","link_m3u8":"https://vip.opstream14.com/20220426/9764_97b173e2/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream14.com/share/6de0f2761a44ff1e2ca60131058d8297","link_m3u8":"https://vip.opstream14.com/20220426/9765_c91a4c8a/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream14.com/share/86636b6605b2bcb9a738d0e9bbce3c43","link_m3u8":"https://vip.opstream14.com/20220426/9766_7b9bef30/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream14.com/share/e7acfd79777f2e49cfd3c2e803c44a3b","link_m3u8":"https://vip.opstream14.com/20220426/9773_8b562dd4/index.m3u8"}]}],"description":"<p>Câu chuyện xoay quanh cô bé Hatori Chise 15 tuổi. Với thể chất đặc biệt, cô bé luôn nhìn thấy và thu hút những sinh vật quái lạ, chúng luôn nhăm nhe để ăn thịt cô. Cũng chính vì thế mà gia đình Chise đổ vỡ, ba mang theo em trai bỏ đi, Chise bị mẹ mình chối bỏ rồi bà tìm đến cái chết. Chise phải sống vật vờ từ nhà họ hàng này sang nhà họ hàng khác. Khi đã đến ngượng chịu đựng, Chise tìm đến cái chết nhưng rồi được một ông chú lạ đến bắt chuyện. Thế rồi Chise quyết định bán mình cho vị pháp sư phi nhân. Từ đó, cuộc đời Chise đã bước sang trang mới, những tưởng cuối cùng cũng tìm được mái ấm thì Chise lại phải đánh đổi nhiều thứ, thậm chí là tính mạng để bảo về gia đình bé nhỏ mới của mình. Liệu Chise sẽ giữ được hạnh phúc cho bản thân chăng?</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-dau-phap-su.json","tmdb_checked":false}