8d8297","link_m3u8":"https://vip.opstream14.com/20220426/9765_c91a4c8a/index.m3u8"},{"name":"23","slug":"23","filename":"Cô Dâu Pháp Sư Tập 23 - Không tìm thì không thấy","link_embed":"https://vip.opstream14.com/share/86636b6605b2bcb9a738d0e9bbce3c43","link_m3u8":"https://vip.opstream14.com/20220426/9766_7b9bef30/index.m3u8"},{"name":"24","slug":"24","filename":"Cô Dâu Pháp Sư Tập 24 - Dĩ hòa vi quý","link_embed":"https://vip.opstream14.com/share/e7acfd79777f2e49cfd3c2e803c44a3b","link_m3u8":"https://vip.opstream14.com/20220426/9773_8b562dd4/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Câu chuyện xoay quanh cô bé Hatori Chise 15 tuổi. Với thể chất đặc biệt, cô bé luôn nhìn thấy và thu hút những sinh vật quái lạ, chúng luôn nhăm nhe để ăn thịt cô. Cũng chính vì thế mà gia đình Chise đổ vỡ, ba mang theo em trai bỏ đi, Chise bị mẹ mình chối bỏ rồi bà tìm đến cái chết. Chise phải sống vật vờ từ nhà họ hàng này sang nhà họ hàng khác. Khi đã đến ngượng chịu đựng, Chise tìm đến cái chết nhưng rồi được một ông chú lạ đến bắt chuyện. Thế rồi Chise quyết định bán mình cho vị pháp sư phi nhân. Từ đó, cuộc đời Chise đã bước sang trang mới, những tưởng cuối cùng cũng tìm được mái ấm thì Chise lại phải đánh đổi nhiều thứ, thậm chí là tính mạng để bảo về gia đình bé nhỏ mới của mình. Liệu Chise sẽ giữ được hạnh phúc cho bản thân chăng?</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-07-24T09:50:51.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-dau-phap-su.json","keywords":[],"tmdb_checked":false}