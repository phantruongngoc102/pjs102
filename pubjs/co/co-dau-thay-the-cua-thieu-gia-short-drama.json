18568_2b9417a4/index.m3u8"},{"name":"94","slug":"94","link_embed":"https://vip.opstream-short.com/share/35dcd930df68a3b6194ad8764644721d","link_m3u8":"https://vip.opstream-short.com/20251111/18569_35dcd930/index.m3u8"},{"name":"95","slug":"95","link_embed":"https://vip.opstream-short.com/share/8eb3926a025bb86899f452f3dd675f04","link_m3u8":"https://vip.opstream-short.com/20251111/18570_8eb3926a/index.m3u8"},{"name":"96","slug":"96","link_embed":"https://vip.opstream-short.com/share/1424b9b97976fd6a10e46c9f8aa72597","link_m3u8":"https://vip.opstream-short.com/20251111/18571_1424b9b9/index.m3u8"},{"name":"97","slug":"97","link_embed":"https://vip.opstream-short.com/share/595afbd7f5a99efd71556d99b39c268e","link_m3u8":"https://vip.opstream-short.com/20251111/18572_595afbd7/index.m3u8"}]}],"description":"<p>Kiếp trước, Bạch Cẩm tin nhầm người - tên khốn Cố Tầu Cảnh và em gái Bạch Tư Doanh. Chỉ khi họ phản bội và giết cô, cô mới nhận ra mẹ ruột bị mẹ kế đầu độc. Chết với lòng hận thù, cô được tái sinh với căm phẫn sâu sắc. Kiếp này, cô từ chối làm nạn nhân bất lực và tự nguyện thay em gái cưới Dạ Bách Dực ốm yếu. Đêm tân hôn, Dạ Bách Dực bị đầu độc thuốc kích dục và rơi vào nguy hiểm. Sự cứu giúp kịp thời của Bạch Cẩm không chỉ cứu anh mà còn mang đến khởi đầu khác cho cuộc hôn nhân sắp đặt này. Ngày hôm sau, Dạ Bách Dực thể hiện bản chất mạnh mẽ thật sự bằng cách đưa Bạch Cẩm về nhà, phá tan tin đồn về sự yếu đuối của anh. Thấy vận may bất ngờ của Bạch Cẩm trong hôn nhân, Bạch Tư Doanh và mẹ kế bùng cháy ghen tức và bắt đầu âm mưu các kế hoạch. Bạch Cẩm biết đây chỉ là khởi đầu của sự báo thù. Cô sẽ tạo dựng vị thế trong gia đình giàu có này như thế nào khi đối mặt với các cuộc tấn công của em gái và mẹ kế? Cô sẽ khám phá sự thật kiếp trước và đạt được báo thù ra sao? Và Dạ Bách Dực, người đàn ông có vẻ yếu đuối nhưng sắc bén này, sẽ đóng vai trò gì trong vở kịch báo thù này? Tia lửa nào sẽ bùng nổ giữa họ? Một câu chuyện về tình yêu, hận thù và âm mưu bắt đầu.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-dau-thay-the-cua-thieu-gia-short-drama.json","tmdb_checked":false}