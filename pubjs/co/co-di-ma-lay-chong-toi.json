f3ff5/index.m3u8"},{"name":"15","slug":"15","filename":"Marry My Husband 15","link_embed":"https://vip.opstream13.com/share/3f5ee243547dee91fbd053c1c4a845aa","link_m3u8":"https://vip.opstream13.com/20240228/3058_24a332ae/index.m3u8"},{"name":"16","slug":"16","filename":"Marry My Husband 16","link_embed":"https://vip.opstream13.com/share/cc431fd7ec4437de061c2577a4603995","link_m3u8":"https://vip.opstream13.com/20240228/3059_3d89b0b9/index.m3u8"}]}],"time":"80 phút/tập","description":"<p>Khi Ji-won, một bệnh nhân ung thư 37 tuổi, bước vào gặp chồng và cũng là bạn thân của cô, cô nhận ra cả cuộc đời mình chỉ là một lời nói dối. Tệ hơn nữa, cô lại chết một cách bi thảm dưới tay chồng mình. Liệu mọi chuyện có khác đi nếu cô ấy đưa ra những lựa chọn khác? May mắn thay cho Ji-won, cô có cơ hội viết lại số phận của mình khi được tái sinh thành bản thân lúc trẻ. Lần này, cô thề sẽ sống một cuộc sống hạnh phúc. Nhưng trước hết là sự trả thù. Kế hoạch của cô ấy? Để gả người bạn thân cũ của mình cho người chồng dối trá, lừa dối của mình.</p>","tmdb":{"type":"tv","id":"221851","season":1,"vote_average":8.4,"vote_count":638},"modified":"2024-02-28T16:46:08.000Z","cast":["Park Min-young","Na In-woo","Lee Yi-kyung","Song Ha-yoon","Lee Gi-kwang","Gong Min-jeung","Kwon BoA","Choi Gyu-ri","Kim Joong-hee","Ha Do-kwon","Lee Ha-joo","Moon Sung-keun","Jung Kyung-soon","Jeong Seok-yong","Cho Jin-se"],"director":["Park Won-gook"],"cast_meta":[{"name":"Park Min-young","name_vi":null,"name_original":"Park Min-young","tmdb_id":1234603,"profile":"https://image.tmdb.org/t/p/w500/5Op0Gx0DULFLHtGdWVdqnYdwkAS.jpg","tmdb_url":"https://www.themoviedb.org/person/1234603"},{"name":"Na In-woo","name_vi":null,"name_original":"Na In-woo","tmdb_id":2935390,"profile":"https://image.tmdb.org/t/p/w500/75rOHTfq7M3E29D88mvYQf1cS0M.jpg","tmdb_url":"https://www.themoviedb.org/person/2935390"},{"name":"Lee Yi-kyung","name_vi":null,"name_original":"Lee Yi-kyung","tmdb_id":1330446,"profile":"https://image.tmdb.org/t