k_m3u8":"https://vip.opstream15.com/20220421/6514_c5db0e9c/index.m3u8"},{"name":"22","slug":"22","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-22","link_embed":"https://vip.opstream15.com/share/530468698061c34fe19ecbdf1a5fb950","link_m3u8":"https://vip.opstream15.com/20220421/6516_f3e36542/index.m3u8"},{"name":"23","slug":"23","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-23","link_embed":"https://vip.opstream15.com/share/c646a3b8b24cb64c1314c03292fff0fd","link_m3u8":"https://vip.opstream15.com/20220421/6517_17c53091/index.m3u8"},{"name":"24","slug":"24","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-24","link_embed":"https://vip.opstream15.com/share/80fee67c8a4c4989bf8a580b4bbb0cd2","link_m3u8":"https://vip.opstream15.com/20220421/6520_06dfa77a/index.m3u8"},{"name":"25","slug":"25","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-25","link_embed":"https://vip.opstream15.com/share/c900fe92840c527a0c54f28640c2f254","link_m3u8":"https://vip.opstream15.com/20220421/6522_b5248b0e/index.m3u8"},{"name":"26","slug":"26","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-26","link_embed":"https://vip.opstream15.com/share/534488729ab74ff059356cb58c9907ef","link_m3u8":"https://vip.opstream15.com/20220421/6524_c6fbddc5/index.m3u8"},{"name":"27","slug":"27","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-27","link_embed":"https://vip.opstream15.com/share/40afd3a37cca05efe623b7509855c73a","link_m3u8":"https://vip.opstream15.com/20220421/6526_e16d8819/index.m3u8"},{"name":"28","slug":"28","filename":"co-gai-den-tu-dai-duong-my-love-from-the-ocean-tap-28","link_embed":"https://vip.opstream15.com/share/ac10ec1ace51b2d973cd87973a98d3ab","link_m3u8":"https://vip.opstream15.com/20220421/6529_bc0382f7/index.m3u8"}]}],"time":"45 Phút / Tập","description":"<p>Trong một sự cố trúng độc, Trì Lục nhận được sự uỷ thác, nguỵ trang thành học giả đến Hải Nham, từ đó phá huỷ cuộc sống bình yên của Đới Tịch. Cùng với sự tiến triển của nhiệm vụ, tình cảm của hai người cũng dần ấm áp hơn. Một lần thầy Đới, ba của Đới Tịch mất tích, thân phận của Trì Lục bị lộ, mọi thứ cứ quấn lấy Đới Tịch, từ đó cơ thể cô cũng có những thay đổi. Trong quá trình tìm kiếm cha mình, Đới Tịch cũng dần mở ra được bí mật về thân thế mình. Cùng lúc đó, thảm án ở thuỷ cung đảo của tộc người cá 20 năm trước cũng được vạch ra. Tộc người cá vất vả tìm kiếm nước mắt người cá, không ngờ lại ở trong người của Trì Lục. Giữa tình yêu và bộ tộc, giữa tín nhiệm và hoài nghi, công chúa người cá Đới Tịch dần dần rơi vào tuyệt vọng. Hung thủ phía sau cái chết của Trình Hoành Vĩ, khiến Đới Tịch và Trì Lục cùng những người bạn của họ phải đứng ở mặt đối lập. Khoảnh khắc Đới Tịch quyết định gánh lên mình trọng trách của bộ tộc, tình cảm của cô và Trì Lục rồi sẽ về đâu ?</p>","tmdb":{"type":"tv","id":"96637","season":1,"vote_average":7,"vote_count":2},"modified":"2023-06-30T19:22:34.000Z","cast":["Châu Vũ Đồng","Lý Hoành Nghị","Chen Meilin"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Châu Vũ Đồng","name_vi":"Châu Vũ Đồng","name_original":"Zhou Yutong","tmdb_id":1782333,"profile":"https://image.tmdb.org/t/p/w500/anylalvMOzuctoNu2Wn36ZoyW6G.jpg","tmdb_url":"https://www.themoviedb.org/person/1782333"},{"name":"Lý Hoành Nghị","name_vi":"Lý Hoành Nghị","name_original":"Li Hongyi","tmdb_id":1672871,"profile":"https://image.tmdb.org/t/p/w500/wVz4aIGMONhqjzADzKfBcCMPpFy.jpg","tmdb_url":"https://www.themoviedb.org/person/1672871"},{"name":"Chen Meilin","name_vi":null,"name_original":"Chen Meilin","tmdb_id":1929217,"profile":"https://image.tmdb.org/t/p/w500/2OBdkEdeosQep607Z9ZeD3X9VZj.jpg","tmdb_url":"https://www.themoviedb.org/person/1929217"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-gai-den-tu-dai-duong.json"}