p.opstream10.com/share/4861650dafeb90c197212d5c90e60a7b","link_m3u8":"https://vip.opstream10.com/20220519/15479_ad7ea5f8/index.m3u8"},{"name":"27","slug":"27","filename":"co-gai-ngoai-hanh-tinh-sai-tieu-that-thuyet-minh-my-girlfriend-is-an-alien-tap-27","link_embed":"https://vip.opstream10.com/share/9a9c759a3bc07fef5ebaf9d2eea33dc1","link_m3u8":"https://vip.opstream10.com/20220519/15480_ad70cf75/index.m3u8"},{"name":"28","slug":"28","filename":"co-gai-ngoai-hanh-tinh-sai-tieu-that-thuyet-minh-my-girlfriend-is-an-alien-tap-28","link_embed":"https://vip.opstream10.com/share/abe1f87b60e4b5d2798c7bad84b1905e","link_m3u8":"https://vip.opstream10.com/20220519/15481_14e244bc/index.m3u8"}]}],"time":"","description":"<p>Cô Gái Ngoài Hành Tinh Sài Tiểu Thất​ kể về cô nàng Sài Tiểu Thất tới từ hành tinh \"Cape Town\" xuyên không đến trái đất và vô tình gặp Phương Lãnh - là một tổng tài cao lãnh, tài giỏi. Tuy nhiên Phương Lãnh lại có một căn bênh kì lạ là cứ mỗi khi trời mưa quên đi những người khác giới đã từng xuất hiên trong cuộc đời mình. Ở trái đất Tiểu Thất đã vô tình để mất dữ liệu và bị giữ lại. Để sống sót ở trái đất Tiểu Thất đã phải sử dụng rất nhiều siêu năng lực của mình, hết lần này đến lần khác tự mình giải quyết mọi khó khăn rắc rối. Từ đó mở ra câu chuyện tình vô cùng hài hước mà không kém phần lãng mạn.</p>","tmdb":{"type":"tv","id":"92779","season":1,"vote_average":7.8,"vote_count":49},"modified":"2022-05-20T07:23:37.000Z","cast":["Vạn Bằng","Từ Chí Hiền","Dương Nguyệt"],"director":["Đặng Khoa","Cao Tông Khải"],"cast_meta":[{"name":"Vạn Bằng","name_vi":null,"name_original":"Vạn Bằng"},{"name":"Từ Chí Hiền","name_vi":null,"name_original":"Từ Chí Hiền"},{"name":"Dương Nguyệt","name_vi":null,"name_original":"Dương Nguyệt"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-gai-ngoai-hanh-tinh-sai-tieu-that.json"}