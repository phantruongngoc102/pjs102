.opstream-short.com/20251106/10274_2779fda0/index.m3u8"},{"name":"82","slug":"82","filename":"Cô Gái Ngoan Hiền - Tập 82---2025","link_embed":"https://vip.opstream-short.com/share/3ac01363eb96084101c0e5ed8be7374a","link_m3u8":"https://vip.opstream-short.com/20251106/10275_3ac01363/index.m3u8"},{"name":"83","slug":"83","filename":"Cô Gái Ngoan Hiền - Tập 83---2025","link_embed":"https://vip.opstream-short.com/share/450ad5ed12c018f57a29c8f0ea7008ff","link_m3u8":"https://vip.opstream-short.com/20251106/10276_450ad5ed/index.m3u8"}]}],"time":"2 phút/tập","description":"<p>Lâm Vi Vi trong mắt mọi người là một cô gái ngoan ngoãn và hiểu chuyện, nhưng thực tế cô có những nét nổi loạn nhỏ và thầm thích Giang Triệt - giọng ca chính của một ban nhạc. Trong một hoạt động trường học, Lâm Vi Vi đã tập trung dũng khí để gia nhập ban nhạc của Giang Triệt với vai trò người chơi đàn organ. Qua những buổi tập luyện và biểu diễn, Giang Triệt dần khám phá ra tính cách sống động bên dưới vẻ ngoài ngoan hiền của Lâm Vi Vi. Hai người hấp dẫn lẫn nhau và bắt đầu một câu chuyện tình ngọt ngào, trong trẻo trên giảng đường.</p>","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-10T10:01:37.000Z","cast":[],"director":[],"cast_meta":[],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-gai-ngoan-hien-short-drama.json"}