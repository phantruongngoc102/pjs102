are/50abc3e730e36b387ca8e02c26dc0a22","link_m3u8":"https://vip.opstream15.com/20220404/2599_67011f02/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Giám đốc tập đoàn Vân Mã, Vệ Khanh và sinh viên tốt nghiệp khoa mỹ thuật Châu Thị đã chia tay nhau vì vấn đề tin tưởng khi yêu xa. Hai năm sau Châu Thị trở lại thế giới của Vệ Khanh nhưng lại hoàn toàn khác xưa. Vệ Khanh vì muốn níu kéo Châu Thị nên đã nghĩ đủ mọi cách, hai người lúc đầu còn nhiều mâu thuẫn sau đó đã hóa giải hết hiểu lầm trước đây. Những khó khăn họ gặp phải khiến hai người một lần nữa tin tưởng tấm lòng của đối phương, đồng thời cũng khẳng định được tình cảm của mình dành cho nhau, tình cảm giữa hai người ngày càng bền chặt. Hai người bạn tốt của Châu Thị cũng có những thu hoạch mới trên con đường trưởng thành. Nữ thần Lâm Phi Phi và nghệ sĩ Ninh Phi hòa hợp với nhau ngọt ngào hơn. Lý Minh Thành và Tất Thu Tịch cũng trở thành một nhà 3 người hạnh phúc.</p>","tmdb":{"type":"tv","id":"85011","season":2,"vote_average":6.3,"vote_count":7},"modified":"2023-05-09T18:29:42.000Z","cast":["Yan Xi","Hứa Hiểu Nặc","Cai Yijia","Dương Hân Dĩnh","Li Xinbo","Hu Wenzhe"],"director":[],"cast_meta":[{"name":"Yan Xi","name_vi":null,"name_original":"Yan Xi","tmdb_id":2378290,"profile":"https://image.tmdb.org/t/p/w500/9rGDX6yyWcD8nOIk9vc7ptbyMQv.jpg","tmdb_url":"https://www.themoviedb.org/person/2378290"},{"name":"Hứa Hiểu Nặc","name_vi":"Hứa Hiểu Nặc","name_original":"Xu Xiaonuo","tmdb_id":2378292,"profile":"https://image.tmdb.org/t/p/w500/7i9HVcCtXDDRfsub5kkJJOvkkrC.jpg","tmdb_url":"https://www.themoviedb.org/person/2378292"},{"name":"Cai Yijia","name_vi":null,"name_original":"Cai Yijia","tmdb_id":2378303,"profile":"https://image.tmdb.org/t/p/w500/oOsW0ZNQbbzuhplTd87fYKQy8HV.jpg","tmdb_url":"https://www.themoviedb.org/person/2378303"},{"name":"Dương Hân Dĩnh","name_vi":"Dương Hân Dĩnh","name_original":"Yang Xinying","tmdb_id":2378302,"profile":"https://image.tmdb.org/t/p/w500/6QSH489aRmVPO4AXLr0A6GQSHMv.jpg","tmd