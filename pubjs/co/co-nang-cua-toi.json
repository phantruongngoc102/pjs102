vip.opstream11.com/20220515/24585_b59b637a/index.m3u8"}]}],"time":"30 phút","description":"<p>Joo Yoo Rin là một cô gái có biệt tài nói dối và giỏi nhiều ngoại ngữ Anh, Hoa Nhật. Seol Gong Chan là người kế thừa một tập đoàn khách sạn lớn. Vì để cứu ông nội khỏi cơn bệnh nặng, Gong Chan đã yêu cầu Yoo Rin giả làm cô em họ để làm ông nội vui. Và chuyện này không một ai biết. Nhưng mọi chuyện lại bị Suh Jung Woo , người bạn thân của Gong Chan phát hiện. Nhưng Jung Woo quyết định không nói ra sự thật mà giữ kín cho hai người vì Jung Woo đã có tình cảm với Yoo Rin. Nhưng Yoo Rin lại bắt đầu có tình cảm với Gong Chan làm cho cả Yoo Rin và Jung Woo đều đau khổ. Nhưng đúng lúc này người bạn gái cũ của Gong Chan là Kim Se Hyun từ nước ngoài trở về với mong muốn nối lại quan hệ với Gong Chan...</p>","tmdb":{"type":"tv","id":"6074","season":1,"vote_average":7.8,"vote_count":29},"modified":"2022-05-15T03:31:04.000Z","cast":["Lee Da-hae","Lee Dong-wook","Lee Joon-gi","Park Si-yeon","Hwang Bo-ra","Jo Kye-hyung","Byun Hee-bong","Ahn Suk-hwan","Oh Ji-young"],"director":["Jeon Ki Sang"],"cast_meta":[{"name":"Lee Da-hae","name_vi":null,"name_original":"Lee Da-hae","tmdb_id":1235045,"profile":"https://image.tmdb.org/t/p/w500/liWpwu9TfCsoT6ovDuDMKwIyxDo.jpg","tmdb_url":"https://www.themoviedb.org/person/1235045"},{"name":"Lee Dong-wook","name_vi":null,"name_original":"Lee Dong-wook","tmdb_id":1238592,"profile":"https://image.tmdb.org/t/p/w500/vXTijFOceeVgjPLaSzVdVmGzklm.jpg","tmdb_url":"https://www.themoviedb.org/person/1238592"},{"name":"Lee Joon-gi","name_vi":null,"name_original":"Lee Joon-gi","tmdb_id":122408,"profile":"https://image.tmdb.org/t/p/w500/tHPJUgGiQRWt1Bh7ymqmmJ2zKF6.jpg","tmdb_url":"https://www.themoviedb.org/person/122408"},{"name":"Park Si-yeon","name_vi":null,"name_original":"Park Si-yeon","tmdb_id":84752,"profile":"https://image.tmdb.org/t/p/w500/iaP44f9OYuHoLKi2Mhyo27LdBlJ.jpg","tmdb_url":"https://www.themoviedb.org/person/84752"},{"name":"Hwang Bo-ra","name_vi":nu