ẽ chọn con đường nào cho mình?</p>","tmdb":{"type":"tv","id":"211332","season":1,"vote_average":5,"vote_count":3},"modified":"2025-04-25T13:11:33.000Z","cast":["Chang Zhekuan","Mao Na","He Wenxiao","林申","Wang Quiang"],"director":["Hàn Dương"],"cast_meta":[{"name":"Chang Zhekuan","name_vi":null,"name_original":"Chang Zhekuan","tmdb_id":3731856,"profile":"https://image.tmdb.org/t/p/w500/icjeSccoqk1dkeUjCp8KxhHDEcZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3731856"},{"name":"Mao Na","name_vi":null,"name_original":"Mao Na","tmdb_id":2969652,"profile":"https://image.tmdb.org/t/p/w500/2ua5HB40DxNWY6YqIgoEonc8BHu.jpg","tmdb_url":"https://www.themoviedb.org/person/2969652"},{"name":"He Wenxiao","name_vi":null,"name_original":"He Wenxiao","tmdb_id":3621845,"profile":"https://image.tmdb.org/t/p/w500/bPsFFEEFjTFwqmM8SWrkHloBdjH.jpg","tmdb_url":"https://www.themoviedb.org/person/3621845"},{"name":"林申","name_vi":null,"name_original":"林申","tmdb_id":2397758,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2397758"},{"name":"Wang Quiang","name_vi":null,"name_original":"Wang Quiang","tmdb_id":4179560,"profile":"https://image.tmdb.org/t/p/w500/grUvl7RJeAizgPlgY4TQNbCjUQ1.jpg","tmdb_url":"https://www.themoviedb.org/person/4179560"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-nang-dau-go.json"}