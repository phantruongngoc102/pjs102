 tập trung vào sự hài hước và sự phát triển tích cực của cả nam và nữ chính.","tmdb_id":240572,"cast":["Li Yinan","Quý Mỹ Hàm","Chu Gia Kỳ","Luo Mi","Huang Yueran","Huang Yiwei"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"240572","season":1,"vote_average":7,"vote_count":1},"cast_meta":[{"name":"Li Yinan","name_vi":null,"name_original":"Li Yinan","tmdb_id":2611996,"profile":"https://image.tmdb.org/t/p/w500/nVWbhLbycx7lOZINdJejQDSBIOl.jpg","tmdb_url":"https://www.themoviedb.org/person/2611996"},{"name":"Quý Mỹ Hàm","name_vi":"Quý Mỹ Hàm","name_original":"Ji Meihan","tmdb_id":2872808,"profile":"https://image.tmdb.org/t/p/w500/gVDIyMzoq44BdJChnKvdYZsZMVw.jpg","tmdb_url":"https://www.themoviedb.org/person/2872808"},{"name":"Chu Gia Kỳ","name_vi":"Chu Gia Kỳ","name_original":"Zhu Jiaqi","tmdb_id":1684719,"profile":"https://image.tmdb.org/t/p/w500/26CqzL9FxkjjQiZXYkewDqXSbvo.jpg","tmdb_url":"https://www.themoviedb.org/person/1684719"},{"name":"Luo Mi","name_vi":null,"name_original":"Luo Mi","tmdb_id":2235527,"profile":"https://image.tmdb.org/t/p/w500/y1tcm6zo5SKcujHNkrCCw1QzX3H.jpg","tmdb_url":"https://www.themoviedb.org/person/2235527"},{"name":"Huang Yueran","name_vi":null,"name_original":"Huang Yueran","tmdb_id":3929267,"profile":"https://image.tmdb.org/t/p/w500/uAINO5iH89AvIjtCA42ySdwOX39.jpg","tmdb_url":"https://www.themoviedb.org/person/3929267"},{"name":"Huang Yiwei","name_vi":null,"name_original":"Huang Yiwei","tmdb_id":4471776,"profile":"https://image.tmdb.org/t/p/w500/wYauswxQ09JtfVDGqPqVi6OuTIh.jpg","tmdb_url":"https://www.themoviedb.org/person/4471776"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-nang-loi-hai-chan-cao-quy.json"}