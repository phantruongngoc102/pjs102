vip.opstream14.com/20220326/3139_be648c4d/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/747d3443e319a22747fbb873e8b2f9f2","link_m3u8":"https://vip.opstream14.com/20220326/3140_79e4d3a7/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream14.com/share/92a08bf918f44ccd961477be30023da1","link_m3u8":"https://vip.opstream14.com/20220326/3141_d8e491d4/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream14.com/share/bd85282513da4089c441926e1975898c","link_m3u8":"https://vip.opstream14.com/20220326/3142_503dbd52/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream14.com/share/0afa92fc0f8a9cf051bf2961b06ac56b","link_m3u8":"https://vip.opstream14.com/20220326/3143_4e64d893/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream14.com/share/a41b3bb3e6b050b6c9067c67f663b915","link_m3u8":"https://vip.opstream14.com/20220326/3144_c58156cf/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream14.com/share/1160453108d3e537255e9f7b931f4e90","link_m3u8":"https://vip.opstream14.com/20220326/3145_4280c584/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream14.com/share/5d4ae76f053f8f2516ad12961ef7fe97","link_m3u8":"https://vip.opstream14.com/20220326/3146_c092a4e8/index.m3u8"}]}],"description":"<p>Hai cô nàng tính cách hoàn toàn trái ngược do một lần nổi loạn ở tuổi dậy thì mà quen thân. Từ đó, Lục Khả và Thẩm Tư Di đã trở thành những người bạn quan trọng nhất của nhau. Nhưng vì tính cách ngang ngạnh vô lý của Thẩm Tư Di mà hai người đã hoàn toàn đoạn tuyệt quan hệ trong mùa hè sau kỳ thi đại học, Thẩm Tư Di cũng ra nước ngoài. Chín năm sau, hai người gặp lại nhau, quyết định bỏ qua khúc mắc, cùng nhau cố gắng, bắt đầu lại quá trình mạo hiểm để xây dựng sự nghiệp, tình bạn và cả tình yêu.</p>","tmdb_id":115013,"cast":[],"director":[],"keywords":[],"tmdb":{"id":115013},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-nang-loi-hai.json"}