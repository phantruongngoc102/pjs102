:"34","slug":"34","filename":"co-nang-loi-hai-tap-34","link_embed":"https://vip.opstream14.com/share/a41b3bb3e6b050b6c9067c67f663b915","link_m3u8":"https://vip.opstream14.com/20220326/3144_c58156cf/index.m3u8"},{"name":"35","slug":"35","filename":"co-nang-loi-hai-tap-35","link_embed":"https://vip.opstream14.com/share/1160453108d3e537255e9f7b931f4e90","link_m3u8":"https://vip.opstream14.com/20220326/3145_4280c584/index.m3u8"},{"name":"36","slug":"36","filename":"co-nang-loi-hai-tap-36","link_embed":"https://vip.opstream14.com/share/5d4ae76f053f8f2516ad12961ef7fe97","link_m3u8":"https://vip.opstream14.com/20220326/3146_c092a4e8/index.m3u8"}]}],"time":"46M21S","description":"<p>Hai cô nàng tính cách hoàn toàn trái ngược do một lần nổi loạn ở tuổi dậy thì mà quen thân. Từ đó, Lục Khả và Thẩm Tư Di đã trở thành những người bạn quan trọng nhất của nhau. Nhưng vì tính cách ngang ngạnh vô lý của Thẩm Tư Di mà hai người đã hoàn toàn đoạn tuyệt quan hệ trong mùa hè sau kỳ thi đại học, Thẩm Tư Di cũng ra nước ngoài. Chín năm sau, hai người gặp lại nhau, quyết định bỏ qua khúc mắc, cùng nhau cố gắng, bắt đầu lại quá trình mạo hiểm để xây dựng sự nghiệp, tình bạn và cả tình yêu.</p>","tmdb":{"type":"tv","id":"115013","season":1,"vote_average":6,"vote_count":7},"modified":"2023-04-23T19:58:08.000Z","cast":["Lý Nhất Đồng","Kim Thần","Zhang Chao","Sunny Sun","Trần Hạo Lam","Ji Li","Lý Hoan","Zhai Guanhua","Huang Jue","Liu Zi","Wang Zheng","Chi Peng"],"director":["Deng Ke"],"cast_meta":[{"name":"Lý Nhất Đồng","name_vi":"Lý Nhất Đồng","name_original":"Li Yitong","tmdb_id":1736257,"profile":"https://image.tmdb.org/t/p/w500/jfostFmHde0D1Wj9F57GWHEVzmO.jpg","tmdb_url":"https://www.themoviedb.org/person/1736257"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Zhang Chao","name_vi":null,"name_original":"Zhang Cha