5a5a82212ea714ba2923f1bb3f1ffa1","link_m3u8":"https://vip.opstream10.com/20220515/14291_1db7c837/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/22cd4d66fc24fc0163ac00d27c1433c5","link_m3u8":"https://vip.opstream10.com/20220515/14293_1a7a602e/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/5165bb7092845d883f5d8fd52d1f32b5","link_m3u8":"https://vip.opstream10.com/20220515/14294_d18c28c3/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/32f57c0fa63af22a58598d1e0583ece9","link_m3u8":"https://vip.opstream10.com/20220515/14297_6740fe33/index.m3u8"}]}],"description":"<p>Sinh viên đại học Nemoto Kahoko (do Takahata Mitsuki thủ vai) là đứa con trứng mỏng được bảo vệ quá mức trong xã hội Nhật Bản hiện này. Lớn lên trong sự đùm bọc và nuông chiều của cha mẹ, Kahoko đã trở thành một thanh niên nai tơ kỳ tích. Cô đã 21 tuổi và đang trong quá trình tìm kiếm việc làm nhưng cô chưa từng bao giờ ngủ đêm ở bên ngoài, chưa từng đi làm thêm, chưa từng tự lựa chọn quần áo, và cũng chưa từng đi tàu điện một mình. Kahoko được chụp hình rất nhiều nhưng cô chưa từng tự mình chụp. Bây giờ, Kahoko sắp bước ra khỏi vỏ trứng vô trùng của cô để bước vào xã hội đầy rẫy khó khăn. Và rồi cô sẽ nhận ra ngay “Mình thật khác với mọi người!”. Kahoko luôn xem mẹ như người bạn thân và cha của cô không thể sống thiếu cô. Khi Kahoko bắt đầu thay đổi, tinh thần của họ trở nên bất an và gia đình của họ sẽ rơi vào khủng hoảng. Và khi đó cũng chính là lúc Kahoko và mọi người xung quanh nhận ra sức mạnh tìm ẩn trong đó.</p>","tmdb_id":74550,"cast":["Mitsuki Takahata","Ryoma Takeuchi","Saburo Tokito"],"director":["Seiichi Nagumo","Hiroto Akashi","Ken Higurashi"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"74550","season":1,"vote_average":7.5,"vote_count":11},"cast_meta":[{"name":"Mitsuki Takahata","name_vi":null,"name_original":"Mitsuki Takahata"},{"name":"Ryoma Takeuchi","name_vi":null,"name_original"