link_embed":"https://vip.opstream15.com/share/489d7aef9f2316d6ebde24ae1369d74c","link_m3u8":"https://vip.opstream15.com/20241207/44681_489d7aef/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/faf05894ccc2cf4e7ac91178cf39a95b","link_m3u8":"https://vip.opstream15.com/20241208/44740_faf05894/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/6b1e2c2e15d2f2696ea4e0f911334f6b","link_m3u8":"https://vip.opstream15.com/20241208/44741_6b1e2c2e/index.m3u8"}]}],"description":"Tiểu Khưu, biên tập viên của nhà xuất bản vừa mới đánh giá một cuốn tiểu thuyết Mary Sue siêu sốc. Trong buổi họp kiểm duyệt đã trực tiếp đưa ra kết luận \"không duyệt\". Thế nhưng, cô ngủ thiếp đi trong tủ quần áo của mình, khi tỉnh dậy lại bước vào một thế giới khác. Sau vài lần tìm hiểu, cô nhận ra mình đã xuyên không vào cuốn tiểu thuyết mà chính mình đã \"khai tử\", còn trở thành nữ phụ xui xẻo nhất - Thẩm Thanh Ca! Mặc dù cô có lợi thế của tác giả, có thể nhìn thấy chỉ số may mắn của tất cả mọi người, nhưng chỉ số may mắn của bản thân lại thấp đến đáng thương, chuyện xui xẻo gì cũng ập tới cô. Hệ thống của tiểu thuyết gợi ý, chỉ khi tiếp cận nam chính may mắn Cố Dịch Thần thì chỉ số may mắn của cô mới được cải thiện, mới có cơ hội xuyên không về nhà.","tmdb_id":277763,"cast":["Wang Han","Yang Xinke","Wu Chunyi","Jiang Xinqi","Gu Lechen"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"277763","season":1,"vote_average":7,"vote_count":1},"cast_meta":[{"name":"Wang Han","name_vi":null,"name_original":"Wang Han","tmdb_id":4099001,"profile":"https://image.tmdb.org/t/p/w500/77TaTtl3obqPBBsuoiNh4FtvCAN.jpg","tmdb_url":"https://www.themoviedb.org/person/4099001"},{"name":"Yang Xinke","name_vi":null,"name_original":"Yang Xinke","tmdb_id":4729885,"profile":"https://image.tmdb.org/t/p/w500/fS1tDSW8QQItHa69NXWC0ZzI13O.jpg","tmdb_url":"https://www.themoviedb.org/person/4729885"},{"name":"Wu Chunyi","name_vi":null,"name_original":"Wu Chu