bed":"https://vip.opstream11.com/share/2629deb25de85314179e2d27c7210e92","link_m3u8":"https://vip.opstream11.com/20241102/56250_2629deb2/index.m3u8"}]}],"description":"Phim là câu chuyện về bốn quốc gia Tấn, Yên, Hàn, Tần trong đó nước Tấn là có quyền lực mạnh nhất. Phim kể về việc Trấn Bắc vương Sở Bắc Tiệp của Tấn quốc nảy sinh tình cảm với nữ tỳ Bạch Sính Đình của Yên quốc.\n\nBạch Sính Đình là một thị nữ nổi danh trong vương phủ Kính An ở Yên quốc. Vốn thông minh, tài trí và sở hữu tiếng đàn làm say đắm lòng người. Bạch Sính Đình gặp gỡ và đem lòng yêu Sở Bắc Tiệp – người đàn ông quyền lực tối thượng, dáng vẻ uy nghi, phi phàm. Tuy nhiên tình yêu của cả 2 lại liên tiếp gặp phải trắc trở vì ở 2 chiến tuyến khác nhau và vì thiên hạ loạn lạc vì sự ích kỷ của những kẻ cầm quyền.","tmdb_id":69045,"cast":["Angelababy","Chung Hán Lương","Gan Tingting","Sun Yizhou","Madina Memet"],"director":["Kuk Kok-Leung"],"keywords":[],"tmdb":{"type":"tv","id":"69045","season":1,"vote_average":6.1,"vote_count":25},"cast_meta":[{"name":"Angelababy","name_vi":"Angelababy","name_original":"AngelaBaby","tmdb_id":150899,"profile":"https://image.tmdb.org/t/p/w500/gbnjGrNhlvGu1sXhcm0J2IW0orD.jpg","tmdb_url":"https://www.themoviedb.org/person/150899"},{"name":"Chung Hán Lương","name_vi":"Chung Hán Lương","name_original":"Wallace Chung","tmdb_id":1183233,"profile":"https://image.tmdb.org/t/p/w500/mDJQSyCQdPW2lJDbY46udu0161n.jpg","tmdb_url":"https://www.themoviedb.org/person/1183233"},{"name":"Gan Tingting","name_vi":null,"name_original":"Gan Tingting","tmdb_id":1183234,"profile":"https://image.tmdb.org/t/p/w500/xasI6vF76wCitYqsjyPLJ46Nlg4.jpg","tmdb_url":"https://www.themoviedb.org/person/1183234"},{"name":"Sun Yizhou","name_vi":null,"name_original":"Sun Yizhou","tmdb_id":1258617,"profile":"https://image.tmdb.org/t/p/w500/7LrjgcfjklPW6AyC4sxaNx6z089.jpg","tmdb_url":"https://www.themoviedb.org/person/1258617"},{"name":"Madina Memet","name_vi":null,"name_original":"Madina Memet","tmdb_id":1627