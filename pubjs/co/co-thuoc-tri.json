i nhau. Trong khi hai người kết hợp ngăn chặn một âm mưu khủng khiếp, họ phát hiện ra có các dị khách âm thầm thành lập một liên minh muốn lật đổ những người nắm quyền, thành lập một xã hội hòa bình mới. Tả Vân Khởi và nhóm người của anh ta buộc phải tham gia vào trận chiến.","tmdb":{"type":"tv","id":"105929","season":1,"vote_average":8.8,"vote_count":4},"modified":"2024-10-20T14:37:55.000Z","cast":["Ji Aojie","Tao Dian","Sheng Feng","Wei Chao"],"director":[],"cast_meta":[{"name":"Ji Aojie","name_vi":null,"name_original":"Ji Aojie","tmdb_id":2709995,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2709995"},{"name":"Tao Dian","name_vi":null,"name_original":"Tao Dian","tmdb_id":1882418,"profile":"https://image.tmdb.org/t/p/w500/432PwmJv3jlkNElEVWutIROwpEz.jpg","tmdb_url":"https://www.themoviedb.org/person/1882418"},{"name":"Sheng Feng","name_vi":null,"name_original":"Sheng Feng","tmdb_id":1853547,"profile":"https://image.tmdb.org/t/p/w500/1IB7v7KhJWfTTylZHhFXHw5SVFR.jpg","tmdb_url":"https://www.themoviedb.org/person/1853547"},{"name":"Wei Chao","name_vi":null,"name_original":"Wei Chao","tmdb_id":2199340,"profile":"https://image.tmdb.org/t/p/w500/aPYAEWrS1lb1UYwCFejIcJOOGSU.jpg","tmdb_url":"https://www.themoviedb.org/person/2199340"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/co-thuoc-tri.json"}