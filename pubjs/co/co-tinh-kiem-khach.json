 đề của trái tim mang đến những hậu quả sống còn khi âm mưu nguy hiểm đằng sau con rối dần lộ diện.</p>","tmdb":{"type":"tv","id":"94172","season":1,"vote_average":8,"vote_count":1},"modified":"2025-08-24T10:22:31.000Z","cast":["Trịnh Y Kiện","Noel Leung","Elaine Ho Yuen-Ying","Marco Ngai Chun-Git","Amy Wu Mei-Yee","Trần Gia Huy","Sher Ng Wing-Hung"],"director":[],"cast_meta":[{"name":"Trịnh Y Kiện","name_vi":"Trịnh Y Kiện","name_original":"Ekin Cheng Yee-Kin","tmdb_id":21909,"profile":"https://image.tmdb.org/t/p/w500/dS42D99itm6n5ROUoGxJFRH802j.jpg","tmdb_url":"https://www.themoviedb.org/person/21909"},{"name":"Noel Leung","name_vi":null,"name_original":"Noel Leung","tmdb_id":140483,"profile":"https://image.tmdb.org/t/p/w500/zfZvegM9Jzagw1sRGJ4mhNarQ1i.jpg","tmdb_url":"https://www.themoviedb.org/person/140483"},{"name":"Elaine Ho Yuen-Ying","name_vi":null,"name_original":"Elaine Ho Yuen-Ying","tmdb_id":3543356,"profile":"https://image.tmdb.org/t/p/w500/s6qvSYikhM2ev2wdwwmi1UfRk8F.jpg","tmdb_url":"https://www.themoviedb.org/person/3543356"},{"name":"Marco Ngai Chun-Git","name_vi":null,"name_original":"Marco Ngai Chun-Git","tmdb_id":1254989,"profile":"https://image.tmdb.org/t/p/w500/zZ6oHYxfphhe7cPrArQRdBV9r2I.jpg","tmdb_url":"https://www.themoviedb.org/person/1254989"},{"name":"Amy Wu Mei-Yee","name_vi":null,"name_original":"Amy Wu Mei-Yee","tmdb_id":1398250,"profile":"https://image.tmdb.org/t/p/w500/vT6rPsLd3psDUyFISdFTfw7BkVD.jpg","tmdb_url":"https://www.themoviedb.org/person/1398250"},{"name":"Trần Gia Huy","name_vi":"Trần Gia Huy","name_original":"Gary Chan Ga-Fai","tmdb_id":1624824,"profile":"https://image.tmdb.org/t/p/w500/r2ocfvzwvBZBrYMmF6uOqDRwvd7.jpg","tmdb_url":"https://www.themoviedb.org/person/1624824"},{"name":"Sher Ng Wing-Hung","name_vi":null,"name_original":"Sher Ng Wing-Hung","tmdb_id":1374622,"profile":"https://image.tmdb.org/t/p/w500/91j4W8sKUjxl5khiFsAFFOYOKTr.jpg","tmdb_url":"https://www.themoviedb.org/person/1374622"}],"keywords":[],"tmdb_chec