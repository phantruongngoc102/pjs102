0.com/20230120/26146_0d5bf47b/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/5458ddfd38e3d8bd01d4db5519a004ec","link_m3u8":"https://vip.opstream10.com/20230128/26201_4d649777/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/188e30ebbc769aeda748b09cec89f0bb","link_m3u8":"https://vip.opstream10.com/20230203/26270_42677eff/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/aae14bda33aa45a1d45d45011529b806","link_m3u8":"https://vip.opstream10.com/20230210/26326_d3fa2d4f/index.m3u8"}]}],"description":"<p>Firuze và Ayaz. Hai trái tim đẹp đẽ, một đứa con gánh hai gánh nặng gia đình. Số phận đã gắn kết họ, số phận/sự hy sinh đã chia cắt họ. Bây giờ cuộc sống của bạn nợ họ một lời xin lỗi. Anh muốn trả lại tình yêu mà anh đã lấy. Nhưng đường sá khó khăn. Những con đường gập ghềnh. Thời tiết Frosty, Zemheri từ thời gian. Đôi mắt của Firuze màu xanh, trái tim cô ấy là lửa.</p><p>Cha công nhân xây dựng bị kết án oan trong vụ tai nạn thang máy khiến 13 người thiệt mạng; Nó kích hoạt Firuze, người đã chọn con đường của mình vì sự trung thực và công lý. Trên con đường anh bước vào với quyết tâm cứu cha mình; Anh gặp Ayaz, người đã đánh cắp hy vọng của anh, người đã không tiếc lời tạm biệt và bỏ mặc anh.</p><p>Ayaz, người gánh trên vai trách nhiệm trụ cột trong nhà, đối mặt với Firuze, người mà anh đã hy sinh cho mẹ mình ngay khi anh chuẩn bị kết hôn với người khác, và anh vẫn thức dậy mỗi sáng với một niềm khao khát. màu xanh trong mắt anh. Anh ta không biết rằng Firuze đóng vai trò chính trong việc buộc tội cha cô.</p><p>Firuze không biết rằng có những cuộc chia tay không phải vì yêu mà vì tuyệt vọng. Ayaz không biết bao nhiêu lần hy sinh cho một tình yêu.</p>","tmdb_id":97296,"cast":["Alperen Duymaz","Ayça Ayşin Turan","Caner Cindoruk","Hazal Filiz Küçükköse","Şebnem Dönmez","Zerrin Tekindor","Müfit Kayacan","Emir Çubukçu","Aleyna Özgeçen","Lila Gürmen","Sahra Şaş","Nihal Koldaş","Cuma Alagöz","Eylül Lize Kandemir"],"director":["Hilal Saral"],"keywords":[],"tmdb":{"type":"tv","id":"97296","season":1,"vote_average":7.25,"vote_count":18},"cast_meta":[{"name":"Alperen Duymaz","name_vi":null,"name_original":"Alperen Duymaz","tmdb_id":1584432,"profile":"https://image.tmdb.org/t/p/w500/ipjCVnBGIA7vPOmo5kKP8P71Lzf.jpg","tmdb_url":"https://www.themoviedb.org/person/1584432"},{"name":"Ayça Ayşin Turan","name_vi":null,"name_original":"Ayça Ayşin Turan","tmdb_id":1439922,"profile":"https://image.tmdb.org/t/p/w500/2ilINzaNM61FLCh0pGhYoyySJEQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1439922"},{"name":"Caner Cindoruk","name_vi":null,"name_original":"Caner Cindoruk","tmdb_id":147628,"profile":"https://image.tmdb.org/t/p/w500/3YSQLSHulP0X0vuAdan8UUDvbC4.jpg","tmdb_url":"https://www.themoviedb.org/person/147628"},{"name":"Hazal Filiz Küçükköse","name_vi":null,"name_original":"Hazal Filiz Küçükköse","tmdb_id":1575028,"profile":"https://image.tmdb.org/t/p/w500/fAT3PE0xE9CunXY6GqoIGkBN5ij.jpg","tmdb_url":"https://www.themoviedb.org/person/1575028"},{"name":"Şebnem Dönmez","name_vi":null,"name_original":"Şebnem Dönmez","tmdb_id":59753,"profile":"https://image.tmdb.org/t/p/w500/xsXjHqbvB5zaxtEzOnquhnw6W2d.jpg","tmdb_url":"https://www.themoviedb.org/person/59753"},{"name":"Zerrin Tekindor","name_vi":null,"name_original":"Zerrin Tekindor","tmdb_id":1246608,"profile":"https://image.tmdb.org/t/p/w500/mWRvssoXW6GCsyqEubYEn5l1U3s.jpg","tmdb_url":"https://www.themoviedb.org/person/1246608"},{"name":"Müfit Kayacan","name_vi":null,"name_original":"Müfit Kayacan","tmdb_id":1669670,"profile":"https://image.tmdb.org/t/p/w500/2QVDWWQj45uOgnD2DUkB1tC5LWt.jpg","tmdb_url":"https://www.themoviedb.org/person/1669670"},{"name":"Emir Çubukçu","name_vi":null,"name_original":"Emir Çubukçu","tmdb_id":2500153,"profile":"https://image.tmdb.org/t/p/w500/xhc54xy3ny90kKlhEe3PX5x91kr.jpg","tmdb_url":"https://www.themoviedb.org/person/2500153"},{"name":"Aleyna Özgeçen","name_vi"