p.opstream14.com/share/e5a872704d45c7fa661a94abd9f9d92d","link_m3u8":"https://vip.opstream14.com/20221102/27360_7b24b05f/index.m3u8"}]}],"time":"1H26M30S","description":"<p>Con Đường Bi Kịch (Bi Kịch Thượng Lưu, The Road: Tragedy of One) là bộ phim xoay quanh những tham vọng khủng khiếp, bí mật, tội lỗi và sự cứu rỗi xoay quanh Royal the Hills - nơi sinh sống của 1% những người giàu có và quyền lực nhất Hàn Quốc. Bi kịch thượng lưu bắt đầu khi một sự cố khủng khiếp phá vỡ sự yên bình bên trong khu bảo tồn trang nhã. Tất cả mọi người đều bị cuốn vào sự cố này, kéo theo đó là những khúc quanh bất ngờ trong cuộc đời của họ.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2022-11-02T19:04:22.000Z","cast":["Ji Jin Hee","Yoon Se A","Kim Hye Eun"],"director":["Kim No-won"],"cast_meta":[{"name":"Ji Jin Hee","name_vi":null,"name_original":"Ji Jin Hee"},{"name":"Yoon Se A","name_vi":null,"name_original":"Yoon Se A"},{"name":"Kim Hye Eun","name_vi":null,"name_original":"Kim Hye Eun"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/con-duong-bi-kich-bi-kich-thuong-luu.json"}