x.m3u8"},{"name":"36","slug":"36","filename":"con-duong-hanh-phuc-thuyet-minh-far-away-love-tap-36","link_embed":"https://vip.opstream10.com/share/26cd8ecadce0d4efd6cc8a8725cbd1f8","link_m3u8":"https://vip.opstream10.com/20220418/8850_59a0ad58/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Mạnh Sơ Hạ sống một mình với đứa con của chị gái mất tích rất nhiều năm. Thẩm Ngạn từ nước ngoài lập nghiệp, xem mắt và đính hôn với bạn thân của Sơ Hạ là Nhược Nam. Sau đó Nhuợc Nam mất vì tai nạn và nhờ cậy Sơ Hạ chăm sóc Thẩm Ngạn. Mẹ Thẩm Ngạn nghĩ Sơ Hạ có ý đồ nên ngăn cản hai người, nhưng Thẩm Ngạn vẫn quyết lấy Sơ Hạ vì ngày xưa từng bị mẹ phá hoại tình cảm. Hai người dần dần có tình cảm. Nhưng chị gái của Sơ Hạ - cũng chính là người yêu cũ của Thẩm Ngạn trở về, từ đó các tình tiết trong phim trở nên éo le hơn,…</p>","tmdb":{"type":"tv","id":"70094","season":1,"vote_average":4,"vote_count":2},"modified":"2023-06-19T18:20:19.000Z","cast":["Park Hae-jin","Li Fei'er","Angel Liu","Ngô Lỗi","Tống Dật","Qu Jingjing","Lý Lan Địch"],"director":["Ngưu Nhạc"],"cast_meta":[{"name":"Park Hae-jin","name_vi":null,"name_original":"Park Hae-jin","tmdb_id":1244834,"profile":"https://image.tmdb.org/t/p/w500/hiSahEWd1VH0UXgFpZlMLqaS8JG.jpg","tmdb_url":"https://www.themoviedb.org/person/1244834"},{"name":"Li Fei'er","name_vi":null,"name_original":"Li Fei'er","tmdb_id":1624820,"profile":"https://image.tmdb.org/t/p/w500/hH4bsVcm0De76FUTffpM28l2mYh.jpg","tmdb_url":"https://www.themoviedb.org/person/1624820"},{"name":"Angel Liu","name_vi":null,"name_original":"Angel Liu","tmdb_id":2163808,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2163808"},{"name":"Ngô Lỗi","name_vi":"Ngô Lỗi","name_original":"Leo Wu","tmdb_id":1438264,"profile":"https://image.tmdb.org/t/p/w500/43fYrqW26tisHBblj9lazersTdr.jpg","tmdb_url":"https://www.themoviedb.org/person/1438264"},{"name":"Tống Dật","name_vi":"Tống Dật","name_original":"Song Yi","tmdb_id":1877119,"profile":"https://image.tmdb.org/t/p/w