d00c81ea2b9258bee0e3695b6ca1","link_m3u8":"https://vip.opstream16.com/20230411/33788_1e3a47f0/index.m3u8"},{"name":"33","slug":"33","filename":"Con Duong Nhan Sinh E33","link_embed":"https://vip.opstream16.com/share/3b029d4810ab62194de14d4e511ba6fa","link_m3u8":"https://vip.opstream16.com/20230411/33789_7f8d8521/index.m3u8"},{"name":"34","slug":"34","filename":"Con Duong Nhan Sinh E35","link_embed":"https://vip.opstream16.com/share/2b0c3bf2199766fdc565f91ad6e9a534","link_m3u8":"https://vip.opstream16.com/20230411/33790_044e2502/index.m3u8"},{"name":"35","slug":"35","filename":"Con Duong Nhan Sinh E36","link_embed":"https://vip.opstream16.com/share/db8878e70972845cfb00cebc25b2edae","link_m3u8":"https://vip.opstream16.com/20230411/33791_4809aa10/index.m3u8"},{"name":"36","slug":"36","filename":"Con Duong Nhan Sinh E37","link_embed":"https://vip.opstream16.com/share/88757d44d1e0a2bf33e366fe78461e31","link_m3u8":"https://vip.opstream16.com/20230411/33792_247253f9/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Kể về câu chuyện vào những năm 1980, Cao Gia Lâm, một thanh niên sống ở Cao Gia Câu, phía bắc Thiểm Tây, được mọi người trong làng biết đến với biệt danh học tài \"trạng nguyên\". Tuy nhà nghèo nhưng ham đọc sách văn thơ, lòng muốn sánh với trời cao, thầm nhủ phải gột sạch bụi đất quê nghèo. Cao khảo là cơ hội duy nhất để thay đổi vận mệnh của cậu, nhưng ngờ đâu cậu thi trượt. Cậu đã làm việc chăm chỉ để trở thành giáo viên tại một trường tiểu học tư thục, lại bị biên chế giáo viên chèn ép. Cao Gia Lâm rơi xuống vực sâu cuộc sống, sau đó cậu được Lưu Xảo Trân động viên lấy lại niềm vui, kiên trì viết lách, thắp lên hy vọng về cuộc sống, còn khiến lửa tình với Xảo Trân bừng cháy. Việc chú của Gia Lâm trở về làng đã gián tiếp tạo cơ hội cho Gia Lâm làm việc với tư cách là một phóng viên trong quận. Cậu gặp Hoàng Á Bình, một người bạn học cùng chí hướng ở thị trấn, sự bảo vệ thầm lặng của cô gái nhà quê Xảo Trân và màn tỏ tình ấm áp của cô gái Thượng Hải Hoàng Á Bình đã khiến câu rơi vào tình thế tiến thoái lưỡng nan không thể đưa ra lựa chọn. Sau nhiều cuộc đấu tranh và nhiều lựa chọn, chỉ với cây bút bên người câu đã chọn đến Thượng Hải. Những thử thách của số phận nối tiếp nhau, Cao Gia Lâm bất ngờ biết rằng vị trí đại học của cậu đã bị thay thế bởi người bạn Song Tinh khi cậu vừa chạm tuổi ba mươi. Mặc dù vậy, Gia Lâm đã không bị đánh bại, cậu thuận theo thời thế mà làm việc chăm chỉ để học hỏi những kiến ​​​​thức mới, làm việc chăm chỉ và trải qua những thăng trầm của thế giới, cậu đã viết nên những câu chuyện cuộc sống phi thường của những người bình thường trong làn sóng thời đại.</p>","tmdb":{"type":"tv","id":"222663","season":1,"vote_average":6,"vote_count":2},"modified":"2023-04-11T08:16:22.000Z","cast":["Lý Thấm","Trần Hiểu","Zhang Jiani","Vương Thiên Thần","Đường Tằng","Lin Yongjian","Lưu Uy","Quách Hiểu Đình","Liu Yitie","Lưu Nhuận Nam","Li Yutong"],"director":["Yan Jian Gang"],"cast_meta":[{"name":"Lý Thấm","name_vi":"Lý Thấm","name_original":"Li Qin","tmdb_id":568304,"profile":"https://image.tmdb.org/t/p/w500/thak4pt7jCPbl2xx5HnFhkEE0Tu.jpg","tmdb_url":"https://www.themoviedb.org/person/568304"},{"name":"Trần Hiểu","name_vi":"Trần Hiểu","name_original":"Chen Xiao","tmdb_id":1192909,"profile":"https://image.tmdb.org/t/p/w500/6D4YFXfukHzD03IlHtUN67yTwHF.jpg","tmdb_url":"https://www.themoviedb.org/person/1192909"},{"name":"Zhang Jiani","name_vi":null,"name_original":"Zhang Jiani","tmdb_id":2035421,"profile":"https://image.tmdb.org/t/p/w500/cwb9IVbU2stIDl2XyWI38cAFs57.jpg","tmdb_url":"https://www.themoviedb.org/person/2035421"},{"name":"Vương Thiên Thần","name_vi":"Vương Thiên Thần","name_original":"Wang Tianchen","tmdb_id":1815239,"profile":"https://image.tmdb.org/t/p/w500/hWfKsHErCBPR3Z8gRkRvLuj9r0o.jpg","tmdb_url":"https://www.themoviedb.org/person/1815239"},{"name":"Đường Tằng","name_vi":"Đường Tằng","name_original":"Tang Zeng","tmdb_id":3131747,"profile":"https://image.tmdb.org/t/p/w500/dPWJl8mZ7KWyUbd1Hl