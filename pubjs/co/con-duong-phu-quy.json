.opstream17.com/share/285ab9448d2751ee57ece7f762c39095","link_m3u8":"https://vip.opstream17.com/20240224/1211_c7b3efe3/index.m3u8"},{"name":"01","slug":"01","link_embed":"https://vip.opstream17.com/share/f7cade80b7cc92b991cf4d2806d6bd78","link_m3u8":"https://vip.opstream17.com/20240224/1210_bb03927b/index.m3u8"}]}],"description":"Billionaire tycoon Marcus Cheuk Yat-yuen welcomes home Malaysian swindler Sha Fu-loi, who claims to be his long-lost half-brother Cheuk Yat-ming. Blinded by the assumed brotherhood, Marcus fails to recognize the true nature of Fu-loi but brings him into the hierarchy of his family banking empire. They both face dilemmas of their own in their relationships. Marcus is married to Connie Ho Tseuk-nin, but an affair with his old flame Angie Tung Ling-chi following a traumatic kidnap scare threatens to jeopardize all he has. Fu-loi secretly falls for Marcus' younger sister Rene Cheuk Yat-sum, who is torn between this fake brother and her devoted admirer Ko Tok-man. Consumed by greed and jealousy, Fu-loi eventually reveals his hidden agenda...","tmdb_id":18140,"cast":["Lữ Lương Vỹ","La Gia Lương","Viên Vịnh Nghi","Quách Khả Doanh","Jaime Chik Mei-Chun","Joe Ma Tak-Chung","Kenneth Ma Kwok-Ming","Sharon Chan Man-Chi","Nancy Sit Ka-Yin","Hứa Thiệu Hùng","Lưu Giang","Natalie Tong","Tần Bái"],"director":["Trang Vỹ Kiến"],"keywords":[],"tmdb":{"type":"tv","id":"18140","season":1,"vote_average":9.3,"vote_count":3},"cast_meta":[{"name":"Lữ Lương Vỹ","name_vi":"Lữ Lương Vỹ","name_original":"Ray Lui","tmdb_id":78877,"profile":"https://image.tmdb.org/t/p/w500/vAWHhBCWZwBKLsujgEKusfMLmCO.jpg","tmdb_url":"https://www.themoviedb.org/person/78877"},{"name":"La Gia Lương","name_vi":"La Gia Lương","name_original":"Gallen Lo Ka-Leung","tmdb_id":1223043,"profile":"https://image.tmdb.org/t/p/w500/6ZCTOMeRktYL7iTEz7lg7N3XXPc.jpg","tmdb_url":"https://www.themoviedb.org/person/1223043"},{"name":"Viên Vịnh Nghi","name_vi":"Viên Vịnh Nghi","name_original":"Anita Yuen Wing