30980ffc325cc243e1c0f5","link_m3u8":"https://vip.opstream16.com/20221020/24283_1ab9fff8/index.m3u8"},{"name":"15b","slug":"15b","filename":"con-duong-ruc-lua--eps-tap-15b","link_embed":"https://vip.opstream16.com/share/cd370abf1cf7faf99da5daec760de425","link_m3u8":"https://vip.opstream16.com/20221020/24284_c25d6f24/index.m3u8"},{"name":"16a","slug":"16a","filename":"con-duong-ruc-lua--eps-tap-16a","link_embed":"https://vip.opstream16.com/share/d095e9553703cc6e3d058c3b70e8e6ce","link_m3u8":"https://vip.opstream16.com/20221020/24285_6760ac11/index.m3u8"},{"name":"16b","slug":"16b","filename":"con-duong-ruc-lua--eps-tap-16b","link_embed":"https://vip.opstream16.com/share/7b71cd05d1201966672ed91687adaa03","link_m3u8":"https://vip.opstream16.com/20221020/24286_1c5e8684/index.m3u8"},{"name":"17a","slug":"17a","filename":"con-duong-ruc-lua--eps-tap-17a","link_embed":"https://vip.opstream16.com/share/9f62c81d7b48e146423f79c9e151510d","link_m3u8":"https://vip.opstream16.com/20221020/24287_e2e0c31f/index.m3u8"},{"name":"17b","slug":"17b","filename":"con-duong-ruc-lua--eps-tap-17b","link_embed":"https://vip.opstream16.com/share/561abb177528d5bf95d40838809a7cf6","link_m3u8":"https://vip.opstream16.com/20221020/24288_11983dcd/index.m3u8"}]}],"time":"42 phút/tập","description":"<p>Phim được chuyển thể từ tiểu thuyết cùng tên của tác giả Twentine, có nội dung xoanh quanh mối tình chị em cách nhau 8 tuổi khi nữ chính là huấn luyện viên của nam chính. Trong phim, Kim Thần đảm nhận vai nữ chính La Na – một huấn luyện viên có cá tính mạnh mẽ, luôn nhiệt huyết, tận tâm và có trách nhiệm với công việc của mình. Trong khi đó Vương An Vũ thủ vai Đoàn Vũ Thành – một chàng trai trẻ ngây ngô tràn đầy năng lượng, có đam mê tuyệt đối với bộ môn thể thao nhảy cao. Hai người họ đã gặp được nhau ở trường học khi La Na trở thành huấn luyện viên của Đoàn Vũ Thành trong câu lạc bộ điền kinh. Trong quá trình cùng nhau luyện tập, tính cách trầm tĩnh có phần ngây ngô, sự nhiệt huyết đam mê với ước mơ của chàng học trò nhỏ tự lúc nào chẳng hay đã len lỏi khiến trái tim La Na rung động. Đối với cô Đoàn Vũ Thành chính là hình ảnh tiêu biểu cho ánh dương, mồ hôi và con đường đua rực lửa. Câu chuyện tình của bộ đôi hứa hẹn sẽ đem đến cho khán giả những thước phim vô cùng ngọt ngào và tràn ngập hơi thở thanh xuân.</p>","tmdb":{"type":"tv","id":"211228","season":1,"vote_average":8.7,"vote_count":3},"modified":"2025-05-20T13:26:12.000Z","cast":["Kim Thần","Vương An Vũ","Trương Khải Oánh","Chi Jia","Li Zhuozhao","Guo Jinqi","Jill Hsu","Jiang Yushun","Li Jiansan","Peggy Ji","Gao Shenghaoyu"],"director":["Y Tranh"],"cast_meta":[{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Vương An Vũ","name_vi":"Vương An Vũ","name_original":"Wang Anyu","tmdb_id":2482605,"profile":"https://image.tmdb.org/t/p/w500/7ai55C0CoOdzOlkAOpfatW5xuh.jpg","tmdb_url":"https://www.themoviedb.org/person/2482605"},{"name":"Trương Khải Oánh","name_vi":"Trương Khải Oánh","name_original":"Zhang Kaiying","tmdb_id":3331200,"profile":"https://image.tmdb.org/t/p/w500/3XtnEl4vHfQlLg4XJzDrq9HzsjY.jpg","tmdb_url":"https://www.themoviedb.org/person/3331200"},{"name":"Chi Jia","name_vi":null,"name_original":"Chi Jia","tmdb_id":1210973,"profile":"https://image.tmdb.org/t/p/w500/agfOJWbkvTN8Lig0r9U9w7KQOnp.jpg","tmdb_url":"https://www.themoviedb.org/person/1210973"},{"name":"Li Zhuozhao","name_vi":null,"name_original":"Li Zhuozhao","tmdb_id":2304107,"profile":"https://image.tmdb.org/t/p/w500/jOBzktvMtRJliLjTPWXFPXhmIKy.jpg","tmdb_url":"https://www.themoviedb.org/person/2304107"},{"name":"Guo Jinqi","name_vi":null,"name_original":"Guo Jinqi","tmdb_id":3720388,"profile":"https://image.tmdb.org/t/p/w500/uUfRtqCa8pnCOf2fz5cyCCiFz64.jpg","tmdb_url":"https://www.themoviedb.org/person/3720388"},{"name":"Jill Hsu","name_vi":null,"name_original":"Jill