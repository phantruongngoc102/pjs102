{"id":"62ed500c294ccd8d66cf3dc3","title":"Con Mồi","origin_name":"Prey","slug":"con-moi-2022","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/co/con-moi-2022.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/co/con-moi-2022.webp","year":2022,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Prey.2022.1080p.DSNP.WEB-DL.DDP5.1.Atmos.H.264-CM","link_embed":"https://vip.opstream14.com/share/110a186a520a14d6ecab41ff9c083741","link_m3u8":"https://vip.opstream14.com/20220805/19603_8ef6fd72/index.m3u8"}]}],"time":"90 phút","description":"<p>Sau lần phát hành cuối cùng của Quái thú vô hình vào năm 2018, câu chuyện về sinh vật này đã được tái tạo. Lần này có Prey 2022 , người sẽ kể về sự xuất hiện của một Predator ngoài hành tinh trong thế giới loài người.Bộ phim kể về lịch sử lần đầu tiên những kẻ thù săn mồi đến thăm Trái đất cách đây 300 năm. Kẻ săn mồi bắt đầu khám phá hành tinh Trái đất và săn bắt động vật với con người vào năm 1719.Naru, một cô gái thuộc bộ tộc da đỏ Comanche dũng cảm và có ước mơ trở thành thợ săn. Bản thân Naru phải đối mặt với sự kỳ thị của những người phụ nữ vốn chỉ được đánh giá là chỉ biết lo việc nhà và nuôi dạy con cái.</p>","tmdb":{"type":"movie","id":"766507","season":null,"vote_average":7.668,"vote_count":7480},"modified":"2022-08-05T17:34:17.000Z","cast":["Amber Midthunder","Dakota Beavers","Michelle Thrush","Stormee Kipp","Julian Black Antelope","Dane DiLiegro","Stefany Mathias","Bennett Taylor","Mike Paterson","Nels