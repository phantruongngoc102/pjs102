om/share/3dd26ce3b599b4fc1064800673f5b833","link_m3u8":"https://vip.opstream15.com/20220523/16083_1b5413cf/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/fb5ac34d9ac3cc3883230cb5b2b417bb","link_m3u8":"https://vip.opstream15.com/20220523/16085_d73ce73a/index.m3u8"}]}],"description":"<p>Cardia sống ngày này sang ngày khác tách biệt với thế giới bên ngoài, trong một tòa biệt thự bị bỏ hoang để hoàn thành lời hứa với cha mình. Nguyên nhân là do cơ thể của Cardia chứa một chất độc chết người có thể làm hỏng hoặc tan chảy bất cứ thứ gì mà da Cardia chạm vào - khiến người dân địa phương gọi cô là \"con quái vật\", vì thế cha Cardia nói con gái mình hãy tránh xa tất cả mọi người và không được yêu ai, nhưng sau đó cha Cardia đột ngột biến mất. Một ngày nọ, sự cô đơn thường ngày của Cardia bị gián đoạn khi quân đội Hoàng gia đột nhập vào biệt thự để bắt cô. Chính thời điểm đó Cardia gặp tên trộm kỳ quái Arsène Lupin, người giúp cô trốn thoát khỏi Quân Đội Hoàng gia. Cardia sau đó cùng với Lupin trên chuyến phiêu lưu đi tìm cha của mình.</p>","tmdb_id":74084,"cast":["Saori Hayami","Tomoaki Maeno","Junichi Suwabe","Tetsuya Kakihara","Showtaro Morikubo","Daisuke Hirakawa","Miho Ishigami"],"director":["Hideyo Yamamoto"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"74084","season":1,"vote_average":6.1,"vote_count":15},"cast_meta":[{"name":"Saori Hayami","name_vi":null,"name_original":"Saori Hayami","tmdb_id":221773,"profile":"https://image.tmdb.org/t/p/w500/gLv9lO7dlUbIsmyJUvgegqAAXki.jpg","tmdb_url":"https://www.themoviedb.org/person/221773"},{"name":"Tomoaki Maeno","name_vi":null,"name_original":"Tomoaki Maeno","tmdb_id":1249235,"profile":"https://image.tmdb.org/t/p/w500/w3lEuXSbEyzzNyO3YnxsF6wm2N5.jpg","tmdb_url":"https://www.themoviedb.org/person/1249235"},{"name":"Junichi Suwabe","name_vi":null,"name_original":"Junichi Suwabe","tmdb_id":9721,"profile":"https://image.tmdb.org/t/p/w500/4S7c3n3r07A83HvkLrnWZGVhiHg.jpg","tmdb_url":"https:/