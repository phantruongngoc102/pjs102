ream15.com/share/977b33ace8251dd9bee913e7ba56eebc","link_m3u8":"https://vip.opstream15.com/20220417/4364_9196a0f1/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Trong thời đại mà con người và ác quỷ cùng tồn tại, Ma Vương đã bắt cóc công chúa và giam giữ cô ấy trong lâu đài của chính mình. Công chúa Suyaris bị giam giữ vừa lẩm bẩm: \"Ngoài ngủ ra mình chẳng có việc gì để làm cả!\", cô vừa lẻn ra khỏi nhà tù, khám phá Lâu đài Quỷ để tìm kiếm một giấc ngủ thật ngon. Cô công chúa yêu tự do này đã lôi kéo bọn quái vật và làm mọi điều cô thích.</p>","tmdb":{"type":"tv","id":"97923","season":1,"vote_average":8.35,"vote_count":130},"modified":"2025-06-17T19:36:37.000Z","cast":["Inori Minase","Ishikawa Kaito","Yoshitsugu Matsuoka","Hiro Shimono","Rikiya Koyama","Kouichi Souma","Junichi Suwabe","Shinya Takahashi","Chikahiro Kobayashi","Sayaka Ohara","Ayane Sakura","Takeo Otsuka","Masashi Yamane","Takaya Kuroda","Sayaka Ohara"],"director":[],"cast_meta":[{"name":"Inori Minase","name_vi":null,"name_original":"Inori Minase","tmdb_id":1325949,"profile":"https://image.tmdb.org/t/p/w500/cqOrQDUbbQLKpujzcK47YqjFdNp.jpg","tmdb_url":"https://www.themoviedb.org/person/1325949"},{"name":"Ishikawa Kaito","name_vi":"Ishikawa Kaito","name_original":"Kaito Ishikawa","tmdb_id":1324666,"profile":"https://image.tmdb.org/t/p/w500/fzjIkotjUHHs3wgftM9tqdsG8ph.jpg","tmdb_url":"https://www.themoviedb.org/person/1324666"},{"name":"Yoshitsugu Matsuoka","name_vi":null,"name_original":"Yoshitsugu Matsuoka","tmdb_id":233590,"profile":"https://image.tmdb.org/t/p/w500/ugDwdWEXnmv43jcbnfAi4XwiQ8C.jpg","tmdb_url":"https://www.themoviedb.org/person/233590"},{"name":"Hiro Shimono","name_vi":null,"name_original":"Hiro Shimono","tmdb_id":119145,"profile":"https://image.tmdb.org/t/p/w500/yrSDcgFefHtWkFmLnTrcw2t0MV.jpg","tmdb_url":"https://www.themoviedb.org/person/119145"},{"name":"Rikiya Koyama","name_vi":null,"name_original":"Rikiya Koyama","tmdb_id":237076,"profile":"https://image.tmdb.org/t/p/w500/h