 gián Huỳnh Liên. Một hôm, Tấn Thăng kinh ngạc phát hiện mình có khả năng là cháu đích tôn của nhà họ Kim. Với sự xúi giục của Huỳnh Liên, Thăng quyết giành lại tài sản thuộc về mình.","tmdb_id":93336,"cast":["Lê Diệu Tường","Trần Quốc Bang","Tiêu Chính Nam","Tào Vĩnh Liêm","Khương Đại Vệ","Hồ Định Hân","Natalie Tong","Lâm Hạ Vy","Toby Chan","Grace Wong","Yoyo Chen Chi-Yiu"],"director":["La Vĩnh Hiền"],"keywords":[],"time":"45 phút/tập","tmdb":{"type":"tv","id":"93336","season":1,"vote_average":8,"vote_count":1},"cast_meta":[{"name":"Lê Diệu Tường","name_vi":"Lê Diệu Tường","name_original":"Wayne Lai Yiu-Cheung","tmdb_id":123654,"profile":"https://image.tmdb.org/t/p/w500/qm3knPxzkZPgq2SVo1ZTru7MkIM.jpg","tmdb_url":"https://www.themoviedb.org/person/123654"},{"name":"Trần Quốc Bang","name_vi":"Trần Quốc Bang","name_original":"Power Chan Kwok-Pong","tmdb_id":66010,"profile":"https://image.tmdb.org/t/p/w500/o5wZEj3oS527cE4g1JdfVledphb.jpg","tmdb_url":"https://www.themoviedb.org/person/66010"},{"name":"Tiêu Chính Nam","name_vi":"Tiêu Chính Nam","name_original":"Edwin Siu","tmdb_id":1059226,"profile":"https://image.tmdb.org/t/p/w500/bPEjnmBPWTZcrWQklkqcT1bUQwb.jpg","tmdb_url":"https://www.themoviedb.org/person/1059226"},{"name":"Tào Vĩnh Liêm","name_vi":"Tào Vĩnh Liêm","name_original":"Raymond Cho Wing-Lim","tmdb_id":1223053,"profile":"https://image.tmdb.org/t/p/w500/pU3V6I4xp4wIGRix7wibb5ga4wk.jpg","tmdb_url":"https://www.themoviedb.org/person/1223053"},{"name":"Khương Đại Vệ","name_vi":"Khương Đại Vệ","name_original":"David Chiang Da-Wei","tmdb_id":65986,"profile":"https://image.tmdb.org/t/p/w500/7Wwna95s5U3g7T3z4s7uD51ZAXX.jpg","tmdb_url":"https://www.themoviedb.org/person/65986"},{"name":"Hồ Định Hân","name_vi":"Hồ Định Hân","name_original":"Nancy Wu","tmdb_id":1234856,"profile":"https://image.tmdb.org/t/p/w500/9HPuplvtWO5ODGX0IhNaZsssIi4.jpg","tmdb_url":"https://www.themoviedb.org/person/1234856"},{"name":"Natalie Tong","name_vi":null,"name_original":"Natalie Tong",