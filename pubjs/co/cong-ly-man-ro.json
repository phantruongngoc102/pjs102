{"id":"63a144c0418cb6827f4ed5f7","title":"Công Lý Man Rợ","origin_name":"Savage Salvation","slug":"cong-ly-man-ro","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/co/cong-ly-man-ro.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/co/cong-ly-man-ro.webp","year":2022,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2238e0fc277084dfd291","name":"Tâm Lý","slug":"tam-ly"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Savage.Salvation.2022.1080p.WEBRip.x264-RARBG","link_embed":"https://vip.opstream16.com/share/4a2cde3ca35a41a388c8cc1e19edcbdb","link_m3u8":"https://vip.opstream16.com/20230211/31364_4348417d/index.m3u8"}]}],"time":"1 giờ 41 phút","description":"<p>Sheriff Church ( Robert De Niro ) và Thám tử Zeppelin cố gắng giữ hòa bình trong thị trấn gồ ghề của họ, nơi mà hai lợi ích duy nhất của cư dân là nhà thờ hoặc oxycodone. Shelby John ( Jack Huston ) và Ruby Red mới đính hôn muốn có một khởi đầu mới. Họ quyết định cùng nhau có một gia đình và trở nên trong sạch, với sự hỗ trợ của Peter, anh rể của Ruby ( John Malkovich). Tuy nhiên, Shelby phát hiện ra Ruby yêu dấu của mình đã chết trước hiên nhà của họ trước khi cô ấy có thể thực hiện ước nguyện cuối cùng của mình: được rửa tội dưới dòng sông và rửa sạch tội lỗi trong quá khứ. Tràn đầy cơn thịnh nộ, Shelby dấn thân vào một cuộc giết người đầy thù hận để sửa chữa mọi sai trái mà mọi mắt xích trong chuỗi buôn bán ma túy đã gây ra cho Ruby. Không được trang bị gì ngoài adrenaline và một khẩu súng bắn đinh, Shelby lần lượt hạ gục những người chia bài và những kẻ nghiện ngập cho đến khi anh ta lên đến đỉnh.&nbsp;</p>","tmdb":{"type":"movie","id":"740952","season":null,"vote_average":6.2,"vote_count":269},"modified":"2023-02-11T20:25:35.000Z","cast":["Jack Huston","Robert De Niro","John Malkovich","Willa Fitzgerald","Quavo","Meadow Williams","Swen Temmel","Noel Gugliemi","Jonny Orsini","Dale Dickey","Winter Ave Zoli","Lindsay Pulsipher","Tyler Jon Olson","Katalina Viteri","Tierney Smith"],"director":["Randall Emmett"],"cast_meta":[{"name":"Jack Huston","name_vi":null,"name_original":"Jack Huston","tmdb_id":54738,"profile":"https://image.tmdb.org/t/p/w500/dopiwKGjFiWYlC4Pi5U9NNVgbgr.jpg","tmdb_url":"https://www.themoviedb.org/person/54738"},{"name":"Robert De Niro","name_vi":null,"name_original":"Robert De Niro","tmdb_id":380,"profile":"https://image.tmdb.org/t/p/w500/cT8htcckIuyI1Lqwt1CvD02ynTh.jpg","tmdb_url":"https://www.themoviedb.org/person/380"},{"name":"John Malkovich","name_vi":null,"name_original":"John Malkovich","tmdb_id":6949,"profile":"https://image.tmdb.org/t/p/w500/7GoOdGNc4ra1L0F5nJTkmIB37iu.jpg","tmdb_url":"https://www.themoviedb.org/person/6949"},{"name":"Willa Fitzgerald","name_vi":null,"name_original":"Willa Fitzgerald","tmdb_id":1318650,"profile":"https://image.tmdb.org/t/p/w500/hXvCqRAtmrfjozHtVNrBgXFzzao.jpg","tmdb_url":"https://www.themoviedb.org/person/1318650"},{"name":"Quavo","name_vi":null,"name_original":"Quavo","tmdb_id":2138143,"profile":"https://image.tmdb.org/t/p/w500/xnNpJvPluhit6LFxLEFlbZwHtoJ.jpg","tmdb_url":"https://www.themoviedb.org/person/2138143"},{"name":"Meadow Williams","name_vi":null,"name_original":"Meadow Williams","tmdb_id":956385,"profile":"https://image.tmdb.org/t/p/w500/iECIpEM4BWt94kvOMKFJqv5uJEU.jpg","tmdb_url":"https://www.themoviedb.org/person/956385"},{"name":"Swen Temmel","name_vi":null,"name_original":"Swen Temmel","tmdb_id":1075049,"profile":"https://image.tmdb.org/t/p/w500/z6zLmf3PBsTGMU3RBnguAqfHUn3.jpg","tmdb_url":"https://www.themoviedb.org/person/1075049"},{"name":"Noel Gugliemi","name_vi":null,