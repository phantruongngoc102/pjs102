a đã dùng bạo lực, nhưng lý trí đã thắng được cảm xúc...</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/co/cong-nhan-ty-phu-short-drama.json","tmdb_checked":false}