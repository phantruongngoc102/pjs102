ọ tìm ra manh mối.</p>","tmdb":{"type":"movie","id":"434119","season":null,"vote_average":6.857,"vote_count":140},"modified":"2023-03-13T21:30:13.000Z","cast":["Hyun Bin","Yoo Hai-jin","Kim Joo-hyuk","Jang Young-nam","Lee Dong-hwi","Yoona","Kong Jeong-hwan","Lee Hae-yeong","Park Min-ha","Jeon Kuk-hwan","Uhm Hyo-seop","Lee Yi-kyung","Shin Hyun-been","Park Jin-woo","Park Hyoung-soo"],"director":["Kim Sung-hoon"],"cast_meta":[{"name":"Hyun Bin","name_vi":null,"name_original":"Hyun Bin","tmdb_id":544107,"profile":"https://image.tmdb.org/t/p/w500/JQFzhO9j8HRiyr7leGPj6cqhvM.jpg","tmdb_url":"https://www.themoviedb.org/person/544107"},{"name":"Yoo Hai-jin","name_vi":null,"name_original":"Yoo Hai-jin","tmdb_id":84996,"profile":"https://image.tmdb.org/t/p/w500/y6L2EsmnbnCFxCgfHR2oeL7oQoo.jpg","tmdb_url":"https://www.themoviedb.org/person/84996"},{"name":"Kim Joo-hyuk","name_vi":null,"name_original":"Kim Joo-hyuk","tmdb_id":123766,"profile":"https://image.tmdb.org/t/p/w500/nNZzUKARziU8V77Hh8xIJ89neRu.jpg","tmdb_url":"https://www.themoviedb.org/person/123766"},{"name":"Jang Young-nam","name_vi":null,"name_original":"Jang Young-nam","tmdb_id":93996,"profile":"https://image.tmdb.org/t/p/w500/u0hl8WSswFhKVaKwaMAERU0xUJk.jpg","tmdb_url":"https://www.themoviedb.org/person/93996"},{"name":"Lee Dong-hwi","name_vi":null,"name_original":"Lee Dong-hwi","tmdb_id":1418580,"profile":"https://image.tmdb.org/t/p/w500/dqGCVaJ5yuGgKTPUEqCJNk8Nzbs.jpg","tmdb_url":"https://www.themoviedb.org/person/1418580"},{"name":"Yoona","name_vi":null,"name_original":"Yoona","tmdb_id":1252045,"profile":"https://image.tmdb.org/t/p/w500/JzAuAv17bWkLxVtfi9YJvQJhZl.jpg","tmdb_url":"https://www.themoviedb.org/person/1252045"},{"name":"Kong Jeong-hwan","name_vi":null,"name_original":"Kong Jeong-hwan","tmdb_id":123824,"profile":"https://image.tmdb.org/t/p/w500/v4O5Ua8MDKO6UFnz3TWuzA0ujrX.jpg","tmdb_url":"https://www.themoviedb.org/person/123824"},{"name":"Lee Hae-yeong","name_vi":null,"name_original":"Lee Hae-yeong"