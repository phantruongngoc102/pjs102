re/15d0324c4cba39035aedcf51adc6262b","link_m3u8":"https://vip.opstream15.com/20230616/39889_a78227af/index.m3u8"},{"name":"34","slug":"34","filename":"Prosecution Elite EP34","link_embed":"https://vip.opstream15.com/share/3de3b7d9e1ec9e717cf6f5182c9546ad","link_m3u8":"https://vip.opstream15.com/20230617/39902_862c7383/index.m3u8"},{"name":"35","slug":"35","filename":"Prosecution Elite EP35","link_embed":"https://vip.opstream15.com/share/7cbb793c46d7cad3981035cf922bd3f1","link_m3u8":"https://vip.opstream15.com/20230618/39925_a2777f34/index.m3u8"},{"name":"36","slug":"36","filename":"Prosecution Elite EP36","link_embed":"https://vip.opstream15.com/share/39d16e8efa2fe7277bc8eee5c5352ec8","link_m3u8":"https://vip.opstream15.com/20230618/39926_69d67d57/index.m3u8"},{"name":"37","slug":"37","filename":"Công Tố Tinh Anh 37","link_embed":"https://vip.opstream11.com/share/e4656174f0a5436efd535a9a9d050e09","link_m3u8":"https://vip.opstream11.com/20230619/44959_096824e3/index.m3u8"},{"name":"38","slug":"38","filename":"Công Tố Tinh Anh 38","link_embed":"https://vip.opstream11.com/share/3e50ca86fdcdd0a6aae61164aa80c9db","link_m3u8":"https://vip.opstream11.com/20230619/44960_bbfbbcd4/index.m3u8"},{"name":"39","slug":"39","filename":"Prosecution Elite EP39","link_embed":"https://vip.opstream11.com/share/70699f79c6aeddeb2d322d7074c2f366","link_m3u8":"https://vip.opstream11.com/20230620/44987_46f46def/index.m3u8"},{"name":"40","slug":"40","filename":"Prosecution Elite EP40","link_embed":"https://vip.opstream11.com/share/363ed890155b2eeda0aa492cc52e3d34","link_m3u8":"https://vip.opstream11.com/20230620/44988_932c2fd4/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>An Ni, một công tố viên của Viện kiểm sát Giang Thành, được Trưởng công tố Xu An Lâm giao nhiệm vụ điều tra vụ án một sinh viên đại học mất tích nhảy xuống hồ. Cô bắt đầu với Zhao Jikai, Tổng giám đốc của Huiquan Games, và tìm thấy mối liên hệ giữa anh ta với các tổ chức ở nước ngoài thúc đẩy bắt nạt, dẫn đến việc bắt giữ những kẻ phạm tội. Trong khi giá cổ phiếu của Huiquan Games giảm mạnh, Yin Huiquan quyên góp cho Học viện Jiangxiao, từ đó sẽ làm hư hỏng trẻ vị thành niên dưới chiêu bài từ thiện.</p><p>Sinh viên Li Xiaowen và các nạn nhân khác tiến lên, công khai tố cáo các phương tiện không chính thống của Học viện Jiangxiao để kiểm soát thanh niên. An Ni trình bày bằng chứng chắc chắn trước tòa, dẫn đến việc đóng cửa học viện và trừng phạt những người có liên quan.</p><p>Yan Qin, người đã tiếp quản Huiquan Games, đã biển thủ quỹ để đầu tư vào việc phát triển một mỏ đồng. Tuy nhiên, liên doanh đầu tư này là một kế hoạch Ponzi của một băng nhóm lừa đảo tài chính trực tuyến. Có đầy đủ bằng chứng, An Ni ra nước ngoài tham gia phiên tòa xuyên biên giới. Với sự hợp tác của các tổ chức tư pháp Trung Quốc và nước ngoài, Qian Tianxin được đưa về Trung Quốc và tài sản của anh ta bị đóng băng.</p>","tmdb":{"type":"tv","id":"155754","season":1,"vote_average":7.1,"vote_count":11},"modified":"2023-06-20T21:48:50.000Z","cast":["Địch Lệ Nhiệt Ba","Đồng Đại Vĩ","Una You","Gao Xin","Luo Haiqiong","Lei Han","Phùng Lỗi","Trần Tử Hàm","Hàn Đống","Ma Yuan","Quách Già Nam","Hùng Tử Kỳ","Xu Wenguang","Mã Tô","Li Yixiao"],"director":[],"cast_meta":[{"name":"Địch Lệ Nhiệt Ba","name_vi":"Địch Lệ Nhiệt Ba","name_original":"Dilraba Dilmurat","tmdb_id":1557698,"profile":"https://image.tmdb.org/t/p/w500/bLa0rBHdZ4Su1l5Xh0cY4mTB70Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1557698"},{"name":"Đồng Đại Vĩ","name_vi":"Đồng Đại Vĩ","name_original":"Tong Dawei","tmdb_id":1031246,"profile":"https://image.tmdb.org/t/p/w500/rU2KjybHgkoeNeuLwoh5dYn6E2M.jpg","tmdb_url":"https://www.themoviedb.org/person/1031246"},{"name":"Una You","name_vi":null,"name_original":"Una You","tmdb_id":1859899,"profile":"https://image.tmdb.org/t/p/w500/5Q0Ho5x9a2sK1uD2P9qiKbHSRk7.jpg","tmdb_url":"https://www.themoviedb.org/person/1859899"},{"name":"Gao Xin","name_vi":null,"name_original":"Gao Xin","tmdb_id":1177285,"profile":