pstream14.com/20220416/8069_455821ed/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Bị nguyền rủa từ nhỏ, một công tước trẻ nhận được thứ sức mạnh không hề mong muốn là giết hết mọi thứ mà cậu ta chạm vào. Bị buộc phải cách xa gia đình và sống ở một dinh thự sâu trong rừng, cậu bị đối xử như thể không có tồn tại và tiếp tục bị mọi người xa lánh. Tuy nhiên cậu không chỉ một mình. Rob và Alice là quản gia và người hầu luôn ở bên cạnh cậu ta. Alice thích trêu chọc cậu, và dần dà mối quan hệ giữa hai người phát triển, cậu công tước trẻ muốn phá bỏ lời nguyền chết chóc của mình. Để giải được lời nguyền ấy, cậu sẽ cần đến sự trợ giúp từ những người bạn với sức mạnh siêu nhiên.</p>","tmdb":{"type":"tv","id":"117992","season":1,"vote_average":7.795,"vote_count":112},"modified":"2025-06-05T15:55:57.000Z","cast":["Hanae Natsuki","Ayumi Mano","Hochu Otsuka","Inori Minase","Wakana Kuramochi","Hiroshi Kamiya","Yuma Uchida","Yoko Hikasa"],"director":[],"cast_meta":[{"name":"Hanae Natsuki","name_vi":"Hanae Natsuki","name_original":"Natsuki Hanae","tmdb_id":1256603,"profile":"https://image.tmdb.org/t/p/w500/alTb0DlcPIbcwM08WSmxFai58sd.jpg","tmdb_url":"https://www.themoviedb.org/person/1256603"},{"name":"Ayumi Mano","name_vi":null,"name_original":"Ayumi Mano","tmdb_id":2210352,"profile":"https://image.tmdb.org/t/p/w500/umEB1uxpyGCy6866NzE5V2PvaAu.jpg","tmdb_url":"https://www.themoviedb.org/person/2210352"},{"name":"Hochu Otsuka","name_vi":null,"name_original":"Hochu Otsuka","tmdb_id":552683,"profile":"https://image.tmdb.org/t/p/w500/3RHQcrsWnAFK6AifSis1lMq08cR.jpg","tmdb_url":"https://www.themoviedb.org/person/552683"},{"name":"Inori Minase","name_vi":null,"name_original":"Inori Minase","tmdb_id":1325949,"profile":"https://image.tmdb.org/t/p/w500/cqOrQDUbbQLKpujzcK47YqjFdNp.jpg","tmdb_url":"https://www.themoviedb.org/person/1325949"},{"name":"Wakana Kuramochi","name_vi":null,"name_original":"Wakana Kuramochi","tmdb_id":3080027,"profile":"https://image.tmdb.org/t/p/w500/xQJa1