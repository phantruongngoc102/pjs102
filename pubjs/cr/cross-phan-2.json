10.com/share/9a159616e77ecc3db8449214fddbc43e","link_m3u8":"https://vip.opstream10.com/20260313/33027_9a159616/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/62c1507b8202cd94f44733de18ea736b","link_m3u8":"https://vip.opstream10.com/20260320/33096_62c1507b/index.m3u8"}]}],"description":"<p>Sau những sự kiện chấn động ở phần 1, Alex Cross (do Aldis Hodge thủ vai) giờ đây đã vượt qua được nỗi đau mất vợ nhờ trị liệu và quay trở lại công việc với một tinh thần sắc bén hơn. Lần này, Alex phải đối mặt với một nữ sát thủ kiêm dân phòng (vigilante) cực kỳ thông minh và tàn nhẫn tên là Rebecca (hay còn gọi là Luz), nhắm mục tiêu vào những nhà tài phiệt tham nhũng, những kẻ đứng sau các đường dây buôn người và bóc lột lao động trẻ em. Alex phối hợp cùng cộng sự John Sampson và đặc vụ FBI Kayla Craig để điều tra các mối đe dọa nhắm vào Lance Durand (Matthew Lillard) - một tỷ phú công nghệ tin rằng mình là mục tiêu tiếp theo của kẻ sát nhân. Cross Phần 2 là mùa phim nối từ thành công của mùa 1, khai thác một vụ án mới đầy gay cấn với tâm điểm là một kẻ truy đuổi công lý theo cách riêng, buộc Alex Cross phải đối mặt với những ranh giới đạo đức sắc bén hơn bao giờ hết.</p>","tmdb_id":213306,"cast":["Aldis Hodge","Isaiah Mustafa","Juanita Jennings","Alona Tal","Samantha Walkes","Caleb Elijah","Melody Hurd","Johnny Ray Gill","Jeanine Mason","Wes Chatham","Matthew Lillard"],"director":["Stacey Muhammad","Craig Siebels","Nzingha Stewart"],"keywords":[],"tmdb":{"type":"tv","id":"213306","season":2,"vote_average":7.1,"vote_count":239},"cast_meta":[{"name":"Aldis Hodge","name_vi":null,"name_original":"Aldis Hodge","tmdb_id":83860,"profile":"https://image.tmdb.org/t/p/w500/enDU0pemco1mFxxdLKUzWakC6sk.jpg","tmdb_url":"https://www.themoviedb.org/person/83860"},{"name":"Isaiah Mustafa","name_vi":null,"name_original":"Isaiah Mustafa","tmdb_id":1237603,"profile":"https://image.tmdb.org/t/p/w500/tnwz9bf0bplixzyaqyu4iAI9lLj.jpg","tmdb_url":"https://www.themov