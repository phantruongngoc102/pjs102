ông góp mặt xuyên suốt phim như ở phần 1 nhưng trong phần 2 Trần Triển Bằng và Chung Gia Hân vẫn tham gia với tư cách khách mời. Từ đây, người hâm mộ sẽ có được câu trả lời cho chuyện tình giữa Kiều Thiên Sinh (do Trần Triển Bằng đóng) và Trác Tịnh (do Chung Gia Hân đóng) vốn có kết thúc mở không rõ ràng ở phần 1.","tmdb":{"type":"tv","id":"89662","season":1,"vote_average":8,"vote_count":1},"modified":"2024-12-29T19:44:40.000Z","cast":["Tiêu Chính Nam","Kristal Tin Yui-Nei","Louis Yuen Siu-Cheung","Grace Chan","Mat Yeung","Ngô Đại Dung","Lương Tranh","Tsui Wing","Lý Giai Tâm","Steven Cheung Chi-Hang","Trần Triển Bằng","Chung Gia Hân","Chun Wong","Lưu Giang","Yu Chi-Ming"],"director":[],"cast_meta":[{"name":"Tiêu Chính Nam","name_vi":"Tiêu Chính Nam","name_original":"Edwin Siu","tmdb_id":1059226,"profile":"https://image.tmdb.org/t/p/w500/bPEjnmBPWTZcrWQklkqcT1bUQwb.jpg","tmdb_url":"https://www.themoviedb.org/person/1059226"},{"name":"Kristal Tin Yui-Nei","name_vi":null,"name_original":"Kristal Tin Yui-Nei","tmdb_id":123650,"profile":"https://image.tmdb.org/t/p/w500/mjXRFqm1TS6faWfKeOoAGGrgHyU.jpg","tmdb_url":"https://www.themoviedb.org/person/123650"},{"name":"Louis Yuen Siu-Cheung","name_vi":null,"name_original":"Louis Yuen Siu-Cheung","tmdb_id":579496,"profile":"https://image.tmdb.org/t/p/w500/9Ws35BMwo00MUOI53vCaLPhAdZ.jpg","tmdb_url":"https://www.themoviedb.org/person/579496"},{"name":"Grace Chan","name_vi":null,"name_original":"Grace Chan","tmdb_id":2167972,"profile":"https://image.tmdb.org/t/p/w500/tahksYydlyLQGPUDYzcQ9M6wAdv.jpg","tmdb_url":"https://www.themoviedb.org/person/2167972"},{"name":"Mat Yeung","name_vi":null,"name_original":"Mat Yeung","tmdb_id":1588970,"profile":"https://image.tmdb.org/t/p/w500/1YLrCj101GPUsYFRW6MNrUnY06x.jpg","tmdb_url":"https://www.themoviedb.org/person/1588970"},{"name":"Ngô Đại Dung","name_vi":"Ngô Đại Dung","name_original":"Hugo Ng Doi-Yung","tmdb_id":1187932,"profile":"https://image.tmdb.org/t/p/w500/1FNy7eOKdfjQcKT1aIjv6G0ak