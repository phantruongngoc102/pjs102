ận đan xen, những bí ẩn dần được phơi bày. Sau màn sương mù ấy, hóa ra còn có một người trọng sinh khác đang âm thầm thao túng tất cả.</p>","tmdb":{"type":"tv","id":"318434","season":1,"vote_average":0,"vote_count":0},"modified":"2026-04-18T14:14:41.000Z","cast":["Phương Cẩn","Zhang Jingyun"],"director":["Ye Lu"],"cast_meta":[{"name":"Phương Cẩn","name_vi":"Phương Cẩn","name_original":"Fang Jin","tmdb_id":3541107,"profile":"https://image.tmdb.org/t/p/w500/zyFWHwiQkUoxD4gwhsJqXUIdaP8.jpg","tmdb_url":"https://www.themoviedb.org/person/3541107"},{"name":"Zhang Jingyun","name_vi":null,"name_original":"Zhang Jingyun","tmdb_id":3895280,"profile":"https://image.tmdb.org/t/p/w500/l96qPaucPWpboSIquSWpJ34GdBw.jpg","tmdb_url":"https://www.themoviedb.org/person/3895280"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cu-the-ma-gap-em.json"}