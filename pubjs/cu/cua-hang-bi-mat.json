e0d51f63e94","link_m3u8":"https://vip.opstream12.com/20220615/19998_4e46b5a8/index.m3u8"}]}],"time":"70 phút / tập","description":"<p>Đây là một bộ phim về sức mạnh của phụ nữ và giới thượng lưu khi họ tham nhũng để tìm kiếm quyền lực và tiền tài. Nội dung xoay quanh người phụ nữ nghèo tên là Jenny Jang (Kim Sun A), cô ta làm việc tại nhà tắm ở Gangnam, Seoul. Một ngày nọ, cô bắt đầu công việc mới với tư cách là người giúp việc cho một gia đình tập đoàn. Sau đó cô trở nên thành công và điều hành một cửa hàng thời trang J Boutique. Cô cũng bắt đầu vận động hành lang để được tham gia vào một dự án phát triển thành phố quốc tế.</p>","tmdb":{"type":"tv","id":"93096","season":1,"vote_average":7.5,"vote_count":4},"modified":"2023-06-23T19:36:59.000Z","cast":["Kim Seon-a","Chang Mi-hee","Park Hee-von","Kim Jae-young","Go Min-si","Ryu Won","Kim Tae-hun","Ryu Seung-su","Han Jung-soo","Jeong Da-eun","Kim Young-ah","Kim Sung-hyun","Jeong Yoon-hee","Kwon Eun-bin","Chang Ryul"],"director":["Park Hyung Ki"],"cast_meta":[{"name":"Kim Seon-a","name_vi":null,"name_original":"Kim Seon-a","tmdb_id":83221,"profile":"https://image.tmdb.org/t/p/w500/xzS16c1pZwjrhrbj5SGENtRaQkk.jpg","tmdb_url":"https://www.themoviedb.org/person/83221"},{"name":"Chang Mi-hee","name_vi":null,"name_original":"Chang Mi-hee","tmdb_id":1232910,"profile":"https://image.tmdb.org/t/p/w500/eg0crttwzJNdFRhMGrBUjGGv93.jpg","tmdb_url":"https://www.themoviedb.org/person/1232910"},{"name":"Park Hee-von","name_vi":null,"name_original":"Park Hee-von","tmdb_id":1177278,"profile":"https://image.tmdb.org/t/p/w500/uSpV4VUiwffp6SdFxSmD56Sf6qU.jpg","tmdb_url":"https://www.themoviedb.org/person/1177278"},{"name":"Kim Jae-young","name_vi":null,"name_original":"Kim Jae-young","tmdb_id":1613823,"profile":"https://image.tmdb.org/t/p/w500/s6qcQ7rvKOjMZOsxcl1KgYLHIiz.jpg","tmdb_url":"https://www.themoviedb.org/person/1613823"},{"name":"Go Min-si","name_vi":null,"name_original":"Go Min-si","tmdb_id":1787992,"profile":"https://image.tmd