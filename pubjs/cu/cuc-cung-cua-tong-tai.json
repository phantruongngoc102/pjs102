.</p>","tmdb":{"type":"tv","id":"132933","season":1,"vote_average":0,"vote_count":0},"modified":"2023-04-16T14:45:19.000Z","cast":[],"director":[],"cast_meta":[],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuc-cung-cua-tong-tai.json"}