m15.com/share/8ed16b12adc574bb06ec2cb2f5479952","link_m3u8":"https://vip.opstream15.com/20230105/30933_5b736c2a/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream15.com/share/a64f23737e72f85b8fc0eb8ad5b36458","link_m3u8":"https://vip.opstream15.com/20230105/30934_bf1b6603/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream15.com/share/00fae5fc28cb7bd60be9ab6609b9bbf7","link_m3u8":"https://vip.opstream15.com/20230105/30935_5cbf21f6/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream15.com/share/dc96a8266db03d23c786f970c7ddabc0","link_m3u8":"https://vip.opstream15.com/20230105/30936_251a5a46/index.m3u8"},{"name":"55","slug":"55","link_embed":"https://vip.opstream15.com/share/aff00d3a27b58d7e744930ba3a082559","link_m3u8":"https://vip.opstream15.com/20230105/30937_65ea2d03/index.m3u8"},{"name":"56","slug":"56","link_embed":"https://vip.opstream15.com/share/db525c87bd3c69102f83450fbf2c684c","link_m3u8":"https://vip.opstream15.com/20230105/30938_df232c5d/index.m3u8"},{"name":"57","slug":"57","link_embed":"https://vip.opstream15.com/share/c32bcab0e62184cead6c4af4423a9ccf","link_m3u8":"https://vip.opstream15.com/20230105/30939_9e0fc3e5/index.m3u8"},{"name":"58","slug":"58","link_embed":"https://vip.opstream15.com/share/ee4fc5879a7f4f3f200ea3d194facf12","link_m3u8":"https://vip.opstream15.com/20230105/30940_f212afc8/index.m3u8"},{"name":"59","slug":"59","link_embed":"https://vip.opstream15.com/share/ae5f326e8e13fa9517e18acae3b29348","link_m3u8":"https://vip.opstream15.com/20230105/30941_0122c32a/index.m3u8"},{"name":"60","slug":"60","link_embed":"https://vip.opstream15.com/share/93eb9cfb64391c4ee20ac49e72216fa4","link_m3u8":"https://vip.opstream15.com/20230105/30942_abf7c6e8/index.m3u8"}]}],"description":"<p>Bộ phim Cục Cưng Rắc Rối - Childless Comfort xoay quanh câu chuyện về gia đình nhà họ Ahn có ba thế hệ sống chung dưới một mái nhà. Mối quan hệ tam đại đồng đường với cả những yêu thương, trách nhiệm, lẫn những rắc rối, va chạm, bất đồng thế hệ qua từng tập của bộ phim với những tình huống vừa hài hước vừa sâu sắc và thực tế. Trong phim, cô cháu gái bảo bối của gia đình vốn là con gái của con trai cả trong nhà, là một người thông minh, có học vấn cao nhưng lại trở thành mẹ đơn thân. Điều này khiến cả gia đình lâm vào rắc rối, và những chỉ trích nghiệt ngã cô phải hứng chịu khi đối mặt với dư luận xã hội. Những tranh cãi trong cuộc sống hàng ngày giữa cha mẹ và con cái, những mối quan hệ đan xen phức tạp luôn xảy ra. Và trong đó, con cái là gánh nặng hay sẽ là sợi dây tháo gỡ những xung đột giữa các thế hệ?</p>","tmdb_id":50237,"cast":[],"director":[],"keywords":[],"tmdb":{"id":50237},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuc-cung-rac-roi.json"}