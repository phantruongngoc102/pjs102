.opstream12.com/20250222/25313_4ef11693/index.m3u8"},{"name":"37","slug":"37","filename":"My.Amazing.Bride.2015.S01E37.1080p.TV360.WEB-DL.H264.AAC-YH","link_embed":"https://vip.opstream12.com/share/1b12d60e85a7a2d7c03b9daad3d1959f","link_m3u8":"https://vip.opstream12.com/20250222/25314_1b12d60e/index.m3u8"},{"name":"38","slug":"38","filename":"My.Amazing.Bride.2015.S01E38.1080p.TV360.WEB-DL.H264.AAC-YH","link_embed":"https://vip.opstream12.com/share/14c0491f103ab436df4db61a97f227f2","link_m3u8":"https://vip.opstream12.com/20250222/25315_14c0491f/index.m3u8"},{"name":"39","slug":"39","filename":"My.Amazing.Bride.2015.S01E39.1080p.TV360.WEB-DL.H264.AAC-YH","link_embed":"https://vip.opstream12.com/share/51f2e9ae8acea3cede0ab0b8fbcd973d","link_m3u8":"https://vip.opstream12.com/20250222/25316_51f2e9ae/index.m3u8"},{"name":"40","slug":"40","filename":"My.Amazing.Bride.2015.S01E40.1080p.TV360.WEB-DL.H264.AAC-YH","link_embed":"https://vip.opstream12.com/share/141eb5e5e7f7efcaf70f35531014315a","link_m3u8":"https://vip.opstream12.com/20250222/25317_141eb5e5/index.m3u8"}]}],"time":"45 phút/tập","description":"Đường Đậu Đậu, một cô nương đã quá tuổi mà chưa chịu lấy chồng. Nàng rất có niềm tin rằng mình sẽ gặp được đức lang quân thông minh, tài trí, yêu chiều nàng. Nào ngờ, Đường gia gặp chuyện tan nhà nát cửa, phải nhờ trang chủ của Khổng Gia Trang ra tay tương cứu. Trang chủ phu nhân Giả Tương Bình gặp gỡ Đậu Đậu đề xuất hôn sự cho con trai lớn là Thẩm Bách Nam. Bách Nam từ nhỏ đã được người người phong tặng là thần đồng, tài hoa vẹn toàn. Trong đêm động phòng hoa chúc, bỗng nhiên thần đồng biến thành kẻ ngây ngốc khờ khạo, Đậu Đậu nổi giận đùng đùng, bỏ về lại Đường gia. Về nhà, nàng chứng kiến cha già bệnh nặng, mẹ già đã thu nhận hết lễ vật, không còn cách nào khác, Đậu Đậu đành quay trở lại nhà chồng, cùng Giả Tương Bình thỏa thuận hiệp ước 1 năm. Trong khi đó, Thẩm Bách Nam đối với Đậu Đậu si mê, một lòng một dạ, gây ra nhiều tình huống oái ăm, tình cảm cũng dần nảy sinh. Đậu Đậu nhận ra bệnh tình khờ khạo của Bách Nam có ẩn tình, quyết định âm thầm điều tra chân tướng sự việc.","tmdb":{"type":"tv","id":"119359","season":1,"vote_average":10,"vote_count":1},"modified":"2025-03-03T14:09:06.000Z","cast":["Lý Thấm","Kim Thế Giai","Ứng Hạo Minh","Gao Yang","Lu Yulin","Uyển Quỳnh Đan","Trình Phối Phối","Thiệu Mỹ Kỳ","Huang Wenhao"],"director":["梁勝權"],"cast_meta":[{"name":"Lý Thấm","name_vi":"Lý Thấm","name_original":"Li Qin","tmdb_id":568304,"profile":"https://image.tmdb.org/t/p/w500/thak4pt7jCPbl2xx5HnFhkEE0Tu.jpg","tmdb_url":"https://www.themoviedb.org/person/568304"},{"name":"Kim Thế Giai","name_vi":"Kim Thế Giai","name_original":"Jin Shijia","tmdb_id":1480174,"profile":"https://image.tmdb.org/t/p/w500/q8vtZEynxIODbPDIRUellNufUHH.jpg","tmdb_url":"https://www.themoviedb.org/person/1480174"},{"name":"Ứng Hạo Minh","name_vi":"Ứng Hạo Minh","name_original":"Ying Haoming","tmdb_id":1784502,"profile":"https://image.tmdb.org/t/p/w500/fbyZuhlhy1kKOJPMCU80oxoB7dQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1784502"},{"name":"Gao Yang","name_vi":null,"name_original":"Gao Yang","tmdb_id":1138126,"profile":"https://image.tmdb.org/t/p/w500/kyjg20IDp0x65jt42gE3iZmKzza.jpg","tmdb_url":"https://www.themoviedb.org/person/1138126"},{"name":"Lu Yulin","name_vi":null,"name_original":"Lu Yulin","tmdb_id":5020808,"profile":"https://image.tmdb.org/t/p/w500/2SS1Q4TvNh7gWgBaLkCvQjTOGWC.jpg","tmdb_url":"https://www.themoviedb.org/person/5020808"},{"name":"Uyển Quỳnh Đan","name_vi":"Uyển Quỳnh Đan","name_original":"Kingdom Yuen King-Tan","tmdb_id":94076,"profile":"https://image.tmdb.org/t/p/w500/nXVQeVWR0sMpW2eZ4blSqZt9ces.jpg","tmdb_url":"https://www.themoviedb.org/person/94076"},{"name":"Trình Phối Phối","name_vi":"Trình Phối Phối","name_original":"Cheng Pei-Pei","tmdb_id":1624,"profile":"https://image.tmdb.org/t/p/w500/jp33KMCMjy08FQWAtxhvJS2tHnn.jpg","tmdb_url":"https://www.themoviedb.org/person/1624"},{"name":"Thiệu Mỹ Kỳ","name_vi":"Thiệu Mỹ Kỳ","n