ream10.com/20220407/6062_db98d44b/index.m3u8"},{"name":"24","slug":"24","filename":"cuc-quan-ly-dong-vat-tap-24","link_embed":"https://vip.opstream10.com/share/ae2a2db40a12ec0131d48acc1218d2ef","link_m3u8":"https://vip.opstream10.com/20220407/6063_a5acbe49/index.m3u8"}]}],"time":"45M26S","description":"<p>Hác Vận mở một phòng khám tư nhân cho thú nuôi. Sau một tai nạn mất đi chú mèo của mình. Đồng thời cậu vô tình phát hiện có “người tinh” tồn tại trên đời. Cục quản lý động vật dẫn Hác Vận đi nhưng không tìm được cách xoá đi ký ức của cậu ta đành ép cậu gia nhập và trở thành đặc vụ. Từ đó, cuộc đời của Hác Vận đã thay đổi chóng mặt. Thì ra đâu đâu cũng có “người tinh”. Hác Vận và Ngô Ái Ái trở thành cộng sự, dần dần lật giải các vụ án…</p>","tmdb":{"type":"tv","id":"90117","season":1,"vote_average":8,"vote_count":6},"modified":"2023-06-02T18:16:52.000Z","cast":["Chen He","Vương Tử Văn","Đường Hiểu Thiên","Long Bin","Kong Songjin","Tan Quan","Huang Tianyuan","Huang Yilin","Quách Kinh Phi","Li Yinan","Chen Han"],"director":["Jin Zhe Yong","Li Ya Tao"],"cast_meta":[{"name":"Chen He","name_vi":null,"name_original":"Chen He","tmdb_id":1397016,"profile":"https://image.tmdb.org/t/p/w500/78V2SYzwekBQOK55F4CmFWTwk34.jpg","tmdb_url":"https://www.themoviedb.org/person/1397016"},{"name":"Vương Tử Văn","name_vi":"Vương Tử Văn","name_original":"Wang Ziwen","tmdb_id":1006594,"profile":"https://image.tmdb.org/t/p/w500/qcbGx4uKq3HAbAZRsZkrOztVgGe.jpg","tmdb_url":"https://www.themoviedb.org/person/1006594"},{"name":"Đường Hiểu Thiên","name_vi":"Đường Hiểu Thiên","name_original":"Tang Xiaotian","tmdb_id":2312401,"profile":"https://image.tmdb.org/t/p/w500/84NlC4nbZqwUJXH0tSNw9O6o3Um.jpg","tmdb_url":"https://www.themoviedb.org/person/2312401"},{"name":"Long Bin","name_vi":null,"name_original":"Long Bin","tmdb_id":4128061,"profile":"https://image.tmdb.org/t/p/w500/syDyQWvOIQTUxumjC76AkJJnqwK.jpg","tmdb_url":"https://www.themoviedb.org/person/4128061"},{"name":"Kong Songjin","name_vi":nul