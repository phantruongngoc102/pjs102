/20231115/37605_89c669ec/index.m3u8"},{"name":"16","slug":"16","filename":"Cực Tốc Bội Luận - Ep16","link_embed":"https://vip.opstream16.com/share/5d8508487ea46d5235bb6d5431c3c756","link_m3u8":"https://vip.opstream16.com/20231115/37606_8b1fbb4f/index.m3u8"},{"name":"17","slug":"17","filename":"Cực Tốc Bội Luận - Ep17","link_embed":"https://vip.opstream16.com/share/bc75da6b715e7bf1f4ab8af3f4ef294a","link_m3u8":"https://vip.opstream16.com/20231115/37607_26b3cc8c/index.m3u8"},{"name":"18","slug":"18","filename":"Cực Tốc Bội Luận - Ep18","link_embed":"https://vip.opstream16.com/share/f93de28d9a9839c043f525890cb2f2fa","link_m3u8":"https://vip.opstream16.com/20231115/37608_7a01fb47/index.m3u8"},{"name":"19","slug":"19","filename":"Cực Tốc Bội Luận - Ep19","link_embed":"https://vip.opstream16.com/share/9e38b231e32ad1066f81da8e83626957","link_m3u8":"https://vip.opstream16.com/20231115/37609_08be80e6/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Đây là câu chuyện tình yêu giữa một tay đua thiên tài nhưng xấu bụng và một kỹ sư đầy tài năng về cơ khí động học và khí động lực học.</p><p>Trần Mặc Bạch: Anh yêu em không phải vì sự ngây thơ của em mà bởi vì trên thế giới này, em là người hiểu anh nhất.</p><p>Văn án bản say rượu: Một con sói xám lớn xấu bụng một ngày đẹp trời nọ nổi hứng nuôi một mầm đậu nhỏ.</p><p>Mầm đậu nhỏ rất đáng yêu, lúc nào cũng hướng về phía ánh mặt trời, mong ngóng mùa xuân đến để nở hoa.</p><p>Sói xám càng nuôi càng thích, kiên quyết đánh bay mọi đối thủ có ý đồ với mầm đậu của hắn. (Lời tác giả: Tôi say mất rồi)</p><p>Văn án bản chính thức: Thẩm Khê có một cái dạ dày rất “to”, có một cái đầu cực kỳ thông minh, có một tâm hồn đơn giản cùng với một người rất cưng chiều cô có tên là Trần Mặc Bạch.&nbsp;</p>","tmdb":{"type":"tv","id":"238582","season":1,"vote_average":5.8,"vote_count":4},"modified":"2023-11-15T17:58:14.000Z","cast":["Trạch Tử Lộ","Ko Chia-Yen","James Lee","Chen Miqi","Chen Pengwanli","Ma Yinyin","Liu Jia","Zhu Ran","Li Jiansan","Da