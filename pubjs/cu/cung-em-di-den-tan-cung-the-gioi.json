.com/share/5c0321b6b78eecdfcf72e6a44222fef9","link_m3u8":"https://vip.opstream11.com/20220522/26061_cadb79a9/index.m3u8"},{"name":"35B","slug":"35b","filename":"cung-em-di-den-tan-cung-the-gioi-gank-your-heart-tap-35B","link_embed":"https://vip.opstream11.com/share/002fdf1e30206e2b0289c5bdc7d5a369","link_m3u8":"https://vip.opstream11.com/20220522/26063_a07a98fa/index.m3u8"}]}],"time":"35 phút","description":"<p>Cùng Em Đi Đến Tận Cùng Thế Giới - Gank Your Heart là bộ phim mới tâm lý, lãng mạng của Trung Quốc, được chuyển thể từ tác phẩm Điện Cạnh Luyến Nhân của Nam Dã Lâm Nhi. Cùng Em Đi Đến Tận Cùng Thế Giới kể về chàng trai Lý Hương Không (Vương Nhất Bác), là một game thủ tài năng và luôn cố gắng không ngừng để trở thành người giỏi nhất. Tuy là một cao thủ chiến thuật và chưa bao giờ chịu thất bại nhưng Hương Không luôn bị gắn mác gà mờ. Tình cờ anh quen biết với Khâu Ánh (Vương Tử Tuyền), một cô gái xinh đẹp, nhiệt huyết trong công việc nhưng cũng chưa bao giờ được đánh giá cao. Hai con người, một hoàn cảnh, họ khích lệ cùng nhau cố gắng và dần đạt được ước mơ.</p>","tmdb":{"type":"tv","id":"90504","season":1,"vote_average":8.4,"vote_count":9},"modified":"2022-05-22T14:01:09.000Z","cast":["Vương Nhất Bác","Vương Tử Hiên","Ngôn Thừa Húc","Đinh Quán Sâm","Lv Xiaoyu","Cheng Qimeng","Yan Xujia","Kodii Ke","Hoàng Hinh Dao","Guo Ziyu","Shi Dao"],"director":["Sa Duy Kỳ"],"cast_meta":[{"name":"Vương Nhất Bác","name_vi":"Vương Nhất Bác","name_original":"Wang Yibo","tmdb_id":1594612,"profile":"https://image.tmdb.org/t/p/w500/5akr656RvJX8hl1pa1qZckfiQeF.jpg","tmdb_url":"https://www.themoviedb.org/person/1594612"},{"name":"Vương Tử Hiên","name_vi":"Vương Tử Hiên","name_original":"Wang Zixuan","tmdb_id":4444646,"profile":"https://image.tmdb.org/t/p/w500/6yQGSuQh8hK3seJ2En63GE99CBh.jpg","tmdb_url":"https://www.themoviedb.org/person/4444646"},{"name":"Ngôn Thừa Húc","name_vi":"Ngôn Thừa Húc","name_original":"Jerry Yan","tmdb_id":2151540,"profile":"https://image.tmdb.org/t/p/w50