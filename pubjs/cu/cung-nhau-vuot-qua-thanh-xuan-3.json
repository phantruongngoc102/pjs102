share/428b8e0c8ae876e78e551367212ae73b","link_m3u8":"https://vip.opstream13.com/20251011/11887_428b8e0c/index.m3u8"},{"name":"25","slug":"25","filename":"Cùng Nhau Vượt Qua Thanh Xuân 3 - Tập 25---2022","link_embed":"https://vip.opstream13.com/share/94c28dcfc97557df0df6d1f7222fc384","link_m3u8":"https://vip.opstream13.com/20251011/11888_94c28dcf/index.m3u8"},{"name":"26","slug":"26","filename":"Cùng Nhau Vượt Qua Thanh Xuân 3 - Tập 26---2022","link_embed":"https://vip.opstream13.com/share/11a31db27a7b70be0bb9759cf73d0939","link_m3u8":"https://vip.opstream13.com/20251011/11889_11a31db2/index.m3u8"},{"name":"27","slug":"27","filename":"Cùng Nhau Vượt Qua Thanh Xuân 3 - Tập 27---2022","link_embed":"https://vip.opstream13.com/share/56f88dc950d4b32c2a461b792372f82f","link_m3u8":"https://vip.opstream13.com/20251011/11890_56f88dc9/index.m3u8"},{"name":"28","slug":"28","filename":"Cùng Nhau Vượt Qua Thanh Xuân 3 - Tập 28---2022","link_embed":"https://vip.opstream13.com/share/6ef1173b096aa200158bfbc8af3ae8e3","link_m3u8":"https://vip.opstream13.com/20251011/11891_6ef1173b/index.m3u8"},{"name":"29","slug":"29","filename":"Cùng Nhau Vượt Qua Thanh Xuân 3 - Tập 29---2022","link_embed":"https://vip.opstream13.com/share/2d16ad1968844a4300e9a490588ff9f8","link_m3u8":"https://vip.opstream13.com/20251011/11892_2d16ad19/index.m3u8"},{"name":"30","slug":"30","filename":"Cùng Nhau Vượt Qua Thanh Xuân 3 - Tập 30---2022","link_embed":"https://vip.opstream13.com/share/afd0be2fd16b0101d8926769343c7950","link_m3u8":"https://vip.opstream13.com/20251011/11894_afd0be2f/index.m3u8"}]}],"time":"30 phút/tập","description":"<p>Với những kỷ niệm vui nhộn và thú vị trong chuyến du lịch nghỉ hè, các bạn học sinh đã bắt đầu cuộc sống học sinh cuối cấp của mình. Giáo viên lớp Feng Cuicui đã trực tiếp cho họ một Mawei - bởi vì họ là chuyên ngành nhiếp ảnh, các học sinh cuối cấp bắt đầu thực tập và làm việc, có nghĩa là năm trung học cơ sở. Đây là năm cuối cùng họ ở lại trường, và nhiều người vẫn còn rất hoang mang về tương lai của họ cho đến bây giờ. Sau buổi họp lớp, tuy ai cũng không nói ra nhưng trong lòng đều có ý kiến ​​riêng. Đây là định mệnh để trở thành một đàn em khác thường. Sau đó, cuộc bầu cử lại ban cán sự lớp, việc tuyển chọn khuôn viên trường, bầu cử chủ tịch hội sinh viên, công việc của các phóng viên, và cuộc thi video dài một phút tiếp tục gây cười, và mỗi người đều gây bất ngờ, và kết quả thật bất ngờ. Feng Cuicui đặc biệt điều chỉnh lớp chiến đấu trong hai tuần để quay các tác phẩm thực tập. Mọi người đã có một cuộc gặp gỡ bất ngờ ở Bucun và có được một liên lạc khác nhau. Sau đó, mọi người tham gia cuộc họp cứu hộ mùa đông trong khuôn viên trường lần cuối và kết thúc cuộc sống trong khuôn viên trường trong tiếng cười. Những nỗ lực chăm chỉ của giáo viên đứng lớp đã không vô ích, và các sinh viên bắt đầu cố gắng kết hợp sở thích và chuyên ngành của họ và đi theo hướng riêng của họ.</p>","tmdb":{"type":"tv","id":"75642","season":3,"vote_average":8.1,"vote_count":8},"modified":"2025-10-12T14:33:41.000Z","cast":["Xu Xiaolu","Pang Hanchen","Ding Xiangnan","Alex Ying","Li Ruojia","Xiang Yu","Li Chuan","Xu Huiqiang","Li Bin"],"director":[],"cast_meta":[{"name":"Xu Xiaolu","name_vi":null,"name_original":"Xu Xiaolu","tmdb_id":2036535,"profile":"https://image.tmdb.org/t/p/w500/eWrSEIFxcBh6fc3ZQecE6xX1UbS.jpg","tmdb_url":"https://www.themoviedb.org/person/2036535"},{"name":"Pang Hanchen","name_vi":null,"name_original":"Pang Hanchen","tmdb_id":1944965,"profile":"https://image.tmdb.org/t/p/w500/6SkVfGiILoj7lpmcOmk1lz8UDxi.jpg","tmdb_url":"https://www.themoviedb.org/person/1944965"},{"name":"Ding Xiangnan","name_vi":null,"name_original":"Ding Xiangnan","tmdb_id":2036541,"profile":"https://image.tmdb.org/t/p/w500/yDuRTwznimbamLlje6wvd6wqZ03.jpg","tmdb_url":"https://www.themoviedb.org/person/2036541"},{"name":"Alex Ying","name_vi":null,"name_original":"Alex Ying","tmdb_id":2036540,"profile":"https://image.tmdb.org/t/p/w500/hXzDCDK9UmsIUSO7hmxijYtCL8g.jpg","tm