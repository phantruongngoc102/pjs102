e/9b82e5326a49df7fc5bb45cc1f8b1a2a","link_m3u8":"https://vip.opstream11.com/20220703/34049_c120b882/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/a7eb93ef92a8a65cf69d578336b6be20","link_m3u8":"https://vip.opstream11.com/20220703/34051_c2ea08a8/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/7bec253137855f3740a2809234da1c07","link_m3u8":"https://vip.opstream11.com/20220703/34052_4d51b71b/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/0cceadf3ddbbe14c074611b16739876c","link_m3u8":"https://vip.opstream11.com/20220703/34053_468a470a/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream11.com/share/dff0ec9d8da6f85895d60730fcad2e5a","link_m3u8":"https://vip.opstream11.com/20220703/34054_dc900bcc/index.m3u8"}]}],"description":"<p>Trung tâm quyền lực cao nhất của tổng quản nội vụ hậu cung đời Đường chính là Cục Thượng Cung, thống lãnh 4 phòng: Ti Trân Phòng, Ti Chế Phòng, Ti Thiện Phòng và Ti Thiết Phòng. Lưu Tam Hảo và Diêu Kim Linh từ nhỏ đã được đưa vào cung làm nô tì học việc, cả hai đều thông minh lanh lợi, đặc biệt là Tam Hảo, tính tình hiền hậu, được Ti Trân Nguyễn Thúy Vân và Ti Chế Chung Tuyết Hà hết mực yêu thương, ai cũng muốn thu nhận cô, cuối cùng Tam Hảo trở thành nguyên nhân khiến hai người họ tranh giành kịch liệt. Tam Hảo luôn tuân thủ di huấn của mẹ “làm việc tốt, nói lời hay, có lòng thiện”, sống chân thành lương thiện giữa chốn thâm cung tranh giành đấu đá khốc liệt. Ngược với Tam Hảo, Kim Linh lại là người tự tư tự lợi, vì muốn trở thành phi tần sẵn sàng bất chấp thủ đoạn. Tam Hảo vốn có tình cảm với tiến sĩ Cao Hiển Dương nhưng khi biết người hoàng đế Lý Di yêu thương nhất chính là Tam Hảo, Kim Linh nảy lòng đố kỵ. Vì muốn bảo vệ ngôi vị hoàng phi, sẵn sàng vu oan Tam Hảo giết hại thái hậu, nhằm đẩy cô vào chỗ chết. Thế nhưng, mưu kế thâm sâu cỡ nào, cũng sẽ có lúc tính sai, thủ đoạn tàn bạo cỡ nào, cũng sẽ có chỗ sơ hở.</p>","tmdb_id":16209,"cast":["Dương Thiến Nghiêu","Trần Hào","Xa Thi Mạn","Trịnh Gia Dĩnh","Susanna Kwan","Mễ Tuyết","Lý Thi Hoa","Tiêu Chính Nam","Rosanne Lui Shan","Huệ Anh Hồng","Lý Quốc Lân","Susan Tse Suet-Sum","Hàn Mã Lợi","Ram Chiang Chi-Kwong","Yoyo Chen Chi-Yiu"],"director":["Mui Siu-Ching"],"keywords":[],"tmdb":{"type":"tv","id":"16209","season":1,"vote_average":7.3,"vote_count":13},"cast_meta":[{"name":"Dương Thiến Nghiêu","name_vi":"Dương Thiến Nghiêu","name_original":"Tavia Yeung","tmdb_id":1222259,"profile":"https://image.tmdb.org/t/p/w500/tuvy2JTxuYPzkS6YqYJ0RvOlPlE.jpg","tmdb_url":"https://www.themoviedb.org/person/1222259"},{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Xa Thi Mạn","name_vi":"Xa Thi Mạn","name_original":"Charmaine Sheh Sze-Man","tmdb_id":123643,"profile":"https://image.tmdb.org/t/p/w500/nacsBV6rdWH3rTy5cZpiwb9luFB.jpg","tmdb_url":"https://www.themoviedb.org/person/123643"},{"name":"Trịnh Gia Dĩnh","name_vi":"Trịnh Gia Dĩnh","name_original":"Kevin Cheng Ka-Wing","tmdb_id":1140044,"profile":"https://image.tmdb.org/t/p/w500/rzT8YmWjBRbrfXii9is8uZAbiBQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1140044"},{"name":"Susanna Kwan","name_vi":null,"name_original":"Susanna Kwan","tmdb_id":2063704,"profile":"https://image.tmdb.org/t/p/w500/9wWnSJbRtMDaSjnlq6nxBHAz33O.jpg","tmdb_url":"https://www.themoviedb.org/person/2063704"},{"name":"Mễ Tuyết","name_vi":"Mễ Tuyết","name_original":"Michelle Yim","tmdb_id":64384,"profile":"https://image.tmdb.org/t/p/w500/xrLTxPNUIH3tlPnLCi6BA0ewnG1.jpg","tmdb_url":"https://www.themoviedb.org/person/64384"},{"name":"Lý Thi Hoa","name_vi":"Lý Thi Hoa","name_original":"Selena Lee","tmdb_id":1178843,"profile":"https://image.tmdb.org/t/p/w500/fHwTvf1qkwspkfPYEWP4rj1QKjE.jpg","tmdb_url":"https://www.themoviedb.org/person/1178843"}