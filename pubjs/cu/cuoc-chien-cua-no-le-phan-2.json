us lãnh đạo trước khi họ có thể gây thêm thiệt hại. Spartacus được đưa ra lựa chọn giữa việc thỏa mãn nhu cầu cá nhân của mình để trả thù người đàn ông đã kết án vợ mình làm nô lệ và cuối cùng là cái chết hoặc hy sinh nhiều hơn cần thiết để giữ cho đội quân mới chớm nở của mình không bị tan rã.</p>","tmdb":{"type":"tv","id":"46296","season":2,"vote_average":8.03,"vote_count":2818},"modified":"2023-04-15T01:44:39.000Z","cast":["Liam McIntyre","Manu Bennett","Dustin Clare","Cynthia Addai-Robinson","Jaime Murray","Ellen Hollman","Luna Rioumina","Marisa Ramirez","Ditch Davey","Barry Duffield","Pana Hema-Taylor","Stephen Lovatt","Blessing Mokgohloa","Jenna Lind","Hanna Mangan Lawrence"],"director":[],"cast_meta":[{"name":"Liam McIntyre","name_vi":null,"name_original":"Liam McIntyre","tmdb_id":934219,"profile":"https://image.tmdb.org/t/p/w500/vTw11F1awNW8AlxInljEsK96cNB.jpg","tmdb_url":"https://www.themoviedb.org/person/934219"},{"name":"Manu Bennett","name_vi":null,"name_original":"Manu Bennett","tmdb_id":41782,"profile":"https://image.tmdb.org/t/p/w500/vwcTCQoRqfOjGZA1TPCx9TWTNht.jpg","tmdb_url":"https://www.themoviedb.org/person/41782"},{"name":"Dustin Clare","name_vi":null,"name_original":"Dustin Clare","tmdb_id":220916,"profile":"https://image.tmdb.org/t/p/w500/3F2pmjmi7CnUELSq613ifLekYx1.jpg","tmdb_url":"https://www.themoviedb.org/person/220916"},{"name":"Cynthia Addai-Robinson","name_vi":null,"name_original":"Cynthia Addai-Robinson","tmdb_id":182272,"profile":"https://image.tmdb.org/t/p/w500/fgXXRWLRDprVH9Bf2et0zRLk7HQ.jpg","tmdb_url":"https://www.themoviedb.org/person/182272"},{"name":"Jaime Murray","name_vi":null,"name_original":"Jaime Murray","tmdb_id":1223059,"profile":"https://image.tmdb.org/t/p/w500/viqfbECKPLI8nRO6sya8YFu8yc2.jpg","tmdb_url":"https://www.themoviedb.org/person/1223059"},{"name":"Ellen Hollman","name_vi":null,"name_original":"Ellen Hollman","tmdb_id":83218,"profile":"https://image.tmdb.org/t/p/w500/ebNqpUF7WFr4lhP6FhT9O1doc8q.jpg","tmdb_url":"