{"id":"6767ebfd8051c191a1e63b6e","title":"Cuộc Đời Thứ 2","origin_name":"Second Life","slug":"cuoc-doi-thu-2-2024","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/cu/cuoc-doi-thu-2-2024.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/cu/cuoc-doi-thu-2-2024.webp","year":"2024","type":"single","genre":[{"name":"Hành Động","slug":"hanh-dong"},{"name":"Hài Hước","slug":"hai-huoc"}],"country":[{"name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","modified":"2025-03-04T09:36:04.000Z","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"name":"Vietsub #1","slug":"vietsub-1","server_name":"Vietsub #1","server_data":[{"name":"Full","slug":"full","link_embed":"https://vip.opstream15.com/share/7125a10499ff1d99aa7cfbbc91cf2278","link_m3u8":"https://vip.opstream15.com/20241222/45898_7125a104/index.m3u8"},{"name":"Full","slug":"full","link_embed":"https://vip.opstream16.com/share/fdd62f8bdc8bd18509c0d3b5159ffc8d","link_m3u8":"https://vip.opstream16.com/20250303/41151_fdd62f8b/index.m3u8"}]}],"description":"Trong nhà tù nữ, “Chiến thần” Lão Lương (do Nguyên Thu thủ vai) – người khiến ai cũng khiếp sợ, và A Quỷ (do Ngô Vĩnh Long thủ vai) – sát thủ mù lòa của băng Thanh Long từng một thời nổi tiếng, vô tình gặp lại nhau. Từ đó, giữa hai mẹ con tại một tiệm thuốc Đông y đã xảy ra một loạt những cuộc đấu trí, đấu sức đầy kịch tính. Một người là bậc thầy võ học Đông y, đã thất lạc con trai nhiều năm, luôn mong muốn yêu thương con bằng cách tốt nhất; người kia là một đứa trẻ mồ côi bị băng đảng bỏ rơi, nay đã quay về gia đình nhưng lại luôn tìm cách ám sát mẹ mình. Cả hai gặp lại nhau trong hoàn cảnh sai lầm, thời điểm sai lầm, dẫn đến hàng loạt các màn đối đầu võ thuật đỉnh cao, gây ra những tình huống dở khóc dở cười nhưng cũng đầy nhiệt huyết, cuối cùng tạo nên một mối duyên kỳ diệu về sự cứu rỗi lẫn nhau và cùng hoàn thiện lẫn nhau.","tmdb_id":1329643,"cast":["Nguyên Thu","Ngũ Doãn Long","Lei Mu","Chen Zhihui","Zhou Xiaofei","Mamat Tursun Mamateli","Xu Zhanwei","Ji Jiahe","Yang Zhiqing","Liu Yaxi"],"director":["Chris Huo"],"keywords":["prison","martial arts","mistaken identity","revenge","blind man","estranged mother","action"],"tmdb":{"type":"movie","id":"1329643","season":null,"vote_average":7.7,"vote_count":3},"cast_meta":[{"name":"Nguyên Thu","name_vi":"Nguyên Thu","name_original":"Yuen Qiu","tmdb_id":119426,"profile":"https://image.tmdb.org/t/p/w500/5S70RuTmpHXCcyZNzx1sTjamOKw.jpg","tmdb_url":"https://www.themoviedb.org/person/119426"},{"name":"Ngũ Doãn Long","name_vi":"Ngũ Doãn Long","name_original":"Philip Ng Wan-Lung","tmdb_id":100585,"profile":"https://image.tmdb.org/t/p/w500/dUvw7dvUyfAiXhyzGWNV0Gd5ycN.jpg","tmdb_url":"https://www.themoviedb.org/person/100585"},{"name":"Lei Mu","name_vi":null,"name_original":"Lei Mu","tmdb_id":2491103,"profile":"https://image.tmdb.org/t/p/w500/sgeJ5pI8EWGE4Ny5q1O07bsYbCx.jpg","tmdb_url":"https://www.themoviedb.org/person/2491103"},{"name":"Chen Zhihui","name_vi":null,"name_original":"Chen Zhihui","tmdb_id":224927,"profile":"https://image.tmdb.org/t/p/w500/13dhV4a6z90A0HH7MGgsNr7YFsy.jpg","tmdb_url":"https://www.themoviedb.org/person/224927"},{"name":"Zhou Xiaofei","name_vi":null,"name_original":"Zhou Xiaofei","tmdb_id":1801161,"profile":"https://image.tmdb.org/t/p/w500/eA5ysPj0Bi8JSE0TOXPug6rxwdz.jpg","tmdb_url":"https://www.themoviedb.org/person/1801161"},{"name":"Mamat Tursun Mamateli","name_vi":null,"name_original":"Mamat Tursun Mamateli","tmdb_id":3416050,"profile":"https://image.tmdb.org/t/p/w500/48NR9EPvqXEpm5tNwEljrzR3leh.jpg","tmdb_url":"https://www.themoviedb.org/person/3416050"},{"name":"Xu Zhanwei","name_vi":null,"name_original":"Xu Zhanwei","tmdb_id":2785425,"profile":"https://image.tmdb.org/t/p/w500/hGxdoSir6nKbafgEH2zzn8vtaJ1.jpg","tmdb_url":"https://www.themoviedb.org/person/2785425"},{"nam