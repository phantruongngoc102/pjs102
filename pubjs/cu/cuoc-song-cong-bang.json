/43537_10fa9723/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream16.com/share/24d8bb61f5e86f7cbee14fc015f3ef91","link_m3u8":"https://vip.opstream16.com/20250726/43538_24d8bb61/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream16.com/share/bf86ac1ef70c8d7151cf993de222d66f","link_m3u8":"https://vip.opstream16.com/20250726/43539_bf86ac1e/index.m3u8"}]}],"description":"<p>Sau cái chết của vị hôn thê (Pauline Yeung), huyền thoại xã hội đen Minh Điền (Alex Man) rũ bỏ mọi hoạt động ngầm, sống một cuộc sống bình lặng, điều hành một tiệm mạt chược nhỏ. Ban đầu, anh cũng không màng đến chuyện tình cảm, nhưng rồi hai người phụ nữ rất khác biệt (Tanny Tien và Teresa Mo) lại xuất hiện trong cuộc đời anh. Minh Điền sống với mẹ (Lee Heung Kam), chú (Ng Man Tat) và anh họ Gam Sui (Stephen Chow). Minh Điền và Gam Sui thân thiết như anh em ruột, nhưng cha của Gam Sui lại có mối thù với Minh Điền, dẫn đến nhiều cuộc cãi vã và bất hòa trong gia đình kỳ lạ này. Khi Gam Sui và cha anh vô tình lạc vào con đường sai trái, Ming Tin phải dùng những mối quan hệ cũ để kéo họ trở lại.</p>","tmdb_id":52110,"cast":["Alex Man Chi-Leung","Điềm Nữu","Châu Tinh Trì","Mao Thuần Quân","Ngô Mạnh Đạt","Lee Heung-Kam","La Lan","Quan Hải Sơn","Huỳnh Thu Sinh","Đới Chí Vỹ","Hứa Thiệu Hùng","Yvonne Lam Yee-Man","Leung Oi","Pauline Yeung Bo-Ling","Cutie Mui Siu-Wai"],"director":["李力持","王冠輝"],"keywords":[],"tmdb":{"type":"tv","id":"52110","season":1,"vote_average":8,"vote_count":4},"cast_meta":[{"name":"Alex Man Chi-Leung","name_vi":null,"name_original":"Alex Man Chi-Leung","tmdb_id":148886,"profile":"https://image.tmdb.org/t/p/w500/jY5DKV1oioxxhD2xZdjBJPqVa8.jpg","tmdb_url":"https://www.themoviedb.org/person/148886"},{"name":"Điềm Nữu","name_vi":"Điềm Nữu","name_original":"Tien Niu","tmdb_id":115610,"profile":"https://image.tmdb.org/t/p/w500/6MxBj1REjW2pwKnglAcli1w08F.jpg","tmdb_url":"https://www.themoviedb.org/person/115610"},{"name":"Châu Tinh Trì","name_vi":"Châ