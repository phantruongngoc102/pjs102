com/20250509/5353_aa0d2a80/index.m3u8"},{"name":"12","slug":"12","filename":"Into The Heat - Tập 12---2025","link_embed":"https://vip.opstream90.com/share/609c5e5089a9aa967232aba2a4d03114","link_m3u8":"https://vip.opstream90.com/20250510/5428_609c5e50/index.m3u8"},{"name":"13","slug":"13","filename":"Into The Heat - Tập 13---2025","link_embed":"https://vip.opstream90.com/share/eab0141b79354969d1edd234fbc07422","link_m3u8":"https://vip.opstream90.com/20250510/5429_eab0141b/index.m3u8"},{"name":"14","slug":"14","filename":"Into The Heat - Tập 14---2025","link_embed":"https://vip.opstream90.com/share/4275f89744278864da88c2fda68ec4e9","link_m3u8":"https://vip.opstream90.com/20250511/5465_4275f897/index.m3u8"},{"name":"15","slug":"15","filename":"Into The Heat - Tập 15---2025","link_embed":"https://vip.opstream90.com/share/3b5e2c9be5002e87e0477099db5ff21b","link_m3u8":"https://vip.opstream90.com/20250511/5466_3b5e2c9b/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Để đấu tranh chống tội phạm và thực hiện ước mơ làm cảnh sát, chàng trai trẻ Lưu Tử Minh mang trong mình nhiệt huyết đã đến làm việc tại một đội cảnh sát hình sự thuộc Cục Công an thành phố. Tuy nhiên, công việc rà soát vụn vặt và nhàm chán khiến anh cảm thấy khô khan. Trong quá trình phá án thực tế tại hiện trường, Lưu Tử Minh ngày càng trở nên điềm tĩnh và dày dạn kinh nghiệm, dẫn dắt các học trò của mình tiếp tục phá giải các loại vụ án. Sau khi trải qua sự tôi luyện và mài giũa từ hàng loạt vụ án lớn, trọng án, Lưu Tử Minh đã có cái nhìn sâu sắc hơn về thiện và ác trong bản tính con người, trưởng thành thành một đội trưởng cảnh sát hình sự xuất sắc. Sự chỉ dạy tận tình không giấu giếm của sư phụ, lòng tin được vun đắp qua những lần vào sinh ra tử cùng đồng đội đã giúp anh thực sự nhận thức được trọng trách trên vai người cảnh sát hình sự. Anh cảm thấy vô cùng vinh dự khi được làm công việc cảnh sát hình sự, góp phần bảo vệ sự ổn định xã hội.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"282890","seaso