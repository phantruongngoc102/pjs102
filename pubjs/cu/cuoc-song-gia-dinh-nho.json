b53dca4ecfcb9c","link_m3u8":"https://vip.opstream17.com/20240323/3043_6747580a/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/097e26b2ffb0339458b55da17425a71f","link_m3u8":"https://vip.opstream17.com/20240324/3121_1f1cf7c4/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/a2d10d355cdebc879e4fc6ecc6f63dd7","link_m3u8":"https://vip.opstream17.com/20240324/3122_c2c040ce/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/df83971673de5c8e71ca1e2645718dad","link_m3u8":"https://vip.opstream17.com/20240326/3223_07b98025/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/0d352b4d3a317e3eae221199fdb49651","link_m3u8":"https://vip.opstream17.com/20240326/3224_79ba0bc2/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream17.com/share/6dfe08eda761bd321f8a9b239f6f4ec3","link_m3u8":"https://vip.opstream17.com/20240326/3225_3018fef2/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream17.com/share/907edb0aa6986220dbffb79a788596ee","link_m3u8":"https://vip.opstream17.com/20240326/3226_c7418c9e/index.m3u8"}]}],"description":"<p>Cố Mạt Lị và Chu Kình Thảo vật lộn phấn đấu từ quê hương lên Thượng Hải để cắm rễ và lập gia đình. Tuy nhiên, hôn nhân lại mang đến cho họ một vấn đề vốn không đáng có, đó là làm sao để chung sống hòa hợp với cha mẹ. Từ việc mất không gian riêng tư cho đến mua nhà, từ bố mẹ đôi bên cho đến hai vợ chồng cũng bất đồng quan điểm. Cuộc sống của gia đình nhỏ bắt đầu đầy rẫy nguy cơ, đến khi vượt ngoài tầm kiểm soát, cặp đôi mới nhận ra nguyên nhân đến từ chính họ. Sau khi trải qua giai đoạn nguội lạnh, cả hai quyết định ly hôn, xử lý lại vướng mắc trong gia đình. Với sự xuất hiện của giấy ly hôn, những thử thách cho đôi vợ chồng trẻ và gia đình họ mới bắt đầu. Trưởng thành luôn đi kèm với vô vàn va vấp. Sau khi ly hôn, cả hai gặp phải khủng hoảng lòng tin, khủng hoảng tài chính và khủng hoảng nơi đất khách, điều này cũng khiến họ hiểu rõ hơn về trách nhiệm gia đình.</p>","tmdb_id":232966,"cast":["Trần Hiểu","Đồng Dao","Tát Nhật Na","Dĩnh Nhi","Kiều Chấn Vũ","Yu Haoming","Du Haitao","Yue Hong","Wang Yuanke","Zhao Jun","Sun Zhong Yi","Han Xintong"],"director":["An Jian"],"keywords":[],"tmdb":{"type":"tv","id":"232966","season":1,"vote_average":7.3,"vote_count":3},"cast_meta":[{"name":"Trần Hiểu","name_vi":"Trần Hiểu","name_original":"Chen Xiao","tmdb_id":1192909,"profile":"https://image.tmdb.org/t/p/w500/6D4YFXfukHzD03IlHtUN67yTwHF.jpg","tmdb_url":"https://www.themoviedb.org/person/1192909"},{"name":"Đồng Dao","name_vi":"Đồng Dao","name_original":"Tong Yao","tmdb_id":1298729,"profile":"https://image.tmdb.org/t/p/w500/darU7n51ym1dziYRwOtD10qiljn.jpg","tmdb_url":"https://www.themoviedb.org/person/1298729"},{"name":"Tát Nhật Na","name_vi":"Tát Nhật Na","name_original":"Sa Rina","tmdb_id":1645147,"profile":"https://image.tmdb.org/t/p/w500/xYIcyuKGKtxwqzth47dG6RyjZCz.jpg","tmdb_url":"https://www.themoviedb.org/person/1645147"},{"name":"Dĩnh Nhi","name_vi":"Dĩnh Nhi","name_original":"Ying Er","tmdb_id":1339399,"profile":"https://image.tmdb.org/t/p/w500/6E3NhvhaS5NWqBJl9AEqEbBXDfZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1339399"},{"name":"Kiều Chấn Vũ","name_vi":"Kiều Chấn Vũ","name_original":"Qiao Zhenyu","tmdb_id":232808,"profile":"https://image.tmdb.org/t/p/w500/A7WEtJqduIVkPVvJ9zA0DnuTLJP.jpg","tmdb_url":"https://www.themoviedb.org/person/232808"},{"name":"Yu Haoming","name_vi":null,"name_original":"Yu Haoming","tmdb_id":1539663,"profile":"https://image.tmdb.org/t/p/w500/hDq6SM6bojCkR7PJF6vdJXurmF9.jpg","tmdb_url":"https://www.themoviedb.org/person/1539663"},{"name":"Du Haitao","name_vi":null,"name_original":"Du Haitao","tmdb_id":1089499,"profile":"https://image.tmdb.org/t/p/w500/kPIvdQ2klfW13pppR2mQF2Zei2E.jpg","tmdb_url":"https://www.themoviedb.org/person/1089499"},{"name":"Yue Hong","name_vi":null,"name_original":"Yue Hong","tmdb_id":237460,