8":"https://vip.opstream11.com/20220408/11454_09d16c18/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream11.com/share/20ba66f905957b34253d9d7abde919f3","link_m3u8":"https://vip.opstream11.com/20220408/11455_8a0c842e/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream11.com/share/e19099504769f3f7eb7e2f8b933db898","link_m3u8":"https://vip.opstream11.com/20220408/11456_f38a6adb/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream11.com/share/57b4b4a28e16316cdd028bf6e23ae100","link_m3u8":"https://vip.opstream11.com/20220408/11457_b27cee8e/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream11.com/share/42a3ddf2e1df611a280d556f1c81996a","link_m3u8":"https://vip.opstream11.com/20220408/11458_056e9e82/index.m3u8"},{"name":"39","slug":"39","link_embed":"https://vip.opstream11.com/share/da56910e9cfdd3202aca15bcd589f301","link_m3u8":"https://vip.opstream11.com/20220408/11459_b6f12b99/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream11.com/share/ab4ac2d850c6a8542ce122e0d82ceace","link_m3u8":"https://vip.opstream11.com/20220408/11460_08aa54f3/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream11.com/share/f806c5d2707545d718717be03e69a8d4","link_m3u8":"https://vip.opstream11.com/20220408/11461_f0c8927c/index.m3u8"}]}],"description":"<p>Cuộc Sống Hôn Nhân - Why Get Married xoay quanh câu chuyện của 3 cô bạn thân: Phàm Phàm (Diêu Địch đóng), Đại Hà (Nhậm Trọng đóng), Lão Điếu (Trịnh Nhã Văn đóng). Bảy năm trước, Phàm Phàm có mối tình đầu đẹp thuần khiết với Vương Đường Dịch (Ngô Trác Hy đóng) nhưng không thành. Quên đi mối tình đầu sâu đậm, Phàm Phàm có tình yêu 3 năm với người đàn ông hoàn mỹ và được gia đình chấp thuận. Mọi chuyện tưởng chừng như rất thuận lợi, nhưng tất cả đã đi trật đường ray. Sau một đêm tiệc tùng, trong cơn say, Phàm Phàm cùng 2 người bạn thân đã đăng kí kết hôn với 3 người đàn ông xa lạ họ mới gặp trong vũ trường. Trớ trêu nhất có lẽ chính là Phàm Phàm, khi người đàn ông cô kết hôn cùng lại không hề xa lạ mà chính là người yêu cũ.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuoc-song-hon-nhan.json","tmdb_checked":false}