h một đôi. Từ một người cao ngạo, độc đoán, Thành Minh giờ đây trở nên hiền lành, hiểu chuyện hơn. Dần dần, họ phát hiện ra điểm tốt của đối phương và nảy sinh tình cảm lúc nào không hay.</p>","tmdb":{"type":"tv","id":"126471","season":1,"vote_average":7.8,"vote_count":5},"modified":"2022-06-04T13:41:22.000Z","cast":["Ji Xiaobing","Jin Meichen","Xia Ningjun","Peng Biyao","He Xingyu","Yang Yi","Amy Yang","Xu Weihao","Peng Shiteng"],"director":["Lý Nhạn Thiến"],"cast_meta":[{"name":"Ji Xiaobing","name_vi":null,"name_original":"Ji Xiaobing","tmdb_id":1982719,"profile":"https://image.tmdb.org/t/p/w500/kD9JVFcbXz9K1E6Wt6Wfdq5EQiW.jpg","tmdb_url":"https://www.themoviedb.org/person/1982719"},{"name":"Jin Meichen","name_vi":null,"name_original":"Jin Meichen","tmdb_id":2503072,"profile":"https://image.tmdb.org/t/p/w500/em77vkLMXnaL9XSPKFqtHsc1bJ3.jpg","tmdb_url":"https://www.themoviedb.org/person/2503072"},{"name":"Xia Ningjun","name_vi":null,"name_original":"Xia Ningjun","tmdb_id":2392823,"profile":"https://image.tmdb.org/t/p/w500/cjKnfU4yKGqejQiER651lmvi5Ki.jpg","tmdb_url":"https://www.themoviedb.org/person/2392823"},{"name":"Peng Biyao","name_vi":null,"name_original":"Peng Biyao","tmdb_id":2725363,"profile":"https://image.tmdb.org/t/p/w500/tvniNAD4EFca6jzBYAucNtA9FJn.jpg","tmdb_url":"https://www.themoviedb.org/person/2725363"},{"name":"He Xingyu","name_vi":null,"name_original":"He Xingyu","tmdb_id":3379021,"profile":"https://image.tmdb.org/t/p/w500/qoRn0asY1Bmp7BaUodFQN2BoD1c.jpg","tmdb_url":"https://www.themoviedb.org/person/3379021"},{"name":"Yang Yi","name_vi":null,"name_original":"Yang Yi","tmdb_id":3596931,"profile":"https://image.tmdb.org/t/p/w500/pgcyScWCDXlMFyqnqtb9BAnuaWL.jpg","tmdb_url":"https://www.themoviedb.org/person/3596931"},{"name":"Amy Yang","name_vi":null,"name_original":"Amy Yang","tmdb_id":3300303,"profile":"https://image.tmdb.org/t/p/w500/kE7KaSLLez2q7ou5lQAHJt7aDUC.jpg","tmdb_url":"https://www.themoviedb.org/person/3300303"},{"name":"Xu Weihao","nam