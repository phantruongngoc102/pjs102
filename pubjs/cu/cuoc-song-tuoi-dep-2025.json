. Câu chuyện là hành trình họ cùng đạt được thành công trong sự nghiệp, đồng thời tìm lại bản ngã và ý nghĩa thật sự của cuộc sống.</p><p>&nbsp;</p>","tmdb_id":261586,"cast":["Tôn Lệ","Đổng Tử Kiện","Hồ Hạnh Nhi","Gao Xin","Trần Dao","Tong Lei","Diệp Thanh","Xu Weiluo"],"director":["汪俊"],"keywords":[],"tmdb":{"type":"tv","id":"261586","season":1,"vote_average":7.7,"vote_count":7},"cast_meta":[{"name":"Tôn Lệ","name_vi":"Tôn Lệ","name_original":"Sun Li","tmdb_id":52898,"profile":"https://image.tmdb.org/t/p/w500/12JSX18m5yzoNpLCTLQ104CUslf.jpg","tmdb_url":"https://www.themoviedb.org/person/52898"},{"name":"Đổng Tử Kiện","name_vi":"Đổng Tử Kiện","name_original":"Dong Zijian","tmdb_id":1353695,"profile":"https://image.tmdb.org/t/p/w500/cSaRGUAjFWsfYakGTfCuRghIkhW.jpg","tmdb_url":"https://www.themoviedb.org/person/1353695"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/938251"},{"name":"Gao Xin","name_vi":null,"name_original":"Gao Xin","tmdb_id":1177285,"profile":"https://image.tmdb.org/t/p/w500/mhVZKsGESu7XHRzRNDGIKDzqLqk.jpg","tmdb_url":"https://www.themoviedb.org/person/1177285"},{"name":"Trần Dao","name_vi":"Trần Dao","name_original":"Chen Yao","tmdb_id":1865921,"profile":"https://image.tmdb.org/t/p/w500/9sqEtFKYtPZ5InwqmfX6qVOYNKV.jpg","tmdb_url":"https://www.themoviedb.org/person/1865921"},{"name":"Tong Lei","name_vi":null,"name_original":"Tong Lei","tmdb_id":1887796,"profile":"https://image.tmdb.org/t/p/w500/mE1cujh8yv3GhcBZ0Lc6Fdx3S0H.jpg","tmdb_url":"https://www.themoviedb.org/person/1887796"},{"name":"Diệp Thanh","name_vi":"Diệp Thanh","name_original":"Ye Qing","tmdb_id":1210413,"profile":"https://image.tmdb.org/t/p/w500/6EJNgDmKUXpdhBqKzvaWShFMxlS.jpg","tmdb_url":"https://www.themoviedb.org/person/1210413"},{"name":"Xu Weiluo","name_vi":null,"name_original":"Xu Weiluo","tmdb_id":3868664,