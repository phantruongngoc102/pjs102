am vọng nhất” khi kết hợp yếu tố trinh thám, những yếu tố kỳ ảo đặc trưng của văn hóa Navajo cùng với bầu không khí giật gân pha lẫn lịch sử giả tưởng.</p>","tmdb":{"type":"tv","id":"128904","season":4,"vote_average":7.509,"vote_count":168},"modified":"2026-04-05T14:11:29.000Z","cast":["Zahn McClarnon","Kiowa Gordon","Jessica Matten","Deanna Allison","Isabel DeRoy-Olson","Franka Potente"],"director":[],"cast_meta":[{"name":"Zahn McClarnon","name_vi":null,"name_original":"Zahn McClarnon","tmdb_id":42376,"profile":"https://image.tmdb.org/t/p/w500/54M2t1gziirkDdvj4SxAl6dXaVO.jpg","tmdb_url":"https://www.themoviedb.org/person/42376"},{"name":"Kiowa Gordon","name_vi":null,"name_original":"Kiowa Gordon","tmdb_id":84218,"profile":"https://image.tmdb.org/t/p/w500/yK3u2Rfb02VCb8mL7d76FjhFbiB.jpg","tmdb_url":"https://www.themoviedb.org/person/84218"},{"name":"Jessica Matten","name_vi":null,"name_original":"Jessica Matten","tmdb_id":1703912,"profile":"https://image.tmdb.org/t/p/w500/EQsPxsav8AZmaeT3mpU3Evilee.jpg","tmdb_url":"https://www.themoviedb.org/person/1703912"},{"name":"Deanna Allison","name_vi":null,"name_original":"Deanna Allison","tmdb_id":1380129,"profile":"https://image.tmdb.org/t/p/w500/6Qz0PNDWysTEeYeBVSWMqjyPs6W.jpg","tmdb_url":"https://www.themoviedb.org/person/1380129"},{"name":"Isabel DeRoy-Olson","name_vi":null,"name_original":"Isabel DeRoy-Olson","tmdb_id":3820201,"profile":"https://image.tmdb.org/t/p/w500/5Q00DYyruBqaJQuHqnu6qxVnpXT.jpg","tmdb_url":"https://www.themoviedb.org/person/3820201"},{"name":"Franka Potente","name_vi":null,"name_original":"Franka Potente","tmdb_id":679,"profile":"https://image.tmdb.org/t/p/w500/aU6f9UemZsTkqKEG4l77zf6masg.jpg","tmdb_url":"https://www.themoviedb.org/person/679"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuong-phong-bong-toi-phan-4.json"}