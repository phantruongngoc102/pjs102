222/32765_562f08b7/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream14.com/share/7cf91b300ff3ecef82c59dd47b89253a","link_m3u8":"https://vip.opstream14.com/20230222/32767_605db4db/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/f43764367fa4b73ba947fae71b0223a4","link_m3u8":"https://vip.opstream14.com/20230222/32768_7fb170e0/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream14.com/share/6499e19d47d7cbd3302a26fdb40d0b41","link_m3u8":"https://vip.opstream14.com/20230222/32769_6683910d/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream14.com/share/c2d2db7da651df36ea69da7bee48304b","link_m3u8":"https://vip.opstream14.com/20230222/32771_ca84170f/index.m3u8"}]}],"description":"<p>Cương Thi – Ân Oán Truyền Kiếp là thước phim truyền hình ăn khách bậc nhất điện ảnh Hong Kong nửa đầu năm 2016 do Trịnh Gia Dĩnh, Tạ An Kỳ đóng chính. Bộ phim được đánh giá khá cao và nhận được không ít lời khen từ khán giả. Với nội dung hấp dẫn xoay quanh chuyện tình giữa người và cương thi, tuy chủ đề không mấy mới mẻ nhưng nội dung lại hết sức sáng tạo, cuốn hút người xem, thêm vào đó là kỹ sảo được đánh giá cao cùng một cái kết được cho là làm thỏa mãn nhiều khán giả. Cương Thi Ân Oán Truyền Kiếp với tựa đề tiếng anh là Blue Veins, phim kể về cuộc chiến truyền kì giữa 2 chủng tộc là con người và cương thi.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuong-thi-an-oan-truyen-kiep.json"}