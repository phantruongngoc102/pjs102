{"id":"62da25b15e3e7bf958df8364","title":"Cướp Rồng Hóa Mèo","origin_name":"Civet cat for crown prince","slug":"cuop-rong-hoa-meo","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/cu/cuop-rong-hoa-meo.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/cu/cuop-rong-hoa-meo.webp","year":2022,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a220de0fc277084dfd16d","name":"Tình Cảm","slug":"tinh-cam"},{"id":"620a2238e0fc277084dfd291","name":"Tâm Lý","slug":"tam-ly"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"cuop-rong-hoa-meo-2022","link_embed":"https://vip.opstream14.com/share/d7c3f8dee9f1ce4c631160e82f1ec938","link_m3u8":"https://vip.opstream14.com/20220722/18694_95e3c32e/index.m3u8"}]}],"time":"1H25M22S","description":"<p>Bộ phim là một loạt tình tiết gay cấn bắt nguồn từ việc tình cờ trao đổi thân phận của hai người đàn ông ban đầu không liên quan gì đến nhau. Từ Nghị vốn là một gã lang thang thất nghiệp ở khu phố Trung Quốc của Thái Lan. Anh ta cho rằng thất bại trong cuộc sống là số không may mắn và luôn đổ lỗi cho người khác. Một cách tình cờ, anh đã vô tình hoán đổi danh tính với Long Sơn, từ đó dính vào cuộc chiến giữa Long Sơn và băng nhóm tội phạm Skeleton Buddha. Từ Nghị cuối cùng đã lựa chọn đứng về phía công lý và cùng với Long Sơn đưa băng nhóm Skeleton Buddha ra trước công lý, anh ấy cũng nhận ra những khiếm khuyết của bản thân dưới ảnh hưởng của Long Sơn và quyết định đối mặt với cuộc sống với một thái độ tích cực thay vì phàn nàn.</p>","tmdb":{"type":"movie","id":"992466","season":null,"vote_average":0,"vote_count":0},"