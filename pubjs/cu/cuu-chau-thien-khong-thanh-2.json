20220530/17314_3baef4dd/index.m3u8"},{"name":"34","slug":"34","filename":"cuu-chau-thien-khong-thanh-2-thuyet-minh-novoland-the-castle-in-the-sky-2-tap-34","link_embed":"https://vip.opstream15.com/share/6b219d75118d8793048bde740a3c9e60","link_m3u8":"https://vip.opstream15.com/20220530/17316_9dd75a4b/index.m3u8"}]}],"time":"","description":"<p>Cửu Châu Thiên Không Thành 2 cũng kể về câu chuyện tình yêu của Phong Như Triệt do Vương Ngọc Văn đảm nhận là con gái duy nhất của Thiên Dật, Phục Linh và Tuyết Cảnh Không do Từ Chính Khê thủ vai là con trai của Lan Châu. Tuyết Cảnh Không là một người đàn ông giỏi tiết chế tình cảm, luôn luôn nhẹ nhàng, lạnh lùng, khó gần. Còn Phong Như Triệt là một cô gái lớn lên ở một nơi hoang vu và có một cuộc sống gai góc, bụi bặm, tinh nghịch nhưng đến khi Như Triệt gặp Cảnh Không, cô đã trở thành một cô gái nhút nhát, nữ tính hơn.Cảnh Không và Như Triệt đã cùng nhau trải qua bao sóng gió, gian nan, liệu cặp đôi này sẽ đi về đâu? Mọi người hãy cùng theo dõi những diễn biến của bộ phim Cửu Châu Thiên Không Thành 2 nhé.</p>","tmdb":{"type":"tv","id":"124702","season":1,"vote_average":6,"vote_count":2},"modified":"2022-06-05T16:09:57.000Z","cast":["Từ Chính Khê","Vương Ngọc Văn","Lý Mộc Thần","Đại Văn Văn","Vương Tử Kỳ","Chai Ge","Hứa Hiểu Nặc","Liang Yolin","Wang Jialin","Yu Xinyan","Li Daikun","Zhao Jian","Wang Ziming"],"director":["Jinqing Zhang","Min Guohui","Zhao Jin-Tao"],"cast_meta":[{"name":"Từ Chính Khê","name_vi":"Từ Chính Khê","name_original":"Xu Zhengxi","tmdb_id":1147121,"profile":"https://image.tmdb.org/t/p/w500/a0HMEoOEtuzTKnxZRZJFPPMhWK0.jpg","tmdb_url":"https://www.themoviedb.org/person/1147121"},{"name":"Vương Ngọc Văn","name_vi":"Vương Ngọc Văn","name_original":"Wang Yuwen","tmdb_id":1836775,"profile":"https://image.tmdb.org/t/p/w500/lVmpKpml6evG5gWciRELbgdhvII.jpg","tmdb_url":"https://www.themoviedb.org/person/1836775"},{"name":"Lý Mộc Thần","name_vi":"Lý Mộc Thần","name_original":"Daisy Li","tmdb_id":1747503,"profile":"h