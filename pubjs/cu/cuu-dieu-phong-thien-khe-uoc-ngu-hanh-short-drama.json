dex.m3u8"}]}],"time":"2 phút/tập","description":"Tân Di được sư phụ sai xuống núi đến Giang Châu tìm kiếm người nắm giữ Khế Ước Ngũ Hành để tái tạo phong ấn ngăn chặn Huyền Ly thức tỉnh. Anh ta bị cuốn vào cuộc đấu tranh khốc liệt giữa ba thế lực lớn còn lại ở Giang Châu. Các phe phái đều muốn kiểm soát Tân Di để tranh đoạt khí vận từ Huyền Ly. Tân Di luân chuyển giữa các tộc, cố gắng tạo liên minh chống lại Thành Chủ Phủ mạnh nhất, đồng thời tìm kiếm khế ước và manh mối về Vân Mộc Đường mất tích.","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-08T10:17:35.000Z","cast":[],"director":[],"cast_meta":[],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuu-dieu-phong-thien-khe-uoc-ngu-hanh-short-drama.json"}