5f7b702c448f83eb60d77551e20f3","link_m3u8":"https://vip.opstream90.com/20260307/26640_5b85f7b7/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream90.com/share/13941bddb1399810f387f38dc7c775f0","link_m3u8":"https://vip.opstream90.com/20260314/27079_13941bdd/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream90.com/share/09a04b5f6189f34a3a8bb148c87cce78","link_m3u8":"https://vip.opstream90.com/20260321/27648_09a04b5f/index.m3u8"}]}],"description":"<p>Cửu Dương Võ Thần khắc họa lại hành trình trở thành một Thiên Đế đầy gian khổ và dài đằng đẵng của Diệp Vân Phi, anh chàng phải trải qua mọi cung bậc cảm xúc của sự đau khổ và phản bội trên cuộc đời này. Phải trải qua tới hai kiếp người mà Diệp Vân Phi mới đạt đến ngôi vị của Thiên Đế, đạp lên tất cả nhưng quả thật quá nhiều chông gai. Từng được biết đến mà một thiếu niên sở hữu những tài năng và thiên phú thiên bẩm nhưng những biến cố cứ thay nhau bủa vây lấy anh chàng khốn khổ ấy, gia tộc bị chèn ép, cha của anh thì bị giết, vợ thì phản bội mà quay đi, ngay cả võ mạch cũng không còn dùng để tu luyện được nữa. Vô tình lúc đó Diệp Vân đã gặp được thánh nhân tên là Tử Thánh Chân Quân, được ngài nhận là đệ tử và đưa anh trở lại con đường tu luyện, một bước trở thành vị Thiên Đế có một không hai trẻ nhất trong lịch sử.</p>","tmdb_id":305899,"cast":["Ma Zhengyang","Zhang Youwu","Ye Zhiqiu","祁欣","李琦","吴晛","戈昕宇","Jiang Yingjun","Shuang Zhao","Zhang Enze"],"director":["张德方"],"keywords":[],"tmdb":{"type":"tv","id":"305899","season":1,"vote_average":8,"vote_count":1},"cast_meta":[{"name":"Ma Zhengyang","name_vi":null,"name_original":"Ma Zhengyang","tmdb_id":2532862,"profile":"https://image.tmdb.org/t/p/w500/d7ySPv0g1cq8QrWbdfqG4YvTxM1.jpg","tmdb_url":"https://www.themoviedb.org/person/2532862"},{"name":"Zhang Youwu","name_vi":null,"name_original":"Zhang Youwu","tmdb_id":1853548,"profile":"https://image.tmdb.org/t/p/w500/2wnGZ6IXWkmdf4CdvwiygJOK9tm.jpg","tmdb_url":"https://www.themoviedb.or