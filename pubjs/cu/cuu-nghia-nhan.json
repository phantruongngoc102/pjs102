 công lý cho bạn mình. Trong quá trình đó, cuộc đấu tranh của một cô gái trẻ bị thời gian chôn vùi dần lộ diện.</p>","tmdb_id":234411,"cast":["Ngô Thiến","Lý Giai Hàng","Hồ Ý Hoàn","Kiều Chấn Vũ","Bạch Chú","Zhang Kangle","Thang Tinh Mị"],"director":["Zang Xichuan"],"keywords":[],"tmdb":{"type":"tv","id":"234411","season":1,"vote_average":7.4,"vote_count":5},"cast_meta":[{"name":"Ngô Thiến","name_vi":"Ngô Thiến","name_original":"Janice Wu","tmdb_id":1677008,"profile":"https://image.tmdb.org/t/p/w500/zNw2OQbHC343epJkSgR3FUHGWmA.jpg","tmdb_url":"https://www.themoviedb.org/person/1677008"},{"name":"Lý Giai Hàng","name_vi":"Lý Giai Hàng","name_original":"Li Jiahang","tmdb_id":1260866,"profile":"https://image.tmdb.org/t/p/w500/fiVqFXt65U2AQooaAgm65eArH34.jpg","tmdb_url":"https://www.themoviedb.org/person/1260866"},{"name":"Hồ Ý Hoàn","name_vi":"Hồ Ý Hoàn","name_original":"Hu Yixuan","tmdb_id":2164832,"profile":"https://image.tmdb.org/t/p/w500/vOa4szQkowRT34eNPvjwwJKqBAN.jpg","tmdb_url":"https://www.themoviedb.org/person/2164832"},{"name":"Kiều Chấn Vũ","name_vi":"Kiều Chấn Vũ","name_original":"Qiao Zhenyu","tmdb_id":232808,"profile":"https://image.tmdb.org/t/p/w500/A7WEtJqduIVkPVvJ9zA0DnuTLJP.jpg","tmdb_url":"https://www.themoviedb.org/person/232808"},{"name":"Bạch Chú","name_vi":"Bạch Chú","name_original":"Bai Shu","tmdb_id":1824165,"profile":"https://image.tmdb.org/t/p/w500/dj5Fl8QWEStjxnYb7Oshx6250rl.jpg","tmdb_url":"https://www.themoviedb.org/person/1824165"},{"name":"Zhang Kangle","name_vi":null,"name_original":"Zhang Kangle","tmdb_id":3503858,"profile":"https://image.tmdb.org/t/p/w500/uU9xZH9CEuHt4ZK6CS3VlSbI1Vz.jpg","tmdb_url":"https://www.themoviedb.org/person/3503858"},{"name":"Thang Tinh Mị","name_vi":"Thang Tinh Mị","name_original":"Tang Jingmei","tmdb_id":2795738,"profile":"https://image.tmdb.org/t/p/w500/xlJ2Q7ELGbkqNSwXh4sfC8loW9f.jpg","tmdb_url":"https://www.themoviedb.org/person/2795738"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/ph