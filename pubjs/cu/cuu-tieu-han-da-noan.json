ed":"https://vip.opstream16.com/share/cc4312e64f7f87d3f310d3fc1cd94fc6","link_m3u8":"https://vip.opstream16.com/20230312/32961_ac0a708a/index.m3u8"},{"name":"36","slug":"36","filename":"Cuu Tieu E36","link_embed":"https://vip.opstream16.com/share/2b308c2e1f6e80e6e1a82aa93a11fb1f","link_m3u8":"https://vip.opstream16.com/20230312/32962_bb6cb41e/index.m3u8"}]}],"time":"45 phút","description":"<p>Cửu Tiêu Hàn Dạ Noãn do Lí Tuệ Châu đạo diễn, ''Cung'' do Nhâm tổng đạo diễn, ''Phượng Tù Hoàng'' - Đặng Vĩ Ân, \" Cẩm Tú Nam Ca\" - Hoàng Bân, \"Anh hùng xạ điêu\" - Lý Nhất Đồng, là bộ phim cổ trang tình yêu đặc biệt. Bộ phim kể về câu chuyện của nữ bộ khoái sợ lạnh của Kiền quốc Tô Cửu Nhi(Lý Nhất Đồng thủ vai) cùng Thiếu chủ “ngoài lạnh trong nóng” Hàn Tranh của Kỳ tộc (Tất Văn Quân thủ vai) vụ án giết người liên quan đến hai gia tộc mà gặp nhau, tình cờ tạo thành \"Đối tác chênh lệch nhiệt độ\" , cùng nhau vượt qua màn sương mù âm mưu dày đặc, tìm chân tướng sau lưng vụ án đồng thời hoá giải mối nguy hiểm của quốc gia.</p>","tmdb":{"type":"tv","id":"137800","season":1,"vote_average":5.8,"vote_count":4},"modified":"2025-07-17T20:30:50.000Z","cast":["Lý Nhất Đồng","Tất Văn Quân","Trần Hạc Nhất","Wang Maolei","Ma Yue","Dương Thế Trạch","Deng Ying","Fu Shouer","Lưu Đặc"],"director":["Lý Huệ Châu"],"cast_meta":[{"name":"Lý Nhất Đồng","name_vi":"Lý Nhất Đồng","name_original":"Li Yitong","tmdb_id":1736257,"profile":"https://image.tmdb.org/t/p/w500/jfostFmHde0D1Wj9F57GWHEVzmO.jpg","tmdb_url":"https://www.themoviedb.org/person/1736257"},{"name":"Tất Văn Quân","name_vi":"Tất Văn Quân","name_original":"Bi Wenjun","tmdb_id":2492320,"profile":"https://image.tmdb.org/t/p/w500/l5660lRS4dzmsFZwX6KXKinSi53.jpg","tmdb_url":"https://www.themoviedb.org/person/2492320"},{"name":"Trần Hạc Nhất","name_vi":"Trần Hạc Nhất","name_original":"Chen Heyi","tmdb_id":2972064,"profile":"https://image.tmdb.org/t/p/w500/86nzG9p1WfL3OS2Q4L5cOHIkwwh.jpg","tmdb_url":"https://www.themoviedb.org/person/2972064"}