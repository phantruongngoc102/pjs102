,"link_m3u8":"https://vip.opstream90.com/20260124/22996_22a8b63c/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream90.com/share/ae4b60a20b0fe8582450c458ed35a28b","link_m3u8":"https://vip.opstream90.com/20260124/22997_ae4b60a2/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream90.com/share/769470af8480e9dbeba55f503be83247","link_m3u8":"https://vip.opstream90.com/20260124/22998_769470af/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream90.com/share/97adbcd253402895e56cdeceb5f4ca29","link_m3u8":"https://vip.opstream90.com/20260125/23054_97adbcd2/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream90.com/share/1101c92ba65fb18468e246180daafb5a","link_m3u8":"https://vip.opstream90.com/20260125/23055_1101c92b/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream90.com/share/9fbcbcb41e52efd7dbcb96e8a5c4cb63","link_m3u8":"https://vip.opstream90.com/20260125/23056_9fbcbcb4/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream90.com/share/5fb04d1ce991c11c0fb16a6777163629","link_m3u8":"https://vip.opstream90.com/20260125/23057_5fb04d1c/index.m3u8"}]}],"description":"<p>Hoắc Trung Nhân, chủ bộ của thành Mộc Hề, đột ngột mất tích một cách bí ẩn trong cung. Để tìm kiếm tung tích của phụ thân, con gái ông là Hoắc Hương Cửu cải trang thành cung nữ, lén xâm nhập hoàng cung. Tuy nhiên, cô tình cờ phát hiện ra thân phận thực sự của phong thần quyền lực triều đình Phong Mặc Trần chính là hồ li tinh nghìn năm tuổi. Hai người còn vô tình hoán đổi linh hồn cho nhau. Cùng lúc đó, trong cung lại có rất nhiều sự kiện quái dị, khó lý giải liên tiếp xảy ra, là do yêu ma quỷ quái quấy phá, hay có người phàm đứng sau khuấy động phong ba? Mỗi người mang theo mục đích riêng, Hoắc Hương Cửu và Phong Mặc Trần buộc phải đồng hành, lần lượt phá giải từng vụ án kỳ lạ không tưởng, tạo nên vô số tình huống dở khóc dở cười. Đồng thời, họ cũng dần hé lộ một mối tình bảy kiếp sâu nặng và lay động lòng người bị chôn vùi suốt ngàn năm.<br>&nbsp;</p>","tmdb_id":274641,"cast":["Tôn Thần Thuân","Zhang Yuenan","Wang Xingwei","Wang Jiali","Zhang Qing","Zhang Feifei","Qi Wei","Li Sicong"],"director":["曾黄武"],"keywords":[],"tmdb":{"type":"tv","id":"274641","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Tôn Thần Thuân","name_vi":"Tôn Thần Thuân","name_original":"Sun Chenjun","tmdb_id":2830737,"profile":"https://image.tmdb.org/t/p/w500/2QAr710FGLb65bFmHEjQcHK09VS.jpg","tmdb_url":"https://www.themoviedb.org/person/2830737"},{"name":"Zhang Yuenan","name_vi":null,"name_original":"Zhang Yuenan","tmdb_id":2698071,"profile":"https://image.tmdb.org/t/p/w500/6ZK8MFqiQGNzjPQR8LSAL4uh9ev.jpg","tmdb_url":"https://www.themoviedb.org/person/2698071"},{"name":"Wang Xingwei","name_vi":null,"name_original":"Wang Xingwei","tmdb_id":2612007,"profile":"https://image.tmdb.org/t/p/w500/ogIeggyCJOb84nSNSa1v6By8EM4.jpg","tmdb_url":"https://www.themoviedb.org/person/2612007"},{"name":"Wang Jiali","name_vi":null,"name_original":"Wang Jiali","tmdb_id":2689643,"profile":"https://image.tmdb.org/t/p/w500/xsa8JNrmuIabauktlJncAySni2q.jpg","tmdb_url":"https://www.themoviedb.org/person/2689643"},{"name":"Zhang Qing","name_vi":null,"name_original":"Zhang Qing","tmdb_id":5235651,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5235651"},{"name":"Zhang Feifei","name_vi":null,"name_original":"Zhang Feifei","tmdb_id":3387704,"profile":"https://image.tmdb.org/t/p/w500/qtLIZQmMhPlwKbgCWWKBz9SNvQW.jpg","tmdb_url":"https://www.themoviedb.org/person/3387704"},{"name":"Qi Wei","name_vi":null,"name_original":"Qi Wei","tmdb_id":5248281,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5248281"},{"name":"Li Sicong","name_vi":null,"name_original":"Li Sicong","tmdb_id":5399218,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5399218"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/cu/cuu-vy-khong-the-giau.json"}