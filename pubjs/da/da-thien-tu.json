m3u8"},{"name":"48","slug":"48","link_embed":"https://vip.opstream15.com/share/a64a1476544db9bd76a6d1f024a3a8c6","link_m3u8":"https://vip.opstream15.com/20220514/14360_aa96eaa5/index.m3u8"}]}],"description":"<p>Phim Dạ Thiên Tử cải biên từ tác phẩm cùng tên của Nguyệt Quan, là một câu chuyện truyền kỳ về Diệp Tiểu Thiên (do Từ Hải Kiều thủ vai), tên quản ngục nho nhỏ ở Lục Phiến môn. Vì một bức di thư mà rời khỏi kinh thành bước chân vào giang hồ, nhưng số phận lại đẩy hắn vào giữa chốn quan trường Đại Minh. Từ đó có vô số chuyện từ gà bay chó sủa cho đến lãng mạn ngọt ngào xảy đến với Diệp Tiểu Thiên, trong đó có cuộc hội ngộ với Hạ Oánh Oánh (do Tống Tổ Nhi thủ vai).</p>","tmdb_id":81558,"cast":["Từ Hải Kiều","Tống Tổ Nhi","Wu Hailong","Wang Zitong","Lưu Quán Lân","Hao Shuai","Yu Tong","Fang Qingping","Hong Jiantao","Lưu Bội Kỳ","Jiang Qinyun"],"director":["Chen Haowei"],"keywords":[],"cast_meta":[{"name":"Từ Hải Kiều","name_vi":"Từ Hải Kiều","name_original":"Joe Xu","tmdb_id":1737891,"profile":"https://image.tmdb.org/t/p/w500/qbFRDTf4ZMRefgMux788tXELzbM.jpg","tmdb_url":"https://www.themoviedb.org/person/1737891"},{"name":"Tống Tổ Nhi","name_vi":"Tống Tổ Nhi","name_original":"Song Zuer","tmdb_id":2104489,"profile":"https://image.tmdb.org/t/p/w500/aB1MfYz5LDZmfULDnqGjRgsg25Z.jpg","tmdb_url":"https://www.themoviedb.org/person/2104489"},{"name":"Wu Hailong","name_vi":null,"name_original":"Wu Hailong","tmdb_id":3873534,"profile":"https://image.tmdb.org/t/p/w500/l2OhJk7pkApMTb0DODH8VQWeaKV.jpg","tmdb_url":"https://www.themoviedb.org/person/3873534"},{"name":"Wang Zitong","name_vi":null,"name_original":"Wang Zitong","tmdb_id":2812510,"profile":"https://image.tmdb.org/t/p/w500/2SWH34rQdhvE5W2ecEOnDuSSqBo.jpg","tmdb_url":"https://www.themoviedb.org/person/2812510"},{"name":"Lưu Quán Lân","name_vi":"Lưu Quán Lân","name_original":"Liu Guanlin","tmdb_id":2178031,"profile":"https://image.tmdb.org/t/p/w500/9V1bgjKnp83ptaFNK17ba6MW4Cf.jpg","tmdb_url":"https://www.themoviedb.o