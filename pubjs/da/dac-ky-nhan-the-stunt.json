 đồng môn của Chí – Thường Mỹ Xu (do Chu Thần Lệ đóng), không cam tâm. Để hoàn thành di nguyện của cha, Xu vẫn miệt mài đến phim trường, làm diễn viên đóng thế. Mặt khác, cô cố gắng lôi kéo các đội viên cũ hành nghề trở lại, khôi phục Đỉnh Cao.","tmdb_id":83667,"cast":["Đàm Tuấn Ngạn","Rebecca Zhu Chenli","Kelvin Kwan","Phó Gia Lợi","Jack Wu","Jess Shum","Claire Yiu","Vu Dương","Strawberry Yeung Yuk-Mui","Chu Mẫn Hãn","Tammy Ou Yeung","Aurora Li","Chloe Nguyen","Auston Lam","Ken Law Ho-Ming"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"83667","season":1,"vote_average":6,"vote_count":1},"cast_meta":[{"name":"Đàm Tuấn Ngạn","name_vi":"Đàm Tuấn Ngạn","name_original":"Shaun Tam Chun-Yin","tmdb_id":1173383,"profile":"https://image.tmdb.org/t/p/w500/iFIuZ0AJznHAQ6C3fFJUlaCTIgQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1173383"},{"name":"Rebecca Zhu Chenli","name_vi":null,"name_original":"Rebecca Zhu Chenli","tmdb_id":985095,"profile":"https://image.tmdb.org/t/p/w500/t9NoLwsjROquMNFGAKr5i3aYzvw.jpg","tmdb_url":"https://www.themoviedb.org/person/985095"},{"name":"Kelvin Kwan","name_vi":null,"name_original":"Kelvin Kwan","tmdb_id":1202563,"profile":"https://image.tmdb.org/t/p/w500/pa44Xldmju81VBia4qQBuv8gbgc.jpg","tmdb_url":"https://www.themoviedb.org/person/1202563"},{"name":"Phó Gia Lợi","name_vi":"Phó Gia Lợi","name_original":"Kelly Fu","tmdb_id":583066,"profile":"https://image.tmdb.org/t/p/w500/7SQ9FDNGDUW98o7lIQ2zp4ADn4Z.jpg","tmdb_url":"https://www.themoviedb.org/person/583066"},{"name":"Jack Wu","name_vi":null,"name_original":"Jack Wu","tmdb_id":1222315,"profile":"https://image.tmdb.org/t/p/w500/8q1QdqHHQxzVFGuProbEgkP1qnh.jpg","tmdb_url":"https://www.themoviedb.org/person/1222315"},{"name":"Jess Shum","name_vi":null,"name_original":"Jess Shum","tmdb_id":3502196,"profile":"https://image.tmdb.org/t/p/w500/g7Ka5FW03y8iV8Y8G469WZPMfhP.jpg","tmdb_url":"https://www.themoviedb.org/person/3502196"},{"name":"Claire Yiu","name_vi":null,"name_original":"Clair