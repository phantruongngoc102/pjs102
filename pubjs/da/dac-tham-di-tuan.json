85e5672dc2ea","link_m3u8":"https://vip.opstream13.com/20260224/22625_ce4c4d59/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/3ada268dec01dab0f6434c3ef50ec89f","link_m3u8":"https://vip.opstream13.com/20260224/22626_3ada268d/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/848ceaa4630331e8384950e09d392365","link_m3u8":"https://vip.opstream13.com/20260224/22627_848ceaa4/index.m3u8"}]}],"description":"<p>Tang Titkin, một cư dân của làng Wai Tau, đã làm cảnh sát ở đây hơn mười năm, giành được tình yêu và sự kính trọng của dân làng. Một cấp trên mới, Mak Chi-Fan, được bổ nhiệm đến đồn cảnh sát. Chi-Fan có thành kiến ​​với dân làng Wai Tau và mâu thuẫn với Titkin vì cách làm việc không theo khuôn phép của anh. Mặt khác, Titkin lại thấy Chi-Fan độc đoán và chống lại quyền lực của bà ta, dẫn đến xung đột sâu sắc giữa hai người. Doanh nhân giàu có Lei Gwan đã vươn lên nắm quyền bằng những thủ đoạn bất chính, thu hút sự chú ý của tội phạm có tổ chức. Tình bạn thân thiết giữa Titkin và Lei Gwan gây ra những hiểu lầm với Chi-Fan...</p>","tmdb_id":109989,"cast":["Ha Yue","Amy Chan","Elaine Ho Yuen-Ying","Lý Quốc Lân","Bao Fang","Chan Yau-Hau","Tam Sin-Hung","Mak Hiu-Wai","Suen Kwai-Hing","Tang Yu-Chiu","Chan Min-Leung","Hoàng Nhất Phi","Vương Vỹ Lương","Michelle Fung","Johnny Ngan"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"109989","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Ha Yue","name_vi":null,"name_original":"Ha Yue","tmdb_id":1135779,"profile":"https://image.tmdb.org/t/p/w500/jASQhIe4XKYmpvcHqYmbrKGsuSN.jpg","tmdb_url":"https://www.themoviedb.org/person/1135779"},{"name":"Amy Chan","name_vi":null,"name_original":"Amy Chan","tmdb_id":2401290,"profile":"https://image.tmdb.org/t/p/w500/oLg3LnRKS6kjZdWAtrM8k0p4N48.jpg","tmdb_url":"https://www.themoviedb.org/person/2401290"},{"name":"Elaine Ho Yuen-Ying","name_vi":null,"name_original":"Elaine Ho Yuen-Ying","tmdb_id":354335