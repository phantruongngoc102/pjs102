ip.opstream12.com/20220402/7251_95b56041/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream12.com/share/201d546992726352471cfea6b0df0a48","link_m3u8":"https://vip.opstream12.com/20220402/7252_76288654/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream12.com/share/7900770abf7086faafd8c122981cc82f","link_m3u8":"https://vip.opstream12.com/20220402/7253_77faf478/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream12.com/share/5248e5118c84beea359b6ea385393661","link_m3u8":"https://vip.opstream12.com/20220402/7254_9b9d2270/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream12.com/share/fbefa505c8e8bf6d46f38f5277fed8d6","link_m3u8":"https://vip.opstream12.com/20220402/7255_954dd806/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream12.com/share/9f8785c7f9b578bec2c09e616568d270","link_m3u8":"https://vip.opstream12.com/20220402/7256_58a41b6f/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream12.com/share/f77ad541b6b5bc48c47d814b95491fbd","link_m3u8":"https://vip.opstream12.com/20220402/7257_34b92842/index.m3u8"},{"name":"47","slug":"47","link_embed":"https://vip.opstream12.com/share/358c850b3836ae02b1d8b319d86d435f","link_m3u8":"https://vip.opstream12.com/20220402/7258_ba7e026c/index.m3u8"},{"name":"48","slug":"48","link_embed":"https://vip.opstream12.com/share/d04cb95ba2bea9fd2f0daa8945d70f11","link_m3u8":"https://vip.opstream12.com/20220402/7259_89a83e6a/index.m3u8"}]}],"description":"<p>Trong Đại thiên giới, nơi các vị diện giao nhau, có một truyền kỳ trong thế giới vô tận này đến từ Hạ vị diện. Thiếu chủ Mục Trần của Bắc Linh Cảnh đã đem lòng yêu thương Lạc Ly trên hành trình tiến vào Linh Lộ. Sau một thảm sát đẫm máu Mục Trần đã bị đuổi khỏi Linh Lộ, vẫn quyết gặp lại Lạc Ly ở Ngũ Đại Viện. Trong Bắc Linh Cảnh, Liễu vực và Mục vực luôn đối đầu với nhau, mà Liễu Kinh Thiên – chủ nhân của Liễu vực luôn ấp ủ một âm mưu to lớn. Gánh trên vai trách nhiệm về sự hưng thịnh của Mục vực, về lời hẹn ước với Lạc Ly, Mục Trần bắt đầu con đường trở thành Đại chúa tể của mình.</p>","tmdb_id":98874,"cast":[],"director":[],"keywords":[],"tmdb":{"id":98874},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/dai-chua-te.json"}