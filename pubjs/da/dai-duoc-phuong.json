d2c00","link_m3u8":"https://vip.opstream16.com/20220709/20321_0eb2e0e1/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream16.com/share/e811387c8fc99fc6fe3585e61f7917a8","link_m3u8":"https://vip.opstream16.com/20220709/20322_23e19339/index.m3u8"}]}],"description":"<p>Thượng Xuân Đường là 1 hiệu thuốc danh tiếng lúc bấy giờ. Ông chủ họ Đỗ không có con trai, chỉ có duy nhất một đứa con gái là Đỗ Giai Kỳ (Chung Gia Hân). Giai Kỳ rất có hứng thú với ngành y, nhưng cha của cô không hy vọng cô có thể kế thừa gia nghiệp. Phu quân Trang Kế Tổ (Huỳnh Hạo Nhiên) đột ngột qua đời trong ngày tân hôn. Thượng Xuân Đường bị niêm phong, cha mang thân tù ngục, Giai Kỳ không chốn dung thân, Thượng Xuân Đường bị thương nhân Đinh Nhất Nguyên mua lại. Nhưng bất ngờ Giai Kỳ gặp được một thần y đã thoái ẩn, được truyền thụ y thuật và hóa thù thành bạn với thương nhân Nhất Nguyên. Trong trấn xảy ra dịch bệnh, tuy rằng hiểm nguy trùng trùng, trong nguy có cơ, đó là thời cơ để Giai Kỳ gầy dựng lại Thượng Xuân Đường...</p>","tmdb_id":88383,"cast":["Chung Gia Hân","Trần Triển Bằng","Huỳnh Hạo Nhiên","Natalie Tong","Dương Tư Kỳ","Ngao Gia Niên","Lâm Tử Thiện","Trương Chấn Lãng","Nhạc Hoa","Sammy Sum Chun-Hin"],"director":["Từ Chính Khang"],"keywords":[],"tmdb":{"type":"tv","id":"88383","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Chung Gia Hân","name_vi":"Chung Gia Hân","name_original":"Linda Chung Ka-Yan","tmdb_id":146654,"profile":"https://image.tmdb.org/t/p/w500/ao0Hei6czNVCJq1m8n0lRFk9SqG.jpg","tmdb_url":"https://www.themoviedb.org/person/146654"},{"name":"Trần Triển Bằng","name_vi":"Trần Triển Bằng","name_original":"Ruco Chan","tmdb_id":1238985,"profile":"https://image.tmdb.org/t/p/w500/jD9jx5wiF3Y0XYzvcCNC2oRBrvT.jpg","tmdb_url":"https://www.themoviedb.org/person/1238985"},{"name":"Huỳnh Hạo Nhiên","name_vi":"Huỳnh Hạo Nhiên","name_original":"Raymond Ho-Yin Wong","tmdb_id":123648,"profile":"https://image.tmdb.org/t/p/w500/wrs7gHK5Ykyae2okZbrQU9bgIK