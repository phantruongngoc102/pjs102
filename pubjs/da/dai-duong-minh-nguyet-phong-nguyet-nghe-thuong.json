2a05ed8/index.m3u8"},{"name":"39B","slug":"39b","filename":"dai-duong-minh-nguyet-weaving-a-tale-of-love-tap-39B","link_embed":"https://vip.opstream12.com/share/17bfc1d7c4dad1d69cf2a78825516205","link_m3u8":"https://vip.opstream12.com/20220611/18735_9176f35d/index.m3u8"},{"name":"40A","slug":"40a","filename":"dai-duong-minh-nguyet-weaving-a-tale-of-love-tap-40A","link_embed":"https://vip.opstream12.com/share/92fd79ada7ac5803c79b9bd287492312","link_m3u8":"https://vip.opstream12.com/20220611/18734_7c2262f0/index.m3u8"},{"name":"40B","slug":"40b","filename":"dai-duong-minh-nguyet-weaving-a-tale-of-love-tap-40B","link_embed":"https://vip.opstream12.com/share/f8f6b523ba28dcc12b82576b0d694d18","link_m3u8":"https://vip.opstream12.com/20220611/18737_8bd32034/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Lấy bối cảnh Đại Đường dưới thời của Võ Tắc Thiên, khán giả sẽ được thấy những biến động lớn về chính trị mà tác giả nguyên tác Lam Vân Thư đưa vào. Khố Địch Lưu Ly (Cổ Lực Na Trát đóng) sống lại ở thời cổ đại, cô chỉ muốn quãng đời còn lại sống bình yên hạnh phúc là được. Nhưng nàng không được toại nguyện, về sau bị cuốn vào những âm mưu chính trị và rồi gặp gỡ Bùi Hành Kiệm (Hứa Ngụy Châu đóng), một người tài giỏi luôn vì nước vì dân. Cùng nhau vượt qua mọi âm mưu chính trị và những khó khăn vất vả khác, Lưu Ly và Bùi Hạnh Kiệm cuối cùng cũng có thể sống hạnh phúc bên nhau.</p>","tmdb":{"type":"tv","id":"117685","season":1,"vote_average":6.1,"vote_count":7},"modified":"2022-06-11T11:46:42.000Z","cast":["Cổ Lực Na Trát","Timmy Xu","Zhao Shunran","Lưu Đoan Đoan","Zeng Yixuan","Zhang Tao","Song Hanyu","Lin Zi","Chen Xinxuan"],"director":[],"cast_meta":[{"name":"Cổ Lực Na Trát","name_vi":"Cổ Lực Na Trát","name_original":"Gulnezer Bextiyar","tmdb_id":1291460,"profile":"https://image.tmdb.org/t/p/w500/9HZkWl3glcA56J1rWlMU1TKh71q.jpg","tmdb_url":"https://www.themoviedb.org/person/1291460"},{"name":"Timmy Xu","name_vi":null,"name_original":"Timmy Xu","tmdb_id":1591362,"pr