bef0018e0773a0","link_m3u8":"https://vip.opstream14.com/20230222/32591_95786d88/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Vay nặng lãi là phương thức phổ biến để giải quyết nhanh chóng nhu cầu tài chính, một ông trùm với hệ thống cho vay nặng lãi sử dụng các quy tắc giang hồ để quản lý, thu hồi nợ bằng các biện pháp bạo lực. Ông trùm bị điều tra, lời khuyên từ người vợ rửa tay gác kiếm. Rồi biến cố xảy ra, ông trùm bị sét đánh, trở thành một người tốt bất ngờ. Bộ phim là câu chuyện về các băng đảng xã hội đen, mối quan hệ của các nhân vật sừng sỏ, tài chính đen và giang hồ, cuộc chiến chống tội phạm của cảnh sát, những câu chuyện cảm động….Xã hội chứa đầy những bất công và sự bất bình đẳng giữa người giàu và người nghèo. Những công dân nhỏ bé trong những góc tối đang rất cần được giải cứu. Mọi người thực sự cần một người đàn ông giàu có được cứu trợ.</p>","tmdb":{"type":"tv","id":"93203","season":1,"vote_average":8,"vote_count":1},"modified":"2023-02-22T15:17:44.000Z","cast":["Trịnh Tắc Sĩ","Chris Lai","Uyển Quỳnh Đan","Thiệu Mỹ Kỳ","Ngô Nghiệp Khôn","Mandy Wong","Lesley Chiang","Viên Văn Kiệt","Jack Hui Ka Kit"],"director":[],"cast_meta":[{"name":"Trịnh Tắc Sĩ","name_vi":"Trịnh Tắc Sĩ","name_original":"Kent Cheng Jak-Si","tmdb_id":65966,"profile":"https://image.tmdb.org/t/p/w500/a1ebM3aLwYkPckPzc9FgfW2xTsZ.jpg","tmdb_url":"https://www.themoviedb.org/person/65966"},{"name":"Chris Lai","name_vi":null,"name_original":"Chris Lai","tmdb_id":112986,"profile":"https://image.tmdb.org/t/p/w500/en9t651XkkOpdfIZRQdtqmZD6YG.jpg","tmdb_url":"https://www.themoviedb.org/person/112986"},{"name":"Uyển Quỳnh Đan","name_vi":"Uyển Quỳnh Đan","name_original":"Kingdom Yuen King-Tan","tmdb_id":94076,"profile":"https://image.tmdb.org/t/p/w500/nXVQeVWR0sMpW2eZ4blSqZt9ces.jpg","tmdb_url":"https://www.themoviedb.org/person/94076"},{"name":"Thiệu Mỹ Kỳ","name_vi":"Thiệu Mỹ Kỳ","name_original":"Maggie Shiu","tmdb_id":1173600,"profile":"https://image.tmdb.org/t/p/w500/smUbYgh0zhsCb