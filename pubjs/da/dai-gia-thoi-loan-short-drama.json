1/index.m3u8"},{"name":"91","slug":"91","link_embed":"https://vip.opstream-short.com/share/afb10ddfce75e4a231f083365f04e08f","link_m3u8":"https://vip.opstream-short.com/20251116/29275_afb10ddf/index.m3u8"},{"name":"92","slug":"92","link_embed":"https://vip.opstream-short.com/share/d0adfd0849265d3738d28df149746e21","link_m3u8":"https://vip.opstream-short.com/20251116/29276_d0adfd08/index.m3u8"},{"name":"93","slug":"93","link_embed":"https://vip.opstream-short.com/share/67245236ce5a981076ce7feffc35c893","link_m3u8":"https://vip.opstream-short.com/20251116/29277_67245236/index.m3u8"},{"name":"94","slug":"94","link_embed":"https://vip.opstream-short.com/share/46bf8132ed264dd0192d219f8be3be51","link_m3u8":"https://vip.opstream-short.com/20251116/29278_46bf8132/index.m3u8"}]}],"description":"<p>Câu chuyện diễn ra trong một thời đại hỗn loạn và bất ổn, theo chân một doanh nhân giàu có với óc kinh doanh nhạy bén và lòng dũng cảm. Trong thời kỳ khó khăn đầy khủng hoảng và thử thách này, các thế lực khác nhau chiến đấu không ngừng trong khi trật tự xã hội sụp đổ. Nhân vật chính xây dựng tài sản khổng lồ thông qua sự nhìn nhận sâu sắc và quyết định táo bạo, mở rộng đế chế kinh doanh của mình qua thương mại, sản xuất, tài chính và bất động sản. Tuy nhiên, sự giàu có mang đến vô số rắc rối và nguy hiểm khi các phe khác nhau thèm muốn tài sản của ông - một số cố gắng lôi kéo ông trong khi những kẻ khác tìm cách cướp đoạt. Ông phải đối phó với các chính trị gia xảo quyệt, các lãnh chúa tham lam và băng đảng tàn nhẫn. Dù đối mặt với thử thách, ông vẫn thể hiện tính nhân văn bằng cách giúp đỡ nạn nhân thiên tai và xây dựng trường học, bệnh viện. Cùng với những người bạn cùng chí hướng, ông chống lại các thế lực tà ác trong thế giới hỗn loạn này. Khi câu chuyện phát triển, ông đối mặt với những lựa chọn khó khăn hơn giữa việc bảo vệ tài sản và gia đình trong khi mang lại hy vọng cho thời đại đầy vấn đề này.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/dai-gia-thoi-loan-short-drama.json","tmdb_checked":false}