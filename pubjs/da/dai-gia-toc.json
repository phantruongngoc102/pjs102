om/20230207/30685_4dce11fc/index.m3u8"},{"name":"25","slug":"25","filename":"TVB Đại Gia Tộc tập 25","link_embed":"https://vip.opstream14.com/share/b3d2a9a2985c5a32c669cc33c885e6c8","link_m3u8":"https://vip.opstream14.com/20230207/30686_701ee2c9/index.m3u8"},{"name":"26","slug":"26","filename":"TVB Đại Gia Tộc tập 26","link_embed":"https://vip.opstream14.com/share/bd689c29167187a5b0a27f7be2c915b5","link_m3u8":"https://vip.opstream14.com/20230207/30687_0e5c014d/index.m3u8"},{"name":"27","slug":"27","filename":"TVB Đại Gia Tộc tập 27","link_embed":"https://vip.opstream14.com/share/9c8001602e98208ef4e8d1bbf79fee65","link_m3u8":"https://vip.opstream14.com/20230207/30688_ae068368/index.m3u8"},{"name":"28","slug":"28","filename":"TVB Đại Gia Tộc tập 28","link_embed":"https://vip.opstream14.com/share/98d27eaef365d1710da5106ffbabf73c","link_m3u8":"https://vip.opstream14.com/20230207/30689_c50e50b1/index.m3u8"},{"name":"29","slug":"29","filename":"TVB Đại Gia Tộc tập 29","link_embed":"https://vip.opstream14.com/share/48566ed0fe86539f5d9b227667e4260b","link_m3u8":"https://vip.opstream14.com/20230207/30690_4d09fcc2/index.m3u8"},{"name":"30","slug":"30","filename":"TVB Đại Gia Tộc tập 30","link_embed":"https://vip.opstream14.com/share/57c0ef6ca5eb27bf4dd7ff5bc1ba7d0d","link_m3u8":"https://vip.opstream14.com/20230207/30691_761d3615/index.m3u8"}]}],"time":"45 phút / tập","description":"<p>Là một trong những thể loại rất thành công của TVB suốt từ những năm đầu thập lập đài, đề tài gia đình được sử dụng một cách thường xuyên và luôn có một lượng người xem ổn định với nhiều độ tuổi, thành phần khác nhau nhờ vào cốt truyện dễ hiểu, đặc biệt là những phim đề cập tới gia tộc mà minh chứng chính là Đại Gia Tộc của đạo diễn nổi tiếng Lý Chiêm Thắng được ra mắt vào năm 1991. Phim không chỉ được đánh giá cao về nội dung, sự kịch tính ngày càng tăng về những tập sau mà còn xuất sắc về mặt diễn xuất khi quy tụ dàn diễn viên cực chất lượng của nhà đài tại thời điểm đó.</p><p>Nội dung của phim Đại Gia Tộc bắt đầu từ việc tranh giành tài sản Vĩnh Nghiệp của 2 cha con Tưởng Văn Sơn, từ đó mà những mối bất hòa bắt đầu nảy sinh giữa 2 người. Thực tế, con trai Văn Sơn là Tưởng Tiến, người đã theo mẹ đến Mã Lai ngay từ khi còn nằm trong bụng nhưng khi lớn lên thì chú Kiệt của Tiến gọi về làm trong Vĩnh Nghiệp.</p><p>Vốn dĩ mọi chuyện không có gì gọi là nghiêm trọng nếu như không có sự xuất hiện của Tiền Huệ Châu, người đã đứng ra tiếp quản gia đình, từ đó gây ra không ít việc khó dễ để rồi hậu quả là làm cho Kiệt phải chết, thậm chí tồi tệ hơn, con trai của bà ta – Khang, là người thay thế chức vụ của Kiệt, những biến cố trong Đại Gia Tộc nhà họ Tưởng ngày càng lên đến đỉnh điểm…</p>","tmdb":{"type":"tv","id":"110011","season":1,"vote_average":0,"vote_count":0},"modified":"2023-02-09T16:46:50.000Z","cast":["Alex Man Chi-Leung","Tăng Giang","Điềm Nữu","Samantha Chuk Man-Kwan","Wing Lam","Elizabeth Lee Mei-Fung","Canti Lau Sek-Ming","Chu Giang","Hứa Thiệu Hùng","Lê Diệu Tường","Quan Hải Sơn","Hạ Bình","Phùng Tố Ba","Cutie Mui Siu-Wai","Kong Ngai"],"director":[],"cast_meta":[{"name":"Alex Man Chi-Leung","name_vi":null,"name_original":"Alex Man Chi-Leung","tmdb_id":148886,"profile":"https://image.tmdb.org/t/p/w500/jY5DKV1oioxxhD2xZdjBJPqVa8.jpg","tmdb_url":"https://www.themoviedb.org/person/148886"},{"name":"Tăng Giang","name_vi":"Tăng Giang","name_original":"Kenneth Tsang","tmdb_id":10885,"profile":"https://image.tmdb.org/t/p/w500/nqlO9OTaqPA38fEmWont8n6spms.jpg","tmdb_url":"https://www.themoviedb.org/person/10885"},{"name":"Điềm Nữu","name_vi":"Điềm Nữu","name_original":"Tien Niu","tmdb_id":115610,"profile":"https://image.tmdb.org/t/p/w500/6MxBj1REjW2pwKnglAcli1w08F.jpg","tmdb_url":"https://www.themoviedb.org/person/115610"},{"name":"Samantha Chuk Man-Kwan","name_vi":null,"name_original":"Samantha Chuk Man-Kwan","tmdb_id":3450480,"profile":"https://image.tmdb.org/t/p/w500/3Vm1lCAP9cqfiwbGhNam6Xly6iO.jpg","tmdb_url":"https://www.themoviedb.org/person/3450480"},{