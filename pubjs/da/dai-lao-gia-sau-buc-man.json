 thanh niên có tài nhưng anh rất cứng nhắc trong suy nghĩ cũng như quan điểm của mình. Anh luôn cảm thấy bất mãn với các luật lệ và quy tắc hà khắc chốn quan trường, vì vậy anh luôn gặp trở ngại trên con đường tiến thân. Để giải sầu, Châu Bỉnh thường lui tới tửu điếm và anh tình gặp được vị cô nương xinh đẹp Trang Tiểu Nhàn (Đường Ninh đóng) tại đây. Mối quan hệ giữa Châu Bình và Tiểu Nhàn khiến nương tử anh là Triệu Ngọc Khanh (Từ Tử San đóng) nổi máu hoạn thư. ...","tmdb":{"type":"tv","id":"7627","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-20T10:33:37.000Z","cast":["Kenneth Ma Kwok-Ming","Kate Tsui Tsz-Shan","Đường Ninh","Cao Quân Hiền","Lưu Giang","Lưu Gia Huy","La Quân Tả"],"director":["Lý Thiêm Thắng"],"cast_meta":[{"name":"Kenneth Ma Kwok-Ming","name_vi":null,"name_original":"Kenneth Ma Kwok-Ming","tmdb_id":1232198,"profile":"https://image.tmdb.org/t/p/w500/6DejZHB8htcmosNwuOGJeDUgfJr.jpg","tmdb_url":"https://www.themoviedb.org/person/1232198"},{"name":"Kate Tsui Tsz-Shan","name_vi":null,"name_original":"Kate Tsui Tsz-Shan","tmdb_id":131256,"profile":"https://image.tmdb.org/t/p/w500/d1YkPN0x4o46Jz7ws5WowWgOoW8.jpg","tmdb_url":"https://www.themoviedb.org/person/131256"},{"name":"Đường Ninh","name_vi":"Đường Ninh","name_original":"Leila Tong","tmdb_id":102884,"profile":"https://image.tmdb.org/t/p/w500/tQWWpHIWP9gW1uu2Zv4aErQiDYY.jpg","tmdb_url":"https://www.themoviedb.org/person/102884"},{"name":"Cao Quân Hiền","name_vi":"Cao Quân Hiền","name_original":"Matthew Ko","tmdb_id":1240854,"profile":"https://image.tmdb.org/t/p/w500/ve3Aa62QmWrEuTAIwdNJ0h6OZZt.jpg","tmdb_url":"https://www.themoviedb.org/person/1240854"},{"name":"Lưu Giang","name_vi":"Lưu Giang","name_original":"Lau Kong","tmdb_id":140481,"profile":"https://image.tmdb.org/t/p/w500/cWSJGJ1f5moLrbSXWiJ2qQWldlK.jpg","tmdb_url":"https://www.themoviedb.org/person/140481"},{"name":"Lưu Gia Huy","name_vi":"Lưu Gia Huy","name_original":"Gordon Liu Chia-Hui","tmdb_id":240171,"profile":"https:/