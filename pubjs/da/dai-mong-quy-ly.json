:"33","filename":"Fangs.of.Fortune.2024.S01E33.1080p.IQIYI.WEB-DL.AAC.H.264-ANDY","link_embed":"https://vip.opstream11.com/share/4b9ef0c61196d0ca7fe417623c7ddfd1","link_m3u8":"https://vip.opstream11.com/20241117/57694_4b9ef0c6/index.m3u8"},{"name":"34","slug":"34","filename":"Fangs.of.Fortune.2024.S01E34.1080p.IQIYI.WEB-DL.AAC.H.264-ANDY","link_embed":"https://vip.opstream11.com/share/1ad89ae52344fad4251c73175f044c58","link_m3u8":"https://vip.opstream11.com/20241117/57695_1ad89ae5/index.m3u8"}]}],"time":"40 phút/tập","description":"\"Đại Mộng Quy Li\" là một bộ phim cổ trang do Hầu Minh Hạo (\"Thợ Săn Tâm Trạch\", \"Hộ Tâm\"), Trần Đô Linh (\"Liên Hoa Lâu\"), Điền Gia Thụy (\"Vân Chi Vũ\"), Trình Tiêu (\"Khanh Khanh Ngã Tâm\") đóng vai chính. Bộ phim này được lấy cảm hứng từ \"Sơn Hải Kinh\", kể về một câu chuyện truyền kỳ quỷ lệ về \"yêu muốn bắt yêu\". Trong thời kỳ Trinh Nguyên, do nữ thần Bạch Tắc, người kiểm soát hai giới người và yêu bất ngờ mất mạng, Bạch Tắc mất tích không dấu vết, yêu thú hoành hành trên đất người, gây ra nhiều vụ án đẫm máu. Trong thời điểm này, \"Chu Yếm\", thủ lĩnh đạo của bách yêu đã biến hình thành người có tên là Triệu Viễn Châu (Hầu Minh Hạo đóng), tự nguyện \"sát cánh\" với triều đình, đề xuất hỗ trợ triều đình thành lập Tập Yêu Ti, bắt yêu dẹp loạn.","tmdb":{"type":"tv","id":"239389","season":1,"vote_average":8.714,"vote_count":21},"modified":"2024-11-17T10:57:01.000Z","cast":["Hầu Minh Hạo","Trần Đô Linh","Điền Gia Thụy","Trình Tiêu","Lâm Tử Diệp","Từ Chấn Hiên","Diêm An","Lại Vĩ Minh","Lưu Hoan"],"director":["Edward Guo","Luo Luo"],"cast_meta":[{"name":"Hầu Minh Hạo","name_vi":"Hầu Minh Hạo","name_original":"Hou Minghao","tmdb_id":1844511,"profile":"https://image.tmdb.org/t/p/w500/cKFIKmHNPtAdeaWozo3MZkirojC.jpg","tmdb_url":"https://www.themoviedb.org/person/1844511"},{"name":"Trần Đô Linh","name_vi":"Trần Đô Linh","name_original":"Chen Duling","tmdb_id":1476992,"profile":"https://image.tmdb.org/t/p/w500/awVbnhkLiGuv6h6axIb5oNgRJ