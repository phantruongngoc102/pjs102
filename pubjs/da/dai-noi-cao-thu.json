nk_embed":"https://vip.opstream12.com/share/58a3db58796ee4fbe42b1bcea1a888ff","link_m3u8":"https://vip.opstream12.com/20250409/26965_58a3db58/index.m3u8"},{"name":"30","slug":"30","filename":"Đại Nội Cao Thủ - The Amateur Imperial Bodyguard - Tập 30","link_embed":"https://vip.opstream12.com/share/7a16092a4fa489c835c716ea3815f704","link_m3u8":"https://vip.opstream12.com/20250409/26966_7a16092a/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Đại Nội Cao Thủ - The Amateur Imperial Bodyguard kể về Truyền Vệ (Từ Tranh đóng) là một trong mười hai thị vệ của Niêm Can Xứ- một tổ chức bí mật chỉ nghe lệnh của Hoàng Đế. Anh đã bị thương và mất trí nhớ trong một lần thi hành nhiệm vụ. Triệu Tam Phát (Từ Tranh đóng) - chàng lang thang vì có tướng mạo giống với Lý Truyền Vệ như hai giọt nước, nên bị nhìn nhầm là Truyền Vệ. Trong phút chốc, chàng lang thang Triệu Tam Phát bỗng trở thành một cao thủ của Niêm Can Xứ, thực hiện những nhiệm vụ được giao trước và sau khi Hoàng đế Càn Long (Lôi Cách Sinh đóng) nhường ngôi.</i></p>","tmdb":{"type":"tv","id":"257783","season":1,"vote_average":0,"vote_count":0},"modified":"2025-04-09T22:53:23.000Z","cast":["Vu Ba","Triệu Lệ Dĩnh","Lei Kesheng"],"director":[],"cast_meta":[{"name":"Vu Ba","name_vi":"Vu Ba","name_original":"Apollo Yu","tmdb_id":237593,"profile":"https://image.tmdb.org/t/p/w500/rQslbjYAvS6Ek7Hdas0wYx6B2T0.jpg","tmdb_url":"https://www.themoviedb.org/person/237593"},{"name":"Triệu Lệ Dĩnh","name_vi":"Triệu Lệ Dĩnh","name_original":"Zhao Liying","tmdb_id":1260868,"profile":"https://image.tmdb.org/t/p/w500/lDkliS0cwOFO0QA7epHYZJWNttG.jpg","tmdb_url":"https://www.themoviedb.org/person/1260868"},{"name":"Lei Kesheng","name_vi":null,"name_original":"Lei Kesheng","tmdb_id":143029,"profile":"https://image.tmdb.org/t/p/w500/vPOhJiDYkPDk8xHGdoxZ3Kfhdpq.jpg","tmdb_url":"https://www.themoviedb.org/person/143029"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/dai-noi-cao-thu.json"}