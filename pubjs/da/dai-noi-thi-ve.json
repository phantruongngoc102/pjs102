re/14318e2a43a225fc24ab55f3c0122cf0","link_m3u8":"https://vip.opstream16.com/20221020/24317_48028bb6/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/9154498493d8e734d9c7489c2b6b26d7","link_m3u8":"https://vip.opstream16.com/20221020/24318_09ec8d68/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/62343fe688d3b70314b5c1730328a936","link_m3u8":"https://vip.opstream16.com/20221020/24319_8bc527c3/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream16.com/share/b2f29338576d3ba925ba0f99088726b5","link_m3u8":"https://vip.opstream16.com/20221020/24320_7c376b86/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream16.com/share/a774b1d228003465cbd98d456af7bf43","link_m3u8":"https://vip.opstream16.com/20221020/24321_fb1998ed/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream16.com/share/b13c180ba3b4c0afdd38ed2cb91fc498","link_m3u8":"https://vip.opstream16.com/20221020/24322_1e424df6/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream16.com/share/a6a87ed8d5af6aeff8d859ffd50c5db0","link_m3u8":"https://vip.opstream16.com/20221020/24323_6c5b77f8/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream16.com/share/fb2e636577105f243646d6f1e199f0ba","link_m3u8":"https://vip.opstream16.com/20221020/24324_31c7c29e/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream16.com/share/f7da8deec4b7a7e1e9421420b2dfa049","link_m3u8":"https://vip.opstream16.com/20221020/24325_ad74dcb2/index.m3u8"},{"name":"27","slug":"27","link_embed":"https://vip.opstream16.com/share/4c8c1946e71215e6e30d5f5de3f473ef","link_m3u8":"https://vip.opstream16.com/20221020/24326_c2ff397e/index.m3u8"}]}],"description":"<p>Đại Nội Thị Vệ nói về một thị vệ cận thân thị vệ của vua Khang Hy tên là Đa bảo. Đa bảo là một chàng thanh niên luôn có ước mơ được vào làm thị vệ trong tử cấm thành. Chàng thanh niên này có võ nghệ cao cường, luôn muốn phục vụ người dân. Cuối cùng Đa Bao cũng đạt được ước mơ của mình, Đa Bảo được xung làm cận vệ cho Du Thân Vương Phứơc Toàn, được sự tín nhiệm và kết thân với vị vương gia này, Đa Bảo được đề cử bảo vệ vua Khang Hy. Nhưng trong chốn cấm cung luôn đầy rẩy những âm mưu toan tính, tranh giành quyền lực. Đa Bảo Phát hiện ra âm mưu soán vị ngôi vua của người huynh đệ Phước Toàn. Người bạn thanh mai trúc mã Trác Tử Ngưng của Đa Bảo lại bị cuốn vào cuộc chiến quyền lực chốn hậu cung. Đa Bảo phải làm thế nào để biết ai là thù, ai là bạn?</p>","tmdb_id":37729,"cast":["Mã Tuấn Vỹ","Kenneth Ma Kwok-Ming","Natalie Tong","Elaine Yiu","Rosanne Lui Shan","Trần Quốc Bang","Lý Thi Hoa","Mạch Trường Thanh"],"director":["Lương Tài Viễn"],"keywords":[],"tmdb":{"type":"tv","id":"37729","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Mã Tuấn Vỹ","name_vi":"Mã Tuấn Vỹ","name_original":"Steven Ma Chun-Wai","tmdb_id":1233285,"profile":"https://image.tmdb.org/t/p/w500/q60svjeSi9KpyZCwhnwwy6iy8Qs.jpg","tmdb_url":"https://www.themoviedb.org/person/1233285"},{"name":"Kenneth Ma Kwok-Ming","name_vi":null,"name_original":"Kenneth Ma Kwok-Ming","tmdb_id":1232198,"profile":"https://image.tmdb.org/t/p/w500/6DejZHB8htcmosNwuOGJeDUgfJr.jpg","tmdb_url":"https://www.themoviedb.org/person/1232198"},{"name":"Natalie Tong","name_vi":null,"name_original":"Natalie Tong","tmdb_id":1237978,"profile":"https://image.tmdb.org/t/p/w500/jZHpp0BOnVW3M0NqH3TVpj0oGo6.jpg","tmdb_url":"https://www.themoviedb.org/person/1237978"},{"name":"Elaine Yiu","name_vi":null,"name_original":"Elaine Yiu","tmdb_id":1234807,"profile":"https://image.tmdb.org/t/p/w500/CV05R5HbE4MnpeWeE5HAFaV2bG.jpg","tmdb_url":"https://www.themoviedb.org/person/1234807"},{"name":"Rosanne Lui Shan","name_vi":null,"name_original":"Rosanne Lui Shan","tmdb_id":1334858,"profile":"https://image.tmdb.org/t/p/w500/5yfVsjkqDNxegSYDjv9NKWwSddU.jpg","tmdb_url":"https://www.themoviedb.org/person/1334858"},{"name":"Trần Quốc Bang","name_vi":"Trầ