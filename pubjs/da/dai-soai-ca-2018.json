ủa thế lực hai bên đảng Cách Mạng và thế lực Nhật Bản xâm lược, lại chính là vợ của Địch Kỳ! Địch Kỳ phải giải quyết ra sao đây?","tmdb":{"type":"tv","id":"85737","season":1,"vote_average":6.3,"vote_count":3},"modified":"2025-09-19T17:55:12.000Z","cast":["Trương Vệ Kiện","Sisley Choi Si-Pui","Hồng Vĩnh Thành","Đàm Khải Kỳ","Vivien Yeo","Tsui Wing","Oscar Li Ka","Tào Vĩnh Liêm","Jessica Kan Shuk-Yi","Marine Lee Yee-Man","Max Cheung Tat-Lun","Jerry Koo Ming-Wah","Choi Kwok-Hing","Eddie Pang Wai-On","Joseph Yeung"],"director":["Cheng-kang Tse"],"cast_meta":[{"name":"Trương Vệ Kiện","name_vi":"Trương Vệ Kiện","name_original":"Dicky Cheung Wai-Kin","tmdb_id":83489,"profile":"https://image.tmdb.org/t/p/w500/b2a2h0Xz4pDk7B0WDFADvzc5S1g.jpg","tmdb_url":"https://www.themoviedb.org/person/83489"},{"name":"Sisley Choi Si-Pui","name_vi":null,"name_original":"Sisley Choi Si-Pui","tmdb_id":1545561,"profile":"https://image.tmdb.org/t/p/w500/kMoFQdV3Do1kIuDMq2dYOYNrMZ2.jpg","tmdb_url":"https://www.themoviedb.org/person/1545561"},{"name":"Hồng Vĩnh Thành","name_vi":"Hồng Vĩnh Thành","name_original":"Tony Hung","tmdb_id":2214358,"profile":"https://image.tmdb.org/t/p/w500/vsJtcHg5IIOmZTIHrhntjjwZ5zl.jpg","tmdb_url":"https://www.themoviedb.org/person/2214358"},{"name":"Đàm Khải Kỳ","name_vi":"Đàm Khải Kỳ","name_original":"Zoie Tam","tmdb_id":1315729,"profile":"https://image.tmdb.org/t/p/w500/rHoeN66q8PBV2TLZdWbmyXQE1Wt.jpg","tmdb_url":"https://www.themoviedb.org/person/1315729"},{"name":"Vivien Yeo","name_vi":null,"name_original":"Vivien Yeo","tmdb_id":1240093,"profile":"https://image.tmdb.org/t/p/w500/qLhex12qwHLJK1Fd0XVSrJP6Fne.jpg","tmdb_url":"https://www.themoviedb.org/person/1240093"},{"name":"Tsui Wing","name_vi":null,"name_original":"Tsui Wing","tmdb_id":1258590,"profile":"https://image.tmdb.org/t/p/w500/hMQmjh0tZcT5E7T66oSYjiUvW7n.jpg","tmdb_url":"https://www.themoviedb.org/person/1258590"},{"name":"Oscar Li Ka","name_vi":null,"name_original":"Oscar Li Ka","tmdb_id":1888226,"pr