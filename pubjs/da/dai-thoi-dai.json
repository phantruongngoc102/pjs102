16.com/share/c31de872e4b768853e4180258bb2ab00","link_m3u8":"https://vip.opstream16.com/20241119/41073_c31de872/index.m3u8"}]}],"description":"<p>Được kể theo trình tự thời gian ngược lại, câu chuyện bắt đầu ở hiện tại (ngày 7 tháng 6 năm 1994), khi thị trường chứng khoán phục hồi sau khi thị trường trở nên bất ổn và sụp đổ vào cuối tuần. Sau khi thị trường chứng khoán ngừng giao dịch vào cuối tuần, gia đình Ting đã đặt cược sai và toàn bộ tài sản của họ bị xóa sổ, cộng thêm việc họ phải gánh khoản nợ hàng tỷ đô la. Ting Hai buộc các con trai của mình phải tự tử bằng cách nhảy từ trên đỉnh tòa nhà giao dịch chứng khoán trước khi đi theo họ.</p>","tmdb_id":20382,"cast":["Trịnh Thiếu Thu","Lưu Thanh Vân","Amy Kwok"],"director":["Wai Ka-fai"],"keywords":[],"tmdb":{"type":"tv","id":"20382","season":1,"vote_average":7.933,"vote_count":15},"cast_meta":[{"name":"Trịnh Thiếu Thu","name_vi":"Trịnh Thiếu Thu","name_original":"Adam Cheng Siu-Chow","tmdb_id":82401,"profile":"https://image.tmdb.org/t/p/w500/KHy7b3kAXP05VGcdsPy3Qf34GM.jpg","tmdb_url":"https://www.themoviedb.org/person/82401"},{"name":"Lưu Thanh Vân","name_vi":"Lưu Thanh Vân","name_original":"Sean Lau Ching-wan","tmdb_id":940339,"profile":"https://image.tmdb.org/t/p/w500/ecxJyPA6EPDG2AXomVJORaN4qLZ.jpg","tmdb_url":"https://www.themoviedb.org/person/940339"},{"name":"Amy Kwok","name_vi":null,"name_original":"Amy Kwok","tmdb_id":263591,"profile":"https://image.tmdb.org/t/p/w500/qLvidMwwS5IrF48UQgBT2fy8lEi.jpg","tmdb_url":"https://www.themoviedb.org/person/263591"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/da/dai-thoi-dai.json"}