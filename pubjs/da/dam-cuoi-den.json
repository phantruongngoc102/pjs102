7/10973_7a5981c5/index.m3u8"},{"name":"Full","slug":"full","link_embed":"https://vip.opstream12.com/share/b1c14790bce31f481f50e49de3542a85","link_m3u8":"https://vip.opstream12.com/20220417/10973_7a5981c5/index.m3u8"}]}],"description":"<p>Nội dung phim xoay quanh câu chuyện của tên Zhenya, một cô gái đau khổ vì tình yêu với người chồng đã bỏ mình nên cô quyết định mang anh ta trở lại. Trong sự tuyệt vọng, cô gái đã sử dụng một câu thần chú gọi là \"Đám cưới đen\", một nghi lễ ma thuật nổi tiếng với sức mạnh to lớn và không thể đảo ngược. Sau nghi lễ, người chồng yêu dấu của cô trở lại, mặc dù tình yêu của anh trở nên giống như một nỗi ám ảnh: anh thậm chí sẵn sàng giết Zhenya, để không trao cô cho bất cứ ai.</p>","tmdb_id":633802,"cast":["Yana Enzhaeva","Konstantin Beloshapka","Ilya Ermolov","Nikita Yuranov","Varvara Borodina","Sabina Akhmedova","Larysa Domaskina","Andrey Zavodyuk","Anna Vartanyan","Alla Malkova","Igor Khripunov","Maksim Bramatkin","Aleksey Klimenko","Nikita Klimenko","Nikol Koreneva"],"director":["Svyatoslav Podgaevsky"],"keywords":["baby","ritual","black magic","housewife","dressmaker","wedding","spell","demonic ceremony"],"cast_meta":[{"name":"Yana Enzhaeva","name_vi":null,"name_original":"Yana Enzhaeva","tmdb_id":2097313,"profile":"https://image.tmdb.org/t/p/w500/8TfHZVzXDNmTUbixzmnFNr86Kd6.jpg","tmdb_url":"https://www.themoviedb.org/person/2097313"},{"name":"Konstantin Beloshapka","name_vi":null,"name_original":"Konstantin Beloshapka","tmdb_id":2202678,"profile":"https://image.tmdb.org/t/p/w500/mZOwKzs4NHoMT7XXA2ta1q412YF.jpg","tmdb_url":"https://www.themoviedb.org/person/2202678"},{"name":"Ilya Ermolov","name_vi":null,"name_original":"Ilya Ermolov","tmdb_id":1626928,"profile":"https://image.tmdb.org/t/p/w500/s3kxd1znLcBSjMBBGYH8AcIVWZZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1626928"},{"name":"Nikita Yuranov","name_vi":null,"name_original":"Nikita Yuranov","tmdb_id":2759180,"profile":null,"tmdb_url":"https://www.themoviedb.org/person