k_embed":"https://vip.opstream14.com/share/4803eb7efe3ec7031867d3f9fe9f4dc5","link_m3u8":"https://vip.opstream14.com/20220629/16261_5bb58abe/index.m3u8"},{"name":"25","slug":"25","filename":"EP25- Love The Way You Are","link_embed":"https://vip.opstream12.com/share/7575c8affdb795572947dae77f9e4287","link_m3u8":"https://vip.opstream12.com/20220704/22942_4fbb48e9/index.m3u8"},{"name":"26","slug":"26","filename":"EP26- Love The Way You Are","link_embed":"https://vip.opstream12.com/share/fd9ff6393ae3278cf017fbfb56b38c85","link_m3u8":"https://vip.opstream12.com/20220704/22943_8eb1c331/index.m3u8"},{"name":"27","slug":"27","filename":"EP27- Love The Way You Are","link_embed":"https://vip.opstream14.com/share/fada3d8ed2d4a4ace2863798fece05ac","link_m3u8":"https://vip.opstream14.com/20220705/17257_ed7c8ea1/index.m3u8"},{"name":"28","slug":"28","filename":"EP28- Love The Way You Are","link_embed":"https://vip.opstream14.com/share/42dac78c17149caac83296b32af38f59","link_m3u8":"https://vip.opstream14.com/20220705/17258_656bda92/index.m3u8"},{"name":"29","slug":"29","filename":"EP29- Love The Way You Are","link_embed":"https://vip.opstream12.com/share/c6fd6c7e4da27ed17b8f3b14d35aaeb6","link_m3u8":"https://vip.opstream12.com/20220706/23072_f9fb6629/index.m3u8"},{"name":"30","slug":"30","filename":"EP30- Love The Way You Are","link_embed":"https://vip.opstream12.com/share/432bb7cac8a262cdea28cb357545d50a","link_m3u8":"https://vip.opstream12.com/20220706/23073_75cbd3a9/index.m3u8"}]}],"time":"40 phút/tập","description":"<p>Doãn Diệc Khả người dường như có một cuộc sống hoàn hảo, dù ở văn phòng hay ở nhà, cô gái ngoài 30 tuổi ấy giống như Wonder Woman. Cô ấy rất quan tâm đến mọi người xung quanh, nhưng đã quên giữ sự ấm áp trong trái tim mình. Cho đến khi ở một góc cửa hàng tiện lợi cô gặp lại cậu bé hay đến nhà mình ăn cơm lúc nhỏ Từ Quang Tây thì mọi chuyện đã thay đổi. Từ Quang Tây bây giờ đã là một chàng trai tràn đầy ánh nắng, anh đã sưởi ấm trái tim cô. Gặp lại cô sau khi du học về, sự dựa dẫm của Từ Quang Tây đối với cô khi còn nhỏ đã phát triển thành tình cảm không thể cưỡng lại. Nhưng theo đuổi Doãn Diệc Khả không phải là một việc dễ dàng. Điều đó có nghĩa là Quảng Tây sẽ phải trưởng thành nhanh chóng và chịu những áp lực của thực tế. Vì tình yêu, anh dần trưởng thành và học cách điều chỉnh tốc độ của mình để tiến về phía cô một cách dễ dàng. Sau khi trải qua một số chuyện, họ hiểu ra ý nghĩa của tình yêu. Đó không phải là hi sinh cho nhau mà là thu hút lẫn nhau, tôn trọng lẫn nhau và khiến đối phương trưởng thành hơn.</p>","tmdb":{"type":"tv","id":"204254","season":1,"vote_average":4.5,"vote_count":2},"modified":"2022-07-06T11:50:16.000Z","cast":["Angelababy","Lai Guan-lin","Điền Y Đồng","Liu Yitong","Lăng Mỹ Sỹ","Quản Tử Tịnh","Kiều Chấn Vũ","Zhang Tao","Liu Hailan","Pan Luyu","Trương Hy Lâm","Ran Xu","Zhao Simei"],"director":["Vũ Trung Trung"],"cast_meta":[{"name":"Angelababy","name_vi":"Angelababy","name_original":"AngelaBaby","tmdb_id":150899,"profile":"https://image.tmdb.org/t/p/w500/gbnjGrNhlvGu1sXhcm0J2IW0orD.jpg","tmdb_url":"https://www.themoviedb.org/person/150899"},{"name":"Lai Guan-lin","name_vi":null,"name_original":"Lai Guan-lin","tmdb_id":1901644,"profile":"https://image.tmdb.org/t/p/w500/p5O8waTlO2Pn2oSFgl0wWbTukCy.jpg","tmdb_url":"https://www.themoviedb.org/person/1901644"},{"name":"Điền Y Đồng","name_vi":"Điền Y Đồng","name_original":"Tian Yitong","tmdb_id":2489608,"profile":"https://image.tmdb.org/t/p/w500/xHM19SUwFIKAhfa0sMspVgekmwV.jpg","tmdb_url":"https://www.themoviedb.org/person/2489608"},{"name":"Liu Yitong","name_vi":null,"name_original":"Liu Yitong","tmdb_id":2489604,"profile":"https://image.tmdb.org/t/p/w500/fR74dhyNnUJvq0p1KkvCM1A5ug.jpg","tmdb_url":"https://www.themoviedb.org/person/2489604"},{"name":"Lăng Mỹ Sỹ","name_vi":"Lăng Mỹ Sỹ","name_original":"Ling Meishi","tmdb_id":2456845,"profile":"https://image.tmdb.org/t/p/w500/6M9jsWuwa1xUv06enEUzBWZN6W9.jpg","tmdb_url":"https://www.themoviedb.org/person/2