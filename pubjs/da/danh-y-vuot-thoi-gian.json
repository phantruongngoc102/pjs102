iếu thốn những dụng cụ cần thiết cùng những kiến thức y học thô sơ ở thời kỳ này, buộc anh phải tìm kiếm những phương pháp mới để giúp đỡ các bệnh nhân. Bởi những thách thức mà anh phải vượt qua, cuối cùng thì Jin Hyuk cũng trở thành một bác sĩ đích thực.</p>","tmdb":{"type":"tv","id":"45940","season":1,"vote_average":4.6,"vote_count":17},"modified":"2023-06-26T17:01:38.000Z","cast":["Park Min-young","Song Seung-heon","Lee So-yeon","HERO Jaejoong","Lee Beom-soo","Jin Yi-han","Lee Seung-joon","Kim Kwang-shik","Ha Soo-ho"],"director":["Oh Hyun Jong"],"cast_meta":[{"name":"Park Min-young","name_vi":null,"name_original":"Park Min-young","tmdb_id":1234603,"profile":"https://image.tmdb.org/t/p/w500/5Op0Gx0DULFLHtGdWVdqnYdwkAS.jpg","tmdb_url":"https://www.themoviedb.org/person/1234603"},{"name":"Song Seung-heon","name_vi":null,"name_original":"Song Seung-heon","tmdb_id":83020,"profile":"https://image.tmdb.org/t/p/w500/AloHkgRwhj3BzCKClXxPInjbW9R.jpg","tmdb_url":"https://www.themoviedb.org/person/83020"},{"name":"Lee So-yeon","name_vi":null,"name_original":"Lee So-yeon","tmdb_id":1239251,"profile":"https://image.tmdb.org/t/p/w500/juzOwXNr3f1R2pEKwNKOkroLZm6.jpg","tmdb_url":"https://www.themoviedb.org/person/1239251"},{"name":"HERO Jaejoong","name_vi":null,"name_original":"HERO Jaejoong","tmdb_id":240144,"profile":"https://image.tmdb.org/t/p/w500/40FR8lELNgp2oUwgIVMv5fuenR7.jpg","tmdb_url":"https://www.themoviedb.org/person/240144"},{"name":"Lee Beom-soo","name_vi":null,"name_original":"Lee Beom-soo","tmdb_id":86330,"profile":"https://image.tmdb.org/t/p/w500/9CSDpnR1gjbulTQdusJMiGc59Ff.jpg","tmdb_url":"https://www.themoviedb.org/person/86330"},{"name":"Jin Yi-han","name_vi":null,"name_original":"Jin Yi-han","tmdb_id":1257606,"profile":"https://image.tmdb.org/t/p/w500/96wMfWIFEQgDFlxVCtKpghvh1lj.jpg","tmdb_url":"https://www.themoviedb.org/person/1257606"},{"name":"Lee Seung-joon","name_vi":null,"name_original":"Lee Seung-joon","tmdb_id":1113060,"profile":"https://image.tmdb.o