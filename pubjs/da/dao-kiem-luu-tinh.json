61032a","link_m3u8":"https://vip.opstream17.com/20240705/14244_f507d89d/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/0676f43ba89ef089f43c6f36ca40fa4a","link_m3u8":"https://vip.opstream17.com/20240705/14245_894aebb3/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/b8a0cabd92e8b9ab1727347dfd138421","link_m3u8":"https://vip.opstream17.com/20240705/14246_e4c18293/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/695146e2eb92eb4df74536a74b022fcf","link_m3u8":"https://vip.opstream17.com/20240705/14247_675fe98d/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/61c0bc869c02703fe2244a64cf2860d9","link_m3u8":"https://vip.opstream17.com/20240705/14248_393c3a32/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream17.com/share/2ac82abfbbba61cc903d25f55ed38aa8","link_m3u8":"https://vip.opstream17.com/20240705/14249_4cc5c8f2/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream17.com/share/fb465909b8627e4912b4a32d1030164c","link_m3u8":"https://vip.opstream17.com/20240705/14250_960d5d47/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream17.com/share/a4315d65e05d0a6ce8724fae0d6380bf","link_m3u8":"https://vip.opstream17.com/20240705/14251_a5ece437/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream17.com/share/dce30dee7d6980c287d5c2992de9b752","link_m3u8":"https://vip.opstream17.com/20240705/14252_d0d2ef9c/index.m3u8"}]}],"description":"<p><i>Diệp Thường Lục (do Huỳnh Đức Bân thủ vai) là một đao phủ pháp trường từng giết vô số người. Trên đường đến kinh thành nhận nhiệm vụ thì cơ duyên trùng hợp xui khiến Thường Lục gặp gỡ và tá túc tại nhà bà đỡ nổi tiếng của kinh thành, Hoa Nhị Hồng (do Thiệu Mỹ Kỳ đóng vai). Từ đây họ cùng chứng kiến một vụ án mạng ly kì. Tình huống nguy cấp, Nhị Hồng đã ép Thường Lục dùng cây đao Quỷ Đầu mổ bụng nạn nhân cứu một sinh mạng nhỏ. Nào ngờ cậu bé sơ sinh này đã khiến cho Thường Lục và Nhị Hồng vướng vào vòng xoáy chính trị của triều đình, đối mặt với vòng quay sinh tử cận kề. Hai người từ chỗ nghi kỵ, lạnh lùng rồi dần nảy sinh tình cảm yêu thương trong hoạn nạn... Sự xuất hiện của nhiều nhân vật bí ẩn khiến cho quan hệ giữa mọi người rất phức tạp. Và khi thân phận của cậu bé sơ sinh dần được hé lộ cũng là lúc tiếng chuông tử thần vang lên...mở màn cho những cuộc chiến thanh trừng đẫm máu tranh giành quyền lực nơi cung cấm. Liệu tình cảm sâu nặng và cơ duyên trùng hợp có giữ cho Thường Lục và Nhị Hồng được bình yên bên nhau mãi mãi? Hay chỉ như Hoa Bỉ Ngạn – loài hoa duy nhất nở rộ trên đường Hoàng Tuyền. Khi hoa nở thì không có lá, khi có lá thì hoa không nở. Hoa và lá luôn luôn không gặp nhau...</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/dao-kiem-luu-tinh.json","tmdb_checked":false}