trẻ đặc biệt là Đường Yên. Cô được khán giả Hoa Ngữ hết lời khen ngợi bởi tạo hình mới với vai nữ chính cá tính có diễn xuất ấn tượng. Đường Yên được chọn vào vai nữ chính – một nữ thám hiểm vô cùng khôn ngoan, giỏi giang và đầy bản lĩnh; cô trở thành một đối thủ nặng ký với nam chính Ngô Tà do Lý Dịch Phong thủ vai trong hành trình tìm kiếm mộ cổ. Vấn đề về nguyên bản Đạo Mộ Bút Ký cũng được khán giả quan tâm một cách đặc biệt và tỏ rõ quan điểm rằng không muốn Nam Phái Tam Phúc và đơn vị sản xuất Hoan Thụy Thế Kỷ thổi luồng gió mới vào tá phẩm và biến nó thành một tác phẩm sến sẩm. Tác giả tiểu thuyết và đơn vị sản xuất cũng đã hứa hẹn sẽ luôn tôn trọng khán giả và nội dung Đạo Mộ Bút Ký cũng sẽ bám sát tác phẩm gốc.","tmdb":{"type":"tv","id":"64592","season":1,"vote_average":6.333,"vote_count":18},"modified":"2025-05-31T21:26:46.000Z","cast":["Lý Dịch Phong","Đường Yên","Dương Dương","Liu Tianzuo","Trương Tấn","Wei Wei","Sun Yaoqi","Leon Lee","Dĩnh Nhi","Trình Phối Phối","Zhang Xiaochen","Huang Youming"],"director":["Soi Cheang"],"cast_meta":[{"name":"Lý Dịch Phong","name_vi":"Lý Dịch Phong","name_original":"Li Yifeng","tmdb_id":1377674,"profile":"https://image.tmdb.org/t/p/w500/c3ia1FsY5pqcqRQ7EskiWMMbkHc.jpg","tmdb_url":"https://www.themoviedb.org/person/1377674"},{"name":"Đường Yên","name_vi":"Đường Yên","name_original":"Tang Yan","tmdb_id":99691,"profile":"https://image.tmdb.org/t/p/w500/eW3F16Namf5EoCmeWaTdkd3ncoH.jpg","tmdb_url":"https://www.themoviedb.org/person/99691"},{"name":"Dương Dương","name_vi":"Dương Dương","name_original":"Yang Yang","tmdb_id":1635792,"profile":"https://image.tmdb.org/t/p/w500/lEBuoN1XItYMLpgsMmtORrEx1BY.jpg","tmdb_url":"https://www.themoviedb.org/person/1635792"},{"name":"Liu Tianzuo","name_vi":null,"name_original":"Liu Tianzuo","tmdb_id":589906,"profile":"https://image.tmdb.org/t/p/w500/5cR0QsAcKUUpXOjiRrpim4Cv0sM.jpg","tmdb_url":"https://www.themoviedb.org/person/589906"},{"name":"Trương Tấn","name_vi":"Trương Tấn","name_origin