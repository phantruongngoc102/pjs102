opstream-short.com/20251102/6919_b670dfc5/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream-short.com/share/659b7b42e9c002ce0075077cd55a1623","link_m3u8":"https://vip.opstream-short.com/20251102/6920_659b7b42/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream-short.com/share/39e98420b5e98bfbdc8a619bef7b8f61","link_m3u8":"https://vip.opstream-short.com/20251102/6921_39e98420/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream-short.com/share/29fdff891569187da8e5ed4f7a6ea4c8","link_m3u8":"https://vip.opstream-short.com/20251102/6922_29fdff89/index.m3u8"}]}],"description":"Bộ phim kể về câu chuyện của Tân Di, một chàng trai trẻ sống trên núi cùng sư phụ. Khi đến Giang Châu, anh tìm kiếm manh mối từ năm hôn thư mà sư phụ để lại để khám phá bí ẩn về thân世 của mình. Mặc dù liên tục đối mặt với những mối đe dọa từ kẻ xấu, anh không bao giờ từ bỏ việc khám phá dũng cảm. Qua nhiều thử thách, Tân Di trưởng thành từ một cậu bé nghịch ngợm thành một chàng trai có trách nhiệm. Câu chuyện cho thấy ngay cả những người bình thường cũng có thể đấu tranh cho công lý bằng lòng tốt và sự trung thực, đánh bại những âm mưu xấu xa và chứng minh rằng điều tốt luôn chiến thắng điều xấu. Thông qua tinh thần khám phá kiên trì, bộ phim trình bày các chủ đề về hy sinh, trưởng thành và cứu rỗi. Nó thể hiện đầy đủ những đức tính truyền thống của người Trung Quốc và ý thức thức tỉnh của họ. Trong mỗi âm mưu, dù sinh ra trong vùng hoang dã, Tân Di không bao giờ ngừng tìm kiếm sự thật và giúp đỡ người khác, mang lại cảm hứng, sự chữa lành, hy vọng và cảm giác về di sản.","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/dao-si-xuong-nui-nam-hon-thu-short-drama.json"}