ip.opstream14.com/20220521/12295_938c12c9/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream14.com/share/ef0e27f5a8bf73583a680da7f20ef5e9","link_m3u8":"https://vip.opstream14.com/20220527/12904_59551d43/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream14.com/share/e2e1cbe72ab1192e395c35295763982a","link_m3u8":"https://vip.opstream14.com/20220603/13380_d538dcaf/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream14.com/share/f29e862f7307c4eb635b0bb98fdbaf60","link_m3u8":"https://vip.opstream14.com/20220610/13932_60efdf0b/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream14.com/share/fb50ef2594daff9dd6322cbb5489bcbc","link_m3u8":"https://vip.opstream14.com/20220617/14827_a42f07e2/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream14.com/share/d4f457bca5d92483c063b48d7a33b36b","link_m3u8":"https://vip.opstream14.com/20220624/15503_d4ca8dc6/index.m3u8"}]}],"description":"<p>Phần 4 của loạt anime Date A Live. Tinh linh thứ chín (thực ra là thứ hai) Honjou Nia sở hữu một cuốn sách (hay cũng chính là thiên sứ của cô) tên Rasiel cho phép cô có được thông tin về bất cứ điều gì từng xảy ra trên thế giới, bất kể địa điểm hay thời gian. Nhờ khả năng này, Nia khám phá ra sự thật về nguồn gốc của chính mình, cũng như biết được mọi thứ về những người cô gặp, kể cả động cơ hay ác ý bên trong họ. Mất niềm tin vào nhân loại, Nia rơi vào tình yêu với thế giới manga và trò chơi điện tử. Cô trở thành mangaka, tự cô lập bản thân, giấu mình sau một lớp mặt nạ và vờ như mọi người chỉ là NPC trong một trò chơi. Cô đã bị DEM phát hiện ra là Tinh linh và cử Ellen Mira Mathers đến bắt sống.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/date-a-live-iv.json","tmdb_checked":false}