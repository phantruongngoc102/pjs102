m người chị bị mất tích trong cuộc tấn công của Nergal, Lý Tinh Lan đã tình nguyện tham gia vào đơn vị AG ở đầu chiến tuyến.</p>","tmdb":{"type":"tv","id":"135691","season":1,"vote_average":4.6,"vote_count":5},"modified":"2025-06-06T11:15:15.000Z","cast":["Shan Xin","Shuang Zhao","Meme Yan","Ye Zhiqiu","Yang Ning","Yeqiao Yan"],"director":[],"cast_meta":[{"name":"Shan Xin","name_vi":null,"name_original":"Shan Xin","tmdb_id":1907244,"profile":"https://image.tmdb.org/t/p/w500/fm3Hpzr4Fb8g43Oo8TvDfv7O3O1.jpg","tmdb_url":"https://www.themoviedb.org/person/1907244"},{"name":"Shuang Zhao","name_vi":null,"name_original":"Shuang Zhao","tmdb_id":2541123,"profile":"https://image.tmdb.org/t/p/w500/i2o0fZgnN0gHQ9UOQXYPCOcY2IV.jpg","tmdb_url":"https://www.themoviedb.org/person/2541123"},{"name":"Meme Yan","name_vi":null,"name_original":"Meme Yan","tmdb_id":2156554,"profile":"https://image.tmdb.org/t/p/w500/8Gf8Ji8CKJ3lhnKlnYM2ZpDOIXy.jpg","tmdb_url":"https://www.themoviedb.org/person/2156554"},{"name":"Ye Zhiqiu","name_vi":null,"name_original":"Ye Zhiqiu","tmdb_id":2156491,"profile":"https://image.tmdb.org/t/p/w500/eqdPGpXF9cb98Ft80xRdA83G2An.jpg","tmdb_url":"https://www.themoviedb.org/person/2156491"},{"name":"Yang Ning","name_vi":null,"name_original":"Yang Ning","tmdb_id":2207400,"profile":"https://image.tmdb.org/t/p/w500/8km0tWsz1qVMsMrc2ZAs7z0LxZl.jpg","tmdb_url":"https://www.themoviedb.org/person/2207400"},{"name":"Yeqiao Yan","name_vi":null,"name_original":"Yeqiao Yan","tmdb_id":2156562,"profile":"https://image.tmdb.org/t/p/w500/b8tvMttp6YnaVV9hBn2codIHHSI.jpg","tmdb_url":"https://www.themoviedb.org/person/2156562"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/da/dau-than-co.json"}