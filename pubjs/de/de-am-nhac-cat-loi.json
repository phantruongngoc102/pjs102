ream12.com/20220302/2404_3ead8ba3/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/bd7db7397f7d83052f829816ecc7f004","link_m3u8":"https://vip.opstream12.com/20220302/2403_33c2deca/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/b3f61131b6eceeb2b14835fa648a48ff","link_m3u8":"https://vip.opstream12.com/20220302/2409_3c630cb2/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/7cac11e2f46ed46c339ec3d569853759","link_m3u8":"https://vip.opstream12.com/20220302/2408_34a2ed7c/index.m3u8"}]}],"description":"<p>Để âm nhạc cất lời kể về câu chuyện cuộc sống, tình yêu của bốn chàng trai cô gái. Họ bắt đầu các mối quan hệ của mình thông qua âm nhạc. Một vụ án mạng xảy ra, Yi Young là người có liên quan nhưng cô lại không nhớ bất kỳ một điều gì nên việc tìm kiếm thủ phạm thực sự rất khó khăn. Cô bị chứng mất ngủ và luôn bị làm phiền bởi những tiếng ồn nhỏ nhất. Một ngày, Yi Young gặp được chàng nghệ sĩ piano Jang Youn, tuy tài năng nhưng anh lại có giọng hát rất dở khiến con đường sự nghiệp trở nên khó khăn. Để điều trị chứng mất ngủ cho Yi Young, anh gọi điện đến cho cô mỗi tối và cố gắng tìm ra sự thật về vụ giết người.</p>","tmdb_id":90237,"cast":[],"director":[],"keywords":[],"tmdb":{"id":90237},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/de/de-am-nhac-cat-loi.json"}