ời chị em khác của Yggdrasil. Với lòng tốt bẩm sinh và lòng dũng cảm mới tìm thấy, Ein vượt qua vô số thử thách trên con đường của mình.</p>","tmdb_id":270474,"cast":["Kikunosuke Toya","Hikaru Tono","Sayumi Suzushiro","Yu Serizawa","Minami Tsuda","Kana Ichinose","Aimi","Takeo Otsuka","Daisuke Namikawa","Kana Hanazawa"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"270474","season":1,"vote_average":6.789,"vote_count":45},"cast_meta":[{"name":"Kikunosuke Toya","name_vi":null,"name_original":"Kikunosuke Toya","tmdb_id":3651176,"profile":"https://image.tmdb.org/t/p/w500/tSAHe7tjN7luUD1Tx5yPSCuCnuD.jpg","tmdb_url":"https://www.themoviedb.org/person/3651176"},{"name":"Hikaru Tono","name_vi":null,"name_original":"Hikaru Tono","tmdb_id":2431912,"profile":"https://image.tmdb.org/t/p/w500/mQ3BgehaQKedMbMkpnlz790U4fi.jpg","tmdb_url":"https://www.themoviedb.org/person/2431912"},{"name":"Sayumi Suzushiro","name_vi":null,"name_original":"Sayumi Suzushiro","tmdb_id":2206133,"profile":"https://image.tmdb.org/t/p/w500/7wEX0bXCs2djnp0dKsCqmMKZpZV.jpg","tmdb_url":"https://www.themoviedb.org/person/2206133"},{"name":"Yu Serizawa","name_vi":null,"name_original":"Yu Serizawa","tmdb_id":1356201,"profile":"https://image.tmdb.org/t/p/w500/mQITB0XYHCZjYef39xsHnSHIH56.jpg","tmdb_url":"https://www.themoviedb.org/person/1356201"},{"name":"Minami Tsuda","name_vi":null,"name_original":"Minami Tsuda","tmdb_id":1307031,"profile":"https://image.tmdb.org/t/p/w500/r23Dp350O0KnPSY0i7uBVSTYzpG.jpg","tmdb_url":"https://www.themoviedb.org/person/1307031"},{"name":"Kana Ichinose","name_vi":null,"name_original":"Kana Ichinose","tmdb_id":1972402,"profile":"https://image.tmdb.org/t/p/w500/hBJx5tpLA2vkXqfkPZosGjW4e8C.jpg","tmdb_url":"https://www.themoviedb.org/person/1972402"},{"name":"Aimi","name_vi":null,"name_original":"Aimi","tmdb_id":1950099,"profile":"https://image.tmdb.org/t/p/w500/9mk1CHBZDmY2hh9BT5gb7yDMsQY.jpg","tmdb_url":"https://www.themoviedb.org/person/1950099"},{"name":"Takeo Otsuka","na