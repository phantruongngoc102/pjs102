ân loại. Để tồn tại, Tris bị buộc phải lựa chọn giữa lòng dũng cảm, lòng trung thành, sự hy sinh và tình yêu.</p>","tmdb_id":262504,"cast":["Shailene Woodley","Theo James","Miles Teller","Zoë Kravitz","Naomi Watts","Jeff Daniels","Ansel Elgort","Octavia Spencer","Keiynan Lonsdale","Daniel Dae Kim","Maggie Q","Bình Sẹo","Jonny Weston","Nadia Hilker","Andy Bean"],"director":["Robert Schwentke"],"keywords":["based on novel or book","revolution","dystopia","sequel","transhumanism","vaccination","based on young adult novel","mass surveillance","smart city"],"cast_meta":[{"name":"Shailene Woodley","name_vi":null,"name_original":"Shailene Woodley","tmdb_id":94185,"profile":"https://image.tmdb.org/t/p/w500/tqNlTcDxDFQOQi0GpEtx0lqQyWt.jpg","tmdb_url":"https://www.themoviedb.org/person/94185"},{"name":"Theo James","name_vi":null,"name_original":"Theo James","tmdb_id":587020,"profile":"https://image.tmdb.org/t/p/w500/lSC4cMhcQeCjPFkK6qCjSGDSeR3.jpg","tmdb_url":"https://www.themoviedb.org/person/587020"},{"name":"Miles Teller","name_vi":null,"name_original":"Miles Teller","tmdb_id":996701,"profile":"https://image.tmdb.org/t/p/w500/aciu7YM8fD0BzrrA6cJ5wDKZIA6.jpg","tmdb_url":"https://www.themoviedb.org/person/996701"},{"name":"Zoë Kravitz","name_vi":null,"name_original":"Zoë Kravitz","tmdb_id":37153,"profile":"https://image.tmdb.org/t/p/w500/hJKmhbuzDjmfw2nPBDWGbLagj16.jpg","tmdb_url":"https://www.themoviedb.org/person/37153"},{"name":"Naomi Watts","name_vi":null,"name_original":"Naomi Watts","tmdb_id":3489,"profile":"https://image.tmdb.org/t/p/w500/5s6UE6VjYx5TBDvyFk4vfOdS9GR.jpg","tmdb_url":"https://www.themoviedb.org/person/3489"},{"name":"Jeff Daniels","name_vi":null,"name_original":"Jeff Daniels","tmdb_id":8447,"profile":"https://image.tmdb.org/t/p/w500/r0mkZJZnTSJO3HJRsMW5HtszxE8.jpg","tmdb_url":"https://www.themoviedb.org/person/8447"},{"name":"Ansel Elgort","name_vi":null,"name_original":"Ansel Elgort","tmdb_id":1159982,"profile":"https://image.tmdb.org/t/p/w500/pbU6qz8e