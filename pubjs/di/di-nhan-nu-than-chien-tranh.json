 vực. Vào thời điểm quan trọng, tỷ lệ dung hợp gen của Ngô Thanh Thanh đã vượt quá 50%, và cô ấy có một tốc độ kỳ lạ tương đương với một \\\"con quỷ\\</p>","tmdb":{"type":"movie","id":"1028725","season":null,"vote_average":5.393,"vote_count":56},"modified":"2022-10-11T01:14:35.000Z","cast":["Mẫu Kỳ Di Nhã","Li Mingxuan","Liu Beige","Cui Zhenzhen","Mou Fengbin","Shang Na","Zeng Youzhen","Guo Ziheng","Qingyun Hu"],"director":["Liu Bin Jie"],"cast_meta":[{"name":"Mẫu Kỳ Di Nhã","name_vi":"Mẫu Kỳ Di Nhã","name_original":"Miya Muqi","tmdb_id":1764717,"profile":"https://image.tmdb.org/t/p/w500/bRnt4FwvIFLXcIBdnZJmUnjbnxj.jpg","tmdb_url":"https://www.themoviedb.org/person/1764717"},{"name":"Li Mingxuan","name_vi":null,"name_original":"Li Mingxuan","tmdb_id":2730674,"profile":"https://image.tmdb.org/t/p/w500/v8xr5Ji0ucHDyAyPLcbI8RFevJg.jpg","tmdb_url":"https://www.themoviedb.org/person/2730674"},{"name":"Liu Beige","name_vi":null,"name_original":"Liu Beige","tmdb_id":2506115,"profile":"https://image.tmdb.org/t/p/w500/m1b9M0yIgWyhKkAYn6eJatsQvgY.jpg","tmdb_url":"https://www.themoviedb.org/person/2506115"},{"name":"Cui Zhenzhen","name_vi":null,"name_original":"Cui Zhenzhen","tmdb_id":2317138,"profile":"https://image.tmdb.org/t/p/w500/sc3dJLeKh8Wkb3Ka27Sih7m5Kbu.jpg","tmdb_url":"https://www.themoviedb.org/person/2317138"},{"name":"Mou Fengbin","name_vi":null,"name_original":"Mou Fengbin","tmdb_id":2317761,"profile":"https://image.tmdb.org/t/p/w500/htAJ7V22MjC56HwHggUCcBKrks7.jpg","tmdb_url":"https://www.themoviedb.org/person/2317761"},{"name":"Shang Na","name_vi":null,"name_original":"Shang Na","tmdb_id":3826613,"profile":"https://image.tmdb.org/t/p/w500/ioUraH2AahGD8NfrpDmnSc8zExS.jpg","tmdb_url":"https://www.themoviedb.org/person/3826613"},{"name":"Zeng Youzhen","name_vi":null,"name_original":"Zeng Youzhen","tmdb_id":3303296,"profile":"https://image.tmdb.org/t/p/w500/m0Cw1LDKXmAMLgsvi5bUxxlDZgh.jpg","tmdb_url":"https://www.themoviedb.org/person/3303296"},{"name":"Guo Ziheng"