":"https://vip.opstream15.com/share/6d80b1c2a094e276f2b422475d8fa5be","link_m3u8":"https://vip.opstream15.com/20220530/17309_873970d7/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream15.com/share/61d8c968f0a66dcf2b05982bdccb484b","link_m3u8":"https://vip.opstream15.com/20220530/17311_e200ef22/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/3057aa0acb6d937295819f3d94f015e9","link_m3u8":"https://vip.opstream15.com/20220530/17313_67660b08/index.m3u8"}]}],"description":"<p>Phim Điện Hạ Đại Nhân Chọc Không Nổi hay Chọc Phải Điện Hạ Lạnh Lùng Phần 2 – To Get Her tập trung chuyện tình thanh mai trúc mã giữa Đồ Tư Dập và Lâm Tranh Tranh ở thời cổ đại. Cụ thể, Đồ Tư Dập là thần tượng đang hot, được làm đại diện phát ngôn của một game cổ đại. Chuyện ngoài ý muốn bất ngờ xảy ra khiến anh biến thành nam chủ Tam Vương Tử trong chính loại game này. Vì để cứu vãn bạn trai, Lâm Tranh Tranh từ người chơi cũng tiến vào game, lúc này cô phát hiện mình là Tam Vương Phi, chỉ có 3 mạng cơ hội thực hiện nhiệm vụ giúp Đồ Tư Dập giành lấy ngai vàng. Tuy nhiên, Đồ Tư Dập lại bị hệ thống game xoá hết trí nhớ, anh chỉ còn niềm đam mê âm nhạc vốn đã ăn sâu trong tiềm thức. Mỗi người một nhiệm vụ, một đam mê khác nhau nên bắt đầu xảy ra đấu trí kết oan gia, trải qua nhiều biến động họ lần nữa tìm thấy cảm giác tình yêu của chính mình. Đảm nhận vai chính trong phần 2 này không phải là Quách Tuấn Thần – Tôn Nghệ Ninh mà là nam người mẫu điển trai Đường Hiểu Thiên và cô nàng xinh đẹp Hoàng Nhật Oánh.</p>","tmdb_id":96605,"cast":["Pan Leiyi","Đường Hiểu Thiên","Hoàng Nhật Oánh","Lu Yunfeng","Lin Fengsong","Kenji Chen","Teng Yufei","Liu Ziye","Tăng Khả Ny","Wang Xingchen"],"director":["Zhong Qing"],"keywords":[],"tmdb":{"type":"tv","id":"96605","season":1,"vote_average":6.8,"vote_count":5},"cast_meta":[{"name":"Pan Leiyi","name_vi":null,"name_original":"Pan Leiyi","tmdb_id":3148081,"profile":"https://image.tmdb.org/t/p/w500/vYfCBgk6CLxAtfMWm