2323_8d66c162/index.m3u8"},{"name":"24","slug":"24","filename":"TVB Điện Hạ Ma Mãnh tập 24","link_embed":"https://vip.opstream11.com/share/53d15057a8e24f26ce9cb71c90ee7be7","link_m3u8":"https://vip.opstream11.com/20230204/42324_26fdc8af/index.m3u8"},{"name":"25","slug":"25","filename":"TVB Điện Hạ Ma Mãnh tập 25","link_embed":"https://vip.opstream11.com/share/bf5a72f10c8a5910f76537e4a7ed07dc","link_m3u8":"https://vip.opstream11.com/20230204/42325_caaefa40/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Hài hước cổ trang nói về Tứ hoàng tử nước Bách Thắng - Kỷ Uy (do Châu Gia Lạc đóng). Hoàng tử không biết võ công, lại mắc bệnh suyễn nên không được hoàng đế Kỷ Huỳnh (do Đỗ Yến Ca đóng) thương yêu. Nhằm tạo quan hệ bang giao giữa hai nước, Kỷ Uy bị ép thành thân với công chúa nước Ca Liên Thần là Nạp Khắc Ôn Nhu (do Trần Oánh đóng). Do Ca Liên Thần là một nước xem trọng nữ quyền nên công chúa giỏi võ công Ôn Nhu không muốn gả cho hoàng tử yếu ớt Kỷ Uy. Công chúa muốn giết hoàng tử, nào ngờ cả hai rơi xuống biển và mất hết trí nhớ. Họ cùng lưu lạc đến Thủ Chấn trấn – một nơi nằm giữa bảy nước không pháp kỷ. Nhờ sự thông minh và khứu giác nhạy bén nên Kỷ Uy được Tiêu cục Dịch Phong trọng dụng. Đại đương gia Cầu Dũng (do Ngô Đại Dung đóng) và Nhị đương gia Hoắc Thanh Sơn (do Tào Vĩnh Liêm đóng) thu nhận Kỷ Uy và Ôn Nhu. Con gái Thanh Sơn là Hoắc Tiểu Muội (do Vương Hạo Nhi đóng) tìm mọi cách chữa bệnh mất trí nhớ cho Uy và Nhu. Trong khi đó, Uy lại đắc tội với hai con nuôi của Cầu Dũng là Phạm Tráng Long (do Trương Dĩnh Khang đóng) và Cầu Thiên Đao (do Chu Mẫn Hãn đóng).</p>","tmdb":{"type":"tv","id":"207179","season":1,"vote_average":0,"vote_count":0},"modified":"2025-04-17T12:45:42.000Z","cast":["Châu Gia Lạc","Trần Oánh","Ngô Đại Dung","Tào Vĩnh Liêm","Chu Mẫn Hãn","Vương Tổ Hiền","Mayanne Mak","Vi Gia Hùng","To Yin-Gor","Derek Wong","Wong Ka-Lok","Sunny Tai Yiu-Ming","Helen Ma Hoi-Lun","May Chan","Frankie Choi"],"director":["Trần Duy Toàn"],"cast_meta":[{"name