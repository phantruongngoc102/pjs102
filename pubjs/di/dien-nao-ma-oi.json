nk_embed":"https://vip.opstream11.com/share/f70576b9278d9a5c4814046749627269","link_m3u8":"https://vip.opstream11.com/20220523/26106_db2d7be5/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>Diễn Nào, Ma Ơi! - From Now On, Showtime! là phim hài lãng mạn giả tưởng về một pháp sư và một nữ cảnh sát. Park Hae Jin vào vai nam chính Cha Cha Woong, một pháp sư lôi cuốn, người có khả năng nhìn thấy và điều khiển các hồn ma. Jin Ki Joo vào vai nữ chính Go Seul Hae, một cảnh sát đầy nhiệt huyết nhưng bí ẩn. Với mục tiêu gia nhập bộ phận tội phạm, Go Seul Hae rất hăng say trong công việc. Khi cô tham gia với pháp sư Cha Cha Woong, một câu chuyện thú vị sẽ bắt đầu mở ra.</p>","tmdb":{"type":"tv","id":"194820","season":1,"vote_average":7.6,"vote_count":35},"modified":"2022-05-23T11:03:19.000Z","cast":["Park Hae-jin","Jin Ki-joo","Ko Kyu-pil","Jung Jun-ho","Kim Hee-jae","Jeong Seok-yong","Jang Ha-eun","Cha Mi-kyeong","Park Seo-yeon","Kim Jong-hoon","Ha Sung-kwang","Choi Seong-won","Shin Hyun-jun","Oh Ye-ju","Yoon Sang-ah"],"director":["Lee Hyung Min"],"cast_meta":[{"name":"Park Hae-jin","name_vi":null,"name_original":"Park Hae-jin","tmdb_id":1244834,"profile":"https://image.tmdb.org/t/p/w500/hiSahEWd1VH0UXgFpZlMLqaS8JG.jpg","tmdb_url":"https://www.themoviedb.org/person/1244834"},{"name":"Jin Ki-joo","name_vi":null,"name_original":"Jin Ki-joo","tmdb_id":1564175,"profile":"https://image.tmdb.org/t/p/w500/xwhR8nrFKxalOjmADxJPTouxE0g.jpg","tmdb_url":"https://www.themoviedb.org/person/1564175"},{"name":"Ko Kyu-pil","name_vi":null,"name_original":"Ko Kyu-pil","tmdb_id":1574622,"profile":"https://image.tmdb.org/t/p/w500/uP18ldneBx5WcmHmvwoyGVSBArY.jpg","tmdb_url":"https://www.themoviedb.org/person/1574622"},{"name":"Jung Jun-ho","name_vi":null,"name_original":"Jung Jun-ho","tmdb_id":84854,"profile":"https://image.tmdb.org/t/p/w500/nWvJeFnFQYfh2M8LbRsb2AUUSda.jpg","tmdb_url":"https://www.themoviedb.org/person/84854"},{"name":"Kim Hee-jae","name_vi":null,"name_original":"Kim Hee-ja