/vip.opstream13.com/20251020/13036_91cf0815/index.m3u8"}]}],"description":"<p>Năm 1941, dưới sự chiếm đóng của Nhật Bản, Thượng Hải trở thành trung tâm của một chiến dịch bí mật nhằm tràn ngập Trung Quốc bằng tiền giả và cướp bóc các kho tàng văn hóa. Hai thủ lĩnh kháng chiến ngầm Ngụy Đại Hồng và Lâm Thu Nhạn bắt tay vào một nhiệm vụ bí mật để ngăn chặn âm mưu này. Trên đường đi, họ hợp tác với một nhóm đồng minh trẻ tuổi, bất chấp mọi nguy hiểm để bảo vệ quê hương.</p>","tmdb_id":222714,"cast":["Yue Feng","Ngụy Đại Huân","Daniel Chen","He Ziming","Xuesong Lin","Tian Luhan","Li Honglei","Li Bin"],"director":["Wang Lixing"],"keywords":[],"tmdb":{"type":"tv","id":"222714","season":1,"vote_average":5,"vote_count":1},"cast_meta":[{"name":"Yue Feng","name_vi":null,"name_original":"Yue Feng","tmdb_id":3345844,"profile":"https://image.tmdb.org/t/p/w500/8239xx5RzHV282jyEgIrFNYSpSu.jpg","tmdb_url":"https://www.themoviedb.org/person/3345844"},{"name":"Ngụy Đại Huân","name_vi":"Ngụy Đại Huân","name_original":"Wei Daxun","tmdb_id":1712691,"profile":"https://image.tmdb.org/t/p/w500/8zDh8Tp6xbVSpxr307alnGqUiJP.jpg","tmdb_url":"https://www.themoviedb.org/person/1712691"},{"name":"Daniel Chen","name_vi":null,"name_original":"Daniel Chen","tmdb_id":3227744,"profile":"https://image.tmdb.org/t/p/w500/cCWVFdEzon4aAy6hZwnxjHbZlpr.jpg","tmdb_url":"https://www.themoviedb.org/person/3227744"},{"name":"He Ziming","name_vi":null,"name_original":"He Ziming","tmdb_id":1671010,"profile":"https://image.tmdb.org/t/p/w500/yh7CS770lyowIDMgNtPF10q8zps.jpg","tmdb_url":"https://www.themoviedb.org/person/1671010"},{"name":"Xuesong Lin","name_vi":null,"name_original":"Xuesong Lin","tmdb_id":2659152,"profile":"https://image.tmdb.org/t/p/w500/bL2irfk3z81ckbPKDYAii9jMAKR.jpg","tmdb_url":"https://www.themoviedb.org/person/2659152"},{"name":"Tian Luhan","name_vi":null,"name_original":"Tian Luhan","tmdb_id":3316044,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3316044"},{"name":"Li Honglei","n