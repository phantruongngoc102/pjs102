 ấy ra sao và liệu còn có rắc rối nào đang chờ anh phía trước?","tmdb":{"type":"movie","id":"416249","season":null,"vote_average":6.232,"vote_count":114},"modified":"2023-06-12T11:00:02.000Z","cast":["Quách Phú Thành","Lương Gia Huy","Châu Nhuận Phát","Dương Thái Ni","Văn Vịnh San","Bành Vu Yến","Lý Trị Đình","Dương Hựu Ninh","Chang Kuo-Chu","Ngô Việt","Lâm Văn Long","Zhou Bichang","Trần Oánh","Huỳnh Đức Bân","Ram Chiang Chi-Kwong"],"director":["Leung Lok-man","Sunny Luk Kim-Ching"],"cast_meta":[{"name":"Quách Phú Thành","name_vi":"Quách Phú Thành","name_original":"Aaron Kwok","tmdb_id":21908,"profile":"https://image.tmdb.org/t/p/w500/haCdKHKCBle20HkbHCapfYTibc0.jpg","tmdb_url":"https://www.themoviedb.org/person/21908"},{"name":"Lương Gia Huy","name_vi":"Lương Gia Huy","name_original":"Tony Leung Ka-fai","tmdb_id":56861,"profile":"https://image.tmdb.org/t/p/w500/il4L0QSp5STfZCB1wsvb6rSCDar.jpg","tmdb_url":"https://www.themoviedb.org/person/56861"},{"name":"Châu Nhuận Phát","name_vi":"Châu Nhuận Phát","name_original":"Chow Yun-Fat","tmdb_id":1619,"profile":"https://image.tmdb.org/t/p/w500/uDPYSiZrW7OZ79qgcgkWefALlXY.jpg","tmdb_url":"https://www.themoviedb.org/person/1619"},{"name":"Dương Thái Ni","name_vi":"Dương Thái Ni","name_original":"Charlie Yeung Choi-Nei","tmdb_id":66762,"profile":"https://image.tmdb.org/t/p/w500/7clzAMBYr56NAIU7W2KGnGe5a5V.jpg","tmdb_url":"https://www.themoviedb.org/person/66762"},{"name":"Văn Vịnh San","name_vi":"Văn Vịnh San","name_original":"Janice Man Wing-San","tmdb_id":78253,"profile":"https://image.tmdb.org/t/p/w500/h7UKw1U1JQnROUO3mOCrXdDeiKL.jpg","tmdb_url":"https://www.themoviedb.org/person/78253"},{"name":"Bành Vu Yến","name_vi":"Bành Vu Yến","name_original":"Eddie Peng Yu-Yan","tmdb_id":126778,"profile":"https://image.tmdb.org/t/p/w500/gIiEFUVbGRwrLKUURxU67ShJ00o.jpg","tmdb_url":"https://www.themoviedb.org/person/126778"},{"name":"Lý Trị Đình","name_vi":"Lý Trị Đình","name_original":"Aarif Rahman","tmdb_id":148881,"profile":"https