vai. Lúc đầu, khi chưa biết đối thủ của mình thế nào, 2 người chiến đấu giống như một sống một còn nhưng chính những lần đối đầu đó khiến 2 người hiểu nhau hơn và dần dần trở thành cặp đôi hoàn hảo.</p>","tmdb":{"type":"movie","id":"419544","season":null,"vote_average":5.8,"vote_count":15},"modified":"2023-08-16T13:46:34.000Z","cast":["Lưu Đức Hoa","Huỳnh Hiểu Minh","Trịnh Tú Văn","Michelle Hu","Âu Dương Na Na","Vương Tổ Lam","Tạ Y Lâm","Philippe Joly","Sean Tierney","Ngô Việt","Teng Shen","Petrina Fung Bo-Bo","Lô Huệ Quang","Lâm Địch An","Từ Đông Đông"],"director":["Wong Jing"],"cast_meta":[{"name":"Lưu Đức Hoa","name_vi":"Lưu Đức Hoa","name_original":"Andy Lau","tmdb_id":25246,"profile":"https://image.tmdb.org/t/p/w500/z9R2yerjfgxwDWIH8sjiS0hhcre.jpg","tmdb_url":"https://www.themoviedb.org/person/25246"},{"name":"Huỳnh Hiểu Minh","name_vi":"Huỳnh Hiểu Minh","name_original":"Huang Xiaoming","tmdb_id":109434,"profile":"https://image.tmdb.org/t/p/w500/pnSbq1pNDb0uLkzGOJ8zy7piBvb.jpg","tmdb_url":"https://www.themoviedb.org/person/109434"},{"name":"Trịnh Tú Văn","name_vi":"Trịnh Tú Văn","name_original":"Sammi Cheng Sau-Man","tmdb_id":86318,"profile":"https://image.tmdb.org/t/p/w500/fecOHFVJC0R16aSraJmULaHV6hx.jpg","tmdb_url":"https://www.themoviedb.org/person/86318"},{"name":"Michelle Hu","name_vi":null,"name_original":"Michelle Hu","tmdb_id":1209782,"profile":"https://image.tmdb.org/t/p/w500/oNwNoLJg707G0HSIDnNU4mpaoIu.jpg","tmdb_url":"https://www.themoviedb.org/person/1209782"},{"name":"Âu Dương Na Na","name_vi":"Âu Dương Na Na","name_original":"Ouyang Nana","tmdb_id":1798832,"profile":"https://image.tmdb.org/t/p/w500/l5HZTypx62unYrySDuWlPabWhUs.jpg","tmdb_url":"https://www.themoviedb.org/person/1798832"},{"name":"Vương Tổ Lam","name_vi":"Vương Tổ Lam","name_original":"Wong Cho-Lam","tmdb_id":126807,"profile":"https://image.tmdb.org/t/p/w500/OtRzs4VUqcLlIJncm6SZ3UeI2d.jpg","tmdb_url":"https://www.themoviedb.org/person/126807"},{"name":"Tạ Y Lâm","name_vi":"Tạ Y Lâm",