ug":"51","link_embed":"https://vip.opstream11.com/share/9cdb4000a2c0e308cd60aaa1cc1255e8","link_m3u8":"https://vip.opstream11.com/20221203/38871_7b8a1fdf/index.m3u8"}]}],"description":"<p>Takato Matsuda, Henry Wong, và Rika Nonaka là những đứa trẻ sở hữu Digimon thực sư bởi định mệnh, không giống như những lá bài ảo mà họ có. Mỗi đứa trẻ [còn gọi là Digimon Tamers - người huấn luyện Digimon] có cách nhìn khác nhau về việc đối xử với Digimon. Nhưng họ phải gạt vấn đề đó sang một bên để ngăn chặn các Digimon khác tiến vào xâm nhập Nhật Bản. Kể cả Yamaki, chỉ huy của tổ chức có tên Hypnos đang tìm cách tiêu diệt hết Digimon lẫn Digimon của cậu ta.</p>","tmdb_id":9302,"cast":["Makoto Tsumura","Masako Nozawa","Fumiko Orikasa","Yuka Imai","Mayumi Yamaguchi","Aoi Tada","Tomoko Kaneda","Yoko Asada"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"9302","season":1,"vote_average":8.551,"vote_count":361},"cast_meta":[{"name":"Makoto Tsumura","name_vi":null,"name_original":"Makoto Tsumura","tmdb_id":1222151,"profile":"https://image.tmdb.org/t/p/w500/81DYZwZ4M7Atf6w5Zk1e18QeIW8.jpg","tmdb_url":"https://www.themoviedb.org/person/1222151"},{"name":"Masako Nozawa","name_vi":null,"name_original":"Masako Nozawa","tmdb_id":90496,"profile":"https://image.tmdb.org/t/p/w500/jxbXdejmPoiKnNoQz7Dkb80qC26.jpg","tmdb_url":"https://www.themoviedb.org/person/90496"},{"name":"Fumiko Orikasa","name_vi":null,"name_original":"Fumiko Orikasa","tmdb_id":23988,"profile":"https://image.tmdb.org/t/p/w500/f5d1J13fksa1hK8u7AS95aO8b9.jpg","tmdb_url":"https://www.themoviedb.org/person/23988"},{"name":"Yuka Imai","name_vi":null,"name_original":"Yuka Imai","tmdb_id":1221862,"profile":"https://image.tmdb.org/t/p/w500/SivuDZuk3GsYVm9kYdSKcnQQ9I.jpg","tmdb_url":"https://www.themoviedb.org/person/1221862"},{"name":"Mayumi Yamaguchi","name_vi":null,"name_original":"Mayumi Yamaguchi","tmdb_id":568288,"profile":"https://image.tmdb.org/t/p/w500/uzkuXAZqQhbW03ELeLpmjcIzGpS.jpg","tmdb_url":"https://www.themoviedb