8b2b1dca","link_m3u8":"https://vip.opstream14.com/20221111/27896_e16a5a31/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream14.com/share/91a8651859745d25095a46fdda893cfa","link_m3u8":"https://vip.opstream14.com/20221111/27897_ebf01737/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream14.com/share/7577c54ea4b4258f50a4477dbd1bca3a","link_m3u8":"https://vip.opstream14.com/20221111/27898_599c56ee/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream14.com/share/f016401501ca83458fb6896609ea749e","link_m3u8":"https://vip.opstream14.com/20221111/27899_648de41d/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream14.com/share/5e18b53804c5a18b0d727b0cd8aff97c","link_m3u8":"https://vip.opstream14.com/20221111/27900_48e3215a/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream14.com/share/62ab3ce23f9884db423ce886eb945289","link_m3u8":"https://vip.opstream14.com/20221111/27901_24efabf4/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream14.com/share/fbf697a2b5eed2f138a85082a119b815","link_m3u8":"https://vip.opstream14.com/20221111/27902_ff777906/index.m3u8"}]}],"description":"<p>Phim kể về cuộc đời bà cụ nấu cháo từ thiện cho một bệnh viện Ung Bướu. Ngày xưa, bà là đào hát, thời thiếu nữ bà tên Mận, có hai người bạn thân là Hai Hoài và Tố Phụng gắn bó từ nhỏ. Mận có năng khiếu hát ca, còn Phụng diễn giỏi nhưng ca không được. Hai Hoài có tài thổi sáo và thẩm âm giỏi. Nhà nghèo, ba người bạn theo lớp học chữ của thầy giáo Việt, và thường nghe thầy nói nhiều tới gánh hát Đồng Nữ Ban. Ước mơ được theo gánh hát này, Mận rời quê đi tìm Đồng Nữ Ban. Thầy Việt có người dì lấy ông Phủ bên Vĩnh Long. Ông Phủ có người con trai duy nhất là Thê, do bà Vú Út- một người làm công trong nhà sinh ra. Khi Việt gặp Mận đang trôi dạt hát thuê hát mướn, thấy cô quá giống Vú Út nên đưa về làm việc ở nhà ông bà Phủ. Vì tiếng hát ngọt lịm, Mận khiến cho bá hộ Thê mê mẩn, quyết tâm lấy làm vợ ba. Cuộc đời cô ba chìm, bảy nổi theo nghiệp xướng ca, để rồi sau bao giông bão cuộc đời, trở về già, cô lại tìm sự bình yên với công việc từ thiện.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/do/doan-truong-nam-ai.json","tmdb_checked":false}