ôn nhân và bản thân.</p><p>&nbsp;</p>","tmdb_id":245500,"cast":["Bạch Bách Hà","Lý Thuần","Vương Ngọc Văn","Chen He","Vu Tiểu Vĩ","Zhang Tao","Đinh Dũng Đại","Liu Jia","Hạ Vũ","Thường Hoa Sâm"],"director":["Liu Dong"],"keywords":[],"tmdb":{"type":"tv","id":"245500","season":1,"vote_average":8.4,"vote_count":5},"cast_meta":[{"name":"Bạch Bách Hà","name_vi":"Bạch Bách Hà","name_original":"Bai Baihe","tmdb_id":588057,"profile":"https://image.tmdb.org/t/p/w500/4cEIvt6etPrWzXn59W5GgnijNIG.jpg","tmdb_url":"https://www.themoviedb.org/person/588057"},{"name":"Lý Thuần","name_vi":"Lý Thuần","name_original":"Li Chun","tmdb_id":1683309,"profile":"https://image.tmdb.org/t/p/w500/26Z1lcLUTtcqqwzKYPUqYKmD1h9.jpg","tmdb_url":"https://www.themoviedb.org/person/1683309"},{"name":"Vương Ngọc Văn","name_vi":"Vương Ngọc Văn","name_original":"Wang Yuwen","tmdb_id":1836775,"profile":"https://image.tmdb.org/t/p/w500/lVmpKpml6evG5gWciRELbgdhvII.jpg","tmdb_url":"https://www.themoviedb.org/person/1836775"},{"name":"Chen He","name_vi":null,"name_original":"Chen He","tmdb_id":1397016,"profile":"https://image.tmdb.org/t/p/w500/78V2SYzwekBQOK55F4CmFWTwk34.jpg","tmdb_url":"https://www.themoviedb.org/person/1397016"},{"name":"Vu Tiểu Vĩ","name_vi":"Vu Tiểu Vĩ","name_original":"Yu Jinwei","tmdb_id":1088253,"profile":"https://image.tmdb.org/t/p/w500/jCKIoARlOK7ngz9235ovAYbJB7U.jpg","tmdb_url":"https://www.themoviedb.org/person/1088253"},{"name":"Zhang Tao","name_vi":null,"name_original":"Zhang Tao","tmdb_id":2613633,"profile":"https://image.tmdb.org/t/p/w500/A2aWSvFriLZyXzAgCEp9S258bC6.jpg","tmdb_url":"https://www.themoviedb.org/person/2613633"},{"name":"Đinh Dũng Đại","name_vi":"Đinh Dũng Đại","name_original":"Ding Yongdai","tmdb_id":1194773,"profile":"https://image.tmdb.org/t/p/w500/hB1xrY9K0jwhWsbLEbsJl55h98T.jpg","tmdb_url":"https://www.themoviedb.org/person/1194773"},{"name":"Liu Jia","name_vi":null,"name_original":"Liu Jia","tmdb_id":2390143,"profile":"https://image.tmdb.org/t/p/w500/wcFTjV0Up