 lượt bị sát hại.</p>","tmdb_id":277519,"cast":["Cổ Thiên Lạc","Lâm Gia Đống","Trần Tĩnh","Xia Yan","Michael Wong","Lư Hải Bằng","Âu Cẩm Đường","Tăng Quốc Cường","Trương Triệu Huy","Lạc Ứng Quân","Liêu Khải Trí","Khương Hạo Văn","Tony Ho","Trương Tùng Chi","Clement Tin"],"director":["David Lam Tak-Luk"],"keywords":[],"cast_meta":[{"name":"Cổ Thiên Lạc","name_vi":"Cổ Thiên Lạc","name_original":"Louis Koo","tmdb_id":78875,"profile":"https://image.tmdb.org/t/p/w500/yQuDBTzm7xWlJICNvl20OmcJP80.jpg","tmdb_url":"https://www.themoviedb.org/person/78875"},{"name":"Lâm Gia Đống","name_vi":"Lâm Gia Đống","name_original":"Gordon Lam Ka-Tung","tmdb_id":83820,"profile":"https://image.tmdb.org/t/p/w500/61gQoVwgpd4qzovOaZjzJpdm47K.jpg","tmdb_url":"https://www.themoviedb.org/person/83820"},{"name":"Trần Tĩnh","name_vi":"Trần Tĩnh","name_original":"Dada Chan Ching","tmdb_id":1098628,"profile":"https://image.tmdb.org/t/p/w500/3qwf4oEX2GsQZgVTLdPMlbf2VDw.jpg","tmdb_url":"https://www.themoviedb.org/person/1098628"},{"name":"Xia Yan","name_vi":null,"name_original":"Xia Yan","tmdb_id":1334851,"profile":"https://image.tmdb.org/t/p/w500/3BA7cLJw1x52KV0uClsvf15L77w.jpg","tmdb_url":"https://www.themoviedb.org/person/1334851"},{"name":"Michael Wong","name_vi":null,"name_original":"Michael Wong","tmdb_id":64896,"profile":"https://image.tmdb.org/t/p/w500/k3iH4zPZ8faWEF5uJeiq7fTtg7p.jpg","tmdb_url":"https://www.themoviedb.org/person/64896"},{"name":"Lư Hải Bằng","name_vi":"Lư Hải Bằng","name_original":"Lo Hoi-Pang","tmdb_id":1147123,"profile":"https://image.tmdb.org/t/p/w500/r6dBIn3EjPSLk0ojAOtnk9u2pL0.jpg","tmdb_url":"https://www.themoviedb.org/person/1147123"},{"name":"Âu Cẩm Đường","name_vi":"Âu Cẩm Đường","name_original":"Stephen Au Kam-Tong","tmdb_id":987587,"profile":"https://image.tmdb.org/t/p/w500/jSONQ4UlIaC0nD9EDXfJvU8Njs0.jpg","tmdb_url":"https://www.themoviedb.org/person/987587"},{"name":"Tăng Quốc Cường","name_vi":"Tăng Quốc Cường","name_original":"Derek Tsang Kwok-Cheung","tmdb_id"