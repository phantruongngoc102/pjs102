"https://vip.opstream12.com/share/7e0a4d112e3f40b8f6decb2a7c365f91","link_m3u8":"https://vip.opstream12.com/20260105/31826_7e0a4d11/index.m3u8"}]}],"description":"<p>Lũ quỷ bị phong ấn từ nghìn năm về trước vô tình được giải thoát bởi một nhóm du khách Mỹ, Diabolico đã dẫn đường cho chúng trở về căn cứ và âm mưu lên kế hoạch sẽ thống trị vịnh Marina, California, tàn phá cuộc sống của loài người để biến nơi này thành lãnh địa của chúng, tạo bước đà thống trị thế giới. Tổ chức quân sự Lightspeed Rescue, được lãnh đạo bởi William Mitchell đã triệu tập 4 người ưu tú của thành phố cùng con gái Dana. Với những thành tựu khoa học mà lãnh đạo của đội kỹ thuật là Angela Fairweather, tổ chức đã biến họ thành những Power Rangers, trao cho họ sứ mệnh bảo vệ cả thành phố.</p>","tmdb_id":1097371,"cast":["Mike Chaturantabut","Sean Cw Johnson","Keith D. Robinson","Sasha Williams","Alison MacInnis","Ron Roggé","Monica Louwerens","Diane Salinger","Neil Kaplan","Jennifer L. Yen"],"director":["田崎竜太"],"keywords":[],"tmdb":{"type":"movie","id":"1097371","season":null,"vote_average":8.5,"vote_count":2},"cast_meta":[{"name":"Mike Chaturantabut","name_vi":null,"name_original":"Mike Chaturantabut","tmdb_id":1324263,"profile":"https://image.tmdb.org/t/p/w500/6kh7aitymBygLF7V9fvYe9Ka8Ld.jpg","tmdb_url":"https://www.themoviedb.org/person/1324263"},{"name":"Sean Cw Johnson","name_vi":null,"name_original":"Sean Cw Johnson","tmdb_id":79187,"profile":"https://image.tmdb.org/t/p/w500/qXhdP67lTWvmVOxyawXPtUMAtR2.jpg","tmdb_url":"https://www.themoviedb.org/person/79187"},{"name":"Keith D. Robinson","name_vi":null,"name_original":"Keith D. Robinson","tmdb_id":15564,"profile":"https://image.tmdb.org/t/p/w500/2XN49JQRDzpg1qUjIydbvO5iWxT.jpg","tmdb_url":"https://www.themoviedb.org/person/15564"},{"name":"Sasha Williams","name_vi":null,"name_original":"Sasha Williams","tmdb_id":39174,"profile":"https://image.tmdb.org/t/p/w500/AthV1Mw9LYdSBojYyfdMshYQyhz.jpg","tmdb_url":"https://www.themoviedb.org/person/39