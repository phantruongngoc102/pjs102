u8"}]}],"time":"45 phút/tập","description":"<p>Cuộc sống tình cảm và công việc của nhóm cứu hộ trên không, bao gồm Cao Khả Phong - chủ nhiệm cứu hộ - tên thường gọi là Matt, Diệp Thanh Vân (Ben) - phi công lái máy bay, Khang Vỹ Lam (Carrie )- bác sĩ cấp cứu trên không, Châu Tiểu Quyên (Niki ) - nhân viên điều khiển không lưu, Thi Sở Kỳ (Sandra ) - kiến tập sinh cứu hộ, Tưởng Gia Lạc - phi công tập sự cấp hai. Diệp Thanh Vân vốn là người điềm tĩnh, nhạy bén, làm việc cẩn thận, nhưng lại vụng về và chung thủy trong tình cảm...</p>","tmdb":{"type":"tv","id":"4854","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-02T18:27:04.000Z","cast":["Trịnh Y Kiện","Lâm Bảo Di","Xa Thi Mạn","Dương Tư Kỳ","Chung Gia Hân","Chris Lai","Huỳnh Đức Bân","Trần Sơn Thông","Hứa Thiệu Hùng","Charles Szeto","Ngao Gia Niên","Ngải Uy","Elaine Yiu"],"director":["La Vĩnh Hiền"],"cast_meta":[{"name":"Trịnh Y Kiện","name_vi":"Trịnh Y Kiện","name_original":"Ekin Cheng Yee-Kin","tmdb_id":21909,"profile":"https://image.tmdb.org/t/p/w500/dS42D99itm6n5ROUoGxJFRH802j.jpg","tmdb_url":"https://www.themoviedb.org/person/21909"},{"name":"Lâm Bảo Di","name_vi":"Lâm Bảo Di","name_original":"Bowie Lam Bo-Yee","tmdb_id":552084,"profile":"https://image.tmdb.org/t/p/w500/7scIX24RyIlibdyeXljnEPjXeKO.jpg","tmdb_url":"https://www.themoviedb.org/person/552084"},{"name":"Xa Thi Mạn","name_vi":"Xa Thi Mạn","name_original":"Charmaine Sheh Sze-Man","tmdb_id":123643,"profile":"https://image.tmdb.org/t/p/w500/nacsBV6rdWH3rTy5cZpiwb9luFB.jpg","tmdb_url":"https://www.themoviedb.org/person/123643"},{"name":"Dương Tư Kỳ","name_vi":"Dương Tư Kỳ","name_original":"Shirley Yeung Sze-Kei","tmdb_id":1233366,"profile":"https://image.tmdb.org/t/p/w500/xAZ36bayNij4diOzIm4HAkLcBMz.jpg","tmdb_url":"https://www.themoviedb.org/person/1233366"},{"name":"Chung Gia Hân","name_vi":"Chung Gia Hân","name_original":"Linda Chung Ka-Yan","tmdb_id":146654,"profile":"https://image.tmdb.org/t/p/w500/ao0Hei6czNVCJq1m8n0lRFk9SqG.jpg","tmdb