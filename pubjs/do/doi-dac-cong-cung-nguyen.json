de85a90/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream15.com/share/c8c0f01903dd295f2198b57a5d720693","link_m3u8":"https://vip.opstream15.com/20230510/39048_057c3172/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/5b27b6d632522f24e120a9bed6be579d","link_m3u8":"https://vip.opstream15.com/20230510/39047_ec26f5ab/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/c4620e8a4aaa1f62e739608c2a866f9f","link_m3u8":"https://vip.opstream15.com/20230510/39049_dbb4348f/index.m3u8"}]}],"description":"<p>Ngôi sao Cung Lễ đầy thị phi và cô cử nhân ngành Tâm lý học giả làm nhà chiêm tinh vô tình bị cuốn vào một vụ mưu sát, trở thành kẻ chịu tội thay trong mắt nhiều người. Cũng chính vì thế mà họ bị hãm hại, đuổi giết, mỗi bước đi đều rơi vào một âm mưu ly kì khác khiến con người ta ngày càng suy sụp. Nhưng rồi Cung Lễ đã vận dụng trí thông minh và lòng dũng cảm mà chính bản thân cũng không ngờ đến, chiến thắng bản chất của một người bình thường như lười biếng, ngốc nghếch. Anh nhìn thấu các chiêu trò, tùy cơ ứng biến, hợp tác với lực lượng cảnh sát chính nghĩa, cuối cùng thoát nạn trong tình huống ngàn cân treo sợi tóc và phá được vụ án động trời.</p>","tmdb_id":222528,"cast":["Ming Dao","Jiang Kaitong","Tạ Thiên Hoa","Vu Ba","Josephine Yu","He Zeyuan","Trần Pháp Dung","Ma Yi","Lý Gia Kỳ","Yuni Lee","Bonnie Wong Man-Wai","Doãn Dương Minh","Winnie Lau Siu-Wai","Yi Yunhe","Chae Ri-eun"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"222528","season":1,"vote_average":2,"vote_count":1},"cast_meta":[{"name":"Ming Dao","name_vi":null,"name_original":"Ming Dao","tmdb_id":1137149,"profile":"https://image.tmdb.org/t/p/w500/1auKzPes5Eko91shqmYiwv7miZj.jpg","tmdb_url":"https://www.themoviedb.org/person/1137149"},{"name":"Jiang Kaitong","name_vi":null,"name_original":"Jiang Kaitong","tmdb_id":1486438,"profile":"https://image.tmdb.org/t/p/w500/sNUBnFNJMEWDgC9ZLxfaoJ8ufnq.jpg","tmdb_url":"https: