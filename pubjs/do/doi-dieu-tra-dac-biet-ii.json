.com/share/d157d577520c2e9085acc55d3d794007","link_m3u8":"https://vip.opstream17.com/20251125/23969_d157d577/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/9d82620296a1e1fb76c64302dc3d77ba","link_m3u8":"https://vip.opstream17.com/20251125/23970_9d826202/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/d3fe63d904ee975a2297184b62c6ae60","link_m3u8":"https://vip.opstream17.com/20251125/23971_d3fe63d9/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/e5a7acc236abc42d5e11afede4915282","link_m3u8":"https://vip.opstream17.com/20251125/23972_e5a7acc2/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/5a8a0f2779706d8eff072fa34acfb143","link_m3u8":"https://vip.opstream17.com/20251125/23973_5a8a0f27/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream17.com/share/bcf72cf0c11264b5bd65830efe8feaf8","link_m3u8":"https://vip.opstream17.com/20251125/23974_bcf72cf0/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream17.com/share/a5537a7ededd2ffe4de474cc615ef5be","link_m3u8":"https://vip.opstream17.com/20251125/23975_a5537a7e/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream17.com/share/777081377d8fa759d557429c4a1932d8","link_m3u8":"https://vip.opstream17.com/20251125/23976_77708137/index.m3u8"}]}],"description":"<p>Sau 1 thời gian giải tán, đội điều tra D.I.E đã được khôi phục. Vu Tử Lãng (Quách Tấn An), Trương Chính Nghĩa (Quách Chính Hồng) và các thành viên cũ lại gặp nhau, cùng chung tay điềutra các vụ án kỳ lạ. Bà mẹ trẻ Hình Tinh Tinh (Quách Thiện Ni) cũng muốn chứng tỏ tài năng nên ẵm con trở về đội tham gia phá án. Tử Lãng phản đối không được, đành nhờ mọi người thay phiên chăm sóc con trai. Trong quá trình điềutra, Tinh Tinh phát hiện con trai thừa hưởng khả năng kỳ lạ của Tử Lãng. Vì muốn chứng minh bản thân điều tra vụ án không thua kém chồng, Tinh Tinh thường xuyên dựa vào năng lực của con trai để tìm manh mối. Cũng vì chuyện này mà khoảng cách giữa hai vợ chồng ngày càng xa. Tử Lãng phát hiện em gái của Tinh Tinh, Hình Bội Bội (Hồ Định Hân) luôn bị kẻ gian lợi dụng, Tinh Tinh và con trai anh chính là mục tiêu của hắn. Tử Lãng bị đụng xe ngất xỉu đến mức hồn rời khỏi xác, chỉ có thể đứng nhìn vợ con gặp nguy hiểm. Tình huống cấp bách anh đành nhập hồn vào Chính Nghĩa...</p>","tmdb_id":7694,"cast":["Quách Tấn An","Quách Thiện Ni","Hồ Định Hân","Derek Kwok Jing-Hung","Mimi Lo","Thomas Sin Ho-Ying","Quách Phong","Zac Koo Hau-Zheng","Macy Chan","La Tử Dật","Stefan Wong","Kitty Yuen Siu-Yee","Rain Lau Yuk-Chui","Hạ Bình","Chun Wong"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"7694","season":1,"vote_average":4.5,"vote_count":2},"cast_meta":[{"name":"Quách Tấn An","name_vi":"Quách Tấn An","name_original":"Roger Kwok Chun-On","tmdb_id":230576,"profile":"https://image.tmdb.org/t/p/w500/lmvdYkdC7i8RWF1pK0A4uMOv34k.jpg","tmdb_url":"https://www.themoviedb.org/person/230576"},{"name":"Quách Thiện Ni","name_vi":"Quách Thiện Ni","name_original":"Sonija Kwok Sin-Nae","tmdb_id":1223071,"profile":"https://image.tmdb.org/t/p/w500/UPKGvicMcTMLHZ0vuc49sV0BoG.jpg","tmdb_url":"https://www.themoviedb.org/person/1223071"},{"name":"Hồ Định Hân","name_vi":"Hồ Định Hân","name_original":"Nancy Wu","tmdb_id":1234856,"profile":"https://image.tmdb.org/t/p/w500/9HPuplvtWO5ODGX0IhNaZsssIi4.jpg","tmdb_url":"https://www.themoviedb.org/person/1234856"},{"name":"Derek Kwok Jing-Hung","name_vi":null,"name_original":"Derek Kwok Jing-Hung","tmdb_id":140479,"profile":"https://image.tmdb.org/t/p/w500/cFypay2ZkDNThKVgpighp9msAfk.jpg","tmdb_url":"https://www.themoviedb.org/person/140479"},{"name":"Mimi Lo","name_vi":null,"name_original":"Mimi Lo","tmdb_id":1233365,"profile":"https://image.tmdb.org/t/p/w500/7adlBu98duQrsYe7MfJ8AAt9WMf.jpg","tmdb_url":"https://www.themoviedb.org/person/1233365"},{"name":"Thomas Sin Ho-Ying","name_vi":null,"name_original":"Thomas Sin