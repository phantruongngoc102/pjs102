 ra vẻ thô lỗ cộc cằn. Khi điều tra Tinh luôn quan niệm “Thà giết lầm chứ không bỏ sót”, thường tranh cãi với Lãng, khiến quan hệ đồng nghiệp của hai người ngày càng tồi tệ.</p>","tmdb_id":7153,"cast":["郭晉安","郭羨妮","胡定欣","郭政鴻","羅敏莊","冼灝英","郭鋒","高皓正","黃祥興","陳美詩"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"7153","season":1,"vote_average":6,"vote_count":5},"cast_meta":[{"name":"郭晉安","name_vi":null,"name_original":"郭晉安"},{"name":"郭羨妮","name_vi":null,"name_original":"郭羨妮"},{"name":"胡定欣","name_vi":null,"name_original":"胡定欣"},{"name":"郭政鴻","name_vi":null,"name_original":"郭政鴻"},{"name":"羅敏莊","name_vi":null,"name_original":"羅敏莊"},{"name":"冼灝英","name_vi":null,"name_original":"冼灝英"},{"name":"郭鋒","name_vi":null,"name_original":"郭鋒"},{"name":"高皓正","name_vi":null,"name_original":"高皓正"},{"name":"黃祥興","name_vi":null,"name_original":"黃祥興"},{"name":"陳美詩","name_vi":null,"name_original":"陳美詩"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/do/doi-dieu-tra-dac-biet.json"}