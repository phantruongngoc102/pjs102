share/2bd0a92f3cc8f85e2d23f8addcb52eca","link_m3u8":"https://vip.opstream15.com/20220603/18381_44713d2f/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/f7c4382ef2abd84bbe5297f34f5e3ae4","link_m3u8":"https://vip.opstream15.com/20220603/18383_074976cd/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/02e2259af55fb6a382ca7aa9f13319b3","link_m3u8":"https://vip.opstream15.com/20220603/18385_9fafefc1/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/e231a950ed2aa037c80bdfceb334ec1d","link_m3u8":"https://vip.opstream15.com/20220603/18386_5939064e/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/86f2df8b1f35b23f913ca2da72522a36","link_m3u8":"https://vip.opstream15.com/20220603/18387_c72f6d1b/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream15.com/share/a51f9f66346e1d23bf39c2b2a9f0b685","link_m3u8":"https://vip.opstream15.com/20220603/18391_1f904676/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream15.com/share/9063c84e769a726bd4687c8a230e2e71","link_m3u8":"https://vip.opstream15.com/20220603/18395_1ef08747/index.m3u8"}]}],"description":"<p>Đó là vào thời điểm những năm 2030, Đội Thám Tử Nhí được tập hợp dưới sự dẫn dắt của một vị thám tử bí ẩn - Akechi Kogorou. Nhóm đã giải quyết được rất nhiều vụ án lớn nhỏ nhờ vào những kỹ năng đặc biệt của họ. Một ngày nọ, một thành viên của nhóm là Hanazaki Kensuke tình cờ gặp được một cậu nhóc tên Kobayashi Yoshio. Nhờ vào \"làn khói không xác định\" mà cơ thể của Kobayashi không thể chết, nhưng cậu ta lại khao khát cái chết, dần xa lánh, không muốn tiếp xúc với người khác. Có hứng thú với cậu ta, Hanazaki mời cậu ấy gia nhập Đội Thiếu Niên Thám Tử. Cuộc gặp gỡ của họ được kết nối với số phận đã ràng buộc Akechi Kogorou và tên tội phạm vĩ đại nhất mọi thời đại - Quái Nhân Nhị Thập Diện (Kẻ có 20 khuôn mặt) - lại với nhau.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/do/doi-thieu-nien-tham-tu.json","tmdb_checked":false}