82b964822","link_m3u8":"https://vip.opstream17.com/20240605/10211_86d49a80/index.m3u8"},{"name":"22","slug":"22","filename":"Đồi Trà Tình Yêu Đồi Trà Tình Yêu 22-YOUKU-Drama, Film, Show, Anime","link_embed":"https://vip.opstream17.com/share/8fcd9e5482a62a5fa130468f4cf641ef","link_m3u8":"https://vip.opstream17.com/20240605/10212_ac881b2f/index.m3u8"},{"name":"23","slug":"23","filename":"Đồi Trà Tình Yêu Đồi Trà Tình Yêu 23-YOUKU-Drama, Film, Show, Anime","link_embed":"https://vip.opstream17.com/share/5cc33dfe7e069a757ca0fcbe6b95c89e","link_m3u8":"https://vip.opstream17.com/20240606/10431_f51c5faf/index.m3u8"},{"name":"24","slug":"24","filename":"Đồi Trà Tình Yêu Đồi Trà Tình Yêu 24-YOUKU-Drama, Film, Show, Anime","link_embed":"https://vip.opstream17.com/share/3181d59d19e76e902666df5c7821259a","link_m3u8":"https://vip.opstream17.com/20240606/10432_9ccf90e5/index.m3u8"}]}],"time":"15 phút/tập","description":"Trong một lần về vùng nông thôn khảo sát, thiên kim tập đoàn Diệp thị, Diệp Tịch Nhan (do Thích Nghiên Địch thủ vai) gặp tai nạn xe, được Lục Minh Vũ (do Tiêu Tử Mặc thủ vai) – chủ đồi trà thôn Cổ Yến, tình cờ đi ngang qua cứu giúp. Để tránh nguy hiểm, Diệp Tịch Nhan giả vờ mất trí nhớ nhưng lại bị nhận nhầm thành một cô thôn nữ Tú Phân, còn vô tình đính hôn với Lục Minh Vũ, cuộc sống vui vẻ ngọt ngào cũng bắt đầu từ đây… Tuy nhiên, sự xuất hiện của cậu ấm Thôi Tử Hào của tập đoàn Thôi thị (do Cao Khải thủ vai) đã phá vỡ cuộc sống bình yên của hai người. Thân phận thôn nữ của Diệp Tịch Nhan bị nghi ngờ, quá khứ từng làm vệ sĩ của Lục Minh Vũ cũng dần bại lộ. Hai người đều có tâm sự riêng, sinh ra hiểu lầm chồng chất. Âm mưu nhắm vào đồi trà và tập đoàn Diệp thị cũng dần lộ rõ. Liệu cả hai có thể cùng nhau đối mặt với nguy cơ, kiên định gìn giữ tình yêu đích thực của đời mình?","tmdb":{"type":"tv","id":"255532","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-08T10:59:15.000Z","cast":["Thích Nghiên Địch","Eric Hsiao","Gao Kai"],"director":[],"cast_met