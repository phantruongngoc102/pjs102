b6c/index.m3u8"},{"name":"24","slug":"24","filename":"EP24- My Amazing Captain_Watch online","link_embed":"https://vip.opstream15.com/share/3b0d3acaf5e61ac97738f559aa43fb1d","link_m3u8":"https://vip.opstream15.com/20220814/26482_0ca628a7/index.m3u8"}]}],"time":"4 phút/tập","description":"<p>Thiên tài bóng rổ Chung Đại Hải đột nhiên trở thành nữ sau một tai nạn bất ngờ. Tuy nhiên cậu ấy vẫn không hề từ bỏ ước mơ của mình và vô tình tham gia vào đội bóng rổ với tư cách là thành viên đội cổ vũ. Cô ấy vừa phải đối phó với \"cậu bạn thân\" Lục Tinh Tề, vừa phải đối phó sự giám sát của Diệp Nhiên, người của bác sĩ, để che giấu thân phận của mình, từ đó đã gây ra rất nhiều chuyện cười ra nước mắt. Tuy nhiên trên thực tế Chung Đại Hải vốn là nữ giới mắc chứng rối loạn định dạng giới, nên trước giờ vẫn nghĩ mình là nam.</p>","tmdb":{"type":"tv","id":"206351","season":1,"vote_average":8,"vote_count":1},"modified":"2022-08-14T13:50:11.000Z","cast":["Pan Yuetong","Wang Junhao","Zheng Mingxin","Wang Xinru","Shen Yang","Lv Jun","Wang Guochen","Michael Jen"],"director":["XinweiHou"],"cast_meta":[{"name":"Pan Yuetong","name_vi":null,"name_original":"Pan Yuetong","tmdb_id":3387703,"profile":"https://image.tmdb.org/t/p/w500/ibf2fDUEudsyw8baBGDFpNvdyul.jpg","tmdb_url":"https://www.themoviedb.org/person/3387703"},{"name":"Wang Junhao","name_vi":null,"name_original":"Wang Junhao","tmdb_id":3688186,"profile":"https://image.tmdb.org/t/p/w500/w6Ejo8z1izHTpdCurqrdjeI0NlI.jpg","tmdb_url":"https://www.themoviedb.org/person/3688186"},{"name":"Zheng Mingxin","name_vi":null,"name_original":"Zheng Mingxin","tmdb_id":3688187,"profile":"https://image.tmdb.org/t/p/w500/6DMRwYH4CR826e2FjurkfQgBqE1.jpg","tmdb_url":"https://www.themoviedb.org/person/3688187"},{"name":"Wang Xinru","name_vi":null,"name_original":"Wang Xinru","tmdb_id":2875512,"profile":"https://image.tmdb.org/t/p/w500/sXpf7T7f2SEabptMX2mHK8o2wFH.jpg","tmdb_url":"https://www.themoviedb.org/person/2875512"},{"name":"Shen Yang","name_vi":nu