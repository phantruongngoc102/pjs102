:"https://vip.opstream14.com/20220706/17377_181860b3/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/77dbda525242a07339101a7c6ac73495","link_m3u8":"https://vip.opstream14.com/20220706/17378_6f9007b6/index.m3u8"}]}],"description":"<p>Đông Pha Gia Sự xoay quanh câu chuyện nói về nhân vật trong lịch sữ là Tô Đông Pha sự ra đi của người vợ khiến ông đau lòng và không chấp nhận cô gái nào kể cả Vương Nhuận Chi, sao đó tên Hàn Nguyên đã xuất hiện và có tình ý với Nhuận chi đã để cho Đông Pha phát hiện ra âm mưu của hắn nên trong lúc này Đông Pha chấp nhận cưới Nhuận Chi làm vợ. Tô Mai là đứa con gái duy hất của Tô Đông Pha không chấp nhận được có người mẹ kế nên ông đã dùng đủ mọi cách và ông đã đứng ra giúp đở em trai là Tô Kiệt thoát khỏi đối thủ trong chính trường, Tô Đông Pha cái tên đã lừng danh thiên hạ đã khiến cho nhà vua ganh tị với tài trí của ông nên đã ghép tội chứng cho ông làm thơ phản, kết cuộc của Tô Đông Pha như thế nào có vượt qua được sóng gió hay không mời các bạn cùng đón xem.</p>","tmdb_id":90730,"cast":["Âu Dương Chấn Hoa","Joey Man Yee-Man","Âu Thụy Vỹ","Harriet Yeung Sze-Man","Vương Hạo Tín","Trần Vỹ","Jacqueline Wong","Sire Ma","Đơn Lập Văn","Trương Dĩnh Khang","Hàn Mã Lợi","Leanne Liu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"90730","season":1,"vote_average":4,"vote_count":1},"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Joey Man Yee-Man","name_vi":null,"name_original":"Joey Man Yee-Man","tmdb_id":1191930,"profile":"https://image.tmdb.org/t/p/w500/xX8YV5x5aEFSU9aGxwXNElFwAoZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1191930"},{"name":"Âu Thụy Vỹ","name_vi":"Âu Thụy Vỹ","name_original":"Jimmy Au Shui-Wai","tmdb_id":1365933,"profile":"https://image.tmdb.org/t/p/w500/67