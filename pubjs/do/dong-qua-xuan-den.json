9258df80","link_m3u8":"https://vip.opstream90.com/20260403/28767_e9b3f2e3/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/45204519c15e0b1ce35f9d4b63749226","link_m3u8":"https://vip.opstream90.com/20260403/28768_45204519/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream90.com/share/801ebb19f5827eacf5682802ce3ea179","link_m3u8":"https://vip.opstream90.com/20260403/28769_801ebb19/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream90.com/share/d0bc2050431b6f182680677fc8feb896","link_m3u8":"https://vip.opstream90.com/20260403/28770_d0bc2050/index.m3u8"}]}],"description":"<p>Ở Bắc Kinh vào những năm 90, quán trọ Đông Qua Xuân Đến đã chứng kiến cuộc sống thăng trầm của những nam nữ thanh niên từ khắp mọi miền đất nước đổ về đây ôm ấp giấc mơ sống và làm việc tại Bắc Kinh. Họ là Từ Thắng Lợi, một người đam mê viết kịch bản nhưng thường bị từ chối vẫn kiên trì chiến đấu sau mỗi lần thất bại; Trang Trang, một ca sĩ khao khát bước lên sân khấu thanh lịch nhưng chỉ có thể mưu sinh qua những buổi diễn thương mại; Thẩm Nhiễm Nhiễm, cô gái hi vọng được đóng vai nữ chính lại phải đối mặt với cơ hội và lựa chọn trong làng giải trí hào nhoáng; Đào Lượng Lượng, một nghệ sĩ kèn saxophone tài hoa chơi nhạc cho khách qua đường dưới chân cầu vượt để thực hiện giấc mơ âm nhạc; Quách Tông Bảo, một diễn viên quần chúng yêu văn nghệ nhưng lại làm đủ thứ việc vặt để kiếm tiền chữa bệnh cho vợ con; Tào Dã, một họa sĩ muốn gây tiếng vang với những ý tưởng nghệ thuật tiên phong nhưng không ai thấu hiểu. Họ đã nỗ lực không ngừng để theo đuổi ước mơ nhưng hiện thực luôn khắc nghiệt và vô vọng. Bước qua năm 2000, bước vào thời đại mới, một số người trong số họ vẫn kiên trì, một số người buộc phải từ bỏ, nhưng ngọn lửa nghệ thuật trong trái tim họ chưa từng tắt.<br>&nbsp;</p>","tmdb_id":291470,"cast":["Bạch Vũ","Chương Nhược Nam","Lâm Duẫn","Vương Ngạn Lâm","Song Jiateng","Alvin Cao"],"director":["郑晓龙"],"keywords":[],"ti