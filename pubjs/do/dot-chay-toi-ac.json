n và phó đội trưởng đội hình sự Thẩm Dã. Ba người cùng nhau thiết lập cơ chế phản ứng nhanh để đối phó với các vụ hỏa hoạn nghiêm trọng, phối hợp phá giải nhiều vụ án cháy nổ bí ẩn, cuối cùng làm sáng tỏ chân tướng vụ án cũ của nhà họ Hứa.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"263166","season":1,"vote_average":7.6,"vote_count":5},"modified":"2025-03-27T18:08:34.000Z","cast":["Trương Vân Long","Thái Văn Tịnh","Dai Xu","Đồ Tùng Nham","Wang Longzheng","Wang Tonghui","Phạm Trương","Su Jinyuan","Jeremiah Li"],"director":["Thiên Nhất"],"cast_meta":[{"name":"Trương Vân Long","name_vi":"Trương Vân Long","name_original":"Leon Zhang","tmdb_id":1785826,"profile":"https://image.tmdb.org/t/p/w500/tebbwxd5F9CdDG3YzYZQJ2jC8bY.jpg","tmdb_url":"https://www.themoviedb.org/person/1785826"},{"name":"Thái Văn Tịnh","name_vi":"Thái Văn Tịnh","name_original":"Cai Wenjing","tmdb_id":1680738,"profile":"https://image.tmdb.org/t/p/w500/gyeNAy8ktBNlNqXhzy2R6AQ6Y5l.jpg","tmdb_url":"https://www.themoviedb.org/person/1680738"},{"name":"Dai Xu","name_vi":null,"name_original":"Dai Xu","tmdb_id":1872331,"profile":"https://image.tmdb.org/t/p/w500/3tJyYJ71YJPYTaRQpg68ezLryhW.jpg","tmdb_url":"https://www.themoviedb.org/person/1872331"},{"name":"Đồ Tùng Nham","name_vi":"Đồ Tùng Nham","name_original":"Tu Songyan","tmdb_id":2276453,"profile":"https://image.tmdb.org/t/p/w500/xMN5dqyJQUFgQWp2GUheeBWpXGp.jpg","tmdb_url":"https://www.themoviedb.org/person/2276453"},{"name":"Wang Longzheng","name_vi":null,"name_original":"Wang Longzheng","tmdb_id":1739834,"profile":"https://image.tmdb.org/t/p/w500/gTKEAwwL6yjoNmEbDJ5k8brsuai.jpg","tmdb_url":"https://www.themoviedb.org/person/1739834"},{"name":"Wang Tonghui","name_vi":null,"name_original":"Wang Tonghui","tmdb_id":1397562,"profile":"https://image.tmdb.org/t/p/w500/o1S1SKCd5bleiDS4hPnv4elhj9I.jpg","tmdb_url":"https://www.themoviedb.org/person/1397562"},{"name":"Phạm Trương","name_vi":"Phạm Trương","name_original":"Zhang Fan","tmdb_id":2027655,"profile":"htt