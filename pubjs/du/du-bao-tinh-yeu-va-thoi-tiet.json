stream10.com/share/8010691083622c563813e1f1d85119d6","link_m3u8":"https://vip.opstream10.com/20220608/19316_38bdeb73/index.m3u8"},{"name":"13","slug":"13","filename":"du-bao-tinh-yeu-va-thoi-tiet-thuyet-minh-forecasting-love-and-weather-tap-13","link_embed":"https://vip.opstream10.com/share/d9ab9cc1bf456f1db82299d1226553e4","link_m3u8":"https://vip.opstream10.com/20220608/19318_c8db0c6e/index.m3u8"},{"name":"14","slug":"14","filename":"du-bao-tinh-yeu-va-thoi-tiet-thuyet-minh-forecasting-love-and-weather-tap-14","link_embed":"https://vip.opstream10.com/share/8945e380613d55b5fc2968c42b1a58fd","link_m3u8":"https://vip.opstream10.com/20220608/19321_756f0700/index.m3u8"},{"name":"15","slug":"15","filename":"du-bao-tinh-yeu-va-thoi-tiet-thuyet-minh-forecasting-love-and-weather-tap-15","link_embed":"https://vip.opstream10.com/share/4de7729ea5daf28540ee79b3dca73d19","link_m3u8":"https://vip.opstream10.com/20220608/19323_6f313ed2/index.m3u8"},{"name":"16","slug":"16","filename":"du-bao-tinh-yeu-va-thoi-tiet-thuyet-minh-forecasting-love-and-weather-tap-16","link_embed":"https://vip.opstream10.com/share/62d3acf0e33805d5309154e95195fea1","link_m3u8":"https://vip.opstream10.com/20220608/19326_c5b7a202/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Phim kể về công việc và tình yêu, cuộc sống của những người làm việc tại Cục Khí tượng Hàn Quốc, dịch vụ dự báo thời tiết quốc gia của Hàn Quốc.</p><p>Jin Ha Kyung (Park Min Young) là một người thông minh và có tổ chức cao. Cô làm mọi thứ theo lý thuyết và khó tính trong việc giữ cuộc sống cá nhân với nghề nghiệp của mình một cách riêng biệt. Do tính cách lạnh lùng, cô ấy có ít bạn bè tại nơi làm việc và trở thành “người ngoài cuộc theo sự lựa chọn”.</p><p>Lee Shi Woo (Song Kang) là người sở hữu một tinh thần tự do, luôn suy nghĩ cởi mở. Mặc dù có vẻ ngoài vụng về nhưng anh ấy tự hào có chỉ số IQ ấn tượng 150 và có thể đạt được bất cứ điều gì một khi anh ấy quyết tâm. Tuy nhiên, bất chấp trí thông minh và khả năng của mình, tất cả những gì anh ta quan tâm là thời tiết.</p>","tmdb":{"type":"tv","id":"152511","season":1,"vote_average":7.197,"vote_count":127},"modified":"2025-05-15T15:28:45.000Z","cast":["Park Min-young","Song Kang","Yoon Park","Yura","Lee Sung-wook","Moon Tae-yu","Yoon Sa-bong","Chae Seo-eun","Kwon Hae-hyo","Kim Mi-kyeong","Jung Woon-sun","Jang So-yeon","Bae Myeong-jin","Lee Seung-ju","Jeong Seung-jin"],"director":[],"cast_meta":[{"name":"Park Min-young","name_vi":null,"name_original":"Park Min-young","tmdb_id":1234603,"profile":"https://image.tmdb.org/t/p/w500/5Op0Gx0DULFLHtGdWVdqnYdwkAS.jpg","tmdb_url":"https://www.themoviedb.org/person/1234603"},{"name":"Song Kang","name_vi":null,"name_original":"Song Kang","tmdb_id":1878952,"profile":"https://image.tmdb.org/t/p/w500/83fLAMMb1LGT8YZ4dgRI0fti3az.jpg","tmdb_url":"https://www.themoviedb.org/person/1878952"},{"name":"Yoon Park","name_vi":null,"name_original":"Yoon Park","tmdb_id":1664895,"profile":"https://image.tmdb.org/t/p/w500/6num8dBRqOgdKQtuvaEP7bjTNg7.jpg","tmdb_url":"https://www.themoviedb.org/person/1664895"},{"name":"Yura","name_vi":null,"name_original":"Yura","tmdb_id":1547200,"profile":"https://image.tmdb.org/t/p/w500/agb4el3J2wBVq4ZmNHTJlms07Q8.jpg","tmdb_url":"https://www.themoviedb.org/person/1547200"},{"name":"Lee Sung-wook","name_vi":null,"name_original":"Lee Sung-wook","tmdb_id":1682490,"profile":"https://image.tmdb.org/t/p/w500/erpOUfjadjH2duXd6XWDsa2kNfw.jpg","tmdb_url":"https://www.themoviedb.org/person/1682490"},{"name":"Moon Tae-yu","name_vi":null,"name_original":"Moon Tae-yu","tmdb_id":3118861,"profile":"https://image.tmdb.org/t/p/w500/6aoS9Dcr2KJNUc7AotfQnzYEM4D.jpg","tmdb_url":"https://www.themoviedb.org/person/3118861"},{"name":"Yoon Sa-bong","name_vi":null,"name_original":"Yoon Sa-bong","tmdb_id":3481970,"profile":"https://image.tmdb.org/t/p/w500/3SURKmyLFOdb96ITQ0bIQSUwdSw.jpg","tmdb_url":"https://www.themoviedb.org/person/3481970"},{"name":"Chae Seo-eun","name_vi":null,"name_original":"Chae Seo-