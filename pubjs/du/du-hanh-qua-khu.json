{"id":"6433619f11f407ffb90f3224","title":"Du Hành Quá Khứ","origin_name":"Project Almanac","slug":"du-hanh-qua-khu","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/du/du-hanh-qua-khu.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/du/du-hanh-qua-khu.webp","year":2015,"type":"single","genre":[{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Project Almanac - Du Hành Quá Khứ - 2015","link_embed":"https://vip.opstream14.com/share/7fa66f426416d30c0c885937fed3c9d1","link_m3u8":"https://vip.opstream14.com/20230410/35065_9b16028c/index.m3u8"}]}],"time":"106 Phút","description":"Khai thác một đề tài quen thuộc nhưng chưa bao giờ cũ đó là du hành thời gian, bộ phim đưa khán giả làm quen với một nhóm bạn trẻ đang học trung học phổ thông với niềm đam mê tìm tòi và sáng tạo công nghệ. Trong số đó nổi bật nhất là David Raskin (Jonny Weston), thủ lĩnh của cả nhóm, và anh nuôi mộng kiếm được học bổng để vào học trường MIT danh giá. Nhưng trớ trêu là gia đình cậu lại không đủ tiền để chi trả phần còn lại của học phí khi có giấy báo được nhận vào học. Tưởng như David phải từ bỏ ước mơ của mình, thì trong lúc lục lọi căn gác xép tại nhà, một cuốn phim trong chiếc camera cũ của bố để lại đã thu hút sự chú ý của cậu, với đoạn phim cho thấy dường như cậu đã xuất hiện trong sinh nhật 7 tuổi của chính mình trong quá khứ.","tmdb":{"type":"movie","id":"227719","season":null,"vote_average":6.781,"vote_count":2778},"mod