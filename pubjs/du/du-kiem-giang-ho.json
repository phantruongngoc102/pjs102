ug":"33","filename":"Du Kiem Giang Ho 2006 33","link_embed":"https://vip.opstream11.com/share/a9fa34b067b19c21e33f71497b73ae59","link_m3u8":"https://vip.opstream11.com/20241106/56720_a9fa34b0/index.m3u8"},{"name":"34","slug":"34","filename":"Du Kiem Giang Ho 2006 34","link_embed":"https://vip.opstream11.com/share/f6a33f21ae9b58ae75f34d4c8f89edeb","link_m3u8":"https://vip.opstream11.com/20241106/56721_f6a33f21/index.m3u8"},{"name":"35","slug":"35","filename":"Du Kiem Giang Ho 2006 35","link_embed":"https://vip.opstream11.com/share/56837c1ff93278edf23087d3ec33b1b9","link_m3u8":"https://vip.opstream11.com/20241106/56722_56837c1f/index.m3u8"},{"name":"36","slug":"36","filename":"Du Kiem Giang Ho 2006 36","link_embed":"https://vip.opstream11.com/share/4c53e9ccb96d931f1c8e32a3ef9de55b","link_m3u8":"https://vip.opstream11.com/20241106/56723_4c53e9cc/index.m3u8"},{"name":"37","slug":"37","filename":"Du Kiem Giang Ho 2006 37","link_embed":"https://vip.opstream11.com/share/57649c2c46cc3ba8cd9b55467020acee","link_m3u8":"https://vip.opstream11.com/20241106/56724_57649c2c/index.m3u8"},{"name":"38","slug":"38","filename":"Du Kiem Giang Ho 2006 38","link_embed":"https://vip.opstream11.com/share/b69332f6eb354ca14fe70ed07e544000","link_m3u8":"https://vip.opstream11.com/20241106/56725_b69332f6/index.m3u8"},{"name":"39","slug":"39","filename":"Du Kiem Giang Ho 2006 39","link_embed":"https://vip.opstream11.com/share/4b5d3a2835660b72d416ca0c4debeb80","link_m3u8":"https://vip.opstream11.com/20241106/56726_4b5d3a28/index.m3u8"},{"name":"40","slug":"40","filename":"Du Kiem Giang Ho 2006 40 END","link_embed":"https://vip.opstream11.com/share/178a7a5f39ab1ea59af1006f5645e6e8","link_m3u8":"https://vip.opstream11.com/20241106/56727_178a7a5f/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Vừa biết tin Mạnh Nguyên Siêu (do Trần Long đóng) bị giết chết, tổng tiêu đầu Dương Mục (do Trần Cẩm Hồng đóng) lập tức mang sính lễ đến hỏi cưới Vân Tử La (do Quách Thiện Ni đóng). Lúc này, La đã mang cốt nhục của Siêu. Để bảo toàn tính mạng đứa bé, cô đành nhận lời lấy Mục. Thật ra, Siêu đã thoát chết trong gang tấc. Anh định trở về hội ngộ cùng La nhưng đã quá muộn. Siêu đành lặng lẽ bỏ đi, dồn hết tâm sức để thực hiện di nguyện của cha – liên minh tiêu cục của 18 tỉnh. Ước vọng của Siêu gặp nhiều sóng gió vì sự xuất hiện của phái Phù Tang mà người đứng đầu là Mưu Tông Đào (do Lý Thiên Tường đóng). Vì Siêu vô tình giúp sư muội Lâm Vô Song (do Trần Di Dung đóng) đoạt được ngôi vị tôn chủ của phái Phù Tang, nên Đào càng căm hận Siêu. Trong khi đó, Mục lo sợ mất La, đã vu cho Siêu tội thông dâm, khiến anh thân bại danh liệt. Tổ chức liên minh chưa kịp ra đời đã bị chết yểu. Thừa cơ hội này, Đào cấu kết với tổng lệnh ngự lâm quân Bắc Cung Vọng (do Lưu Vệ Hoa đóng), mua chuộc Mục, tiếp tục dồn Siêu vào con đường cùng. May thay, bên cạnh Siêu còn có Mậu Trường Phong (do Hà Gia Kính đóng). Chẳng những ngưỡng mộ đạo pháp của Mạnh gia, Phong còn yêu thầm La từ rất lâu. Cho nên, anh nguyện bất chấp tất cả để giúp đỡ Siêu và La, kể cả phải hy sinh tính mạng của mình.</i></p>","tmdb":{"type":"tv","id":"107932","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-16T10:43:29.000Z","cast":["Quách Thiện Ni","Trần Cẩm Hồng","Hà Gia Kính","Chen Long","Lee Tin-Cheung","Lý Thiến","Liu Weihua","Dương Mẫn Na","Chu Vũ Thần","Li Jianqun","Pan Hong","Wang Yanan","Cao Jun","Zhao Liang"],"director":["Đường Cơ Minh"],"cast_meta":[{"name":"Quách Thiện Ni","name_vi":"Quách Thiện Ni","name_original":"Sonija Kwok Sin-Nae","tmdb_id":1223071,"profile":"https://image.tmdb.org/t/p/w500/UPKGvicMcTMLHZ0vuc49sV0BoG.jpg","tmdb_url":"https://www.themoviedb.org/person/1223071"},{"name":"Trần Cẩm Hồng","name_vi":"Trần Cẩm Hồng","name_original":"Sunny Chan Kam-Hung","tmdb_id":548050,"profile":"https://image.tmdb.org/t/p/w500/pUMJUtdpFutN7uHk7yPw11iwAbh.jpg","tmdb_url":"https://www.themoviedb.org/person/548050"},{"name":"Hà Gia Kính","name_vi":"Hà Gia Kính","name_original":"Kenny Ho Ka-King