 Tạ Dư Hành không phải con cháu hoàng thất.","tmdb_id":251639,"cast":["Lâm Trach Huy","Từ Chẩn Chẩn","Zhu Minxin","He Shi","Gao Kai","Zhu Xinyuan","Zhang Zhexu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"251639","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lâm Trach Huy","name_vi":"Lâm Trach Huy","name_original":"Lin Zehui","tmdb_id":3716468,"profile":"https://image.tmdb.org/t/p/w500/stEok10jjs6rISy5ZgcQV5CfPVc.jpg","tmdb_url":"https://www.themoviedb.org/person/3716468"},{"name":"Từ Chẩn Chẩn","name_vi":"Từ Chẩn Chẩn","name_original":"Xu Zhenzhen","tmdb_id":1747017,"profile":"https://image.tmdb.org/t/p/w500/iCmnBNyueTJBa1V40m5zHswyffd.jpg","tmdb_url":"https://www.themoviedb.org/person/1747017"},{"name":"Zhu Minxin","name_vi":null,"name_original":"Zhu Minxin","tmdb_id":3092426,"profile":"https://image.tmdb.org/t/p/w500/aLkfFhOQJmg32immXMiBPurIZg5.jpg","tmdb_url":"https://www.themoviedb.org/person/3092426"},{"name":"He Shi","name_vi":null,"name_original":"He Shi","tmdb_id":4858973,"profile":"https://image.tmdb.org/t/p/w500/zdtpu4kJALIwYuswn48riSpgEh7.jpg","tmdb_url":"https://www.themoviedb.org/person/4858973"},{"name":"Gao Kai","name_vi":null,"name_original":"Gao Kai","tmdb_id":3331574,"profile":"https://image.tmdb.org/t/p/w500/zQbChrrjZWnVt6lDbUBttut9t8I.jpg","tmdb_url":"https://www.themoviedb.org/person/3331574"},{"name":"Zhu Xinyuan","name_vi":null,"name_original":"Zhu Xinyuan","tmdb_id":3273819,"profile":"https://image.tmdb.org/t/p/w500/peq8BVtTRS7qFv1CSojlAryOWuO.jpg","tmdb_url":"https://www.themoviedb.org/person/3273819"},{"name":"Zhang Zhexu","name_vi":null,"name_original":"Zhang Zhexu","tmdb_id":5356665,"profile":"https://image.tmdb.org/t/p/w500/iluYHpr2aC58ltGQMMo2imI0e0S.jpg","tmdb_url":"https://www.themoviedb.org/person/5356665"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/du/du-quan-hanh.json"}