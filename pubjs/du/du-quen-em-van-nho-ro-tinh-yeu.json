ột tổng tài lạnh lùng của chuỗi khách sạn lớn nhất châu Á. Trong một lần tình cờ, anh gặp gỡ Diệp Thiên Ngữ – một cô gái mê tiền và mơ ước được lấy chồng giàu. Giữa hai người họ đã xảy ra xích mích. Sau đó Thiện Tuấn Hạo không may bị tao nạn giao thông và mất đi trí nhớ. Diệp Thiên Ngữ đã cưu mang anh. Từ đó, Thiện Tuấn Hạo trở thành một con người hoàn toàn khác: tốt bụng, dịu dàng và luôn quan tâm đến mọi người. Câu chuyện tình giữa Hoàng tử ếch và nàng Lọ Lem bắt đầu.","tmdb":{"type":"tv","id":"100875","season":1,"vote_average":8.3,"vote_count":4},"modified":"2025-09-25T11:44:55.000Z","cast":["Hình Phi","Kim Trạch","Jiang Xingcheng","Li Zhengjun","Wen Yuan","Jurat","Joyce Zhao","Dong Zhicheng","Dương Mẫn Na","Xue Bowen"],"director":[],"cast_meta":[{"name":"Hình Phi","name_vi":"Hình Phi","name_original":"Xing Fei","tmdb_id":1737082,"profile":"https://image.tmdb.org/t/p/w500/pQaUc5pJRaGwD8iwwzY1Z2YbrEj.jpg","tmdb_url":"https://www.themoviedb.org/person/1737082"},{"name":"Kim Trạch","name_vi":"Kim Trạch","name_original":"Jin Ze","tmdb_id":2595206,"profile":"https://image.tmdb.org/t/p/w500/MOjid8gln59Qpkn4f3COwPS7AS.jpg","tmdb_url":"https://www.themoviedb.org/person/2595206"},{"name":"Jiang Xingcheng","name_vi":null,"name_original":"Jiang Xingcheng","tmdb_id":2523921,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2523921"},{"name":"Li Zhengjun","name_vi":null,"name_original":"Li Zhengjun","tmdb_id":2738546,"profile":"https://image.tmdb.org/t/p/w500/zZCBVzXt6kwXh32Q2e89FwO0b2n.jpg","tmdb_url":"https://www.themoviedb.org/person/2738546"},{"name":"Wen Yuan","name_vi":null,"name_original":"Wen Yuan","tmdb_id":2972066,"profile":"https://image.tmdb.org/t/p/w500/xSY1S6IyRKvAgj4sEGfQ9nXSik4.jpg","tmdb_url":"https://www.themoviedb.org/person/2972066"},{"name":"Jurat","name_vi":null,"name_original":"Jurat","tmdb_id":3764025,"profile":"https://image.tmdb.org/t/p/w500/ygPmnD0drGl5QWYKoGpg6ZLK55H.jpg","tmdb_url":"https://www.themoviedb.org/person/3764025"},{"name":"J