12.com/share/751f915c24612ce66dba400a86a0909b","link_m3u8":"https://vip.opstream12.com/20220329/6541_05839f22/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream10.com/share/f471223d1a1614b58a7dc45c9d01df19","link_m3u8":"https://vip.opstream10.com/20220330/3340_0088e3ee/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream10.com/share/acf06cdd9c744f969958e1f085554c8b","link_m3u8":"https://vip.opstream10.com/20220330/3341_065d432f/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/383beaea4aa57dd8202dbff464fee3af","link_m3u8":"https://vip.opstream12.com/20220331/6993_82b55604/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/70d31b87bd021441e5e6bf23eb84a306","link_m3u8":"https://vip.opstream12.com/20220331/6994_c2f9f91f/index.m3u8"}]}],"description":"<p>Phim xoay quanh câu chuyện Lâm Chi Hiệu - sinh viên năm 4 trước khi tốt nghiệp đại học đã vấp phải những khó khăn nhất của đời người khi cha mắc bệnh nằm viện, không thể từ bỏ cơ hội làm việc ở nước ngoài, lại phải chia tay với bạn trai. Tất cả những những sự tốt đẹp của tình yêu và cuộc sống tương lai đều bị hủy hoại hết vào thời khắc này. Nhưng trùng hợp thay, Cố Ngụy - bác sĩ của bệnh viện mà cha Lâm Chi Hiệu ở đã bước vào cuộc sống của cô. Hai người họ từng chịu vết thương trong chuyện tình cảm nên không còn tin tưởng mấy vào tình yêu. Nhưng cả hai từng bước từng bước từ quen biết đến yêu thương nhau. Từng có hiểu lầm cũng như vấp phải những chuyện không vui, nhưng trong quá trình họ càng ngày càng phát hiện đối phương thực sự là nửa kia đáng phó thác trong quãng đời còn lại của mình.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/du-sinh-xin-chi-giao-nhieu-hon-quang-doi-con-lai-xin-chi-giao-nhieu-hon.json"}