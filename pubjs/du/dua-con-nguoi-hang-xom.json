{"id":"68ff2e9df12b874482d17274","title":"Đứa Con Người Hàng Xóm","origin_name":"The Neighbor's Son","slug":"dua-con-nguoi-hang-xom","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/du/dua-con-nguoi-hang-xom.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/du/dua-con-nguoi-hang-xom.webp","year":"1981","type":"single","genre":[{"name":"Chiến Tranh","slug":"chien-tranh"}],"country":[{"name":"Việt Nam","slug":"viet-nam"}],"lang_key":"Lồng Tiếng","episode_current":"Full","quality":"HD","modified":"2025-10-27T15:47:33.000Z","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"name":"Việt Nam #1","slug":"vietsub-1","server_name":"Việt Nam #1","server_data":[{"name":"Full","slug":"full","link_embed":"https://vip.opstream13.com/share/4223a1d5b9e017dda51515829140e5d2","link_m3u8":"https://vip.opstream13.com/20251022/13652_4223a1d5/index.m3u8"}]}],"description":"Đứa con người hàng xóm là bộ phim Việt Nam cũ của đạo diễn Hà Trọng với sự tham gia của các diễn viên Minh Châu, Cao Khương.  Trong phim, chị Thuận sống ở xóm trài ven biển. Túc Sẹo là hàng xóm của chị, y có quá khứ bất hảo, bị đi tù vì trộm cắp tài sản nhà nước. Túc Sẹo nghi ngờ chị Thuận là người đã tố giác y, nên rất hận chị.  Ra tù, hắn rắp tâm trả thù. Nhưng trong lúc ở tù con trai của hắn sống lang thang không nơi nương tựa, chị Thuận đã cưu mang nó. Túc Sẹo đã tỉnh ngộ, không để Tư Ất, một trùm lưu manh lôi kéo vào con đường tội lỗi. Không lôi kéo được Túc Sẹo, Tư Ất bắt con trai hắn, ám hại chị Thuận. Công an vây bắt được Tư Ất khi hắn đang tìm đường trốn chạy.","tmdb_id":677720,"cast":["Minh Châu","Cao Khương","Viết Liên","Lê Mai","Mạnh Sinh"],"director":["Van Trong Ha"],"keywords":[],"tmdb":{"type":"movie","id":"677720","season":null,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Minh Châu","name_vi":"Minh Châu","name_original":"Minh Châu","tmdb_id":2752751,"profile":"ht