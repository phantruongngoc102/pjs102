ật thay thế. Khi thế thân và danh tính thật hợp lại, lại lỡ làng một đoạn lương duyên đích thực</p>","tmdb":{"type":"movie","id":"1059859","season":null,"vote_average":3,"vote_count":1},"modified":"2025-04-28T14:30:22.000Z","cast":["Lại Vũ Mông","Jia Zhengyu","Yang Jingru","Fu Qianwen","Yun Xiang"],"director":["Song Hai Bo"],"cast_meta":[{"name":"Lại Vũ Mông","name_vi":"Lại Vũ Mông","name_original":"Lai Yumeng","tmdb_id":2184051,"profile":"https://image.tmdb.org/t/p/w500/1EOwf0wQ7wtVPUGDIb6QXBADPgN.jpg","tmdb_url":"https://www.themoviedb.org/person/2184051"},{"name":"Jia Zhengyu","name_vi":null,"name_original":"Jia Zhengyu","tmdb_id":590036,"profile":"https://image.tmdb.org/t/p/w500/pVpiBkfl7d5b9R7NAqGxShhZkNc.jpg","tmdb_url":"https://www.themoviedb.org/person/590036"},{"name":"Yang Jingru","name_vi":null,"name_original":"Yang Jingru","tmdb_id":2593868,"profile":"https://image.tmdb.org/t/p/w500/hQOQbymt5245OPw0AMiLGWQSn4r.jpg","tmdb_url":"https://www.themoviedb.org/person/2593868"},{"name":"Fu Qianwen","name_vi":null,"name_original":"Fu Qianwen","tmdb_id":3852554,"profile":"https://image.tmdb.org/t/p/w500/TX45EdQQ2XTCIVCCq12a97BCuR.jpg","tmdb_url":"https://www.themoviedb.org/person/3852554"},{"name":"Yun Xiang","name_vi":null,"name_original":"Yun Xiang","tmdb_id":3093349,"profile":"https://image.tmdb.org/t/p/w500/g717Uc66uRuq0gqWPCLiNamn4jm.jpg","tmdb_url":"https://www.themoviedb.org/person/3093349"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/duc-hoa-mau-dan.json"}