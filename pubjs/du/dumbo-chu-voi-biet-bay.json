ho công viên giải trí Dreamland của hắn. Dumbo vút bay đến một tầm cao mới cùng với nghệ sĩ xiếc Colette Marchant (Eva Green) cho đến khi Holt phát hiện ra những bí ẩn đen tối đằng sau vẻ ngoài hào nhoáng của Dreamland</p>","tmdb":{"type":"movie","id":"329996","season":null,"vote_average":6.6,"vote_count":4480},"modified":"2023-09-03T10:55:37.000Z","cast":["Colin Farrell","Michael Keaton","Danny DeVito","Eva Green","Nico Parker","Finley Hobbins","Alan Arkin","Roshan Seth","Deobia Oparei","Joseph Gatt","Douglas Reith","Sharon Rooney","Michael Buffer","Zenaida Alcalde","Miguel Muñoz Segura"],"director":["Tim Burton"],"cast_meta":[{"name":"Colin Farrell","name_vi":null,"name_original":"Colin Farrell","tmdb_id":72466,"profile":"https://image.tmdb.org/t/p/w500/oyQVfpowL9eSudYhwoPGkd9WxS7.jpg","tmdb_url":"https://www.themoviedb.org/person/72466"},{"name":"Michael Keaton","name_vi":null,"name_original":"Michael Keaton","tmdb_id":2232,"profile":"https://image.tmdb.org/t/p/w500/tYSja1KByFnZ4Hkp3stPqkKHnNL.jpg","tmdb_url":"https://www.themoviedb.org/person/2232"},{"name":"Danny DeVito","name_vi":null,"name_original":"Danny DeVito","tmdb_id":518,"profile":"https://image.tmdb.org/t/p/w500/6kO4IN7ndoIGw2JhyhAQN3SFmdx.jpg","tmdb_url":"https://www.themoviedb.org/person/518"},{"name":"Eva Green","name_vi":null,"name_original":"Eva Green","tmdb_id":10912,"profile":"https://image.tmdb.org/t/p/w500/8MqXy7Jd6HsRSBFK05J0KrR2x5Z.jpg","tmdb_url":"https://www.themoviedb.org/person/10912"},{"name":"Nico Parker","name_vi":null,"name_original":"Nico Parker","tmdb_id":2064124,"profile":"https://image.tmdb.org/t/p/w500/gt0NJClVSCPCEfcPgcLj3f85uLa.jpg","tmdb_url":"https://www.themoviedb.org/person/2064124"},{"name":"Finley Hobbins","name_vi":null,"name_original":"Finley Hobbins","tmdb_id":2064125,"profile":"https://image.tmdb.org/t/p/w500/nOzsSOl1nIHANMARS6tPotVXliu.jpg","tmdb_url":"https://www.themoviedb.org/person/2064125"},{"name":"Alan Arkin","name_vi":null,"name_original":"Alan Arkin","tmdb