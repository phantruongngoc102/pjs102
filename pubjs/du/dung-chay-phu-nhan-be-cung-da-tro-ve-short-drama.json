tream-short.com/share/1c9ec0091cc7ff3314655c0dfd09db85","link_m3u8":"https://vip.opstream-short.com/20251118/33997_1c9ec009/index.m3u8"},{"name":"60","slug":"60","link_embed":"https://vip.opstream-short.com/share/005f4666bf5b2ac98530f20c67b5ab52","link_m3u8":"https://vip.opstream-short.com/20251118/33998_005f4666/index.m3u8"},{"name":"61","slug":"61","link_embed":"https://vip.opstream-short.com/share/d67c5b78d7386c6026c1ecb1b4c6d585","link_m3u8":"https://vip.opstream-short.com/20251118/33999_d67c5b78/index.m3u8"},{"name":"62","slug":"62","link_embed":"https://vip.opstream-short.com/share/d84bd56368eda057bc128981c6b1e2ae","link_m3u8":"https://vip.opstream-short.com/20251118/34000_d84bd563/index.m3u8"},{"name":"63","slug":"63","link_embed":"https://vip.opstream-short.com/share/3c50c0cf057cb8aab8bf3fb28b711b6a","link_m3u8":"https://vip.opstream-short.com/20251118/34001_3c50c0cf/index.m3u8"},{"name":"64","slug":"64","link_embed":"https://vip.opstream-short.com/share/d748a600fe89a6abd01b174e8d2eb35c","link_m3u8":"https://vip.opstream-short.com/20251118/34002_d748a600/index.m3u8"},{"name":"65","slug":"65","link_embed":"https://vip.opstream-short.com/share/8411899c3d68aa07d7d142ed8e13833b","link_m3u8":"https://vip.opstream-short.com/20251118/34003_8411899c/index.m3u8"}]}],"description":"<p>Năm năm trước, Nhan Trúc bị em gái hãm hai ở nước ngoài và tình cờ gặp Phó Bạc Ngôn. Dù phải đối mặt với sự phản đối và непонимание của gia đình, cô dũng cảm sinh con, điều này khiến cô bị ô nhục và bị đuổi khỏi gia tộc họ Nhan. Nhan Trúc buộc phải một mình nuôi con. Phó Bạc Ngôn, người thừa kế Tập đoàn Phó và thủ lĩnh gia tộc giàu có, đã tìm kiếm cô từ cuộc gặp định mệnh đó. Năm năm sau, họ gặp lại nhau. Dù có thù hận gia tộc, sự can thiệp của đối thủ và nhiều trở ngại, tình yêu của họ vẫn mạnh mẽ. Họ cùng đối mặt với âm mưu gia đình, khủng hoảng sự nghiệp và sự phản bội. Khi phẩm giá của Nhan Trúc bị thử thách, Phó Bạc Ngôn đứng bên cạnh cô, giúp vượt qua những âm mưu gia đình. Cùng nhau họ đối mặt với thử thách tình yêu trong câu chuyện đam mê và báo thù giữa giới thượng lưu giàu có.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/dung-chay-phu-nhan-be-cung-da-tro-ve-short-drama.json"}