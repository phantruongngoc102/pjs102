618020f77accdc22dc65a26bfe2b44","link_m3u8":"https://vip.opstream10.com/20230529/27433_9c66e198/index.m3u8"}]}],"time":"10 phút/ tập","description":"<p>Sau cái chết bất ngờ của cha mẹ, hai chị em phải tự lo cho bản thân. Những tin đồn lan truyền trong khu phố rằng họ đã nhận được một số tiền bồi thường lớn, nhưng cả hai không bao giờ trả lời. Khi họ lớn lên, họ từng kết hôn. Không ngờ, chị chồng đòi bồi thường thì em chồng lại bạo hành, vô tâm. Sau khi nhìn rõ bộ mặt thật của chồng, hai chị em đã chung sức chống trả và bước tiếp một cuộc sống mới tốt đẹp hơn.</p>","tmdb":{"type":"tv","id":"226798","season":1,"vote_average":0,"vote_count":0},"modified":"2025-03-30T15:03:36.000Z","cast":["Mu Le'en","Dong Xinyun","Zhang Aiyue","Huang Ruoyuan","Li Xinghao"],"director":[],"cast_meta":[{"name":"Mu Le'en","name_vi":null,"name_original":"Mu Le'en","tmdb_id":2359899,"profile":"https://image.tmdb.org/t/p/w500/fRfFU0VR6OBYgIQGypCGi7BoJ0N.jpg","tmdb_url":"https://www.themoviedb.org/person/2359899"},{"name":"Dong Xinyun","name_vi":null,"name_original":"Dong Xinyun","tmdb_id":3378075,"profile":"https://image.tmdb.org/t/p/w500/ll0A2IGkdQ0s3xp2cxcFEHOs4au.jpg","tmdb_url":"https://www.themoviedb.org/person/3378075"},{"name":"Zhang Aiyue","name_vi":null,"name_original":"Zhang Aiyue","tmdb_id":2476670,"profile":"https://image.tmdb.org/t/p/w500/na0NuVt9Lwiq3XL7NhQBANh6v4F.jpg","tmdb_url":"https://www.themoviedb.org/person/2476670"},{"name":"Huang Ruoyuan","name_vi":null,"name_original":"Huang Ruoyuan","tmdb_id":4511339,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4511339"},{"name":"Li Xinghao","name_vi":null,"name_original":"Li Xinghao","tmdb_id":4511346,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4511346"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/dung-lua-doi-toi.json"}