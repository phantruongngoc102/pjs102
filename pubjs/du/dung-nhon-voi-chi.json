4.com/share/391e1830d381c2f388575154a12b19a8","link_m3u8":"https://vip.opstream14.com/20220520/12190_c8936010/index.m3u8"},{"name":"16","slug":"16","filename":"Đừng Nhờn Với Chị - Tập 16","link_embed":"https://vip.opstream14.com/share/c4c28b367e14df88993ad475dedf6b77","link_m3u8":"https://vip.opstream14.com/20220520/12191_52a7ce41/index.m3u8"},{"name":"17","slug":"17","filename":"Đừng Nhờn Với Chị - Tập 17","link_embed":"https://vip.opstream14.com/share/1b0251ccb8bd5f9ccf444e4bda7713e3","link_m3u8":"https://vip.opstream14.com/20220520/12241_1414462d/index.m3u8"},{"name":"18","slug":"18","filename":"Đừng Nhờn Với Chị - Tập 18","link_embed":"https://vip.opstream14.com/share/47a878d199b3fcb8447a9a1b3a78ee73","link_m3u8":"https://vip.opstream14.com/20220520/12242_8124fbaa/index.m3u8"},{"name":"19","slug":"19","filename":"Đừng Nhờn Với Chị - Tập 19","link_embed":"https://vip.opstream16.com/share/b7a09dca296f4517c1c7b5ca5e72c412","link_m3u8":"https://vip.opstream16.com/20220521/14912_f59a0198/index.m3u8"},{"name":"20","slug":"20","filename":"Đừng Nhờn Với Chị - Tập 20","link_embed":"https://vip.opstream16.com/share/c06b57c153593ad97339f96585f6692a","link_m3u8":"https://vip.opstream16.com/20220521/14913_57ff4845/index.m3u8"}]}],"time":"15 phút/tập","description":"<p>Jin Rong Rong, tổng giám đốc kiên quyết của tập đoàn Jinchao, đã gặp Gu Cong Bei, một ca sĩ của một quán bar, trên đường bí mật kiểm tra hoạt động của khu kinh doanh.<br>Sau một đêm say xỉn Jin Rong Rong biết rằng Gu Cong Bei vẫn còn là một sinh viên đại học, và kinh nghiệm tình yêu bằng không, cô giả vờ bình tĩnh và tuyên bố phải chịu trách nhiệm với anh ta. Thật trùng hợp khi Jin Rong Rong đến văn phòng hẹn hò, cô bất ngờ phát hiện ra rằng Gu Cong Bei là con trai thứ ba của gia đình họ Gu, và cũng có nhu cầu kết hôn, vì vậy cô quyết định chọn anh làm đối tượng kết hôn của mình. Điều mà cô không biết là Gu Cong Bei đang cố tình đến gần cô.<br>Giờ đây, về chung sống dưới một mái nhà sau khi kết hôn, Gu Cong Bei nhận thấy Jin Rong Rong khác biệt, độc nhất nhưng Jin Rong Rong cũng rất kín tiếng và không chịu công khai với chồng mới về lý do cô sợ lạnh. Khi sự thật và động cơ bắt đầu xuất hiện, liệu hai người này có thể vượt qua những thử thách đang xảy ra?</p>","tmdb":{"type":"tv","id":"201920","season":1,"vote_average":6.9,"vote_count":16},"modified":"2022-05-21T13:38:33.000Z","cast":["Yang Ze","Lục Nghiên Kỳ","Ni Hanjin","Yang Dachuan"],"director":[],"cast_meta":[{"name":"Yang Ze","name_vi":null,"name_original":"Yang Ze","tmdb_id":2494668,"profile":"https://image.tmdb.org/t/p/w500/9CUVdHRklKsufhY0EiJfxcvdKi5.jpg","tmdb_url":"https://www.themoviedb.org/person/2494668"},{"name":"Lục Nghiên Kỳ","name_vi":"Lục Nghiên Kỳ","name_original":"Lu Yanqi","tmdb_id":2317989,"profile":"https://image.tmdb.org/t/p/w500/mX7isDFH6NlXzZhLZnHTUFpdKo9.jpg","tmdb_url":"https://www.themoviedb.org/person/2317989"},{"name":"Ni Hanjin","name_vi":null,"name_original":"Ni Hanjin","tmdb_id":2456847,"profile":"https://image.tmdb.org/t/p/w500/xLOwqZIT9QIcbm9BzX0AGQFdPC0.jpg","tmdb_url":"https://www.themoviedb.org/person/2456847"},{"name":"Yang Dachuan","name_vi":null,"name_original":"Yang Dachuan","tmdb_id":3857245,"profile":"https://image.tmdb.org/t/p/w500/pbD7nws0evraNmmWuOFtNrosyZl.jpg","tmdb_url":"https://www.themoviedb.org/person/3857245"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/dung-nhon-voi-chi.json"}