ea72","link_m3u8":"https://vip.opstream13.com/20250920/9012_c5c53759/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream13.com/share/17ab7b5bb7ca18f6d5f33dfbcbaee1a2","link_m3u8":"https://vip.opstream13.com/20250920/9013_17ab7b5b/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream13.com/share/dc554706afe4c72a60a25314cbaece80","link_m3u8":"https://vip.opstream13.com/20250920/9014_dc554706/index.m3u8"}]}],"description":"<p>Hứa Dịch Nhân mất cả tình yêu lẫn sự nghiệp chỉ sau một đêm. Người bạn thân của cô, Hạ Địch, giới thiệu cô đến một công ty kiến ​​trúc làm trợ lý cho CEO. Tuy nhiên, trong buổi phỏng vấn, cô phát hiện ra CEO chính là người đã vạch trần chuyện bạn trai cô ngoại tình, Phương Chí Hữu. Dù không hiểu tại sao, cuối cùng Hứa Dịch Nhân cũng được nhận vào làm, nhưng lại phải đối mặt với một nhiệm vụ kỳ lạ - nói dối thay sếp. Nhưng việc Phương Chí Hữu thường xuyên vạch trần lời nói dối của mình trước công chúng luôn khiến cô rơi vào những tình huống khó khăn.</p>","tmdb_id":105430,"cast":["Lương Khiết","Tân Vân Lai","Lưu Hải Khoan","La Thu Vận","Ngô Quý Phong","Chen Shimin","Liu Luoxi","Su Zishan","Aoyu Xiang","Gao Qifan","Đoàn Nghi Hiên","Li Baixin","Chen Liyang","Ma Haifeng","Baomu Zhongyang"],"director":["Li Yian Qian","Zhu Dong Ning"],"keywords":[],"tmdb":{"type":"tv","id":"105430","season":1,"vote_average":7.8,"vote_count":5},"cast_meta":[{"name":"Lương Khiết","name_vi":"Lương Khiết","name_original":"Liang Jie","tmdb_id":1855300,"profile":"https://image.tmdb.org/t/p/w500/pYYvBkKizMO8vulvZNNdqEkEYPL.jpg","tmdb_url":"https://www.themoviedb.org/person/1855300"},{"name":"Tân Vân Lai","name_vi":"Tân Vân Lai","name_original":"Xin Yunlai","tmdb_id":2174696,"profile":"https://image.tmdb.org/t/p/w500/2HZ9v5Bi8uADMFNfghzrEcD7dws.jpg","tmdb_url":"https://www.themoviedb.org/person/2174696"},{"name":"Lưu Hải Khoan","name_vi":"Lưu Hải Khoan","name_original":"Liu Haikuan","tmdb_id":2340874,"profile":"https://image.tmdb.org/t/p/