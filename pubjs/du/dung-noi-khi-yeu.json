share/519edc8db508d1c088f793f2c3647e6f","link_m3u8":"https://vip.opstream13.com/20251128/20157_519edc8d/index.m3u8"},{"name":"25","slug":"25","filename":"Đừng Nói Khi Yêu S01E25","link_embed":"https://vip.opstream13.com/share/212112eece862ca4a3da112f217288fb","link_m3u8":"https://vip.opstream13.com/20251128/20158_212112ee/index.m3u8"},{"name":"26","slug":"26","filename":"Đừng Nói Khi Yêu S01E26","link_embed":"https://vip.opstream13.com/share/9f4241002d82d931ad8c5cec67f17e9a","link_m3u8":"https://vip.opstream13.com/20251128/20159_9f424100/index.m3u8"},{"name":"27","slug":"27","filename":"Đừng Nói Khi Yêu S01E27","link_embed":"https://vip.opstream13.com/share/293131be3fe9d60523ebbc6dd0c2e5c3","link_m3u8":"https://vip.opstream13.com/20251128/20160_293131be/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Đừng nói khi yêu</i> là câu chuyện \"trên tình bạn, dưới tình yêu\" của Ly (Thùy Anh) – Tú (Đình Tú) và hành trình trưởng thành của họ. Ly và Tú là bạn thân cùng lớn lên bên nhau, học chung từ mẫu giáo đến cấp 2. Cả hai thân thiết như chị em. Tình bạn đó luôn là niềm tự hào của Ly và Tú cho đến khi thế giới của họ xuất hiện \"đối tượng yêu đương\". Những chia sẻ vốn là đương nhiên, những gần gũi vốn là bình thường bỗng trở nên không còn bình thường nữa. Bản thân mỗi người trong họ, cũng vì những chia sẻ tình cảm của bạn thân cho người khác mà không tránh khỏi hụt hẫng, ghen tị.</p>","tmdb":{"type":"tv","id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2025-12-01T15:03:03.000Z","cast":["Mạnh Trường","Thùy Anh","Đình Tú","Trình Mỹ Duyên","Tú Oanh","Đức Khuê","Xuân Trường","Quách Thu Phương","Lương Thanh","Nguyễn Hoàng Ngọc Huyền","Thái Dũng"],"director":["Bùi Tiến Huy"],"cast_meta":[{"name":"Mạnh Trường","name_vi":null,"name_original":"Mạnh Trường"},{"name":"Thùy Anh","name_vi":null,"name_original":"Thùy Anh"},{"name":"Đình Tú","name_vi":null,"name_original":"Đình Tú"},{"name":"Trình Mỹ Duyên","name_vi":null,"name_original":"Trình Mỹ Duyên"},{"n