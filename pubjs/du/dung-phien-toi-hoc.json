m/share/f095cedd23b99f1696fc8caecbcf257e","link_m3u8":"https://vip.opstream11.com/20220322/3667_fee6029a/index.m3u8"},{"name":"22","slug":"22","filename":"Đừng Phiền Tôi Học - Don't Disturb My Learning - Tập 22","link_embed":"https://vip.opstream11.com/share/e1228be46de6a0234ac22ded31417bc7","link_m3u8":"https://vip.opstream11.com/20220322/3669_5a3a055a/index.m3u8"},{"name":"23","slug":"23","filename":"Đừng Phiền Tôi Học - Don't Disturb My Learning - Tập 23","link_embed":"https://vip.opstream11.com/share/77ec6f21c85b637cc42bb997841e11a6","link_m3u8":"https://vip.opstream11.com/20220322/3670_53d59e0e/index.m3u8"},{"name":"24","slug":"24","filename":"Đừng Phiền Tôi Học - Don't Disturb My Learning - Tập 24","link_embed":"https://vip.opstream11.com/share/54ebdfbbfe6c31c39aaba9a1ee83860a","link_m3u8":"https://vip.opstream11.com/20220322/3671_99f4cae1/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Đừng Phiền Tôi Học - Don't Disturb My Learning xoay quanh cuộc sống của Nam Hướng Vãn (Lý Lan Địch) - một cô gái thông minh, xinh đẹp và đầy quyết tâm. Mới 28 tuổi nhưng cô đã là giám đốc nhân sự của một xí nghiệp lớn. Vì thành tích bá đạo thời trung học mà cô mắc chứng bệnh kỳ thị bằng cấp, bên ngoài thể hiện cuộc sống vẫn ổn, nhưng trong lòng lại vô cùng lo lắng. Chính vì thế mà cô phải điều trị tâm lý bằng những công nghệ mới, và điều đó vô tình đưa Hướng Vãn về lại ký ức của 10 năm trước, đối mặt với những chuyện cũ. Tuy nhiên, lần này trở về hoàn toàn khác so với cô của trước kia.</p>","tmdb":{"type":"tv","id":"120561","season":1,"vote_average":6.2,"vote_count":4},"modified":"2022-06-09T11:27:21.000Z","cast":["Lý Lan Địch","Lai Guan-lin","Vương Nhuận Trạch","Chen Shujun","Zhao Luoran","Zhang Cheng","Wu Yang","Liang Dawei","Liu Chao","Bai Yufei","Johnson Wang","Chen Yu Er","Zhang Zijian","Zhao Xuan"],"director":["Trần Phi Hồng"],"cast_meta":[{"name":"Lý Lan Địch","name_vi":"Lý Lan Địch","name_original":"Li Landi","tmdb_id":1909812,"profile":"https://image.tmdb.org/t/