stream90.com/share/6872937617af85db5a39a5243e858d1f","link_m3u8":"https://vip.opstream90.com/20250719/9005_68729376/index.m3u8"},{"name":"24","slug":"24","filename":"Dược sư tự sự_S02E48_Khởi đầu","link_embed":"https://vip.opstream90.com/share/831da40e5907987235ebe5616446e083","link_m3u8":"https://vip.opstream90.com/20250719/9006_831da40e/index.m3u8"}]}],"time":"23 phút/tập","description":"Trong triều đình phong kiến Trung Quốc, một vài tháng đã trôi qua kể từ khi bé gái 17 tuổi có tên Miêu Miêu bị bắt cóc và bị buộc làm người hầu cấp thấp trong cung điện hoàng gia. Tuy nhiên, cô bé vẫn giữ tinh thần tích cực và cứ làm việc cho đến mãn hạn. Một ngày nọ, cô đã nghe tin hai đứa con của hoàng đế bị mắc bệnh nặng. Tại đây, cô đã quyết định hành động bí mật dựa vào những kinh nghiệm có sẵn từ phố đèn đỏ nghèo để cứu chữa.\n\nMặc dù đã cố gắng ở ẩn nhưng Miêu Miêu lại nhanh chóng gây sự chú ý với Jinshi, một người có quyền lực nhận ra tài năng của cô. Từ đây, thân phận thực sự của Miêu Miêu được tiết lộ với những bí ẩn về y học đa dạng.","tmdb":{"type":"tv","id":"220542","season":2,"vote_average":8.6,"vote_count":469},"modified":"2025-07-19T00:15:22.000Z","cast":["Aoi Yuuki","Takeo Otsuka","Katsuyuki Konishi"],"director":[],"cast_meta":[{"name":"Aoi Yuuki","name_vi":null,"name_original":"Aoi Yuuki","tmdb_id":936275,"profile":"https://image.tmdb.org/t/p/w500/a5Mkd66GV1l3c9bZZtnvjUf33T2.jpg","tmdb_url":"https://www.themoviedb.org/person/936275"},{"name":"Takeo Otsuka","name_vi":null,"name_original":"Takeo Otsuka","tmdb_id":1279666,"profile":"https://image.tmdb.org/t/p/w500/wqeAMR0HOGUPBXz0TCNxDR51cQy.jpg","tmdb_url":"https://www.themoviedb.org/person/1279666"},{"name":"Katsuyuki Konishi","name_vi":null,"name_original":"Katsuyuki Konishi","tmdb_id":24647,"profile":"https://image.tmdb.org/t/p/w500/nYM5cH6U7cp4x9dIzW0enmEKmeV.jpg","tmdb_url":"https://www.themoviedb.org/person/24647"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/duoc-s