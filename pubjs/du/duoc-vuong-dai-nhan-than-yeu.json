3/index.m3u8"},{"name":"23","slug":"23","filename":"duoc-vuong-dai-nhan-than-yeu-thuyet-minh-dear-herbal-lord-tap-23","link_embed":"https://vip.opstream10.com/share/a82aac2169c9a76e374b2f4c96bfa0a0","link_m3u8":"https://vip.opstream10.com/20220429/11087_e83deff3/index.m3u8"},{"name":"24","slug":"24","filename":"duoc-vuong-dai-nhan-than-yeu-thuyet-minh-dear-herbal-lord-tap-24","link_embed":"https://vip.opstream10.com/share/f508afaa848fefb2033d262ad7237a5c","link_m3u8":"https://vip.opstream10.com/20220429/11091_99808ad1/index.m3u8"}]}],"time":"29M10S","description":"<p>Tiểu Tùng Lam một lòng muốn tu luyện thành chính quả, nhưng không ngờ âm dương sai lối bị quận chúa ăn luôn vào bụng. Để sớm được đắc đạo thành tiên, nàng đành phải đâm lao theo lao ép hôn “Dược Vương” Sở Chi Mặc, hòng hấp thụ dược khí trên người hắn. Mặc dù cây Bản Lam Căn này hơi ngốc, nhưng lại rất cố chấp. Nàng ngó lơ sự lạnh lùng của Sở Chi Mặc, trăm phương nghìn kế quyết tâm phải gả bằng được cho hắn. Trước đó, nàng còn cố tình về núi Trầm Hương, gọi hết mấy người tiên hữu thân thiết với mình đến nhân gian, để họ giúp nàng theo đuổi tình yêu. Thế mới có hàng loạt hành động cọc đi tìm trâu vừa ngốc vừa đáng yêu, đồng thời cũng từ đó mà “tìm lại được” tình yêu chân thành nhất, để cùng nhau viết nên câu chuyện chống lại “Ôn Thần”, giải cứu nhân thế.</p>","tmdb":{"type":"tv","id":"107596","season":1,"vote_average":0,"vote_count":0},"modified":"2023-04-11T19:32:21.000Z","cast":["Ding Yiyi","Yan Xi","Leo Yang","Liu Yu"],"director":["Hu Chu Xi"],"cast_meta":[{"name":"Ding Yiyi","name_vi":null,"name_original":"Ding Yiyi","tmdb_id":3236620,"profile":"https://image.tmdb.org/t/p/w500/m01lnHw63FT82mp9TpR0rpYizMB.jpg","tmdb_url":"https://www.themoviedb.org/person/3236620"},{"name":"Yan Xi","name_vi":null,"name_original":"Yan Xi","tmdb_id":2378290,"profile":"https://image.tmdb.org/t/p/w500/9rGDX6yyWcD8nOIk9vc7ptbyMQv.jpg","tmdb_url":"https://www.themoviedb.org/person/2378290"},{"name":"Leo Yang","name_vi":null,