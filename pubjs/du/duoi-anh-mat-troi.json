/vip.opstream13.com/share/8ea9805479ddb07d9183081b059dd0d2","link_m3u8":"https://vip.opstream13.com/20251027/14412_8ea98054/index.m3u8"}]}],"description":"<p>Xem trọng việc phát triển sự nghiệp, Tống Tư Ngưng và chồng thường xuyên mâu thuẫn về vấn đề sinh con thứ hai. Sự xuất hiện của cậu em trai Duy Nhất và vợ là Khả Doanh lại càng khiến Tư Ngưng phải đối mặt với nhiều căng thẳng hơn. Trong khi đó, sếp của cô là Trần Tụng Anh lại bắt đầu thay đổi suy nghĩ về thỏa thuận hôn nhân không con cái giữa cô và chồng bấy lâu nay. Thông qua câu chuyện của ba người phụ nữ ở ba giai đoạn khác nhau của cuộc đời, phim khắc họa chân thực và sinh động đời sống tình yêu, hôn nhân, sự nghiệp và việc nuôi dạy con cái trong thời đại hiện nay.</p>","tmdb_id":137111,"cast":["Cao Lộ","Jiang Yi","Trần Tử Hàm","Quách Hiểu Đông","Chen Siche","Leng Jiyuan","Liu Tingyu","Liu Enyou","Li Zheng Yan Qi","Wen Haibo","Fang Qingzhuo"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"137111","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Cao Lộ","name_vi":"Cao Lộ","name_original":"Gao Lu","tmdb_id":1630009,"profile":"https://image.tmdb.org/t/p/w500/q4ubJjkZoHV48CKc8FOZD3KZHXa.jpg","tmdb_url":"https://www.themoviedb.org/person/1630009"},{"name":"Jiang Yi","name_vi":null,"name_original":"Jiang Yi","tmdb_id":1183508,"profile":"https://image.tmdb.org/t/p/w500/Ac0UhirgvMItkDH2QYG7LsxH6oH.jpg","tmdb_url":"https://www.themoviedb.org/person/1183508"},{"name":"Trần Tử Hàm","name_vi":"Trần Tử Hàm","name_original":"Chen Zihan","tmdb_id":593166,"profile":"https://image.tmdb.org/t/p/w500/xItbxt0SQa6FlA4w0rrlDRH0ghY.jpg","tmdb_url":"https://www.themoviedb.org/person/593166"},{"name":"Quách Hiểu Đông","name_vi":"Quách Hiểu Đông","name_original":"Guo Xiaodong","tmdb_id":116636,"profile":"https://image.tmdb.org/t/p/w500/8CqQFvETwz0FpJyDvKnIMBN3Obj.jpg","tmdb_url":"https://www.themoviedb.org/person/116636"},{"name":"Chen Siche","name_vi":null,"name_original":"Chen Siche","tmdb_id":3563569,"prof