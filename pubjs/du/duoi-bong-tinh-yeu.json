5e52d105","link_m3u8":"https://vip.opstream16.com/20221019/24125_5dac464d/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream16.com/share/3704d4263d1f0a0b2bca7bf7b4d64a58","link_m3u8":"https://vip.opstream16.com/20221019/24126_3bbf9ae8/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream16.com/share/635b616c7d29a7c2a118dc59a578d053","link_m3u8":"https://vip.opstream16.com/20221019/24127_b6326855/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream16.com/share/6f5e6653c2100f36ef017088363ea359","link_m3u8":"https://vip.opstream16.com/20221019/24128_1d4cd87f/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream16.com/share/78c58f11547724e65c6fde2ddc7dfdfc","link_m3u8":"https://vip.opstream16.com/20221019/24129_734c50a1/index.m3u8"}]}],"description":"<p>Câu chuyện bắt đầu vào năm 1921. Jao Karmfah là một nhà quý tộc đến từ Chiang Mai. Như một sự sắp đặt của các thành viên trong gia đình, anh đã đính hôn với Yaowalak. Sau khi trở lại Chiang Mai để kinh doanh, anh đã yêu Fongkae ngay từ cái nhìn đầu tiên. Karmfah quyết định cắt đứt giao ước với Yaowalak để theo đuổi Fongkae. Tuy nhiên, Fongkae đã có một người đàn ông cô ấy yêu, Khun Chai Yingsak Warangkorn. Cha mẹ của Fongkae thích Karmfah làm con rể của họ và nhốt Fongkae đi, trong khi chờ đợi lễ cưới của cô cho Karmfah. Yingsak lẻn vào nhà Fongkae và đưa cô ấy đi. Khi nghe thấy điều này, Karmfah nhanh chóng đuổi theo họ. Khi anh tìm thấy họ, anh nhận ra rằng anh không thể ép buộc bất cứ ai yêu anh. Cũng như Yaowalak không thể ép anh yêu cô. Anh cho phép họ ở bên nhau, và đưa cho Fongkae một chiếc trâm cài tóc mà anh đã đặc biệt chế tạo cho cô. Fongkae và Yingsak tiếp tục có hai con, Mom Luang Sakchai và Mom Luang Sommapa.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/duoi-bong-tinh-yeu.json"}