s://vip.opstream12.com/20250228/25564_d2f8a028/index.m3u8"},{"name":"26","slug":"26","filename":"Dưới Tán Cây Có Ngôi Nhà Mái Đỏ - Tập 26---2025","link_embed":"https://vip.opstream90.com/share/9edda0fd4d983bf975935cfd492fd50b","link_m3u8":"https://vip.opstream90.com/20250301/3462_9edda0fd/index.m3u8"},{"name":"27","slug":"27","filename":"Dưới Tán Cây Có Ngôi Nhà Mái Đỏ - Tập 27---2025","link_embed":"https://vip.opstream90.com/share/73c03186765e199c116224b68adc5fa0","link_m3u8":"https://vip.opstream90.com/20250301/3463_73c03186/index.m3u8"},{"name":"28","slug":"28","filename":"Dưới Tán Cây Có Ngôi Nhà Mái Đỏ - Tập 28---2025","link_embed":"https://vip.opstream90.com/share/51e6d6e679953c6311757004d8cbbba9","link_m3u8":"https://vip.opstream90.com/20250301/3464_51e6d6e6/index.m3u8"},{"name":"29","slug":"29","filename":"Dưới Tán Cây Có Ngôi Nhà Mái Đỏ - Tập 29---2025","link_embed":"https://vip.opstream90.com/share/797134c3e42371bb4979a462eb2f042a","link_m3u8":"https://vip.opstream90.com/20250301/3465_797134c3/index.m3u8"},{"name":"30","slug":"30","filename":"Dưới Tán Cây Có Ngôi Nhà Mái Đỏ - Tập 30---2025","link_embed":"https://vip.opstream90.com/share/606555cf42a6719782a952aa33cfa2cb","link_m3u8":"https://vip.opstream90.com/20250301/3466_606555cf/index.m3u8"}]}],"time":"40 phút/tập","description":"<p>Cô gái từ thị trấn nhỏ, Trần Hoan Nhĩ, cùng cha mẹ chuyển đến thành phố lớn. Cô và hai người bạn mới quen, Cảnh Tê Trì và Tống Tùng, từ thời cấp ba, đến đại học cho đến khi ra trường, đã cùng nhau trải qua tất cả những cột mốc quan trọng trong cuộc đời. Những ngày tháng giản dị và bình yên với việc học, đi dã ngoại, tham gia hội thể thao, và những chuyến \"sách lưu động\" cũng như những cảm xúc ngọt ngào, nỗi đắng cay của mối tình đơn phương, sự tiếc nuối khi lý tưởng bị gãy vụn, những cú sốc khi đối mặt với biến cố gia đình, và cả sự lúng túng, đau đớn khi lần đầu tiên đối diện với sự ra đi của người thân... Ba người trẻ tuổi này đã luôn giúp đỡ nhau vượt qua nỗi đau của sự trưởng thành, từ những thiếu niên ngây thơ trở thành người lớn hòa nhập với xã hội. Cuối cùng, họ trở thành một phiên bản tốt đẹp nhưng hoàn toàn khác xa với tưởng tượng thời cấp ba. Quan trọng hơn cả là họ luôn đồng hành bên nhau, chưa từng tách rời.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"261600","season":1,"vote_average":8.833,"vote_count":6},"modified":"2025-03-03T15:06:45.000Z","cast":["Trạch Tiêu Văn","Dương Hật Tử","Châu Kha Vũ","Hạc Thu","Chu Hạo Kỳ","Zhang Xuzhen","Xu Shixin","Tùy Viên","Zhao Fanshu"],"director":["Zhang Xiaoan"],"cast_meta":[{"name":"Trạch Tiêu Văn","name_vi":"Trạch Tiêu Văn","name_original":"Zhai Xiaowen","tmdb_id":3133673,"profile":"https://image.tmdb.org/t/p/w500/sX4Fhh35IZxJwultxPSilG8C8Ng.jpg","tmdb_url":"https://www.themoviedb.org/person/3133673"},{"name":"Dương Hật Tử","name_vi":"Dương Hật Tử","name_original":"Yang Xizi","tmdb_id":3159925,"profile":"https://image.tmdb.org/t/p/w500/74ELL78RSLTUnOt6jXsNi5wygML.jpg","tmdb_url":"https://www.themoviedb.org/person/3159925"},{"name":"Châu Kha Vũ","name_vi":"Châu Kha Vũ","name_original":"Daniel Zhou","tmdb_id":2986719,"profile":"https://image.tmdb.org/t/p/w500/vbouvEZoWedKOg7F7GK4UF46yyM.jpg","tmdb_url":"https://www.themoviedb.org/person/2986719"},{"name":"Hạc Thu","name_vi":"Hạc Thu","name_original":"He Qiu","tmdb_id":4773380,"profile":"https://image.tmdb.org/t/p/w500/rRzBOsMr1TS5eJMUs4L4Omdp9T7.jpg","tmdb_url":"https://www.themoviedb.org/person/4773380"},{"name":"Chu Hạo Kỳ","name_vi":"Chu Hạo Kỳ","name_original":"Zhou Haoqi","tmdb_id":5248296,"profile":"https://image.tmdb.org/t/p/w500/tJYcJHOG6TqmrVInPVGtb0O1o7I.jpg","tmdb_url":"https://www.themoviedb.org/person/5248296"},{"name":"Zhang Xuzhen","name_vi":null,"name_original":"Zhang Xuzhen","tmdb_id":4810884,"profile":"https://image.tmdb.org/t/p/w500/ArmA5IJoU7wbVUxLTMBMYb0TJhm.jpg","tmdb_url":"https://www.themoviedb.org/person/4810884"},{"name":"Xu Shixin","name_vi":null,"na