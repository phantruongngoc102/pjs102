":"29","slug":"29","link_embed":"https://vip.opstream90.com/share/7b5f37cf6529d139d0735e31fa4baae4","link_m3u8":"https://vip.opstream90.com/20260220/25468_7b5f37cf/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/aea9789988c08f28538422f1c3427388","link_m3u8":"https://vip.opstream90.com/20260221/25555_aea97899/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream90.com/share/80088112c1b2f1ef9063e0f8ed2f9fe0","link_m3u8":"https://vip.opstream90.com/20260223/25620_80088112/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream90.com/share/f3bda8482463fdd4796e4f3880688643","link_m3u8":"https://vip.opstream90.com/20260223/25621_f3bda848/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream90.com/share/0a8e9d1cf3ee0af0e6526059e1ac59d1","link_m3u8":"https://vip.opstream90.com/20260223/25625_0a8e9d1c/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream90.com/share/8845ac2b3647d7e9dbad5e7dd7474281","link_m3u8":"https://vip.opstream90.com/20260223/25627_8845ac2b/index.m3u8"}]}],"description":"<p>Vào tiết Nguyên Tiêu, công chúa Ninh Viễn chết một cách ly kỳ trong dạ yến, Lý Bội Nghi của Nội Yết Cục và Thái Sử thừa Tiêu Hoài Cẩn của Thái Sử Cục phụng mệnh điều tra. Lý Bội Nghi võ nghệ cao cường lại giỏi nhìn thấu lòng người, vẻ ngoài lạnh lùng nhưng tâm địa lương thiện, một lòng truy tìm chân tướng. Với cô, phá án không chỉ là truy tìm sự thật mà còn là cuộc đấu trí so tài với hung thủ. Dưới sự phối hợp ăn ý với Tiêu Hoài Cẩn tư duy kín kẽ, họ từng bước bóc tách sự thật, thông qua cô gái quyền quý hống hách và Vũ Lâm Lang Tướng Kim Ngô Vệ mang trong mình bí mật, cuối cùng đã điều tra ra chân tướng, tìm được hung thủ. Sau đó, hàng loạt bí mật thâm cung và các vụ án kỳ lạ phức tạp liên tiếp xảy ra trong nội đình Đại Đường. \"Hoa trên tường đá\", \"Huyết Sắc Thiên Tư\", \"Lời đồn bí mật giờ lành\", \"Thất Tinh Thác\" và nhiều vụ án khác liên quan đến số phận của nữ tử hậu cung. Trong quá trình phá án, Lý, Tiêu khám phá những cảnh tượng kỳ vĩ của Đại Đường, cảm nhận tình người kỳ diệu, đồng thời từng bước làm sáng tỏ chân tướng vụ thảm án diệt môn Lý gia 15 năm trước, cuối cùng vạch trần âm mưu của chủ mưu đứng sau. Lý Bội Nghi không chỉ rửa sạch oan khuất cho cha, mà trong quá trình truy tìm chân tướng còn có thêm bạn đồng hành và tìm thấy sự cứu rỗi.</p>","tmdb_id":278127,"cast":["Bạch Lộc","Vương Tinh Việt","Diêu An Na","Triệu Tình","Triệu Dịch Khâm"],"director":["尹涛"],"keywords":[],"tmdb":{"type":"tv","id":"278127","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Bạch Lộc","name_vi":"Bạch Lộc","name_original":"Bai Lu","tmdb_id":1879666,"profile":"https://image.tmdb.org/t/p/w500/aRcUVDRO2wewQe0NXJ0RfzSgvUa.jpg","tmdb_url":"https://www.themoviedb.org/person/1879666"},{"name":"Vương Tinh Việt","name_vi":"Vương Tinh Việt","name_original":"Wang Xingyue","tmdb_id":3157355,"profile":"https://image.tmdb.org/t/p/w500/mi4dqtBt53fRpRWFTgCf9GHgOA7.jpg","tmdb_url":"https://www.themoviedb.org/person/3157355"},{"name":"Diêu An Na","name_vi":"Diêu An Na","name_original":"Annabel Yao","tmdb_id":3567741,"profile":"https://image.tmdb.org/t/p/w500/e7OyuR1f3wHArvkhshAn6R1Dm8V.jpg","tmdb_url":"https://www.themoviedb.org/person/3567741"},{"name":"Triệu Tình","name_vi":"Triệu Tình","name_original":"Zhao Qing","tmdb_id":2937438,"profile":"https://image.tmdb.org/t/p/w500/ribX33OKeV7LLGo4N4aLW5a14Wc.jpg","tmdb_url":"https://www.themoviedb.org/person/2937438"},{"name":"Triệu Dịch Khâm","name_vi":"Triệu Dịch Khâm","name_original":"Zhao Yiqin","tmdb_id":1879667,"profile":"https://image.tmdb.org/t/p/w500/5QiIAqWAAzuhbDQ9MwGTpMtUlYj.jpg","tmdb_url":"https://www.themoviedb.org/person/1879667"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/duong-cung-ky-an-thanh-vu-phong-minh.json"}