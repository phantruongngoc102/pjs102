phức tạp mang tầm quốc tế. Những mối quan hệ của Sam từ những ngày còn trong quân ngũ rất hữu ích - nhưng chúng bắt đầu kéo anh trở lại thế giới đen tối mà anh muốn bỏ lại phía sau.</p>","tmdb":{"type":"tv","id":"58812","season":1,"vote_average":5.857,"vote_count":7},"modified":"2024-09-14T13:32:27.000Z","cast":["Don Hany","Maeve Dermody","Trần Xung","Alaric Tay","Michael Dorman","Pamelyn Chee","Chin Han"],"director":[],"cast_meta":[{"name":"Don Hany","name_vi":null,"name_original":"Don Hany","tmdb_id":79089,"profile":"https://image.tmdb.org/t/p/w500/bkwWtqP5NgsYGrFLfWQuJEWWFvw.jpg","tmdb_url":"https://www.themoviedb.org/person/79089"},{"name":"Maeve Dermody","name_vi":null,"name_original":"Maeve Dermody","tmdb_id":81331,"profile":"https://image.tmdb.org/t/p/w500/bbpRTgz7O2DBmQJi7ixdK0Q2hWz.jpg","tmdb_url":"https://www.themoviedb.org/person/81331"},{"name":"Trần Xung","name_vi":"Trần Xung","name_original":"Joan Chen","tmdb_id":6720,"profile":"https://image.tmdb.org/t/p/w500/7uMTJpY8B2hufXqmlxJpaUPpcJi.jpg","tmdb_url":"https://www.themoviedb.org/person/6720"},{"name":"Alaric Tay","name_vi":null,"name_original":"Alaric Tay","tmdb_id":390858,"profile":"https://image.tmdb.org/t/p/w500/kX7TKWSGBbwqTO0db9A3EaD9Jig.jpg","tmdb_url":"https://www.themoviedb.org/person/390858"},{"name":"Michael Dorman","name_vi":null,"name_original":"Michael Dorman","tmdb_id":76068,"profile":"https://image.tmdb.org/t/p/w500/7Ut9ofZ7fJAvLZ95LVLO1Lepbuc.jpg","tmdb_url":"https://www.themoviedb.org/person/76068"},{"name":"Pamelyn Chee","name_vi":null,"name_original":"Pamelyn Chee","tmdb_id":991930,"profile":"https://image.tmdb.org/t/p/w500/iwLwtVLKEYDwvbOhKD3g0FNALXR.jpg","tmdb_url":"https://www.themoviedb.org/person/991930"},{"name":"Chin Han","name_vi":null,"name_original":"Chin Han","tmdb_id":101015,"profile":"https://image.tmdb.org/t/p/w500/3XJXmYm6r4Hvm3izOArU58fhQrT.jpg","tmdb_url":"https://www.themoviedb.org/person/101015"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdeliv