ream10.com/share/2674cea93e3214abce13e072a2dc2ca5","link_m3u8":"https://vip.opstream10.com/20220513/13804_fd0475b7/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream10.com/share/71ffa17407d66e134442eebb32d330ec","link_m3u8":"https://vip.opstream10.com/20220513/13807_f4fb1498/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream10.com/share/fd7a2c9c29fd3962afc288c0d0e1aad4","link_m3u8":"https://vip.opstream10.com/20220513/13809_bca9dc87/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream10.com/share/62cb1b02c845efe41e4f41b8c1fc87fd","link_m3u8":"https://vip.opstream10.com/20220513/13810_010e874c/index.m3u8"},{"name":"15","slug":"15","link_embed":"https://vip.opstream10.com/share/f5c80b20fdee4e645ff315a56f12a716","link_m3u8":"https://vip.opstream10.com/20220513/13812_c537dbde/index.m3u8"},{"name":"16","slug":"16","link_embed":"https://vip.opstream10.com/share/45ddfa251d2530f6865be72a998b03dc","link_m3u8":"https://vip.opstream10.com/20220513/13815_48bab8bf/index.m3u8"},{"name":"17","slug":"17","link_embed":"https://vip.opstream10.com/share/43b136e4e130934ebda7768e3e728671","link_m3u8":"https://vip.opstream10.com/20220513/13816_077a1b97/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream10.com/share/51934729f32d36841a17e43e9390483a","link_m3u8":"https://vip.opstream10.com/20220513/13820_7e2353f4/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream10.com/share/16e66f0d674db0deec510772414cd5b1","link_m3u8":"https://vip.opstream10.com/20220513/13823_befdfc82/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream10.com/share/822bfaa40020f5d6b232139160b48b05","link_m3u8":"https://vip.opstream10.com/20220513/13829_39db4dab/index.m3u8"}]}],"description":"<p>Vào thời khai nguyên của Lý Đường, tin đồn Võ hậu chuyển thế nổi lên khắp nơi, tàn trang Thôi Bối Đồ tái hiện ở nhân gian ý chỉ rằng mảnh tàn trang Thôi Bối Đồ thứ 61 tiên đoán Võ hậu sắp chuyển thế, nhất định sẽ cướp đoạt giang sơn của Lý Đường. Lời đồn trực tiếp hướng về phía Ngọc quý phi đang được sủng ái nhất trong hậu cung nói cô ta chính là Võ hậu chuyển thế, đồng thời các thế lực trong triều thay đổi kịch liệt, án mạng liên tiếp xảy ra. Nghi Vân, Đậu Sinh và Lý Mặc Bạch mượn cơ hội xin đi điều tra vụ án này. Trên đường làm quen với nữ yêu Đông Nam của Vô Tương Tháp và đạo sĩ ngao du tứ phương Nguyên Đan Khâu. Từ đó Lý Mặc Bạch bước lên con đường làm 300 bài thơ, phá 300 vụ án. Đồng thời âm thầm điều tra kẻ đứng sau vụ án lời đồn Võ hậu chuyển thế.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/du/duong-thi-tam-bach-an.json"}