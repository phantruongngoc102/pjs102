11.com/share/bead7746a397e7cba55be9edd37486ba","link_m3u8":"https://vip.opstream11.com/20230911/47069_6869a8e1/index.m3u8"},{"name":"24","slug":"24","filename":"Vinh Quang Của Bậc Cha Chú - Tập 24","link_embed":"https://vip.opstream11.com/share/b118541d4f591a458e325079668192b4","link_m3u8":"https://vip.opstream11.com/20230911/47068_0f49a153/index.m3u8"},{"name":"25","slug":"25","filename":"Vinh Quang Của Bậc Cha Chú - Tập 25","link_embed":"https://vip.opstream11.com/share/525980bf3c8cef003e559e95475082dc","link_m3u8":"https://vip.opstream11.com/20230911/47090_2c0722a9/index.m3u8"},{"name":"26","slug":"26","filename":"Vinh Quang Của Bậc Cha Chú - Tập 26","link_embed":"https://vip.opstream11.com/share/5c68c574eb52dbbb337b4e46d2dbcfc8","link_m3u8":"https://vip.opstream11.com/20230911/47091_82f67f88/index.m3u8"},{"name":"27","slug":"27","filename":"Vinh Quang Của Bậc Cha Chú - Tập 27","link_embed":"https://vip.opstream11.com/share/cb5ee661c68128229cbc049927193fff","link_m3u8":"https://vip.opstream11.com/20230913/47103_dfc06b04/index.m3u8"},{"name":"28","slug":"28","filename":"Vinh Quang Của Bậc Cha Chú - Tập 28","link_embed":"https://vip.opstream11.com/share/cb1c772c359ae814c34a9c82352a77fb","link_m3u8":"https://vip.opstream11.com/20230913/47104_718182f8/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Là một câu chuyện đầy cảm hứng diễn ra tại Trung Quốc trong thời kỳ từ năm 1998 đến 2015. Đây là khoảng thời gian quan trọng đánh dấu sự chuyển đổi cảnh quan kinh tế của đất nước. Câu chuyện tập trung vào Gu Changshan và người con nuôi của ông, Xingjie, trong một câu chuyện về sự kiên nhẫn và sự thay đổi. Cuộc sống của Gu Changshan đã thay đổi toàn diện khi ông nhận nuôi Xingjie, con trai của đối tác quá cố. Đối mặt với sự lựa chọn quan trọng này, gia đình Gu quyết định gửi Xingjie đi du học ở nước ngoài. Trong bối cảnh đe dọa của việc cắt giảm nhân sự, nhiều người đã ra đi, trong khi Gu Changshan và đồng đội kiên định của ông đã tìm ra một con đường mới thông qua khái niệm \"lâm nghiệp sinh thái gia đình\", một phương pháp sáng tạo để đối phó với cuộc khủng hoảng kinh tế. Năm 2007, một bước ngoặt quan trọng xảy ra khi dự án tái định cư người di cư từ các vùng núi xa xôi bắt đầu, nhằm bảo vệ môi trường và nâng cao chất lượng cuộc sống. Đội làm việc 923 đã đối mặt với nhiều thách thức khi họ liều mình vào vùng đất chưa được khám phá. Trong khi đó, Xingjie trở lại quê nhà của mình, những ngọn núi. Trong quá trình giải quyết khủng hoảng gia đình, anh đã đảm nhận một nhiệm vụ khó khăn - kêu gọi di dân. Từ công việc này, anh đã khám phá ra giá trị riêng của mình và quyết định ở lại, chấp nhận nhiệm vụ cải cách lâm nghiệp. Trong bối cảnh lệnh cấm đốn gỗ toàn diện vào năm 2014 và 2015, Xingjie đã đáp ứng tiếng gọi của \"nước trong, núi xanh\" - hình ảnh của sự bảo vệ môi trường được coi là cực kỳ quan trọng như vàng, bạc. Anh cùng gia đình và cộng đồng người dân trong vùng rừng đã bắt đầu hành trình vượt qua khó khăn, hướng tới một cuộc sống tốt đẹp hơn. \"Hành Trình Vượt Khó - Chặng Đường Trở Về Gian Nan 2023 VietSub\" mang đến cho chúng ta một cái nhìn sâu sắc về sự tận tụy, sự đổi mới và sự thắng lợi của tinh thần cộng đồng trong đối mặt với những khó khăn. Dựa trên sự cam kết không dao động của Xingjie với cải cách lâm nghiệp và bảo vệ môi trường, câu chuyện nhấn mạnh tác động sâu sắc của khát vọng cùng nhau hình thành một tương lai bền vững.</p>","tmdb":{"type":"tv","id":"233465","season":1,"vote_average":7.7,"vote_count":3},"modified":"2023-09-13T09:27:01.000Z","cast":["Trương Vãn Ý","Quách Đào","Lưu Lâm","Trương Nguyệt","Li Haofei","Zhou Fang","Zhang Kaitai","Li Le","Liu Pei"],"director":["Zhao Dong Ling"],"cast_meta":[{"name":"Trương Vãn Ý","name_vi":"Trương Vãn Ý","name_original":"Zhang Wanyi","tmdb_id":3028958,"profile":"https://image.tmdb.org/t/p/w500/wG7GZ5XRUgwTMiAQS1gvgJEABKl.jpg","tmdb_url":"https://www.themoviedb.org/person/3028958"},{"name":"Quách Đào","name_vi":"Quách Đào","name_origina