20251004/30524_a1d053a7/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream10.com/share/f09a9eae79258394989c32e851c9ec10","link_m3u8":"https://vip.opstream10.com/20251008/30559_f09a9eae/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/5fa5ca950fb704c977027ddfc2ee7e3f","link_m3u8":"https://vip.opstream10.com/20251016/30656_5fa5ca95/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/a0cb7709c09ff314737732c317c87039","link_m3u8":"https://vip.opstream10.com/20251022/30738_a0cb7709/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/d4ce8d58dbccac2aec2197cb4ddafa01","link_m3u8":"https://vip.opstream10.com/20251030/30950_d4ce8d58/index.m3u8"}]}],"description":"<p>Phần 5 tiếp tục với bộ ba nhân vật chính quen thuộc đầy hài hước và kỳ quặc — Charles, Oliver và Mabel — khi họ lại một lần nữa bị cuốn vào một vụ án mạng bí ẩn ngay tại Arconia. Lần này, cái chết tưởng chừng vô tình của một người thân quen, một cái chết bất ngờ mở ra chuỗi manh mối rắc rối, kéo họ vào hành trình điều tra vừa hài hước vừa căng thẳng, đẩy cả ba vào hành trình điều tra gay cấn và kịch tính hơn bao giờ hết.&nbsp;</p><p>Nếu bạn đã yêu mến series này với tinh thần đầy hài hước, pha trộn giữa bí ẩn, âm mưu, nhân vật kỳ cục, vừa châm biếm đời sống và văn hóa thành phố, thì mùa 5 hứa hẹn giữ được tinh thần ấy, đồng thời mở rộng quy mô và độ phức tạp của thử thách lần này khi có thêm nhiều nhân vật khách mời mới xuất hiện, gồm những người trong giới giàu có, các nhân vật mafia, và những người có ảnh hưởng trong xã hội New York.</p>","tmdb_id":107113,"cast":["Steve Martin","Martin Short","Selena Gomez","Michael Cyril Creighton"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"107113","season":5,"vote_average":8.486,"vote_count":2096},"cast_meta":[{"name":"Steve Martin","name_vi":null,"name_original":"Steve Martin","tmdb_id":67773,"profile":"https://image.tmdb.org/t/p/w500/d0KthX8hVWU9