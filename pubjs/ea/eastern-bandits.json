 sau khi chứng kiến ​​​​anh ta đã trải qua như thế nào trong các giai đoạn thẩm vấn khi anh ta bị Fang bắt giữ.","tmdb":{"type":"movie","id":"134770","season":null,"vote_average":4,"vote_count":2},"modified":"2023-03-23T16:40:08.000Z","cast":["Huỳnh Hiểu Minh","Trương Hâm Nghệ","Trương Dịch","Ni Jingyang","Tino Bao","Yue Zhang","Gao Qunshu","Lý Tử Hùng","Liang Jing","Jiang Shan","Guo Wei","Asano Nagahide"],"director":["Yang Shupeng"],"cast_meta":[{"name":"Huỳnh Hiểu Minh","name_vi":"Huỳnh Hiểu Minh","name_original":"Huang Xiaoming","tmdb_id":109434,"profile":"https://image.tmdb.org/t/p/w500/pnSbq1pNDb0uLkzGOJ8zy7piBvb.jpg","tmdb_url":"https://www.themoviedb.org/person/109434"},{"name":"Trương Hâm Nghệ","name_vi":"Trương Hâm Nghệ","name_original":"Zhang Xinyi","tmdb_id":126851,"profile":"https://image.tmdb.org/t/p/w500/envIGo2oj73IuCKO835po6nhaMP.jpg","tmdb_url":"https://www.themoviedb.org/person/126851"},{"name":"Trương Dịch","name_vi":"Trương Dịch","name_original":"Zhang Yi","tmdb_id":146098,"profile":"https://image.tmdb.org/t/p/w500/l34U9AP3AegNzvogW2rYs0H5DOG.jpg","tmdb_url":"https://www.themoviedb.org/person/146098"},{"name":"Ni Jingyang","name_vi":null,"name_original":"Ni Jingyang","tmdb_id":1387957,"profile":"https://image.tmdb.org/t/p/w500/9W0bL3jX0NenH70EJL3xQ5K2PE9.jpg","tmdb_url":"https://www.themoviedb.org/person/1387957"},{"name":"Tino Bao","name_vi":null,"name_original":"Tino Bao","tmdb_id":1400584,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1400584"},{"name":"Yue Zhang","name_vi":null,"name_original":"Yue Zhang","tmdb_id":4720716,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4720716"},{"name":"Gao Qunshu","name_vi":null,"name_original":"Gao Qunshu","tmdb_id":109426,"profile":"https://image.tmdb.org/t/p/w500/16p8ZaoKIjypuWcHl7ebNEf9alP.jpg","tmdb_url":"https://www.themoviedb.org/person/109426"},{"name":"Lý Tử Hùng","name_vi":"Lý Tử Hùng","name_original":"Waise Lee Chi-Hung","tmdb_id":25249,"profile":"https://image.tmdb.or