heo đuổi Hạ Mạt. \\nBộ phim này sẽ được phát sóng trực tuyến trên iQIYI quốc tế (iq.com).","tmdb_id":231955,"cast":["La Chính","Quý Mỹ Hàm","Yang Ze","Chen Siche","Wang Kang","Yang Xueer","Nan Xi","Jie Bing","Fang Chutong","Duanmu Yichen","Han Shumei","Xing Yun","Zheng Yuan","Min Siyu","Chu Hạo Kỳ"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"231955","season":1,"vote_average":6.7,"vote_count":7},"cast_meta":[{"name":"La Chính","name_vi":"La Chính","name_original":"Luo Zheng","tmdb_id":2364800,"profile":"https://image.tmdb.org/t/p/w500/ubLHizRd9jDhjfp2wD0me0EwCE7.jpg","tmdb_url":"https://www.themoviedb.org/person/2364800"},{"name":"Quý Mỹ Hàm","name_vi":"Quý Mỹ Hàm","name_original":"Ji Meihan","tmdb_id":2872808,"profile":"https://image.tmdb.org/t/p/w500/gVDIyMzoq44BdJChnKvdYZsZMVw.jpg","tmdb_url":"https://www.themoviedb.org/person/2872808"},{"name":"Yang Ze","name_vi":null,"name_original":"Yang Ze","tmdb_id":2494668,"profile":"https://image.tmdb.org/t/p/w500/9CUVdHRklKsufhY0EiJfxcvdKi5.jpg","tmdb_url":"https://www.themoviedb.org/person/2494668"},{"name":"Chen Siche","name_vi":null,"name_original":"Chen Siche","tmdb_id":3563569,"profile":"https://image.tmdb.org/t/p/w500/xl7UFHMZo4lxCXh6BNzvuWUhx4.jpg","tmdb_url":"https://www.themoviedb.org/person/3563569"},{"name":"Wang Kang","name_vi":null,"name_original":"Wang Kang","tmdb_id":3153935,"profile":"https://image.tmdb.org/t/p/w500/iZt2q8o5Wbtz33xHtdzurCQhBmM.jpg","tmdb_url":"https://www.themoviedb.org/person/3153935"},{"name":"Yang Xueer","name_vi":null,"name_original":"Yang Xueer","tmdb_id":3136788,"profile":"https://image.tmdb.org/t/p/w500/fFE9lqsSt7Fq59dpgLDzYYgRQIA.jpg","tmdb_url":"https://www.themoviedb.org/person/3136788"},{"name":"Nan Xi","name_vi":null,"name_original":"Nan Xi","tmdb_id":2801618,"profile":"https://image.tmdb.org/t/p/w500/aKz0klnZFhKVx6WdHsxxokFNPmj.jpg","tmdb_url":"https://www.themoviedb.org/person/2801618"},{"name":"Jie Bing","name_vi":null,"name_original":"Jie Bing","tmdb_id":3028322,"