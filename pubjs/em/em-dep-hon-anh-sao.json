ame":"(Vietsub) As.Beautiful.As.You.S01E36.2024.2160p.IQ.WEB-DL.H265.DDP2.0-HHWEB","link_embed":"https://vip.opstream17.com/share/5c6a2ff5001c13fb4b0425a45e5b8e11","link_m3u8":"https://vip.opstream17.com/20240724/15604_e013e0a2/index.m3u8"},{"name":"37","slug":"37","filename":"(Vietsub) As.Beautiful.As.You.S01E37.2024.2160p.IQ.WEB-DL.H265.DDP2.0-HHWEB","link_embed":"https://vip.opstream17.com/share/a47cc7b881ce40bc6ba3e71d5d47fbf1","link_m3u8":"https://vip.opstream17.com/20240724/15605_2be11013/index.m3u8"},{"name":"38","slug":"38","filename":"(Vietsub) As.Beautiful.As.You.S01E38.2024.2160p.IQ.WEB-DL.H265.DDP2.0-HHWEB","link_embed":"https://vip.opstream17.com/share/6863f2f626660f54ec03d557f9b79bd6","link_m3u8":"https://vip.opstream17.com/20240724/15606_755e8719/index.m3u8"},{"name":"39","slug":"39","filename":"(Vietsub) As.Beautiful.As.You.S01E39.2024.2160p.IQ.WEB-DL.H265.DDP2.0-HHWEB","link_embed":"https://vip.opstream17.com/share/1475b0b5094e6f4f7dfc284649259195","link_m3u8":"https://vip.opstream17.com/20240724/15607_d531f601/index.m3u8"},{"name":"40","slug":"40","filename":"(Vietsub) As.Beautiful.As.You.S01E40.2024.2160p.IQ.WEB-DL.H265.DDP2.0-HHWEB","link_embed":"https://vip.opstream17.com/share/d09168b62f80ae8aa28c426919b808c7","link_m3u8":"https://vip.opstream17.com/20240724/15608_5837c858/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Kỷ Tinh tốt nghiệp từ một trường Đại học có danh tiếng, cô là một sinh viên có kiến thức chuyên ngành rất vững chắc. Sau khi tốt nghiệp, Kỷ Tinh vào làm ở Quảng Hoa, hừng hực khí thế muốn tạo dựng một tương lai tươi sáng. Kết quả là hiện thực phũ phàng đã giáng cho cô một cái bạt tai. Đi làm ba năm, chưa xây dựng nên cơ đồ thì đã rơi vào đủ mọi “cạm bẫy” nơi công sở, trải qua nhiều nỗi đau. Với tư duy sắc bén, thông minh, sau khi cô xử lý xong việc ở công ty liền hiên ngang từ chức, bắt đầu khởi nghiệp. Kỷ Tinh dám nghĩ dám làm, hơn nữa cô lại còn rất thông minh, vì vậy trên con đường khởi nghiệp dù có trắc trở những cô đã gặt hái được thành công riêng. Cô ấy gặp được Hàn Đình - “Bá Lạc” của đời mình, cũng là nhà đầu tư cho dự án khởi nghiệp của cô.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"219915","season":1,"vote_average":8.4,"vote_count":10},"modified":"2024-07-24T22:46:58.000Z","cast":["Đàm Tùng Vận","Hứa Khải","Hà Thụy Hiền","Cao Hàn","Thi Thi","Wu Shile","Zhou Dawei","Vương Nhất Lan","Tang Zhenchao","Luo Zekai","Liu Hailan","Guan Yajun","Yi Yunhe"],"director":[],"cast_meta":[{"name":"Đàm Tùng Vận","name_vi":"Đàm Tùng Vận","name_original":"Tan Songyun","tmdb_id":1614218,"profile":"https://image.tmdb.org/t/p/w500/yYMnfaIix23U51z21EJhznq3DHN.jpg","tmdb_url":"https://www.themoviedb.org/person/1614218"},{"name":"Hứa Khải","name_vi":"Hứa Khải","name_original":"Xu Kai","tmdb_id":2091759,"profile":"https://image.tmdb.org/t/p/w500/wEfatQWa3v9tNtmgr5LOOmFSSJj.jpg","tmdb_url":"https://www.themoviedb.org/person/2091759"},{"name":"Hà Thụy Hiền","name_vi":"Hà Thụy Hiền","name_original":"He Ruixian","tmdb_id":2513783,"profile":"https://image.tmdb.org/t/p/w500/i5ZjOyhbtZumfdqUo27obFagoBo.jpg","tmdb_url":"https://www.themoviedb.org/person/2513783"},{"name":"Cao Hàn","name_vi":"Cao Hàn","name_original":"Gao Han","tmdb_id":3788274,"profile":"https://image.tmdb.org/t/p/w500/hMz9cKmW8tt7YWIigyAhsXG8qN4.jpg","tmdb_url":"https://www.themoviedb.org/person/3788274"},{"name":"Thi Thi","name_vi":"Thi Thi","name_original":"Shi Shi","tmdb_id":2103412,"profile":"https://image.tmdb.org/t/p/w500/7LTskavi0aUSSls3thKNIG3oeCH.jpg","tmdb_url":"https://www.themoviedb.org/person/2103412"},{"name":"Wu Shile","name_vi":null,"name_original":"Wu Shile","tmdb_id":4356701,"profile":"https://image.tmdb.org/t/p/w500/jg2afWBPGfR5WZrIf3fIZXfQhRW.jpg","tmdb_url":"https://www.themoviedb.org/person/4356701"},{"name":"Zhou Dawei","name_vi":null,"name_original":"Zhou Dawei","tmdb_id":3154482,"profile":"https://image.tmdb.org/t/p/w500/2YZsLDUdW7plnLLogi8ijRcRSt.jpg","tmdb_url":"https://www.themoviedb.org/person/3154482"},{"name