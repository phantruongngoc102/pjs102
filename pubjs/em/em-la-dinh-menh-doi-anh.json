người có khả năng nuôi dạy gia đình. Vì đã quá nhiều thời gian trôi qua, lịch sử và khả năng hội tụ khi hai người tình cờ gặp nhau ở Hungary.","tmdb":{"type":"tv","id":"104431","season":1,"vote_average":7.2,"vote_count":26},"modified":"2025-09-26T14:59:27.000Z","cast":["Hình Chiêu Lâm","Lương Khiết","Fu Jing","Lý Cửu Lâm","Vương Đức Thuận"],"director":["Ding Ying Zhou","周俊伦"],"cast_meta":[{"name":"Hình Chiêu Lâm","name_vi":"Hình Chiêu Lâm","name_original":"Xing Zhaolin","tmdb_id":1855299,"profile":"https://image.tmdb.org/t/p/w500/8UPCvdZggQhuzCGkXvSOJ8EMqdI.jpg","tmdb_url":"https://www.themoviedb.org/person/1855299"},{"name":"Lương Khiết","name_vi":"Lương Khiết","name_original":"Liang Jie","tmdb_id":1855300,"profile":"https://image.tmdb.org/t/p/w500/pYYvBkKizMO8vulvZNNdqEkEYPL.jpg","tmdb_url":"https://www.themoviedb.org/person/1855300"},{"name":"Fu Jing","name_vi":null,"name_original":"Fu Jing","tmdb_id":2633320,"profile":"https://image.tmdb.org/t/p/w500/5ZdFhfkjHl8bNEqULry0CMm2j16.jpg","tmdb_url":"https://www.themoviedb.org/person/2633320"},{"name":"Lý Cửu Lâm","name_vi":"Lý Cửu Lâm","name_original":"Li Jiulin","tmdb_id":2752786,"profile":"https://image.tmdb.org/t/p/w500/29NG6ZFlXsvfvsF7eIOW6OTKRou.jpg","tmdb_url":"https://www.themoviedb.org/person/2752786"},{"name":"Vương Đức Thuận","name_vi":"Vương Đức Thuận","name_original":"Wang Deshun","tmdb_id":1129530,"profile":"https://image.tmdb.org/t/p/w500/yTmSmUH3CdEhU1zYd3maDg3ipBZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1129530"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/em/em-la-dinh-menh-doi-anh.json"}