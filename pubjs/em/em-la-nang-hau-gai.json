ip.opstream15.com/share/7173c3941ffacdd5d9422135c65b6bab","link_m3u8":"https://vip.opstream15.com/20250310/50529_7173c394/index.m3u8"},{"name":"7","slug":"7","filename":"Em là nàng hầu gái_S01E07_Tập 7","link_embed":"https://vip.opstream15.com/share/d86b00eaec7e7f2a77c3bb48961726f8","link_m3u8":"https://vip.opstream15.com/20250310/50530_d86b00ea/index.m3u8"},{"name":"8","slug":"8","filename":"Em là nàng hầu gái_S01E08_Tập 8","link_embed":"https://vip.opstream15.com/share/4b562e5a92d94dabf8d31fe0395f9e87","link_m3u8":"https://vip.opstream15.com/20250310/50531_4b562e5a/index.m3u8"},{"name":"9","slug":"9","filename":"Em là nàng hầu gái_S01E09_Tập 9","link_embed":"https://vip.opstream15.com/share/784ac113a896b449407e35da48e21d26","link_m3u8":"https://vip.opstream15.com/20250310/50532_784ac113/index.m3u8"},{"name":"10","slug":"10","filename":"Em là nàng hầu gái_S01E10_Tập 10","link_embed":"https://vip.opstream15.com/share/108a525a89b7c0224a5a4ca3abb718a2","link_m3u8":"https://vip.opstream15.com/20250310/50533_108a525a/index.m3u8"},{"name":"11","slug":"11","filename":"Em là nàng hầu gái_S01E11_Tập 11","link_embed":"https://vip.opstream15.com/share/15ae6e4df22b4f882654f0dc81350aad","link_m3u8":"https://vip.opstream15.com/20250310/50534_15ae6e4d/index.m3u8"},{"name":"12","slug":"12","filename":"Em là nàng hầu gái_S01E12_Tập 12","link_embed":"https://vip.opstream15.com/share/632ad1a427967e4bef22caa70e70c5ca","link_m3u8":"https://vip.opstream15.com/20250310/50535_632ad1a4/index.m3u8"}]}],"time":"23 phút/tập","description":"Một ngày nọ, đột nhiên có một cô hầu gái đến gõ cửa nhà—.\n\nYokoya Hitoyoshi, một nam sinh trung học, bất ngờ nhận được một vị khách không mời. Đó là một cô hầu gái với mái tóc đen, tính cách nghiêm trang và lời nói lịch sự. Câu đầu tiên cô ấy nói là: “Xin hãy thuê tôi.”\n\nTrước đây, cô ấy là một “sát thủ”, sở trường của cô là “ám sát”, và việc nhà thì lại rất vụng về. Cuộc sống chung dưới một mái nhà cùng cô hầu gái ấy bắt đầu từ cuộc gặp gỡ định mệnh này…!?\n\nDần dần, trái tim của cô gái không biết đến cảm xúc ấy bắt đầu dao động—.\n\nĐây là câu chuyện về một cô hầu gái từng cô độc, nhưng rồi đã tìm thấy một “gia đình” cho mình.","tmdb":{"type":"tv","id":"242143","season":1,"vote_average":7.5,"vote_count":32},"modified":"2025-03-10T16:02:17.000Z","cast":["Toshiki Kumagai","Reina Ueda","Eriko Matsui","Hikaru Iida","Lynn","Konomi Inagaki"],"director":[],"cast_meta":[{"name":"Toshiki Kumagai","name_vi":null,"name_original":"Toshiki Kumagai","tmdb_id":2835109,"profile":"https://image.tmdb.org/t/p/w500/18bGMZ4FdYPTFnFLgwJpYbVC9wT.jpg","tmdb_url":"https://www.themoviedb.org/person/2835109"},{"name":"Reina Ueda","name_vi":null,"name_original":"Reina Ueda","tmdb_id":1452028,"profile":"https://image.tmdb.org/t/p/w500/2WV61uVU7y6XGYqNHLMpP0sApdu.jpg","tmdb_url":"https://www.themoviedb.org/person/1452028"},{"name":"Eriko Matsui","name_vi":null,"name_original":"Eriko Matsui","tmdb_id":1325964,"profile":"https://image.tmdb.org/t/p/w500/atMgu6hwHQisLA2tK8aVmevZYh6.jpg","tmdb_url":"https://www.themoviedb.org/person/1325964"},{"name":"Hikaru Iida","name_vi":null,"name_original":"Hikaru Iida","tmdb_id":3162774,"profile":"https://image.tmdb.org/t/p/w500/jwy5HpVGSIiwnRX2m9hR32KPVBy.jpg","tmdb_url":"https://www.themoviedb.org/person/3162774"},{"name":"Lynn","name_vi":null,"name_original":"Lynn","tmdb_id":1691384,"profile":"https://image.tmdb.org/t/p/w500/eJ2NqgzpnzNbT6Nt9EpDfzqNeZM.jpg","tmdb_url":"https://www.themoviedb.org/person/1691384"},{"name":"Konomi Inagaki","name_vi":null,"name_original":"Konomi Inagaki","tmdb_id":3049705,"profile":"https://image.tmdb.org/t/p/w500/qYizWDjykF0j5foMvKGYyRta037.jpg","tmdb_url":"https://www.themoviedb.org/person/3049705"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/em/em-la-nang-hau-gai.json"}