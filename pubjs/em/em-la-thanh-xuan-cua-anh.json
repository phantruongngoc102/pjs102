ream10.com/20220514/14004_6d6418da/index.m3u8"},{"name":"23","slug":"23","filename":"em-la-thanh-xuan-cua-anh-youth-tap-23","link_embed":"https://vip.opstream10.com/share/16b5e60b803fb3925ea88833ff398caf","link_m3u8":"https://vip.opstream10.com/20220514/14005_9f3032df/index.m3u8"},{"name":"24","slug":"24","filename":"em-la-thanh-xuan-cua-anh-youth-tap-24","link_embed":"https://vip.opstream10.com/share/11084aaf0a5fc9561425a254a219f6f6","link_m3u8":"https://vip.opstream10.com/20220514/14007_3b875e11/index.m3u8"}]}],"time":"","description":"<p>Em Là Thanh Xuân Của Anh (Youth) là bộ phim về đề tài thanh xuân, câu chuyện xoay quanh 5 người bạn từ tình yêu thuần khiết trong khuôn viên trường, đến sự rối rắm tình cảm của tương lai những giấc mơ ở tuổi trưởng thành, niềm vui và nỗi buồn của hơn mười năm. Từ Vĩnh Tâm (Lý Mặc Chi đóng) sau khi trưởng thành, đã gặp lại người bạn thời cấp 3 của mình Trịnh Đại Uy (Từ Gia Vĩ đóng), cuộc gặp gỡ sau nhiều năm xa cách này đã gợi lại những kí ức tuổi học trò. Thời gian trở lại 10 năm trước, Từ Vĩnh Tâm khi đó là một nàng mọt sách ưu tú, trong một lần gặp sự cố với quyển vở, mà đâm phải Đỗ Á Tu (Liên Thần Tường đóng), sau khi hiểu rõ về nhau, cô phát hiện Á Tu bên ngoài dáng vẻ của một học sinh cá biệt, thực ra bên trong lại có một trái tim lương thiện nhiệt tình. Và qua Á Tu, một cô gái chỉ biết đến sách như Vĩnh Tâm đã có thêm những người bạn tốt .</p>","tmdb":{"type":"tv","id":"82762","season":1,"vote_average":10,"vote_count":2},"modified":"2022-05-15T14:53:32.000Z","cast":["Hà Lam Đậu","Ngu Thư Hân","Shen Wei","Yang Zhiying","Wang Yanzhi","Tào Dục Thần","Triệu Chí Vỹ","Hu Wenzhe","Yang Yifei","Lý Cửu Lâm"],"director":["Lại Mạnh Kiệt"],"cast_meta":[{"name":"Hà Lam Đậu","name_vi":"Hà Lam Đậu","name_original":"He Landou","tmdb_id":2140108,"profile":"https://image.tmdb.org/t/p/w500/ihjaMHKdIgO9VcX6UiiSSa400f4.jpg","tmdb_url":"https://www.themoviedb.org/person/2140108"},{"name":"Ngu Thư Hân","name_vi":"Ngu Thư Hân","name_original":"Yu 