48217_b9974005/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/ee7230dec6c5cf2229f0a706a265ca49","link_m3u8":"https://vip.opstream11.com/20231008/48219_50d4e94b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/012849d3021dca5ddefa4d967324caeb","link_m3u8":"https://vip.opstream11.com/20231008/48220_fa9f69a9/index.m3u8"}]}],"description":"<p>Yan Mo, một siêu sao đến từ tương lai, mắc một căn bệnh về máu hiếm gặp và cô phát hiện ra rằng người duy nhất có thể cứu cô chính là Gu Yan Zhi, một nhà khoa học thiên tài sống ở thời hiện đại. Yan Mo du hành về quá khứ (thời hiện đại của chúng ta) chỉ để phát hiện ra rằng nếu muốn lấy được máu của anh ấy, cô ấy phải tạo ra những phản ứng cảm xúc trong cơ thể Gu Yan Zhi. Tuy nhiên, trong quá trình “dạy” Gu Yan Zhi cách cảm nhận, họ đã phải lòng nhau. Nhưng điều gì sẽ xảy ra khi họ nhận ra rằng tình yêu của họ đã thay đổi quỹ đạo số phận của mỗi người, và giữa cuộc đời và tình yêu của họ chỉ có thể có một? Liệu họ có ôm lấy tình yêu không?</p>","tmdb_id":235892,"cast":["Zhang Chao","Zong Yuanyuan","Arthur Ma","Đặng Khải"],"director":["Xu Chi"],"keywords":[],"tmdb":{"type":"tv","id":"235892","season":1,"vote_average":6,"vote_count":1},"cast_meta":[{"name":"Zhang Chao","name_vi":null,"name_original":"Zhang Chao","tmdb_id":1390950,"profile":"https://image.tmdb.org/t/p/w500/tbIuAfaU0MpBLC5UPFZu8U1IUcu.jpg","tmdb_url":"https://www.themoviedb.org/person/1390950"},{"name":"Zong Yuanyuan","name_vi":null,"name_original":"Zong Yuanyuan","tmdb_id":3212797,"profile":"https://image.tmdb.org/t/p/w500/flJ2FQqaMYo5fKEQ66vv5KEBr9P.jpg","tmdb_url":"https://www.themoviedb.org/person/3212797"},{"name":"Arthur Ma","name_vi":null,"name_original":"Arthur Ma","tmdb_id":2426972,"profile":"https://image.tmdb.org/t/p/w500/gshlyICRK46QfcZiq662Y8sf3tx.jpg","tmdb_url":"https://www.themoviedb.org/person/2426972"},{"name":"Đặng Khải","name_vi":"Đặng Khải","name_original":"Deng Kai","tmdb_id