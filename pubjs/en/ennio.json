 nhiều thứ khiến bạn phải mê mẩn</p>","tmdb":{"type":"movie","id":"396194","season":null,"vote_average":8.308,"vote_count":367},"modified":"2024-09-02T10:54:28.000Z","cast":["Ennio Morricone","Silvano Agosti","Alessandro Alessandroni","Fausto Ancillai","Dario Argento","Joan Baez","Sergio Bassetti","Bruno Battisti D'Amario","Marco Bellocchio","Bernardo Bertolucci","Marco Biscarini","Walter Branchi","Gilda Buttà","Caterina Caselli","Enzo G. Castellari"],"director":["Giuseppe Tornatore"],"cast_meta":[{"name":"Ennio Morricone","name_vi":null,"name_original":"Ennio Morricone","tmdb_id":1259,"profile":"https://image.tmdb.org/t/p/w500/avjgzi45bdXgC1AtyNsRc5nxtFM.jpg","tmdb_url":"https://www.themoviedb.org/person/1259"},{"name":"Silvano Agosti","name_vi":null,"name_original":"Silvano Agosti","tmdb_id":1002674,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1002674"},{"name":"Alessandro Alessandroni","name_vi":null,"name_original":"Alessandro Alessandroni","tmdb_id":30657,"profile":"https://image.tmdb.org/t/p/w500/vgUlqCSQygJ8H7jQmZmaNCjVLnH.jpg","tmdb_url":"https://www.themoviedb.org/person/30657"},{"name":"Fausto Ancillai","name_vi":null,"name_original":"Fausto Ancillai","tmdb_id":1661161,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1661161"},{"name":"Dario Argento","name_vi":null,"name_original":"Dario Argento","tmdb_id":4955,"profile":"https://image.tmdb.org/t/p/w500/2WjQlcLxhvmO9NtCfNh2npMVYqp.jpg","tmdb_url":"https://www.themoviedb.org/person/4955"},{"name":"Joan Baez","name_vi":null,"name_original":"Joan Baez","tmdb_id":1490,"profile":"https://image.tmdb.org/t/p/w500/blirnm784OsM2csUEZUBunrqXkt.jpg","tmdb_url":"https://www.themoviedb.org/person/1490"},{"name":"Sergio Bassetti","name_vi":null,"name_original":"Sergio Bassetti","tmdb_id":3968118,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3968118"},{"name":"Bruno Battisti D'Amario","name_vi":null,"name_original":"Bruno Battisti D'Amario","tmdb_id":2505255,"profile":"https://i