8":"https://vip.opstream11.com/20230325/43131_83ea4f2e/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Qua đời vì bệnh tật ở tuổi 39, Machio Hiraku có cơ hội đến một thế giới khác. Khi được hỏi điều ước của anh ấy là gì bởi Chúa định ban cho anh ấy sức mạnh, anh ấy yêu cầu có một cơ thể khỏe mạnh, được đưa ra điều ước thứ hai và anh ấy chọn sống bình yên. Điều ước thứ ba là có thể biết tiếng địa phương, và điều ước cuối cùng là có thể làm nông dân.</p>","tmdb":{"type":"tv","id":"196285","season":1,"vote_average":7.59,"vote_count":117},"modified":"2023-03-24T23:33:37.000Z","cast":["Atsushi Abe","Shino Shimoji","Aya Suzaki","Lynn"],"director":[],"cast_meta":[{"name":"Atsushi Abe","name_vi":null,"name_original":"Atsushi Abe","tmdb_id":1154449,"profile":"https://image.tmdb.org/t/p/w500/b59PickRsrhT6kaUKN2dD8c7ip.jpg","tmdb_url":"https://www.themoviedb.org/person/1154449"},{"name":"Shino Shimoji","name_vi":null,"name_original":"Shino Shimoji","tmdb_id":1780773,"profile":"https://image.tmdb.org/t/p/w500/8T2DboiJA3PC1OLJjhN12o4THYn.jpg","tmdb_url":"https://www.themoviedb.org/person/1780773"},{"name":"Aya Suzaki","name_vi":null,"name_original":"Aya Suzaki","tmdb_id":1258548,"profile":"https://image.tmdb.org/t/p/w500/sApBzyEHk0hvpH1IIxYwfi4GS9p.jpg","tmdb_url":"https://www.themoviedb.org/person/1258548"},{"name":"Lynn","name_vi":null,"name_original":"Lynn","tmdb_id":1691384,"profile":"https://image.tmdb.org/t/p/w500/eJ2NqgzpnzNbT6Nt9EpDfzqNeZM.jpg","tmdb_url":"https://www.themoviedb.org/person/1691384"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/fa/farming-life-in-another-world.json"}