ream17.com/share/b4681a619cf018eed690452faeb0e94f","link_m3u8":"https://vip.opstream17.com/20240422/5622_6a75c170/index.m3u8"},{"name":"01","slug":"01","link_embed":"https://vip.opstream17.com/share/249338e601902b14d0f529fe5e6ae417","link_m3u8":"https://vip.opstream17.com/20240422/5621_7012da28/index.m3u8"}]}],"description":"Fist of Fury is a 1995 Hong Kong television series adapted from the 1972 film of the same title. Produced by ATV and STAR TV, the series starred Donnie Yen as Chen Zhen, a role previously played by Bruce Lee in Fist of Fury and Jet Li in Fist of Legend. The series is also related to the 2010 film Legend of the Fist: The Return of Chen Zhen, in which Yen reprises his role. This series was edited into a 225 minute movie titled Sworn Revenge for the US market in 2002.","tmdb_id":21643,"cast":["Chân Tử Đan","Joey Man Yee-Man","Cao Hùng","Ngô Đình Diệp","Eric Wan Tin-Chiu","David Lau Chi-Wing","Yeung Chak-Lam","Khương Hạo Văn","Lo Lieh","Kenny Lam Chi-Ho","Xiong Xinxin"],"director":["Benny Chan"],"keywords":[],"tmdb":{"type":"tv","id":"21643","season":1,"vote_average":6.2,"vote_count":10},"cast_meta":[{"name":"Chân Tử Đan","name_vi":"Chân Tử Đan","name_original":"Donnie Yen","tmdb_id":1341,"profile":"https://image.tmdb.org/t/p/w500/hTlhrrZMj8hZVvD17j4KyAFWBHc.jpg","tmdb_url":"https://www.themoviedb.org/person/1341"},{"name":"Joey Man Yee-Man","name_vi":null,"name_original":"Joey Man Yee-Man","tmdb_id":1191930,"profile":"https://image.tmdb.org/t/p/w500/xX8YV5x5aEFSU9aGxwXNElFwAoZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1191930"},{"name":"Cao Hùng","name_vi":"Cao Hùng","name_original":"Eddy Ko Hung","tmdb_id":612216,"profile":"https://image.tmdb.org/t/p/w500/1Zsn0zSmo5AS5p527XDaZvD0i3y.jpg","tmdb_url":"https://www.themoviedb.org/person/612216"},{"name":"Ngô Đình Diệp","name_vi":"Ngô Đình Diệp","name_original":"Berg Ng Ting-Yip","tmdb_id":1139045,"profile":"https://image.tmdb.org/t/p/w500/m5xPhFT6li4ZasJzVAZAgBWnPw3.jpg","tmdb_url":"https://w