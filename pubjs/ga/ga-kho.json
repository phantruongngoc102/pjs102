/245_4cdb9a0f/index.m3u8"},{"name":"33","slug":"33","filename":"Gã Khờ - The Innocent Man - Tập 33","link_embed":"https://vip.opstream12.com/share/38db3aed920cf82ab059bfccbd02be6a","link_m3u8":"https://vip.opstream12.com/20220217/246_9b5d7d74/index.m3u8"},{"name":"34","slug":"34","filename":"Gã Khờ - The Innocent Man - Tập 34","link_embed":"https://vip.opstream12.com/share/f340f1b1f65b6df5b5e3f94d95b11daf","link_m3u8":"https://vip.opstream12.com/20220217/241_b15f9b3a/index.m3u8"},{"name":"35","slug":"35","filename":"Gã Khờ - The Innocent Man - Tập 35","link_embed":"https://vip.opstream12.com/share/e4a6222cdb5b34375400904f03d8e6a5","link_m3u8":"https://vip.opstream12.com/20220217/242_594b369c/index.m3u8"},{"name":"36","slug":"36","filename":"Gã Khờ - The Innocent Man - Tập 36","link_embed":"https://vip.opstream12.com/share/cb70ab375662576bd1ac5aaf16b3fca4","link_m3u8":"https://vip.opstream12.com/20220217/243_04d8e8a0/index.m3u8"},{"name":"37","slug":"37","filename":"Gã Khờ - The Innocent Man - Tập 37","link_embed":"https://vip.opstream12.com/share/335f5352088d7d9bf74191e006d8e24c","link_m3u8":"https://vip.opstream12.com/20220217/240_729f548f/index.m3u8"},{"name":"38","slug":"38","filename":"Gã Khờ - The Innocent Man - Tập 38","link_embed":"https://vip.opstream12.com/share/ac1dd209cbcc5e5d1c6e28598e8cbbe8","link_m3u8":"https://vip.opstream12.com/20220217/238_ca8d894d/index.m3u8"},{"name":"39","slug":"39","filename":"Gã Khờ - The Innocent Man - Tập 39","link_embed":"https://vip.opstream12.com/share/555d6702c950ecb729a966504af0a635","link_m3u8":"https://vip.opstream12.com/20220217/239_8a19c207/index.m3u8"},{"name":"40","slug":"40","filename":"Gã Khờ - The Innocent Man - Tập 40","link_embed":"https://vip.opstream12.com/share/9188905e74c28e489b44e954ec0b9bca","link_m3u8":"https://vip.opstream12.com/20220217/244_48d2d249/index.m3u8"}]}],"time":"30 phút/tập","description":"<p>Gã khờ - The Innocent Man là bộ phim tâm lý xã hội mang phong cách cổ điển về sự phản bội, sự trả thù và tình yêu. Mỹ nam Song Joong-ki trong phim thủ vai Kang Ma-ru, một chàng trai thư sinh trong sáng có một tình yêu đẹp. Nhưng mọi chuyện thay đổi hoàn toàn, khi Ma-ru bị phản bội bởi chính người bạn gái chạy theo tiền tài và danh vọng. Nhiều năm sau, Ma-ru trở lại mang trong mình mối hận và một kế hoạch trả thù những kẻ phản bội. Anh lên kế hoạch quyến rũ Seo Eun-gi, con gái của một tài phiệt và biến cô thành con tốt trong kế hoạch của mình. Mọi chuyện sẽ ra sao, khi thiện lương trong Ma-ru được đánh thức bởi chính tình cảm chân thành của Eun-gi.</p>","tmdb":{"type":"tv","id":"44969","season":1,"vote_average":7.6,"vote_count":49},"modified":"2023-04-07T18:12:37.000Z","cast":["Song Joong-ki","Moon Chae-won","Park Si-yeon","Lee Kwang-soo","Lee Yu-bi","Lee Sang-yeob","Yang Ik-june","Kim Yeong-cheol","Kim Tae-hun","Kang Chan-hee","Park Si-woo"],"director":["Kim Jin Won","Lee Na Jung"],"cast_meta":[{"name":"Song Joong-ki","name_vi":"Song Joong-ki","name_original":"Song Joong-ki","tmdb_id":150698,"profile":"https://image.tmdb.org/t/p/w500/kgjb5OppOVTh5tz3hhnfDVnTvDv.jpg","tmdb_url":"https://www.themoviedb.org/person/150698"},{"name":"Moon Chae-won","name_vi":null,"name_original":"Moon Chae-won","tmdb_id":1248204,"profile":"https://image.tmdb.org/t/p/w500/x8kARXMszobY1YRcc3nbWczqyeZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1248204"},{"name":"Park Si-yeon","name_vi":null,"name_original":"Park Si-yeon","tmdb_id":84752,"profile":"https://image.tmdb.org/t/p/w500/iaP44f9OYuHoLKi2Mhyo27LdBlJ.jpg","tmdb_url":"https://www.themoviedb.org/person/84752"},{"name":"Lee Kwang-soo","name_vi":null,"name_original":"Lee Kwang-soo","tmdb_id":1326172,"profile":"https://image.tmdb.org/t/p/w500/eqjZXCV4EutnoVxZwOveK6Nl5W9.jpg","tmdb_url":"https://www.themoviedb.org/person/1326172"},{"name":"Lee Yu-bi","name_vi":null,"name_original":"Lee Yu-bi","tmdb_id":1346876,"profile":"https://image.tmdb.org/t/p/w500/dWJhrhEf9IfT62Qo7bT4j3ab1IE.jpg","tmdb_url":"https://www.themoviedb.org/person