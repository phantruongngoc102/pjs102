3/index.m3u8"},{"name":"42","slug":"42","filename":"EP42- Hello, My Shining Love","link_embed":"https://vip.opstream14.com/share/67845006067b1ce96cc0e291320e7149","link_m3u8":"https://vip.opstream14.com/20220715/18219_8f66ad0c/index.m3u8"},{"name":"43","slug":"43","filename":"EP43- Hello, My Shining Love","link_embed":"https://vip.opstream14.com/share/abfd676ad3a01f1e8860fecff9f5b8e0","link_m3u8":"https://vip.opstream14.com/20220715/18220_d6ba9def/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim kể về cô gái mạnh mẽ, thành đạt Độc Cô Nhược Nam (do Trần Kiều Ân thủ vai) bỗng dưng bị nghệ sĩ dưới quyền quản lý của mình là Tống Tử Hào (do Vương Tử Duệ thủ vai) và nhân viên bắt tay nhau phản bội, sự nghiệp đang đà thăng tiến bỗng rơi xuống vực thẳm chỉ trong một đêm. Nhược Nam chưa bao giờ chịu thua, thề phải quay về thời kỳ huy hoàng. Cô dốc bao tâm huyết lăng xê Tư Đạt (do Trần Hựu Duy thủ vai), trong hành trình khởi đầu sự nghiệp lần thứ hai, trời xui đất khiến Độc Cô Nhược Nam lại cùng tổng giám đốc vừa nho nhã vừa độc miệng là Quý Mặc (do Kim Hạn thủ vai) bắt đầu cuộc hành trình vừa tô điểm cho nhau vừa soi tỏ cá tính riêng và sưởi ấm lẫn nhau, hai con người từng chịu tổn thương trong tình cảm cùng trình diễn một cuộc chiến ái tình trưởng thành đầy sâu sắc...</p>","tmdb":{"type":"tv","id":"204147","season":1,"vote_average":4,"vote_count":2},"modified":"2022-07-15T04:21:11.000Z","cast":["Kim Hãn","Trần Kiều Ân","Trần Hựu Duy","Trâu Đình Uy","Wang Jianing","Vương Tử Duệ","Vương Tử Hiên"],"director":["Chen Mingzhang"],"cast_meta":[{"name":"Kim Hãn","name_vi":"Kim Hãn","name_original":"Jin Han","tmdb_id":2123398,"profile":"https://image.tmdb.org/t/p/w500/lelUjhsbZve5AMe2RWD1L9RCkXs.jpg","tmdb_url":"https://www.themoviedb.org/person/2123398"},{"name":"Trần Kiều Ân","name_vi":"Trần Kiều Ân","name_original":"Joe Chen","tmdb_id":1239952,"profile":"https://image.tmdb.org/t/p/w500/1ExQFQRhiivl35kLycW6k2UU1pU.jpg","tmdb_url":"https://www.themoviedb.org/person/12399