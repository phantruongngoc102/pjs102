am15.com/share/9426e9770a77cbcaefe1fb3a7e36327d","link_m3u8":"https://vip.opstream15.com/20220527/17041_772ca62b/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/9a96179f5027c861921aaa4c88ddcf85","link_m3u8":"https://vip.opstream15.com/20220527/17042_c13eaf18/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/02a4f95155ad30321d3a88b53b85f2d6","link_m3u8":"https://vip.opstream15.com/20220527/17044_67c62ad0/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/db90e948252c7d1753efe6fc9612dabe","link_m3u8":"https://vip.opstream15.com/20220527/17046_62e92f74/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/f9c8cde98a8d6dfda2273e26fedaeda8","link_m3u8":"https://vip.opstream15.com/20220527/17049_540970a6/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream15.com/share/9aeadabd8172e574de598c611e410eed","link_m3u8":"https://vip.opstream15.com/20220527/17050_38c5fb56/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream15.com/share/40ab3567559c1b511cd5f61365aae953","link_m3u8":"https://vip.opstream15.com/20220527/17052_3ee51e8e/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream15.com/share/07fb6ce39032041f0d9e1cbeb08f2fb2","link_m3u8":"https://vip.opstream15.com/20220527/17054_d0c3f2b0/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream15.com/share/2f834c6dc78805618e628fa9f02a39e4","link_m3u8":"https://vip.opstream15.com/20220527/17056_e5e83435/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream15.com/share/523f43693bfa6c607d2fe43b43ba96fd","link_m3u8":"https://vip.opstream15.com/20220527/17058_08af921c/index.m3u8"}]}],"description":"<p>Bộ phim chuyển thể từ tiểu thuyết cùng tên của Huyền Ẩn. Có một loại tình yêu là vì phân ly. Sáu năm trước, bạn trai Vương Lịch Xuyên không từ mà biệt. Từ đó trở đi, Tiểu Thu bị vây khốn trong những trắc trở của tình yêu. Cô không hiểu sao tình yêu sâu đậm nồng nhiệt sau một đêm lại hóa thành mây khói. Lý do Lịch Xuyên rời bỏ Tiểu Thu trở thành sự dày vò của Tiểu Thu. Sau này tình cờ gặp lại, trong vòng xoáy xoay vần tiến thoái lưỡng nan, đối mặt với sự trầm mặc, nhẫn nhịn của người đàn ông cực phẩm, Tiểu Thu đột nhiên hiểu ra hạnh phúc từ trước đến nay đều không phải dễ dàng có được. Khiếm khuyết và hoàn mỹ thật ra lúc nào cũng như hình với bóng.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ga/gap-go-vuong-lich-xuyen.json"}