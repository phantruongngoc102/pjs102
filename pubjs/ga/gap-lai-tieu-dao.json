e5d8c0a40bd9","link_m3u8":"https://vip.opstream17.com/20240425/5937_1eae9049/index.m3u8"}]}],"description":"<p>Tiểu nhị Lý Tiêu Dao có ước mơ trở thành đại hiệp tình cờ gặp được Triệu Linh Nhi, hậu duệ của Nữ Oa. Họ kết bạn và cùng nhau đi tìm Thủy Linh Châu có thể chấm dứt nạn hạn hán khắp thiên hạ. Trên đường đi, họ lần lượt kết giao với nhiều người bạn cùng chí hướng như oan gia Lâm Nguyệt Như, thư sinh nho nhã Lưu Tấn Nguyên... Cả nhóm cùng nhau vượt qua khó khăn, nguy hiểm để tìm kiếm linh châu, đập tan âm mưu đáng sợ là hủy diệt cả thế giới của Bái Nguyệt giáo chủ.</p><p>&nbsp;</p>","tmdb_id":213882,"cast":["Hà Dữ","Dương Vũ Đồng","Từ Hảo","Li Chuan","Diệp Thịnh Giai","Hồ Ý Hoàn","Vương Kính Tùng","Ngô Việt","Đinh Tiểu Oánh","Huang Xing"],"director":["Yang Long"],"keywords":[],"tmdb":{"type":"tv","id":"213882","season":1,"vote_average":6.4,"vote_count":5},"cast_meta":[{"name":"Hà Dữ","name_vi":"Hà Dữ","name_original":"He Yu","tmdb_id":2650306,"profile":"https://image.tmdb.org/t/p/w500/xgXKg2EgqrCGKghJ1QEkJ1dCSEf.jpg","tmdb_url":"https://www.themoviedb.org/person/2650306"},{"name":"Dương Vũ Đồng","name_vi":"Dương Vũ Đồng","name_original":"Yang Yutong","tmdb_id":3445470,"profile":"https://image.tmdb.org/t/p/w500/5gGixj3RSBEzpB7cFXwSVq7FBam.jpg","tmdb_url":"https://www.themoviedb.org/person/3445470"},{"name":"Từ Hảo","name_vi":"Từ Hảo","name_original":"Xu Hao","tmdb_id":2590478,"profile":"https://image.tmdb.org/t/p/w500/ga160oB0YlT8sxd80JPTvHBu5go.jpg","tmdb_url":"https://www.themoviedb.org/person/2590478"},{"name":"Li Chuan","name_vi":null,"name_original":"Li Chuan","tmdb_id":1846861,"profile":"https://image.tmdb.org/t/p/w500/aYswXVsa6gCoTKOqHYSOpS3bjsS.jpg","tmdb_url":"https://www.themoviedb.org/person/1846861"},{"name":"Diệp Thịnh Giai","name_vi":"Diệp Thịnh Giai","name_original":"Ye Shengjia","tmdb_id":2913711,"profile":"https://image.tmdb.org/t/p/w500/q17RhwdKWhzCcfYjM6XwD0jDsEo.jpg","tmdb_url":"https://www.themoviedb.org/person/2913711"},{"name":"Hồ Ý Hoàn"