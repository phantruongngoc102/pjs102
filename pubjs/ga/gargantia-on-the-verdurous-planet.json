ống với nhau trên những chiếc thuyền khổng lồ.</p>","tmdb_id":55011,"cast":["Hisako Kanemoto","Ishikawa Kaito","Ai Kayano","Hideaki Tezuka","Kana Asumi","Katsuyuki Konishi","Sayaka Ohara","Shizuka Itoh","Tomokazu Sugita","Yuka Terasaki","Yuki Hayashi","Yuki Ono"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"55011","season":1,"vote_average":7.2,"vote_count":72},"cast_meta":[{"name":"Hisako Kanemoto","name_vi":null,"name_original":"Hisako Kanemoto","tmdb_id":1116333,"profile":"https://image.tmdb.org/t/p/w500/qyJPQaehMc4Sy5jaTfIJLdrll2v.jpg","tmdb_url":"https://www.themoviedb.org/person/1116333"},{"name":"Ishikawa Kaito","name_vi":"Ishikawa Kaito","name_original":"Kaito Ishikawa","tmdb_id":1324666,"profile":"https://image.tmdb.org/t/p/w500/fzjIkotjUHHs3wgftM9tqdsG8ph.jpg","tmdb_url":"https://www.themoviedb.org/person/1324666"},{"name":"Ai Kayano","name_vi":null,"name_original":"Ai Kayano","tmdb_id":1254671,"profile":"https://image.tmdb.org/t/p/w500/l8ywp387rfdAS7mOExe3cEZnsk0.jpg","tmdb_url":"https://www.themoviedb.org/person/1254671"},{"name":"Hideaki Tezuka","name_vi":null,"name_original":"Hideaki Tezuka","tmdb_id":224454,"profile":"https://image.tmdb.org/t/p/w500/9zJhLamvMx9cUgBAl8i0lmXUfo0.jpg","tmdb_url":"https://www.themoviedb.org/person/224454"},{"name":"Kana Asumi","name_vi":null,"name_original":"Kana Asumi","tmdb_id":227879,"profile":"https://image.tmdb.org/t/p/w500/5GroiCPTO6PcYaZQXTGWltoT1kq.jpg","tmdb_url":"https://www.themoviedb.org/person/227879"},{"name":"Katsuyuki Konishi","name_vi":null,"name_original":"Katsuyuki Konishi","tmdb_id":24647,"profile":"https://image.tmdb.org/t/p/w500/nYM5cH6U7cp4x9dIzW0enmEKmeV.jpg","tmdb_url":"https://www.themoviedb.org/person/24647"},{"name":"Sayaka Ohara","name_vi":null,"name_original":"Sayaka Ohara","tmdb_id":148447,"profile":"https://image.tmdb.org/t/p/w500/4WQXLzj0gjYqkYFcTTxAkIwedvr.jpg","tmdb_url":"https://www.themoviedb.org/person/148447"},{"name":"Shizuka Itoh","name_vi":null,"name_original":"Shizuka Ito