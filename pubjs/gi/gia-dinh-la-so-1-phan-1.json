uộc hôn nhân vội vàng.</p>","tmdb":{"type":"tv","id":"3729","season":1,"vote_average":8.5,"vote_count":13},"modified":"2022-10-27T12:20:43.000Z","cast":["Park Hae-mi","Jeong Jun-ha","Kim Hye-seong","Jung Il-woo","Lee Soon-jae","Choi Min-yong","Park Min-young","Kim Bum","Shin Ji","Suh Min-jung","Na Moon-hee","Hwang Chan-sung","Kim Yeong-ok","Lee Tae-ri","Lee Su-na"],"director":["Kim Byeong Wook","Kim Young Ki","Kim Cha Dong"],"cast_meta":[{"name":"Park Hae-mi","name_vi":null,"name_original":"Park Hae-mi","tmdb_id":1234596,"profile":"https://image.tmdb.org/t/p/w500/bDdGh3m6zIwHZ3Wg6TNF5Qm0MAV.jpg","tmdb_url":"https://www.themoviedb.org/person/1234596"},{"name":"Jeong Jun-ha","name_vi":null,"name_original":"Jeong Jun-ha","tmdb_id":1234597,"profile":"https://image.tmdb.org/t/p/w500/fNcdFdfAQuQXVd6fBLwH1ijXwvs.jpg","tmdb_url":"https://www.themoviedb.org/person/1234597"},{"name":"Kim Hye-seong","name_vi":null,"name_original":"Kim Hye-seong","tmdb_id":1234599,"profile":"https://image.tmdb.org/t/p/w500/srOAI66xNTR6QZ5SbqN1gwVYbCv.jpg","tmdb_url":"https://www.themoviedb.org/person/1234599"},{"name":"Jung Il-woo","name_vi":"Jung Il-woo","name_original":"Jung Il-woo","tmdb_id":1234600,"profile":"https://image.tmdb.org/t/p/w500/znYZO1v1oJr48YXA3UNY62h3ZFp.jpg","tmdb_url":"https://www.themoviedb.org/person/1234600"},{"name":"Lee Soon-jae","name_vi":null,"name_original":"Lee Soon-jae","tmdb_id":566367,"profile":"https://image.tmdb.org/t/p/w500/zYjhQJ27PUY2hxiIr50AIJ7TWa8.jpg","tmdb_url":"https://www.themoviedb.org/person/566367"},{"name":"Choi Min-yong","name_vi":null,"name_original":"Choi Min-yong","tmdb_id":1234602,"profile":"https://image.tmdb.org/t/p/w500/tAc3NG4PGCrNxKEhptAr7CEaVsT.jpg","tmdb_url":"https://www.themoviedb.org/person/1234602"},{"name":"Park Min-young","name_vi":null,"name_original":"Park Min-young","tmdb_id":1234603,"profile":"https://image.tmdb.org/t/p/w500/5Op0Gx0DULFLHtGdWVdqnYdwkAS.jpg","tmdb_url":"https://www.themoviedb.org/person/1234603"},{"name":"Kim B