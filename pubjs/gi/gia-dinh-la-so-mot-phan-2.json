/share/adc2ae7cea48a58d0a7dcbe2a88fd856","link_m3u8":"https://vip.opstream15.com/20220520/15758_488ea27d/index.m3u8"}]}],"time":"","description":"<p>Gia Đình Là Số 1 là bộ phim sitcom thuộc thể loại hài hước với nhiều tình huống vui nhộn, hấp dẫn thu hút sự chú ý của hàng ngàn khán giả. Bộ phim đã tạo ra một bước ngoặc hoàn toàn mới trong điện ảnh Hàn Quốc, với sự tham gia của các diễn viên nổi tiếng và được yêu thích vào thời điểm hiện tại. Bộ phim kể về một gia đình hiện đại Hàn Quốc với những thành viên trong gia đình có những tính cách hoàn toàn khác nhau đã diễn tả một cách hết sức gần gũi cuộc sống đời thường trong một gia đình hiện đại tại đất nước kim chi này. Phim không như những bộ phim khác nói về chuyện tình yêu lãng mạng đầy nước mắt hay những cảnh quay với những khung cảnh đẹp mê hồn mà chủ yếu nói về những tình tiết hài hước trong cuộc sống hàng ngày, khiến người xem có những phút giây cười thoải mái...</p>","tmdb":{"type":"tv","id":"83518","season":1,"vote_average":7.333,"vote_count":12},"modified":"2022-05-24T10:49:20.000Z","cast":["Soon-jae Lee","Hye-sung Kim","Min-yong Choi"],"director":["Kim Byeong-Wook","Kim Cha-Dong","Kim Yeong-Ki"],"cast_meta":[{"name":"Soon-jae Lee","name_vi":null,"name_original":"Soon-jae Lee"},{"name":"Hye-sung Kim","name_vi":null,"name_original":"Hye-sung Kim"},{"name":"Min-yong Choi","name_vi":null,"name_original":"Min-yong Choi"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/gi/gia-dinh-la-so-mot-phan-2.json"}