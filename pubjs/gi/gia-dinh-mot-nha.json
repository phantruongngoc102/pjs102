70_4641f63d/index.m3u8"},{"name":"15","slug":"15","filename":"Gia Đình Một Nhà - Tập 15---2021","link_embed":"https://vip.opstream13.com/share/95e2b3bc377ab32c26e010300ce0081b","link_m3u8":"https://vip.opstream13.com/20251025/13971_95e2b3bc/index.m3u8"},{"name":"16","slug":"16","filename":"Gia Đình Một Nhà - Tập 16---2021","link_embed":"https://vip.opstream13.com/share/c4d856156b2c629314b9edd13523fe8e","link_m3u8":"https://vip.opstream13.com/20251025/13972_c4d85615/index.m3u8"}]}],"time":"25 phút/tập","description":"<p>Mã Đại, một lập trình viên tự do, sống trong căn nhà tái định cư của ông nội Mã Thiên Minh, còn ông nội thì sống trong một căn nhà ba phòng ngủ khác với cháu gái và gia đình cô. Họ đã mở một tiệm mát-xa trong khu dân cư. Một ngày nọ, Mã Thiên Minh vô tình làm bong gân một khách hàng và phải nhập viện. Để kiếm tiền bồi thường, anh quyết định cho thuê căn nhà hai phòng ngủ nơi Mã Đại đang sống. Vậy là Mã Đại bắt đầu cuộc sống chung với Bành Vi Vi, người dẫn chương trình của Taobao Live. Hai người ban đầu bất hòa, dần dần nảy sinh tình cảm. Kể từ đó, cuộc sống thường nhật của khu dân cư tái định cư luôn tràn ngập tiếng cười và những lời trách móc.</p>","tmdb":{"type":"tv","id":"130172","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-27T10:24:58.000Z","cast":["Ma Shuliang","Zhang Haiyu","He Ping","Wei Lai","Liang Wen Hui","Xuanrui Liu","Chen Xixu","Hải Nhất Thiên","Lý Kiến Nghĩa","Jia Bing","Hạ Chi Quang","Sa Dật","Ni Ping","Hàn Hạo Lâm","Đàn Kiện Thứ"],"director":["徐小朋"],"cast_meta":[{"name":"Ma Shuliang","name_vi":null,"name_original":"Ma Shuliang","tmdb_id":1353692,"profile":"https://image.tmdb.org/t/p/w500/nRK6owQ3q5rWH0R4U7JBXZCeXNa.jpg","tmdb_url":"https://www.themoviedb.org/person/1353692"},{"name":"Zhang Haiyu","name_vi":null,"name_original":"Zhang Haiyu","tmdb_id":1970992,"profile":"https://image.tmdb.org/t/p/w500/zjKhiWDdlcMd8yx6D7YfQZglks7.jpg","tmdb_url":"https://www.themoviedb.org/person/1970992"},{"name":"He Ping","name_vi":n