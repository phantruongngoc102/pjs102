t.</p><p>Từ một “vỏ bọc nhiệm vụ”, họ bất ngờ tìm thấy thứ mà mình chưa từng có — một mái ấm thực sự.</p>","tmdb_id":279873,"cast":["Leo Yang","Carmen Tong Ka-Man","Mu Le'en","Yu Yifu","Feng Mi","Wang Zhonghao","Trương Hinh Nguyệt","Zhu Hong","Fan Yize"],"director":["周九钦"],"keywords":[],"tmdb":{"type":"tv","id":"279873","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Leo Yang","name_vi":null,"name_original":"Leo Yang","tmdb_id":2480231,"profile":"https://image.tmdb.org/t/p/w500/dOjn9t7lUVlXdMsY6JUsNXSyccp.jpg","tmdb_url":"https://www.themoviedb.org/person/2480231"},{"name":"Carmen Tong Ka-Man","name_vi":null,"name_original":"Carmen Tong Ka-Man","tmdb_id":2070579,"profile":"https://image.tmdb.org/t/p/w500/lJxtckkXteDCYVHuB7YmCZBINYF.jpg","tmdb_url":"https://www.themoviedb.org/person/2070579"},{"name":"Mu Le'en","name_vi":null,"name_original":"Mu Le'en","tmdb_id":2359899,"profile":"https://image.tmdb.org/t/p/w500/fRfFU0VR6OBYgIQGypCGi7BoJ0N.jpg","tmdb_url":"https://www.themoviedb.org/person/2359899"},{"name":"Yu Yifu","name_vi":null,"name_original":"Yu Yifu","tmdb_id":2482909,"profile":"https://image.tmdb.org/t/p/w500/AjvpFlWQDW9XrlH6eYXWV1nXoFk.jpg","tmdb_url":"https://www.themoviedb.org/person/2482909"},{"name":"Feng Mi","name_vi":null,"name_original":"Feng Mi","tmdb_id":5523490,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5523490"},{"name":"Wang Zhonghao","name_vi":null,"name_original":"Wang Zhonghao","tmdb_id":3143026,"profile":"https://image.tmdb.org/t/p/w500/4zvU0a89Ie8ueIgKRfzPgRkMRnC.jpg","tmdb_url":"https://www.themoviedb.org/person/3143026"},{"name":"Trương Hinh Nguyệt","name_vi":"Trương Hinh Nguyệt","name_original":"Zhang Xinyue","tmdb_id":3942537,"profile":"https://image.tmdb.org/t/p/w500/fAR54onP9VUuS1m0JeEvNNcCCIp.jpg","tmdb_url":"https://www.themoviedb.org/person/3942537"},{"name":"Zhu Hong","name_vi":null,"name_original":"Zhu Hong","tmdb_id":2081506,"profile":"https://image.tmdb.org/t/p/w500/xd3XJQRwe9NEjn6ZvwOV9DH0weh