8"},{"name":"26","slug":"26","filename":"Aile 26","link_embed":"https://vip.opstream13.com/share/5352696a9ca3397beb79f116f3a33991","link_m3u8":"https://vip.opstream13.com/20231230/2032_3d257aab/index.m3u8"},{"name":"27","slug":"27","filename":"Aile 27","link_embed":"https://vip.opstream13.com/share/6cd9313ed34ef58bad3fdd504355e72c","link_m3u8":"https://vip.opstream13.com/20240114/2229_58411800/index.m3u8"},{"name":"28","slug":"28","filename":"Aile 28","link_embed":"https://vip.opstream13.com/share/f1e2b2c9255d552500a833ac828cd635","link_m3u8":"https://vip.opstream13.com/20240120/2326_0dec7011/index.m3u8"},{"name":"29","slug":"29","filename":"Aile 29","link_embed":"https://vip.opstream13.com/share/54b2b21af94108d83c2a909d5b0a6a50","link_m3u8":"https://vip.opstream13.com/20240127/2458_13aaadbe/index.m3u8"},{"name":"30","slug":"30","filename":"Aile 30","link_embed":"https://vip.opstream13.com/share/9457fc28ceb408103e13533e4a5b6bd1","link_m3u8":"https://vip.opstream13.com/20240203/2578_396f4b6e/index.m3u8"}]}],"time":"120 phút/tập","description":"<p>Chiếc bàn là nơi duy nhất nhắc nhở người Soykan rằng họ là 'gia đình'. Ngày hôm đó, trong khi đang dọn bàn để cả gia đình quây quần, Aslan có mặt trên chuyến bay đến Izmir để giải quyết một trong những chuyện \"đen tối\" liên quan đến chú của mình.</p><p>Nhà tâm lý học Devin và Aslan gặp nhau trên hành trình này. Devin cũng sẽ đến Izmir để giải quyết một rắc rối mới mà em gái anh ấy vướng phải. Rất rõ ràng rằng họ là những người thuộc các thế giới khác nhau. Nhưng không mất nhiều thời gian để họ phát hiện ra 'vết thương' chung của mình; những gia đình của họ.</p><p>Aslan đã phá vỡ một quy tắc rất quan trọng của Hiến pháp Soykan đối với Devin ngay từ đêm đầu tiên. Điều này là đủ để mẹ cô là Hülya, người luôn cảm thấy có một sự gắn bó ám ảnh với Aslan, nhận ra mối nguy hiểm lớn đang đến gần; Devin.</p><p>Công việc của Hülya, người đã nhiều lần thể hiện rằng cô ấy có thể làm mọi cách để ngăn con trai mình rời xa gia đình, sẽ không còn dễ dàng như trước vào thời điểm này. Tuy nhiên, Hülya không phải là người duy nhất có công việc không dễ dàng. Cuộc chạm trán trên máy bay Izmir sẽ chỉ là khởi đầu của con đường khó khăn mà những anh hùng bị thương của chúng ta sẽ đi để thành lập gia đình của riêng họ.</p>","tmdb":{"type":"tv","id":"219446","season":1,"vote_average":7.639,"vote_count":36},"modified":"2024-02-03T21:41:25.000Z","cast":["Kıvanç Tatlıtuğ","Serenay Sarıkaya","Nur Sürer","Nejat İşler","Canan Ergüder","Yüsra Geyik","Umutcan Ütebay","Emel Göksu","İpek Tenolcay","Abdurrahman Yunusoğlu","Musa Uzunlar","Selin Şekerci","Ayda Aksel","Alper Çankaya","Rüçhan Çalışkur"],"director":["Ahmet Katıksız"],"cast_meta":[{"name":"Kıvanç Tatlıtuğ","name_vi":null,"name_original":"Kıvanç Tatlıtuğ","tmdb_id":1078769,"profile":"https://image.tmdb.org/t/p/w500/rs7Z3PKa82UhKGQLrBNAy0JAWV5.jpg","tmdb_url":"https://www.themoviedb.org/person/1078769"},{"name":"Serenay Sarıkaya","name_vi":null,"name_original":"Serenay Sarıkaya","tmdb_id":1258305,"profile":"https://image.tmdb.org/t/p/w500/1SJAapOz81mn34WTmlx0SoPIVm.jpg","tmdb_url":"https://www.themoviedb.org/person/1258305"},{"name":"Nur Sürer","name_vi":null,"name_original":"Nur Sürer","tmdb_id":142781,"profile":"https://image.tmdb.org/t/p/w500/dHTgCwwmGyvJK5LyCpFtzYpap2d.jpg","tmdb_url":"https://www.themoviedb.org/person/142781"},{"name":"Nejat İşler","name_vi":null,"name_original":"Nejat İşler","tmdb_id":98834,"profile":"https://image.tmdb.org/t/p/w500/xFhmBekB2odhRY335lJ6rWiIdyw.jpg","tmdb_url":"https://www.themoviedb.org/person/98834"},{"name":"Canan Ergüder","name_vi":null,"name_original":"Canan Ergüder","tmdb_id":1254543,"profile":"https://image.tmdb.org/t/p/w500/8CCShaweDW2bdvb0dqkf1DIsfvu.jpg","tmdb_url":"https://www.themoviedb.org/person/1254543"},{"name":"Yüsra Geyik","name_vi":null,"name_original":"Yüsra Geyik","tmdb_id":1252057,"profile":"https://image.tmdb.org/t/p/w500/iIhe8VNWk8Du7DGDqWV952k69hY.jpg","tmdb_url":"https://www.themoviedb.org/person/