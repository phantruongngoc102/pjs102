uộc sống luôn gặp những điều rắc rối. Cô chị cả Hae Ryung tuy có một gia đình ấm áp nhưng đó chỉ là vẻ bên ngoài, cô luôn phải hứng chịu những áp lực không nhỏ từ ngôi nhà nhỏ của mình, cậu thứ 2 thì luôn phải dựa vào vợ mình và luôn bị xem nhẹ vì kém cỏi còn cô út thì Hae Won là một người phụ nữ xinh đẹp và thành công nhưng luôn gặp rắc rối từ sếp mình.","tmdb_id":65714,"cast":["Kim So-yeon","Lee Sang-woo","Lee Pil-mo","Kim Yeong-cheol","Kang Yi-eun","Won Mi-kyung","Jang In-sub","Yoon Da-hoon","So Hee-jung","Ji Soo-won","Ahn Hyo Seop","Park Ji-il","Kim Sa-rang"],"director":["Lee Dong-yoon"],"keywords":[],"tmdb":{"type":"tv","id":"65714","season":1,"vote_average":5.6,"vote_count":5},"cast_meta":[{"name":"Kim So-yeon","name_vi":null,"name_original":"Kim So-yeon","tmdb_id":148673,"profile":"https://image.tmdb.org/t/p/w500/3N97WhQVtQjyVYtmrrTK4Wt98Rc.jpg","tmdb_url":"https://www.themoviedb.org/person/148673"},{"name":"Lee Sang-woo","name_vi":null,"name_original":"Lee Sang-woo","tmdb_id":1254391,"profile":"https://image.tmdb.org/t/p/w500/4j3gHnhVUcSVPOmJRaabbYsJNVD.jpg","tmdb_url":"https://www.themoviedb.org/person/1254391"},{"name":"Lee Pil-mo","name_vi":null,"name_original":"Lee Pil-mo","tmdb_id":1352803,"profile":"https://image.tmdb.org/t/p/w500/sVnDH47xdLtTs3dyHkZu6LzWkGn.jpg","tmdb_url":"https://www.themoviedb.org/person/1352803"},{"name":"Kim Yeong-cheol","name_vi":null,"name_original":"Kim Yeong-cheol","tmdb_id":69080,"profile":"https://image.tmdb.org/t/p/w500/ubEiUU1qZrURs3JLQcKb3VQDhZd.jpg","tmdb_url":"https://www.themoviedb.org/person/69080"},{"name":"Kang Yi-eun","name_vi":null,"name_original":"Kang Yi-eun","tmdb_id":1643330,"profile":"https://image.tmdb.org/t/p/w500/rri7gmWu4CZbQQaz0o2u0HPcvjU.jpg","tmdb_url":"https://www.themoviedb.org/person/1643330"},{"name":"Won Mi-kyung","name_vi":null,"name_original":"Won Mi-kyung","tmdb_id":1249318,"profile":"https://image.tmdb.org/t/p/w500/wWwtM0g47D2sYsVKxBTX3IjH6su.jpg","tmdb_url":"https://www.themoviedb.org/person