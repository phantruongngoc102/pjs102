i kể từ lần đầu tiên họ đến Mê cung. Thomas sẽ và phi hành đoàn làm cho nó sống? Hoặc ava paige sẽ có được cách của cô ấy?</p>","tmdb":{"type":"movie","id":"336843","season":null,"vote_average":7.087,"vote_count":8245},"modified":"2023-04-12T00:21:43.000Z","cast":["Dylan O'Brien","Kaya Scodelario","Thomas Brodie-Sangster","Ki Hong Lee","Dexter Darden","Rosa Salazar","Giancarlo Esposito","Will Poulter","Aidan Gillen","Patricia Clarkson","Barry Pepper","Walton Goggins","Nathalie Emmanuel","Jacob Lofland","Katherine McNamara"],"director":["Wes Ball"],"cast_meta":[{"name":"Dylan O'Brien","name_vi":null,"name_original":"Dylan O'Brien","tmdb_id":527393,"profile":"https://image.tmdb.org/t/p/w500/xN3GdvIlqsR838gDoblhPH0numP.jpg","tmdb_url":"https://www.themoviedb.org/person/527393"},{"name":"Kaya Scodelario","name_vi":null,"name_original":"Kaya Scodelario","tmdb_id":115150,"profile":"https://image.tmdb.org/t/p/w500/uVp7VarM5GX08hfCEGt63OM5c5c.jpg","tmdb_url":"https://www.themoviedb.org/person/115150"},{"name":"Thomas Brodie-Sangster","name_vi":null,"name_original":"Thomas Brodie-Sangster","tmdb_id":25663,"profile":"https://image.tmdb.org/t/p/w500/ovfgjgaE7aAXKYaemABX6pJFwRk.jpg","tmdb_url":"https://www.themoviedb.org/person/25663"},{"name":"Ki Hong Lee","name_vi":null,"name_original":"Ki Hong Lee","tmdb_id":1310760,"profile":"https://image.tmdb.org/t/p/w500/96zkB3e07LB1hw2segekZS1PlQb.jpg","tmdb_url":"https://www.themoviedb.org/person/1310760"},{"name":"Dexter Darden","name_vi":null,"name_original":"Dexter Darden","tmdb_id":1036196,"profile":"https://image.tmdb.org/t/p/w500/4Io5JOdl17GtCaXt0ZBv0p6IEEk.jpg","tmdb_url":"https://www.themoviedb.org/person/1036196"},{"name":"Rosa Salazar","name_vi":null,"name_original":"Rosa Salazar","tmdb_id":973667,"profile":"https://image.tmdb.org/t/p/w500/f8MITeVNUrP9mMiXcPnCEZTIW56.jpg","tmdb_url":"https://www.themoviedb.org/person/973667"},{"name":"Giancarlo Esposito","name_vi":null,"name_original":"Giancarlo Esposito","tmdb_id":4808,"prof