12.com/share/ea5b254610d3af85fb861cc7be787ad5","link_m3u8":"https://vip.opstream12.com/20250227/25488_ea5b2546/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/99e54f99035fe00a5b02e468dedeb7fe","link_m3u8":"https://vip.opstream12.com/20250227/25499_99e54f99/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/108fe115000c147427da50c2b0c9ce31","link_m3u8":"https://vip.opstream12.com/20250227/25500_108fe115/index.m3u8"}]}],"description":"Bác sỹ cao cấp chuyên khoa tâm thần thuộc bệnh viện Nhân Hòa - Cao Lập Nhân (Phương Trung Tín đóng) là một lương y nhân ái và có giàu kinh nghiệm về bệnh tâm thần phân liệt và hội chứng thiểu năng. Tuy nhiên, cách làm việc của Lập Nhân đôi lúc khó hiểu, lạ thường nhưng cũng rất thú vị. Anh không đơn thuần chữa trị cho bệnh nhân bằng các phương pháp y khoa mà còn áp dụng các liệu pháp phân tích tâm lý trong lúc điều trị. Trong bệnh viện, bác sỹ Liên Chí Thâm (Tưởng Chí Quang đóng) và anh chàng điều dưỡng viên Lý Ứng Xuân (Huỳnh Hạo Nhiên đóng) là hai người bạn chí cốt của Lập Nhân. Chí Thâm là một bác sỹ tốt bụng. Trong một lần, anh điều trị cho một bệnh nhân tên Tôn Gia Bích (Dương Tú Huệ đóng), do say rượu nên bị rối loạn tiêu hóa. Thâm và Bích phải trải qua nhiều khó khăn để đến với nhau.","tmdb_id":18678,"cast":["Ngao Gia Niên","Nhạc Hoa","Yoyo Chen Chi-Yiu","Charmaine Li","Ellesmere Choi","Vivien Yeo","Suki Chui","Huỳnh Hạo Nhiên","Natalie Tong","Ben Wong Chi-Yin","Kate Tsui Tsz-Shan","Trần Triển Bằng","Phương Trung Tín","Kwan Ching","Hồng Thiên Minh"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"18678","season":1,"vote_average":7,"vote_count":1},"cast_meta":[{"name":"Ngao Gia Niên","name_vi":"Ngao Gia Niên","name_original":"Ngo Ka-Nin","tmdb_id":1240871,"profile":"https://image.tmdb.org/t/p/w500/cvFz4MA8jN7GXbfaIgjho1XYPCJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1240871"},{"name":"Nhạc Hoa","name_vi":"Nhạc Hoa","name_original":"Elliot Ngok Wah