ắt đầu lại cuộc đời mới cho mình. Đột nhiên, 1 vụ giết người liên hoàn khủng khiếp xuất hiện và Cao Lập Nhân phát hiện Lâm Tụng Ân có dính líu đến, cô cũng có vấn đề về tâm thần…","tmdb":{"type":"tv","id":"46839","season":1,"vote_average":0,"vote_count":0},"modified":"2025-03-01T09:41:07.000Z","cast":["Phương Trung Tín","Mông Gia Tuệ","Dương Thiến Nghiêu","Ram Chiang Chi-Kwong","Ben Wong Chi-Yin","Tiêu Chính Nam","Huỳnh Hạo Nhiên","Aimee Chan","Oscar Leung Lit-Wai"],"director":[],"cast_meta":[{"name":"Phương Trung Tín","name_vi":"Phương Trung Tín","name_original":"Alex Fong Chung-Sun","tmdb_id":21914,"profile":"https://image.tmdb.org/t/p/w500/qQKB910E3e2YLOQs4WdaouJiFJE.jpg","tmdb_url":"https://www.themoviedb.org/person/21914"},{"name":"Mông Gia Tuệ","name_vi":"Mông Gia Tuệ","name_original":"Yoyo Mung Ka-Wai","tmdb_id":25248,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/25248"},{"name":"Dương Thiến Nghiêu","name_vi":"Dương Thiến Nghiêu","name_original":"Tavia Yeung","tmdb_id":1222259,"profile":"https://image.tmdb.org/t/p/w500/tuvy2JTxuYPzkS6YqYJ0RvOlPlE.jpg","tmdb_url":"https://www.themoviedb.org/person/1222259"},{"name":"Ram Chiang Chi-Kwong","name_vi":null,"name_original":"Ram Chiang Chi-Kwong","tmdb_id":1083956,"profile":"https://image.tmdb.org/t/p/w500/7ikYgSecvhDXc8tQgqFucBitfG0.jpg","tmdb_url":"https://www.themoviedb.org/person/1083956"},{"name":"Ben Wong Chi-Yin","name_vi":null,"name_original":"Ben Wong Chi-Yin","tmdb_id":1192984,"profile":"https://image.tmdb.org/t/p/w500/yhL5DLBZv4BQIWIZQROvoNGyZuw.jpg","tmdb_url":"https://www.themoviedb.org/person/1192984"},{"name":"Tiêu Chính Nam","name_vi":"Tiêu Chính Nam","name_original":"Edwin Siu","tmdb_id":1059226,"profile":"https://image.tmdb.org/t/p/w500/bPEjnmBPWTZcrWQklkqcT1bUQwb.jpg","tmdb_url":"https://www.themoviedb.org/person/1059226"},{"name":"Huỳnh Hạo Nhiên","name_vi":"Huỳnh Hạo Nhiên","name_original":"Raymond Ho-Yin Wong","tmdb_id":123648,"profile":"https://image.tmdb.org/t/p/w500/wrs7gHK5Yk