/20220527/17086_bb087251/index.m3u8"},{"name":"22","slug":"22","filename":"giai-mat-thuyet-minh-decoded-thuyet-minh-tap-22","link_embed":"https://vip.opstream15.com/share/0fee63978c85715541a6a87d1d4d319a","link_m3u8":"https://vip.opstream15.com/20220527/17087_3e42f47e/index.m3u8"},{"name":"23","slug":"23","filename":"giai-mat-thuyet-minh-decoded-thuyet-minh-tap-23","link_embed":"https://vip.opstream15.com/share/86d3d62e1c57e5ebed8576f74b5ebbf8","link_m3u8":"https://vip.opstream15.com/20220527/17088_9a08ee2e/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Thời kỳ đầu xây dựng nước Trung Quốc mới. Nước X phái một đội đặc vụ dẫn đầu là “ Giác tỉnh giả - The awakening” đột nhập vào TQ, dùng mật mã cao cấp là “Tử Mật” để tiến hành liên lạc.Nhóm người Trịnh Dương của đơn vị đặc biệt 701 nhận lệnh đi khắp nơi tìm kiếm nhân tài, bổ sung cho lực lượng mới để phá giải được “Tử Mật” và tậm chí “Hắc Mật”- một mật mã có mức độ trí tuệ cao nhất. Đám người của “thiên tài ngốc nghếch”- thiên tài đặc biệt về số học Dung Kim Trân đã được phát hiện. Một câu chuyện bí ẩn mà vĩ đại dần dần được hé lộ.</p>","tmdb":{"type":"tv","id":"82413","season":1,"vote_average":7,"vote_count":1},"modified":"2022-06-05T15:59:00.000Z","cast":["Dĩnh Nhi","Trần Học Đông","Kinh Siêu","Trương Triết Hạn","Yin Xiaotian","Quách Kinh Phi","Wang Yanyang","An Dĩ Hiên","Vu Ba","Yang Yitong","Wang Tonghui"],"director":["An Jian"],"cast_meta":[{"name":"Dĩnh Nhi","name_vi":"Dĩnh Nhi","name_original":"Ying Er","tmdb_id":1339399,"profile":"https://image.tmdb.org/t/p/w500/6E3NhvhaS5NWqBJl9AEqEbBXDfZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1339399"},{"name":"Trần Học Đông","name_vi":"Trần Học Đông","name_original":"Chen Xuedong","tmdb_id":1193310,"profile":"https://image.tmdb.org/t/p/w500/pgzMLCxvpsh3CUto5Ag7vcx99PD.jpg","tmdb_url":"https://www.themoviedb.org/person/1193310"},{"name":"Kinh Siêu","name_vi":"Kinh Siêu","name_original":"Jing Chao","tmdb_id":1528926,"profile":"https://image.tmdb.org/t/p/w5