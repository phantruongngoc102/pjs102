index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Mùa giải này bắt đầu với việc SAMCRO cảm thấy bất lực trước vụ bắt cóc Abel, đặc biệt là Jax, người mà nỗi đau khiến anh rơi vào tình trạng hỗn loạn sâu sắc hơn về tương lai của mình với câu lạc bộ. Cuộc tìm kiếm Abel đưa các chàng trai của chúng ta đến Ireland, nơi Jax không chỉ đối mặt với Quân đội Cộng hòa Ireland mà còn cả một lịch sử cá nhân chưa kể. Trong khi đó, vẫn đang trên xe lam, Gemma phải đối mặt với một tin tức bất ngờ và mạo hiểm tự do của mình để đối phó với nó.</p>","tmdb":{"type":"tv","id":"1409","season":3,"vote_average":8.417,"vote_count":3158},"modified":"2023-02-06T07:09:49.000Z","cast":["Charlie Hunnam","Katey Sagal","Tommy Flanagan","Mark Boone Junior","Kim Coates","Theo Rossi","Dayton Callie","David Labrava","Drea De Matteo","Jimmy Smits","Niko Nicotera"],"director":[],"cast_meta":[{"name":"Charlie Hunnam","name_vi":null,"name_original":"Charlie Hunnam","tmdb_id":56365,"profile":"https://image.tmdb.org/t/p/w500/5WIDrnY25Ps2RYu0zIzHSVuSt5n.jpg","tmdb_url":"https://www.themoviedb.org/person/56365"},{"name":"Katey Sagal","name_vi":null,"name_original":"Katey Sagal","tmdb_id":18980,"profile":"https://image.tmdb.org/t/p/w500/jdnBWdXlQG2Q2F6v9MPJkaWQ9Vd.jpg","tmdb_url":"https://www.themoviedb.org/person/18980"},{"name":"Tommy Flanagan","name_vi":null,"name_original":"Tommy Flanagan","tmdb_id":2478,"profile":"https://image.tmdb.org/t/p/w500/5OnvT1KpEk3juZavqOCSAEYOtwl.jpg","tmdb_url":"https://www.themoviedb.org/person/2478"},{"name":"Mark Boone Junior","name_vi":null,"name_original":"Mark Boone Junior","tmdb_id":534,"profile":"https://image.tmdb.org/t/p/w500/rcncVr356hpfKX9qOrKL3SJlEO7.jpg","tmdb_url":"https://www.themoviedb.org/person/534"},{"name":"Kim Coates","name_vi":null,"name_original":"Kim Coates","tmdb_id":8335,"profile":"https://image.tmdb.org/t/p/w500/brhVd2vTTBJNpM2ZrOFc6SnXCAd.jpg","tmdb_url":"https://www.themoviedb.org/person/8335"},{"name":"Theo Rossi","name_vi":null,"name_origin