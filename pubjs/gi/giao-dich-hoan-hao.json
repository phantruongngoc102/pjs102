0","link_m3u8":"https://vip.opstream11.com/20231027/48650_e63ef937/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream11.com/share/6f555667001fd239a4edbb3856e86489","link_m3u8":"https://vip.opstream11.com/20231027/48651_4cf6e5b9/index.m3u8"}]}],"description":"<p>Lee Joon Sung, Song Jae Hyo và Park Min Woo cùng nhau tốt nghiệp trung học và hiện đang ở độ tuổi đôi mươi. Joon Sung là một ngôi sao bóng đá đang lên khi còn học trung học, nhưng ước mơ của anh đã tan vỡ. Sau một thời gian lạc đường, anh quyết định làm lại cuộc đời. Jae Hyo, người có tên Lee Jun Sung ở trường trung học, hiện đang theo học trường y. Min Woo là con trai duy nhất của một gia đình giàu có.</p><p>Ba người bạn hẹn nhau đi uống nước và Jae Hyo, người đang phải đối mặt với khủng hoảng cá nhân, đã nhờ đến sự giúp đỡ của Jun Sung và Min Woo. Để tránh rắc rối cho bản thân, anh ta bốc đồng xúi giục giả bắt cóc Min Woo với mục tiêu kiếm được một tỷ won. Tuy nhiên, sau khi vụ bắt cóc được dàn dựng, mọi thứ diễn ra theo chiều hướng bất ngờ và những phức tạp sau đó đã đẩy cả ba người vào con đường đen tối và đầy sóng gió.</p>","tmdb_id":213320,"cast":["Yoo Seung-ho","Kim Dong-hwi","Yoo Su-bin","Lee Joo-young","Baek Ji-won","Kim Do-yoon","Lee Sung-wook","Jung Yong-ju","Woo Ji-hyun","Jeong In-kyeom","Shim Young-eun","Shin Hye-ji"],"director":["Lee Jung-gon"],"keywords":[],"tmdb":{"type":"tv","id":"213320","season":1,"vote_average":7.7,"vote_count":11},"cast_meta":[{"name":"Yoo Seung-ho","name_vi":null,"name_original":"Yoo Seung-ho","tmdb_id":110382,"profile":"https://image.tmdb.org/t/p/w500/cDkIwmfjChprlO7qaoDQl1Em54P.jpg","tmdb_url":"https://www.themoviedb.org/person/110382"},{"name":"Kim Dong-hwi","name_vi":null,"name_original":"Kim Dong-hwi","tmdb_id":2455171,"profile":"https://image.tmdb.org/t/p/w500/bW7FmJC4hL5BKdDp6L99k466pGa.jpg","tmdb_url":"https://www.themoviedb.org/person/2455171"},{"name":"Yoo Su-bin","name_vi":null,"name_original":"Yoo Su-bin","tmdb_id":2149762,"profile":"https