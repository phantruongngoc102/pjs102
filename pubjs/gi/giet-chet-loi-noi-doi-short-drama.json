/20251124/45085_4855e26d/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream-short.com/share/c0ca5d6a5e9d01d0a3090342be8d5751","link_m3u8":"https://vip.opstream-short.com/20251124/45086_c0ca5d6a/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream-short.com/share/5ce9e5e89c326160e2908b5c477ebba6","link_m3u8":"https://vip.opstream-short.com/20251124/45087_5ce9e5e8/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream-short.com/share/7cc91e71a49d62457bed9533c605da9b","link_m3u8":"https://vip.opstream-short.com/20251124/45088_7cc91e71/index.m3u8"}]}],"description":"<p>Tại một bữa tiệc tối bí ẩn đầy bí mật, những người trong ngành giải trí buộc phải đối mặt với sự thật khi một nhà sản xuất giới thiệu trò chơi 'thuốc nói thật'. Khi đêm trôi qua, những bê bối ẩn giấu lần lượt lộ diện - từ những giao dịch tham nhũng để giành vai diễn đến hình ảnh công chúng giả tạo. Căng thẳng lên đến đỉnh điểm khi xung đột nổ ra giữa một nam diễn viên và người đại diện về vụ tự tử của nữ diễn viên. Bị mắc kẹt trong mạng lưới dối trá này, các khách mời phải hợp tác để khám phá toàn bộ sự thật đằng sau bi kịch. Chỉ bằng cách tiết lộ tất cả bí mật, họ mới có thể thoát khỏi cơn ác mộng này và học cách trung thực với bản thân trong một thế giới đầy lừa dối.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/gi/giet-chet-loi-noi-doi-short-drama.json"}