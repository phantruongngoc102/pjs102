{"id":"6235c5253d016a3b6717c224","title":"Giờ Cao Điểm 2","origin_name":"Rush Hour 2","slug":"gio-cao-diem-2","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/gi/gio-cao-diem-2.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/gi/gio-cao-diem-2.webp","year":2001,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"},{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Giờ Cao Điểm 2","link_embed":"https://vip.opstream12.com/share/60495b4e033e9f60b32a6607b587aadd","link_m3u8":"https://vip.opstream12.com/20220318/4163_d0abd19e/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Đó là thời gian nghỉ để Det. James Carter và anh thấy mình cùng với Det. Lee ở Hồng Kông mong muốn phấn khích hơn. Trong khi Carter muốn tiệc tùng và gặp gỡ những người phụ nữ, Lee ra ngoài để theo dõi một Lord Gang Triad, người có thể chịu trách nhiệm giết hai người đàn ông tại Đại sứ quán Mỹ. Mọi thứ trở nên phức tạp khi cặp đôi vấp phải một âm mưu giả bởi L.A. Ông chủ tội phạm Steven Ricky và Triad Ricky Tan, một cựu cảnh sát đã đóng một vai trò bí ẩn trong cái chết của Det. Cha của Lee. Ném vào một cuộc đấu tranh quyền lực giữa Tan và Hu Li li tuyệt đẹp nhưng nguy hiểm và các chàng trai sẽ sớm đến cổ trong các trận đấu nắm đấm và các tình huống đe dọa tính mạng. Một chuyến đi trở về Hoa Kỳ có thể cung cấp các câu trả lời về vụ đánh bom, giả mạo và lòng trung thành thực sự của đại lý hải quan gợi cảm Isabella. Sau đó, một lần nữa, nó có thể trở nên phấn khích hơn Carter đang tìm kiếm trong kỳ nghỉ của mình.</p>","tmdb":{"type":"movie","id":"5175","season":null,"vote_average":6.754,"vote_count":4456},"modified":"2024-10-22T11:03:51.000Z","cast":["Thành Long","Chris Tucker","John Lone","Roselyn Sánchez","Chương Tử Di","Alan King","Harris Yulin","Tăng Giang","Lisa LoCicero","Meiling Melançon","Maggie Q","Lucy Lin","Cindy Lu","Audrey Quock","Ernie Reyes Jr."],"director":["Brett Ratner"],"cast_meta":[{"name":"Thành Long","name_vi":"Thành Long","name_original":"Jackie Chan","tmdb_id":18897,"profile":"https://image.tmdb.org/t/p/w500/nraZoTzwJQPHspAVsKfgl3RXKKa.jpg","tmdb_url":"https://www.themoviedb.org/person/18897"},{"name":"Chris Tucker","name_vi":null,"name_original":"Chris Tucker","tmdb_id":66,"profile":"https://image.tmdb.org/t/p/w500/k0oLIL0xTgDR6Qn3yCsNuLCJhFT.jpg","tmdb_url":"https://www.themoviedb.org/person/66"},{"name":"John Lone","name_vi":null,"name_original":"John Lone","tmdb_id":11389,"profile":"https://image.tmdb.org/t/p/w500/cO62O0mZGCvR0y5zM5oI2rUDhto.jpg","tmdb_url":"https://www.themoviedb.org/person/11389"},{"name":"Roselyn Sánchez","name_vi":null,"name_original":"Roselyn Sánchez","tmdb_id":41901,"profile":"https://image.tmdb.org/t/p/w500/srU7Oi0P5F3IuEEk14gKZwzzMWu.jpg","tmdb_url":"https://www.themoviedb.org/person/41901"},{"name":"Chương Tử Di","name_vi":"Chương Tử Di","name_original":"Zhang Ziyi","tmdb_id":1339,"profile":"https://image.tmdb.org/t/p/w500/6DUCAJzpw06VoAA9VWrvB2g4dpq.jpg","tmdb_url":"https://www.themoviedb.org/person/1339"},{"name":"Alan King","name_vi":null,"name_original":"Alan King","tmdb_id":7169,"profile":"https://image.tmdb.org/t/p/w500/wq3yjC2S2SMxjs4tAAuryJ91Hum.jpg","tmdb_url":"https://www.themoviedb.org/person/7169"},{"name":"Harris Yulin","name_vi":null,"name_original":"Harris Yulin","tmdb_id":1166,"profile":"https://image.tmdb.org/t/p/w500/3W758yxhdphzblpgDz4wKgLCriB.jpg","tmdb_url":"https://www.themoviedb.org/person/1166"},{"name":"Tăng Giang","name_vi":"Tăng Giang","na