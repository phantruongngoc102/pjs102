am13.com/20251122/18819_af7fc848/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/146017373d58c750fab8341254cf6c16","link_m3u8":"https://vip.opstream13.com/20251122/18820_14601737/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/fb945b3067434474ba269b604525ca02","link_m3u8":"https://vip.opstream13.com/20251122/18821_fb945b30/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream13.com/share/51c807b4fe8dfbe0e36373fb415d2e65","link_m3u8":"https://vip.opstream13.com/20251122/18822_51c807b4/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream13.com/share/a269ef5c1e7623a02a651fad5f2b8905","link_m3u8":"https://vip.opstream13.com/20251122/18823_a269ef5c/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream13.com/share/2425ad56cc45acbd2fc44f149d69a9b8","link_m3u8":"https://vip.opstream13.com/20251122/18824_2425ad56/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream13.com/share/05a0c4a3f3a22424cf61ae7edb982888","link_m3u8":"https://vip.opstream13.com/20251122/18825_05a0c4a3/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream13.com/share/c9663f86bdfd6137c73121a550887aa4","link_m3u8":"https://vip.opstream13.com/20251122/18826_c9663f86/index.m3u8"}]}],"description":"<p>Bối cảnh chính ở một vùng quê chuyên nghề thủ công đang trên đà đô thị hóa ở châu thổ sông Hồng.</p><p>Năm 2004, ủy ban nhân dân xã Kình Hợp (tục gọi làng Kình) tổ chức tuyển cử trưởng thôn, và đó là cơ hội cho các thế lực thủ cựu trỗi dậy với mưu toan kiềm hãm thôn quê trong trì trệ và ngu dốt. Ông Phạm Khuếnh trúng cử chức trưởng thôn và bắt đầu tung ra những vòi bạch tuộc để thao túng quyền lực xó quê, vô hình trung biến những người nông phu quen chân lấm tay bùn thành phường uống máu không tanh.</p><p>Vây cánh ông Khuếnh càng khuếch trương thì mọi thói hư tật xấu cố hữu vốn ngủ quên bao đời bỗng vùng dậy tàn hại biết bao phận người. Nhưng cũng từ chỗ căm phẫn với những thủ đoạn của ông mà đây đó dần mọc lên một số con người biết hướng thiện và khuyến thiện. Họ dần siết lại thành hàng ngũ để chặn đứng âm mưu của bè lũ Khuếnh, qua đó trả lại yên vui cho bà con làng xã.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/gi/gio-lang-kinh.json"}