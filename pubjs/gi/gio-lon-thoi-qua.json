e8d38","link_m3u8":"https://vip.opstream11.com/20220513/24464_c0629823/index.m3u8"},{"name":"28B","slug":"28b","filename":"gio-lon-thoi-qua-blowing-in-the-wind-tap-28B","link_embed":"https://vip.opstream11.com/share/8d7c30cf7b10b49f854c2a295a5c9413","link_m3u8":"https://vip.opstream11.com/20220513/24465_3a04aeb9/index.m3u8"}]}],"time":"45 phút","description":"<p>Bộ phim kể về câu chuyện tình đan xen những bước trưởng thành trong cuộc sống của các cô cậu sinh viên. Vì muốn vực dậy hội leo núi của trường mà nữ sinh đại học Lâm Phong (Lý Khải Hinh đóng) đã làm quen với Hạ Địch (Hình Chiêu Lâm đóng) - một cựu thành viên của hội nhưng lại mắc chứng sợ độ cao. Trải qua một số hiểu lầm, nhờ có chung đam mê và mơ ước mà cả 2 ngày càng thân thiết. Lâm Phong đã giúp cho Hạ Địch vượt qua chứng bệnh của bản thân và vực dậy được câu lạc bộ leo núi.</p>","tmdb":{"type":"tv","id":"90708","season":1,"vote_average":4,"vote_count":1},"modified":"2022-05-14T03:30:04.000Z","cast":["Hình Chiêu Lâm","Lý Khải Hinh","Chanon Santinatornkul","Guo Weijie","Xiang Hao","Ren Bin","Shih Chih-tian"],"director":["Lý Bỉnh Cường"],"cast_meta":[{"name":"Hình Chiêu Lâm","name_vi":"Hình Chiêu Lâm","name_original":"Xing Zhaolin","tmdb_id":1855299,"profile":"https://image.tmdb.org/t/p/w500/8UPCvdZggQhuzCGkXvSOJ8EMqdI.jpg","tmdb_url":"https://www.themoviedb.org/person/1855299"},{"name":"Lý Khải Hinh","name_vi":"Lý Khải Hinh","name_original":"Eleanor Lee","tmdb_id":2126495,"profile":"https://image.tmdb.org/t/p/w500/xeYJamjizAVbUtSR2daLISDmlBV.jpg","tmdb_url":"https://www.themoviedb.org/person/2126495"},{"name":"Chanon Santinatornkul","name_vi":null,"name_original":"Chanon Santinatornkul","tmdb_id":1353678,"profile":"https://image.tmdb.org/t/p/w500/osG0qvkXtpO0DPiZKlSllAVjTlE.jpg","tmdb_url":"https://www.themoviedb.org/person/1353678"},{"name":"Guo Weijie","name_vi":null,"name_original":"Guo Weijie","tmdb_id":1740640,"profile":"https://image.tmdb.org/t/p/w500/yBGTdpu0fQgzW2UsaMITq3IObkB.jpg","tmdb_url":"http