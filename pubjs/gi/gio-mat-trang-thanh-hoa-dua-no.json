7aa554886ec8","link_m3u8":"https://vip.opstream15.com/20220305/715_9be958d5/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/e7f8a7fb0b77bcb3b283af5be021448f","link_m3u8":"https://vip.opstream15.com/20220305/716_d6abe292/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/788d986905533aba051261497ecffcbb","link_m3u8":"https://vip.opstream15.com/20220305/717_f1ca3652/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/50c3d7614917b24303ee6a220679dab3","link_m3u8":"https://vip.opstream15.com/20220305/718_b3b01614/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/2afe4567e1bf64d32a5527244d104cea","link_m3u8":"https://vip.opstream15.com/20220305/719_c00c3068/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream15.com/share/5f2c22cb4a5380af7ca75622a6426917","link_m3u8":"https://vip.opstream15.com/20220305/720_57b86d51/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream15.com/share/aba3b6fd5d186d28e06ff97135cade7f","link_m3u8":"https://vip.opstream15.com/20220305/721_7596896d/index.m3u8"}]}],"description":"<p>Bô phim “Gió Mát Trăng Thanh Hoa Đua Nở”(2021) kể về câu chuyện trưởng thành của các nhân vật chính. Sau công chúa Đại Tiêu Trần Lãng Nguyệt (Hứa Giai Kỳ thủ vai) trốn ra cung để theo đuổi ước mơ kiến trúc, nàng gặp gỡ người thợ thiên tài Lý Thanh Phong (Hoàng Thánh Trì thủ vai) và hai người cùng theo đuổi ước mơ, thực hiện giá trị chính mình. Là công chúa Đại Tiêu, nữ chính Trần Lãng Nguyệt học rộng tài cao, tinh thông cầm kỳ thi họa từ nhỏ, lại có một ước mơ đủ lớn về kiến trúc. Nam chính Lý Thanh Phong sinh ra trong một dòng dõi quý tộc, là một kiến trúc sư thiên tài nổi tiếng. Chàng cùng bạn La Duệ sáng lập đội thợ Mộc Vũ. Tám người thiếu niên, người thiếu nữ Đại Tiêu tính cách khác hẳn, lại tụ tập vào đội thợ Mộc Vũ do ước mơ riêng mình. Họ cùng cải tạo nhiều kiến trúc kỳ lạ, thú vị, từ thanh lâu đến nhà quỷ, từ tòa nhà đến cầu cống, từ tổ nhỏ ấm áp đến lạc viên tình yêu, từ vườn đất dân gian đến tháp Phong Tương triều đình, cuối cùng họ còn cải tạo công sự bảo vệ cho quốc gia... Họ có khi cãi nhau đến mức gà bay chó chạy, có khi lại giúp đỡ và sưởi ấm lẫn nhau. Trong khi cải tạo kiến trúc, mỗi một người còn được cõi đi về riêng mình và được trưởng thành nhiều. “Gió Mát Trăng Thanh Hoa Đua Nở” được Hứa Giai Kỳ(cựu thành viên nhóm SNH48 và THE9, từng tham gia “Thanh Xuân Có Bạn Mùa 2”, “Như Ý Phương Phi”) và Hoàng Thánh Trì (từng diễn xuất “Thiếu Nữ Toàn Phong Phần 2”, “Bong Bóng Mùa Hè”, “Truy Cầu”) cùng thủ vai chính.</p>","tmdb_id":128725,"cast":["Hứa Giai Kỳ","Hoàng Thánh Trì","Wu Yang","Song Hanyu","Ma Zhenhuan","Fu Yaning","Li Jiahui","Zhang Zhuowen","Jiuyi Zhao","Yang Yuxuan"],"director":["Kenne Yam"],"keywords":[],"tmdb":{"type":"tv","id":"128725","season":1,"vote_average":6,"vote_count":1},"cast_meta":[{"name":"Hứa Giai Kỳ","name_vi":"Hứa Giai Kỳ","name_original":"Xu Jiaqi","tmdb_id":2555745,"profile":"https://image.tmdb.org/t/p/w500/9qmTStr2R2M9MzvP8kPO0vxZatj.jpg","tmdb_url":"https://www.themoviedb.org/person/2555745"},{"name":"Hoàng Thánh Trì","name_vi":"Hoàng Thánh Trì","name_original":"Huang Shengchi","tmdb_id":2043795,"profile":"https://image.tmdb.org/t/p/w500/dgBAYHGdVyWat5d4HGgEnayjvid.jpg","tmdb_url":"https://www.themoviedb.org/person/2043795"},{"name":"Wu Yang","name_vi":null,"name_original":"Wu Yang","tmdb_id":2742124,"profile":"https://image.tmdb.org/t/p/w500/aHWmdKjx8i15H0VstjQh3WqGYDJ.jpg","tmdb_url":"https://www.themoviedb.org/person/2742124"},{"name":"Song Hanyu","name_vi":null,"name_original":"Song Hanyu","tmdb_id":3148340,"profile":"https://image.tmdb.org/t/p/w500/6ZKmDAZzuzux2LYmgWMjzv6ammu.jpg","tmdb_url":"https://www.themoviedb.org/person/3148340"},{"name":"Ma Zhenhuan","name_vi":null,"name_original":"Ma Zhenhuan","tmdb_id":1512736,"profile":"https://image.tmdb.org/t/p/w500/gRSyoZhjrPX6vwRbGOmA8tpgmja.jpg","tmdb_url":"ht