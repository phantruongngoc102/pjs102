11/28327_57d3960b/index.m3u8"},{"name":"31","slug":"31","filename":"gio-thoi-ban-ha-da-man-sinh-truong-tap-31","link_embed":"https://vip.opstream14.com/share/d351f787f92fd392b0c30979e85630ef","link_m3u8":"https://vip.opstream14.com/20221212/28363_dfed49ca/index.m3u8"},{"name":"32","slug":"32","filename":"gio-thoi-ban-ha-da-man-sinh-truong-tap-32","link_embed":"https://vip.opstream14.com/share/788fa30233fcab2260b28ae40dde74a7","link_m3u8":"https://vip.opstream14.com/20221212/28364_c1beb8dd/index.m3u8"},{"name":"33","slug":"33","filename":"gio-thoi-ban-ha-da-man-sinh-truong-tap-33","link_embed":"https://vip.opstream14.com/share/b59978537754917c2df87b96ac795ef2","link_m3u8":"https://vip.opstream14.com/20221213/28388_3d8150b4/index.m3u8"},{"name":"34","slug":"34","filename":"gio-thoi-ban-ha-da-man-sinh-truong-tap-34","link_embed":"https://vip.opstream14.com/share/054feb2acfd28eeca93f8f22e35cc6d1","link_m3u8":"https://vip.opstream14.com/20221213/28389_68c9d83e/index.m3u8"},{"name":"35","slug":"35","filename":"gio-thoi-ban-ha-da-man-sinh-truong-tap-35","link_embed":"https://vip.opstream14.com/share/7854c8701c5da6d80d602a20133d2bf8","link_m3u8":"https://vip.opstream14.com/20221214/28417_a5c417e7/index.m3u8"},{"name":"36","slug":"36","filename":"gio-thoi-ban-ha-da-man-sinh-truong-tap-36","link_embed":"https://vip.opstream14.com/share/041307ce59d60269e84d75fa4c63868c","link_m3u8":"https://vip.opstream14.com/20221214/28418_b9902ee6/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Gió Thổi Bán Hạ (Dã Man Sinh Trưởng) kể về câu chuyện khi mẹ của Hứa Bán Hạ đã mất vì khó sinh, từ khi cô sinh ra người cha cũng chẳng hề quan tâm cô. Vì thế cô trở thành một cô gái kiêu ngạo đầy cá tính. Với sự phát triển nhanh chóng của kinh tế Trung Quốc, Hứa Bán Hạ đã dẫn dắt 2 người bạn cùng khởi nghiệp kinh doanh thép phế liệu và vận tải. Trong ngành công nghiệp thép do nam giới thống trị, Hứa Bán Hạ thể hiện tinh thần mạo hiểm và thái độ thực dụng, sau đó dũng cảm dấn thân lăn lộn. Sau khi trải qua vô số khó khăn và thậm chí là thử thách sinh tử, cô đã mở một doanh nghiệp nhập khẩu thép quốc tế độc lập và thu hoạch thành quả đầu tiên trong công việc kinh doanh của mình. Lúc này, sự cạnh tranh trên thị trường thép rất gay gắt. Với tầm nhìn xuất chúng, tính cách táo bạo và nhạy bén với thị trường, Hứa Bán Hạ đã vượt qua mọi khó khăn và từng bước mở rộng địa bàn kinh doanh của mình. Thông qua những trải nghiệm trong cuộc sống, tình yêu và công việc, Hứa Bán Hạ học cách giải quyết vấn đề một cách dứt khoát, vượt qua giới hạn của bản thân để có được sự nghiệp và tình yêu.</p>","tmdb":{"type":"tv","id":"138289","season":1,"vote_average":7.167,"vote_count":12},"modified":"2025-05-03T10:30:04.000Z","cast":["Triệu Lệ Dĩnh","Âu Hào","Lý Quang Khiết","Huang Chengcheng","Lưu Uy","Ke Lan","Ren Zhong","Vương Kính Tùng","Phùng Gia Di","Tôn Thiến","Liu Weiwei","Shi An","Song Xi","Huang Yiwei","Una You"],"director":["Fu Dong Yu","Mao Wei"],"cast_meta":[{"name":"Triệu Lệ Dĩnh","name_vi":"Triệu Lệ Dĩnh","name_original":"Zhao Liying","tmdb_id":1260868,"profile":"https://image.tmdb.org/t/p/w500/lDkliS0cwOFO0QA7epHYZJWNttG.jpg","tmdb_url":"https://www.themoviedb.org/person/1260868"},{"name":"Âu Hào","name_vi":"Âu Hào","name_original":"Ou Hao","tmdb_id":1355667,"profile":"https://image.tmdb.org/t/p/w500/nHokLSjlWJB3Gwt3zBXUuBPvR77.jpg","tmdb_url":"https://www.themoviedb.org/person/1355667"},{"name":"Lý Quang Khiết","name_vi":"Lý Quang Khiết","name_original":"Li Guangjie","tmdb_id":565344,"profile":"https://image.tmdb.org/t/p/w500/snTfuCkX8Q1GHJJwB3UHQJt7KZs.jpg","tmdb_url":"https://www.themoviedb.org/person/565344"},{"name":"Huang Chengcheng","name_vi":null,"name_original":"Huang Chengcheng","tmdb_id":3094474,"profile":"https://image.tmdb.org/t/p/w500/p5QXYGRxP3688l9oxmy0jcOcCXr.jpg","tmdb_url":"https://www.themoviedb.org/person/3094474"},{"name":"Lưu Uy","name_vi":"Lưu Uy","name_original":"Liu Wei","tmdb_id":1138871,"profile":"https://image.tmdb.org/t/p/w500/zeq1oSsOiVJ