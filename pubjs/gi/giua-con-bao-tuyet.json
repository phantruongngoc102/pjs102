/013a006f03dbc5392effeb8f18fda755","link_m3u8":"https://vip.opstream17.com/20240218/833_9c835920/index.m3u8"},{"name":"30","slug":"30","filename":"EP30- Amidst a Snowstorm of Love - Watch HD Video Online","link_embed":"https://vip.opstream17.com/share/301ad0e3bd5cb1627a2044908a42fdc2","link_m3u8":"https://vip.opstream17.com/20240218/834_d25bf40b/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Yin Guo, một tay chơi bida chuyên nghiệp, đã ở lại New York vài tháng để tham gia một trận đấu mở rộng. Tình cờ cô gặp được Lâm Nhất Dương. Sau khi quen nhau, cô nhận ra Lâm Nhất Dương cũng là một người rất tài năng. Là một tay chơi bi-a, anh mắc sai lầm khi còn trẻ và phù phiếm. Ông không chịu cúi đầu nên đã rời bỏ môn bida yêu quý của mình hơn chục năm và ra nước ngoài. Anh ấy chưa bao giờ từ bỏ môn bida. Lin Yi Yang đã yêu Yin Guo ngay từ cái nhìn đầu tiên. Để theo đuổi cô, anh đã cố gắng hết sức. Vì tương lai của họ, anh quyết định trở lại đấu trường và thực hiện ước mơ của mình từ nhiều năm trước.</p>","tmdb":{"type":"tv","id":"221112","season":1,"vote_average":8.1,"vote_count":25},"modified":"2024-02-19T14:45:02.000Z","cast":["Ngô Lỗi","Triệu Kim Mạch","Vương Tinh Việt","Đinh Tiểu Oánh","Dong Zifan","Wang Jiaxuan","Han Donglin","Vương Nhuận Trạch","Wang Yuexi","Li Ao","Kong Ran"],"director":[],"cast_meta":[{"name":"Ngô Lỗi","name_vi":"Ngô Lỗi","name_original":"Leo Wu","tmdb_id":1438264,"profile":"https://image.tmdb.org/t/p/w500/43fYrqW26tisHBblj9lazersTdr.jpg","tmdb_url":"https://www.themoviedb.org/person/1438264"},{"name":"Triệu Kim Mạch","name_vi":"Triệu Kim Mạch","name_original":"Zhao Jinmai","tmdb_id":2113005,"profile":"https://image.tmdb.org/t/p/w500/hndhOhSK0GAMi1qQaacacl3aHzO.jpg","tmdb_url":"https://www.themoviedb.org/person/2113005"},{"name":"Vương Tinh Việt","name_vi":"Vương Tinh Việt","name_original":"Wang Xingyue","tmdb_id":3157355,"profile":"https://image.tmdb.org/t/p/w500/mi4dqtBt53fRpRWFTgCf9GHgOA7.jpg","tmdb_url":"https://www.themoviedb.org/person/3