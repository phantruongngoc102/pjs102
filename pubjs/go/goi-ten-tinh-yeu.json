index.m3u8"}]}],"description":"<p>Yang Yi-ru là nữ giám đốc quảng cáo nghiện việc, bị gia đình và bạn bè lừa rằng mình mắc ung thư giai đoạn cuối để buộc cô nghỉ ngơi. Cô đi nghỉ dưỡng, gặp Lan Shi-da – chàng trai giàu có – và bắt đầu hành trình tình yêu đầy hài hước, hiểu lầm và trưởng thành. Bộ phim nhấn mạnh thông điệp sống hết mình cho hiện tại và giá trị tình yêu chân thành.</p>","tmdb_id":48146,"cast":["Annie Chen","Hồ Vũ Uy","Bobby Dou","Vivi Lee","Harry Zhang","Esther Yang","Shen Meng-Sheng","Chia-Le Yen","Mandy Wei","Huang Jian Hao"],"director":["Trần Di Quân (Chen Yi-Chun)"],"keywords":[],"tmdb":{"type":"tv","id":"48146","season":1,"vote_average":6.2,"vote_count":5},"cast_meta":[{"name":"Annie Chen","name_vi":null,"name_original":"Annie Chen","tmdb_id":1258375,"profile":"https://image.tmdb.org/t/p/w500/v6eUA0wjN3gSfkyNezh22bhy7Qm.jpg","tmdb_url":"https://www.themoviedb.org/person/1258375"},{"name":"Hồ Vũ Uy","name_vi":"Hồ Vũ Uy","name_original":"George Hu","tmdb_id":1233857,"profile":"https://image.tmdb.org/t/p/w500/ln9uzk6422vL8jEpWmj987QPmy9.jpg","tmdb_url":"https://www.themoviedb.org/person/1233857"},{"name":"Bobby Dou","name_vi":null,"name_original":"Bobby Dou","tmdb_id":1258376,"profile":"https://image.tmdb.org/t/p/w500/bxNEQM7KN9ImUxwcbu0gOdSN48m.jpg","tmdb_url":"https://www.themoviedb.org/person/1258376"},{"name":"Vivi Lee","name_vi":null,"name_original":"Vivi Lee","tmdb_id":2325369,"profile":"https://image.tmdb.org/t/p/w500/wgTM4tZxxYnS8i3Xd9ddaV9MEzt.jpg","tmdb_url":"https://www.themoviedb.org/person/2325369"},{"name":"Harry Zhang","name_vi":null,"name_original":"Harry Zhang","tmdb_id":4580508,"profile":"https://image.tmdb.org/t/p/w500/9I3S00D2IVOySta8Ume8d5Lbf12.jpg","tmdb_url":"https://www.themoviedb.org/person/4580508"},{"name":"Esther Yang","name_vi":null,"name_original":"Esther Yang","tmdb_id":1708948,"profile":"https://image.tmdb.org/t/p/w500/pzLlnv7QOm18oKQcpy9pkZehZJD.jpg","tmdb_url":"https://www.themoviedb.org/person/1708948"},{"name":"Sh