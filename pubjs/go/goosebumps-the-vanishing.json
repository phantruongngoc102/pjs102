m10.com/20250602/29496_5cd33874/index.m3u8"},{"name":"5","slug":"5","filename":"Goosebumps.2023.S02E05.1080p.WEB.h264-EDITH","link_embed":"https://vip.opstream10.com/share/38a44c258ac6985bb71726a37252d313","link_m3u8":"https://vip.opstream10.com/20250606/29553_38a44c25/index.m3u8"},{"name":"6","slug":"6","filename":"Goosebumps.2023.S02E06.1080p.WEB.h264-EDITH","link_embed":"https://vip.opstream10.com/share/b13c4b2504158972122bb5cbeda135b2","link_m3u8":"https://vip.opstream10.com/20250608/29563_b13c4b25/index.m3u8"},{"name":"7","slug":"7","filename":"Goosebumps.2023.S02E07.1080p.WEB.h264-EDITH","link_embed":"https://vip.opstream10.com/share/d0a30abd9c28c1500462bec3acffd50c","link_m3u8":"https://vip.opstream10.com/20250611/29588_d0a30abd/index.m3u8"},{"name":"8","slug":"8","filename":"Goosebumps.2023.S02E08.1080p.WEB.h264-EDITH","link_embed":"https://vip.opstream10.com/share/3649a6a2557a26ada5a5751518e711f7","link_m3u8":"https://vip.opstream10.com/20250614/29608_3649a6a2/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Goosebumps: The Vanishing là phần thứ hai của loạt phim Goosebumps (2023), được phát hành vào năm 2025 do Disney+ và Hulu đồng sản xuất, phần phim này tiếp tục mang đến những câu chuyện rùng rợn, kết hợp giữa kinh dị, bí ẩn và các yếu tố siêu nhiên, với cốt truyện hoàn toàn mới, độc lập với phần trước, nhưng vẫn giữ phong cách kể chuyện ly kỳ đặc trưng của Goosebumps.</p><p>Phần 2 được đánh giá là một bước tiến so với phần 1, với cốt truyện mạch lạc hơn và các nhân vật được phát triển sâu sắc. Series tiếp tục thu hút khán giả trẻ và cả những người lớn từng yêu thích Goosebump(Câu Chuyện Lúc Nửa Đêm) thời thơ ấu, nhờ sự cân bằng giữa kinh dị vui nhộn và cảm xúc chân thực.</p><p>Câu chuyện xoay quanh cặp song sinh Cece và Devin Brewer, được gửi đến Brooklyn để trải qua kỳ nghỉ hè cùng người cha đã ly hôn, Anthony Brewer (do David Schwimmer thủ vai). Tại đây, họ phát hiện những bí ẩn xoay quanh sự mất tích của người chú Matty vào năm 1994 (30 năm trước), sau một trò chơi thử thách tại một cơ sở nghiên cứu bí ẩn bị bỏ hoang.&nbsp;</p><p>Khi khám phá sâu hơn, Cece và Devin nhận ra rằng những bí mật đen tối đang ẩn giấu trong quá khứ của gia đình họ, và một thế lực siêu nhiên đang đe dọa khu phố nơi họ sống.</p>","tmdb":{"type":"tv","id":"281666","season":1,"vote_average":6.745,"vote_count":53},"modified":"2025-06-14T23:00:47.000Z","cast":["David Schwimmer","Ana Ortiz","Jayden Bartels","Sam McCarthy","Elijah M. Cooper","Francesca Noel","Galilea La Salvia"],"director":[],"cast_meta":[{"name":"David Schwimmer","name_vi":null,"name_original":"David Schwimmer","tmdb_id":14409,"profile":"https://image.tmdb.org/t/p/w500/XtKzJ9lM5Xwa7vCmE4xNHy6Owf.jpg","tmdb_url":"https://www.themoviedb.org/person/14409"},{"name":"Ana Ortiz","name_vi":null,"name_original":"Ana Ortiz","tmdb_id":38333,"profile":"https://image.tmdb.org/t/p/w500/qkOrJNR5TA3uZqj0lF2hfNuHP4R.jpg","tmdb_url":"https://www.themoviedb.org/person/38333"},{"name":"Jayden Bartels","name_vi":null,"name_original":"Jayden Bartels","tmdb_id":1738543,"profile":"https://image.tmdb.org/t/p/w500/hTc77laTHb6OGPIsSgG59gWuYg1.jpg","tmdb_url":"https://www.themoviedb.org/person/1738543"},{"name":"Sam McCarthy","name_vi":null,"name_original":"Sam McCarthy","tmdb_id":1993317,"profile":"https://image.tmdb.org/t/p/w500/x0e6w9x04J3vYbp7tlWD4ini1mi.jpg","tmdb_url":"https://www.themoviedb.org/person/1993317"},{"name":"Elijah M. Cooper","name_vi":null,"name_original":"Elijah M. Cooper","tmdb_id":2494599,"profile":"https://image.tmdb.org/t/p/w500/luI18RH8LOZPxwDEfc9HYcGBZXg.jpg","tmdb_url":"https://www.themoviedb.org/person/2494599"},{"name":"Francesca Noel","name_vi":null,"name_original":"Francesca Noel","tmdb_id":2170623,"profile":"https://image.tmdb.org/t/p/w500/36zoqlYQhsqwQBzogQtuhG2PxFa.jpg","tmdb_url":"https://www.themoviedb.org/person/2170623"},{"name":"Galilea La Salvia","name_vi":null,"name_original":"Galilea La Salvia","tmdb_id":1487110,"profile":"https://image.tmdb.org/t/p/w50