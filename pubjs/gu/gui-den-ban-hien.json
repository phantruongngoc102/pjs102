vip.opstream15.com/20230330/37236_53b13156/index.m3u8"},{"name":"11","slug":"11","filename":"Gửi đến bạn hiền_S01E11_Nhận ra","link_embed":"https://vip.opstream15.com/share/8ec5325104e6c8053622fe4c9e1ad57a","link_m3u8":"https://vip.opstream15.com/20230330/37237_13b6464e/index.m3u8"},{"name":"12","slug":"12","filename":"Gửi đến bạn hiền_S01E12_Khởi hành","link_embed":"https://vip.opstream15.com/share/5921c3ce65d4bb3a937371d88ea2d053","link_m3u8":"https://vip.opstream15.com/20230330/37238_5b4a105f/index.m3u8"}]}],"time":"34 phút/tập","description":"<p>Phim kể về Sawako Kuronuma (Sara Minami), học sinh trung học. Mọi người xung quanh gọi cô ấy là \"Sadako\" và các bạn cùng lớp không kết giao với cô ấy. Cô ấy chỉ có một mình ở trường. Shota Kazehaya (Oji Suzuka) là học sinh cùng trường trung học. Anh ấy không quan tâm đến những gì người khác nghĩ và tiếp cận Sawako Kuronuma. Anh ấy là người duy nhất biết Sawako Kuronuma làm những công việc khó chịu cho các bạn cùng lớp của cô ấy. Vì Shota Kazehaya, các học sinh khác bắt đầu nói chuyện với Sawako Kuronuma. Cuộc sống học đường của cô ấy bắt đầu trở thành những gì cô ấy mong muốn và cô ấy cũng có tình cảm với Shota Kazehaya.</p>","tmdb":{"type":"tv","id":"209648","season":1,"vote_average":7.5,"vote_count":40},"modified":"2023-04-01T01:19:06.000Z","cast":["Sara Minami","Ouji Suzuka","Kaito Sakurai","Rinka Kumada","Riho Nakamura","Naho Toda","Hiroyuki Hirayama","Shohei Miura","Jin Suzuki","Atsuhiro Inukai","Kanon","Kosuke Suzuki","Junpei Yasui","Erika Mabuchi","Tetta Sugimoto"],"director":["Kikuchi Takeo","Shinjo Takehiko"],"cast_meta":[{"name":"Sara Minami","name_vi":null,"name_original":"Sara Minami","tmdb_id":1960999,"profile":"https://image.tmdb.org/t/p/w500/4Ixs64qw8oE7BBy9TMA6dhUkzjc.jpg","tmdb_url":"https://www.themoviedb.org/person/1960999"},{"name":"Ouji Suzuka","name_vi":null,"name_original":"Ouji Suzuka","tmdb_id":2269331,"profile":"https://image.tmdb.org/t/p/w500/k5hKLBwSvxcwfSxetS4uo60Knx.jpg","tmdb_url":"https: