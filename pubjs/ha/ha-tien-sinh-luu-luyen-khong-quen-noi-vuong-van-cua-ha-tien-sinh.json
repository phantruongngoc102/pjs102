tại bệnh viện. Nỗi Vương Vấn Của Hạ Tiên Sinh được cho là khi anh chàng tổng tài lạnh lùng kiêu ngạo tan chảy bởi sự nhiệt tình và ấm áp của cô nàng nhỏ bé Tần Dĩ Nguyệt.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2022-05-30T09:22:14.000Z","cast":["Ngụy Triết Minh","Hồ Ý Hoàn","Sun Si Cheng","Zhan Zi Tong"],"director":["李玉磊"],"cast_meta":[{"name":"Ngụy Triết Minh","name_vi":null,"name_original":"Ngụy Triết Minh"},{"name":"Hồ Ý Hoàn","name_vi":null,"name_original":"Hồ Ý Hoàn"},{"name":"Sun Si Cheng","name_vi":null,"name_original":"Sun Si Cheng"},{"name":"Zhan Zi Tong","name_vi":null,"name_original":"Zhan Zi Tong"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ha/ha-tien-sinh-luu-luyen-khong-quen-noi-vuong-van-cua-ha-tien-sinh.json"}