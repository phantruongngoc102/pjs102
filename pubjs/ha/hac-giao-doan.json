u8"},{"name":"Tập 133","slug":"tap-133","filename":"","link_embed":"https://vip.opstream11.com/share/fc4c3b5809a65c60642bc8f144321208","link_m3u8":"https://vip.opstream11.com/20220430/22358_ff30c146/index.m3u8"},{"name":"Tập 134","slug":"tap-134","filename":"","link_embed":"https://vip.opstream11.com/share/5b1e2ac88089bded4f4926a74b303bab","link_m3u8":"https://vip.opstream11.com/20220430/22359_bf49c1f1/index.m3u8"},{"name":"Tập 135","slug":"tap-135","filename":"","link_embed":null,"link_m3u8":null}]}],"time":"23 Phút","description":"<p>Vào cuối thế kỷ 19, Allen Walker chính thức gia nhập tổ chức Exorcist và bắt đầu đi tiêu diệt các sinh vật được gọi là Akuma; vũ khí cơ khí do Thiên niên kỷ Earl với những linh hồn đau khổ của người chết. Allen có một con mắt bị nguyền rủa và vũ khí chống Akuma, mang sức mạnh của \"Innocence\", một món quà dành cho anh là một tông đồ của Chúa. Allen, cùng với Exorcist đồng nghiệp của mình phải chấm dứt âm mưu cuối cùng của thiên niên kỷ của Earl có thể dẫn đến sự hủy diệt của thế giới và tất cả những ai sống trên đó.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-07-24T09:45:11.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ha/hac-giao-doan.json","keywords":[],"tmdb_checked":false}