m nguy giữa sự sinh tồn và đạo đức.</p>","tmdb_id":316861,"cast":["Zheng Jiabin","He Dujuan","Song Xi","Qin Fen","Zhou Zhuo","Chen Jinkang","He Rui"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"316861","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Zheng Jiabin","name_vi":null,"name_original":"Zheng Jiabin","tmdb_id":2999051,"profile":"https://image.tmdb.org/t/p/w500/3FFIzpQyIPC1EuixYumI9aa5Vu1.jpg","tmdb_url":"https://www.themoviedb.org/person/2999051"},{"name":"He Dujuan","name_vi":null,"name_original":"He Dujuan","tmdb_id":1089632,"profile":"https://image.tmdb.org/t/p/w500/qZPZkGFcqdMZv2XX0t8vPEUKrgw.jpg","tmdb_url":"https://www.themoviedb.org/person/1089632"},{"name":"Song Xi","name_vi":null,"name_original":"Song Xi","tmdb_id":1767357,"profile":"https://image.tmdb.org/t/p/w500/pO6qg0XQB1mjwKIki2ffPiPGIUV.jpg","tmdb_url":"https://www.themoviedb.org/person/1767357"},{"name":"Qin Fen","name_vi":null,"name_original":"Qin Fen","tmdb_id":2633280,"profile":"https://image.tmdb.org/t/p/w500/mmHRhfapCFDPZn09xfAV6mQsKaP.jpg","tmdb_url":"https://www.themoviedb.org/person/2633280"},{"name":"Zhou Zhuo","name_vi":null,"name_original":"Zhou Zhuo","tmdb_id":2425538,"profile":"https://image.tmdb.org/t/p/w500/24FEdEN1NfvlegiJbc6z3GgfXoc.jpg","tmdb_url":"https://www.themoviedb.org/person/2425538"},{"name":"Chen Jinkang","name_vi":null,"name_original":"Chen Jinkang","tmdb_id":6079396,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/6079396"},{"name":"He Rui","name_vi":null,"name_original":"He Rui","tmdb_id":2869254,"profile":"https://image.tmdb.org/t/p/w500/wymLCRdL5VC7TRcdmr3XAzUkFzg.jpg","tmdb_url":"https://www.themoviedb.org/person/2869254"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ha/hac-kim.json"}