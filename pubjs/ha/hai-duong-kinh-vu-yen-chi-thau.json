2/index.m3u8"},{"name":"49B","slug":"49b","link_embed":"https://vip.opstream12.com/share/a2b58f07313388cd23868784a6759b64","link_m3u8":"https://vip.opstream12.com/20220610/18136_0c096818/index.m3u8"},{"name":"50A","slug":"50a","link_embed":"https://vip.opstream12.com/share/8d5c2ad003c431f38dfd7c65e0f3d2eb","link_m3u8":"https://vip.opstream12.com/20220610/18135_0d93e250/index.m3u8"},{"name":"50B","slug":"50b","link_embed":"https://vip.opstream12.com/share/69e6b62c2088742add07e1ea717d68e8","link_m3u8":"https://vip.opstream12.com/20220610/18137_84f866fb/index.m3u8"},{"name":"51A","slug":"51a","link_embed":"https://vip.opstream12.com/share/440be16e6577fac91de2fbfee4b91503","link_m3u8":"https://vip.opstream12.com/20220610/18138_78ee8d30/index.m3u8"},{"name":"51B","slug":"51b","link_embed":"https://vip.opstream12.com/share/66d83a2d2a6d2bd6265c95aa833b121b","link_m3u8":"https://vip.opstream12.com/20220610/18139_ad5b3700/index.m3u8"},{"name":"52A","slug":"52a","link_embed":"https://vip.opstream12.com/share/43a0340391b5cdbed42a609a0c2361a5","link_m3u8":"https://vip.opstream12.com/20220610/18142_b155c86d/index.m3u8"},{"name":"52B","slug":"52b","link_embed":"https://vip.opstream12.com/share/9b5af8696030810f396c315b9577ffd0","link_m3u8":"https://vip.opstream12.com/20220610/18140_275795a2/index.m3u8"}]}],"description":"<p>Bộ phim lấy bối cảnh tại thế gia chế tạo son phấn ở vùng sông nước Giang Nam, kể về đoạn tình cảm của nhị thiếu gia Nguyệt Hiên (Đặng Luân) và nữ tử thần bí Cố Hải Đường (Lý Nhất Đồng). Thiếu nữ Cố Hải Đường vì tìm người cha mất tích lâu ngày mà lưu lạc đến Côn Dương, cùng Lãng gia nhị công tử vừa gặp đã kết thành oan gia. Sau đó, Hải Đường lại xin vào làm ở nhà xưởng Lãng gia, bị đại công tử Lãng Nguyệt Minh (Ứng Hạo Minh) chọn trúng. Người nhà Lãng gia dùng thủ đoạn lừa hôn khiến Hải Đường thành thân cùng đại công tử Nguyệt Minh. Biết mình bị gạt, Hải Đường trong lòng mang hận Nguyệt Hiên lừa dối. Cô đề nghị chữa trị khuôn mặt bị hủy dung của Lãng Nguyệt Minh để đổi về một bức hưu thư. Nguyệt Hiên cảm thấy hổ thẹn với Hải Đường, một lần nữa đối mặt với tình cảm thật sự của mình, theo đuổi Hải Đường, hai người cuối cùng nhận ra tình cảm và trở lại bên nhau. Nhưng Nguyệt Minh sau khi khôi phục dung mạo thì lại vì yêu mà sinh hận, không chỉ cướp đi quyền kinh doanh Lãng Lý Xuân, mà còn muốn chia rẽ Nguyệt Hiên và Hải Đường. Cùng lúc đó, thân phận thật sự của cha Hải Đường, nguyên nhân mất tích cùng với thân thế của Nguyệt Hiên cũng dần dần sáng tỏ.</p>","tmdb_id":94892,"cast":["Đặng Luân","Lý Nhất Đồng","Ứng Hạo Minh","Trương Nhã Trác","Lý Nhược Đồng","Huang Wenhao","Bai Shan"],"director":["Sam Ho"],"keywords":[],"cast_meta":[{"name":"Đặng Luân","name_vi":"Đặng Luân","name_original":"Deng Lun","tmdb_id":1826898,"profile":"https://image.tmdb.org/t/p/w500/wRFsh37qJq0lcAQRADBVBPRKKw.jpg","tmdb_url":"https://www.themoviedb.org/person/1826898"},{"name":"Lý Nhất Đồng","name_vi":"Lý Nhất Đồng","name_original":"Li Yitong","tmdb_id":1736257,"profile":"https://image.tmdb.org/t/p/w500/jfostFmHde0D1Wj9F57GWHEVzmO.jpg","tmdb_url":"https://www.themoviedb.org/person/1736257"},{"name":"Ứng Hạo Minh","name_vi":"Ứng Hạo Minh","name_original":"Ying Haoming","tmdb_id":1784502,"profile":"https://image.tmdb.org/t/p/w500/fbyZuhlhy1kKOJPMCU80oxoB7dQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1784502"},{"name":"Trương Nhã Trác","name_vi":"Trương Nhã Trác","name_original":"Zhang Yazhuo","tmdb_id":2441244,"profile":"https://image.tmdb.org/t/p/w500/2X1Fhk29hSNsBoe0pATDFJNtZpu.jpg","tmdb_url":"https://www.themoviedb.org/person/2441244"},{"name":"Lý Nhược Đồng","name_vi":"Lý Nhược Đồng","name_original":"Carman Lee Yeuk-Tung","tmdb_id":110845,"profile":"https://image.tmdb.org/t/p/w500/pWPP7WKLLpXmPmcaZv51afrHnmt.jpg","tmdb_url":"https://www.themoviedb.org/person/110845"},{"name":"Huang Wenhao","name_vi":null,"name_original":"Huang Wenhao","tmdb_id":2349395,"profile":"https://image.tmdb.org/t/p/w500/2PmFGmLB1fDtnjJJyNysJz4su15.jpg","tmdb_url":"ht