50ff","link_m3u8":"https://vip.opstream12.com/20240909/23377_dde5af7b/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream12.com/share/0226aa5193c66d9906300c6cf2bc45df","link_m3u8":"https://vip.opstream12.com/20240909/23378_0226aa51/index.m3u8"}]}],"description":"<p>Trên những con phố và ngõ hẻm nhộn nhịp của Jakarta, một thế giới song song của những sinh vật khát máu từ thần thoại Indonesia đã sống cùng con người qua nhiều thế hệ. Mang hình dạng của chính con người, danh tính thực sự của những \"Demit\" này đã được một gia đình phàm nhân hùng mạnh che giấu cẩn thận trong nhiều thế kỷ. Sự xuất hiện của một sự kiện siêu nhiên bí ẩn chỉ được gọi là Gift sẽ đưa thế giới ẩn giấu này lên bề mặt. Khi ngày của Gift đến gần, một nghệ sĩ đường phố trẻ tuổi tên là Sarah bất ngờ thấy mình ở trong mắt bão. Khi Demit nhận ra Sarah thực sự là ai và cô ấy phải làm gì, con người và Demit đã bắt đầu một cuộc va chạm có thể thay đổi sự cân bằng của hai thế giới của họ mãi mãi.</p>","tmdb_id":65267,"cast":["Thanabordee Jaiyen","Tia Taveepanichpan","Emma Emika","JeeJa Yanin","Myra Molloy","Teresa Daley","Nicole Theriault","David Asavanond","Reza Rahadian","Jake Macapagal","Arifin Putra","Charlie Ruedpokanon"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"65267","season":1,"vote_average":5.7,"vote_count":16},"cast_meta":[{"name":"Thanabordee Jaiyen","name_vi":null,"name_original":"Thanabordee Jaiyen","tmdb_id":1833849,"profile":"https://image.tmdb.org/t/p/w500/3oOWJAB2s1sEhqpqppAKQMlfGnS.jpg","tmdb_url":"https://www.themoviedb.org/person/1833849"},{"name":"Tia Taveepanichpan","name_vi":null,"name_original":"Tia Taveepanichpan","tmdb_id":1937075,"profile":"https://image.tmdb.org/t/p/w500/gu6QVA5vVQv5TrE85q86rsvatGt.jpg","tmdb_url":"https://www.themoviedb.org/person/1937075"},{"name":"Emma Emika","name_vi":null,"name_original":"Emma Emika","tmdb_id":1937076,"profile":"https://image.tmdb.org/t/p/w500/cvdZNAMFB1zN1S3fIReL2a6Qke3.jpg","tmdb_url":"https://www.themovi