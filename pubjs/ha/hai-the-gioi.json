300c/index.m3u8"},{"name":"29","slug":"29","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 29","link_embed":"https://vip.opstream11.com/share/4b55df75e2e804bab559aa885be40310","link_m3u8":"https://vip.opstream11.com/20220330/7153_ffd3cf6b/index.m3u8"},{"name":"30","slug":"30","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 30","link_embed":"https://vip.opstream11.com/share/0c836be97564457619349887cf51b3ba","link_m3u8":"https://vip.opstream11.com/20220330/7154_343a1f5c/index.m3u8"},{"name":"31","slug":"31","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 31","link_embed":"https://vip.opstream11.com/share/9ecff5455677b38d19f49ce658ef0608","link_m3u8":"https://vip.opstream11.com/20220330/7155_f458d865/index.m3u8"},{"name":"32","slug":"32","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 32","link_embed":"https://vip.opstream11.com/share/4bb236de7787ceedafdff83bb8ea4710","link_m3u8":"https://vip.opstream11.com/20220330/7156_2c1eaf3f/index.m3u8"},{"name":"33","slug":"33","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 33","link_embed":"https://vip.opstream11.com/share/6e01383fd96a17ae51cc3e15447e7533","link_m3u8":"https://vip.opstream11.com/20220330/7157_41361dd2/index.m3u8"},{"name":"34","slug":"34","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 34","link_embed":"https://vip.opstream11.com/share/af0a59d77edf6e178ec25cb090df864b","link_m3u8":"https://vip.opstream11.com/20220330/7158_a1975dfd/index.m3u8"},{"name":"35","slug":"35","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 35","link_embed":"https://vip.opstream11.com/share/42e9fb755426f19231217afb43e1aec1","link_m3u8":"https://vip.opstream11.com/20220330/7159_1773d4f7/index.m3u8"},{"name":"36","slug":"36","filename":"Hai Thế Giới - The Unidentical Twins (Phát Song Song) - Tập 36","link_embed":"https://vip.opstream11.com/share/525b8410cc8612283c9ecaf9a319f8ed","link_m3u8":"https://vip.opstream11.com/20220330/7160_ee6d2275/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim được ramek lại từ phiên bản năm 2005 của CH7, kể về hai chị em song sinh Duenyard (Duen) &amp; Pilarluk (Pit) có khuôn mặt lẫn vóc dáng rất giống nhau nhưng tính cách khác nhau hoàn toàn. Duenyard là một người mẫu diễn viên nổi tiếng, có tính tình thất thường, vướng scandai không hay với một nghệ sĩ nhạc rock. Pilarluk trái ngược, hiền hậu, đơn giản, thầm yêu anh chàng Warit. Duen ganh tỵ với Pit, tạo ra mọi hiểu lầm để Warit chia tay chị gái mình nhằm quay sang chú ý đến cô nhưng không thành công. Ngày Warit và Pit tổ chức lễ cưới, Duen lên kế hoạch bắt cóc chị mình để thoã mãn cơn tức nhưng Pit không chống lại vì nghĩ mình chính là nguyên nhân khiến người em mà cô thương yêu nhất phải làm như vậy. Số phận của cặp chị em song sinh sẽ ra sao và hạnh phúc sẽ thuộc về ai?</p>","tmdb":{"type":"tv","id":"124933","season":1,"vote_average":0,"vote_count":0},"modified":"2022-05-24T03:49:33.000Z","cast":["Kimberly Ann Voltemas","James Ma","Pichaya Nitipaisalkul","Sheranut Yusananda","Wattikorn Permsubhirun","Namnung Suttidachanai","Songsit Rungnopakunsi"],"director":["Charapun Jamroensan"],"cast_meta":[{"name":"Kimberly Ann Voltemas","name_vi":null,"name_original":"Kimberly Ann Voltemas","tmdb_id":1256399,"profile":"https://image.tmdb.org/t/p/w500/zgo2a0h3N3oDhsteZzl6f0HEeAE.jpg","tmdb_url":"https://www.themoviedb.org/person/1256399"},{"name":"James Ma","name_vi":null,"name_original":"James Ma","tmdb_id":1259380,"profile":"https://image.tmdb.org/t/p/w500/9BCbyykBaUY3Du8pXqcn1Ehqcs7.jpg","tmdb_url":"https://www.themoviedb.org/person/1259380"},{"name":"Pichaya Nitipaisalkul","name_vi":null,"name_original":"Pichaya Nitipaisalkul","tmdb_id":1343178,"profile":"https://image.tmdb.org/t/p/w500/tGSqiSRgY92aRktCnVe1VzefUyx.jpg","tmdb_url":"https://www.themoviedb.org/person/1343178"},{"name":"Sheranut Yusananda","name_vi":null,"name_original":"Sheranut Yusa