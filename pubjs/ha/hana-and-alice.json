{"id":"6235cabe3d016a3b6717c7c8","title":"Hana and Alice","origin_name":"Hana and Alice","slug":"hana-and-alice","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ha/hana-and-alice.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ha/hana-and-alice.webp","year":2004,"type":"single","genre":[{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"}],"country":[{"id":"620a2307e0fc277084dfd726","name":"Nhật Bản","slug":"nhat-ban"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Hana and Alice","link_embed":"https://vip.opstream14.com/share/e8d92f99edd25e2cef48eca48320a1a5","link_m3u8":"https://vip.opstream14.com/20220318/1665_e36bea3f/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Khi vào trường trung học, hai người bạn thân tên Hana và Alice nhận thấy một cậu bé một năm lớn tuổi hơn trong khi chờ tàu, và cả hai đều bị yêu một năm khá mạnh mẽ với anh ta. Một ngày nọ trong khi bí mật theo anh về nhà, Hana chứng kiến cậu bé bước vào một bức tường và bất tỉnh. Khi anh thức dậy, cô nói dối và thuyết phục anh rằng anh phải có mất trí nhớ, bởi vì anh không nhớ sự thật rằng cô là bạn gái của anh. Sau này, vui nhộn xảy ra khi hai cô gái cố gắng chạy trốn với lời nói dối. Tất nhiên, các biến chứng sớm phát sinh.</p>","tmdb":{"type":"movie","id":"27799","season":null,"vote_average":7,"vote_count":127},"modified":"2024-10-22T11:09:00.000Z","cast":["Anne Suzuki","Yu Aoi","Kaku Tomohiro","Shoko Aida","Hiroshi Abe","Sei Hiraizumi","Tae Kimura","Takao Osawa","Hirosue Ryoko","Lou Ohshiba","Erika Shishido","Ayumi Ito","Hiroyuki Nakano","Nao Omori","Mika Kanô"],"director":["Shunji Iwai"],"cast_meta":[{"name":"Anne Suzuki","name_vi":null,"name_original":"Anne Suzuki","tmdb_id":4