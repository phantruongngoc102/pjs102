8"}]}],"time":"45 phút/tập","description":"Trong cuộc đua ngựa, Đại Hải – ba Chí Cao – thắng cá độ, nhưng không nhận được tiền, bị bọn vay lãi cao đòi nợ. Chí Cao biết rất tức giận nhưng cũng giúp ba 1 lần. Cảnh sát Hướng Minh bắt trọn ổ cá độ nhưng bị thiếu 1 tên. Hướng Tình mang chó đến cho bác sĩ Nhật Tiến chăm sóc, từ đó 2 người quen nhau. Trong 1 đêm Hướng Tình thấy xe của Nhật Tiến chạy ẩu nên làm nhân chứng, Nhật Tiến bị nghi ngờ. Thực ra là do Nhật Chiêu làm, nhưng Kim Chi xin xỏ nên Nhật Tiến sẽ tự mình nhận tội. Ổ cá độ của Kim Nguyên bị cảnh sát bắt, ông ta tức và theo lời của Kim Chi nên giết bịt miệng tên thu tiền cá độ tên Thành.","tmdb":{"type":"tv","id":"4120","season":1,"vote_average":0,"vote_count":0},"modified":"2025-08-10T16:57:31.000Z","cast":["Mã Tuấn Vỹ","Ngô Trác Hy","Nhạc Hoa","Mễ Tuyết","Liêu Bích Nhi","Kenneth Ma Kwok-Ming","Kate Tsui Tsz-Shan","Dương Tư Kỳ","Yoyo Chen Chi-Yiu","Wong Ka-Lok","La Lạc Lâm","Yvonne Lam Yee-Man","Lý Quốc Lân","Hàn Mã Lợi","Lương Kiện Bình"],"director":[],"cast_meta":[{"name":"Mã Tuấn Vỹ","name_vi":"Mã Tuấn Vỹ","name_original":"Steven Ma Chun-Wai","tmdb_id":1233285,"profile":"https://image.tmdb.org/t/p/w500/q60svjeSi9KpyZCwhnwwy6iy8Qs.jpg","tmdb_url":"https://www.themoviedb.org/person/1233285"},{"name":"Ngô Trác Hy","name_vi":"Ngô Trác Hy","name_original":"Ron Ng Cheuk-Hai","tmdb_id":1222249,"profile":"https://image.tmdb.org/t/p/w500/rhT0EL5LYYLZIyS3Aax6MakEE9e.jpg","tmdb_url":"https://www.themoviedb.org/person/1222249"},{"name":"Nhạc Hoa","name_vi":"Nhạc Hoa","name_original":"Elliot Ngok Wah","tmdb_id":94972,"profile":"https://image.tmdb.org/t/p/w500/5yOPmbZfqQ3uHtQsLY5fgksz5I7.jpg","tmdb_url":"https://www.themoviedb.org/person/94972"},{"name":"Mễ Tuyết","name_vi":"Mễ Tuyết","name_original":"Michelle Yim","tmdb_id":64384,"profile":"https://image.tmdb.org/t/p/w500/xrLTxPNUIH3tlPnLCi6BA0ewnG1.jpg","tmdb_url":"https://www.themoviedb.org/person/64384"},{"name":"Liêu Bích Nhi","name_vi":"Liêu Bích Nhi","name_origin