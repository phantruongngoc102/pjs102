túy của Xhaka, một tội phạm ngấp nghé thế lực của Đàm Tiêu Sơn lâu năm, đàm phán với hắn để cứu Đàm Tử Long. Cuối cùng, Trần Xương Bình và Lí Chính Bân cùng nhau bắt được Đàm Tiêu Sơn và Đàm Tử Long, kết thúc “Hành động săn bắn” này.</p>","tmdb_id":877646,"cast":["Li Fei","Trương Vĩnh Cương","Wang Wenxuan","Ge Bu","Huang Kaixiang","Jin Song","He Da","Yang Junchao","Yang Zihua","Wang Ruixuan"],"director":["Hei Zi"],"keywords":[],"cast_meta":[{"name":"Li Fei","name_vi":null,"name_original":"Li Fei","tmdb_id":3137442,"profile":"https://image.tmdb.org/t/p/w500/stYnQzC5m1ihrECe5l4FqYmuymI.jpg","tmdb_url":"https://www.themoviedb.org/person/3137442"},{"name":"Trương Vĩnh Cương","name_vi":"Trương Vĩnh Cương","name_original":"Hei Zi","tmdb_id":1258371,"profile":"https://image.tmdb.org/t/p/w500/b7coEiCPXOwkIj92WGxK8zcCP6r.jpg","tmdb_url":"https://www.themoviedb.org/person/1258371"},{"name":"Wang Wenxuan","name_vi":null,"name_original":"Wang Wenxuan","tmdb_id":3246060,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3246060"},{"name":"Ge Bu","name_vi":null,"name_original":"Ge Bu","tmdb_id":2510959,"profile":"https://image.tmdb.org/t/p/w500/1bHZT1HnAENyaFoUe3qFXQ9Ljxb.jpg","tmdb_url":"https://www.themoviedb.org/person/2510959"},{"name":"Huang Kaixiang","name_vi":null,"name_original":"Huang Kaixiang","tmdb_id":2566306,"profile":"https://image.tmdb.org/t/p/w500/pFlePLJhLm5NRtAPXyGDE36wQ4l.jpg","tmdb_url":"https://www.themoviedb.org/person/2566306"},{"name":"Jin Song","name_vi":null,"name_original":"Jin Song","tmdb_id":113792,"profile":"https://image.tmdb.org/t/p/w500/fHAL9lT0HTeON5eOoDIcngoCyZC.jpg","tmdb_url":"https://www.themoviedb.org/person/113792"},{"name":"He Da","name_vi":null,"name_original":"He Da","tmdb_id":2869369,"profile":"https://image.tmdb.org/t/p/w500/lnjVUZs8SoBH95x4ia1tAJ0HCko.jpg","tmdb_url":"https://www.themoviedb.org/person/2869369"},{"name":"Yang Junchao","name_vi":null,"name_original":"Yang Junchao","tmdb_id":3246062,"profile":null,"tmdb_url":"h