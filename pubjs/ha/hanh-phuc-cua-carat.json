2b038c974aac419","link_m3u8":"https://vip.opstream13.com/20251002/10261_784a9c5b/index.m3u8"},{"name":"15","slug":"15","filename":"Hạnh Phúc Của Carat - Tập 15---2021","link_embed":"https://vip.opstream13.com/share/0247f3dd84906223785fddb18353bafe","link_m3u8":"https://vip.opstream13.com/20251002/10262_0247f3dd/index.m3u8"}]}],"time":"90 phút/tập","description":"<p>Carat là một nữ doanh nhân thành đạt, nắm giữ nhiều quyền lực hơn cả Chakrit, chồng cô. Một ngày nọ, anh ta ngoại tình với thư ký của mình và yêu cầu Carat ly hôn. Mặc dù Carat đang cạnh tranh với Venice để có được một con đường sự nghiệp tốt, nhưng khi nói đến chuyện tình cảm của Carat, Venice lại đứng về phía cô. Ai, một sinh viên năm thứ tư, gặp Carat khi cô đang cãi nhau với Chakrit. Anh đã giúp cô trong thời gian đó và họ cũng tình cờ gặp lại nhau nhiều lần sau đó. Cuối cùng, anh ta muốn tán tỉnh cô và không quan tâm đến khoảng cách hơn 20 tuổi giữa họ. Nhưng mọi chuyện sẽ không dễ dàng khi Mark, ông chủ hoàn hảo của Carat, dường như cũng để ý đến cô.</p>","tmdb":{"type":"tv","id":"139163","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-03T13:25:40.000Z","cast":["Anne Thongprasom","Jirayu Tangsrisuk","Yuranunt Pamornmontri","Dom Hetrakul","Pitchapa Phanthumchinda","Faysal Nakib","Nisachon Tuamsoongnuen","Akekarin Runggran"],"director":["สมจริง ศรีสุภาพ"],"cast_meta":[{"name":"Anne Thongprasom","name_vi":null,"name_original":"Anne Thongprasom","tmdb_id":1160493,"profile":"https://image.tmdb.org/t/p/w500/qVfPVCDf4ncuP3ih67BNyXNlMcR.jpg","tmdb_url":"https://www.themoviedb.org/person/1160493"},{"name":"Jirayu Tangsrisuk","name_vi":null,"name_original":"Jirayu Tangsrisuk","tmdb_id":1259377,"profile":"https://image.tmdb.org/t/p/w500/leCYUlOzQLJfW5bwnQHLlz1Mvt2.jpg","tmdb_url":"https://www.themoviedb.org/person/1259377"},{"name":"Yuranunt Pamornmontri","name_vi":null,"name_original":"Yuranunt Pamornmontri","tmdb_id":2373088,"profile":"https://image.tmdb.org/t/p/w500/1eGjnVBcyYspcUJSx1Z0qYr6L