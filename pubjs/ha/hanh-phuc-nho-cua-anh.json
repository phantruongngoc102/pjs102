ng mới phát hiện mình đã yêu Ôn Thiếu Khanh từ lâu.","tmdb":{"type":"tv","id":"116328","season":1,"vote_average":7.7,"vote_count":21},"modified":"2025-10-02T09:52:52.000Z","cast":["Hình Phi","Đường Hiểu Thiên","Huang Yilin","Li Chuan","Phó Vỹ Luân","Wang Mohan","Yang Anqi","Lưu Sướng","Luo Chenshu","Deng Yuli","Xương Long","Sun Letian","Cui Yi"],"director":["杨龙"],"cast_meta":[{"name":"Hình Phi","name_vi":"Hình Phi","name_original":"Xing Fei","tmdb_id":1737082,"profile":"https://image.tmdb.org/t/p/w500/pQaUc5pJRaGwD8iwwzY1Z2YbrEj.jpg","tmdb_url":"https://www.themoviedb.org/person/1737082"},{"name":"Đường Hiểu Thiên","name_vi":"Đường Hiểu Thiên","name_original":"Tang Xiaotian","tmdb_id":2312401,"profile":"https://image.tmdb.org/t/p/w500/84NlC4nbZqwUJXH0tSNw9O6o3Um.jpg","tmdb_url":"https://www.themoviedb.org/person/2312401"},{"name":"Huang Yilin","name_vi":null,"name_original":"Huang Yilin","tmdb_id":2077932,"profile":"https://image.tmdb.org/t/p/w500/5xhUhWMKOA65e4JuE84JaNDrIk7.jpg","tmdb_url":"https://www.themoviedb.org/person/2077932"},{"name":"Li Chuan","name_vi":null,"name_original":"Li Chuan","tmdb_id":1846861,"profile":"https://image.tmdb.org/t/p/w500/aYswXVsa6gCoTKOqHYSOpS3bjsS.jpg","tmdb_url":"https://www.themoviedb.org/person/1846861"},{"name":"Phó Vỹ Luân","name_vi":"Phó Vỹ Luân","name_original":"Fu Weilun","tmdb_id":3065225,"profile":"https://image.tmdb.org/t/p/w500/mfoiw8LCBDQW6WJGpXy89p1vC6U.jpg","tmdb_url":"https://www.themoviedb.org/person/3065225"},{"name":"Wang Mohan","name_vi":null,"name_original":"Wang Mohan","tmdb_id":3505982,"profile":"https://image.tmdb.org/t/p/w500/7vns7sQwq4OvzxhG9RjIbWRHX9M.jpg","tmdb_url":"https://www.themoviedb.org/person/3505982"},{"name":"Yang Anqi","name_vi":null,"name_original":"Yang Anqi","tmdb_id":3165929,"profile":"https://image.tmdb.org/t/p/w500/t8ZEhVj4KSuXr5WygoQtk38tOvo.jpg","tmdb_url":"https://www.themoviedb.org/person/3165929"},{"name":"Lưu Sướng","name_vi":"Lưu Sướng","name_original":"Liu Chang","tmdb_id":153964