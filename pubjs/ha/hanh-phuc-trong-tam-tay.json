26c7a/index.m3u8"},{"name":"45A","slug":"45a","filename":"hanh-phuc-trong-tam-tay-love-advanced-customization-tap-45A","link_embed":"https://vip.opstream12.com/share/e74e04516a69fd83fdce8ce5eb58cabb","link_m3u8":"https://vip.opstream12.com/20220610/18230_5ea9df50/index.m3u8"},{"name":"45B","slug":"45b","filename":"hanh-phuc-trong-tam-tay-love-advanced-customization-tap-45B","link_embed":"https://vip.opstream12.com/share/d073c2842c53d0ae685a6a72ef66e4d8","link_m3u8":"https://vip.opstream12.com/20220610/18231_5c544905/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Chuyên gia thiết kế thời trang Chu Phóng và giám đốc thương mại điện tử Tống Lẫm gặp nhau trong một vụ kiện. Vốn không đội trời chung nhưng họ bất đắc dĩ phải hợp tác với nhau vì có nhiều điều ràng buộc trong công việc và cuộc sống. Hai con người bướng bỉnh cứng đầu liên tục đụng độ, phát sinh mâu thuẫn. Nhưng trong quá trình tranh đấu lẫn nhau, họ trở nên trưởng thành hơn, hiểu nhau hơn, dần dần nảy sinh tình cảm. Chu Phóng và Tống Lẫm vừa hỗ trợ lẫn nhau, vừa xảy ra nhiều hiềm khích. Họ cùng nhau vượt qua nhiều thử thách. Nhờ mục tiêu lý tưởng muốn hoàn thiện bản thân, họ đạt được nhiều đột phá mới trong sự nghiệp. Chu Phóng thành công sáng lập nhãn hiệu thời trang nổi tiếng, Tống Lẫm cũng gây dựng được mô hình thương mại định chế đẳng cấp.</p>","tmdb":{"type":"tv","id":"103741","season":1,"vote_average":7.2,"vote_count":11},"modified":"2023-04-11T19:26:51.000Z","cast":["Địch Lệ Nhiệt Ba","Hoàng Cảnh Du","Trương Hinh Dư","Dịch Đại Thiên","Hồ Binh","Chu Dục Nhiên","Wang Ruixin","Wang Jiaqi","Zheng Weili","Christine Zheng","Zhao Xin","Lin Yuan","Crystal Yin","Zhang Doudou"],"director":["Shen Yang","Ben Fang"],"cast_meta":[{"name":"Địch Lệ Nhiệt Ba","name_vi":"Địch Lệ Nhiệt Ba","name_original":"Dilraba Dilmurat","tmdb_id":1557698,"profile":"https://image.tmdb.org/t/p/w500/bLa0rBHdZ4Su1l5Xh0cY4mTB70Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1557698"},{"name":"Hoàng Cảnh Du","name_vi":"Hoàng C