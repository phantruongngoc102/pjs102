are/b3b2e5e6e33a19aa35fe31321adc3100","link_m3u8":"https://vip.opstream13.com/20251123/19234_b3b2e5e6/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream13.com/share/f7c6853c7a4a2291e0c49cad09fb1a30","link_m3u8":"https://vip.opstream13.com/20251123/19235_f7c6853c/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream13.com/share/d53ed6e2576ab89b34c972e6aa731423","link_m3u8":"https://vip.opstream13.com/20251123/19236_d53ed6e2/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream13.com/share/b818123d4596c686bf837ce0d839a9af","link_m3u8":"https://vip.opstream13.com/20251123/19237_b818123d/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream13.com/share/c05901fe338c7b91f5251eb0a62df6e1","link_m3u8":"https://vip.opstream13.com/20251123/19238_c05901fe/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream13.com/share/e8e7b4901cc10d831bc1de471920b40d","link_m3u8":"https://vip.opstream13.com/20251123/19239_e8e7b490/index.m3u8"}]}],"description":"<p><i>Hành trình công lý</i> xoay quanh câu chuyện của Anh Phương (Hồng Diễm) và gia đình hoàn hảo của cô với Đức Hoàng (Việt Anh). Phương tốt nghiệp hạng ưu ngành luật nhưng cô quyết định từ bỏ công việc luật sự đầy hứa hẹn về làm hậu phương vững chắc cho chồng. Biến cố xảy ra khi một clip được phát tán ghi lại cảnh ngoại tình của Hoàng với cô gái trẻ xinh đẹp. Cho rằng mình bị gài bẫy, Hoàng tự thân điều tra nhưng khi anh vừa lờ mờ tìm ra manh mối, cô gái trong đoạn clip đó bị ám sát. Hoàng lập tức trở thành nghi can giết người. Cay đắng và suy sụp khi bị phản bội, mất niềm tin, hoang mang vì chồng có thể ngồi tù, những đứa con không còn bố bên cạnh, Phương tưởng chừng sắp gục ngã. Nhưng với sự giúp đỡ của Nguyệt (Thu Quỳnh) và Quân (Quốc Huy), cô vực dậy từ người nội trợ suốt hơn chục năm trở lại với công việc luật sư. Trong hình ảnh một cô luật sư đầy lý trí nhưng cũng đầy cảm xúc, Phương làm lại từ đầu, tìm lại niềm tin, tìm lại giá trị bản thân, tìm ra sự thật và biết được phần nào nỗi ẩn ức của người chồng bị gài bẫy.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ha/hanh-trinh-cong-ly.json"}