ream15.com/share/3817157c9127b4cdb7a8d690ee72d874","link_m3u8":"https://vip.opstream15.com/20220426/8606_e20683f5/index.m3u8"},{"name":"6","slug":"6","filename":"Hành trình của Elaina Tập 6 - Đất Nước Của Những Người Thật Thà","link_embed":"https://vip.opstream15.com/share/fa5375df32bda8862801ea43b6358683","link_m3u8":"https://vip.opstream15.com/20220426/8609_de90749f/index.m3u8"},{"name":"7","slug":"7","filename":"Hành trình của Elaina Tập 7 - Bức Tường Được Khắc Bởi Nhà Lữ Hành - Thiếu Nữ Dẫm Nho","link_embed":"https://vip.opstream15.com/share/1977ab8c9f9473d8594671be4ddf9e7f","link_m3u8":"https://vip.opstream15.com/20220426/8608_07ff1de7/index.m3u8"},{"name":"8","slug":"8","filename":"Hành trình của Elaina Tập 8 - Quỷ Kéo","link_embed":"https://vip.opstream15.com/share/ec79d4bed810ed64267d169b0d37373e","link_m3u8":"https://vip.opstream15.com/20220426/8612_87ebd1f2/index.m3u8"},{"name":"9","slug":"9","filename":"Hành trình của Elaina Tập 9 - Nỗi Đau Truy Hồi","link_embed":"https://vip.opstream15.com/share/1b7663ccddfbba71a405f122e117f95c","link_m3u8":"https://vip.opstream15.com/20220426/8610_44ec81bd/index.m3u8"},{"name":"10","slug":"10","filename":"Hành trình của Elaina Tập 10 - Cặp Đôi Sư Phụ","link_embed":"https://vip.opstream15.com/share/08b7dc6e8b36bcaac15847827b7951a9","link_m3u8":"https://vip.opstream15.com/20220426/8611_d88a4f8f/index.m3u8"},{"name":"11","slug":"11","filename":"Hành trình của Elaina Tập 11 - Cặp Đôi Đệ Tử","link_embed":"https://vip.opstream15.com/share/787afca6b6dd1f06fc22e4b52b0b89bf","link_m3u8":"https://vip.opstream15.com/20220426/8614_2ea47e42/index.m3u8"},{"name":"12","slug":"12","filename":"Hành trình của Elaina Tập 12 - Câu chuyện hằng ngày của Phù thủy Tro Tàn","link_embed":"https://vip.opstream15.com/share/ad8eda80d5b8a3ad710e04d2bd3a9c59","link_m3u8":"https://vip.opstream15.com/20220426/8613_9d9e6dde/index.m3u8"}]}],"time":"","description":"<p>Câu chuyện kể về một cô gái tên Elaina, người đã đạt được danh hiệu cao quý nhất của pháp sư, \"Phù thủy\", và lên đường bắt đầu cuộc hành trình qua khắp các đất nước khác nhau của mình. Lấy động lực từ một quyển sách yêu thích từ nhỏ có tên là \"Cuộc phiêu lưu của Nikeh\", cô nàng cũng đã tự mình dù hành, đi từ vùng đất này đến vùng đất khác, từ đất nước này đến đất nước khác, ghi lại những câu chuyện mà cô đã trải qua. Có những câu chuyện gì ở đất nước đó, và rồi những con người mà cô gặp ra sao, hãy cùng lắng nghe câu chuyện của chính cô ấy, về cuộc hành trình của một phù thủy.</p>","tmdb":{"type":"tv","id":"94693","season":1,"vote_average":7.6,"vote_count":111},"modified":"2022-09-23T08:31:39.000Z","cast":["Kaede Hondo","Kana Hanazawa","Tomoyo Kurosawa","Miho Okasaki","Konomi Kohara","Yoko Hikasa"],"director":[],"cast_meta":[{"name":"Kaede Hondo","name_vi":null,"name_original":"Kaede Hondo","tmdb_id":1779027,"profile":"https://image.tmdb.org/t/p/w500/11BcHnuJYrOZhIftgUiQqfm7TK6.jpg","tmdb_url":"https://www.themoviedb.org/person/1779027"},{"name":"Kana Hanazawa","name_vi":null,"name_original":"Kana Hanazawa","tmdb_id":119143,"profile":"https://image.tmdb.org/t/p/w500/9UTBlNRopSOKyoWnCm74tyHOfR1.jpg","tmdb_url":"https://www.themoviedb.org/person/119143"},{"name":"Tomoyo Kurosawa","name_vi":null,"name_original":"Tomoyo Kurosawa","tmdb_id":1309253,"profile":"https://image.tmdb.org/t/p/w500/eSRnva88YVcUXlDHdVrhier2SGU.jpg","tmdb_url":"https://www.themoviedb.org/person/1309253"},{"name":"Miho Okasaki","name_vi":null,"name_original":"Miho Okasaki","tmdb_id":2138490,"profile":"https://image.tmdb.org/t/p/w500/6vxRulNZRaW47UFvVEq9poRekUx.jpg","tmdb_url":"https://www.themoviedb.org/person/2138490"},{"name":"Konomi Kohara","name_vi":null,"name_original":"Konomi Kohara","tmdb_id":1820616,"profile":"https://image.tmdb.org/t/p/w500/3wjTzpJpBiTkLexdMmo9a3wfgRT.jpg","tmdb_url":"https://www.themoviedb.org/person/1820616"},{"name":"Yoko Hikasa","name_vi":null,"name_original":"Yoko Hikasa","tmdb_id":1072774,"profile":"https://image.tmdb.org/t/p/w500/mP3bj0s1gqJ6tCKFL