2.com/20220609/17742_5057034f/index.m3u8"},{"name":"41B","slug":"41b","filename":"hao-quang-the-justice-tap-41B","link_embed":"https://vip.opstream12.com/share/3f194fbcc671d39373d095ac1e4aab4d","link_m3u8":"https://vip.opstream12.com/20220609/17745_19e91e0f/index.m3u8"}]}],"time":"46M14S","description":"<p>Trình Diệc Trị (Trương Tân Thành đóng) xuất thân bần hàn, vì tình cờ mà quen biết với chủ ngân hàng Ngô Tri Phất, quyết tâm tiến vào ngành tiền tệ phát triển, đồng thời cùng con gái chủ ngân hàng Lệ Tư (Thái Văn Tịnh đóng) kết thành vợ chồng giả. Sau đó, Trình Diệc Trị phát hiện chủ ngân hàng tư nhân đã gây nên cái chết của Ngô Tri Phất, đồng thời cấu kết với thế lực khắp nơi tạo nên một đến quốc tiền đen khổng lồ. Trình Diệc Trị biết được chân tướng không chút do dự lựa chọn rời khỏi ngân hàng tư nhân, cùng tạo nên ngân hàng mới. Sau khi cùng trải qua khó khăn, Trình Diệc Trị và Lệ Tư cũng nảy sinh tình cảm, trở thành cặp đôi hiểu nhau. Bộ phim với sự tham gia diễn xuất của nam chính bộ phim tình cảm “Một Ngày Biến Thành Em” Trương Tân Thành đang được phát sóng tại trang web.</p>","tmdb":{"type":"tv","id":"133007","season":1,"vote_average":6,"vote_count":5},"modified":"2022-06-09T11:06:57.000Z","cast":["Trương Tân Thành","Thái Văn Tịnh","Cổ Tử Thành","Zhang Zhijian","Wang Zijian","Lương Khiết","Lin Peng","Zhang Xuehan","Xiang Yu","Li Na","Zhang Ye Shi"],"director":["Liu Biao"],"cast_meta":[{"name":"Trương Tân Thành","name_vi":"Trương Tân Thành","name_original":"Zhang Xincheng","tmdb_id":2027708,"profile":"https://image.tmdb.org/t/p/w500/mpCVPsEvnMUkmMd1IN1xsBJpk7r.jpg","tmdb_url":"https://www.themoviedb.org/person/2027708"},{"name":"Thái Văn Tịnh","name_vi":"Thái Văn Tịnh","name_original":"Cai Wenjing","tmdb_id":1680738,"profile":"https://image.tmdb.org/t/p/w500/gyeNAy8ktBNlNqXhzy2R6AQ6Y5l.jpg","tmdb_url":"https://www.themoviedb.org/person/1680738"},{"name":"Cổ Tử Thành","name_vi":"Cổ Tử Thành","name_original":"Gu Zicheng","tmdb_id":2662142,"profile":"https://ima