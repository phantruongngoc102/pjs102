230423/34252_a32863b8/index.m3u8"},{"name":"41","slug":"41","filename":"cau-chuyen-trong-hanh-phuc-tap-41","link_embed":"https://vip.opstream16.com/share/a0e862b5c2de0352aeb851d943e6046c","link_m3u8":"https://vip.opstream16.com/20230423/34253_f30b51e0/index.m3u8"},{"name":"42","slug":"42","filename":"cau-chuyen-trong-hanh-phuc-tap-42","link_embed":"https://vip.opstream16.com/share/2931063739d4a2ea969474ff753bf05e","link_m3u8":"https://vip.opstream16.com/20230423/34254_1e7ed14b/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Năm 1978, Trần Ngõa Nhi, Ngô Tây Khải, Lý Khải Minh, Hồ Mỹ Hoa và Hứa Vệ Đông đều cùng nhau bước vào phòng thi tuyển sinh đại học. Nhưng khi kết quả được công bố, Trần Ngõa Nhi và Hồ Mỹ Hoa đã trượt, còn Lý Tường thì được nhận vào trường kế toán tài vụ và Hứa Vệ Đông thì vào trường quân sự. Cuộc sống và công việc của bọn họ khác nhau nên khiến họ ngày càng xa cách hơn. Do theo kịp được nhịp đập của thời đại, Lý Tường đã kiếm được món tiền đầu tiên trên thị trường và cuối cùng đã kết hôn với Trần Ngõa Nhi, nhưng sau đó Lý Tường vì hanh danh vọng nên đã bỏ rơi vợ con mình, Trần Ngõa Nhi đã nhiều lần chịu sự đả kích của cuộc sống nhưng cô chưa bao giờ chịu khuất phục và cuối cùng cô cũng thành lập được một công ty doanh nghiệp nổi tiếng. Hồ Mỹ Hoa, người đã rời quê hương để sang nước Mĩ, lại trở thành chuyên gia tài chính và quay trở về con phố nơi cô đã xa cách nhiều năm.</p>","tmdb":{"type":"tv","id":"111356","season":1,"vote_average":10,"vote_count":1},"modified":"2025-06-14T15:44:38.000Z","cast":["Lý Thần","Su Qing","Vương Hiểu Thần","Che Xiao"],"director":["Yang Ya Zhou"],"cast_meta":[{"name":"Lý Thần","name_vi":"Lý Thần","name_original":"Jerry Lee","tmdb_id":130984,"profile":"https://image.tmdb.org/t/p/w500/29SF639O4mzp3dhIuIFcaux0Te9.jpg","tmdb_url":"https://www.themoviedb.org/person/130984"},{"name":"Su Qing","name_vi":null,"name_original":"Su Qing","tmdb_id":2250335,"profile":"https://image.tmdb.org/t/p/w500/aeIYv2xRRnwlPTzMR3F0da57e74.jpg","tmdb_url":"https://www.themoviedb.org/person/2250335"},{"name":"Vương Hiểu Thần","name_vi":"Vương Hiểu Thần","name_original":"Wang Xiaochen","tmdb_id":1135172,"profile":"https://image.tmdb.org/t/p/w500/4CcEIYCJGsnlonoaNWynM1Fgyvl.jpg","tmdb_url":"https://www.themoviedb.org/person/1135172"},{"name":"Che Xiao","name_vi":null,"name_original":"Che Xiao","tmdb_id":143845,"profile":"https://image.tmdb.org/t/p/w500/otXp80vW3gcZLpXpmj4rNRxyLgi.jpg","tmdb_url":"https://www.themoviedb.org/person/143845"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ha/happiness-in-spring.json"}