ng những người bạn của mình khám phá những điều bí mật nguy hiểm về thế giới của phép thuật...</p>","tmdb":{"type":"movie","id":"671","season":null,"vote_average":7.9,"vote_count":29102},"modified":"2023-11-20T09:14:33.000Z","cast":["Daniel Radcliffe","Rupert Grint","Emma Watson","Richard Harris","Tom Felton","Alan Rickman","Robbie Coltrane","Maggie Smith","Richard Griffiths","Ian Hart","Fiona Shaw","John Hurt","David Bradley","Matthew Lewis","Sean Biggerstaff"],"director":["Chris Columbus"],"cast_meta":[{"name":"Daniel Radcliffe","name_vi":null,"name_original":"Daniel Radcliffe","tmdb_id":10980,"profile":"https://image.tmdb.org/t/p/w500/e64VeB4Mybwm2tOhyLY1h7XQQ8N.jpg","tmdb_url":"https://www.themoviedb.org/person/10980"},{"name":"Rupert Grint","name_vi":null,"name_original":"Rupert Grint","tmdb_id":10989,"profile":"https://image.tmdb.org/t/p/w500/q2KZZ0ltTEl7Sf8volNFV1JDEP4.jpg","tmdb_url":"https://www.themoviedb.org/person/10989"},{"name":"Emma Watson","name_vi":null,"name_original":"Emma Watson","tmdb_id":10990,"profile":"https://image.tmdb.org/t/p/w500/mf0OANvWYSzU1d8yggrhyw8IbIz.jpg","tmdb_url":"https://www.themoviedb.org/person/10990"},{"name":"Richard Harris","name_vi":null,"name_original":"Richard Harris","tmdb_id":194,"profile":"https://image.tmdb.org/t/p/w500/lCvcVMuxrg1f5A8OMqY9AqkkcZR.jpg","tmdb_url":"https://www.themoviedb.org/person/194"},{"name":"Tom Felton","name_vi":null,"name_original":"Tom Felton","tmdb_id":10993,"profile":"https://image.tmdb.org/t/p/w500/etmtUBzJ1i1XJTLS6MkotJFE1se.jpg","tmdb_url":"https://www.themoviedb.org/person/10993"},{"name":"Alan Rickman","name_vi":null,"name_original":"Alan Rickman","tmdb_id":4566,"profile":"https://image.tmdb.org/t/p/w500/7tADZs4ILE93oJ5pAh6mKQFEq2m.jpg","tmdb_url":"https://www.themoviedb.org/person/4566"},{"name":"Robbie Coltrane","name_vi":null,"name_original":"Robbie Coltrane","tmdb_id":1923,"profile":"https://image.tmdb.org/t/p/w500/jOHs3xvlwRiiG2CLtso5zzmGCXg.jpg","tmdb_url":"https://www.themoviedb