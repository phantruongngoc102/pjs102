gọc xá lợi cũng là chìa khóa để cứu thoát tam giới khỏi loià ma quỷ.</i></p>","tmdb":{"type":"tv","id":"100217","season":1,"vote_average":8.2,"vote_count":6},"modified":"2024-12-27T11:36:13.000Z","cast":["Cho Wing","Huỳnh Hải Băng","Trương Vĩnh Cương","Wu Jian","Yu Zhen","Lv Hanbiao","Ma Jielin","Zhang Zhiwei","Qiu Yue","Fu Yujia","Cui Dai","Shan Lianli","Li Jun","Ma Yashu","Yu Yuexian"],"director":["Dương Khiết"],"cast_meta":[{"name":"Cho Wing","name_vi":null,"name_original":"Cho Wing","tmdb_id":67225,"profile":"https://image.tmdb.org/t/p/w500/mNX0Y91ofxg0vqOypBAGs3Awq5.jpg","tmdb_url":"https://www.themoviedb.org/person/67225"},{"name":"Huỳnh Hải Băng","name_vi":"Huỳnh Hải Băng","name_original":"Huang Haibing","tmdb_id":557428,"profile":"https://image.tmdb.org/t/p/w500/vDyKX8JoQOS1rmNLfROH9txSpfo.jpg","tmdb_url":"https://www.themoviedb.org/person/557428"},{"name":"Trương Vĩnh Cương","name_vi":"Trương Vĩnh Cương","name_original":"Hei Zi","tmdb_id":1258371,"profile":"https://image.tmdb.org/t/p/w500/b7coEiCPXOwkIj92WGxK8zcCP6r.jpg","tmdb_url":"https://www.themoviedb.org/person/1258371"},{"name":"Wu Jian","name_vi":null,"name_original":"Wu Jian","tmdb_id":2027751,"profile":"https://image.tmdb.org/t/p/w500/woru4y2zYuRwN20SbHXyiTNJBNq.jpg","tmdb_url":"https://www.themoviedb.org/person/2027751"},{"name":"Yu Zhen","name_vi":null,"name_original":"Yu Zhen","tmdb_id":2391403,"profile":"https://image.tmdb.org/t/p/w500/gf104t00aDOY6w6kNFc3478JjMD.jpg","tmdb_url":"https://www.themoviedb.org/person/2391403"},{"name":"Lv Hanbiao","name_vi":null,"name_original":"Lv Hanbiao","tmdb_id":2977532,"profile":"https://image.tmdb.org/t/p/w500/wcG8ZxE6nxqiZclR9SWuJfI0BDW.jpg","tmdb_url":"https://www.themoviedb.org/person/2977532"},{"name":"Ma Jielin","name_vi":null,"name_original":"Ma Jielin","tmdb_id":2977537,"profile":"https://image.tmdb.org/t/p/w500/tEh7kalCgOmmyD8YGd5Mzt2SNwl.jpg","tmdb_url":"https://www.themoviedb.org/person/2977537"},{"name":"Zhang Zhiwei","name_vi":null,"name_original