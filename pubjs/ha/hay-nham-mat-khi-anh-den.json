ream10.com/share/2dec8d122fa3447e2baa42fbe4fe7918","link_m3u8":"https://vip.opstream10.com/20220606/19119_5cfd3205/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream10.com/share/c31de86411f643ec08e04b38ae397efc","link_m3u8":"https://vip.opstream10.com/20220606/19120_ae3e54dd/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream10.com/share/a0519cba56fbfc7adac9c0a3d313b27d","link_m3u8":"https://vip.opstream10.com/20220606/19123_4da7c658/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream10.com/share/16e62507eba0d973dc7aa14aa3aa41ab","link_m3u8":"https://vip.opstream10.com/20220606/19124_fb2fbb77/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream10.com/share/4c6ec11e967c21b14b970b16579cdf13","link_m3u8":"https://vip.opstream10.com/20220606/19127_d60b835d/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream10.com/share/3a5b32a30dde157ac0e5e90d1330fe91","link_m3u8":"https://vip.opstream10.com/20220606/19126_8ec6cc7e/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream10.com/share/c6b7a3f883ebdc29cbe617ea59b74987","link_m3u8":"https://vip.opstream10.com/20220606/19130_ac9aa027/index.m3u8"}]}],"description":"<p>Phim Love Me If You Dare nói về sự hòa quyện giữa tình tiết lãng mạn, ngọt ngào của tình yêu nam nữ, sự kinh dị của loạt án giết người man rợ và cả sự bí hiểm, hồi hộp của quy trình điều tra. Nhân vật nam trung tâm của một tác phẩm đặc biệt như vậy cũng được khắc họa một cách rất không đụng hàng. Bạc Cận Ngôn có vẻ ngoài điển trai đúng chuẩn nam thần, sở hữu bộ óc nhạy bén của một chuyên gia phân tích tâm lý tội phạm hàng đầu, còn tính cách thi trên cả lập dị.</p>","tmdb_id":64174,"cast":[],"director":[],"keywords":[],"tmdb":{"id":64174},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ha/hay-nham-mat-khi-anh-den.json"}