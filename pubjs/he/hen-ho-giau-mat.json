m/share/911b10b73d26005b82c8d2b5256f2403","link_m3u8":"https://vip.opstream15.com/20220521/15903_8b90f2ef/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream15.com/share/475820c2296dc914143683e9edbce43b","link_m3u8":"https://vip.opstream15.com/20220521/15906_2dac9010/index.m3u8"}]}],"description":"<p>Hạ thiên là 1 cô gái xấu xí, làm biên tập chuyên mục ở đài phát thanh, tính tình hướng nội, do một lần đấu khẩu với mẹ mà cá cược với mẹ rằng, đến ngày cưới của em gái, sẽ dẫn bạn trai về ra mắt, cho mọi người thấy mình lột xác. Nếu như làm được thì được giữ lại căn phòng của bà ngoại hạ thiên. Mẹ Hạ Thiên đồng ý, từ lúc cá cược cho tới hôn lễ còn 278 ngày. Hạ thiên có đăng lên trên chương trình phát thanh nói về trận cá cược của mình và được nhiều người tán đồng, cũng hấp dẫn rất nhiều đối tượng hẹn hò, và lần lượt thất bại… Trải qua những cuộc hẹn đó, Hạ thiên dần trưởng thành, dũng cảm, không còn là cô bé múp tự ti hồi nào nữa… Đến hôn lễ của em gái, cố mới phát hiện ra,tình yêu thực sự vẫn luôn ở bên mình.</p>","tmdb_id":73116,"cast":["Lục Nghị","Lý Nhã Nam","Trương Hàn"],"director":["Đang cập nhật"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"73116","season":1,"vote_average":3,"vote_count":2},"cast_meta":[{"name":"Lục Nghị","name_vi":null,"name_original":"Lục Nghị"},{"name":"Lý Nhã Nam","name_vi":null,"name_original":"Lý Nhã Nam"},{"name":"Trương Hàn","name_vi":null,"name_original":"Trương Hàn"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/he/hen-ho-giau-mat.json"}