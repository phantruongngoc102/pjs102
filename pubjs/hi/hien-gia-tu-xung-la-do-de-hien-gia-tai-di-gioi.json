ẫn trực tuyến và cảm thấy trò chơi đã trở nên thực tế hơn một chút. Arch Earth Online cuối cùng có nhận được bản cập nhật được chờ đợi từ lâu không?</p>","tmdb_id":104032,"cast":["Nichika Omori","Murase Ayumu","Minami Hinata","Yui Horie","Ayane Sakura","Junichi Saito","Hiroki Yasumoto","Yae Sakura","Yuko Natsuyoshi","Kanomi Izawa","Isao Sasaki"],"director":[],"keywords":[],"cast_meta":[{"name":"Nichika Omori","name_vi":null,"name_original":"Nichika Omori","tmdb_id":1779968,"profile":"https://image.tmdb.org/t/p/w500/v65m4toX5Iz0Zsv5WDRmG6PLEoZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1779968"},{"name":"Murase Ayumu","name_vi":"Murase Ayumu","name_original":"Ayumu Murase","tmdb_id":1325230,"profile":"https://image.tmdb.org/t/p/w500/3aGM6KpcCIEKOXP9510tzaKc8uw.jpg","tmdb_url":"https://www.themoviedb.org/person/1325230"},{"name":"Minami Hinata","name_vi":null,"name_original":"Minami Hinata","tmdb_id":3042847,"profile":"https://image.tmdb.org/t/p/w500/q90Z5krEzTMOqJSM4DAjJNUE6Xq.jpg","tmdb_url":"https://www.themoviedb.org/person/3042847"},{"name":"Yui Horie","name_vi":null,"name_original":"Yui Horie","tmdb_id":202806,"profile":"https://image.tmdb.org/t/p/w500/3TXfhSdsfEqPYi4ww0dBPGhVQm0.jpg","tmdb_url":"https://www.themoviedb.org/person/202806"},{"name":"Ayane Sakura","name_vi":null,"name_original":"Ayane Sakura","tmdb_id":992869,"profile":"https://image.tmdb.org/t/p/w500/yPbTmntASE9psPIMhNGU5oo6vIH.jpg","tmdb_url":"https://www.themoviedb.org/person/992869"},{"name":"Junichi Saito","name_vi":null,"name_original":"Junichi Saito","tmdb_id":3298165,"profile":"https://image.tmdb.org/t/p/w500/2yQv14OgDbTXycVqHO4r6Ptdy2x.jpg","tmdb_url":"https://www.themoviedb.org/person/3298165"},{"name":"Hiroki Yasumoto","name_vi":null,"name_original":"Hiroki Yasumoto","tmdb_id":216448,"profile":"https://image.tmdb.org/t/p/w500/vNIGLl0wFmdhdnulMssQ1qyNeBs.jpg","tmdb_url":"https://www.themoviedb.org/person/216448"},{"name":"Yae Sakura","name_vi":null,"name_original":"Yae Sakura","tm