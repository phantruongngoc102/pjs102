lầm lì, cáu kỉnh dễ nổi nóng. Hắn vô cùng căm hận Tiên Phủ Canh Thần và luôn nuôi ý định trả thù. Liêu Đình Nhạn thực chất là thân phận của một thích khách do Ma Vực cài vào, nhưng Trâu Nhạn không hề biết \"bản thân\" còn che giấu thiết lập này nên ngay từ lần đầu chạm mặt, cô suýt nữa đã mất mạng dưới tay Tư Mã Tiêu. Sau thời gian tiếp xúc, nhờ năng lực “lời thề nói thật”, Tư Mã Tiêu dần nhận ra cô không hề có ý định ám sát hay lợi dụng mình. Thái độ này khiến hắn cảm thấy tò mò, nảy sinh hứng thú, từ đó bắt đầu chuyện tình dây dưa nhiều kiếp giữa ma vương phản diện và cô gái lười hệ chữa lành.","tmdb":{"type":"tv","id":"254476","season":1,"vote_average":8.2,"vote_count":10},"modified":"2025-09-02T12:07:54.000Z","cast":["Trần Phi Vũ","Vương Ảnh Lộ","Vương Nhất Đình","Cao Hàn","Wu Yuheng","Wang Yajia","Zhao Shunran"],"director":["温德光"],"cast_meta":[{"name":"Trần Phi Vũ","name_vi":"Trần Phi Vũ","name_original":"Arthur Chen","tmdb_id":2165598,"profile":"https://image.tmdb.org/t/p/w500/rP046czFxScpvRiinBAwJtc3302.jpg","tmdb_url":"https://www.themoviedb.org/person/2165598"},{"name":"Vương Ảnh Lộ","name_vi":"Vương Ảnh Lộ","name_original":"Wang Yinglu","tmdb_id":3066782,"profile":"https://image.tmdb.org/t/p/w500/d6KZ9WWIGdiOtuU0kbxSIA53ng.jpg","tmdb_url":"https://www.themoviedb.org/person/3066782"},{"name":"Vương Nhất Đình","name_vi":"Vương Nhất Đình","name_original":"Wang Yiting","tmdb_id":2850866,"profile":"https://image.tmdb.org/t/p/w500/2Snv38YItpx3bQ4BMhDViHSh7qN.jpg","tmdb_url":"https://www.themoviedb.org/person/2850866"},{"name":"Cao Hàn","name_vi":"Cao Hàn","name_original":"Gao Han","tmdb_id":3788274,"profile":"https://image.tmdb.org/t/p/w500/hMz9cKmW8tt7YWIigyAhsXG8qN4.jpg","tmdb_url":"https://www.themoviedb.org/person/3788274"},{"name":"Wu Yuheng","name_vi":null,"name_original":"Wu Yuheng","tmdb_id":3149730,"profile":"https://image.tmdb.org/t/p/w500/1uygmqdtcY6boX98qBhQpk1T81E.jpg","tmdb_url":"https://www.themoviedb.org/person/3149730"},{"name":"Wang Yajia","nam