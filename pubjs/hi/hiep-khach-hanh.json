8":"https://vip.opstream17.com/20240124/276_617eca28/index.m3u8"}]}],"description":"<p>Câu truyện xoay quanh các cuộc phiêu lưu của Thạch Phá Thiên, xoay quanh bài thơ “Hiệp khách hành” của thi tiên Lý Bạch. Hiệp khách hành là câu chuyện hoàn toàn không có sự liên hệ với lịch sử, với những tình tiết mang tính chất mờ ảo, thần thoại. Chỉ có thể đoán rằng nó xảy ra sau thời kỳ Nguyên-Minh, khi mà đã xuất hiện phái Võ Đang với huyền thoại Trương Tam Phong từng được đem ra so sánh.</p>","tmdb_id":94070,"cast":["Wu Jian","Yanmin Zhang","Đặng Gia Giai","Ji Qilin","Han Yueqiao","Li Xiaobo","Su Tingshi","Quách Quân","Shan Lianli","Zhang Shan","Yanhua Fan","Tan Jianchang","Yuhua Duan","Jia Zhaoji","Tong Xiaohu"],"director":["Louis Cha"],"keywords":[],"tmdb":{"type":"tv","id":"94070","season":1,"vote_average":6.8,"vote_count":4},"cast_meta":[{"name":"Wu Jian","name_vi":null,"name_original":"Wu Jian","tmdb_id":2027751,"profile":"https://image.tmdb.org/t/p/w500/woru4y2zYuRwN20SbHXyiTNJBNq.jpg","tmdb_url":"https://www.themoviedb.org/person/2027751"},{"name":"Yanmin Zhang","name_vi":null,"name_original":"Yanmin Zhang","tmdb_id":3230112,"profile":"https://image.tmdb.org/t/p/w500/tCC0ZjgLhOKZ70M4qQsOA22syjL.jpg","tmdb_url":"https://www.themoviedb.org/person/3230112"},{"name":"Đặng Gia Giai","name_vi":"Đặng Gia Giai","name_original":"Deng Jiajia","tmdb_id":1059217,"profile":"https://image.tmdb.org/t/p/w500/zwTb6M8FI0eOaLEITulpSKUWmtE.jpg","tmdb_url":"https://www.themoviedb.org/person/1059217"},{"name":"Ji Qilin","name_vi":null,"name_original":"Ji Qilin","tmdb_id":3291653,"profile":"https://image.tmdb.org/t/p/w500/fyZUl7DUUZMDsugNG37ioL6L9Lv.jpg","tmdb_url":"https://www.themoviedb.org/person/3291653"},{"name":"Han Yueqiao","name_vi":null,"name_original":"Han Yueqiao","tmdb_id":1910872,"profile":"https://image.tmdb.org/t/p/w500/7nn7GPXtFrkXEr0V5eLTvhMGfUZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1910872"},{"name":"Li Xiaobo","name_vi":null,"name_original":"Li Xiaobo","tmdb_i