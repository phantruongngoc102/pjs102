share/ad551fd8c04785df87b7ae269a20c243","link_m3u8":"https://vip.opstream17.com/20240515/7802_b366d7e9/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/c28f6ae146390a9c1b923233ef556c66","link_m3u8":"https://vip.opstream17.com/20240515/7801_5a41f431/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/6822951732be44edf818dc5a97d32ca6","link_m3u8":"https://vip.opstream17.com/20240515/7800_f36827b6/index.m3u8"}]}],"description":"<p><i>Hiệp Khách Mặt Nạ Đen (phim Singapore) lấy cảm hứng từ một câu chuyện ngắn của Trung Quốc. Câu chuyện kể về một tên trộm chuyên cướp giàu giúp nghèo trong triều đại Nam Tống. Hiệp khách mặt nạ đen ngày thường là một bổ đầu chuyên chống lại những sự bất công. Cả Lý Nam Tinh và Âu Dương Chấn Hoa đều trở thành đối thủ khi cả hai đều rơi vào tình yêu với bà chủ tửu lầu do Phạm Văn Phương thủ vai. Dân chúng của Điền thành đang vô cùng cảm kích hiệp đạo \"Nghĩa lai giả\" nhưng không ngờ anh ta lại chính là bổ đầu của nha môn. Tống đầu 1 kê được triệu tới đây làm sứ giả.</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/hi/hiep-khach-mat-na-den.json","tmdb_checked":false}