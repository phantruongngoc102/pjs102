pstream15.com/share/b56b7c12f20e05664ec7674d075c5fc0","link_m3u8":"https://vip.opstream15.com/20220419/5617_c21a7e81/index.m3u8"},{"name":"47","slug":"47","filename":"hiep-si-mat-na-build-kamen-rider-build-tap-47","link_embed":"https://vip.opstream15.com/share/1a4ab15f37a1d2341d947a9996ddfbf7","link_m3u8":"https://vip.opstream15.com/20220419/5619_99b00aea/index.m3u8"},{"name":"48","slug":"48","filename":"hiep-si-mat-na-build-kamen-rider-build-tap-48","link_embed":"https://vip.opstream15.com/share/249338e601902b14d0f529fe5e6ae417","link_m3u8":"https://vip.opstream15.com/20220419/5621_3f746a93/index.m3u8"},{"name":"49","slug":"49","filename":"hiep-si-mat-na-build-kamen-rider-build-tap-49","link_embed":"https://vip.opstream15.com/share/44bf89b63173d40fb39f9842e308b3f9","link_m3u8":"https://vip.opstream15.com/20220419/5623_d26ef2f0/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim Siêu Nhân Build - Kamen Rider Build 2017: Nói về 1 chiếc hộp bí ẩn gọi là “Pandora” được tìm thấy trên sao Hỏa, khi mở nó ra, thình lình trên bầu trời xuất hiện bức tường gọi là “SkyWall” và chia cắt Nhật Bản thành 3 khu vực : Touto, Hokuto, và Saito (Đông Đô, Bắc Đô và Tây Đô). Cùng lúc đó, ở các khu vực xuất hiện quái vật tên là “smash” quấy phá người dân. nhân vật chính là Kiryuu Sento, một thiên tài vật lý học bị – mất- ký-ức do một tai nạn nhiều năm trước, Kiryuu sống tại nhà một người tốt bụng đã ra tay giúp đỡ khi anh gặp nguy khốn. Nhận lời đề nghị của chính quyền, Kiryuu bắt đầu cuộc nghiên cứu nhằm giải mã bí ẩn chiếc hộp Pandora và thân thế thực sự của mình. Tình cờ thay, vẫn có một người biết quá khứ của Kiryuu, đó là Banjo Ryuga – tù vượt ngục, thụ án với tội danh “Giết người”, đi cùng Kiryuu trong series này, còn có Isurugi Misora , một cô gái có khả năng đặc biệt gây bất lợi với lũ quái vật.</p>","tmdb":{"type":"tv","id":"86644","season":1,"vote_average":8.3,"vote_count":3},"modified":"2023-06-11T19:24:33.000Z","cast":["Atsuhiro Inukai","Eiji Akaso","Kaho Takada"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Atsuhiro Inukai","name_vi":null,"name_original":"Atsuhiro Inukai"},{"name":"Eiji Akaso","name_vi":null,"name_original":"Eiji Akaso"},{"name":"Kaho Takada","name_vi":null,"name_original":"Kaho Takada"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/hi/hiep-si-mat-na-build.json"}