ều Vỹ đóng), phá nhiều vụ án lớn.","tmdb":{"type":"tv","id":"32410","season":1,"vote_average":10,"vote_count":1},"modified":"2025-02-08T11:09:07.000Z","cast":["Huỳnh Nhật Hoa","Miêu Kiều Vỹ","Kwan Ching","Hồ Định Hân","Vương Hạo Tín","Oscar Leung Lit-Wai","Angel Chiang","Tuyên Huyên","Mimi Chu Mai-Mai","Savio Tsang","Go Go Cheung Wai-Yi"],"director":["Đường Cơ Minh","Tô Vạn Thông"],"cast_meta":[{"name":"Huỳnh Nhật Hoa","name_vi":"Huỳnh Nhật Hoa","name_original":"Felix Wong Yat-Wah","tmdb_id":71655,"profile":"https://image.tmdb.org/t/p/w500/9HooA3aF764XKYU8GUxO4P7v5gZ.jpg","tmdb_url":"https://www.themoviedb.org/person/71655"},{"name":"Miêu Kiều Vỹ","name_vi":"Miêu Kiều Vỹ","name_original":"Michael Miu Kiu-Wai","tmdb_id":236075,"profile":"https://image.tmdb.org/t/p/w500/gJt4HBE493fHSBjHezSuA75VQ4A.jpg","tmdb_url":"https://www.themoviedb.org/person/236075"},{"name":"Kwan Ching","name_vi":null,"name_original":"Kwan Ching","tmdb_id":3444638,"profile":"https://image.tmdb.org/t/p/w500/9ItgkyBLMuR1GZZ3WUJMT85HgnS.jpg","tmdb_url":"https://www.themoviedb.org/person/3444638"},{"name":"Hồ Định Hân","name_vi":"Hồ Định Hân","name_original":"Nancy Wu","tmdb_id":1234856,"profile":"https://image.tmdb.org/t/p/w500/9HPuplvtWO5ODGX0IhNaZsssIi4.jpg","tmdb_url":"https://www.themoviedb.org/person/1234856"},{"name":"Vương Hạo Tín","name_vi":"Vương Hạo Tín","name_original":"Vincent Wong Ho-Shun","tmdb_id":1690917,"profile":"https://image.tmdb.org/t/p/w500/tjV6ap01OzpQZq4Wzi42nXQ3aBX.jpg","tmdb_url":"https://www.themoviedb.org/person/1690917"},{"name":"Oscar Leung Lit-Wai","name_vi":null,"name_original":"Oscar Leung Lit-Wai","tmdb_id":1143685,"profile":"https://image.tmdb.org/t/p/w500/ftnBNSi7RriYNkHarXrh5ExA74s.jpg","tmdb_url":"https://www.themoviedb.org/person/1143685"},{"name":"Angel Chiang","name_vi":null,"name_original":"Angel Chiang","tmdb_id":1206205,"profile":"https://image.tmdb.org/t/p/w500/uFn0hNvkSbE7EZoummLW2mRjVG5.jpg","tmdb_url":"https://www.themoviedb.org/person/1206205"},{"na