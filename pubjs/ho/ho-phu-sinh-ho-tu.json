://vip.opstream17.com/share/31f81674a348511b990af268ca3a8391","link_m3u8":"https://vip.opstream17.com/20240424/5743_7fdfdea3/index.m3u8"},{"name":"15","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-15","link_embed":"https://vip.opstream17.com/share/c7be03f5d811ed29c328526ca8ab0d61","link_m3u8":"https://vip.opstream17.com/20240424/5742_46c3c0be/index.m3u8"},{"name":"16","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-16","link_embed":"https://vip.opstream17.com/share/edea298442a67de045e88dfb6e5ea4a2","link_m3u8":"https://vip.opstream17.com/20240424/5741_b6f4ce29/index.m3u8"},{"name":"17","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-17","link_embed":"https://vip.opstream17.com/share/9be681ea06f52111e4c1ef99d3763770","link_m3u8":"https://vip.opstream17.com/20240424/5740_b91ff7da/index.m3u8"},{"name":"18","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-18","link_embed":"https://vip.opstream17.com/share/167ccbe15cc1664c9a63c20ac4c6a55a","link_m3u8":"https://vip.opstream17.com/20240424/5739_89038410/index.m3u8"},{"name":"19","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-19","link_embed":"https://vip.opstream17.com/share/d0f4dae80c3d0277922f8371d5827292","link_m3u8":"https://vip.opstream17.com/20240424/5738_8f1ab7ad/index.m3u8"},{"name":"20","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-20","link_embed":"https://vip.opstream17.com/share/e6e9099e59636a015536fbb07f979201","link_m3u8":"https://vip.opstream17.com/20240424/5737_c93b3754/index.m3u8"},{"name":"21","slug":"","filename":"Ho Phu Sinh Ho Tu - Ban Sao 2009-21end","link_embed":"https://vip.opstream17.com/share/105e822401e5551873cc80584f19c649","link_m3u8":"https://vip.opstream17.com/20240424/5736_cbd25ec4/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Tuy ngạn ngữ có câu Hổ Phụ Vô Khuyển Tử nhưng đối với cha con họ Sở thì quả thật hơi khiên cưỡng: trong khi người cha Sở Phàm (Trần Cẩm Hồng) luôn chìm đắm trong ký ức của thập niên 60 thế kỷ trước, thì cậu con trai Sở Từ (Ngô Trác Hy) tuy sống trong nhịp sống vội vã của thế kỷ 21 nhưng còn lại chê là rất chậm chạp. Sở Từ tình cờ vượt thời gian trở về thập niên 60, gặp lại người cha đang ở độ tuổi thanh niên, tình cha con bỗng chốc trở thành tình anh em. Sở Từ được Sở Phàm cưu mang, và quen biết đươc nhiều người: ông chủ tiệm mì nhát gan Cao Sơn Tuyền (Khương Đại Vệ), bà chủ nhà hung dữ Đàm Lan Thanh (Huỳnh Thục Nghi), tiểu oan gia Trình Lan Phần ( Dương Tư Kỳ) và thiên kim tiểu thư Lương Phiên Phiên (Hồ Định Hân). Sở Từ đắc tội với nhiều người, nhất là với Ngưu Chính Vinh (Nguyễn Thiệu Tường) tên cảnh sát chỉ biết vơ vét của cải, duy chỉ có Sở Phàm là luôn bảo vệ anh, đồng thời giới thiệu anh vào cửa hàng bách hóa làm việc. Tuy nhiên anh chàng ba hoa Sở Từ vẫn không thay đổi tính tình, chỉ biết suốt ngày chê bai tác phong làm việc thủ cựu, tính cách thiệt mình lợi người của cha, rồi còn không cẩn thận suýt làm liên lụy những người ở cùng không nhà để về, thậm chí anh còn cố tình phá hoại tình cảm giữa cha và vua lừa gạt Tô Phụng Ni (Hồ Hạnh Nhi) đến lúc tỉnh ngộ, mới biết bản thân thì ra.</i></p>","tmdb":{"type":"tv","id":"31386","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-14T10:21:44.000Z","cast":["Hồ Định Hân","Trần Cẩm Hồng","Hồ Hạnh Nhi","Ngô Trác Hy","Dương Tư Kỳ","Khương Đại Vệ","Gigi Wong","Louis Yuen Siu-Cheung","Carlo Ng Ka-Lok","Mandy Wong","Teresa Lee Fung","Chun Wong","Lỗ Chấn Thuận","Trần Vinh Tuấn","Lily Lai-Lai Liu"],"director":["Phan Gia Đức"],"cast_meta":[{"name":"Hồ Định Hân","name_vi":"Hồ Định Hân","name_original":"Nancy Wu","tmdb_id":1234856,"profile":"https://image.tmdb.org/t/p/w500/9HPuplvtWO5ODGX0IhNaZsssIi4.jpg","tmdb_url":"https://www.themoviedb.org/person/1234856"},{"name":"Trần Cẩm Hồng","name_vi":"Trần Cẩm Hồng","name_original":"Sunny Chan Kam-Hung","tmdb_id":548050,"profile":"https://image.tmdb.org/t/p/w500/pUMJUtdpFutN7uHk7yPw11iwAbh.jpg","tmdb_url":"https://www.themoviedb.org/person/548050"},{"name":"Hồ Hạnh Nhi","name_vi