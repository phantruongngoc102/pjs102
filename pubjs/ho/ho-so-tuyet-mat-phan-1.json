ỳ bí. Tuy nhiên, tới cuối phim thì nhân vật Fox Mulder xuất hiện ít hơn và có thêm sự xuất hiện của một nhân vật chính khác là đặc vụ John Doggett (Robert Patrick). Tới phiên mình, John Doggett lại nghi ngờ tính xác thực của các vụ án trong X-files và lúc này, chính đặc vụ Scully là người đã khiến cho John Doggett dần dần tin vào X-files</p>","tmdb":{"type":"tv","id":"4087","season":1,"vote_average":8.375,"vote_count":3432},"modified":"2023-01-30T05:36:34.000Z","cast":["David Duchovny","Gillian Anderson","Mitch Pileggi"],"director":[],"cast_meta":[{"name":"David Duchovny","name_vi":null,"name_original":"David Duchovny","tmdb_id":12640,"profile":"https://image.tmdb.org/t/p/w500/rZ2pEvu9IYsnHx3ElWUy4KgK3ia.jpg","tmdb_url":"https://www.themoviedb.org/person/12640"},{"name":"Gillian Anderson","name_vi":null,"name_original":"Gillian Anderson","tmdb_id":12214,"profile":"https://image.tmdb.org/t/p/w500/5emeOf49lM2WSs4rc186Wc9Zgs3.jpg","tmdb_url":"https://www.themoviedb.org/person/12214"},{"name":"Mitch Pileggi","name_vi":null,"name_original":"Mitch Pileggi","tmdb_id":12644,"profile":"https://image.tmdb.org/t/p/w500/ufAWo3HkALg96aEPPoY8C1YB5K7.jpg","tmdb_url":"https://www.themoviedb.org/person/12644"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/ho-so-tuyet-mat-phan-1.json"}