ữa hai người đã thay đổi từng chút một. Tuy nhiên, mỗi người đều có một bí mật không thể tiết lộ.</p>","tmdb":{"type":"tv","id":"94412","season":1,"vote_average":6.2,"vote_count":17},"modified":"2025-06-21T12:54:24.000Z","cast":["Madoka Shiga","Takahiro Sakurai","Yuma Uchida","Yuichi Iguchi","Kana Hanazawa","Masaya Matsukaze","Chiwa Saito","Chiaki Kano","Kaji Yuki","Eiji Takeuchi"],"director":[],"cast_meta":[{"name":"Madoka Shiga","name_vi":null,"name_original":"Madoka Shiga","tmdb_id":2551570,"profile":"https://image.tmdb.org/t/p/w500/tRFAt2fFQP4UqQHYiBFGR4OJdPL.jpg","tmdb_url":"https://www.themoviedb.org/person/2551570"},{"name":"Takahiro Sakurai","name_vi":null,"name_original":"Takahiro Sakurai","tmdb_id":9705,"profile":"https://image.tmdb.org/t/p/w500/8s8owcKmpRAuhzEGjSdRpztthUg.jpg","tmdb_url":"https://www.themoviedb.org/person/9705"},{"name":"Yuma Uchida","name_vi":null,"name_original":"Yuma Uchida","tmdb_id":1492992,"profile":"https://image.tmdb.org/t/p/w500/2otstbLfQ7MXuFt1X8MFOb4OIgd.jpg","tmdb_url":"https://www.themoviedb.org/person/1492992"},{"name":"Yuichi Iguchi","name_vi":null,"name_original":"Yuichi Iguchi","tmdb_id":1256078,"profile":"https://image.tmdb.org/t/p/w500/yYl2M7ou5X9d9BmNzsPYrrdPutC.jpg","tmdb_url":"https://www.themoviedb.org/person/1256078"},{"name":"Kana Hanazawa","name_vi":null,"name_original":"Kana Hanazawa","tmdb_id":119143,"profile":"https://image.tmdb.org/t/p/w500/9UTBlNRopSOKyoWnCm74tyHOfR1.jpg","tmdb_url":"https://www.themoviedb.org/person/119143"},{"name":"Masaya Matsukaze","name_vi":null,"name_original":"Masaya Matsukaze","tmdb_id":934841,"profile":"https://image.tmdb.org/t/p/w500/tUd3ybETFz4hBGLnaqt3VreGeDJ.jpg","tmdb_url":"https://www.themoviedb.org/person/934841"},{"name":"Chiwa Saito","name_vi":null,"name_original":"Chiwa Saito","tmdb_id":81245,"profile":"https://image.tmdb.org/t/p/w500/jxWuA4K0ZPkOQMeIgLlzaHSkgiV.jpg","tmdb_url":"https://www.themoviedb.org/person/81245"},{"name":"Chiaki Kano","name_vi":null,"name_original":