stream11.com/20230607/44397_d227df09/index.m3u8"},{"name":"36","slug":"36","filename":"Ho Tam 36","link_embed":"https://vip.opstream14.com/share/25315d7e8e32b1441d08e0663d3e3187","link_m3u8":"https://vip.opstream14.com/20230608/37390_31b4d126/index.m3u8"},{"name":"37","slug":"37","filename":"Ho Tam 37","link_embed":"https://vip.opstream14.com/share/f65f78d68a2ceb7d945bbf22399e6886","link_m3u8":"https://vip.opstream14.com/20230608/37391_ee301493/index.m3u8"},{"name":"38","slug":"38","filename":"Ho Tam 38","link_embed":"https://vip.opstream14.com/share/d470133ccf31f9bfdc1dcb45a30c73b1","link_m3u8":"https://vip.opstream14.com/20230609/37425_cffa23eb/index.m3u8"},{"name":"39","slug":"39","filename":"Ho Tm 39","link_embed":"https://vip.opstream14.com/share/0a8b2799af5e9b658b8fdb0558fc99c8","link_m3u8":"https://vip.opstream14.com/20230614/37703_2b9f8431/index.m3u8"},{"name":"40","slug":"40","filename":"Ho Tm 40","link_embed":"https://vip.opstream14.com/share/ec3b845037b384da387d9cd90cd03410","link_m3u8":"https://vip.opstream14.com/20230614/37704_10db740e/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><strong>Hộ Tâm </strong>kể về yêu long Thiên Diệu đem lòng yêu Tố Ảnh nhưng lại bị nàng ta phản bột, rút xương phong ấn ở nhiều nơi. Biết được ý đồ của Tố Ảnh, Thiên Diệu lột vảy hộ tâm, ném nội đan đi. Vảy hộ tâm và nội đan của Thiên Diệu rơi xuống trần gian, vô tình cứu giúp Nhạn Hồi. Nhạn Hồi cũng vô tình mà giúp hắn phá vỡ 1 phần phong ấn, giải thoát linh hồn. Thế rồi Nhạn Hồi và Thiên Diệu gặp nhau. Thiên Diệu biết được vảy hộ tâm và nội đan của hắn đang ở trên người Nhạn Hồi nên một mực bám lấy nàng, bày mưu tính kế để nàng giúp mình, coi nàng là quân cờ trong đại nghiệp phục thù. Nhưng hắn đâu ngờ, bản thân lại đánh rơi trái tim nơi nàng mất rồi. Câu chuyện giữa Nhạn Hồi và Thiên Diệu sẽ tiếp tục ra sao?</p>","tmdb":{"type":"tv","id":"146393","season":1,"vote_average":7.4,"vote_count":18},"modified":"2023-06-14T13:21:03.000Z","cast":["Hầu Minh Hạo","Châu Dã","V