1/3656_d0024557/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream17.com/share/a22d33b4a00c165507a61f3bed4b5149","link_m3u8":"https://vip.opstream17.com/20240401/3657_be1f836e/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream17.com/share/30a237d18c50f563cba4531f1db44acf","link_m3u8":"https://vip.opstream17.com/20240401/3658_7366cbc1/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream17.com/share/07845cd9aefa6cde3f8926d25138a3a2","link_m3u8":"https://vip.opstream17.com/20240401/3659_1b927432/index.m3u8"}]}],"description":"Tại thành Hoà Dương nhuốm đầy tội ác, Phan Việt - mỹ nam được vô số thiếu nữ yêu mến, kết hôn cùng người mà ai nấy đều ghét bỏ, Dương Thái Vi. Vào ngày đại hôn, Dương Thái Vi bị giết hại, nghi phạm lại chính là Phan Việt. Sau khi \"từ cõi chết trở về\", Dương Thái Vi trở lại đầy mạnh mẽ dưới vỏ bọc \"ác nữ\" Thượng Quan Chỉ, quyết tâm vạch trần bộ mặt thật của Phan Việt. Trong quá trình chiến đấu chống lại thế lực tà ác \"tứ đại gia tộc\" và điều tra các vụ án cũ, hai trái tim sát lại gần nhau. Dương Thái Vi phát hiện thủ phạm thực sự giết hại mình là một người khác, còn Phan Việt từ đầu đến cuối vẫn luôn yêu cô sâu đậm. Khi mọi chuyện sắp viên mãn, kẻ đứng sau một lần nữa lại giăng bẫy, đẩy hai người vào tình cảnh vạn kiếp bất phục.","tmdb_id":235619,"cast":["Cúc Tịnh Y","Lưu Học Nghĩa","Ngô Giai Di","Lý Ca Dương","Zheng Hehuizi","Trương Duệ","Tất Bồi Hâm","Ding Jie","Liu Jinyan","Zhong Weihua","Fan Jinlun","Han Qiuchi","Sun Zhenglin","Hu Kun","Li Peiming"],"director":["Zhong Qing"],"keywords":[],"tmdb":{"type":"tv","id":"235619","season":1,"vote_average":7.3,"vote_count":11},"cast_meta":[{"name":"Cúc Tịnh Y","name_vi":"Cúc Tịnh Y","name_original":"Ju Jingyi","tmdb_id":1686990,"profile":"https://image.tmdb.org/t/p/w500/xbyH30PEsDMFf1JP3BNYCegkDLP.jpg","tmdb_url":"https://www.themoviedb.org/person/1686990"},{"name":"Lưu Học Nghĩa","name_vi":"Lưu Học Nghĩa","name_original":"Liu Xueyi",