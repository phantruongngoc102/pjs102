share/efb88ef6f3e9cdbf53594b15a1a12a46","link_m3u8":"https://vip.opstream16.com/20240111/40562_8dd3c915/index.m3u8"},{"name":"51","slug":"51","link_embed":"https://vip.opstream16.com/share/237e1e31a05605c3f1479ad59291dd5c","link_m3u8":"https://vip.opstream16.com/20240111/40563_203e62e4/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream16.com/share/53cb0470c05936f8800ec95d9caaecaf","link_m3u8":"https://vip.opstream16.com/20240111/40564_7c95bba0/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream16.com/share/943f4aebfcf2904d5f2cfb5fc7fc5cf6","link_m3u8":"https://vip.opstream16.com/20240111/40565_16cb23ac/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream16.com/share/b5464187e768a1db895e5df954d66a04","link_m3u8":"https://vip.opstream16.com/20240111/40566_7512bbfd/index.m3u8"}]}],"description":"<p>“Bất lương nhân” tiếp nối sự thành công vô cùng đáng nể của “Hiệp lam”, là một tác phẩm hoạt hình võ hiệp 3D khác nữa của công ti trách nhiệm hữu hạn kĩ thuật số Bắc Kinh Nhược Thâm.”Bất lương nhân” sử dụng giọng văn và cách miêu tả chiến loạn liên miên, sự đen tối của thời kì ngũ đại thập quốc vô cùng độc đáo. Các sự kiện lịch sử và truyền thuyết lưu truyền trong dân gian như khởi nghĩa Hoàng Sào, Chu Ôn soán vị, Lý thị bị diệt tộc, Hữu Khuê giết cha, Sa Đà tranh bá được lồng ghép và xuyên suốt cả bộ phim. Các diễn viên chính cùng các vị anh hùng giương kiếm xông pha nơi giang hồ, đồng thời cũng nếm trải bao biến động, bao đổi thay, bao sóng gió giữa tuổi thanh xuân và tình yêu, giữa bội phản và lòng trung thành trong dòng xoáy lịch sử. Và rồi họ trở thành sức mạnh chủ chốt, đặt dấu chấm hết cho một thời kì rối ren, mở ra một kỉ nguyên hoàn toàn mới, đồng thời cũng viết nên trang sử rực rỡ của võ hiệp Trung Quốc.Bắc Kinh Nhược Thâm cho biết, sở dĩ bộ phim hoạt hình 3D này lấy tên là “Họa giang hồ chi bất lương nhân” là bởi bối cảnh phim diễn ra trong những năm cuối thời nhà Đường. Câu chuyện luôn xoay quanh kho báu khổng lồ mà tổ chức Bất lương nhân đã cất giấu, vậy nên tổ sản xuất đã lựa chọn cái tên này, nhằm giúp độc giả có một cái nhìn khách quan nhất cho bộ phim.</p>","tmdb_id":83463,"cast":["Jiang Bian","Mengmeng Yan","Zhao Yi","Qiuxiang Shen","Jun Chu","Shuren Zhao","Bai Xuecen","Lu Zhixing"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"83463","season":1,"vote_average":8.526,"vote_count":19},"cast_meta":[{"name":"Jiang Bian","name_vi":null,"name_original":"Jiang Bian","tmdb_id":2580344,"profile":"https://image.tmdb.org/t/p/w500/udyiTMO6F4pb5JgPO4U9bxtHWZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2580344"},{"name":"Mengmeng Yan","name_vi":null,"name_original":"Mengmeng Yan","tmdb_id":2866411,"profile":"https://image.tmdb.org/t/p/w500/cWGq8HreufQmsNXvrrEDJaavL9G.jpg","tmdb_url":"https://www.themoviedb.org/person/2866411"},{"name":"Zhao Yi","name_vi":null,"name_original":"Zhao Yi","tmdb_id":2199291,"profile":"https://image.tmdb.org/t/p/w500/c35JU0PEZscEHCpOUabFp3EHcpo.jpg","tmdb_url":"https://www.themoviedb.org/person/2199291"},{"name":"Qiuxiang Shen","name_vi":null,"name_original":"Qiuxiang Shen","tmdb_id":2165995,"profile":"https://image.tmdb.org/t/p/w500/iIPbklLu2SHQbVJ603pCNv2GaT7.jpg","tmdb_url":"https://www.themoviedb.org/person/2165995"},{"name":"Jun Chu","name_vi":null,"name_original":"Jun Chu","tmdb_id":2129157,"profile":"https://image.tmdb.org/t/p/w500/nLpYGEAmJrGckMCzd3yStHZJmgY.jpg","tmdb_url":"https://www.themoviedb.org/person/2129157"},{"name":"Shuren Zhao","name_vi":null,"name_original":"Shuren Zhao","tmdb_id":2129169,"profile":"https://image.tmdb.org/t/p/w500/huWlYphNa12UM5PVdorcNbdKy03.jpg","tmdb_url":"https://www.themoviedb.org/person/2129169"},{"name":"Bai Xuecen","name_vi":null,"name_original":"Bai Xuecen","tmdb_id":2866415,"profile":"https://image.tmdb.org/t/p/w500/hU7V64dz0qruxptwUeLQnkJiMcD.jpg","tmdb_url":"https://www.themoviedb.org/person/2866415"},{"name":"Lu Zhixing","name_vi":null,"name_original":"Lu Zhixing","tmdb_id":1965