d":"https://vip.opstream16.com/share/7c8616cf86f6ca71e8189ff8d544d5ac","link_m3u8":"https://vip.opstream16.com/20240111/40506_14b0baca/index.m3u8"},{"name":"5","slug":"5","link_embed":"https://vip.opstream16.com/share/6d09e77eaed6a2162027587f5026efe7","link_m3u8":"https://vip.opstream16.com/20240111/40507_18d82acc/index.m3u8"},{"name":"6","slug":"6","link_embed":"https://vip.opstream16.com/share/c9853b7f3e79b470ccdafbb73b8f5dad","link_m3u8":"https://vip.opstream16.com/20240111/40508_e92cf3d1/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream16.com/share/65f4d68a152bcdfb558e48afafe24a0a","link_m3u8":"https://vip.opstream16.com/20240111/40509_0ec4c113/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream16.com/share/27fb595d8f04cae613c7bd573b930a64","link_m3u8":"https://vip.opstream16.com/20240111/40510_4f0c4353/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream16.com/share/3ca498a36de1c5eb1c2d01f80341383a","link_m3u8":"https://vip.opstream16.com/20240111/40511_2fc88344/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream16.com/share/845803d7964d4fe814b629e902e01f40","link_m3u8":"https://vip.opstream16.com/20240111/40512_1a2bea4e/index.m3u8"}]}],"description":"<p>Sau phần đầu tiên hết sức thành công được ra mắt vào năm 2014, một phần mới cũng được phát hành vào năm 2015 với 40 tập và kéo dài đến năm 2016, tuy nhiên nó không phải là phần nội dung kế tiếp nên khán giả vẫn còn rất mong chờ một phiên bản viết tiếp nội dung của Họa Giang Hồ Chi Bất Lương Nhân PHIÊN BẢN năm 2014, thật tuyệt vời khi người xem không phải chờ đợi lâu và chỉ ngay sau khi kết thúc Chi Linh Chủ thì Họa Giang Hồ Chi Bất Lương Nhân 2 được lên sóng với hứa hẹn mang tới những cậu chuyện hấp dẫn mới mẻ cùng sự đột phá cả về nội dung lẫn đồ họa hình ảnh. Kết thúc ở phần 1 tạm khép lại những cuộc chiến Lý Tinh Vân cùng nhiều thế lực đen tối cũng như môn phái tham lam Long Tuyền kiếm, đồng thời anh chàng cũng có được cho mình một cô nàng người yêu xinh đẹp thì ở Họa Giang Hồ Chi Bất Lương Nhân Phần 2 sẽ là những cuộc chiến mới, cuộc chơi mới với những đối thủ khó nhằn hơn rất nhiều. Từ Chu Hữu Trình, Chung Tiểu Qùy cho tới Chung Tâm Ma, Lý Tồn Húc của 2 quốc gia khác nhau đều muốn có được Long Tuyền kiếm để trị vì thiên hạ bởi chúng tin rằng nhờ vào nó sẽ giúp đánh đâu thắng đấy và không có bất cứ một nước nào dám bén mảng xâm lược. Thử thách đối với Lý Tinh Vân lúc này sẽ là lớn hơn rất nhiều cùng với nhiều kẻ thù mới đang truy sát anh chỉ để giành lấy thanh bảo kiếm. Trong khi anh chàng ngày càng đào hoa với những cuộc hành trình mới thì không biết rằng nhiều nguy hiểm đang chờ cậu ta ở phía trước. Liệu rằng ở Chi Bất Lương Nhân 2, Lý Tinh Vân có tiếp tục bảo vệ được Long Tuyền kiếm và chống chọi lại được với rất nhiều kẻ thù ngày càng mạnh hơn với tầm vóc của cả một quốc gia hay không, chuyện tình cảm của anh chàng này sẽ đi đến đâu</p>","tmdb_id":83463,"cast":["Jiang Bian","Mengmeng Yan","Zhao Yi","Qiuxiang Shen","Jun Chu","Shuren Zhao","Bai Xuecen","Lu Zhixing"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"83463","season":2,"vote_average":8.526,"vote_count":19},"cast_meta":[{"name":"Jiang Bian","name_vi":null,"name_original":"Jiang Bian","tmdb_id":2580344,"profile":"https://image.tmdb.org/t/p/w500/udyiTMO6F4pb5JgPO4U9bxtHWZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2580344"},{"name":"Mengmeng Yan","name_vi":null,"name_original":"Mengmeng Yan","tmdb_id":2866411,"profile":"https://image.tmdb.org/t/p/w500/cWGq8HreufQmsNXvrrEDJaavL9G.jpg","tmdb_url":"https://www.themoviedb.org/person/2866411"},{"name":"Zhao Yi","name_vi":null,"name_original":"Zhao Yi","tmdb_id":2199291,"profile":"https://image.tmdb.org/t/p/w500/c35JU0PEZscEHCpOUabFp3EHcpo.jpg","tmdb_url":"https://www.themoviedb.org/person/2199291"},{"name":"Qiuxiang Shen","name_vi":null,"name_original":"Qiuxiang Shen","tmdb_id":2165995,"profile":"https://image.tmdb.org/t/p/w500/iIPbklLu2SHQbVJ603pCNv2GaT7.jpg","tmdb_url"