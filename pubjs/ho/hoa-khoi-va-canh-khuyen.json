9a60c7f0/index.m3u8"},{"name":"44","slug":"44","filename":"hoa-khoi-va-canh-khuyen-long-tieng-police-beauty-k9-tap-44","link_embed":"https://vip.opstream10.com/share/20c217bfdcfb3cd86113244ac8a461fc","link_m3u8":"https://vip.opstream10.com/20220519/15525_6b9715cb/index.m3u8"}]}],"time":"","description":"<p>Là bộ phim của về nhiệt huyết của tuổi thanh xuân trong môi trường cảnh sát của đạo diễn Cốc Cẩm Vân, làm việc với nhau vì chung hoài bão, cùng mơ ước.Bộ phim nói về Lý Thù Hàn, Nghê Na, Đường Ưu Ưu đại diễn cho hơn 90 nữa cảnh sát, cùng với sự hỗ trợ về thể xác và tinh thần của cảnh khuyển, bắt tội phạm. Lý Thù Hàn và Nghê Na và Đường Ưu Ưu là ba cô gái xinh đẹp tài năng được chuyển từ nhiều tổ khác nhau đến tổ chuyên án. Lý Thù Hàn được mệnh danh là “ siêu trí tuệ”, cô có khả năng nhìn một lần và nhớ được cấu trúc của mọi vật. Nghê Na là thiên tài ngoại ngữ, tinh thông 9 thứ tiếng khác nhau. Đường Ưu Ưu với sở trường lái xe và tính tình hoạt bát. Ba người họ khi kết hợp với nhau dưới sự chỉ huy của siêu trí tuệ Lý Thù Hàn sẽ ra sao? Liệu có thuận lợi phá án hay do những mâu thuẫn nhỏ xung quanh ba người mà khiến vụ án đi vào bế tắc?</p>","tmdb":{"type":"tv","id":"154232","season":1,"vote_average":0,"vote_count":1},"modified":"2022-05-20T07:28:38.000Z","cast":["Hạ Phạm","Hầu Mộng Toa","Hoàng Mộng Oánh"],"director":["Cốc Cảnh Vân"],"cast_meta":[{"name":"Hạ Phạm","name_vi":null,"name_original":"Hạ Phạm"},{"name":"Hầu Mộng Toa","name_vi":null,"name_original":"Hầu Mộng Toa"},{"name":"Hoàng Mộng Oánh","name_vi":null,"name_original":"Hoàng Mộng Oánh"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hoa-khoi-va-canh-khuyen.json"}