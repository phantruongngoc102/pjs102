 bế tắc?</p>","tmdb_id":154232,"cast":["Vu Hòa Vỹ","Hou Meng Sha","Hoàng Mộng Oánh","金美伶","Cui Kefa","Ding Haifeng","夏凡","王浩钩","刘金龙"],"director":["Cốc Cảnh Vân"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"154232","season":1,"vote_average":0,"vote_count":1},"cast_meta":[{"name":"Vu Hòa Vỹ","name_vi":"Vu Hòa Vỹ","name_original":"Yu Hewei","tmdb_id":1344903,"profile":"https://image.tmdb.org/t/p/w500/rtHbXVr0NUWYkV1vqCCdhgyyNXG.jpg","tmdb_url":"https://www.themoviedb.org/person/1344903"},{"name":"Hou Meng Sha","name_vi":null,"name_original":"Hou Meng Sha","tmdb_id":2080702,"profile":"https://image.tmdb.org/t/p/w500/iZwf73OS0jrqVw1bbrEclJYFdy8.jpg","tmdb_url":"https://www.themoviedb.org/person/2080702"},{"name":"Hoàng Mộng Oánh","name_vi":"Hoàng Mộng Oánh","name_original":"Maggie Huang","tmdb_id":1777095,"profile":"https://image.tmdb.org/t/p/w500/ePUdPVMnJWPV6TVBYRYrTaM6iAB.jpg","tmdb_url":"https://www.themoviedb.org/person/1777095"},{"name":"金美伶","name_vi":null,"name_original":"金美伶","tmdb_id":2732888,"profile":"https://image.tmdb.org/t/p/w500/j7cUTNOI5BiPIT5g3a857PttiD1.jpg","tmdb_url":"https://www.themoviedb.org/person/2732888"},{"name":"Cui Kefa","name_vi":null,"name_original":"Cui Kefa","tmdb_id":2079217,"profile":"https://image.tmdb.org/t/p/w500/vcCyfKV8DShyU2If368Sbck24Gw.jpg","tmdb_url":"https://www.themoviedb.org/person/2079217"},{"name":"Ding Haifeng","name_vi":null,"name_original":"Ding Haifeng","tmdb_id":1616830,"profile":"https://image.tmdb.org/t/p/w500/jEWAJOEPJBZxKmN26KtO5843oGv.jpg","tmdb_url":"https://www.themoviedb.org/person/1616830"},{"name":"夏凡","name_vi":null,"name_original":"夏凡","tmdb_id":5482596,"profile":"https://image.tmdb.org/t/p/w500/iLdcBA64c9h2Gov4umkPwcoMIBF.jpg","tmdb_url":"https://www.themoviedb.org/person/5482596"},{"name":"王浩钩","name_vi":null,"name_original":"王浩钩","tmdb_id":5482598,"profile":"https://image.tmdb.org/t/p/w500/7NVydAipk51PzlBEPKgIJB825Dg.jpg","tmdb_url":"https://www.themoviedb.org/person/5482598"},{"name":"刘金龙","name