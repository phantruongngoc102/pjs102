/share/cf91d0f049abb639ff8b0c5873e9f4e1","link_m3u8":"https://vip.opstream14.com/20230228/33072_0b3edc7b/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim kể về quá trình học hỏi, yêu đương và trưởng thành của cô gái mang bệnh Hà Nhiễm ở giai đoạn cuối cùng của cuộc đời. Sau khi gặp Tiêu Hàn, một thợ làm vườn nghệ thuật khó buông bỏ quá khứ và gần như mất niềm tin vào tương lai. Hai người họ đã trải qua những cuộc gặp gỡ bất đắc dĩ nhưng lãng mạn, từ đó tìm lại được những điều mất mát quan trọng nhất trong cuộc đời của mình, tìm nhặt lại được niềm tin và hy vọng với cuộc sống cũng như có được tình yêu khắc cốt ghi tâm.</p>","tmdb":{"type":"tv","id":"220337","season":1,"vote_average":6,"vote_count":5},"modified":"2025-04-04T12:31:07.000Z","cast":["Ngôn Thừa Húc","Từ Nhược Hàm","Huỳnh Dịch","Mã Tư Siêu","Xiang Yu","Đường Tằng","Zhao Yuanyuan","Wu Yaheng","Wu Jing","Cady Yang","Yu Xinhe","Ada Wong Chi-Hom","Jin Le","Wang Xinyue","Zhang Naitian"],"director":["Trần Trụ Phi"],"cast_meta":[{"name":"Ngôn Thừa Húc","name_vi":"Ngôn Thừa Húc","name_original":"Jerry Yan","tmdb_id":1241103,"profile":"https://image.tmdb.org/t/p/w500/5ZoqL8FGlwqPX4IqFmlNGINN0wz.jpg","tmdb_url":"https://www.themoviedb.org/person/1241103"},{"name":"Từ Nhược Hàm","name_vi":"Từ Nhược Hàm","name_original":"Xu Ruohan","tmdb_id":2914051,"profile":"https://image.tmdb.org/t/p/w500/2STQEbzr74sOlJ4iGZLyWxsMenp.jpg","tmdb_url":"https://www.themoviedb.org/person/2914051"},{"name":"Huỳnh Dịch","name_vi":"Huỳnh Dịch","name_original":"Crystal Huang Yi","tmdb_id":589340,"profile":"https://image.tmdb.org/t/p/w500/bsAdYFdtDldL1FoHEvXMm2LxY46.jpg","tmdb_url":"https://www.themoviedb.org/person/589340"},{"name":"Mã Tư Siêu","name_vi":"Mã Tư Siêu","name_original":"Ma Sichao","tmdb_id":2638626,"profile":"https://image.tmdb.org/t/p/w500/xyMLF0ehbXOQpH0ibBCylrNKxlA.jpg","tmdb_url":"https://www.themoviedb.org/person/2638626"},{"name":"Xiang Yu","name_vi":null,"name_original":"Xiang Yu","tmdb_id":2036538,"profil