dex.m3u8"},{"name":"30","slug":"30","filename":"Hoa Nở Nhớ Trăng - Moonshine (Phát Song Song) - Tập 30","link_embed":"https://vip.opstream11.com/share/33bd1b801b3cf1b8eaf31d816bca2c95","link_m3u8":"https://vip.opstream11.com/20220411/13164_bbe3a44a/index.m3u8"},{"name":"31","slug":"31","filename":"Hoa Nở Nhớ Trăng - Moonshine (Phát Song Song) - Tập 31","link_embed":"https://vip.opstream11.com/share/d18b09180684862f5665e1932fdb54fb","link_m3u8":"https://vip.opstream11.com/20220411/13165_5adb3da5/index.m3u8"},{"name":"32","slug":"32","filename":"Hoa Nở Nhớ Trăng - Moonshine (Phát Song Song) - Tập 32","link_embed":"https://vip.opstream11.com/share/130e2cf22996c69455ee7589cc8fed8c","link_m3u8":"https://vip.opstream11.com/20220411/13166_ed3efce0/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>Hoa Nở Nhớ Trăng - Moonshine lấy bối cảnh ở thời đại Joseon trong một thời kỳ được đánh dấu bởi những luật cấm nghiêm ngặt nhất. Sự cấm đoán tạo ra những thách thức khác nhau cho những cư dân này: Thanh tra Nam Young từ Văn phòng Tổng Thanh tra, người đã rời quê hương của mình để đạt được danh tiếng ở Hanyang và khôi phục địa vị gia đình của mình; Kang Ro Seo, người phụ nữ quý tộc nhưng nghèo khó, người làm moonshine để giảm nợ; Thái tử Lee Pyo có xu hướng mở rộng các bức tường cung điện để tìm kiếm một vết nứt. Bộ ba này có một cuộc gặp gỡ định mệnh dẫn họ khám phá ra một kho rượu được giấu kín. Tiết lộ bí mật này có thể đồng nghĩa với cái chết.</p>","tmdb":{"type":"tv","id":"133439","season":1,"vote_average":6.1,"vote_count":26},"modified":"2022-05-22T08:41:06.000Z","cast":["Jennifer Finnigan","Anastasia Phillips","Emma Hunter","Tom Stevens","Alexander Nunez","Erin Darke","Farid Yazdani","James Gilbert","Corrine Koslo","Peter MacNeill","Allegra Fulton","Celia Owen","Calem MacDonald","Loretta Yu"],"director":["Kim Joo Hee"],"cast_meta":[{"name":"Jennifer Finnigan","name_vi":null,"name_original":"Jennifer Finnigan","tmdb_id":76095,"profile":"https://image.tmdb.org/t/p/w500/f3