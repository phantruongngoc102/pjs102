_f719416e/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream11.com/share/d4cd1a17f398e7b67e973a7efb510968","link_m3u8":"https://vip.opstream11.com/20240204/51278_534f7a26/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream11.com/share/806247394ef755e46009b2856ba64e9c","link_m3u8":"https://vip.opstream11.com/20240211/51451_132d840b/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream11.com/share/39eee5d086ad67250179d9be1a436c07","link_m3u8":"https://vip.opstream11.com/20240211/51450_b263da13/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream17.com/share/dd458505749b2941217ddd59394240e8","link_m3u8":"https://vip.opstream17.com/20240217/568_d0d7ef25/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream17.com/share/1efa39bcaec6f3900149160693694536","link_m3u8":"https://vip.opstream17.com/20240218/850_1fb38da9/index.m3u8"}]}],"description":"<p>Hoa Nở Về Đêm - Knight Flower kể về Cho Yeo Hwa, người phụ nữa đã góa chồng 15 năm. Cô là phu nhân trong một gia đình quý tộc danh giá nhất vùng. Ban ngày, cô sống rất lặng lẽ và không bao giờ tiếp xúc với bên ngoài. Cô thể hiện mình là một phu nhân rất chỉnh chu và có gia phép. Tuy nhiên, trong đêm, Cho Yeo Hwa đã lẻn ra ngoài và giúp đỡ những người có hoàn cảnh khó khăn. Trong thời gian này, cô đã vô tình gặp Soo Ho, một cảnh vệ trong thành, có ngoại hình ưa nhìn và rất ưu tú. Soo Ho luôn xuất hiện để giúp đỡ Yeo Hwa mỗi khi cô gặp khó khăn.</p><p>&nbsp;</p>","tmdb_id":220836,"cast":["Lee Hanee","Lee Jong-won","Kim Sang-joong","Jung Yong-ju","Lee Ki-woo","Park Se-hyun","Kim Mi-kyeong","Seo Yi-sook","Jo Jae-yun","Kim Kwang-kyu","Heo Jeong-do","Yoon Sa-bong","Kim Hyeong-mook","Woo Kang-min","Lee Woo-je"],"director":["Jang Tae-yoo"],"keywords":[],"tmdb":{"type":"tv","id":"220836","season":1,"vote_average":8.368,"vote_count":19},"cast_meta":[{"name":"Lee Hanee","name_vi":null,"name_original":"Lee Hanee","tmdb_id":1364528,"profile":"htt