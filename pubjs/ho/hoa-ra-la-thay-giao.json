0220408/8675_2965749f/index.m3u8"},{"name":"34","slug":"34","filename":"hoa-ra-la-thay-giao-tap-34","link_embed":"https://vip.opstream12.com/share/6ba5bc4fe4c3f704112d0ba94020f4c2","link_m3u8":"https://vip.opstream12.com/20220409/8852_d8f2c287/index.m3u8"},{"name":"35","slug":"35","filename":"hoa-ra-la-thay-giao-tap-35","link_embed":"https://vip.opstream12.com/share/84ca205fe6bc691c41c3bfe5a2820a15","link_m3u8":"https://vip.opstream12.com/20220409/8853_6ab08748/index.m3u8"},{"name":"36","slug":"36","filename":"hoa-ra-la-thay-giao-tap-36","link_embed":"https://vip.opstream12.com/share/bd6fd20524553da5f0504d31e4134500","link_m3u8":"https://vip.opstream12.com/20220409/8854_621aa080/index.m3u8"},{"name":"37","slug":"37","filename":"hoa-ra-la-thay-giao-tap-37","link_embed":"https://vip.opstream12.com/share/0527b1b41d984cd95100beff3605d26e","link_m3u8":"https://vip.opstream12.com/20220410/9478_3c786deb/index.m3u8"},{"name":"38","slug":"38","filename":"hoa-ra-la-thay-giao-tap-38","link_embed":"https://vip.opstream12.com/share/d35a29602005cb55aa57a5f683c8e0c2","link_m3u8":"https://vip.opstream12.com/20220410/9479_343d515a/index.m3u8"},{"name":"39","slug":"39","filename":"hoa-ra-la-thay-giao-tap-39","link_embed":"https://vip.opstream12.com/share/6f4b7fd3eea0af87f9990faa8e3287f1","link_m3u8":"https://vip.opstream12.com/20220410/9480_691fd3ee/index.m3u8"},{"name":"40","slug":"40","filename":"hoa-ra-la-thay-giao-tap-40","link_embed":"https://vip.opstream14.com/share/4206e38996fae4028a26d43b24f68d32","link_m3u8":"https://vip.opstream14.com/20220411/7134_8bcf845b/index.m3u8"}]}],"time":"43M21S","description":"<p>Hóa Ra Là Thầy Giáo xoay quay câu chuyện của Hướng Đông Nam, là một ca sĩ-nhạc sĩ tài năng, từng trở thành siêu sao một cách suôn sẻ sau khi bắt đầu sự nghiệp từ chương trình tuyển chọn nghệ sĩ. Nhưng 5 năm sau, anh ấy gặp khó trong quá trình sáng tác, không những vướng bê bối, mà còn bị nhiều người mắng cút khỏi giới giải trí bởi sự hiểm nhầm ăn cắp. Đã đến cùng đường, trợ lý Lâm Thanh hợp tác với hiệu trưởng trường trung học, mượn cớ chương trình thực tế đòi Hướng Đông Nam trở thành một thầy giáo. Sau được biết sự thật, Hướng Đông Nam đành phải để lại ở trường cũ của mình bởi khế ước tinh thần. Bởi vậy, siêu sao mắc nạn trở thành thầy chủ nhiệm của lớp nghệ thuật trong trường, lại bất ngờ trở thành bạn cùng phòng với cô tiếng Anh Tô Kỳ và thầy toán Trần Lục Tam. Khi siêu sao lười cực gặp gỡ người ham mê hồ sơ vừa nhiệt huyết vừa cố chấp, chuyện hài giữa các oan gia ùn ùn đến. Như thế, Hướng Đông Nam và các bạn lảo đảo trên đường, giúp học sinh tìm được bản thân mình trong các nỗi buồn trưởng thành và họ cũng được trưởng thành dần, cuối cùng tìm được tình yêu và hạnh phúc riêng mình.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2022-05-15T08:12:03.000Z","cast":["Cheney Chen","Karlina Zhang","Zhang Li","Vương Thụy Xương","Bian Cheng","Mễ Nhiệt","Zheng Fan Xing","Zidan Sun","Lưu Lâm","Liu Jun"],"director":[],"cast_meta":[{"name":"Cheney Chen","name_vi":null,"name_original":"Cheney Chen"},{"name":"Karlina Zhang","name_vi":null,"name_original":"Karlina Zhang"},{"name":"Zhang Li","name_vi":null,"name_original":"Zhang Li"},{"name":"Vương Thụy Xương","name_vi":null,"name_original":"Vương Thụy Xương"},{"name":"Bian Cheng","name_vi":null,"name_original":"Bian Cheng"},{"name":"Mễ Nhiệt","name_vi":null,"name_original":"Mễ Nhiệt"},{"name":"Zheng Fan Xing","name_vi":null,"name_original":"Zheng Fan Xing"},{"name":"Zidan Sun","name_vi":null,"name_original":"Zidan Sun"},{"name":"Lưu Lâm","name_vi":null,"name_original":"Lưu Lâm"},{"name":"Liu Jun","name_vi":null,"name_original":"Liu Jun"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hoa-ra-la-thay-giao.json"}