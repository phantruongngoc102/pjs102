0e/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream11.com/share/78853ecbfdcbfed58ed8483bf205990b","link_m3u8":"https://vip.opstream11.com/20220624/32461_c11bb8fc/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/899e0b68a9c29f71e128a380cbb0c64e","link_m3u8":"https://vip.opstream11.com/20220624/32462_e667ac36/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/17de7eb570312f4c297dc23606a0fedf","link_m3u8":"https://vip.opstream11.com/20220624/32463_5477ef29/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/0c9fd755f1e941587cabab631a81f89e","link_m3u8":"https://vip.opstream11.com/20220624/32464_2d286a87/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/0fd4fa8a47ec557c40cbbd0273d5083b","link_m3u8":"https://vip.opstream11.com/20220624/32465_a7e79db9/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream11.com/share/031a0d8b9f7e04e38eb55af2ca1550bd","link_m3u8":"https://vip.opstream11.com/20220624/32466_8658b147/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream11.com/share/6d6072ea730f062537e458a1e7d47e78","link_m3u8":"https://vip.opstream11.com/20220624/32467_509fa300/index.m3u8"}]}],"description":"<p>Hoàn Châu Cách Cách (Phần 1) xoay quanh cuộc đời của nàng công chúa Tiểu Yến Tử. Truyện phim khởi đầu từ chuyến lên kinh của Hạ Tử Vy để nhận lại người cha thất lạc nhiều năm là hoàng đế Càn Long. Trên đường lưu lạc, nàng gặp gỡ và kết thân với Tiểu Yến Tử. Đây là cô gái mồ côi từ nhỏ, lớn lên trong cô nhi viện, tính tình vui vẻ, không được học hành nhưng dũng cảm, nghĩa khí. Để giúp người chị em nhập cung, Tiểu Yến Tử đã liều mình tiếp cận Càn Long khi ông đang đi săn. Nàng bất ngờ bị trúng mũi tên của Ngũ A Ca và bị nhận nhầm là con của Càn Long, được sắc phong làm Hoàn Châu cách cách. Cô gái đầu đường xó chợ bắt đầu cuộc phiêu lưu kỳ thú nhưng cũng đầy nguy hiểm trong cung cấm.</p>","tmdb_id":4285,"cast":["Huỳnh Dịch","Ma Yili","Cổ Cự Cơ","Zhou Jie","Địch Long","Zhao Minfen","Huỳnh Hiểu Minh","Vương Diễm","Tưởng Cần Cần","Wen Haibo","Tần Lam","Liu Fang","Lưu Đào","Zang Jinsheng"],"director":["Tôn Thụ Bồi"],"keywords":[],"tmdb":{"type":"tv","id":"4285","season":1,"vote_average":7.674,"vote_count":43},"cast_meta":[{"name":"Huỳnh Dịch","name_vi":"Huỳnh Dịch","name_original":"Crystal Huang Yi","tmdb_id":589340,"profile":"https://image.tmdb.org/t/p/w500/bsAdYFdtDldL1FoHEvXMm2LxY46.jpg","tmdb_url":"https://www.themoviedb.org/person/589340"},{"name":"Ma Yili","name_vi":null,"name_original":"Ma Yili","tmdb_id":2314470,"profile":"https://image.tmdb.org/t/p/w500/77CNJGrpDJJVrU6r7rpEyD6LFVp.jpg","tmdb_url":"https://www.themoviedb.org/person/2314470"},{"name":"Cổ Cự Cơ","name_vi":"Cổ Cự Cơ","name_original":"Leo Ku","tmdb_id":1236321,"profile":"https://image.tmdb.org/t/p/w500/50hNaLKosRAqimtb9XUcrLv7kz.jpg","tmdb_url":"https://www.themoviedb.org/person/1236321"},{"name":"Zhou Jie","name_vi":null,"name_original":"Zhou Jie","tmdb_id":1236263,"profile":"https://image.tmdb.org/t/p/w500/nweQTbIHNjZrsQsXYJ5ONmupVh.jpg","tmdb_url":"https://www.themoviedb.org/person/1236263"},{"name":"Địch Long","name_vi":"Địch Long","name_original":"Ti Lung","tmdb_id":69636,"profile":"https://image.tmdb.org/t/p/w500/dxA5qEE0c6kKxoRJXttAwSooMSv.jpg","tmdb_url":"https://www.themoviedb.org/person/69636"},{"name":"Zhao Minfen","name_vi":null,"name_original":"Zhao Minfen","tmdb_id":3571758,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3571758"},{"name":"Huỳnh Hiểu Minh","name_vi":"Huỳnh Hiểu Minh","name_original":"Huang Xiaoming","tmdb_id":109434,"profile":"https://image.tmdb.org/t/p/w500/pnSbq1pNDb0uLkzGOJ8zy7piBvb.jpg","tmdb_url":"https://www.themoviedb.org/person/109434"},{"name":"Vương Diễm","name_vi":"Vương Diễm","name_original":"Wang Yan","tmdb_id":2041041,"profile":"https://image.tmdb.org/t/p/w500/tYdzpRs98LQ0qMZJgwl6FBnzzKZ.jpg","tmdb_url":"https://w