ex.m3u8"}]}],"time":"8 phút/tập","description":"<p>Hai chị em sinh đôi bị chia cắt sau khi cha mẹ ly hôn - một người được nuôi dưỡng trong nhung lụa, người kia làm việc chăm chỉ nhưng chật vật - vô tình đoàn tụ khi trưởng thành. Bằng cách hoán đổi danh tính, họ cố gắng giải quyết vấn đề của nhau và gây ảnh hưởng đến những người xung quanh, nhưng âm mưu của họ lại dẫn đến những hỗn loạn và rắc rối không ngờ.</p>","tmdb":{"type":"tv","id":"158253","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-03T13:24:55.000Z","cast":["Yan Kexin","Ren Yunjie","Miao Zenglei","Wang Zihao"],"director":[],"cast_meta":[{"name":"Yan Kexin","name_vi":null,"name_original":"Yan Kexin","tmdb_id":3437927,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3437927"},{"name":"Ren Yunjie","name_vi":null,"name_original":"Ren Yunjie","tmdb_id":3793267,"profile":"https://image.tmdb.org/t/p/w500/9yIMhFEvh2lEAqB4c9qImzS7kxx.jpg","tmdb_url":"https://www.themoviedb.org/person/3793267"},{"name":"Miao Zenglei","name_vi":null,"name_original":"Miao Zenglei","tmdb_id":3437929,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3437929"},{"name":"Wang Zihao","name_vi":null,"name_original":"Wang Zihao","tmdb_id":3437930,"profile":"https://image.tmdb.org/t/p/w500/vfKGot2050wLg8hhJ3usvQOtveT.jpg","tmdb_url":"https://www.themoviedb.org/person/3437930"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ho/hoan-doi-than-phan.json"}