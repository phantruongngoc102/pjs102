/index.m3u8"},{"name":"15","slug":"15","filename":"hoc-vien-mary-im-so-pretty-tap-15","link_embed":"https://vip.opstream15.com/share/0af62754d41faf4cabd69b68b2d0368f","link_m3u8":"https://vip.opstream15.com/20220512/13706_33fb02b1/index.m3u8"},{"name":"16","slug":"16","filename":"hoc-vien-mary-im-so-pretty-tap-16","link_embed":"https://vip.opstream15.com/share/74322d3ea58d8c6643c5508ae0a33af5","link_m3u8":"https://vip.opstream15.com/20220512/13707_f4f26615/index.m3u8"},{"name":"17","slug":"17","filename":"hoc-vien-mary-im-so-pretty-tap-17","link_embed":"https://vip.opstream15.com/share/a0f1a0686c4ecffbf795ea2d2a42817e","link_m3u8":"https://vip.opstream15.com/20220512/13708_313318f2/index.m3u8"},{"name":"18","slug":"18","filename":"hoc-vien-mary-im-so-pretty-tap-18","link_embed":"https://vip.opstream15.com/share/3f64b203421386156d5ef92c600045c6","link_m3u8":"https://vip.opstream15.com/20220512/13709_0a84c351/index.m3u8"},{"name":"19","slug":"19","filename":"hoc-vien-mary-im-so-pretty-tap-19","link_embed":"https://vip.opstream15.com/share/5456133e67453a4c86d63b50d1f8bc2e","link_m3u8":"https://vip.opstream15.com/20220512/13710_0de23892/index.m3u8"},{"name":"20","slug":"20","filename":"hoc-vien-mary-im-so-pretty-tap-20","link_embed":"https://vip.opstream15.com/share/e3537ccce7b6d7ed1b54f9a585985716","link_m3u8":"https://vip.opstream15.com/20220512/13711_ab52c163/index.m3u8"}]}],"time":"","description":"<p>Phim Học Viện Mary - I'm So Pretty 2019: Học viện Mary là ngôi trường mơ ước của tất cả cô gái yêu cái đẹp. Nguyên tắc sinh tồn ở Học viện Mary chính là “Nhan sắc là chính nghĩa, cái đẹp là sức chiến đấu”. Tại đây, tiêu chuẩn để đánh giá người thắng làm vua, kẻ thua làm giặc chính là kỹ thuật hóa trang. Trở thành người hóa trang đẹp nhất chính là mục tiêu phấn đấu và mơ ước của mỗi cô gái ở học viện Mary. Thiếu nữ trong sáng Tống Thi Dao không biết đến son phấn vô tình bị cuốn vào cuộc tranh đấu của học viện, cùng với Lâm Tịch, Tiêu Trúc và Hoàng Chính Vũ - nam sinh duy nhất trong trường thành lập nhóm hóa trang, cùng nhau khiêu chiến các cao thủ trong trường. Và từ đây cuộc chiến đấu đặc sắc chỉ vừa mới bắt đầu.</p>","tmdb":{"type":"tv","id":"88515","season":1,"vote_average":0,"vote_count":0},"modified":"2022-05-12T16:16:54.000Z","cast":["Tương Dục Vĩ","Phương Sở Đồng","Ngô Thụy Tùng"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Tương Dục Vĩ","name_vi":null,"name_original":"Tương Dục Vĩ"},{"name":"Phương Sở Đồng","name_vi":null,"name_original":"Phương Sở Đồng"},{"name":"Ngô Thụy Tùng","name_vi":null,"name_original":"Ngô Thụy Tùng"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hoc-vien-mary.json"}