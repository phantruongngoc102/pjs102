stream11.com/20240902/52340_968d84c5/index.m3u8"},{"name":"15","slug":"15","filename":"hoc vien anh hung - Ep153","link_embed":"https://vip.opstream11.com/share/4969491078041c2bf531039a0e3a9e02","link_m3u8":"https://vip.opstream11.com/20240902/52341_49694910/index.m3u8"},{"name":"16","slug":"16","filename":"hoc vien anh hung  - Ep154","link_embed":"https://vip.opstream11.com/share/2d9bbcc6d70c778a52789d13d8a1a00f","link_m3u8":"https://vip.opstream11.com/20240929/53941_2d9bbcc6/index.m3u8"},{"name":"17","slug":"17","filename":"hoc vien anh hung  - Ep155","link_embed":"https://vip.opstream11.com/share/da61dbfa824e2aaa6713f4faa33f4763","link_m3u8":"https://vip.opstream11.com/20240929/53942_da61dbfa/index.m3u8"},{"name":"18","slug":"18","filename":"hoc vien anh hung  - Ep156","link_embed":"https://vip.opstream11.com/share/755526611165c8134cb4c89c31a20c2b","link_m3u8":"https://vip.opstream11.com/20240929/53943_75552661/index.m3u8"},{"name":"19","slug":"19","filename":"hoc vien anh hung  - Ep157","link_embed":"https://vip.opstream11.com/share/592df05011dbe17b30b567033da30cb8","link_m3u8":"https://vip.opstream11.com/20240929/53944_592df050/index.m3u8"},{"name":"20","slug":"20","filename":"boku no hero 158","link_embed":"https://vip.opstream11.com/share/5e3440785572dfb138d7daa70ede079f","link_m3u8":"https://vip.opstream11.com/20241013/54782_5e344078/index.m3u8"},{"name":"21","slug":"21","filename":"boku no hero 159","link_embed":"https://vip.opstream11.com/share/dd6dba44b38c71ce3a24383574a491ec","link_m3u8":"https://vip.opstream11.com/20241013/54783_dd6dba44/index.m3u8"}]}],"time":"24 phút/tập","description":"Chuyển thể từ manga cùng tên của tác giả Horikoshi Kohei. Bối cảnh tương lai, 80% dân số thế giới sở hữu siêu năng lực, anh hùng là một nghề nghiệp phát triển mạnh mẽ. Đây là câu chuyện về Midoriya Izuku (Deku) một cậu nhóc với niềm ngưỡng mộ anh hùng mãnh liệt. Người Deku thần tượng nhất chính là All Might – anh hùng vĩ đại nhất thế giới. Cậu muốn trở thành anh hùng như All Might để bảo vệ và cứu giúp mọi người. Nhưng Hiện thực đau đớn đã dẫm nát giấc mơ của cậu, Deku chỉ là một người bình thường, luôn bị bắt nạt vì không có siêu năng lực. Cứ tưởng chừng ước mơ là không thể thực hiện cho đến ngày Deku gặp gỡ All Might, được ngài ấy ban cho năng lực \"One for All\". Chính thức trở thành học viên của \"Học viện U.A\" - học viện siêu anh hùng hàng đầu tại Nhật Bản. Con đường từ một kẻ bất tài trở thành một siêu anh hùng bắt đầu!","tmdb":{"type":"tv","id":"65930","season":7,"vote_average":8.62,"vote_count":5182},"modified":"2024-10-13T19:54:07.000Z","cast":["Daiki Yamashita"],"director":[],"cast_meta":[{"name":"Daiki Yamashita","name_vi":null,"name_original":"Daiki Yamashita","tmdb_id":1325962,"profile":"https://image.tmdb.org/t/p/w500/rQNdJdZewk7VGP16ZNbpfJ9ZeMd.jpg","tmdb_url":"https://www.themoviedb.org/person/1325962"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hoc-vien-sieu-anh-hung-phan-7.json"}