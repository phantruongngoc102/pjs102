108/17157_c9fa5a72/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream90.com/share/54a6299f9bc0e98a0b01b8364b4bc0af","link_m3u8":"https://vip.opstream90.com/20251115/17759_54a6299f/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream90.com/share/702e52be319c9b692e5225702830df04","link_m3u8":"https://vip.opstream90.com/20251122/18273_702e52be/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream17.com/share/d63cc273ce120d9294c13a73a8aac01a","link_m3u8":"https://vip.opstream17.com/20251129/24445_d63cc273/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream90.com/share/038a237670b78d07d7e5fd9092e82bdd","link_m3u8":"https://vip.opstream90.com/20251206/19404_038a2376/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream90.com/share/c19dc3cf9b0ced13099cc512d5ccaec4","link_m3u8":"https://vip.opstream90.com/20251213/20044_c19dc3cf/index.m3u8"}]}],"description":"<p>Chuyển thể từ manga cùng tên của tác giả Horikoshi Kohei. Bối cảnh tương lai, 80% dân số thế giới sở hữu siêu năng lực, anh hùng là một nghề nghiệp phát triển mạnh mẽ. Đây là câu chuyện về Midoriya Izuku (Deku) một cậu nhóc với niềm ngưỡng mộ anh hùng mãnh liệt. Người Deku thần tượng nhất chính là All Might – anh hùng vĩ đại nhất thế giới. Cậu muốn trở thành anh hùng như All Might để bảo vệ và cứu giúp mọi người. Nhưng Hiện thực đau đớn đã dẫm nát giấc mơ của cậu, Deku chỉ là một người bình thường, luôn bị bắt nạt vì không có siêu năng lực. Cứ tưởng chừng ước mơ là không thể thực hiện cho đến ngày Deku gặp gỡ All Might, được ngài ấy ban cho năng lực \"One for All\". Chính thức trở thành học viên của \"Học viện U.A\" - học viện siêu anh hùng hàng đầu tại Nhật Bản. Con đường từ một kẻ bất tài trở thành một siêu anh hùng bắt đầu!</p>","tmdb_id":65930,"cast":["Daiki Yamashita"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"65930","season":8,"vote_average":8.62,"vote_count":5182},"cast_meta":[{"name":"Daiki Yamashita","