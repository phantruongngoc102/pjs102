p.opstream16.com/share/34547f7d214265ed715e40b7e2866272","link_m3u8":"https://vip.opstream16.com/20230222/32080_a0971791/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/c3a83e015935188821aa9ee65e6b322f","link_m3u8":"https://vip.opstream16.com/20230222/32081_f87a80f4/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/8ea38887f092b8d42ab30baf36bc70e5","link_m3u8":"https://vip.opstream16.com/20230222/32082_b673143b/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream16.com/share/d34250a7e859a05bb6a18edcc70564d8","link_m3u8":"https://vip.opstream16.com/20230222/32083_717693db/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream16.com/share/0f0671779c244dbf8ee04425ad06a093","link_m3u8":"https://vip.opstream16.com/20230222/32084_d35c7bc1/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream16.com/share/5f9491903a313d3a99f8f9bb101d1b89","link_m3u8":"https://vip.opstream16.com/20230228/32338_51adc9c3/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream16.com/share/63b86b88a630f503d6508ebea2945200","link_m3u8":"https://vip.opstream16.com/20230228/32339_a24ee033/index.m3u8"}]}],"description":"<p>Phim kể về câu chuyện vườn trường của nữ sinh viên đại học thời hiện đại bất ngờ xuyên không vào một thư viện cổ đại. Nữ chính Ngô Hoàn Hoàn giả làm nam nhân vào thư viện học tập và những câu chuyện dở khóc dở cười của nàng cùng những người bạn học cùng như Đường Văn Khởi, Kỳ Thiệm. Cùng với đó, họ chung tay cố gắng nỗ lực, cùng thay đổi vấn đề nhức nhối thời cổ đại, chính là phân chia giáo dục không đồng đều. Họ dũng cảm chống lại quan niệm bất công thời cổ đại, cùng xây dựng nên trường học riêng, không kỳ thị dòng dõi, thậm chí còn nhận cả nữ tử vào trường học mà không nhận bất cứ chi phí gì, chỉ với một mục đích đó là ai ai cũng có thể đi học. Cho dù trong quá trình đó có rất nhiều trở ngại nhưng họ đều khắc phục được, cuối cùng mọi người đều bị họ làm cảm động. Cách làm của họ được dần được công nhận, đồng thời đã thành công đưa tư tưởng giáo dục hiện đại vào thư viện thời cổ đại.</p>","tmdb_id":221479,"cast":["Wang Yajia","Thừa Lũy","Chen Huan","Canti Lau Sek-Ming","Wu Bowei"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"221479","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Wang Yajia","name_vi":null,"name_original":"Wang Yajia","tmdb_id":4120132,"profile":"https://image.tmdb.org/t/p/w500/lmSbBxbedHZFLDpCRpEzm4ntzqq.jpg","tmdb_url":"https://www.themoviedb.org/person/4120132"},{"name":"Thừa Lũy","name_vi":"Thừa Lũy","name_original":"Ryan Cheng","tmdb_id":3093089,"profile":"https://image.tmdb.org/t/p/w500/mN45mgpV6TkttOt7zOIGv2u3H0S.jpg","tmdb_url":"https://www.themoviedb.org/person/3093089"},{"name":"Chen Huan","name_vi":null,"name_original":"Chen Huan","tmdb_id":4357478,"profile":"https://image.tmdb.org/t/p/w500/jFG1ZQUaueSII06b20pQY4O2aJ6.jpg","tmdb_url":"https://www.themoviedb.org/person/4357478"},{"name":"Canti Lau Sek-Ming","name_vi":null,"name_original":"Canti Lau Sek-Ming","tmdb_id":1118407,"profile":"https://image.tmdb.org/t/p/w500/8W7DzkYAK75tdTevSvY15pd3RZe.jpg","tmdb_url":"https://www.themoviedb.org/person/1118407"},{"name":"Wu Bowei","name_vi":null,"name_original":"Wu Bowei","tmdb_id":4859650,"profile":"https://image.tmdb.org/t/p/w500/cW0zjQR42XmaZnrwSY2UEBunXNN.jpg","tmdb_url":"https://www.themoviedb.org/person/4859650"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ho/hoc-vien-tren-nui-coc-vien.json"}