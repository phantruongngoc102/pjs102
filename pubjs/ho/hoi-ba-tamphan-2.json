k_embed":"https://vip.opstream15.com/share/49490f256a90aff2c2c4e151515fe241","link_m3u8":"https://vip.opstream15.com/20230822/41507_4e1474d1/index.m3u8"},{"name":"24","slug":"24","filename":"Hội bà tám_season 02_episode 24","link_embed":"https://vip.opstream15.com/share/1404d2d16ab402e5a4b412400ebb2307","link_m3u8":"https://vip.opstream15.com/20230822/41508_3fbfda52/index.m3u8"},{"name":"25","slug":"25","filename":"Hội bà tám_season 02_episode 25","link_embed":"https://vip.opstream15.com/share/08754c54ce88de6711c97623a7c276b6","link_m3u8":"https://vip.opstream15.com/20230822/41509_1c7dc421/index.m3u8"}]}],"time":"42 phút/tập","description":"<p>Tình dục, dối trá và bê bối không bao giờ có ngày nghỉ. Có tin đồn là nhiệt độ bắt đầu tăng cao giữa Nate và Serena, người đã trốn đến Hamptons vào mùa hè sau khi chia tay với Lonely Boy. Khi mùa hè sắp kết thúc, Blair trở về từ nước ngoài cùng với một chàng trai nóng bỏng trong tay và Dan, người đã dành cả mùa hè để giúp đỡ một tác giả nổi tiếng, quyết định đến Hamptons. Sau đó, mọi người trở lại thành phố để học năm cuối. Việc đăng ký vào đại học chỉ là một phần nhỏ của câu chuyện khi những mối tình lãng mạn mới (và một số mối tình không quá mới) nảy nở rồi phai nhạt, những vụ bê bối nổ ra liên tục và các liên minh thậm chí còn thay đổi nhanh hơn mức mà Gossip Girl có thể gửi thông tin cập nhật.</p>","tmdb":{"type":"tv","id":"1395","season":2,"vote_average":8.181,"vote_count":2260},"modified":"2023-08-23T13:20:30.000Z","cast":["Blake Lively","Leighton Meester","Penn Badgley","Chace Crawford","Ed Westwick","Kaylee DeFer","Matthew Settle","Kelly Rutherford"],"director":[],"cast_meta":[{"name":"Blake Lively","name_vi":null,"name_original":"Blake Lively","tmdb_id":59175,"profile":"https://image.tmdb.org/t/p/w500/rkGVjd6wImtgjOCi0IpeffdEWtb.jpg","tmdb_url":"https://www.themoviedb.org/person/59175"},{"name":"Leighton Meester","name_vi":null,"name_original":"Leighton Meester","tmdb_id":85825,"profile":"https://image.tmdb.or