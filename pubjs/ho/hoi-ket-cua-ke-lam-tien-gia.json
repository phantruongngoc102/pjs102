12c7db27fe3488c1918a","link_m3u8":"https://vip.opstream15.com/20230324/36045_91a60123/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Thành phố Ly Sơn xuất hiện 1 loại “tiền giả cao cấp” có thể trót lọt thông qua máy kiểm tra tiền giả. Đội trưởng đội cảnh sát hình sự Tề Thiên cùng 2 cấp dưới của mình là Tiểu Nguỵ và Tương Bắc phụ trách điều tra vụ án này. Tổ chuyên án lần theo từng manh mối của bọn tội phạm, ép chúng phải lộ diện từng tên một. Nhưng những tên tội phạm này, kẻ thì đã chết một cách kì lạ trước khi bị bắt, kẻ thì hoàn toàn biến mất không chút tông tích nào.</p>","tmdb":{"type":"tv","id":"95958","season":1,"vote_average":0,"vote_count":0},"modified":"2023-03-24T09:33:31.000Z","cast":["Wu You","Li Zhuoyang","Wang Ting","Hao Ping","Trương Thần Quang","Gao Yufei","Gong Haibin","Ren Youlun","Yi Zhen","Guo Dongwen","Yi Yunhe"],"director":["gaoxiang"],"cast_meta":[{"name":"Wu You","name_vi":null,"name_original":"Wu You","tmdb_id":2131224,"profile":"https://image.tmdb.org/t/p/w500/7PUzF89kFtJ57V6rePeXsKIvfdn.jpg","tmdb_url":"https://www.themoviedb.org/person/2131224"},{"name":"Li Zhuoyang","name_vi":null,"name_original":"Li Zhuoyang","tmdb_id":2470601,"profile":"https://image.tmdb.org/t/p/w500/5YF2aSP7NQmjbcIBCNVSpUrmV4L.jpg","tmdb_url":"https://www.themoviedb.org/person/2470601"},{"name":"Wang Ting","name_vi":null,"name_original":"Wang Ting","tmdb_id":1484353,"profile":"https://image.tmdb.org/t/p/w500/p0c9TZN2kzRS2BFSbqWyTPb5Htr.jpg","tmdb_url":"https://www.themoviedb.org/person/1484353"},{"name":"Hao Ping","name_vi":null,"name_original":"Hao Ping","tmdb_id":1079120,"profile":"https://image.tmdb.org/t/p/w500/eYZaRPyLAYnjTgROvPiFZPtcJb4.jpg","tmdb_url":"https://www.themoviedb.org/person/1079120"},{"name":"Trương Thần Quang","name_vi":"Trương Thần Quang","name_original":"Morning Chang","tmdb_id":1910034,"profile":"https://image.tmdb.org/t/p/w500/AuFkuY03VN5NqjYjpQvJ7xX3n2I.jpg","tmdb_url":"https://www.themoviedb.org/person/1910034"},{"name":"Gao Yufei","