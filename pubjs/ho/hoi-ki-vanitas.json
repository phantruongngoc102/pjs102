c bí ẩn Charlatan - kẻ đứng sau căn bệnh ma quái ác.</p>","tmdb_id":121964,"cast":[],"director":[],"keywords":[],"time":"24 phút/tập","tmdb":{"type":"tv","id":"121964","season":1,"vote_average":8.3,"vote_count":235},"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hoi-ki-vanitas.json"}