c bí ẩn Charlatan - kẻ đứng sau căn bệnh ma quái ác.</p>","tmdb_id":121964,"cast":["Hanae Natsuki","Ishikawa Kaito","Inori Minase","Shino Shimoji","Ai Kayano","Yoko Hikasa","Toshiyuki Morikawa","Kengo Kawanishi","Tomoaki Maeno","Murase Ayumu","Rie Kugimiya","Daiki Hamano","Akira Ishida","Taro Kiuchi","Koji Yusa"],"director":[],"keywords":[],"time":"24 phút/tập","tmdb":{"type":"tv","id":"121964","season":1,"vote_average":8.3,"vote_count":235},"cast_meta":[{"name":"Hanae Natsuki","name_vi":"Hanae Natsuki","name_original":"Natsuki Hanae","tmdb_id":1256603,"profile":"https://image.tmdb.org/t/p/w500/alTb0DlcPIbcwM08WSmxFai58sd.jpg","tmdb_url":"https://www.themoviedb.org/person/1256603"},{"name":"Ishikawa Kaito","name_vi":"Ishikawa Kaito","name_original":"Kaito Ishikawa","tmdb_id":1324666,"profile":"https://image.tmdb.org/t/p/w500/fzjIkotjUHHs3wgftM9tqdsG8ph.jpg","tmdb_url":"https://www.themoviedb.org/person/1324666"},{"name":"Inori Minase","name_vi":null,"name_original":"Inori Minase","tmdb_id":1325949,"profile":"https://image.tmdb.org/t/p/w500/cqOrQDUbbQLKpujzcK47YqjFdNp.jpg","tmdb_url":"https://www.themoviedb.org/person/1325949"},{"name":"Shino Shimoji","name_vi":null,"name_original":"Shino Shimoji","tmdb_id":1780773,"profile":"https://image.tmdb.org/t/p/w500/8T2DboiJA3PC1OLJjhN12o4THYn.jpg","tmdb_url":"https://www.themoviedb.org/person/1780773"},{"name":"Ai Kayano","name_vi":null,"name_original":"Ai Kayano","tmdb_id":1254671,"profile":"https://image.tmdb.org/t/p/w500/l8ywp387rfdAS7mOExe3cEZnsk0.jpg","tmdb_url":"https://www.themoviedb.org/person/1254671"},{"name":"Yoko Hikasa","name_vi":null,"name_original":"Yoko Hikasa","tmdb_id":1072774,"profile":"https://image.tmdb.org/t/p/w500/mP3bj0s1gqJ6tCKFLhu4b1CkJj7.jpg","tmdb_url":"https://www.themoviedb.org/person/1072774"},{"name":"Toshiyuki Morikawa","name_vi":null,"name_original":"Toshiyuki Morikawa","tmdb_id":9706,"profile":"https://image.tmdb.org/t/p/w500/hrzGBe4nokgkBNFekNo5hlXB2Bv.jpg","tmdb_url":"https://www.themovie