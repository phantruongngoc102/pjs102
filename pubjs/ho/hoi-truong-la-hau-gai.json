://vip.opstream12.com/20220506/14684_e06feb09/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/b8262a23052612c56595a230615f2250","link_m3u8":"https://vip.opstream12.com/20220506/14685_fecb3e59/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/b49732e7c77fbc9badd37b4f49960698","link_m3u8":"https://vip.opstream12.com/20220506/14686_8ca0ede9/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream12.com/share/99e5a6ae292728f981127b71861de113","link_m3u8":"https://vip.opstream12.com/20220506/14687_fab4e063/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream12.com/share/757334847f188c6304b84ec6b018a965","link_m3u8":"https://vip.opstream12.com/20220506/14688_4b9ba5a1/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream12.com/share/09d0326952871a6f35d61a82415468d7","link_m3u8":"https://vip.opstream12.com/20220506/14689_d797e5d4/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream12.com/share/46d361782608fdbb1b4f3bd6cf5e31f3","link_m3u8":"https://vip.opstream12.com/20220506/14690_4349abf8/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream12.com/share/6340831392e9cd8af9598274f4b3c5c0","link_m3u8":"https://vip.opstream12.com/20220506/14691_c669ef72/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream12.com/share/ae7d9dc853482ef5146fb11f73f93b0b","link_m3u8":"https://vip.opstream12.com/20220506/14692_b5b615f7/index.m3u8"}]}],"description":"<p>Ayuzawa Misaki học ở lớp 1 năm thứ hai của Trường Trung học phổ thông Tinh Hoa, mới 16 tuổi thì đã là nữ hội trưởng lần đầu của Hội học sinh. Bởi Tinh Hoa vốn là trường nam, nên dù hiện nay cũng tuyển nữ sinh, nhưng mà phần lớn vẫn là nam sinh mà địa vị của nữ sinh rất thấp. Nhằm bảo vệ nữ sinh, Misaki đối đầu với nam sinh ngang ngược suốt ngày bằng tài năng không thua nam sinh của mình. Bố nàng để lại nợ nần và mất tích, hành vi không chịu trách nhiệm vậy tổn thương lòng nàng mà khiến nàng cực kỳ ghét đàn ông(điều này cũng là động lực khiến nàng mạnh mẽ). Misaki luôn luôn làm thêm trong quán cà phê hầu gái để phụ cấp sinh hoạt gia đình. Nhưng mà không có bí mật viễn vĩnh trên thế giới, bí mật này bị Usui Takumi phát hiện. Đồng thời, chàng chính là đối thủ cạnh tranh được nhiều nữ sinh trong trường ưa thích của Misaki.</p>","tmdb_id":65648,"cast":[],"director":[],"keywords":[],"tmdb":{"id":65648},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hoi-truong-la-hau-gai.json"}