0f59","link_m3u8":"https://vip.opstream16.com/20230307/32724_70f8f847/index.m3u8"},{"name":"34","slug":"34","filename":"Hom Nay Phai Co Len E34","link_embed":"https://vip.opstream16.com/share/63aa6680ffdbedff257a2c5bcb2cc27f","link_m3u8":"https://vip.opstream16.com/20230307/32725_d1ca2fd2/index.m3u8"},{"name":"35","slug":"35","filename":"Hom Nay Phai Co Len E35","link_embed":"https://vip.opstream16.com/share/2704910c10c56a7b11432fb3c698f10c","link_m3u8":"https://vip.opstream16.com/20230308/32766_2a8201d7/index.m3u8"},{"name":"36","slug":"36","filename":"Hom Nay Phai Co Len E36","link_embed":"https://vip.opstream16.com/share/7cf91b300ff3ecef82c59dd47b89253a","link_m3u8":"https://vip.opstream16.com/20230308/32767_a2bd629d/index.m3u8"},{"name":"37","slug":"37","filename":"Hom Nay Phai Co Len E37","link_embed":"https://vip.opstream16.com/share/3cbab37acac4fc1e6b3f78778d48c67d","link_m3u8":"https://vip.opstream16.com/20230309/32811_426768de/index.m3u8"},{"name":"38","slug":"38","filename":"Hom Nay Phai Co Len E38","link_embed":"https://vip.opstream16.com/share/c77ca1eca9810917f4c11a449252b048","link_m3u8":"https://vip.opstream16.com/20230309/32812_6909984e/index.m3u8"},{"name":"39","slug":"39","filename":"Hom Nay Phai Co Len E39","link_embed":"https://vip.opstream16.com/share/5de7a22a52cdc12c0725ff2d2df5bf41","link_m3u8":"https://vip.opstream16.com/20230310/32851_d60df847/index.m3u8"},{"name":"40","slug":"40","filename":"Hom Nay Phai Co Len E40","link_embed":"https://vip.opstream16.com/share/a730bf57002ababb7d6c15f3846c19e3","link_m3u8":"https://vip.opstream16.com/20230310/32852_f1bd514c/index.m3u8"}]}],"time":"25 phút/tập","description":"<p>Nội dung của phim Hôm Nay Phải Cố Lên kể về những câu chuyện của những nhân viên trong Phòng Kế Hoạch 3, từng coi là nơi vô cùng thần bí của Tập đoàn Điện tử Cao Phát, nhưng 3 năm trở lại đây lại liên tục bị thụt lùi do sở hữu nhiều dự án không được khả thi. Tuy nhiên, mỗi nhân viên trong phòng lại có những quan điểm riêng của mình và thể hiện một cuộc sống gọi là “người bình thường phấn đấu”.</p><p>Đặc biệt, dù là hố đen của công ty nhưng Lý Thiên Nhiên (Trịnh Khải thủ vai) hay là cô nàng Phạm Tư Tư (Trần Kỳ Ngọc thủ vai) và Bạch Mã Soái (Vương Hạc Đệ thủ vai) đã lựa chọn cách cố gắng hết hình trong công việc, mặc dù họ là những người bình thường, nhưng họ cũng đang đấu tranh để xây dựng lại vinh quang của bộ phận thứ ba và triển vọng nghề nghiệp của họ.</p>","tmdb":{"type":"tv","id":"220838","season":1,"vote_average":8.5,"vote_count":8},"modified":"2023-03-10T12:49:20.000Z","cast":["Trịnh Khải","Trần Ngọc Kỳ","Vương Hạc Đệ","Shaogang Zhang","Liang Chao","Chung Lệ Lệ","Wu Yaheng","Trình Tử","Viên Văn Khang","Yu Shi"],"director":["Ngô Cường","Vũ Trung Trung"],"cast_meta":[{"name":"Trịnh Khải","name_vi":"Trịnh Khải","name_original":"Ryan Zheng","tmdb_id":1279598,"profile":"https://image.tmdb.org/t/p/w500/wHUCaZAe8KkpXs6sXmPUr9B6C82.jpg","tmdb_url":"https://www.themoviedb.org/person/1279598"},{"name":"Trần Ngọc Kỳ","name_vi":"Trần Ngọc Kỳ","name_original":"Chen Yuqi","tmdb_id":2085448,"profile":"https://image.tmdb.org/t/p/w500/zRPQ7suBiQoCUEzt9BHtzKkxSAx.jpg","tmdb_url":"https://www.themoviedb.org/person/2085448"},{"name":"Vương Hạc Đệ","name_vi":"Vương Hạc Đệ","name_original":"Dylan Wang","tmdb_id":2050456,"profile":"https://image.tmdb.org/t/p/w500/x05cU32ATgu1ekqoySAvF84TmCZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2050456"},{"name":"Shaogang Zhang","name_vi":null,"name_original":"Shaogang Zhang","tmdb_id":2231117,"profile":"https://image.tmdb.org/t/p/w500/i81FZgttr3OVBelXLch0BiojF11.jpg","tmdb_url":"https://www.themoviedb.org/person/2231117"},{"name":"Liang Chao","name_vi":null,"name_original":"Liang Chao","tmdb_id":1510987,"profile":"https://image.tmdb.org/t/p/w500/rauPEiStbnnyZHpDd7Oz8UUielw.jpg","tmdb_url":"https://www.themoviedb.org/person/1510987"},{"name":"Chung Lệ Lệ","name_vi":"Chung Lệ Lệ","name_original":"Zhong Lili","tmdb_id":2876779,"profile":"https://image.tmdb.org/t/p/w