òn đảo hoang.\n\nGu Dan Soo là cháu trai của Chủ tịch Jayce Fashion Hwang Ik Seon và sinh ra trong một người cha giàu có, mẹ nghèo. Dan Soo, người đang sống như một linh hồn tự do ở nước ngoài, đến Hàn Quốc theo kế hoạch của bà anh để trở thành người kế vị chủ tịch và anh đoàn tụ với người bạn thời thơ ấu Maeng Gong Hee một lần nữa.","tmdb":{"type":"tv","id":"262831","season":1,"vote_average":6.4,"vote_count":5},"modified":"2025-04-14T18:55:47.000Z","cast":["Park Ha-na","Park Sang-nam","Kim Sa-Kwon","Lee Yeon-doo","Yang Mi-kyung","Choi Jae-sung","Ban Hyo-jung","Yang Hee-kyung","Lee Eun-hyung","Park Tam-hee","Jeon Soo-kyeong","Cha Kwang-soo"],"director":["Kim Sung-geun"],"cast_meta":[{"name":"Park Ha-na","name_vi":null,"name_original":"Park Ha-na","tmdb_id":1568455,"profile":"https://image.tmdb.org/t/p/w500/fKun3ZjVbRoshh0mljc0ZQ5ePyD.jpg","tmdb_url":"https://www.themoviedb.org/person/1568455"},{"name":"Park Sang-nam","name_vi":null,"name_original":"Park Sang-nam","tmdb_id":2990974,"profile":"https://image.tmdb.org/t/p/w500/tMuVmsxER0FTs55PNOy2QfA6ix3.jpg","tmdb_url":"https://www.themoviedb.org/person/2990974"},{"name":"Kim Sa-Kwon","name_vi":null,"name_original":"Kim Sa-Kwon","tmdb_id":1574620,"profile":"https://image.tmdb.org/t/p/w500/k5etKQgwQnfTnv8fFhd8VMyw6al.jpg","tmdb_url":"https://www.themoviedb.org/person/1574620"},{"name":"Lee Yeon-doo","name_vi":null,"name_original":"Lee Yeon-doo","tmdb_id":1374515,"profile":"https://image.tmdb.org/t/p/w500/didz5J2ZpQ8AMEwbOTXi4N93NlG.jpg","tmdb_url":"https://www.themoviedb.org/person/1374515"},{"name":"Yang Mi-kyung","name_vi":null,"name_original":"Yang Mi-kyung","tmdb_id":1253449,"profile":"https://image.tmdb.org/t/p/w500/3vmMmJw9dYHa9VZRsVaG6WEqQbF.jpg","tmdb_url":"https://www.themoviedb.org/person/1253449"},{"name":"Choi Jae-sung","name_vi":null,"name_original":"Choi Jae-sung","tmdb_id":1180185,"profile":"https://image.tmdb.org/t/p/w500/l6wTRfPF8R1j62ozp7bHo1Kr8bp.jpg","tmdb_url":"https://www.themoviedb.org/person/1180