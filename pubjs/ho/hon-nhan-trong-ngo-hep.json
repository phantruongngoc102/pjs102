Trung Anh), có những lúc tưởng chừng như đã hết hi vọng. Dù vậy, với tình thân gia đình, những điều không thể đều biến thành có thể.</p>","tmdb":{"type":"tv","id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2025-11-24T14:31:12.000Z","cast":["Trung Anh","Thanh Quý","Chí Nhân","Minh Hà","Mạnh Hưng","Trọng Nhân","Kiều My","Diễm Hương","Khuất Quỳnh Hoa"],"director":["Vũ Trường Khoa"],"cast_meta":[{"name":"Trung Anh","name_vi":null,"name_original":"Trung Anh"},{"name":"Thanh Quý","name_vi":null,"name_original":"Thanh Quý"},{"name":"Chí Nhân","name_vi":null,"name_original":"Chí Nhân"},{"name":"Minh Hà","name_vi":null,"name_original":"Minh Hà"},{"name":"Mạnh Hưng","name_vi":null,"name_original":"Mạnh Hưng"},{"name":"Trọng Nhân","name_vi":null,"name_original":"Trọng Nhân"},{"name":"Kiều My","name_vi":null,"name_original":"Kiều My"},{"name":"Diễm Hương","name_vi":null,"name_original":"Diễm Hương"},{"name":"Khuất Quỳnh Hoa","name_vi":null,"name_original":"Khuất Quỳnh Hoa"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ho/hon-nhan-trong-ngo-hep.json","keywords":[],"tmdb_checked":false}