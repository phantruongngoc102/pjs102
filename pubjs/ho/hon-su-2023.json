23_11655903/index.m3u8"},{"name":"26","slug":"26","filename":"Hôn Sự - Tap 26","link_embed":"https://vip.opstream16.com/share/698936639e27b2bc038e0d7b4ea464b2","link_m3u8":"https://vip.opstream16.com/20230407/33724_a253a700/index.m3u8"},{"name":"27","slug":"27","filename":"Hôn Sự - Tap 27","link_embed":"https://vip.opstream16.com/share/41f4893a58fba89b8e7535aadb39ccf4","link_m3u8":"https://vip.opstream16.com/20230407/33725_01d7dcf2/index.m3u8"}]}],"time":"11 phút/tập","description":"<p>Sau nhiều tháng chuẩn bị, Tống Diệc Phi và Tần Lý cuối cùng cũng tổ chức hôn lễ, nhưng buổi lễ trọng thể ban đầu lại kết thúc trong một cuộc gặp gỡ ác mộng. Tống Diệc Phi lớn lên dưới sự chăm sóc của gia đình, cô ngây thơ và khao khát một cuộc hôn nhân viên mãn, nhưng cô lại phát hiện ra rằng cuộc hôn nhân của mình bị bao phủ bởi sự dối trá. Zheng Baosong, một người đàn ông xa lạ xuất hiện trong đám cưới, xuất hiện hết lần này đến lần khác trong cuộc đời cô, và mọi vấn đề dường như đều đổ dồn về chồng cô là Qin Li.</p>","tmdb":{"type":"tv","id":"222225","season":1,"vote_average":7.5,"vote_count":2},"modified":"2025-04-01T11:54:49.000Z","cast":["Phàn Trị Hân","Khuất Mộng Nhũ","Huang Haonan","Zhu Weiling","Tang Lingting","Carrie Wang"],"director":[],"cast_meta":[{"name":"Phàn Trị Hân","name_vi":"Phàn Trị Hân","name_original":"Fan Zhixin","tmdb_id":2533329,"profile":"https://image.tmdb.org/t/p/w500/1TowSJzOOeKvWzpWpPO6RzI3cf0.jpg","tmdb_url":"https://www.themoviedb.org/person/2533329"},{"name":"Khuất Mộng Nhũ","name_vi":"Khuất Mộng Nhũ","name_original":"Qu Mengru","tmdb_id":3067724,"profile":"https://image.tmdb.org/t/p/w500/bbMQbGnjIimCXq1pO3GmkKZnUep.jpg","tmdb_url":"https://www.themoviedb.org/person/3067724"},{"name":"Huang Haonan","name_vi":null,"name_original":"Huang Haonan","tmdb_id":2463078,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2463078"},{"name":"Zhu Weiling","name_vi":null,"name_original":"Zhu Weiling","tmdb_id":3301789,"profile":"https://image.tmdb.org/t/p/