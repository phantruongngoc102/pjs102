2065e6","link_m3u8":"https://vip.opstream15.com/20220419/5530_f7e9e1a3/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/d5a28f81834b6df2b6db6d3e5e2635c7","link_m3u8":"https://vip.opstream15.com/20220419/5531_7345233b/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/378fb9f589cf7930275f25e4b5afbddd","link_m3u8":"https://vip.opstream15.com/20220419/5532_45169da5/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/8965f76632d7672e7d3cf29c87ecaa0c","link_m3u8":"https://vip.opstream15.com/20220419/5533_436dcecb/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/de6b1cf3fb0a3aa1244d30f7b8c29c41","link_m3u8":"https://vip.opstream15.com/20220419/5534_b4366f18/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream15.com/share/7ec69dd44416c46745f6edd947b470cd","link_m3u8":"https://vip.opstream15.com/20220419/5535_4b8ff4ac/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream15.com/share/1134ac57b5b1d38b7d70c1b6feaa28cf","link_m3u8":"https://vip.opstream15.com/20220419/5536_dcbaff61/index.m3u8"}]}],"description":"<p>Thời dân quốc, thân là truyền nhân đời thứ 48 của Dương gia thương pháp, thanh niên thôn quê Dương Tiểu Lang từ nhỏ đã cực ghét tập võ. Bà ngoại hận Thiết Thành Cương nên bắt buộc Dương Tiểu Lang đến Giang thành ở nhờ nhà nhị thúc Lưu Quách, là ông chủ của một tửu lầu trung hoa. Ở nơi phức tạp như Giang thành, Dương Tiểu Lang, Châu Toàn ở cục cảnh sát và Thanh Long hội đối nghịch với đám người Tây Dương. Vốn cho rằng có thể gần bùn nhưng không dính bùn, nhưng Dương Tiểu Lang lại phát hiện mình đang rơi vào một âm mưu lớn của các cỗ thế lực đó bày ra. Để bảo vệ Tiểu Phàm, cô gái mình yêu mến, Dương Tiểu Lang đã đứng ra đương đầu. Dựa vào bộ võ công tuyệt học \"Sai Thời Thuật\" được truyền thụ từ chỗ du hiệp giang hồ Vương Xử Nhị cùng với cái lưỡi không xương của mình, liệu Dương Tiểu Lang có thể trở thành một anh hùng hảo hán bảo vệ Giang thành và người mình yêu được không?</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hon-the-tieu-ma-dau.json"}