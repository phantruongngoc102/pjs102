ed":"https://vip.opstream17.com/share/b4591e1ef51fdd8a9a8e7e7659c1a702","link_m3u8":"https://vip.opstream17.com/20251213/24827_b4591e1e/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream17.com/share/f15422af60aef6cd7e46f10b21b23d8c","link_m3u8":"https://vip.opstream17.com/20251213/24828_f15422af/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream17.com/share/8a4d3214af1524fd478f2e338c9295f2","link_m3u8":"https://vip.opstream17.com/20251213/24829_8a4d3214/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream17.com/share/643ddc64cb0f826743e01e79f4ccf6ae","link_m3u8":"https://vip.opstream17.com/20251213/24830_643ddc64/index.m3u8"},{"name":"55","slug":"55","link_embed":"https://vip.opstream17.com/share/7273e671a40fa9f0d3867d1098d5ac6e","link_m3u8":"https://vip.opstream17.com/20251213/24831_7273e671/index.m3u8"},{"name":"56","slug":"56","link_embed":"https://vip.opstream17.com/share/659f7811510c2a2b265a09a56095c702","link_m3u8":"https://vip.opstream17.com/20251213/24832_659f7811/index.m3u8"},{"name":"57","slug":"57","link_embed":"https://vip.opstream17.com/share/eef80e65b8d54b757eb4a6bee35864df","link_m3u8":"https://vip.opstream17.com/20251213/24833_eef80e65/index.m3u8"},{"name":"58","slug":"58","link_embed":"https://vip.opstream17.com/share/e3133801456d68c42114514a81db864b","link_m3u8":"https://vip.opstream17.com/20251213/24834_e3133801/index.m3u8"},{"name":"59","slug":"59","link_embed":"https://vip.opstream17.com/share/2842db40fd1da44e0be74335fb55004d","link_m3u8":"https://vip.opstream17.com/20251213/24835_2842db40/index.m3u8"},{"name":"60","slug":"60","link_embed":"https://vip.opstream17.com/share/bd44f20ee6ac130433c642094cecd336","link_m3u8":"https://vip.opstream17.com/20251213/24836_bd44f20e/index.m3u8"}]}],"description":"<p>Ở thế giới tu tiên luyện đạo này, thứ được coi trọng nhất chính là tiền bạc. Sở Thiên, đệ tử nghèo kiết xác của Học viện Thiên Phong bỗng được kế thừa một khối tài sản bạc tỉ, từ đó hắn bắt đầu cuộc đời tiêu xài sung sướng. Dựa trên nguyên tắc không được phung phí tài nguyên của xã hội, Sở Thiên đã mua một căn biệt phủ đỉnh cấp, trang bị những thứ xa hoa, mua các loại đan dược và bùa chú tinh phẩm cấp cao độc quyền ở thành Thiên Phong, sống một cuộc sống tiêu tiền như nước và thực sự bước lên cảnh giới coi tiền như cỏ rác. Nhưng thành Phong Thiên tưởng chừng yên bình này lại đang nổi lên một làn sóng ngầm, các thế lực hắc ám trong thành bên nào cũng nuôi dã tâm thống trị thiên hạ, Sở Thiên kết thù hận và trở thành mục tiêu truy sát của các thế lực hắc ám.</p>","tmdb_id":235017,"cast":[],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"235017","season":1,"vote_average":7,"vote_count":1},"cast_meta":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ho/hong-hoang-linh-ton.json"}