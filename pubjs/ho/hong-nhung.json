s://vip.opstream13.com/20240710/4674_fe931454/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/f0bf4a2da952528910047c31b6c2e951","link_m3u8":"https://vip.opstream13.com/20240722/4860_f4cb48cb/index.m3u8"}]}],"description":"<p><br>\"Kızıl Goncalar\" kể câu chuyện cảm động về Meryem, kết hôn từ năm 14 tuổi trong một tôn giáo Hồi giáo, và hiện đang dũng cảm chiến đấu để ngăn con gái của mình, Zeynep, khỏi phải chịu cảnh giống như cô dâu của cháu trai của thủ lĩnh. Dẫn dắt bởi chị dâu của mình, một cựu thành viên của tôn giáo, họ nhận ra rằng họ phải trốn chạy để cứu Zeynep khỏi cánh tay mạnh mẽ của tôn giáo. Sợ hãi giấu kín kế hoạch của mình khỏi chồng tàn ác, Meryem phải trước tiên kiếm tiền bằng cách làm người chăm sóc trong nhà của bác sĩ tâm thần học không tôn giáo Levent, người đồng ý giúp đỡ cô. Mặc dù họ có niềm tin tôn giáo và tiến bộ trái ngược nhau, Meryem và Levent được hấp dẫn bởi cảm xúc, nhưng cuộc hỗn loạn trong cuộc sống của họ trở nên nghiêm trọng hơn khi danh tính của con gái anh được tiết lộ.</p>","tmdb_id":241020,"cast":["Özgü Namal","Özcan Deniz","Erkan Avcı","Mert Turak","Mert Yazıcıoğlu","Selen Öztürk","Şerif Erol","Duygu Sarışın","Sitare Akbaş","Tuğrul Tülek","Yakup Turğut","Mina Demirtaş","Esma Yılmaz","Zehra Kelleci","Mısra Tüfek"],"director":["Ömür Atay"],"keywords":[],"tmdb":{"type":"tv","id":"241020","season":1,"vote_average":5.4,"vote_count":16},"cast_meta":[{"name":"Özgü Namal","name_vi":null,"name_original":"Özgü Namal","tmdb_id":89760,"profile":"https://image.tmdb.org/t/p/w500/i2qUbe9wYZJFgY79KrfhRVnscMz.jpg","tmdb_url":"https://www.themoviedb.org/person/89760"},{"name":"Özcan Deniz","name_vi":null,"name_original":"Özcan Deniz","tmdb_id":1250945,"profile":"https://image.tmdb.org/t/p/w500/9D2yddtuU6qqFKa8vzMRg1CPacA.jpg","tmdb_url":"https://www.themoviedb.org/person/1250945"},{"name":"Erkan Avcı","name_vi":null,"name_original":"Erkan Avcı","tmdb_id":1052797,"profile":"https://image.tmdb.org/t/p/w500/2S