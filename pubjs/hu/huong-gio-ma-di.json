 mọi trở ngại, cùng nhau xây dựng ước mơ.</p>","tmdb":{"type":"tv","id":"217038","season":1,"vote_average":7.7,"vote_count":6},"modified":"2025-04-18T10:43:26.000Z","cast":["Vương Khải","Đàm Tùng Vận","Lưu Sướng","Yan Zidong","Ji Shuyi","Zhou Qiqi","Bo Zicheng","Guo Xiaoran","Cao Yi","Cao Yixin","Zhao Kedi","Robin Luo","Gong Rui","Xie Zhixun"],"director":["Wang Zhi"],"cast_meta":[{"name":"Vương Khải","name_vi":"Vương Khải","name_original":"Wang Kai","tmdb_id":1559226,"profile":"https://image.tmdb.org/t/p/w500/35Lm6dPSN5qygFC5PrDbjqjWJdG.jpg","tmdb_url":"https://www.themoviedb.org/person/1559226"},{"name":"Đàm Tùng Vận","name_vi":"Đàm Tùng Vận","name_original":"Tan Songyun","tmdb_id":1614218,"profile":"https://image.tmdb.org/t/p/w500/yYMnfaIix23U51z21EJhznq3DHN.jpg","tmdb_url":"https://www.themoviedb.org/person/1614218"},{"name":"Lưu Sướng","name_vi":"Lưu Sướng","name_original":"Liu Chang","tmdb_id":1539645,"profile":"https://image.tmdb.org/t/p/w500/k3W30yTY1H34A5He9Ns3zKarN94.jpg","tmdb_url":"https://www.themoviedb.org/person/1539645"},{"name":"Yan Zidong","name_vi":null,"name_original":"Yan Zidong","tmdb_id":1850115,"profile":"https://image.tmdb.org/t/p/w500/hKO1P17mUdhNYf71Qqv9sEPw004.jpg","tmdb_url":"https://www.themoviedb.org/person/1850115"},{"name":"Ji Shuyi","name_vi":null,"name_original":"Ji Shuyi","tmdb_id":3844785,"profile":"https://image.tmdb.org/t/p/w500/lZDPFOgpdjuqmwhRBG8G3aNuTXK.jpg","tmdb_url":"https://www.themoviedb.org/person/3844785"},{"name":"Zhou Qiqi","name_vi":null,"name_original":"Zhou Qiqi","tmdb_id":543160,"profile":"https://image.tmdb.org/t/p/w500/2Sob9mjw8LJCDrfTES9tGu1GZM5.jpg","tmdb_url":"https://www.themoviedb.org/person/543160"},{"name":"Bo Zicheng","name_vi":null,"name_original":"Bo Zicheng","tmdb_id":3845702,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3845702"},{"name":"Guo Xiaoran","name_vi":null,"name_original":"Guo Xiaoran","tmdb_id":2571558,"profile":"https://image.tmdb.org/t/p/w500/j6NmOojwyaoqMPL87mlpsmeUw1c.j