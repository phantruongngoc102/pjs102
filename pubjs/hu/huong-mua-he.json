rong những ngày mưa. Hye Won phải sống trong tâm trạng giằng xé, vừa không muốn làm tổn thương vị hôn phu của mình vừa không thể che giấu tình cảm định mệnh đối với Min Woo.","tmdb":{"type":"tv","id":"14761","season":1,"vote_average":8.5,"vote_count":8},"modified":"2023-06-01T01:43:45.000Z","cast":["Son Ye-jin","Song Seung-heon","Han Ji-hye","Ryu Jin","Ha Jae-yeong","Shin Ae","Cho Eun-sook","Kim Hae-sook","Kim Yong-geon","Ahn Jung-hoon"],"director":[],"cast_meta":[{"name":"Son Ye-jin","name_vi":"Son Ye-jin","name_original":"Son Ye-jin","tmdb_id":86889,"profile":"https://image.tmdb.org/t/p/w500/pR3QiJKcMBG7oseZUnnU54lgU1V.jpg","tmdb_url":"https://www.themoviedb.org/person/86889"},{"name":"Song Seung-heon","name_vi":null,"name_original":"Song Seung-heon","tmdb_id":83020,"profile":"https://image.tmdb.org/t/p/w500/AloHkgRwhj3BzCKClXxPInjbW9R.jpg","tmdb_url":"https://www.themoviedb.org/person/83020"},{"name":"Han Ji-hye","name_vi":null,"name_original":"Han Ji-hye","tmdb_id":127710,"profile":"https://image.tmdb.org/t/p/w500/z93b2rusGoTrqJnIPAREXX1tHvk.jpg","tmdb_url":"https://www.themoviedb.org/person/127710"},{"name":"Ryu Jin","name_vi":null,"name_original":"Ryu Jin","tmdb_id":1235326,"profile":"https://image.tmdb.org/t/p/w500/e27rlkK2aPR5jzSo43h1GgyP1lv.jpg","tmdb_url":"https://www.themoviedb.org/person/1235326"},{"name":"Ha Jae-yeong","name_vi":null,"name_original":"Ha Jae-yeong","tmdb_id":1238555,"profile":"https://image.tmdb.org/t/p/w500/rslo4YRlZgvRgHZJtgYKza7jeSN.jpg","tmdb_url":"https://www.themoviedb.org/person/1238555"},{"name":"Shin Ae","name_vi":null,"name_original":"Shin Ae","tmdb_id":1547163,"profile":"https://image.tmdb.org/t/p/w500/kXxdBUaz5Y7hwt7c7krrsPWQjxP.jpg","tmdb_url":"https://www.themoviedb.org/person/1547163"},{"name":"Cho Eun-sook","name_vi":null,"name_original":"Cho Eun-sook","tmdb_id":1277307,"profile":"https://image.tmdb.org/t/p/w500/aOXK3inmVLlUwkcSdB2b9nHMyMd.jpg","tmdb_url":"https://www.themoviedb.org/person/1277307"},{"name":"Kim Hae-sook"