ùng cha khác mẹ của Chi - Giang Thượng Du (do Lâm Phong đóng).","tmdb_id":104489,"cast":["Ngô Khải Hoa","Flora Chan Wai-Shan","Joe Ma Tak-Chung","Đằng Lệ Danh","Lâm Phong","Dương Thiên Hoa","Hilary Tsui Ho-Ying","Thành Khuê An","Celine Ma","Suet Nei","Emotion Cheung Kam-Ching","Lưu Giang","Lưu Gia Huy","Châu Thông","Wong Wai"],"director":["林志華"],"keywords":[],"tmdb":{"type":"tv","id":"104489","season":1,"vote_average":7,"vote_count":3},"cast_meta":[{"name":"Ngô Khải Hoa","name_vi":"Ngô Khải Hoa","name_original":"Lawrence Ng Kai-Wah","tmdb_id":122818,"profile":"https://image.tmdb.org/t/p/w500/nOgwDEg0QSavgTo9mscVSkKTpLa.jpg","tmdb_url":"https://www.themoviedb.org/person/122818"},{"name":"Flora Chan Wai-Shan","name_vi":null,"name_original":"Flora Chan Wai-Shan","tmdb_id":1223045,"profile":"https://image.tmdb.org/t/p/w500/oR3CF5xIbUZgci1BQfeHvAGqaYo.jpg","tmdb_url":"https://www.themoviedb.org/person/1223045"},{"name":"Joe Ma Tak-Chung","name_vi":null,"name_original":"Joe Ma Tak-Chung","tmdb_id":227805,"profile":"https://image.tmdb.org/t/p/w500/oK0d0kFPwSNKtlcBNbDqt6ExVYa.jpg","tmdb_url":"https://www.themoviedb.org/person/227805"},{"name":"Đằng Lệ Danh","name_vi":"Đằng Lệ Danh","name_original":"Joyce Tang Lai-Ming","tmdb_id":1223072,"profile":"https://image.tmdb.org/t/p/w500/rCGjxrs3HeRoOhzqbAwCucV12qo.jpg","tmdb_url":"https://www.themoviedb.org/person/1223072"},{"name":"Lâm Phong","name_vi":"Lâm Phong","name_original":"Raymond Lam Fung","tmdb_id":89409,"profile":"https://image.tmdb.org/t/p/w500/Ak40P6TWthdQ9diRki5RIcJ6r95.jpg","tmdb_url":"https://www.themoviedb.org/person/89409"},{"name":"Dương Thiên Hoa","name_vi":"Dương Thiên Hoa","name_original":"Miriam Yeung Chin-Wah","tmdb_id":56863,"profile":"https://image.tmdb.org/t/p/w500/3NgovoC2nnHOFq7vr6j7m6URS7V.jpg","tmdb_url":"https://www.themoviedb.org/person/56863"},{"name":"Hilary Tsui Ho-Ying","name_vi":null,"name_original":"Hilary Tsui Ho-Ying","tmdb_id":237786,"profile":"https://image.tmdb.org/t/p/w500/sebpAa10lVxqX