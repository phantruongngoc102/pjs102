t anh bằng mọi giá để cướp cuốn sổ. Lúc này, Madara (hay còn được Natsume gọi là Nyanko-sensei) xuất hiện, ông trở thành vệ sĩ và là cố vấn của Natsume. Dù ông lúc nào cũng ra vẻ muốn chiếm Hữu Nhân Sổ, nhưng ông dần trở thành người bạn đồng hành thân thiết của Natsume Takashi.","tmdb":{"type":"tv","id":"69500","season":7,"vote_average":8.1,"vote_count":93},"modified":"2024-12-22T21:40:11.000Z","cast":["Hiroshi Kamiya","Kazuhiko Inoue","Eiji Itoh","Miki Ito","Hisayoshi Suganuma","Akira Ishida","Sanae Kobayashi","Kimura Ryohei","Miyuki Sawashiro","Kazuma Horie","Junichi Suwabe","Rina Sato"],"director":[],"cast_meta":[{"name":"Hiroshi Kamiya","name_vi":null,"name_original":"Hiroshi Kamiya","tmdb_id":93801,"profile":"https://image.tmdb.org/t/p/w500/5aAAOlQ2hW5EqEQOzk4UeroxcTN.jpg","tmdb_url":"https://www.themoviedb.org/person/93801"},{"name":"Kazuhiko Inoue","name_vi":null,"name_original":"Kazuhiko Inoue","tmdb_id":89968,"profile":"https://image.tmdb.org/t/p/w500/3BpYtYRiLAmTNbCm2LXlXnkMRit.jpg","tmdb_url":"https://www.themoviedb.org/person/89968"},{"name":"Eiji Itoh","name_vi":null,"name_original":"Eiji Itoh","tmdb_id":1252607,"profile":"https://image.tmdb.org/t/p/w500/2GMFkzZg6mnI2axTCQFFJkOV15R.jpg","tmdb_url":"https://www.themoviedb.org/person/1252607"},{"name":"Miki Ito","name_vi":null,"name_original":"Miki Ito","tmdb_id":122660,"profile":"https://image.tmdb.org/t/p/w500/6osSzjWq1MZ0XznG3UZHpB81lJF.jpg","tmdb_url":"https://www.themoviedb.org/person/122660"},{"name":"Hisayoshi Suganuma","name_vi":null,"name_original":"Hisayoshi Suganuma","tmdb_id":1241598,"profile":"https://image.tmdb.org/t/p/w500/axMNYDvCAcne4t3rzJho5g3lxJI.jpg","tmdb_url":"https://www.themoviedb.org/person/1241598"},{"name":"Akira Ishida","name_vi":null,"name_original":"Akira Ishida","tmdb_id":81244,"profile":"https://image.tmdb.org/t/p/w500/jnW2Gn2NlR2uwOCeyOuzypnTmkH.jpg","tmdb_url":"https://www.themoviedb.org/person/81244"},{"name":"Sanae Kobayashi","name_vi":null,"name_original":"Sanae Kobaya