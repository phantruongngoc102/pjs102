02","link_embed":"https://vip.opstream14.com/share/9c87b4fa747d4b5675c82f561eb9cd4c","link_m3u8":"https://vip.opstream14.com/20230213/31281_6163b795/index.m3u8"},{"name":"26","slug":"26","filename":"TVB Huyền Thoại Bắt Đầu tập 26⧸27 ｜ tiếng Việt ｜ Thái Thiếu Phân, Mã Tuấn Vỹ, Trần Hào ｜ TVB 2002","link_embed":"https://vip.opstream14.com/share/add4f684a678d13d0ce8b389da309842","link_m3u8":"https://vip.opstream14.com/20230213/31282_0c97dda1/index.m3u8"},{"name":"27","slug":"27","filename":"TVB Huyền Thoại Bắt Đầu tập 27⧸27 ｜ tiếng Việt ｜ Thái Thiếu Phân, Mã Tuấn Vỹ, Trần Hào ｜ TVB 2002","link_embed":"https://vip.opstream14.com/share/dc9dab195b7aeefb54a4f8bfa798d2da","link_m3u8":"https://vip.opstream14.com/20230213/31283_60f53fec/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Nhân vật chính của Lạc Thần là cô nàng Chân Mật do Thái Thiếu Phân thủ vai, nàng được coi là một tuyệt sắc giai nhân thời điểm đó, vẻ đẹp của nàng đã làm mê đắm không biết bao nhiêu chàng trai, vị anh hùng, trong đó có cả Tào Tháo (Lưu Đan) và hai người con của ông ta là Tào Phi (Trần Hào) và Tào Thực (Mã Tuấn Vỹ). Tuy nhiên, khi này Chân Mật đã là “hoa đã có chủ”, cô làm dâu nhà Viên Thiệu, sau khi Tào Tháo đem quân chiếm đánh khiến cả nhà họ Viên không còn một ai sống sót và người duy nhất còn sống chính là Mật, từ đó cô luôn nuôi ý nguyện trả thù cho nhà chồng.</p>","tmdb":{"type":"tv","id":"6054","season":1,"vote_average":7,"vote_count":5},"modified":"2023-02-13T14:24:55.000Z","cast":["Mã Tuấn Vỹ","Thái Thiếu Phân","Trần Hào","Quách Thiện Ni","Lưu Đan","Mạch Trường Thanh","Irene Wong","Lâm Vỹ Thần","Priscilla Ku","Trình Khả Vi","Michelle Fung","Samantha Chuk Man-Kwan","Đặng Nhất Quân","Timothy Cheng Chi-Sing","Kong Hon"],"director":["Liu Bo"],"cast_meta":[{"name":"Mã Tuấn Vỹ","name_vi":"Mã Tuấn Vỹ","name_original":"Steven Ma Chun-Wai","tmdb_id":1233285,"profile":"https://image.tmdb.org/t/p/w500/q60svjeSi9KpyZCwhnwwy6iy8Qs.jpg","tmdb_url":"https://www.themoviedb.org/person/1233285"},{"n