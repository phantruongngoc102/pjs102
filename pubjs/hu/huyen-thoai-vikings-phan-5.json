u8"}]}],"time":"35 phút/tập","description":"<p>Phim Huyền Thoại Vikings (Phần 5) - Vikings (Season 5) 2017 là một bộ phim về tộc chiến binh được coi là hiếu chiến nhất trong dòng lịch sử của thế giới loài người, từng tạo nên cơn sốt trên thị trường điện ảnh tại rất nhiều quốc gia trên thế giới. Phim được khởi quay tại Ireland, nội dung nói về hành trình của người chiến binh Ragnar Lodbrok, kẻ từng tạ ra nỗi kinh hoàng cho nước Pháp và Anh trong thời kì hưng thịnh của tộc người Viking.</p>","tmdb":{"type":"tv","id":"44217","season":5,"vote_average":8.095,"vote_count":7455},"modified":"2023-06-11T19:32:41.000Z","cast":["Alex Høgh Andersen","Jordan Patrick Smith","Marco Ilsø","Peter Franzén","Georgia Hirst","Danila Kozlovsky"],"director":[],"cast_meta":[{"name":"Alex Høgh Andersen","name_vi":null,"name_original":"Alex Høgh Andersen","tmdb_id":1609347,"profile":"https://image.tmdb.org/t/p/w500/kDO1gFqMnsV5gCQsMgEL9BZongX.jpg","tmdb_url":"https://www.themoviedb.org/person/1609347"},{"name":"Jordan Patrick Smith","name_vi":null,"name_original":"Jordan Patrick Smith","tmdb_id":1394429,"profile":"https://image.tmdb.org/t/p/w500/v9hY8mCo7Dk5AptzZbLE2F8Tzhu.jpg","tmdb_url":"https://www.themoviedb.org/person/1394429"},{"name":"Marco Ilsø","name_vi":null,"name_original":"Marco Ilsø","tmdb_id":1372317,"profile":"https://image.tmdb.org/t/p/w500/xfcrAKFHq81VVO9axg1zP8JrYCN.jpg","tmdb_url":"https://www.themoviedb.org/person/1372317"},{"name":"Peter Franzén","name_vi":null,"name_original":"Peter Franzén","tmdb_id":11263,"profile":"https://image.tmdb.org/t/p/w500/zJ8JV2TefLQIT5DzMinl5eoK5YH.jpg","tmdb_url":"https://www.themoviedb.org/person/11263"},{"name":"Georgia Hirst","name_vi":null,"name_original":"Georgia Hirst","tmdb_id":2074237,"profile":"https://image.tmdb.org/t/p/w500/7xHIjmpI4jWUfB1EFiTMtYzpVXM.jpg","tmdb_url":"https://www.themoviedb.org/person/2074237"},{"name":"Danila Kozlovsky","name_vi":null,"name_original":"Danila Kozlovsky","tmdb_id":562730,"profile":"https://image.t