ờ Hàn Quốc) vào mỗi thứ Năm. Chương trình kết thúc với việc thành lập một nhóm nhạc nữ bảy thành viên mang tên IZNA, được WakeOne đào tạo và quản lý, trở thành nhóm nhạc nữ đầu tiên không phải tạm thời có hợp đồng tiêu chuẩn.</p>","tmdb":{"type":"tv","id":"105301","season":2,"vote_average":8.2,"vote_count":19},"modified":"2025-10-20T18:09:58.000Z","cast":["Song Kang","Sung Hanbin","TAEYANG","Monika","Leejung Lee","VVN","24"],"director":["김신영"],"cast_meta":[{"name":"Song Kang","name_vi":null,"name_original":"Song Kang","tmdb_id":1878952,"profile":"https://image.tmdb.org/t/p/w500/83fLAMMb1LGT8YZ4dgRI0fti3az.jpg","tmdb_url":"https://www.themoviedb.org/person/1878952"},{"name":"Sung Hanbin","name_vi":null,"name_original":"Sung Hanbin","tmdb_id":4378410,"profile":"https://image.tmdb.org/t/p/w500/qhPBRLkUcDGC6tB9EY7ibUPSbg5.jpg","tmdb_url":"https://www.themoviedb.org/person/4378410"},{"name":"TAEYANG","name_vi":null,"name_original":"TAEYANG","tmdb_id":1415327,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1415327"},{"name":"Monika","name_vi":null,"name_original":"Monika","tmdb_id":3240411,"profile":"https://image.tmdb.org/t/p/w500/i042YLfHJ58glpt9virmDMX2ikM.jpg","tmdb_url":"https://www.themoviedb.org/person/3240411"},{"name":"Leejung Lee","name_vi":null,"name_original":"Leejung Lee","tmdb_id":2989155,"profile":"https://image.tmdb.org/t/p/w500/4q5ZvW0wEqrj6pKchxEp9FCrtwA.jpg","tmdb_url":"https://www.themoviedb.org/person/2989155"},{"name":"VVN","name_vi":null,"name_original":"VVN","tmdb_id":4662541,"profile":"https://image.tmdb.org/t/p/w500/bq0Q0iKuz1NcFJc9EGpjHhVGmnA.jpg","tmdb_url":"https://www.themoviedb.org/person/4662541"},{"name":"24","name_vi":null,"name_original":"24","tmdb_id":5955686,"profile":"https://image.tmdb.org/t/p/w500/6BVnbSExrKm41Ac7E3tdxfH1goq.jpg","tmdb_url":"https://www.themoviedb.org/person/5955686"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/i_/i-land-phan-2.json"}