9d9352e0/index.m3u8"},{"name":"3","slug":"3","filename":"Idol Thần Thánh E3","link_embed":"https://vip.opstream16.com/share/9ec3cff2fc5008ded145994ef2b906d7","link_m3u8":"https://vip.opstream16.com/20230223/32106_4679a5d1/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Pontifex Lembrary chiến đấu chống lại ác quỷ, anh ta được chuyển đến một thế giới khác với cơ thể của Woo Yeon-woo, thành viên của một nhóm nhạc thần tượng không nổi tiếng có tên là Wild Animal. Trong một ngành kinh doanh giải trí nơi các kỹ năng xã hội, xu hướng và tài năng áp đảo là rất cần thiết, thật khó để Lembrary trang nghiêm, thánh thiện thích nghi. Do những lời nói và việc làm không phù hợp với tư cách là một người nổi tiếng, Lembrary bị công chúng bàn tán và nhận được sự chú ý mà anh không ngờ tới. Sử dụng lòng tốt và tình yêu của mình, Lembrary chữa lành thế giới cằn cỗi và vặn vẹo mà mọi người đang sống trong khi đi hết con đường này đến con đường khác để ổn định bản thân như một thần tượng.</p>","tmdb":{"type":"tv","id":"202625","season":1,"vote_average":7.3,"vote_count":33},"modified":"2023-03-24T18:40:47.000Z","cast":["Kim Min-gue","Go Bo-gyeol","Lee Jang-woo","Oh Jin-seok","Ye Ji-won","Shin Myung-sung","Tak Jae-hoon","Park Sang-nam","Jeong Soo-hyun","Kim Seo-ha","Hong Seung-bum","Choi Jae-hyun","Shin Kyu-hyun","Cha Joo-young"],"director":["Park So-yeon","Lee So-yoon"],"cast_meta":[{"name":"Kim Min-gue","name_vi":null,"name_original":"Kim Min-gue","tmdb_id":1565088,"profile":"https://image.tmdb.org/t/p/w500/w4NojHsHdLGf7LLoT6jfyDcE8K6.jpg","tmdb_url":"https://www.themoviedb.org/person/1565088"},{"name":"Go Bo-gyeol","name_vi":null,"name_original":"Go Bo-gyeol","tmdb_id":1678451,"profile":"https://image.tmdb.org/t/p/w500/wuLbzPR4eJ8tZsWJMsYDjy1Rewx.jpg","tmdb_url":"https://www.themoviedb.org/person/1678451"},{"name":"Lee Jang-woo","name_vi":null,"name_original":"Lee Jang-woo","tmdb_id":1348986,"profile":"https://image.tmdb.org/t/p/w500/o7eXMPTBj1wCNnRofaIxF5OgnDh.jpg","tmdb_url":"