78/index.m3u8"},{"name":"26","slug":"26","filename":"Ina26-muxed","link_embed":"https://vip.opstream10.com/share/d9511037d3a058e1fc0b56e0d86f8ffe","link_m3u8":"https://vip.opstream10.com/20220831/24818_b2adc81c/index.m3u8"},{"name":"27","slug":"27","filename":"Ina27-muxed","link_embed":"https://vip.opstream10.com/share/e4eea37faf446ffa7acd4ab006b3d53c","link_m3u8":"https://vip.opstream10.com/20220907/24848_971a3f92/index.m3u8"},{"name":"28","slug":"28","filename":"Ina28-muxed","link_embed":"https://vip.opstream10.com/share/e0070f4adceee3ac92c8eb8b95ad84a7","link_m3u8":"https://vip.opstream10.com/20220908/24852_6cc84e09/index.m3u8"},{"name":"29","slug":"29","filename":"Ina29-muxed","link_embed":"https://vip.opstream10.com/share/90da3608667e990227e76560921e5fa7","link_m3u8":"https://vip.opstream10.com/20220912/24868_4b507766/index.m3u8"},{"name":"30","slug":"30","filename":"Ina30-muxed","link_embed":"https://vip.opstream10.com/share/38a647f544eaa16673a5d33b77f942fe","link_m3u8":"https://vip.opstream10.com/20220915/24883_7d055b0d/index.m3u8"},{"name":"31","slug":"31","filename":"Ina31-muxed","link_embed":"https://vip.opstream10.com/share/d3d9007636be26969e05f6ba1d3cf7dd","link_m3u8":"https://vip.opstream10.com/20220917/24915_a2973ffb/index.m3u8"},{"name":"32","slug":"32","filename":"Ina32-muxed","link_embed":"https://vip.opstream10.com/share/493733b1ea397d196293bbf12b839a4f","link_m3u8":"https://vip.opstream10.com/20220918/24951_2fb1c080/index.m3u8"}]}],"time":"2h30p/tập","description":"<p>Defne ( Acelya Topaloglu ) là một cô gái trẻ và thành đạt, vừa tốt nghiệp một trường đại học nổi tiếng ở Thổ Nhĩ Kỳ. Cô ấy sẽ bắt đầu làm việc tại Arass Technology với tư cách là một kỹ sư máy tính. Tuy nhiên, trong ngày làm việc đầu tiên, Defne tranh cãi với anh trai Cinar vì anh ta nhận thấy cô ăn mặc hở hang và muốn cô ăn mặc chỉn chu hơn.</p><p>Để không bị trễ thêm, Defne làm theo lời anh trai nhưng cô cũng bí mật lấy váy và thay đồ trong khu vực đậu xe của Arass Technology. Khi đang thay váy, Defne vô tình gặp một thanh niên mà cô cho là nhân viên an ninh nhưng thực chất, anh ta là CEO của Arass Technology, tên là Yalin. Yalin không tiết lộ danh tính của mình và chế nhạo Defne.</p><p>Vì Defne đến quá muộn trong ngày làm việc đầu tiên nên suýt bị đuổi việc. Nhưng cô ấy đưa ra một thỏa thuận và có quyền tiếp tục làm việc tại Arass Technology nếu cô ấy phát hiện ra vấn đề trong mã máy tính trong vòng một ngày.</p><p>Defne giải quyết vấn đề và chứng minh rằng cô ấy là ứng viên tốt nhất cho vị trí này. Tuy nhiên, cô phát hiện ra rằng anh chàng trong khu vực đậu xe là Giám đốc điều hành của Arass Technology. Khi Defne phát hiện ra mình bị lừa, cô ấy đã từ chức ngay trong ngày đầu tiên của mình.</p><p>Trong khi đó, Yalin hiểu lỗi của mình và đi theo Defne để xin lỗi nhưng anh ta lại bắt gặp Defne ở khu vực đậu xe khi cô đang thay váy. Nhưng lần này, anh trai của Defne xuất hiện và đánh Yalin. Câu chuyện trở nên quá phức tạp khi Defne bắt đầu làm việc tại Arass Technology và anh trai cô đem lòng yêu Yesim - em gái của Yalin.</p><p>Trong bộ phim truyền hình Love Out-Of-Spite (Inadina Ask), bạn sẽ được xem những câu chuyện hài hước của Defne và Yalin, những người làm việc trong cùng một công ty nhưng không mấy hòa hợp với nhau.&nbsp;</p><p>Liệu Defne và Yalin có bắt đầu yêu nhau</p><p>&nbsp;Defne sẽ xử lý tất cả các vấn đề trong công việc đầu tiên của cô ấy hay không</p><p>Tất cả sẽ được giải đáp khi bộ phim Inadina Ask lên sóng, lót dép hóng thôi nào các bác ơiiiiii</p>","tmdb":{"type":"tv","id":"73766","season":1,"vote_average":7,"vote_count":10},"modified":"2022-09-19T06:47:14.000Z","cast":["Açelya Topaloğlu","Can Yaman","Nilay Duru","Eren Vurdem","Cevahir Turan","Cem Belevi","Yeşim Dalgıçer","Taner Rumeli","İlay Erkök","Funda Eskioğlu","Tibet Tursun","Alper Saylık","Bilge Şen","Selim Gürata"],"director":["Osman Sinav","Yusuf Omer Sinav"],"cast_meta":[{"name":"Açelya Topaloğlu","name_vi":null,"name_original":"Açelya Topaloğlu",