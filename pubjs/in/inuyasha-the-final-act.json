opstream12.com/share/8eb3926a025bb86899f452f3dd675f04","link_m3u8":"https://vip.opstream12.com/20220610/18570_588fda00/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/1424b9b97976fd6a10e46c9f8aa72597","link_m3u8":"https://vip.opstream12.com/20220610/18571_ccddd536/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/595afbd7f5a99efd71556d99b39c268e","link_m3u8":"https://vip.opstream12.com/20220610/18572_732b3b2a/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream12.com/share/acc564daafaaf26d45b5d37c5e68384e","link_m3u8":"https://vip.opstream12.com/20220610/18573_82399d77/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream12.com/share/a64bcca2a087451831e31b6d339940b9","link_m3u8":"https://vip.opstream12.com/20220610/18574_a1746408/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream12.com/share/4c21c9d351543562af3562a7add8685f","link_m3u8":"https://vip.opstream12.com/20220610/18575_2f9a7190/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream12.com/share/601c6bc71c7480010b164805579ad343","link_m3u8":"https://vip.opstream12.com/20220610/18576_9854ecca/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream12.com/share/0eda666a2704efc2e5b37dd165607c0f","link_m3u8":"https://vip.opstream12.com/20220610/18577_2eb3096f/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream12.com/share/80f0fe8bd3a7ea69b926c38b6e3c4772","link_m3u8":"https://vip.opstream12.com/20220610/18578_d68763b8/index.m3u8"}]}],"description":"<p>Cuộc chiến giữa ác ma Naraku và đội của Inuyasha ngày càng gay gắt. Để bảo vệ trái tim khỏi bị tổn hại, Naraku đã tách một đứa bé có thể nhìn thấy tâm trí con người ở Bạch Linh Sơn và giao trái tim cho anh ta trông coi. Sau đó, đứa bé bị một nhà sư lỗi lạc cắt làm đôi và biến thành HakuToshi và Akago. Khi biết được tầm quan trọng của trái tim Naraku, hai đứa trẻ độc ác này quyết định lật ngược thế cờ đối với anh. Akago sử dụng Mouryomaru để tăng cường lớp giáp bên ngoài cơ thể, trong khi HakuToshi và Kagura bí mật đối đầu với Naraku khi chiến đấu với Inuyasha. Cuộc đấu trí của hai bên cuối cùng cũng đang tiến đến cao trào, và cuộc đấu tay đôi giữa thiện và ác là điều không thể tránh khỏi.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/in/inuyasha-the-final-act.json"}