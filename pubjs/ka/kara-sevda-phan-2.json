.</p>","tmdb":{"type":"tv","id":"65555","season":1,"vote_average":7.8,"vote_count":689},"modified":"2022-12-02T16:36:18.000Z","cast":["Burak Özçivit","Neslihan Atagül","Kaan Urgancıoğlu","Zerrin Tekindor","Neşe Baykent","Hazal Filiz Küçükköse","Melisa Aslı Pamuk","Burak Sergen","Rüzgar Aksoy","Orhan Güner","Zeyno Eracar","Kerem Alışık","Uğur Aslan","Ali Burak Ceylan"],"director":["Hilal Saral"],"cast_meta":[{"name":"Burak Özçivit","name_vi":null,"name_original":"Burak Özçivit","tmdb_id":1424928,"profile":"https://image.tmdb.org/t/p/w500/pF8EHDM2ETDT2X2Pwg3Ak0ZCPAY.jpg","tmdb_url":"https://www.themoviedb.org/person/1424928"},{"name":"Neslihan Atagül","name_vi":null,"name_original":"Neslihan Atagül","tmdb_id":1254465,"profile":"https://image.tmdb.org/t/p/w500/pPqu9maHAbEhV1tD0tackGK7AiC.jpg","tmdb_url":"https://www.themoviedb.org/person/1254465"},{"name":"Kaan Urgancıoğlu","name_vi":null,"name_original":"Kaan Urgancıoğlu","tmdb_id":145408,"profile":"https://image.tmdb.org/t/p/w500/oWYb9CAkBLh0ojzsO3OySduVjpM.jpg","tmdb_url":"https://www.themoviedb.org/person/145408"},{"name":"Zerrin Tekindor","name_vi":null,"name_original":"Zerrin Tekindor","tmdb_id":1246608,"profile":"https://image.tmdb.org/t/p/w500/mWRvssoXW6GCsyqEubYEn5l1U3s.jpg","tmdb_url":"https://www.themoviedb.org/person/1246608"},{"name":"Neşe Baykent","name_vi":null,"name_original":"Neşe Baykent","tmdb_id":1575024,"profile":"https://image.tmdb.org/t/p/w500/ePEGpdPSVRkKkW2AYlieENjczWy.jpg","tmdb_url":"https://www.themoviedb.org/person/1575024"},{"name":"Hazal Filiz Küçükköse","name_vi":null,"name_original":"Hazal Filiz Küçükköse","tmdb_id":1575028,"profile":"https://image.tmdb.org/t/p/w500/fAT3PE0xE9CunXY6GqoIGkBN5ij.jpg","tmdb_url":"https://www.themoviedb.org/person/1575028"},{"name":"Melisa Aslı Pamuk","name_vi":null,"name_original":"Melisa Aslı Pamuk","tmdb_id":1575026,"profile":"https://image.tmdb.org/t/p/w500/3AV366jXJB2k0lARh207zNo1V3R.jpg","tmdb_url":"https://www.themoviedb.org/person/1575026"},{"name":