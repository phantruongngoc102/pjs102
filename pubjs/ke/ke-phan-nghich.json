e","link_m3u8":"https://vip.opstream15.com/20221129/28826_0b8d9ee5/index.m3u8"},{"name":"43","slug":"43","filename":"ke-phan-nghich-tap-43","link_embed":"https://vip.opstream15.com/share/30219b29705d056409e50d7e369be507","link_m3u8":"https://vip.opstream15.com/20221129/28827_3456703a/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Năm 1936, học viên lớp đào tạo cán bộ Hội Phục Hưng Lâm Nam Sênh bị đưa đến Thượng Hải tham gia hoạt động bắt giữ các thành viên thuộc Đảng bí mật. Trong quá trình thực hiện, Lâm Nam Sênh bị tinh thần hy sinh cũng như sứ mệnh của những người Đảng Cộng sản làm cho dao động. Lâm Nam Sênh dũng cảm quyết đoán, nhiều lần lập công trong quá trình kháng chiến chống Nhật. Nhiều lần đứng về phía Đảng Cộng sản, lợi dụng thân phận đặc biệt của mình trong quân đội giúp đỡ vô cùng lớn cho Đảng bí mật. Sau khí kháng chiến thắng lợi, Lâm Nam Sênh trở thành một Đảng viên chân chính, đồng thời vào thời khắc quyết định giải phóng, đã cống hiến rất nhiều cho đất nước và Đảng Cộng sản.</p>","tmdb":{"type":"tv","id":"127123","season":1,"vote_average":9.2,"vote_count":4},"modified":"2022-11-29T18:37:20.000Z","cast":["Chu Nhất Long","Đồng Dao","Wang Zhiwen","Vương Dương","Chu Châu","Lý Cường","Zhang Zixian","Yao Anlian","Viên Văn Khang"],"director":["You ZHOU"],"cast_meta":[{"name":"Chu Nhất Long","name_vi":"Chu Nhất Long","name_original":"Zhu Yilong","tmdb_id":1743471,"profile":"https://image.tmdb.org/t/p/w500/tdm21vg4E7ubhd429UT1UpPpFGo.jpg","tmdb_url":"https://www.themoviedb.org/person/1743471"},{"name":"Đồng Dao","name_vi":"Đồng Dao","name_original":"Tong Yao","tmdb_id":1298729,"profile":"https://image.tmdb.org/t/p/w500/darU7n51ym1dziYRwOtD10qiljn.jpg","tmdb_url":"https://www.themoviedb.org/person/1298729"},{"name":"Wang Zhiwen","name_vi":null,"name_original":"Wang Zhiwen","tmdb_id":109435,"profile":"https://image.tmdb.org/t/p/w500/tjb6puOdCya3c1lVsVQ6AA6itHE.jpg","tmdb_url":"https://www.themoviedb.org/person/109435"},{"name":"Vương Dương","name_vi":"