{"id":"6444b1f29a90db3f525cf4e8","title":"Kẻ Sưu Tầm","origin_name":"The Collector","slug":"ke-suu-tam","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/ke/ke-suu-tam.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/ke/ke-suu-tam.webp","year":2009,"type":"single","genre":[{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"The Collector - Kẻ Sưu Tầm 1 - 2009","link_embed":"https://vip.opstream14.com/share/bf7e527b0c579691ec93e1a1066fa18f","link_m3u8":"https://vip.opstream14.com/20230423/35755_5483fa93/index.m3u8"}]}],"time":"88 Phút","description":"Nội dung của phim xoay quanh một người đàn ông tên là Arkin (Josh Stewart), người đang có công việc sửa chữa cửa sổ và cửa ra vào của gia đình nhà Chase (Michael Reilly Burke), những người mới chuyển đến một căn nhà biệt lập tại Detroit, ở giữa nơi không có nhiều người ở. Trong khoảng thời gian này, vợ của anh đang nợ một số tiền khá lớn của những tay cho vay lãi cực kỳ nguy hiểm, anh đang rất cần tiền nhưng khoản thanh toán mà anh nhận được sau đó thực tế là không đủ để trả các khoản nợ của vợ anh. Để có tiền trả nợ cho vợ, Arkin đã liều lĩnh tìm đường đột nhập vào trộm đá qúy trong két sắt của gia đình nhà Chase. Ngờ đâu rằng cả căn nhà là một mê cung chết chóc chỉ có đường vào mà không có đường ra. Khi anh ta đến nhà, anh ta nhận ra rằng một tên tội phạm bị cách ly vốn đã bị giam cầm trong ngôi nhà từ lâu với những cái bẫy được đặt ở khắp mọi nơi. Arkin tìm cách thoát khỏi căn nhà chết người và làm mọi thứ để có thể tự cứu mạng mình.","tmdb":{"type":"movie","id":"21407","season":null,"vote_average":6.612,"vote_count":1608},"modified":"2023-04-23T11:20:04.000Z","cast":["Josh Stewart","Juan Fernández","Michael Reilly Burke","Madeline Zima","Andrea Roth","Karley Scott Collins","Robert Wisdom","Daniella Alonso","Haley Pullos","Diane Ayala Goldner","Alex Feldman","Krystal Mayo","Gregory Alan Williams","Michael Showers","Bill Stinchcomb"],"director":["Marcus Dunstan"],"cast_meta":[{"name":"Josh Stewart","name_vi":null,"name_original":"Josh Stewart","tmdb_id":40039,"profile":"https://image.tmdb.org/t/p/w500/prgoT9fq5Z2ZCGmC1rrSZkq4wH9.jpg","tmdb_url":"https://www.themoviedb.org/person/40039"},{"name":"Juan Fernández","name_vi":null,"name_original":"Juan Fernández","tmdb_id":1607,"profile":"https://image.tmdb.org/t/p/w500/gd5gNboWvdpoEtiNtIUJoWn8SSR.jpg","tmdb_url":"https://www.themoviedb.org/person/1607"},{"name":"Michael Reilly Burke","name_vi":null,"name_original":"Michael Reilly Burke","tmdb_id":108774,"profile":"https://image.tmdb.org/t/p/w500/zcvCPaOXtcNbp3yYPA9nU5sNyJq.jpg","tmdb_url":"https://www.themoviedb.org/person/108774"},{"name":"Madeline Zima","name_vi":null,"name_original":"Madeline Zima","tmdb_id":84613,"profile":"https://image.tmdb.org/t/p/w500/l7ISws9XpnYyE6GZ15HcdR4zVfR.jpg","tmdb_url":"https://www.themoviedb.org/person/84613"},{"name":"Andrea Roth","name_vi":null,"name_original":"Andrea Roth","tmdb_id":44151,"profile":"https://image.tmdb.org/t/p/w500/upv6wjBLhbHY4uadqEovtxvxVr4.jpg","tmdb_url":"https://www.themoviedb.org/person/44151"},{"name":"Karley Scott Collins","name_vi":null,"name_original":"Karley Scott Collins","tmdb_id":109784,"profile":"https://image.tmdb.org/t/p/w500/cd0iFjqA9ApfA91oj08FcMs0tJS.jpg","tmdb_url":"https://www.themoviedb.org/person/109784"},{"name":"Robert Wisdom","name_vi":null,"name_original":"Robert Wisdom","tmdb_id":21505,"profile":"https://image.tmdb.org/t/p/w500/5fd8CwnL2YpWyq2G9WooejgnKiX.jpg","tmdb_url":"https://www.themoviedb.org/p