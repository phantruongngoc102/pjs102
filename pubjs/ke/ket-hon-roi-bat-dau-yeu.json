b","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-32B","link_embed":"https://vip.opstream11.com/share/767f4c28a2895898b0edab21c1b18ebd","link_m3u8":"https://vip.opstream11.com/20220608/29351_6126c399/index.m3u8"},{"name":"33A","slug":"33a","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-33A","link_embed":"https://vip.opstream11.com/share/2bc3900bff210b080e6bd19c10331244","link_m3u8":"https://vip.opstream11.com/20220608/29352_6dcd84df/index.m3u8"},{"name":"33B","slug":"33b","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-33B","link_embed":"https://vip.opstream11.com/share/f1d28af8c8d21575eb00e70075b5d1de","link_m3u8":"https://vip.opstream11.com/20220608/29353_05f6ce47/index.m3u8"},{"name":"34A","slug":"34a","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-34A","link_embed":"https://vip.opstream11.com/share/9ddaf29fd4e776a9d94bd4f0add6dd5d","link_m3u8":"https://vip.opstream11.com/20220608/29354_853b80de/index.m3u8"},{"name":"34B","slug":"34b","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-34B","link_embed":"https://vip.opstream11.com/share/b0199c060aaef7f56d1995e3e4bf8f8e","link_m3u8":"https://vip.opstream11.com/20220608/29355_bf6160c7/index.m3u8"},{"name":"35A","slug":"35a","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-35A","link_embed":"https://vip.opstream11.com/share/d69762da81e1d0a33b4d3839e7108eb8","link_m3u8":"https://vip.opstream11.com/20220608/29357_ee3fc2bd/index.m3u8"},{"name":"35B","slug":"35b","filename":"ket-hon-roi-bat-dau-yeu-begin-again-tap-35B","link_embed":"https://vip.opstream11.com/share/32f8bee7c830d03270034463142809cd","link_m3u8":"https://vip.opstream11.com/20220608/29356_e874301b/index.m3u8"}]}],"time":"41M2S","description":"<p>Kết Hôn Rồi Bắt Đầu Yêu là bộ phim xoay quanh một nữ Chủ tịch tập đoàn nội thất Lộc Phương Ninh xinh đẹp nhưng tính tình hống hách, lạnh lùng. Cô bị gia đình ép lấy chồng nên đã phải đi tìm đối tượng phù hợp trong khi cô chưa sẵn sàng. Cô bất ngờ gặp được Lăng Duệ (Cung Tuấn đảm nhận) - một bác sĩ phẫu thuật điển trai, hiền lành. Vì một số lý do mà Lăng Duệ đồng ý trở thành ứng cử viên sáng giá trong bản hợp đồng với vai diễn chàng rể tốt của Lộc Chủ tịch. Sau khi kết hôn, Lộc Phương Ninh thay đổi tính tình bá đạo chuyên chế, sống cuộc sống chậm rãi với Lăng Duệ. Nhưng biến cố xảy ra, để không trở thành gánh nặng của Lăng Duệ, Lộc Phương Ninh lựa chọn chấm dứt hợp đồng, biến mất trước tầm mắt của mọi người. 6 năm sau, cô mang theo món quà trời ban quay về cố hương, mà lần này, bác sĩ Lăng dịu dàng lựa chọn trở thành người tấn công, chủ động bảo vệ hạnh phúc thuộc về anh.</p>","tmdb":{"type":"tv","id":"112280","season":1,"vote_average":8.083,"vote_count":24},"modified":"2023-04-11T19:24:41.000Z","cast":["Châu Vũ Đồng","Cung Tuấn","Kim Trạch","Wu Mansi","Li Siqi","Zhang Shulun"],"director":["Xu Chi","Xu Chi Dao Yan"],"cast_meta":[{"name":"Châu Vũ Đồng","name_vi":"Châu Vũ Đồng","name_original":"Zhou Yutong","tmdb_id":1782333,"profile":"https://image.tmdb.org/t/p/w500/anylalvMOzuctoNu2Wn36ZoyW6G.jpg","tmdb_url":"https://www.themoviedb.org/person/1782333"},{"name":"Cung Tuấn","name_vi":"Cung Tuấn","name_original":"Gong Jun","tmdb_id":1820070,"profile":"https://image.tmdb.org/t/p/w500/rtjBdEF61NySmDDnoDgAtuclAJJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1820070"},{"name":"Kim Trạch","name_vi":"Kim Trạch","name_original":"Jin Ze","tmdb_id":2595206,"profile":"https://image.tmdb.org/t/p/w500/MOjid8gln59Qpkn4f3COwPS7AS.jpg","tmdb_url":"https://www.themoviedb.org/person/2595206"},{"name":"Wu Mansi","name_vi":null,"name_original":"Wu Mansi","tmdb_id":2834760,"profile":"https://image.tmdb.org/t/p/w500/jCbpSuvlLN6hmOOdsXfMijSic7l.jpg","tmdb_url":"https://www.themoviedb.org/person/2834760"},{"name":"Li Siqi","name_vi":null,"name_original":"Li Siqi","tmdb_id":3303286,"profile":"https://image.tmdb.org/t/p/w500/JBp0PBE3XOb3lyfNmbVM39DYDe.jpg","tmdb_url":"https://www.themoviedb.org/person/3303286"},{"name":"Zhang Shulun","name_vi":null,"name_original":"Zhang Shulu