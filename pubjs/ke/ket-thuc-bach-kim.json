ream15.com/share/54a2a6a714d383485e79899dd53e8b24","link_m3u8":"https://vip.opstream15.com/20230824/41668_8e75601e/index.m3u8"},{"name":"23","slug":"23","filename":"Kết thúc bạch kim_S01E23_Tận cùng suy nghĩ","link_embed":"https://vip.opstream15.com/share/c306791fb7d2c4488fd53630c7e5e91d","link_m3u8":"https://vip.opstream15.com/20230824/41669_4fac47f2/index.m3u8"},{"name":"24","slug":"24","filename":"Kết thúc bạch kim_S01E24_Mũi tên cuối cùng","link_embed":"https://vip.opstream15.com/share/1030d227d3fe9ed0555666c4ffd14ab1","link_m3u8":"https://vip.opstream15.com/20230824/41670_2db06faf/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Khi các bạn cùng lớp tổ chức lễ tốt nghiệp cấp hai, Mirai gặp rắc rối và chìm trong bóng tối. Nhưng trận chiến của anh ấy chỉ mới bắt đầu khi anh ấy nhận được sự cứu rỗi từ trên cao dưới hình dạng một thiên thần. Bây giờ Mirai phải đọ sức với 12 người được chọn khác trong một trận chiến mà người chiến thắng sẽ trở thành vị thần tiếp theo của thế giới. Mirai có một thiên thần trong góc của mình, nhưng anh ấy có thể cần phải trở thành ác quỷ để tồn tại.</p>","tmdb":{"type":"tv","id":"114892","season":1,"vote_average":7.7,"vote_count":244},"modified":"2023-08-25T12:55:25.000Z","cast":["Irino Miyu","Yui Ogura","Mao Ichimichi","Hanae Natsuki","Toshiyuki Morikawa","Ai Kayano","Ishikawa Kaito","Kikuko Inoue","Tomoaki Maeno","Hikaru Midorikawa","Kaori Maeda","Shoya Chiba","Hiroshi Tsuchida"],"director":[],"cast_meta":[{"name":"Irino Miyu","name_vi":"Irino Miyu","name_original":"Miyu Irino","tmdb_id":19588,"profile":"https://image.tmdb.org/t/p/w500/8qEEhHUObNvGQr4e6eqLu5z4qTz.jpg","tmdb_url":"https://www.themoviedb.org/person/19588"},{"name":"Yui Ogura","name_vi":null,"name_original":"Yui Ogura","tmdb_id":1057990,"profile":"https://image.tmdb.org/t/p/w500/vUuyLWde2CEd5G0oqeEzzFE6qqA.jpg","tmdb_url":"https://www.themoviedb.org/person/1057990"},{"name":"Mao Ichimichi","name_vi":null,"name_original":"Mao Ichimichi","tmdb_id":1161472,"profile"