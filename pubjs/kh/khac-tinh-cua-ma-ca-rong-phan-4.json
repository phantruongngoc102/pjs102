ến","link_embed":"https://vip.opstream90.com/share/83f97f4825290be4cb794ec6a234595f","link_m3u8":"https://vip.opstream90.com/20240719/1177_83f97f48/index.m3u8"}]}],"time":"42 phút/tập","description":"<p>Sam đã hoàn thành định mệnh của mình để trở thành Trưởng lão thứ 4 và giờ đây thế giới hậu tận thế của chúng ta thậm chí còn tiến gần hơn đến việc chứng kiến ​​Kẻ bóng tối hồi sinh. Vanessa thề sẽ đi theo ánh sáng và chiến đấu với bóng tối đã lấy đi mọi thứ cô yêu thương. Ngay khi cô nghĩ mình đơn độc trong nhiệm vụ, cô gặp hai phụ nữ trẻ, Violet và Jack - những người có khả năng chiến đấu với ma cà rồng độc đáo và bí ẩn.</p>","tmdb":{"type":"tv","id":"65820","season":4,"vote_average":7.041,"vote_count":909},"modified":"2024-07-20T14:13:59.000Z","cast":["Kelly Overton","Rukiya Bernard","Aleks Paunovic"],"director":[],"cast_meta":[{"name":"Kelly Overton","name_vi":null,"name_original":"Kelly Overton","tmdb_id":61829,"profile":"https://image.tmdb.org/t/p/w500/u1KnPtnHfdLCrImtONXCYwJDqZk.jpg","tmdb_url":"https://www.themoviedb.org/person/61829"},{"name":"Rukiya Bernard","name_vi":null,"name_original":"Rukiya Bernard","tmdb_id":83948,"profile":"https://image.tmdb.org/t/p/w500/1xnSniYd3y84qt6lqLvDIzGT4x0.jpg","tmdb_url":"https://www.themoviedb.org/person/83948"},{"name":"Aleks Paunovic","name_vi":null,"name_original":"Aleks Paunovic","tmdb_id":107810,"profile":"https://image.tmdb.org/t/p/w500/k8j9Nr0xS2vEUMV8Wl0y5cC2NeB.jpg","tmdb_url":"https://www.themoviedb.org/person/107810"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/kh/khac-tinh-cua-ma-ca-rong-phan-4.json"}