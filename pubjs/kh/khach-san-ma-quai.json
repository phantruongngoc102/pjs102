ân hạnh được cung cấp cho quý khách những dịch vụ tuyệt hảo nhất, nhưng những dịch vụ này chỉ dành riêng cho những hồn ma vất vưởng\\\"</p>","tmdb_id":90447,"cast":[],"director":[],"keywords":[],"tmdb":{"id":90447},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/kh/khach-san-ma-quai.json"}