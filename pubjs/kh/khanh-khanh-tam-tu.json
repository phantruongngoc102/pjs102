 ức mà vào kinh, hai người trải qua nhiều sự cố, hỗ trợ lẫn nhau và cuối cùng đã tạo nên một câu chuyện tình yêu đẹp.","tmdb_id":235369,"cast":["Triệu Gia Mẫn","Lý Phi","Li Ji","Yu Yangzi","Minh Gia Gia","Zhang Chi","Liu Ning"],"director":["Zhou Xiao"],"keywords":[],"tmdb":{"type":"tv","id":"235369","season":1,"vote_average":8,"vote_count":1},"cast_meta":[{"name":"Triệu Gia Mẫn","name_vi":"Triệu Gia Mẫn","name_original":"Zhao Jiamin","tmdb_id":4280942,"profile":"https://image.tmdb.org/t/p/w500/aNEoa4wVDqa5gMzXxC55DX2SaMW.jpg","tmdb_url":"https://www.themoviedb.org/person/4280942"},{"name":"Lý Phi","name_vi":"Lý Phi","name_original":"Richard Li","tmdb_id":3264069,"profile":"https://image.tmdb.org/t/p/w500/cZRBQnxvNTulyL2aBrUMu0RjMoh.jpg","tmdb_url":"https://www.themoviedb.org/person/3264069"},{"name":"Li Ji","name_vi":null,"name_original":"Li Ji","tmdb_id":3327734,"profile":"https://image.tmdb.org/t/p/w500/2NyP9HcD89qlHfkTZPRO2sDmSv3.jpg","tmdb_url":"https://www.themoviedb.org/person/3327734"},{"name":"Yu Yangzi","name_vi":null,"name_original":"Yu Yangzi","tmdb_id":3723582,"profile":"https://image.tmdb.org/t/p/w500/2aIIjr7fFsT1ZyYkcaRNpOygvL6.jpg","tmdb_url":"https://www.themoviedb.org/person/3723582"},{"name":"Minh Gia Gia","name_vi":"Minh Gia Gia","name_original":"Ming Jiajia","tmdb_id":3704716,"profile":"https://image.tmdb.org/t/p/w500/eHtb6uehxwrW8RIeemV0idHAtIN.jpg","tmdb_url":"https://www.themoviedb.org/person/3704716"},{"name":"Zhang Chi","name_vi":null,"name_original":"Zhang Chi","tmdb_id":4216856,"profile":"https://image.tmdb.org/t/p/w500/1KzBFf1SzlF7lYT7MlDDVX5S8YC.jpg","tmdb_url":"https://www.themoviedb.org/person/4216856"},{"name":"Liu Ning","name_vi":null,"name_original":"Liu Ning","tmdb_id":4903156,"profile":"https://image.tmdb.org/t/p/w500/fzmouuf1k7ONUaKe906EQ7I5lwo.jpg","tmdb_url":"https://www.themoviedb.org/person/4903156"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/kh/khanh-khanh-tam-tu.json"}