4_8b2bce10/index.m3u8"},{"name":"26A","slug":"26a","link_embed":"https://vip.opstream11.com/share/6ee684091fe7cba88c97f114350cb2ea","link_m3u8":"https://vip.opstream11.com/20220517/25282_35b406ff/index.m3u8"},{"name":"26B","slug":"26b","link_embed":"https://vip.opstream11.com/share/4b5fb5ef53ac99fb4961f6844ce0dd43","link_m3u8":"https://vip.opstream11.com/20220517/25286_c16e59ff/index.m3u8"},{"name":"27A","slug":"27a","link_embed":"https://vip.opstream11.com/share/1ef039b8c360653698d917512eb41140","link_m3u8":"https://vip.opstream11.com/20220517/25285_5b3deeb2/index.m3u8"},{"name":"27B","slug":"27b","link_embed":"https://vip.opstream11.com/share/793a0cce41071c3362bed8fddeaa2b15","link_m3u8":"https://vip.opstream11.com/20220517/25287_33c31d9f/index.m3u8"}]}],"description":"<p>Xem Phim Miễn Phí: Bộ phim Khát Vọng Giàu Sang - Talay Rissaya kể về vợ chồng Dujdao và Ekarin là chủ của một khách sạn giàu có. Một ngày, khi Dujdao và Ekarin dạo chơi trong thuyền, có một cơn bão lớn xuất hiện, Dujdao và con gái mất tích, được một ngư dân cứu sống. Pavinee, người hầu của gia đình, trở thành vợ lẽ của Ekarin. 23 năm sau, Pat - con trai riêng của Pavinee - cũng dọn vào sống ở resort. Tại đây, anh gặp Fah Sai, cô gái trẻ đang làm việc chăm chỉ ở đây và được ông chủ Ekarin quý mến vô cùng. Pavinee quyết tâm ngăn cản tình yêu của đôi trẻ, vô tình biết được Fah Sai chính là cô con gái của chồng mất tích bao nhiêu năm qua. Với tham vọng và âm mưu sâu độc, Pavinee sẽ làm gì khi biết được sự thật?</p>","tmdb_id":87284,"cast":["Wannarot Sonthichai","Jes Jespipat Tilapornputt","Phiyada Jutharattanakul","Saksit Tangthong","Amika Klinpratoom","Cholawit Meetongcom","Koravich Sarasin","Vorarit Fuangarome","Janistar Phomphadungcheep"],"director":[],"keywords":[],"time":"45 phút","tmdb":{"type":"tv","id":"87284","season":1,"vote_average":8,"vote_count":1},"cast_meta":[{"name":"Wannarot Sonthichai","name_vi":null,"name_original":"Wannarot Sonthichai","tmdb_id":1344504,"profile":"https://image.tm