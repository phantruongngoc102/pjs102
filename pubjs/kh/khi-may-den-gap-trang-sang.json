://vip.opstream15.com/share/732e8277feb283afe0c4703473dae5fa","link_m3u8":"https://vip.opstream15.com/20221017/27423_c991b522/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Ô Ngộ và Đàm Giảo gặp nhau trên một chiếc du thuyền du lịch, hai người vừa gặp đã yêu. Sau chuyến du lịch, hai người cùng mất đi một phần trí nhớ, Ô Ngộ quên mất ký ức mấy ngày sau khi chuyến du lịch kết thúc, Đàm Giảo mất đi ký ức gần một năm rưỡi. Ô Ngộ là một học bá phát triển toàn diện, tiền đồ như gấm, nhưng sau chuyến du lịch cuộc đời anh thay đổi kinh thiên động địa, mẹ và em gái của mình bị giết. Vì để tìm ra hung thủ, anh buông bỏ tiền đồ trở thành thợ sửa xe hơi. Đàm Giảo gặp lại anh lúc đến sửa xe, sau đó bỗng cách nửa tháng hai người sẽ xuyên không một lần.</p>","tmdb":{"type":"tv","id":"116132","season":1,"vote_average":6.6,"vote_count":5},"modified":"2025-05-21T13:14:52.000Z","cast":["Lý Nhất Đồng","Kim Hãn","Tăng Khả Ny","Vương Tử Duệ"],"director":["Cai Cong","Yu Chung-chung"],"cast_meta":[{"name":"Lý Nhất Đồng","name_vi":"Lý Nhất Đồng","name_original":"Li Yitong","tmdb_id":1736257,"profile":"https://image.tmdb.org/t/p/w500/jfostFmHde0D1Wj9F57GWHEVzmO.jpg","tmdb_url":"https://www.themoviedb.org/person/1736257"},{"name":"Kim Hãn","name_vi":"Kim Hãn","name_original":"Jin Han","tmdb_id":2123398,"profile":"https://image.tmdb.org/t/p/w500/lelUjhsbZve5AMe2RWD1L9RCkXs.jpg","tmdb_url":"https://www.themoviedb.org/person/2123398"},{"name":"Tăng Khả Ny","name_vi":"Tăng Khả Ny","name_original":"Jenny Zeng","tmdb_id":2376754,"profile":"https://image.tmdb.org/t/p/w500/c0iALcsclRIpkx0XGsbWWqvQIOx.jpg","tmdb_url":"https://www.themoviedb.org/person/2376754"},{"name":"Vương Tử Duệ","name_vi":"Vương Tử Duệ","name_original":"Wang Zirui","tmdb_id":2236383,"profile":"https://image.tmdb.org/t/p/w500/k6bEsfbPstOi0XtX6qg0Yo9fAYY.jpg","tmdb_url":"https://www.themoviedb.org/person/2236383"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/kh/khi-may-den-gap-trang-s