.opstream90.com/20260113/22307_63cd917a/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/3d20badc2e5a7bf74ce0fc12cabfbd92","link_m3u8":"https://vip.opstream90.com/20260114/22365_3d20badc/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream90.com/share/67f098b0f09ef0f126d271764cf270fc","link_m3u8":"https://vip.opstream90.com/20260115/22514_67f098b0/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream90.com/share/246ba26b5b33d037405f55b240be4777","link_m3u8":"https://vip.opstream90.com/20260116/22559_246ba26b/index.m3u8"}]}],"description":"<p>Vào những năm 80, Mã Đinh và ba người bạn thân thiết như anh em ruột thịt cùng nhau lớn lên trong một con ngõ nhỏ ở Bắc Kinh. Trước ngày tốt nghiệp cấp ba, Mã Đinh gây ra một biến cố khiến tình bạn của họ tan vỡ, mỗi người một ngả. Thanh xuân qua đi, Mã Đinh đi nước ngoài, kể từ đó bặt vô âm tín. Nhiều năm sau, Mã Đinh - nay đã trở thành phó tổng một công ty niêm yết - bỗng dưng phát hiện mình bị u não, anh cứ thế đơn độc bình tĩnh chờ đợi cái chết. Tuy nhiên, trong lòng Mã Đinh vẫn có nỗi day dứt khôn nguôi khiến anh không thể nào từ bỏ. Anh muốn trước khi rời khỏi thế giới này tháo gỡ khúc mắc xưa, hàn gắn lại tình bạn. Bốn người trung niên cùng nhau gây dựng sự nghiệp, cuộc sống của cả bốn người đều thay đổi, tình bạn giữa họ cũng dần dần được hàn gắn, và Mã Đinh cũng một lần nữa dấy lên hy vọng về cuộc sống.</p><p>&nbsp;</p>","tmdb_id":257789,"cast":["Hoắc Kiến Hoa","Điền Vũ","Trương Tuyết Nghênh","Kiều Chấn Vũ","Lưu Đoan Đoan","Tùy Tuấn Ba","Zhang Yao","Xue Haojing"],"director":["Qing Hua"],"keywords":[],"tmdb":{"type":"tv","id":"257789","season":1,"vote_average":6.3,"vote_count":3},"cast_meta":[{"name":"Hoắc Kiến Hoa","name_vi":"Hoắc Kiến Hoa","name_original":"Wallace Huo","tmdb_id":1192904,"profile":"https://image.tmdb.org/t/p/w500/kiuLPAKlIT98fgjuwnYF9u6Wus7.jpg","tmdb_url":"https://www.themoviedb.org/person/1192904"},{"name":"Điền Vũ","name_vi":"