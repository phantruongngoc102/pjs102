x.m3u8"},{"name":"31","slug":"31","filename":"Khó Dỗ Dành - Tập 31---2025","link_embed":"https://vip.opstream90.com/share/c4fa7aecedac73641320d24d5bf3bf38","link_m3u8":"https://vip.opstream90.com/20250310/3613_c4fa7aec/index.m3u8"},{"name":"32","slug":"32","filename":"Khó Dỗ Dành - Tập 32---2025","link_embed":"https://vip.opstream90.com/share/6add07cf50424b14fdf649da87843d01","link_m3u8":"https://vip.opstream90.com/20250310/3614_6add07cf/index.m3u8"}]}],"time":"47 phút/tập","description":"Kể về một chuyện tình đầy trắc trở của đôi bạn trẻ Ôn Dĩ Phàm và Tang Diên khi họ phải yêu đi yêu lại và đối mặt với những rào cản mà đối với nhiều người có thể là sẽ phải sớm buông tay. Ôn Dĩ Phàm là một cô gái trẻ trung, nhiệt huyết và luôn khao khát khám phá những điều mới mẻ, tình đầu của cô là Tang Diên, một anh chàng khá điển trai và phong lưu.\n\nTuy nhiên mọi thứ quay ngoắt lại và họ phải chia tay để mỗi người bước đi trên con đường của riêng mình. Cho đến khi gặp lại ở một bán bar, họ vờ như không nhận ra nhau, thử lòng nhau và cũng muốn bắt đầu thêm một lần nữa. Khi mà cả Ôn Dĩ Phàm và Tang Diên nhận ra được tình cảm của mình là hoàn toàn chân thật thì họ lại một lần nữa vướng phải những rào cản từ phía gia đình và cả công việc. Cuối cùng thì họ nhận ra rằng chỉ tình yêu đích thực mới đưa họ vượt qua được những rào cản và có thể đến với nhau một cách bền vững nhất.","tmdb":{"type":"tv","id":"250060","season":1,"vote_average":8.443,"vote_count":61},"modified":"2025-03-10T12:06:25.000Z","cast":["Bạch Kính Đình","Chương Nhược Nam","Trần Hạo Sâm","Trương Miểu Di","Trạch Tiêu Văn","Nguyên Dã","Chen Jianan","Phó Miểu","Feng Yunzhi"],"director":["瞿友寧"],"cast_meta":[{"name":"Bạch Kính Đình","name_vi":"Bạch Kính Đình","name_original":"Bai Jingting","tmdb_id":1672869,"profile":"https://image.tmdb.org/t/p/w500/b3kmtLVQtgywB1QKWYHoNLsdqSO.jpg","tmdb_url":"https://www.themoviedb.org/person/1672869"},{"name":"Chương Nhược Nam","name_vi":"Chương Nhược Nam","name_original":"Z