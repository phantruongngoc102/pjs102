om/share/2281165f5495a1c5b48a776ab6a8c8df","link_m3u8":"https://vip.opstream14.com/20230403/34591_e79d8b4d/index.m3u8"}]}],"time":"45 phút/tập","description":"Tại Đại học Khoa học và Công nghệ Đông Nam, một trường kỹ thuật nổi tiếng trong nước, tỷ lệ nam nữ là 7:1 , vậy mà sinh viên ngành sinh vật Tô Trinh Trinh chưa bao giờ có thể thoát ế. Cho đến một ngày, một loạt cuộc gặp gỡ kỳ lạ, lãng mạn và kỳ diệu giữa Tô Trinh Trinh và \\\"thần nghiên cứu khoa học\\\" Tiêu Vũ Hà đã diễn ra. Do bốc đồng, Trinh Trinh đã đến gặp Vũ Hà và ttỏ tình: \\\"Em thích anh\\\". Thật bất ngờ, cô được đưa vào phòng thí nghiệm não bộ và trí thông minh, để thử nghiệm, bằng cách sử dụng các phương pháp khoa học như khoa học não bộ, y học thần kinh và tâm lý học để xác minh \\\"tình cảm\\\" của cô dành cho anh. Tuy nhiên, trong một thí nghiệm tình yêu được cho là ngọt ngào, Trinh Trinh phát hiện ra rằng Vũ Hà đầy \\\"ác ý\\\"...","tmdb":{"type":"tv","id":"222320","season":1,"vote_average":4.7,"vote_count":3},"modified":"2025-04-01T11:52:57.000Z","cast":["Liu Yichang","Ngô Giai Di","Trần Hạo Lam","Wu Fei","Gao Yuhang","Yao Yiqi","Wang Meiyan"],"director":["Hao Fei Huan"],"cast_meta":[{"name":"Liu Yichang","name_vi":null,"name_original":"Liu Yichang","tmdb_id":2609007,"profile":"https://image.tmdb.org/t/p/w500/sfYQAiJY1y5Y0X6kCyiIePiRrjG.jpg","tmdb_url":"https://www.themoviedb.org/person/2609007"},{"name":"Ngô Giai Di","name_vi":"Ngô Giai Di","name_original":"Wu Jiayi","tmdb_id":2459066,"profile":"https://image.tmdb.org/t/p/w500/eVVguFgs2NNIOlRUgAYbCxb1R3h.jpg","tmdb_url":"https://www.themoviedb.org/person/2459066"},{"name":"Trần Hạo Lam","name_vi":"Trần Hạo Lam","name_original":"Chen Haolan","tmdb_id":2150003,"profile":"https://image.tmdb.org/t/p/w500/jyjIunAcma6jGcTSUWeN29L3sxd.jpg","tmdb_url":"https://www.themoviedb.org/person/2150003"},{"name":"Wu Fei","name_vi":null,"name_original":"Wu Fei","tmdb_id":3965172,"profile":"https://image.tmdb.org/t/p/w500/jA5jwtCXIODNr1vbLjGPMiMrek6.jpg","tmdb