i người dần dần nảy sinh tình cảm. Khỏe Trước Yêu Sau (Pump Up The Healthy Love) hứa hẹn sẽ mang đến những thông điệp ý nghĩa và tích cực về sự tự tin và khởi đầu mới.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"260555","season":1,"vote_average":7.4,"vote_count":16},"modified":"2025-06-06T00:28:07.000Z","cast":["Lee Jun-young","Jung Eun-ji","Lee Mi-do","Lee Da-eun","Park Seong-yeon","Lee Seung-woo","Hong Yun-hwa","Jung Wook-jin","Nam Kyu-hee","Lee Sang-jin","Kim Kwon","Choi Seol-hwa"],"director":["Park Jun-soo","Choi Yeon-su"],"cast_meta":[{"name":"Lee Jun-young","name_vi":null,"name_original":"Lee Jun-young","tmdb_id":1904058,"profile":"https://image.tmdb.org/t/p/w500/zH8kiGox6n3FD82MKEhUq79X6gj.jpg","tmdb_url":"https://www.themoviedb.org/person/1904058"},{"name":"Jung Eun-ji","name_vi":null,"name_original":"Jung Eun-ji","tmdb_id":1257603,"profile":"https://image.tmdb.org/t/p/w500/omS5dArrZFSj6mFy0FfbhHzHMGi.jpg","tmdb_url":"https://www.themoviedb.org/person/1257603"},{"name":"Lee Mi-do","name_vi":null,"name_original":"Lee Mi-do","tmdb_id":994300,"profile":"https://image.tmdb.org/t/p/w500/uwr67BaJDF0xiiUZ2C56M61U7g3.jpg","tmdb_url":"https://www.themoviedb.org/person/994300"},{"name":"Lee Da-eun","name_vi":null,"name_original":"Lee Da-eun","tmdb_id":3673215,"profile":"https://image.tmdb.org/t/p/w500/ccnG7V1xpwTgzKdT7eD39Vrb0X5.jpg","tmdb_url":"https://www.themoviedb.org/person/3673215"},{"name":"Park Seong-yeon","name_vi":null,"name_original":"Park Seong-yeon","tmdb_id":1793045,"profile":"https://image.tmdb.org/t/p/w500/30aZicvfKu8ey6YCFrThpD2lsLR.jpg","tmdb_url":"https://www.themoviedb.org/person/1793045"},{"name":"Lee Seung-woo","name_vi":null,"name_original":"Lee Seung-woo","tmdb_id":4365677,"profile":"https://image.tmdb.org/t/p/w500/Ail0c4xZ2gwfVmlayIh28TFUSqn.jpg","tmdb_url":"https://www.themoviedb.org/person/4365677"},{"name":"Hong Yun-hwa","name_vi":null,"name_original":"Hong Yun-hwa","tmdb_id":1252866,"profile":"https://image.tmdb.org/t/p/w500/76FHoqkTkoAyHp