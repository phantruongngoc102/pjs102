/share/ea3ce3f65b0dcb09b148b728d01ee291","link_m3u8":"https://vip.opstream15.com/20230330/37160_2d3246f1/index.m3u8"},{"name":"34","slug":"34","filename":"khong-phu-thoi-gian-tap-34","link_embed":"https://vip.opstream15.com/share/25da35c3caae93fe52ceb26ba1d5adb1","link_m3u8":"https://vip.opstream15.com/20230330/37161_5dc337cd/index.m3u8"},{"name":"35","slug":"35","filename":"khong-phu-thoi-gian-tap-35","link_embed":"https://vip.opstream15.com/share/61aaff0c8c9eb2ad890af217556b3394","link_m3u8":"https://vip.opstream15.com/20230330/37162_72704e24/index.m3u8"},{"name":"36","slug":"36","filename":"khong-phu-thoi-gian-tap-36","link_embed":"https://vip.opstream15.com/share/c7204958ab2a72430f7c9c8bbea79be0","link_m3u8":"https://vip.opstream15.com/20230330/37163_8e306aa0/index.m3u8"},{"name":"37","slug":"37","filename":"khong-phu-thoi-gian-tap-37","link_embed":"https://vip.opstream15.com/share/bf050ac42411f066b9f802fe83ae053b","link_m3u8":"https://vip.opstream15.com/20230330/37164_1b3fc25b/index.m3u8"},{"name":"38","slug":"38","filename":"khong-phu-thoi-gian-tap-38","link_embed":"https://vip.opstream15.com/share/9a3fffd26a576a089927f9c34f60c7e6","link_m3u8":"https://vip.opstream15.com/20230330/37165_913c2eb1/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Lý Hiệu, từ nhỏ đã chịu ảnh hưởng tích cực từ tạp chí Resa, luôn mong ước sẽ có ngày được trở thành một biên tập thời trang của tạp chí. Sau khi tốt nghiệp đại học, cô quyết tâm đến nhà xuất bản Đông Phàm thực tập. Cô luôn tự tin rằng mình có thể trở thành nhân viên chính thức, nhưng lại chưa từng nghĩ đến việc tạp chí Resa không còn trống vị trí biên tập nào. Thất vọng vì nguyện vọng không thành, Lý Hiệu vào công viên ngồi rồi gặp được một chàng trai cũng đang có tâm trạng giống mình. Chàng trai trẻ đã dùng những lời văn câu chữ của mình để cổ vũ cho Lý Hiệu. Cô cũng động viên chàng trai rất nhiều. Hạt giống tình yêu được gieo trồng từ đó.</p>","tmdb":{"type":"tv","id":"94842","season":1,"vote_average":0,"vote_coun