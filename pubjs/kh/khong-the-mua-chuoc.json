{"id":"64d97d9d6f63d8738af55061","title":"Không Thể Mua Chuộc","origin_name":"The Untouchables","slug":"khong-the-mua-chuoc","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/kh/khong-the-mua-chuoc.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/kh/khong-the-mua-chuoc.webp","year":1987,"type":"single","genre":[{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"The Untouchables - Không Thể Mua Chuộc - 1987","link_embed":"https://vip.opstream14.com/share/9d8f603b6ac6aeab2c10c00d15979c89","link_m3u8":"https://vip.opstream14.com/20230814/39026_a6071dae/index.m3u8"}]}],"time":"119 Phút","description":"Nội dung phim lấy bối cảnh thành phố Chicago đầu thế kỉ 20, khi tội phạm đầy rẫy ngoài đường và những băng nhóm xã hội đen mặc sức tung hoành. Al Capone – kẻ đứng đầu thế giới ngầm đã tạo nên một thế lực bất khả xâm phạm, nhưng vỏ quýt dày có móng tay nhọn. Chính phủ Liên bang Mỹ đã đích thân tuyển chọn và lập ra một đội cảnh sát thông minh dũng cảm và không bao giờ có thể mua chuộc được họ. Chuyện phim xoay quanh cuộc chiến đẫm máu của nhóm cảnh sát này với những tên tội phạm nguy hiểm.\r Phim có góc nhìn rộng về cuộc chiến trong thế giới tội phạm vào những năm 1920, cùng với đó là nhiều tiếng cười và âm nhạc hoành tráng tạo dấu ấn sâu sắc cho khán giả. Nhiều ý kiến cho rằng, không phải Scarface mà chính The Untouchables mới là phim tội phạm xuất sắc nhất của Palma. Phim đã trở thành một trong những “bom tấn” của thập niên 80 và cũng là phim về mafia xuất sắc của giai đoạn này.","tmdb":{"type":"movie","id":"117","season":null,"vote_average":7.756,"vote_count":6042},"modified":"2023-08-14T08:04:31.000Z","cast":["Kevin Costner","Sean Connery","Robert De Niro","Charles Martin Smith","Andy Garcia","Richard Bradford","Jack Kehoe","Brad Sullivan","Billy Drago","Patricia Clarkson","Vito D'Ambrosio","Steven Goldstein","Peter Aylward","Don Harvey","Robert Swan"],"director":["Brian De Palma"],"cast_meta":[{"name":"Kevin Costner","name_vi":null,"name_original":"Kevin Costner","tmdb_id":1269,"profile":"https://image.tmdb.org/t/p/w500/608blZipRDZkDpzp8VItB64qMaT.jpg","tmdb_url":"https://www.themoviedb.org/person/1269"},{"name":"Sean Connery","name_vi":null,"name_original":"Sean Connery","tmdb_id":738,"profile":"https://image.tmdb.org/t/p/w500/hbB676mW62gjsh0f51ICYE11niG.jpg","tmdb_url":"https://www.themoviedb.org/person/738"},{"name":"Robert De Niro","name_vi":null,"name_original":"Robert De Niro","tmdb_id":380,"profile":"https://image.tmdb.org/t/p/w500/cT8htcckIuyI1Lqwt1CvD02ynTh.jpg","tmdb_url":"https://www.themoviedb.org/person/380"},{"name":"Charles Martin Smith","name_vi":null,"name_original":"Charles Martin Smith","tmdb_id":1270,"profile":"https://image.tmdb.org/t/p/w500/uzm5v0Q7nCH223EvPiJyh9Y0qiN.jpg","tmdb_url":"https://www.themoviedb.org/person/1270"},{"name":"Andy Garcia","name_vi":null,"name_original":"Andy Garcia","tmdb_id":1271,"profile":"https://image.tmdb.org/t/p/w500/9EivXoBlczZcFBet96WOoFbDsfF.jpg","tmdb_url":"https://www.themoviedb.org/person/1271"},{"name":"Richard Bradford","name_vi":null,"name_original":"Richard Bradford","tmdb_id":1272,"profile":"https://image.tmdb.org/t/p/w500/kGCq5DdgmhK5tL9P87SwmsJigPz.jpg","tmdb_url":"https://www.themoviedb.org/person/1272"},{"name":"Jack Kehoe","name_vi":null,"name_original":"Jack Kehoe","tmdb_id":1273,"profile":"https://image.tmdb.org/t/p/w500/bwsY19BaN9vF21XuH8nVZrEAplo.jpg","tmdb_url":"https://www.themoviedb.org/person/1273"},{"name":"Brad Sullivan","name_vi":null,"name_original":