ps://vip.opstream17.com/share/e0b60d939b4a80628dfd66b1e0bb65fa","link_m3u8":"https://vip.opstream17.com/20240425/5941_fe8ce42e/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream17.com/share/b0dd033cbe58aa5ea27747271bfd84e3","link_m3u8":"https://vip.opstream17.com/20240425/5942_49ef3780/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream17.com/share/9a3f54913bf27e648d1759c18d007165","link_m3u8":"https://vip.opstream17.com/20240425/5943_c4cb2ec4/index.m3u8"}]}],"description":"<p>Học bá Vật lý Hoa Nghê bất ngờ xuyên không đến thành Khổng Tước và vô tình trở thành thánh sứ của phái Khổng Tước. Hoa Nghê quanh quẩn giữa phái Khổng Tước coi cô như cái đinh trong mắt, và tổ chức sát thủ bí ẩn Bách Hoa Sát. Dưới sự giúp đỡ của Lễ bộ lang trung Lý Mục Dương, Hoa Nghê đã chuyển nguy thành an. Khi Hoa Nghê đang rung động trước nam tử tuấn nhã, ôn hòa và biết lễ nghĩa này, cô lại phát hiện anh chính là thủ lĩnh của Bách Hoa Sát. Hoa Nghê từ từ cảm nhận được mục tiêu của Bách Hoa Sát là cứu rỗi dân chúng và bảo vệ chân lý. Vì vậy, Hoa Nghê quyết tâm cùng Lý Mục Dương giúp đỡ dân chúng thành Khổng Tước. Trong quá trình này, họ dần trở nên thấu hiểu và đồng cam cộng khổ. Tuy nhiên, khi họ chuẩn bị cho đại hôn sắp tới, những bí mật từ quá khứ bất ngờ được hé lộ...</p>","tmdb_id":252064,"cast":["Châu Tuấn Vỹ","Zhang Chuhan","Xu Muchan","Jerron Wu","Rocky Du"],"director":["Hanyang Liu"],"keywords":[],"tmdb":{"type":"tv","id":"252064","season":1,"vote_average":7,"vote_count":1},"cast_meta":[{"name":"Châu Tuấn Vỹ","name_vi":"Châu Tuấn Vỹ","name_original":"Jacky Zhou","tmdb_id":3044436,"profile":"https://image.tmdb.org/t/p/w500/tBpjurRC7xiYwV3tMScLnE0NDiN.jpg","tmdb_url":"https://www.themoviedb.org/person/3044436"},{"name":"Zhang Chuhan","name_vi":null,"name_original":"Zhang Chuhan","tmdb_id":3503856,"profile":"https://image.tmdb.org/t/p/w500/726OGXSWm31nWPnsL011Jl80Mks.jpg","tmdb_url":"https://www.themoviedb.org/person/3503856"},{"name":"Xu Muc