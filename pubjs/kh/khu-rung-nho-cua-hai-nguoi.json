om/share/8ebef38fe0b242f7c7a87e7f5b2de305","link_m3u8":"https://vip.opstream15.com/20230108/31230_688ff9df/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Kể về câu chuyện tình yêu giữa giáo sư thực vật Trang Vũ (Trương Bân Bân) và bà chủ nhà trọ Ngu Mỹ Nhân (Ngu Thư Hân). Vì công việc, Trang Vũ phải tới thôn Thanh Thủy khảo sát nghiên cứu, nghỉ chân tại một nhà trọ do nhà Ngu Mỹ Nhân mở, hai người lại gặp nhau. Ngu Mỹ Nhân đã thích Trang Vũ từ trước, vì thế nhờ cơ hội này để \"cưa cẩm\" chàng.</p>","tmdb":{"type":"tv","id":"135185","season":1,"vote_average":7.3,"vote_count":12},"modified":"2023-01-09T00:30:34.000Z","cast":["Trương Bân Bân","Ngu Thư Hân","Li Jiaqi","Đinh Quán Sâm","Jerron Wu","An Ge","Liu Jieyi"],"director":["Cai Cong"],"cast_meta":[{"name":"Trương Bân Bân","name_vi":"Trương Bân Bân","name_original":"Vin Zhang","tmdb_id":1701963,"profile":"https://image.tmdb.org/t/p/w500/8LvvrOhj4zxPuYgpPJ9HWyJzf4a.jpg","tmdb_url":"https://www.themoviedb.org/person/1701963"},{"name":"Ngu Thư Hân","name_vi":"Ngu Thư Hân","name_original":"Yu Shuxin","tmdb_id":2140103,"profile":"https://image.tmdb.org/t/p/w500/xQ2Bur9AEy0IX3qHMvLbr7tmTyD.jpg","tmdb_url":"https://www.themoviedb.org/person/2140103"},{"name":"Li Jiaqi","name_vi":null,"name_original":"Li Jiaqi","tmdb_id":1207608,"profile":"https://image.tmdb.org/t/p/w500/irRmvwQmWDaKJ270nZSSdSYGyrt.jpg","tmdb_url":"https://www.themoviedb.org/person/1207608"},{"name":"Đinh Quán Sâm","name_vi":"Đinh Quán Sâm","name_original":"Ding Guansen","tmdb_id":1780717,"profile":"https://image.tmdb.org/t/p/w500/iuf2pu3drbiYMsqW3DEIbpxaPt8.jpg","tmdb_url":"https://www.themoviedb.org/person/1780717"},{"name":"Jerron Wu","name_vi":null,"name_original":"Jerron Wu","tmdb_id":3362027,"profile":"https://image.tmdb.org/t/p/w500/A006tf0uJWMSD7mjdqUdDqCD3L6.jpg","tmdb_url":"https://www.themoviedb.org/person/3362027"},{"name":"An Ge","name_vi":null,"name_original":"An Ge","tmdb_id":3218876,"profile":"https://image.tmdb.org/t/p/w500/sce4lVzk