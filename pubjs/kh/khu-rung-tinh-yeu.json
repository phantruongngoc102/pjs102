1.com/share/9b3c2148ce85c4124006e10631e77b28","link_m3u8":"https://vip.opstream11.com/20220818/35734_0f21515b/index.m3u8"},{"name":"16","slug":"16","filename":"khu-rung-tinh-yeu--eps-tap-16","link_embed":"https://vip.opstream11.com/share/d5882d22ec8a123cd6e4a50432049d67","link_m3u8":"https://vip.opstream11.com/20220818/35735_732731c6/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Phim xoay quanh anh chàng Kang San Hyuk (Park Hae Jin), Tổng giám đốc một tập đoàn đầu tư hàng đầu trong nước. Sau đó vì để điều tra ẩn khuất trong khu rừng Miryeong mà trở thành đội viên của đội cứu hộ trên không thuộc nhóm cứu hộ đặc biệt 119 Miryeong. Thông minh và điển trai, nhưng Kang San Hyuk không may mất hết kí ức trong quá khứ. Trong khi đó, Jung Young Jae (Jo Bo Ah) là một bác sĩ nội trú nhiệt huyết. Cả hai đã gặp nhau trong khu rừng Miryeong kì bí. Dù không muốn, Kang San Hyuk và Jung Young Jae buộc phải sống cùng nhau tại đây. Không lâu sau đó, cả hai dần tìm hiểu được nhiều bí mật xoay quanh họ, và thậm chí là cả khu rừng bí ẩn này.</p>","tmdb":{"type":"tv","id":"97565","season":1,"vote_average":7.1,"vote_count":18},"modified":"2022-08-19T07:01:39.000Z","cast":["Park Hae-jin","Cho Bo-ah","Jeong Yeon-joo","No Gwang-Sik","Ryu Seung-su","Lee Do-gyeong","Lee Si-hoon","Woo Jung-kook","Ahn Sang-woo","Koh Soo-hee","Geum Gwang-san","Choi Gwang-il","Shim Hye-rim","Kim Min-seok"],"director":["Oh Jong Rok"],"cast_meta":[{"name":"Park Hae-jin","name_vi":null,"name_original":"Park Hae-jin","tmdb_id":1244834,"profile":"https://image.tmdb.org/t/p/w500/hiSahEWd1VH0UXgFpZlMLqaS8JG.jpg","tmdb_url":"https://www.themoviedb.org/person/1244834"},{"name":"Cho Bo-ah","name_vi":null,"name_original":"Cho Bo-ah","tmdb_id":1256349,"profile":"https://image.tmdb.org/t/p/w500/1torx99sDl20pTzMI9XHaPuVP96.jpg","tmdb_url":"https://www.themoviedb.org/person/1256349"},{"name":"Jeong Yeon-joo","name_vi":null,"name_original":"Jeong Yeon-joo","tmdb_id":1552969,"profile":"https://image.tmdb.org/t/p/w500/10Woy