9be","link_m3u8":"https://vip.opstream15.com/20220511/13112_4ae253a7/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream15.com/share/40bf82623caded1cd84332d5e3cf4d72","link_m3u8":"https://vip.opstream15.com/20220511/13114_62e77383/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream15.com/share/6b45b57b849fe8c82ea4358a949a753d","link_m3u8":"https://vip.opstream15.com/20220511/13117_36a050b5/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream15.com/share/0c6fc0ac5afb01a75fe1910da98db915","link_m3u8":"https://vip.opstream15.com/20220511/13120_4d3d26ae/index.m3u8"}]}],"description":"<p>Bộ phim bắt đầu với cảnh Thiên Hữu đang đuổi bắt cướp. Trân Trân đến gặp anh và bị bắt làm con tin, nhưng Thiên Hữu đã giải cứu cô kịp lúc. Trong khi đó, Tiểu Linh đang làm người mẫu (bán thời gian) vì cô cần tiền để thanh toán các khoản nợ của thẻ tín dụng. Hóa ra tất cả các người mẫu đều là cương thi và họ đang tìm kiếm một viên đá quý có tên là Nước mắt thiên thần. Tiểu Linh và đệ tử của mình là Chánh Trung hợp sức chiến đấu với 7 cô người mẫu. Sau đó, họ khám phá ra rằng những cô người mẫu này đến từ Anh Quốc nên họ cũng tìm đến Anh Quốc và tại đây họ đã quen với 1 cương thi và khám phá ra quá khứ của ông ta. Họ phá được vụ án và trở về Hồng Kông, nhưng những người bạn của Thiên Hữu cũng khám phá rằng anh đã có những thay đổi. Mọi chuyện càng trở nên phức tạp hơn trong phần này khi có thêm nhân vật Tướng Thần và Nữ Oa xuất hiện ...</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/kh/khu-ta-diet-ma-2.json"}