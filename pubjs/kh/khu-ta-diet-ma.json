.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream12.com/share/a5d3526558368a8cda8a30a3c35963cb","link_m3u8":"https://vip.opstream12.com/20260130/32380_a5d35265/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/cc95aa39a060194468cf78fa7dc1cb99","link_m3u8":"https://vip.opstream12.com/20260130/32381_cc95aa39/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/1d304d9c141c271cd60a9cb5ac5e862b","link_m3u8":"https://vip.opstream12.com/20260130/32382_1d304d9c/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/7cab59661cfaa9701dba0ee2d13eb25f","link_m3u8":"https://vip.opstream12.com/20260130/32383_7cab5966/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream12.com/share/f41f94e3576a8e292c03201210b90cbb","link_m3u8":"https://vip.opstream12.com/20260130/32384_f41f94e3/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream12.com/share/8e9a0e5f19caa707db6dfae2a3551504","link_m3u8":"https://vip.opstream12.com/20260130/32385_8e9a0e5f/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream12.com/share/32492a842010652919d07f02c6de8608","link_m3u8":"https://vip.opstream12.com/20260130/32386_32492a84/index.m3u8"}]}],"description":"<p>Khử Tà Diệt Ma mở đầu bằng câu chuyện tình yêu định mệnh giữa nhân loại và cương thi, đan xen với những cuộc chiến giữa thiện – ác, người – ma trong thế giới huyền ảo.<br>Nhân vật chính Mã Tiểu Linh (Dương Tư Kỳ) là người thừa kế của dòng tộc diệt ma trứ danh, có nhiệm vụ trấn áp cương thi và tà linh. Trong một lần hành động, cô tình cờ gặp Cửu Ca (Trịnh Y Kiện) – một cương thi mang linh hồn con người, không sát hại ai và luôn đấu tranh để giữ lại phần nhân tính trong mình. Giữa hai người dần nảy sinh tình cảm, nhưng tình yêu ấy lại bị ngăn cấm bởi ranh giới sinh – tử và định mệnh nghiệt ngã.<br>Bộ phim kết hợp xuất sắc yếu tố võ thuật, kinh dị, tâm linh và lãng mạn, tạo nên một vũ trụ cương thi độc đáo của ATV, đồng thời gửi gắm thông điệp nhân văn: “Dù là người hay ma, chỉ cần có trái tim biết yêu thương, vẫn xứng đáng được sống như một con người.”</p>","tmdb_id":19389,"cast":["Joey Man Yee-Man","Eric Wan Tin-Chiu","Kenneth Chan","Trần Vỹ","Pinky Cheung Man-Chi","Wong Shu-Tong","Daniel Cheung","Thomas Sin Ho-Ying","Asuka Higuchi","Ricky Chan Po-Yuen","Trần Triển Bằng","Viên Văn Kiệt","Tần Lam","Từ Thiếu Cường","Remus Kam"],"director":["Phan Gia Đức (Wong Jing Keung)"],"keywords":[],"tmdb":{"type":"tv","id":"19389","season":1,"vote_average":8.6,"vote_count":7},"cast_meta":[{"name":"Joey Man Yee-Man","name_vi":null,"name_original":"Joey Man Yee-Man","tmdb_id":1191930,"profile":"https://image.tmdb.org/t/p/w500/xX8YV5x5aEFSU9aGxwXNElFwAoZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1191930"},{"name":"Eric Wan Tin-Chiu","name_vi":null,"name_original":"Eric Wan Tin-Chiu","tmdb_id":1247371,"profile":"https://image.tmdb.org/t/p/w500/eAygXJjiT3icxWdqyArHkkINsRr.jpg","tmdb_url":"https://www.themoviedb.org/person/1247371"},{"name":"Kenneth Chan","name_vi":null,"name_original":"Kenneth Chan","tmdb_id":1247365,"profile":"https://image.tmdb.org/t/p/w500/xA41hprmw5xoZHR0OAT2mxsJA2F.jpg","tmdb_url":"https://www.themoviedb.org/person/1247365"},{"name":"Trần Vỹ","name_vi":"Trần Vỹ","name_original":"Alice Chan Wai","tmdb_id":1021936,"profile":"https://image.tmdb.org/t/p/w500/wxRBCvpATXZ5y4ejR7JrSChmS3N.jpg","tmdb_url":"https://www.themoviedb.org/person/1021936"},{"name":"Pinky Cheung Man-Chi","name_vi":null,"name_original":"Pinky Cheung Man-Chi","tmdb_id":112982,"profile":"https://image.tmdb.org/t/p/w500/cKmeSkj1QmQIaL0OSgPoyk7I3Dz.jpg","tmdb_url":"https://www.themoviedb.org/person/112982"},{"name":"Wong Shu-Tong","name_vi":null,"name_original":"Wong Shu-Tong","tmdb_id":228462,"profile":"https://image.tmdb.org/t/p/w500/fGmTiDvp1sCsQiuqSUmXItONQB5.jpg","tmdb_url":"https://www.themoviedb.org/person/228462"},{"name":"Daniel Cheung","name_vi":null,"name_or