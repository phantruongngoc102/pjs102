e/4a5cfa9281924139db466a8a19291aff","link_m3u8":"https://vip.opstream17.com/20240429/6239_9cc1cb56/index.m3u8"},{"name":"16","slug":"","filename":"16 Khu Vuc Tuan Tra","link_embed":"https://vip.opstream17.com/share/1fc30b9d4319760b04fab735fbfed9a9","link_m3u8":"https://vip.opstream17.com/20240429/6238_55018147/index.m3u8"},{"name":"17","slug":"","filename":"17 Khu Vuc Tuan Tra","link_embed":"https://vip.opstream17.com/share/885cb47f87718a2cd8641ae79113eeea","link_m3u8":"https://vip.opstream17.com/20240429/6237_5994ac56/index.m3u8"},{"name":"18","slug":"","filename":"18 Khu Vuc Tuan Tra","link_embed":"https://vip.opstream17.com/share/1fdc0ee9d95c71d73df82ac8f0721459","link_m3u8":"https://vip.opstream17.com/20240429/6236_b1c4807a/index.m3u8"},{"name":"19","slug":"","filename":"19 Khu Vuc Tuan Tra","link_embed":"https://vip.opstream17.com/share/c5c64c10cfd77b16a03aa81f09499f25","link_m3u8":"https://vip.opstream17.com/20240429/6235_85a2c45e/index.m3u8"},{"name":"20","slug":"","filename":"20End Khu Vuc Tuan Tra","link_embed":"https://vip.opstream17.com/share/91576cbf171986154e523305a69c79d3","link_m3u8":"https://vip.opstream17.com/20240429/6234_7ad2be28/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Châu Thế Phân và Diệp Gia Tín đều là cảnh sát, nhưng mối quan hệ của hai người luôn xung đột dấn đến hai người như hai kẻ đối địch,cả hai không nhìn mặt nhau. Về sau, Phân biết rõ quá khứ của cô người yêu - Giang Bích Tình, Phân không những không ngần ngại, ngược lại anh còn động viên khích lệ Tình cố gắng vượt qua những khó khăn trong cuộc sống. Nhưng những năm tháng làm việc với nhau,Phân và Tín dần dần hiểu nhau hơn, họ giúp đỡ lẫn nhau trong công việc. Nhưng không lâu sau đó một nữ phóng viên tên xuất hiện làm cho mối quan hệ giữa hai người lại một lần nữa lâm vào bế tắc...</i></p>","tmdb":{"type":"tv","id":"109420","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-28T10:27:25.000Z","cast":["Wong Hei","Lữ Tụng Hiền","Flora Chan Wai-Shan","Elaine N