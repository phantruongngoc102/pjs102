5/18748_9226b8de/index.m3u8"},{"name":"62","slug":"62","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-62","link_embed":"https://vip.opstream15.com/share/b47122497e685d3a5ebbc85f018d1936","link_m3u8":"https://vip.opstream15.com/20220605/18751_2355b668/index.m3u8"},{"name":"63","slug":"63","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-63","link_embed":"https://vip.opstream15.com/share/b2c1a4c8e4f9c3f8efe19a903a005149","link_m3u8":"https://vip.opstream15.com/20220605/18752_4f11d138/index.m3u8"},{"name":"64","slug":"64","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-64","link_embed":"https://vip.opstream15.com/share/04706884b423f40f1a04c54e36da6038","link_m3u8":"https://vip.opstream15.com/20220605/18753_4186e853/index.m3u8"},{"name":"65","slug":"65","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-65","link_embed":"https://vip.opstream15.com/share/ef862a59a5728e21170530ebcfb17ef4","link_m3u8":"https://vip.opstream15.com/20220605/18756_e0f239c1/index.m3u8"},{"name":"66","slug":"66","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-66","link_embed":"https://vip.opstream15.com/share/eb6de71b465f16507cadfb2347a9d98f","link_m3u8":"https://vip.opstream15.com/20220605/18757_bda6bcdb/index.m3u8"},{"name":"67","slug":"67","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-67","link_embed":"https://vip.opstream15.com/share/e33bdf729e96e6de85b6ffa555ff59db","link_m3u8":"https://vip.opstream15.com/20220605/18758_4003a5a0/index.m3u8"},{"name":"68","slug":"68","filename":"khuc-nhac-thanh-binh-long-tieng-serenade-of-peaceful-joy-tap-68","link_embed":"https://vip.opstream15.com/share/61501c1f651da2774f8bb6bbec365d84","link_m3u8":"https://vip.opstream15.com/20220605/18760_7368dde3/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Thanh Bình Nhạc kể về Thời Bắc Tống, hoàng đế Triệu Trinh (Vương Khải đóng) biết được Thái hậu đương triều Lưu Nga nuôi dưỡng mình thực ra không phải là mẹ đẻ, mẹ đẻ của y là tì nữ của Thái hậu năm xưa, tên là Lý Lan Huệ. Y cảm thấy rất hổ thẹn, vì để báo đáp Lý gia, Triệu Trinh đem con gái mình thương yêu nhất – Triệu Huy Nhu (Nhậm Mẫn đóng) gả cho con cháu của Lý gia là Lý Vĩ. Trong triều đình, đại thần tân chính Khánh Lịch và quyền thần cổ hủ đối chọi gay gắt, tranh đấu nổi lên. Triệu Trinh trị quốc vô cùng gian nan, cân nhắc thế lực khắp nơi, vì đất nước mà hết lòng lo lắng. Huy Nhu cùng nội thị của mình là Lương Hoài Cát (Biên Trình đóng) cùng nhau trưởng thành, tình cảm rất sâu sắc, mà nàng đối với Lý Vĩ tư chất tầm thường vừa bất hòa lại chán ghét, cuối cùng xảy ra mâu thuẫn với gia đình nhà chồng, ban đêm bất chấp tất cả tới gõ cửa cung, phá vỡ quy củ tôn nghiêm nhất của đất nước, dẫn đến chỉ trích nặng nề, thậm chí Tư Mã Quang ở trên cung điện phải khuyên can. Triệu Trinh cả đời thuận theo ý dân khiến cho y đấu tranh day dứt giữa tình cảm cha con cùng giữ gìn kỉ cương phép nước. Cuối cùng, công chúa vì kháng cự mà nửa điên nửa dại, từ đầu tới cuối chưa từng khuất phục vận mệnh “trở thành thê tử chân chính của Lý Vĩ”, nhưng cả đời nàng lại chẳng thể gặp lại Hoài Cát…</p>","tmdb":{"type":"tv","id":"87841","season":1,"vote_average":5.7,"vote_count":3},"modified":"2025-10-27T17:57:22.000Z","cast":["Vương Khải","Giang Sơ Ảnh","Nhậm Mẫn","Dương Lặc","Biên Trình","Ye Zuxin","Yu Entai","Vương Sở Nhiên","Lưu Quân","Feng Hui","Zhang Benyu"],"director":["Trương Khai Trụ"],"cast_meta":[{"name":"Vương Khải","name_vi":"Vương Khải","name_original":"Wang Kai","tmdb_id":1559226,"profile":"https://image.tmdb.org/t/p/w500/35Lm6dPSN5qygFC5PrDbjqjWJdG.jpg","tmdb_url":"https://www.themoviedb.org/person/1559226"},{"name":"Giang Sơ Ảnh","name_vi":"Giang Sơ Ảnh","name_original":"Maggie Jiang","tmdb_id":1590275,"profile":"https://image.tmdb.org/t/p/w500/luquCFWpyv8ejXYJuyWCpUPneNe.jpg","tmdb_url":"https://www.themoviedb.org/person/1590275"},{"name":"Nhậm Mẫn","name_vi":"Nhậm Mẫn","name_or