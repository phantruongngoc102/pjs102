 Tiêu, khiến Lê Tiêu ngột ngạt không thôi. Nhược Nam và Lê Tiêu chạm mặt nhau trong một lần tình cờ, cả ba người lại bắt đầu dây dưa, Lê Tiêu vốn đã chán ngấy sự quản giáo của Hiểu Vy nên muốn nối lại tình xưa với Nhược Nam, đồng thời đề nghị chia tay với Hiểu Vy. Hiểu Vy lại trút hết mọi tội lỗi lên đầu Nhược Nam, vì thế cô xin vào công ty mới của Nhược Nam để bắt đầu kế hoạch trả thù.","tmdb":{"type":"tv","id":"224046","season":1,"vote_average":0,"vote_count":0},"modified":"2023-04-10T17:03:30.000Z","cast":["Lưu Vịnh Hi","Liu Chenglin","Mai Tong","Wang Chaoyang","Ren Zhong"],"director":["leiwang"],"cast_meta":[{"name":"Lưu Vịnh Hi","name_vi":"Lưu Vịnh Hi","name_original":"Liu Yongxi","tmdb_id":2604820,"profile":"https://image.tmdb.org/t/p/w500/sQiomQqMfY7qGU0K8xNMKXv9e3d.jpg","tmdb_url":"https://www.themoviedb.org/person/2604820"},{"name":"Liu Chenglin","name_vi":null,"name_original":"Liu Chenglin","tmdb_id":2984301,"profile":"https://image.tmdb.org/t/p/w500/2Bzbh5j6g6PCD8x97rQIu7e7VpI.jpg","tmdb_url":"https://www.themoviedb.org/person/2984301"},{"name":"Mai Tong","name_vi":null,"name_original":"Mai Tong","tmdb_id":2990398,"profile":"https://image.tmdb.org/t/p/w500/ciXKXt0gOQaYynxWIaltPQRqqBV.jpg","tmdb_url":"https://www.themoviedb.org/person/2990398"},{"name":"Wang Chaoyang","name_vi":null,"name_original":"Wang Chaoyang","tmdb_id":3856177,"profile":"https://image.tmdb.org/t/p/w500/sdOFZIHvC21XmN5QpYNuY1VpmZY.jpg","tmdb_url":"https://www.themoviedb.org/person/3856177"},{"name":"Ren Zhong","name_vi":null,"name_original":"Ren Zhong","tmdb_id":2439104,"profile":"https://image.tmdb.org/t/p/w500/mz6P3ujJkUOfMPOUImYBu1cbJfZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2439104"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/kh/khue-trung-mat-huu.json"}