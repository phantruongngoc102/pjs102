ream15.com/share/0740bb92e583cd2b88ec7c59f985cb41","link_m3u8":"https://vip.opstream15.com/20220502/10709_1cd87401/index.m3u8"},{"name":"21","slug":"21","filename":"kich-ban-tinh-yeu-cua-doi-ta-thuyet-minh-love-script-tap-21","link_embed":"https://vip.opstream15.com/share/57ebe10efddcad20314b2eb42fd3a5bd","link_m3u8":"https://vip.opstream15.com/20220502/10710_5bb476dd/index.m3u8"},{"name":"22","slug":"22","filename":"kich-ban-tinh-yeu-cua-doi-ta-thuyet-minh-love-script-tap-22","link_embed":"https://vip.opstream15.com/share/231e535a63030cd69bf4b9a07d9968bf","link_m3u8":"https://vip.opstream15.com/20220502/10711_20700220/index.m3u8"},{"name":"23","slug":"23","filename":"kich-ban-tinh-yeu-cua-doi-ta-thuyet-minh-love-script-tap-23","link_embed":"https://vip.opstream15.com/share/87efe7b5fa21d969f4ca491ed04b0149","link_m3u8":"https://vip.opstream15.com/20220502/10712_e44bc43f/index.m3u8"},{"name":"24","slug":"24","filename":"kich-ban-tinh-yeu-cua-doi-ta-thuyet-minh-love-script-tap-24","link_embed":"https://vip.opstream15.com/share/4d6ce445727ef59cc07abb95d3e4a1d4","link_m3u8":"https://vip.opstream15.com/20220502/10713_f7813ce8/index.m3u8"}]}],"time":"","description":"<p>Phim kể về Chu Tuyên Văn (Hoàn Nhan Lạc Nhung đảm nhận) là nam thần sở hữu điểm mạnh khiến bao người ghen tị gồm IQ cao, nhan sắc đẹp và bất động sản nhiều. Sau một vụ tai nạn giao thông anh mắc hội chứng hoang tưởng, suốt ngày nghĩ mình là hoàng đế bỏ bê công việc kinh doanh của công ty. Và rồi anh gặp bác sĩ tâm lý thực tập trong một lần điều trị, cô là La Khai Hoài (Trang Đạt Phi thủ vai). Vì cần tiền nuôi gia đình nên không thể chữa bệnh cho Chu Tuyên Văn, không rằng đây “vào hậu cung sâu thẳm như biển, đời người không còn ngày thái bình nữa”. Hai người ngày nào cũng đánh đánh đấm đấm, ra chiêu tiếp chiêu và trở thành đôi oan gia lúc nào không hay. Và rồi Chu Tuyên Văn không thể nào ngờ đến được vì cái bẫy do anh đặt ra nhưng nó lại trở thành bẫy cho trái tim mình.</p>","tmdb":{"type":"tv","id":"115210","season":1,"vote_average":8.5,"vote_count":2},"modified":"2022-07-03T02:11:22.000Z","cast":["Hoàn Nhanh Lạc Nhung","Trang Đạt Phi","Đới Hướng Vũ","Leo Yang","Leslie Ma","Liu Zhiwei"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Hoàn Nhanh Lạc Nhung","name_vi":"Hoàn Nhanh Lạc Nhung","name_original":"Wanyan Luorong","tmdb_id":2916833,"profile":"https://image.tmdb.org/t/p/w500/k8U05P4rCPVGTfUAwjLEh3wFGqS.jpg","tmdb_url":"https://www.themoviedb.org/person/2916833"},{"name":"Trang Đạt Phi","name_vi":"Trang Đạt Phi","name_original":"Sabrina Zhuang","tmdb_id":2611997,"profile":"https://image.tmdb.org/t/p/w500/fDAPC5xUqxMhEowcsObB8z5YsBX.jpg","tmdb_url":"https://www.themoviedb.org/person/2611997"},{"name":"Đới Hướng Vũ","name_vi":"Đới Hướng Vũ","name_original":"Dai Xiangyu","tmdb_id":1716603,"profile":"https://image.tmdb.org/t/p/w500/reNlNO5Jt7zQBWbRaMPgJEniAi6.jpg","tmdb_url":"https://www.themoviedb.org/person/1716603"},{"name":"Leo Yang","name_vi":null,"name_original":"Leo Yang","tmdb_id":2480231,"profile":"https://image.tmdb.org/t/p/w500/dOjn9t7lUVlXdMsY6JUsNXSyccp.jpg","tmdb_url":"https://www.themoviedb.org/person/2480231"},{"name":"Leslie Ma","name_vi":null,"name_original":"Leslie Ma","tmdb_id":2625134,"profile":"https://image.tmdb.org/t/p/w500/dE4Y7RAOWuOtrcMuT927Cp6GlFN.jpg","tmdb_url":"https://www.themoviedb.org/person/2625134"},{"name":"Liu Zhiwei","name_vi":null,"name_original":"Liu Zhiwei","tmdb_id":2456575,"profile":"https://image.tmdb.org/t/p/w500/wcADVRAaWE4yD3mi4alXewY21Jc.jpg","tmdb_url":"https://www.themoviedb.org/person/2456575"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ki/kich-ban-tinh-yeu-cua-doi-ta.json"}