fb3","link_m3u8":"https://vip.opstream16.com/20231130/38343_86bb3f60/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream16.com/share/401dce020a4c8619924067bb0b098f85","link_m3u8":"https://vip.opstream16.com/20231130/38342_d66ffc7e/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream16.com/share/4a5e7eaf73d59a6a1fd24878ff762889","link_m3u8":"https://vip.opstream16.com/20231130/38341_d41e848d/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream16.com/share/8e3502fa984f26f6890f4a54c4be3f8d","link_m3u8":"https://vip.opstream16.com/20231130/38340_b2942958/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream16.com/share/db5362e819448c35aafb4dc80add9aec","link_m3u8":"https://vip.opstream16.com/20231130/38339_5310d164/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream16.com/share/5761547e8b52b26d2f7f9bdc41e0336a","link_m3u8":"https://vip.opstream16.com/20231130/38338_b2fc03a6/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream16.com/share/bab0f742373b1c7c3c62aeda2e7dd8bf","link_m3u8":"https://vip.opstream16.com/20231130/38337_a981414a/index.m3u8"}]}],"description":"<p>Người đúc ra Lệ Sầu Kiếm mang họ Tiêu, Đại Sư đúc kiếm giỏi nhất chưa từng dùng kiếm, thậm chí chưa từng rút kiếm ra vì kiếm này rất hung, chỉ cần rút ra là phải thấy máu người. Đại sư thấy đó là một hung khí vĩnh viễn không thể nào giải thích nỗi. Đại Sư biết mình phạm sai lầm cho nên đã rơi lệ. Giọt lệ đó rơi vào kiếm hóa thành ngân lệ. Tiêu Đại Sư sau đó ở ẩn và giao kiếm cho đồ đệ.<br>Đại sư muốn đồ đệ hoàn thanh lới ước của mình. Nay với tuổi già đã đến. Người đồ đệ ngày xưa bây giờ đã có hai đệ tử một trai là Tiểu Cao và một gái là Hổ Phách. Ông muốn Hổ Phách phải thề bằng tính mạng của mình như ông đã từng thề với sư phụ của mình. Một là phải ở ẩn trên núi để giữ Lệ Sầu Kiếm và nếu người nào muốn lấy kiếm thì giết không tha. Hai là ông hy vọng Hổ Phách và Tiểu Cao sẽ trở thành phu thê.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ki/kiem-ngan-le-sau.json"}