"}]}],"time":"13 phút/tập","description":"<p>Tại Vương quốc Thiên Sinh, Tô Phong Chi, con gái út của tướng quân Tô Liệt, phải đối mặt với một bi kịch gia đình do người anh rể mưu mô của cô dàn dựng. Cô hợp tác với Tam hoàng tử Kiến Khánh Huân, một nạn nhân khác của âm mưu này, và cùng nhau họ vượt qua những thử thách chết người và xung đột cá nhân. Được gắn kết bởi tình yêu và khát vọng trả thù chung, họ tìm kiếm công lý và cơ hội để bắt đầu lại.</p>","tmdb":{"type":"tv","id":"278401","season":1,"vote_average":7.3,"vote_count":3},"modified":"2025-03-26T22:57:13.000Z","cast":["Phương Cẩn","Li Daikun","Yu Yilei","Wang Zihe","Gong Qiu La Mu","Ji Hongxing"],"director":["Wu Chengfeng","张铭座"],"cast_meta":[{"name":"Phương Cẩn","name_vi":"Phương Cẩn","name_original":"Fang Jin","tmdb_id":3541107,"profile":"https://image.tmdb.org/t/p/w500/zyFWHwiQkUoxD4gwhsJqXUIdaP8.jpg","tmdb_url":"https://www.themoviedb.org/person/3541107"},{"name":"Li Daikun","name_vi":null,"name_original":"Li Daikun","tmdb_id":3011364,"profile":"https://image.tmdb.org/t/p/w500/hHO4JsUta4pYGuHkfoIFmZq4TDy.jpg","tmdb_url":"https://www.themoviedb.org/person/3011364"},{"name":"Yu Yilei","name_vi":null,"name_original":"Yu Yilei","tmdb_id":4556465,"profile":"https://image.tmdb.org/t/p/w500/fQY4Z1AjngjFogUqVt88jjKGPOw.jpg","tmdb_url":"https://www.themoviedb.org/person/4556465"},{"name":"Wang Zihe","name_vi":null,"name_original":"Wang Zihe","tmdb_id":5088727,"profile":"https://image.tmdb.org/t/p/w500/A5KlgkB5SW8Ws507mLRXxnBnqWE.jpg","tmdb_url":"https://www.themoviedb.org/person/5088727"},{"name":"Gong Qiu La Mu","name_vi":null,"name_original":"Gong Qiu La Mu","tmdb_id":3547362,"profile":"https://image.tmdb.org/t/p/w500/rCNxpY92hjGdHwh2CvZZhnV0N6Q.jpg","tmdb_url":"https://www.themoviedb.org/person/3547362"},{"name":"Ji Hongxing","name_vi":null,"name_original":"Ji Hongxing","tmdb_id":5260519,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5260519"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https: