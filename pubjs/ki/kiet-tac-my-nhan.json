tream11.com/20220414/15146_b6d9e14a/index.m3u8"},{"name":"30","slug":"30","filename":"Kiệt Tác Mỹ Nhân - Cosmetology High - Tập 30","link_embed":"https://vip.opstream11.com/share/62519b8f83ec10cacb56d46342ace8f1","link_m3u8":"https://vip.opstream11.com/20220414/15147_756148f1/index.m3u8"},{"name":"31","slug":"31","filename":"Kiệt Tác Mỹ Nhân - Cosmetology High - Tập 31","link_embed":"https://vip.opstream11.com/share/ca889fd9b844559dc1d47b4a52d5e40b","link_m3u8":"https://vip.opstream11.com/20220414/15148_f1bd0a3a/index.m3u8"},{"name":"32","slug":"32","filename":"Kiệt Tác Mỹ Nhân - Cosmetology High - Tập 32","link_embed":"https://vip.opstream11.com/share/45847868f97554aaf56672aab3f644e9","link_m3u8":"https://vip.opstream11.com/20220414/15149_9da26ed7/index.m3u8"}]}],"time":"44phút/tập","description":"<p>Phim kể về một vị thái y tài ba bậc nhất Hạ Lan Quân. Y là một người khá kiêu ngạo và tự cao tự đại. Nhiều chuyện rắc rối đã xảy ra sau đó: Sa cơ thất thế, vợ gian díu với quản gia sinh ra con trai (Trước tưởng đây là con mình), phải vào kỹ viện làm phục vụ... Từ đây, người đệ tử của anh thay thế chức vụ của anh phục vụ cho Võ Tắc Thiên, còn anh phải lang thang đường phố kiếm sống qua ngày, bị những tên quan tép riu ăn hiếp, bị bọn ăn mày đánh đập. Rất may, vẫn còn một vị cô nương xinh đẹp tên Tô Liên Y vẫn rất yêu anh ta nên đã giúp anh ta qua cơn đói ban đầu, cô còn bán cả gia sản, giải tán kỹ viện của cô để giúp Hạ Lan Quân. Hạ Lan Quân là một người có thực tài, anh vẫn đối đầu với người học trò năm xưa đã mưu đồ hãm hại mình.</p>","tmdb":{"type":"tv","id":"90713","season":1,"vote_average":7,"vote_count":3},"modified":"2023-07-05T20:16:02.000Z","cast":["Kim Thế Giai","Dương Dung","Đặng Tụy Văn","Dương Cung Như","Yuan Shanshan","Trương Triết Hạn","La Tấn","Huỳnh Tông Trạch","Cherrie Ying Choi-Yi","Địch Lệ Nhiệt Ba","Anna Kay","Mễ Nhiệt","Cao Xinyue"],"director":["Lý Tuệ Châu","Đặng Vỹ Ân"],"cast_meta":[{"name":"Kim Thế Giai","name_vi":"Kim Thế Giai","name_original":"