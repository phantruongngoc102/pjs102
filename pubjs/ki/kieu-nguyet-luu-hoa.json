vip.opstream17.com/20240320/2899_453df04c/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/86c4ad52768c511046fea7b2d42b300c","link_m3u8":"https://vip.opstream17.com/20240321/2931_5fbd4a83/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/c429429bf1f2af051f2021dc92a8ebea","link_m3u8":"https://vip.opstream17.com/20240321/2932_0c0832bd/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/63f44623dd8686aba388944c8810087f","link_m3u8":"https://vip.opstream17.com/20240322/2967_26611591/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/62da8c91ce7b10846231921795d6059e","link_m3u8":"https://vip.opstream17.com/20240322/2968_c31ed905/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream17.com/share/f6b5f8c32c65fee991049a55dc97d1ce","link_m3u8":"https://vip.opstream17.com/20240323/2990_c3db348b/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream17.com/share/fedf67d6f3d7341c1c1e8a54774987d3","link_m3u8":"https://vip.opstream17.com/20240324/3067_f1e53239/index.m3u8"}]}],"description":"Võ lâm có Linh Thiên Cung nửa chính nửa tà, thế lực hùng mạnh nhưng quy ẩn đã lâu. Mười năm trước, trong một lần du ngoạn, thiếu cung chủ Linh Huyền bắt gặp một cặp huynh muội hấp hối. Cô lập ra giao ước mười năm với người ca ca, lấy việc cứu sống muội muội y làm điều kiện để đưa y vào Ảnh Các của Linh Thiên Cung huấn luyện. Nếu mười năm sau y có thể sống sót trở ra thì sẽ trở thành trợ thủ của cô. Thiếu niên trải qua muôn vàn cuộc vật lộn chém giết, thập tử nhất sinh, cuối cùng đã sống sót rời khỏi Ảnh Các với cái tên Ảnh Thập. Tuy nhiên lúc này, Linh Thiên Cung nguy cơ rình rập, lão cung chủ vì muốn chiếm đoạt công pháp Vạn Tâm Quyết của mẹ Linh Huyền mà bất chấp làm loạn võ lâm, thậm chí trở mặt với con gái ruột. Linh Huyền đành phải đóng vai một kẻ vô dụng phóng đãng, tính tình quái đản, tàn nhẫn ác độc nhằm tự bảo vệ mình, chờ thời cơ lên kế hoạch phản kích. Đúng lúc này, Ảnh Thập phụng mệnh Ảnh Các tìm kiếm Vạn Tâm Quyết và đến bên Linh Huyền.","tmdb_id":248749,"cast":["Hồ Diệc Dao","Lâm Trach Huy","Hou Yige","Wu Tianhao","Yuan Ziming","Wang Jiusheng","Xu Yingzhi","Zhang Haosen"],"director":["Zhang Ao"],"keywords":[],"tmdb":{"type":"tv","id":"248749","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Hồ Diệc Dao","name_vi":"Hồ Diệc Dao","name_original":"Hu Yiyao","tmdb_id":4284315,"profile":"https://image.tmdb.org/t/p/w500/6Evom0l5JFJvZr4dNh2xlIq1nMX.jpg","tmdb_url":"https://www.themoviedb.org/person/4284315"},{"name":"Lâm Trach Huy","name_vi":"Lâm Trach Huy","name_original":"Lin Zehui","tmdb_id":3716468,"profile":"https://image.tmdb.org/t/p/w500/stEok10jjs6rISy5ZgcQV5CfPVc.jpg","tmdb_url":"https://www.themoviedb.org/person/3716468"},{"name":"Hou Yige","name_vi":null,"name_original":"Hou Yige","tmdb_id":4959142,"profile":"https://image.tmdb.org/t/p/w500/1B3Ug0APDEgNAxBvUo2G9MZ1Qjt.jpg","tmdb_url":"https://www.themoviedb.org/person/4959142"},{"name":"Wu Tianhao","name_vi":null,"name_original":"Wu Tianhao","tmdb_id":4770619,"profile":"https://image.tmdb.org/t/p/w500/iusjTIZRl4GQDJ5z6P2nN84te2p.jpg","tmdb_url":"https://www.themoviedb.org/person/4770619"},{"name":"Yuan Ziming","name_vi":null,"name_original":"Yuan Ziming","tmdb_id":4088292,"profile":"https://image.tmdb.org/t/p/w500/3VbgTuJwbW8Cs2dk4812j87sAws.jpg","tmdb_url":"https://www.themoviedb.org/person/4088292"},{"name":"Wang Jiusheng","name_vi":null,"name_original":"Wang Jiusheng","tmdb_id":1620870,"profile":"https://image.tmdb.org/t/p/w500/p7i376UgQzJlyclZBaGh6qAPAs0.jpg","tmdb_url":"https://www.themoviedb.org/person/1620870"},{"name":"Xu Yingzhi","name_vi":null,"name_original":"Xu Yingzhi","tmdb_id":2822644,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2822644"},{"name":"Zhang Haosen","name_vi":null,"name_original":"Zhang Haosen","tmdb_id":2517052,"profile":"https://image.tmdb.org/t/p/w500/pluJ