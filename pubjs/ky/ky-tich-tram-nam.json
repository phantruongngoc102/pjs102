am13.com/20230912/1025_806711f5/index.m3u8"},{"name":"7","slug":"7","filename":"Yuz Yillik Mucize 7","link_embed":"https://vip.opstream13.com/share/36a16a2505369e0c922b6ea7a23a56d2","link_m3u8":"https://vip.opstream13.com/20230920/1081_6cf480c4/index.m3u8"},{"name":"8","slug":"8","filename":"Yuz Yillik Mucize 8","link_embed":"https://vip.opstream13.com/share/c3e0c62ee91db8dc7382bde7419bb573","link_m3u8":"https://vip.opstream13.com/20230927/1138_1bd789c2/index.m3u8"},{"name":"9","slug":"9","filename":"Yuz Yillik Mucize 9","link_embed":"https://vip.opstream13.com/share/285f89b802bcb2651801455c86d78f2a","link_m3u8":"https://vip.opstream13.com/20230928/1155_02d80d68/index.m3u8"},{"name":"10","slug":"10","filename":"Yuz Yillik Mucize 10","link_embed":"https://vip.opstream13.com/share/e22312179bf43e61576081a2f250f845","link_m3u8":"https://vip.opstream13.com/20230928/1156_0e3731fe/index.m3u8"},{"name":"11","slug":"11","filename":"Yuz Yillik Mucize 11","link_embed":"https://vip.opstream13.com/share/a8240cb8235e9c493a0c30607586166c","link_m3u8":"https://vip.opstream13.com/20230928/1157_ba55a655/index.m3u8"},{"name":"12","slug":"12","filename":"Yuz Yillik Mucize 12","link_embed":"https://vip.opstream13.com/share/0c048b3a434e49e655c1247efb389cec","link_m3u8":"https://vip.opstream13.com/20230928/1158_020b5c14/index.m3u8"},{"name":"13","slug":"13","filename":"Yuz Yillik Mucize 13","link_embed":"https://vip.opstream13.com/share/2f29b6e3abc6ebdefb55456ea6ca5dc8","link_m3u8":"https://vip.opstream13.com/20230930/1168_03890afc/index.m3u8"}]}],"time":"130 phút/tập","description":"<p>Ali Tahir (Birkan Sokullu) đã tử vì đạo khi chiến đấu ở Mặt trận Sakarya. Một phép màu đã xảy ra khi anh sắp được chôn cất đã mang lại sự sống cho anh. Tuy nhiên, điều kỳ diệu này lại khiến Ali Tahir trẻ mãi không già. Đối với Ali Tahir, người đã đóng gói rất nhiều trong cuộc đời 130 năm của mình, việc tiếp tục cuộc sống của mình càng trở nên khó khăn hơn. Người duy nhất biết bí mật của Kemal với họ của Ali Tahir là Turgut (Necip Memili), người mà anh đã biết từ khi còn nhỏ.<br>Marvelous (Ebru Şahin), nghề nghiệp chính là luật sư nhưng ham viết lách và đang vật lộn để viết cuốn tiểu thuyết đầu tiên của mình, được nuôi dưỡng bởi dì Süreyya (Zerrin Tekindor) và 8 người phụ nữ sống cùng nhà với dì, anh trai và anh em họ của cô. Tuyệt vời, người rời nhà để viết cuốn tiểu thuyết của mình, tình cờ gặp Kemal khi anh ấy ít ngờ tới nhất.<br>Great cần tìm một câu chuyện hay, còn Kemal cần trút bỏ gánh nặng và kể câu chuyện của mình. Cuộc sống của cả hai sẽ thay đổi theo những cách mà họ không ngờ tới sau khi gặp nhau.</p>","tmdb":{"type":"tv","id":"222899","season":1,"vote_average":6.7,"vote_count":3},"modified":"2023-09-30T10:43:37.000Z","cast":["Birkan Sokullu","Ebru Şahin","Zerrin Tekindor","Necip Memili","Gözde Seda Altuner","Laçin Ceylan","Aysegül Cengiz","Yalçın Hafızoğlu","Merve Nur Bengi","Ecem Çalhan","Zehra Kelleci","Hümeyra"],"director":["Hilal Saral"],"cast_meta":[{"name":"Birkan Sokullu","name_vi":null,"name_original":"Birkan Sokullu","tmdb_id":1579476,"profile":"https://image.tmdb.org/t/p/w500/55QxG1UURYvy1y2LP9aqLvCH1rj.jpg","tmdb_url":"https://www.themoviedb.org/person/1579476"},{"name":"Ebru Şahin","name_vi":null,"name_original":"Ebru Şahin","tmdb_id":2341909,"profile":"https://image.tmdb.org/t/p/w500/fjc23yerRCRhf9JJP4eVHwwnntq.jpg","tmdb_url":"https://www.themoviedb.org/person/2341909"},{"name":"Zerrin Tekindor","name_vi":null,"name_original":"Zerrin Tekindor","tmdb_id":1246608,"profile":"https://image.tmdb.org/t/p/w500/mWRvssoXW6GCsyqEubYEn5l1U3s.jpg","tmdb_url":"https://www.themoviedb.org/person/1246608"},{"name":"Necip Memili","name_vi":null,"name_original":"Necip Memili","tmdb_id":1184151,"profile":"https://image.tmdb.org/t/p/w500/d1jeBnsh30FkL5I196HHz85dz7h.jpg","tmdb_url":"https://www.themoviedb.org/person/1184151"},{"name":"Gözde Seda Altuner","name_vi":null,"name_original":"Gözde Seda Altuner","tmdb_id":3004115,"profile":"https://image.tmdb.org/t/p/w