e/8be61bb4942454f1fce2c9ff38c40ec3","link_m3u8":"https://vip.opstream11.com/20231130/49631_320b57f0/index.m3u8"}]}],"description":"<p>Kể về câu chuyện của cháu trai hoàng đế Li Ni, người canh giữ biên giới và buộc phải nhận trách nhiệm dẹp loạn. Lý Ni tuy là cháu nội của hoàng đế nhưng lại không hề được vua cha cưng chiều. Anh ta che giấu danh tính của mình và hài lòng với việc trở thành một vị tướng biên cương tiền tuyến vô tư không có ý định tranh giành quyền lực. Trong các chiến dịch quân sự chống lại quân nổi dậy, anh chạm trán với Cui Lin đầy tham vọng, con gái duy nhất của tướng Cui Yi, chỉ huy quân đội nhà Cui. Cui Lin đã che giấu danh tính thật của mình và cải trang thành Trung úy He, chiến đấu cùng quân đội. Họ vượt qua những con đường với nhau nhiều lần trên các chiến trường. Một người thì mưu mô và hóm hỉnh, người kia thì lanh lợi và thẳng thắn. Trong khả năng cạnh tranh của họ với nhau, đôi khi họ tính toán và dự đoán kế hoạch và chuyển động của nhau để chiến đấu như người chiến thắng dẫn họ đến con đường yêu.</p>","tmdb_id":209915,"cast":["Hứa Khải","Cảnh Điềm","Zheng Hehuizi","Cao Hàn","Triệu Gia Mẫn","Lưu Đông Thấm","Dai Yi","Hà Phụng Thiên","Tăng Lê","Vu Ba","Zhang Fuzheng","Liu Xiaoyu","Qiao Su","Chen Zhangtaikang","Qing Liu"],"director":["Steve Cheng"],"keywords":[],"tmdb":{"type":"tv","id":"209915","season":1,"vote_average":7.7,"vote_count":13},"cast_meta":[{"name":"Hứa Khải","name_vi":"Hứa Khải","name_original":"Xu Kai","tmdb_id":2091759,"profile":"https://image.tmdb.org/t/p/w500/wEfatQWa3v9tNtmgr5LOOmFSSJj.jpg","tmdb_url":"https://www.themoviedb.org/person/2091759"},{"name":"Cảnh Điềm","name_vi":"Cảnh Điềm","name_original":"Jing Tian","tmdb_id":1151657,"profile":"https://image.tmdb.org/t/p/w500/nNlM15XOEJU8A1dKuGEnN7NgxEy.jpg","tmdb_url":"https://www.themoviedb.org/person/1151657"},{"name":"Zheng Hehuizi","name_vi":null,"name_original":"Zheng Hehuizi","tmdb_id":1850227,"profile":"https://image.tmdb.org/t/p/w500/q9dHA42JLYCaC7JEe2KyRRcL2wJ.jpg","