,"link_embed":"https://vip.opstream16.com/share/c66f374e0826c14bc9d4202012b20068","link_m3u8":"https://vip.opstream16.com/20220906/22391_878da380/index.m3u8"},{"name":"23","slug":"23","filename":"lam-dau-nha-giau-or-daughter-in-war-tap-23","link_embed":"https://vip.opstream16.com/share/ad7a56645fcfda9b3436271850604962","link_m3u8":"https://vip.opstream16.com/20220906/22393_5fe24de1/index.m3u8"},{"name":"24","slug":"24","filename":"lam-dau-nha-giau-or-daughter-in-war-tap-24","link_embed":"https://vip.opstream16.com/share/a56ff1a378b80c51b65395011b05bd87","link_m3u8":"https://vip.opstream16.com/20220906/22395_5ee6f704/index.m3u8"},{"name":"25","slug":"25","filename":"lam-dau-nha-giau-or-daughter-in-war-tap-25","link_embed":"https://vip.opstream16.com/share/96b4fe5485ce30e17ec085bfc3b6db85","link_m3u8":"https://vip.opstream16.com/20220906/22397_506c6832/index.m3u8"},{"name":"26","slug":"26","filename":"lam-dau-nha-giau-or-daughter-in-war-tap-26","link_embed":"https://vip.opstream16.com/share/f0d65c0d56a5c7ff1c5bd9f9909f1c54","link_m3u8":"https://vip.opstream16.com/20220906/22399_2d495994/index.m3u8"},{"name":"27","slug":"27","filename":"lam-dau-nha-giau-or-daughter-in-war-tap-27","link_embed":"https://vip.opstream16.com/share/1b9ff04ef832682d4712ece27487f84e","link_m3u8":"https://vip.opstream16.com/20220906/22402_2a46eca3/index.m3u8"},{"name":"28","slug":"28","filename":"lam-dau-nha-giau-or-daughter-in-war-tap-28","link_embed":"https://vip.opstream16.com/share/2051430a15d3d44d5dd81ef133b61908","link_m3u8":"https://vip.opstream16.com/20220906/22403_85c23a3f/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim Làm Dâu Nhà Giàu (Daughter In War) xoay quanh gia đình ông Tien, một doanh nhân giàu có nhưng bảo thủ và gia trưởng. Ông luôn bắt 4 người con trai phải làm theo ý của mình thậm chí là chuyện kết hôn. Tuy nhiên, người con trai út tên là Traiwit vì không muốn nối nghiệp gia đình nên đã quyết định trở thành cảnh sát và rời khỏi nhà chuyển đến vùng Đông Bắc sống. Tại đó anh gặp Fahsai, cô gái thôn quê mạnh mẽ và luôn mang trong mình hoài bão phát triển quê hương. Ban đầu vì hiểu lầm mà Fahsai không ưa Traiwit. Sau đó, do phải trở về Băng Cốc, Traiwit đã thuê Fahsai kết hôn giả với anh và cùng nhau nghĩ cách đối phó ông Tien. Khi về làm dâu, Fahsai đã gặp phải sự phản đối dữ dội của cha chồng trong khi tình cảm giữa cô và Traiwit lại ngày một lớn dần.</p>","tmdb":{"type":"tv","id":"131688","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-30T11:10:05.000Z","cast":["Kanin Stanley","Singto Sakolrat Puntace","Katherine Morson","Farida Waller","Nong Pornsuda Tainaokhong","Jaturong Mokjok","Rungrawan Tonahongsa","Unruean Rachot","Thawatchanin Darayon","Prima Bhunjaroeun","Khame Narawit Chitbanchong","Krittakan Prasitpanit","Phutharit Prombandal","Darran Zeththinich Chanavarasutthisiri","Chanidapa Pongsilpipat"],"director":["Intanon Ratanakarn"],"cast_meta":[{"name":"Kanin Stanley","name_vi":null,"name_original":"Kanin Stanley","tmdb_id":1129780,"profile":"https://image.tmdb.org/t/p/w500/diVWlcxdoXF8AJlQ7pCfHBQBsqA.jpg","tmdb_url":"https://www.themoviedb.org/person/1129780"},{"name":"Singto Sakolrat Puntace","name_vi":null,"name_original":"Singto Sakolrat Puntace","tmdb_id":3502295,"profile":"https://image.tmdb.org/t/p/w500/6IqfNANWS0SwYjems9xHsXwPQbF.jpg","tmdb_url":"https://www.themoviedb.org/person/3502295"},{"name":"Katherine Morson","name_vi":null,"name_original":"Katherine Morson","tmdb_id":3502296,"profile":"https://image.tmdb.org/t/p/w500/j3FcloGFb5ixDTWPwTluyca68Jm.jpg","tmdb_url":"https://www.themoviedb.org/person/3502296"},{"name":"Farida Waller","name_vi":null,"name_original":"Farida Waller","tmdb_id":3502300,"profile":"https://image.tmdb.org/t/p/w500/lY7VDix2sApBfUs5hJq2zQAsye8.jpg","tmdb_url":"https://www.themoviedb.org/person/3502300"},{"name":"Nong Pornsuda Tainaokhong","name_vi":null,"name_original":"Nong Pornsuda Tainaokhong","tmdb_id":3502302,"profile":"https://image.tmd