1/7678_77b917da/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/c6776f93bc9afe2e511a1dbd5478362c","link_m3u8":"https://vip.opstream90.com/20250621/7690_c6776f93/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream90.com/share/c74c4bf0dad9cbae3d80faa054b7d8ca","link_m3u8":"https://vip.opstream90.com/20250621/7691_c74c4bf0/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream90.com/share/15bb63b28926cd083b15e3b97567bbea","link_m3u8":"https://vip.opstream90.com/20250621/7692_15bb63b2/index.m3u8"}]}],"description":"<p>Lâm Giang Tiên là bộ phim tiên hiệp yêu hận đan xen, do Triệu Na (Vô Ưu Độ, Sở Kiều Truyện) và Nhâm Á Nam chấp bút, Trí Lỗi (Mạch Thượng Nhân Như Ngọc) và Quốc Hạo (Học Viện Quân sự Liệt Hỏa) đồng đạo diễn. Phim có sự tham gia của các diễn viên chính: Bạch Lộc (Bạch Nguyệt Phạn Tinh, Ninh An Như Mộng, Châu Sinh Như Cố), Tăng Thuấn Hy (Liên Hoa Lâu, Điền Canh Ký, Cô Châu), Hà Thụy Hiền (Cửu Tiêu Hàn Dạ Noãn), và Trần Hâm Hải (Tiên Đài Có Cây, Sắc Màu Pháo Hoa Nhân Gian). Bộ phim kể về chuyện tình yêu hận đầy bi thương giữa Tứ Linh Tiên Tôn Lý Thanh Nguyệt và Đại Thành Tôn Giả Bạch Cửu Tư. Hai người vừa yêu vừa hận, cuối cùng hóa giải hiểu lầm, cùng nhau vượt qua kiếp nạn, cứu lấy chúng sinh, viết nên một thiên tình sử tiên hiệp tuyệt đẹp.<br>&nbsp;</p>","tmdb_id":252320,"cast":["Bạch Lộc","Tăng Thuấn Hy","Hà Thụy Hiền","Trần Hâm Hải","Lương Vĩnh Kỳ","Trịnh Khải","Huỳnh Dịch"],"director":["Zhi Lei","Guo Hao"],"keywords":[],"tmdb":{"type":"tv","id":"252320","season":1,"vote_average":7.8,"vote_count":14},"cast_meta":[{"name":"Bạch Lộc","name_vi":"Bạch Lộc","name_original":"Bai Lu","tmdb_id":1879666,"profile":"https://image.tmdb.org/t/p/w500/aRcUVDRO2wewQe0NXJ0RfzSgvUa.jpg","tmdb_url":"https://www.themoviedb.org/person/1879666"},{"name":"Tăng Thuấn Hy","name_vi":"Tăng Thuấn Hy","name_original":"Joseph Zeng","tmdb_id":1803092,"profile":"https://image.tmdb.org/t/p/w500/hfMNwzZv7SxJ6d8gk8r