ps://vip.opstream10.com/share/cac8ec2e0e8d39ca1612df964d942c01","link_m3u8":"https://vip.opstream10.com/20220531/18111_15a503ca/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream10.com/share/6ab7fa24224ddd2c8cf2f573e68f8b13","link_m3u8":"https://vip.opstream10.com/20220531/18114_8775fa6b/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream10.com/share/1452f0389a6958d1dde205a3c5d29495","link_m3u8":"https://vip.opstream10.com/20220531/18117_4fca4d5c/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream10.com/share/f41ba39ddd5e6fba9016468c5964b05a","link_m3u8":"https://vip.opstream10.com/20220531/18119_8fb63d80/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream10.com/share/6110f81cb5fe9566dec78d1dbf08a8dc","link_m3u8":"https://vip.opstream10.com/20220531/18122_236b14fa/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream10.com/share/2fefc978e8573441bb22120ecc62ac7d","link_m3u8":"https://vip.opstream10.com/20220531/18124_516ad50c/index.m3u8"},{"name":"47","slug":"47","link_embed":"https://vip.opstream10.com/share/35109f5ad05b4af6bf2f9279ef9d145c","link_m3u8":"https://vip.opstream10.com/20220531/18127_82b9e16b/index.m3u8"},{"name":"48","slug":"48","link_embed":"https://vip.opstream10.com/share/181ec6b7c833c0340d5120dba27c3bb0","link_m3u8":"https://vip.opstream10.com/20220531/18129_1a06290c/index.m3u8"},{"name":"49","slug":"49","link_embed":"https://vip.opstream10.com/share/2635749c5721bb3d5021ce2144ca0146","link_m3u8":"https://vip.opstream10.com/20220531/18131_201de298/index.m3u8"},{"name":"50","slug":"50","link_embed":"https://vip.opstream10.com/share/5f75e8eea894213d75a7c471116a3378","link_m3u8":"https://vip.opstream10.com/20220531/18134_302be22d/index.m3u8"}]}],"description":"<p>Phim Làm Vợ Anh Nhé kể về nữ sinh viên y khoa Park Yoo Ha hiện đã hoàn thành khóa thực tập của mình. Cô nỗ lực trở thành bác sĩ vì cha mình. Ông đã tự nuội bốn đứa con, bỗng một ngày ông quyết định kết hôn với một người giàu có, bà chủ của một tòa nhà…Park Yoo-Ha (Han Ji-Hye) học tập chăm chỉ tại trường dược và đã kết thúc kỳ thực tập. Cô ấy luôn cố gắng trở thành bác sĩ vì bố cô ấy. Ông chăm sóc 4 người con và chị cả cô ấy cũng phải hi sinh cho gia đình. Cô không có hứng thú với bất kỳ ai. Đột nhiên, cha cô ấy kết hôn với một người phụ nữ giàu có. Ngược lại, Jung Eun-Tae (Lee Sang-Woo) là một bác sĩ và là tình nguyện viên y tế về dược ở nước ngoài, nhưng anh phải trở lại Hàn Quốc. Anh không thích kết hôn và có ước muốn được như bố của mình – một người tiên phong trong ngành dược.</p>","tmdb_id":78052,"cast":[],"director":[],"keywords":[],"tmdb":{"id":78052},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/la/lam-vo-anh-nhe.json"}