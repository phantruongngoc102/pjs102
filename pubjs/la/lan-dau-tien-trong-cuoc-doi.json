ream15.com/share/2a07e653170f3679b2fc660d3ade0d0f","link_m3u8":"https://vip.opstream15.com/20230325/36270_2d161833/index.m3u8"}]}],"time":"65 phút/tập","description":"<p>Câu chuyện xuyên suốt ba khoảng thời gian và không gian, trong cùng một bệnh viện phụ sản, câu chuyện xoay quanh ba cặp vợ chồng về chuyện sinh nở, hôn nhân, sự nghiệp và gia đình. Năm 1993, Lu Minglei và Dai Sijin tìm kiếm một giải pháp dưới áp lực của cải cách hệ thống và thị trường. Năm 2008, Cheng Qianjin và Chen Lanqing, mặc dù họ là cha mẹ, nhưng trái tim họ không lớn lên. Năm 2022, Xia Zhixiong và Lu Yuan dần dần mất kiểm soát với cuộc sống của mình, và nhận ra rằng chỉ có hòa giải với chính mình, họ mới có thể đến được bờ bên kia.</p>","tmdb":{"type":"tv","id":"219204","season":1,"vote_average":7,"vote_count":1},"modified":"2025-04-03T10:33:22.000Z","cast":["Vương Tử Văn","Đường Nghệ Hân","Hồ Hạnh Nhi","Allen","Li Honglei","Guan Yajun"],"director":["Yi Jun"],"cast_meta":[{"name":"Vương Tử Văn","name_vi":"Vương Tử Văn","name_original":"Wang Ziwen","tmdb_id":1006594,"profile":"https://image.tmdb.org/t/p/w500/qcbGx4uKq3HAbAZRsZkrOztVgGe.jpg","tmdb_url":"https://www.themoviedb.org/person/1006594"},{"name":"Đường Nghệ Hân","name_vi":"Đường Nghệ Hân","name_original":"Tang Yixin","tmdb_id":1539646,"profile":"https://image.tmdb.org/t/p/w500/4b8sLZlCFrOVFwdqRSc0ssYXwaq.jpg","tmdb_url":"https://www.themoviedb.org/person/1539646"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/938251"},{"name":"Allen","name_vi":null,"name_original":"Allen","tmdb_id":1519031,"profile":"https://image.tmdb.org/t/p/w500/r2LykUtJ1fXCFKuzuS1vaGF9s3p.jpg","tmdb_url":"https://www.themoviedb.org/person/1519031"},{"name":"Li Honglei","name_vi":null,"name_original":"Li Honglei","tmdb_id":2699896,"profile":"https://image.tmdb.org/t/p/w500/gBOHffCXT6Bj4oIzfLGI