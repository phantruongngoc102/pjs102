h. Vì Lan Lăng Vương được người người yêu quý, ngưỡng mộ nên Thái tử Cao Vỹ sinh lòng ghen ghét, đố kỵ. Liệu Tuyết Vũ có thể bảo vệ được Lan Lăng Vương không khi Cao Vỹ muốn giết chết anh?","tmdb_id":59081,"cast":["Phùng Thiệu Phong","Lâm Y Thần","Trần Hiểu Đông","Địch Thiên Lâm","Mao Lâm Lâm","Hàn Đống","Hồ Vũ Uy","Tiara Huang","Zhang Zimu","Wang Di","Tông Phong Nham","Zheng Xiaoning","Wang Zheng","Lữ Trung","Lu Yong"],"director":["Chung Shu-Kai"],"keywords":[],"tmdb":{"type":"tv","id":"59081","season":1,"vote_average":5.833,"vote_count":6},"cast_meta":[{"name":"Phùng Thiệu Phong","name_vi":"Phùng Thiệu Phong","name_original":"William Feng","tmdb_id":936431,"profile":"https://image.tmdb.org/t/p/w500/tSn5BIRw3Xdj3XYKIycjyNTgl49.jpg","tmdb_url":"https://www.themoviedb.org/person/936431"},{"name":"Lâm Y Thần","name_vi":"Lâm Y Thần","name_original":"Ariel Lin","tmdb_id":1222312,"profile":"https://image.tmdb.org/t/p/w500/hFzUAwsQcz2nLw6BIjwSjDNPFtb.jpg","tmdb_url":"https://www.themoviedb.org/person/1222312"},{"name":"Trần Hiểu Đông","name_vi":"Trần Hiểu Đông","name_original":"Daniel Chan Hiu-Tung","tmdb_id":588138,"profile":"https://image.tmdb.org/t/p/w500/esZcqbVjPYyErUgmr24Rm8hyW8Z.jpg","tmdb_url":"https://www.themoviedb.org/person/588138"},{"name":"Địch Thiên Lâm","name_vi":"Địch Thiên Lâm","name_original":"Zhai Tianlin","tmdb_id":1518224,"profile":"https://image.tmdb.org/t/p/w500/weEnyU5Kd72XdOUFVpRDymv37yS.jpg","tmdb_url":"https://www.themoviedb.org/person/1518224"},{"name":"Mao Lâm Lâm","name_vi":"Mao Lâm Lâm","name_original":"Nikita Mao","tmdb_id":1518223,"profile":"https://image.tmdb.org/t/p/w500/3dAutF22fOmde3BZag3VbRWTodi.jpg","tmdb_url":"https://www.themoviedb.org/person/1518223"},{"name":"Hàn Đống","name_vi":"Hàn Đống","name_original":"Han Dong","tmdb_id":1518226,"profile":"https://image.tmdb.org/t/p/w500/85yojZHWpgEpOb8sE3VqTeuXrNq.jpg","tmdb_url":"https://www.themoviedb.org/person/1518226"},{"name":"Hồ Vũ Uy","name_vi":"Hồ Vũ Uy","name_original":"George Hu