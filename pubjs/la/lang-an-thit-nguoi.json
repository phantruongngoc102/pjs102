stream11.com/share/b28fefe9233a0ac0c53fc319b7efd173","link_m3u8":"https://vip.opstream11.com/20230204/42336_359d9b70/index.m3u8"},{"name":"6","slug":"6","filename":"Gannibal.S01E06.Premonition.1080p.DSNP.WEB-DL.DDP5.1.H.264-SMURF","link_embed":"https://vip.opstream15.com/share/e0d04159c4304a1f2a5e191f551f3a94","link_m3u8":"https://vip.opstream15.com/20230205/32554_0a9bb280/index.m3u8"},{"name":"7","slug":"7","filename":"Gannibal.S01E07.Promise.1080p.DSNP.WEB-DL.DDP5.1.H.264-SMURF","link_embed":"https://vip.opstream15.com/share/b8a7a43c42b54ca12d847eaff8f7c9e8","link_m3u8":"https://vip.opstream15.com/20230206/32563_2d70131d/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Truyện tranh hồi hộp gây sốc cùng tên của Masaaki Ninomiya, đã bán được tổng cộng hơn 2 triệu bản, sẽ được dựng thành phim truyền hình người thật đóng dưới dạng sê-ri từ Nhật Bản. Dàn nhân sự hàng đầu của Nhật Bản đã tập hợp cho tác phẩm này, vốn được cho là khó thực hiện live action do nội dung gây sốc.Daigo Agawa và gia đình đóng quân tại một ngôi làng miền núi cách xa thành phố. Tuy nhiên, có một tin đồn ở ngôi làng xinh đẹp rằng mọi người sẽ bị ăn thịt trong ngôi làng này... Daigo tìm kiếm sự thật với niềm tin là một sĩ quan cảnh sát, nhưng chẳng bao lâu sau, cuộc sống hàng ngày bình lặng của ngôi làng bắt đầu lộ ra một bộ mặt \"đáng sợ\". Những sự kiện bí ẩn nối tiếp nhau, những người dân làng thân thiện nhưng hơi kỳ quái... Daigo trở nên nghi ngờ mọi thứ và bị đẩy đến bờ vực của sự điên loạn. Tôi hay họ xa lạ? Với sự tham gia của Yuya Yagira, đạo diễn thiên tài Shinzo Katayama và nhà biên kịch từng đoạt giải Cannes Takayoshi Oe giới thiệu một bộ phim bom tấn kinh dị tâm lý làm rung chuyển lẽ thường trong một xã hội làng quê khép kín.</p>","tmdb":{"type":"tv","id":"210213","season":1,"vote_average":7.7,"vote_count":71},"modified":"2025-04-17T12:47:00.000Z","cast":["Yuya Yagira","Show Kasamatsu","Riho Yoshioka","Takato Nagata","Mahiro Takasugi","Tsunematsu Yuri","Mitsuko Baisho","Rio Yamas