n nại rất cao. Cuộc sống phụ thuộc vào việc chớp thời cơ, sói và người Mông Cổ đều hiểu rõ đạo lý này\".","tmdb":{"type":"movie","id":"309302","season":null,"vote_average":6.501,"vote_count":395},"modified":"2023-04-11T10:42:36.000Z","cast":["Phùng Thiệu Phong","Đậu Kiêu","Ankhnyam Ragchaa","Doãn Chú Thắng","Baasanjav Mijid","Tumenbayaer","Hàn Đồng Sinh","Huỳnh Tiểu Lội","Qi Na Ri Tu","Xia Xing"],"director":["Jean-Jacques Annaud"],"cast_meta":[{"name":"Phùng Thiệu Phong","name_vi":"Phùng Thiệu Phong","name_original":"William Feng","tmdb_id":936431,"profile":"https://image.tmdb.org/t/p/w500/tSn5BIRw3Xdj3XYKIycjyNTgl49.jpg","tmdb_url":"https://www.themoviedb.org/person/936431"},{"name":"Đậu Kiêu","name_vi":"Đậu Kiêu","name_original":"Shawn Dou","tmdb_id":145093,"profile":"https://image.tmdb.org/t/p/w500/3SN0FoX3rqFez0A5WrBZhXKsFQm.jpg","tmdb_url":"https://www.themoviedb.org/person/145093"},{"name":"Ankhnyam Ragchaa","name_vi":null,"name_original":"Ankhnyam Ragchaa","tmdb_id":1465994,"profile":"https://image.tmdb.org/t/p/w500/cTCd8S5ZGC0kCcEr3DGfSVLnAVX.jpg","tmdb_url":"https://www.themoviedb.org/person/1465994"},{"name":"Doãn Chú Thắng","name_vi":"Doãn Chú Thắng","name_original":"Yin Zhusheng","tmdb_id":1174659,"profile":"https://image.tmdb.org/t/p/w500/5MuK3eCMOR3b5WANNGMeFbqXlJI.jpg","tmdb_url":"https://www.themoviedb.org/person/1174659"},{"name":"Baasanjav Mijid","name_vi":null,"name_original":"Baasanjav Mijid","tmdb_id":1117866,"profile":"https://image.tmdb.org/t/p/w500/7fkkraLMALIN8HKfvQS9xPwSe7O.jpg","tmdb_url":"https://www.themoviedb.org/person/1117866"},{"name":"Tumenbayaer","name_vi":null,"name_original":"Tumenbayaer","tmdb_id":3235272,"profile":"https://image.tmdb.org/t/p/w500/26RVxdx3ikKHQazVhEvVo07pefB.jpg","tmdb_url":"https://www.themoviedb.org/person/3235272"},{"name":"Hàn Đồng Sinh","name_vi":"Hàn Đồng Sinh","name_original":"Han Tongsheng","tmdb_id":1268918,"profile":"https://image.tmdb.org/t/p/w500/j4rUYKbzH1F6EFL6ukXeTMlsL8R.jpg","tmdb_url":"https://w