11.com/20220319/2841_03329bb4/index.m3u8"},{"name":"25","slug":"25","filename":"Cute-Programmer-tap-25","link_embed":"https://vip.opstream11.com/share/3812f9a59b634c2a9c574610eaba5bed","link_m3u8":"https://vip.opstream11.com/20220319/2842_889810a0/index.m3u8"},{"name":"26","slug":"26","filename":"Cute-Programmer-tap-26","link_embed":"https://vip.opstream11.com/share/bf2fb7d1825a1df3ca308ad0bf48591e","link_m3u8":"https://vip.opstream11.com/20220319/2843_67b56c19/index.m3u8"},{"name":"27","slug":"27","filename":"Cute-Programmer-tap-27","link_embed":"https://vip.opstream11.com/share/6f1d0705c91c2145201df18a1a0c7345","link_m3u8":"https://vip.opstream11.com/20220319/2844_ebfb172c/index.m3u8"},{"name":"28","slug":"28","filename":"Cute-Programmer-tap-28","link_embed":"https://vip.opstream11.com/share/4b29fa4efe4fb7bc667c7b301b74d52d","link_m3u8":"https://vip.opstream11.com/20220319/2845_7fbeeb12/index.m3u8"},{"name":"29","slug":"29","filename":"Cute-Programmer-tap-29","link_embed":"https://vip.opstream11.com/share/eb9fc349601c69352c859c1faa287874","link_m3u8":"https://vip.opstream11.com/20220319/2846_7ca5bc41/index.m3u8"},{"name":"30","slug":"30","filename":"Cute-Programmer-tap-30","link_embed":"https://vip.opstream11.com/share/fdf1bc5669e8ff5ba45d02fded729feb","link_m3u8":"https://vip.opstream11.com/20220319/2847_d8a2f8d6/index.m3u8"}]}],"time":"48 phút/tập","description":"<p>Sau khi yêu nam thần code Khương Dật Thành, Lục Ly không những ra sức học hành để vào cùng trường, cùng khoa công nghệ thông tin với anh mà còn ấp ủ giấc mơ trở thành một lập trình viên xinh đẹp. Với mục tiêu theo đuổi Khương Dật Thành, Lục Ly trở thành cô sinh viên xuất sắc như anh đã từng, nhưng không ngờ rằng công ty khởi nghiệp của Khương Dật Thành lại không tuyển dụng nhân viên nữ. Để lại gần nam thần, Lục Ly không ngần ngại giả nam để vào được công ty, sau đó bắt đầu đấu trí đấu dũng với anh chàng tổng giám đốc kiêu ngạo - Khương Dật Thành. Sau nhiều lần bị đả kích và nghi ngờ thân phận khiến Lục Ly ở công ty gặp nhiều khó khăn. Vì sự nghiệp yêu thầm, vì mục tiêu cuộc đời mà Lục Ly liều mình nắm bắt cơ hội, cuối cùng kí hợp đồng hôn nhân một năm với Khương Dật Thành. Trong thời gian sống chung, hai người có những câu chuyện ngọt ngào, Khương Dật Thành cũng dần dần yêu Lục Ly từ lúc nào không hay.</p>","tmdb":{"type":"tv","id":"133060","season":1,"vote_average":7.3,"vote_count":23},"modified":"2023-05-17T21:31:07.000Z","cast":["Hình Chiêu Lâm","Chúc Tự Đan","Dịch Đại Thiên","Điền Y Đồng","Guan Xin","Joy Sheng","Hong Siyang","Yu Cong","Jun Sheng","Zhao Zhengyang","Zhang Qingqing","Wang Yiming","Vương Sách","Rong Rong","Wang Weihua"],"director":["Wu Qiang"],"cast_meta":[{"name":"Hình Chiêu Lâm","name_vi":"Hình Chiêu Lâm","name_original":"Xing Zhaolin","tmdb_id":1855299,"profile":"https://image.tmdb.org/t/p/w500/8UPCvdZggQhuzCGkXvSOJ8EMqdI.jpg","tmdb_url":"https://www.themoviedb.org/person/1855299"},{"name":"Chúc Tự Đan","name_vi":"Chúc Tự Đan","name_original":"Zhu Xudan","tmdb_id":1838200,"profile":"https://image.tmdb.org/t/p/w500/bfqvBRuDi56O2WB1Hvg6IPeITlm.jpg","tmdb_url":"https://www.themoviedb.org/person/1838200"},{"name":"Dịch Đại Thiên","name_vi":"Dịch Đại Thiên","name_original":"Yi Daqian","tmdb_id":2288957,"profile":"https://image.tmdb.org/t/p/w500/ndoTYEzy44C3Gwp8z863iALbf0u.jpg","tmdb_url":"https://www.themoviedb.org/person/2288957"},{"name":"Điền Y Đồng","name_vi":"Điền Y Đồng","name_original":"Tian Yitong","tmdb_id":2489608,"profile":"https://image.tmdb.org/t/p/w500/xHM19SUwFIKAhfa0sMspVgekmwV.jpg","tmdb_url":"https://www.themoviedb.org/person/2489608"},{"name":"Guan Xin","name_vi":null,"name_original":"Guan Xin","tmdb_id":2117545,"profile":"https://image.tmdb.org/t/p/w500/AbRquS5qY7lSLv81yHz9i8JP5zk.jpg","tmdb_url":"https://www.themoviedb.org/person/2117545"},{"name":"Joy Sheng","name_vi":null,"name_original":"Joy Sheng","tmdb_id":1310282,"profile":"https://image.tmdb.org/t/p/w500/qbuq10qITGWHe6Esh0jI1SBGusX.jpg","tmdb_url":"https://www.themovie