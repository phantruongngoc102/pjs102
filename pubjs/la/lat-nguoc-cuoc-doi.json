https://vip.opstream90.com/20260425/30196_517031b6/index.m3u8"}]}],"description":"<p>Chàng trai trẻ Trương Tiểu Bắc rơi vào bước đường cùng, nhưng bất ngờ có được chiếc chìa khóa thay đổi số phận khi hoán đổi cuộc đời với Thịnh Nguyên Châu, cậu ấm của một gia tộc tài phiệt. Từ vực sâu nghịch cảnh, cậu từng bước vươn mình, đổi đời để bảo vệ gia đình, đồng thời quyết tâm truy tìm hung thủ đã hại chị gái mình.Hai thiếu niên, trong hành trình cứu rỗi và chữa lành lẫn nhau, phải đối mặt với vô vàn thử thách về bản chất con người trong 30 ngày định mệnh. Cuối cùng, cả hai bắt tay vạch trần âm mưu chốn hào môn và tung đòn báo thù đanh thép nhắm thẳng vào kẻ đứng sau mọi chuyện!</p>","tmdb_id":319810,"cast":["Vương Thụy Xương","Tào Ân Tề","Thích Nghiên Địch"],"director":[],"keywords":[],"time":"? phút/tập","tmdb":{"type":"tv","id":"319810","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Vương Thụy Xương","name_vi":"Vương Thụy Xương","name_original":"Wang Ruichang","tmdb_id":1973972,"profile":"https://image.tmdb.org/t/p/w500/92c3MXEXFYCbej3qDAaSQEL20y6.jpg","tmdb_url":"https://www.themoviedb.org/person/1973972"},{"name":"Tào Ân Tề","name_vi":"Tào Ân Tề","name_original":"Vincent Cao","tmdb_id":2027714,"profile":"https://image.tmdb.org/t/p/w500/mPq283zAuBLPKs1L8ygATpHbq0R.jpg","tmdb_url":"https://www.themoviedb.org/person/2027714"},{"name":"Thích Nghiên Địch","name_vi":"Thích Nghiên Địch","name_original":"Qi Yandi","tmdb_id":2447692,"profile":"https://image.tmdb.org/t/p/w500/yVjBFaeGZRcu1FGQcouyhuAsjpW.jpg","tmdb_url":"https://www.themoviedb.org/person/2447692"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/la/lat-nguoc-cuoc-doi.json"}