hỉ thoát khỏi thành kiến ​​​​của mọi người đối với sinh viên y khoa thiên về nghiên cứu, mà còn có được tình bạn và tình yêu, đồng thời thành lập \"Bốn bác sĩ cấp cứu\" cùng với Louis, Zu Wenda và Liu Fei .</p>","tmdb":{"type":"tv","id":"227649","season":1,"vote_average":7,"vote_count":1},"modified":"2023-06-25T16:55:22.000Z","cast":["Bành Quán Anh","Đồ Tùng Nham","Gai Yuexi","Gao Xin","Hùng Tử Kỳ","Huỳnh Tiểu Lội","Thi Thi","Zhang Zhijian","Trần Sổ"],"director":["Dương Văn Quân"],"cast_meta":[{"name":"Bành Quán Anh","name_vi":"Bành Quán Anh","name_original":"Peng Guanying","tmdb_id":1690592,"profile":"https://image.tmdb.org/t/p/w500/xPWJwXDVHy1biQxVMBYkzSFQm8q.jpg","tmdb_url":"https://www.themoviedb.org/person/1690592"},{"name":"Đồ Tùng Nham","name_vi":"Đồ Tùng Nham","name_original":"Tu Songyan","tmdb_id":2276453,"profile":"https://image.tmdb.org/t/p/w500/xMN5dqyJQUFgQWp2GUheeBWpXGp.jpg","tmdb_url":"https://www.themoviedb.org/person/2276453"},{"name":"Gai Yuexi","name_vi":null,"name_original":"Gai Yuexi","tmdb_id":2177276,"profile":"https://image.tmdb.org/t/p/w500/sgxFqeHU3R3UvptlLgQ17G4je2E.jpg","tmdb_url":"https://www.themoviedb.org/person/2177276"},{"name":"Gao Xin","name_vi":null,"name_original":"Gao Xin","tmdb_id":1177285,"profile":"https://image.tmdb.org/t/p/w500/mhVZKsGESu7XHRzRNDGIKDzqLqk.jpg","tmdb_url":"https://www.themoviedb.org/person/1177285"},{"name":"Hùng Tử Kỳ","name_vi":"Hùng Tử Kỳ","name_original":"Dylan Xiong","tmdb_id":1838195,"profile":"https://image.tmdb.org/t/p/w500/fa6DVbw4seYJvaphn5kmzfvfiWR.jpg","tmdb_url":"https://www.themoviedb.org/person/1838195"},{"name":"Huỳnh Tiểu Lội","name_vi":"Huỳnh Tiểu Lội","name_original":"Huang Xiaolei","tmdb_id":143826,"profile":"https://image.tmdb.org/t/p/w500/4PrbAr5Hj0ZHubA3o9H0W0Z72GN.jpg","tmdb_url":"https://www.themoviedb.org/person/143826"},{"name":"Thi Thi","name_vi":"Thi Thi","name_original":"Shi Shi","tmdb_id":2103412,"profile":"https://image.tmdb.org/t/p/w500/7LTskavi0aUSSls3thKNIG3oeCH.jpg","tmdb_