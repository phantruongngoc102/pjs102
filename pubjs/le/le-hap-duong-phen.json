tream12.com/share/24c386cd9c503780b1b219e9aa063136","link_m3u8":"https://vip.opstream12.com/20220617/20270_700714a0/index.m3u8"},{"name":"40B","slug":"40b","filename":"le-hap-duong-phen-skate-into-love-tap-40B","link_embed":"https://vip.opstream12.com/share/c9041cfd2a40932691855abd98fd219a","link_m3u8":"https://vip.opstream12.com/20220617/20269_23e6e8fa/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>\"Lê hấp đường phèn\" là phim truyền hình thanh xuân, hiện đại do Ngô Thiến và Trương Tân Thành vào vai chính. Tác phẩm được chuyển thể từ tiểu thuyết cùng tên của nhà văn nổi tiếng Tử Tiểu Thất, kể về thiếu nữ trượt băng tốc độ Đường Tuyết đã gặp nam thần khúc côn cầu Lê Ngữ Băng, hai người cùng nhau theo đuổi giấc mơ trượt băng đã có được tình yêu đích thực. Lê Ngữ Băng dần phát hiện ra sự can đảm khi chơi khúc côn cầu trên băng của anh đều bắt nguồn từ Đường Tuyết. Đường Tuyết cũng nhờ Lê Ngữ Băng mà tìm lại giấc mơ trượt băng tưởng chừng đã từng bị lãng quên. Nhưng cha mẹ Đường Tuyết cản trở sự nghiệp, chấn thương trong thể thao buộc cô phải đối mặt với sự lựa chọn. Ở nơi tình yêu và giấc mơ đan xen, hai trái tim nồng nàn biến đã tình yêu thành một sức mạnh vượt qua mọi xúi giục và rào cản của cuộc sống.</p>","tmdb":{"type":"tv","id":"100803","season":1,"vote_average":7.9,"vote_count":19},"modified":"2023-04-11T19:21:18.000Z","cast":["Trương Tân Thành","Ngô Thiến","Chu Lịch Kiệt","Chu Yue","Cao Bo","Hà Tuyên Lâm","Ngụy Thiên Hạo","Hàn Cửu Nặc","Qin Tianyu"],"director":["Chu Yui Bun"],"cast_meta":[{"name":"Trương Tân Thành","name_vi":"Trương Tân Thành","name_original":"Zhang Xincheng","tmdb_id":2027708,"profile":"https://image.tmdb.org/t/p/w500/mpCVPsEvnMUkmMd1IN1xsBJpk7r.jpg","tmdb_url":"https://www.themoviedb.org/person/2027708"},{"name":"Ngô Thiến","name_vi":"Ngô Thiến","name_original":"Janice Wu","tmdb_id":1677008,"profile":"https://image.tmdb.org/t/p/w500/zNw2OQbHC343epJkSgR3FUHGWmA.jpg","tmdb_url":"https://www.themoviedb.org/person/1677008"},{"name":"Chu