.com/share/4fc66104f8ada6257fa55f29a2a567c7","link_m3u8":"https://vip.opstream13.com/20250917/8126_4fc66104/index.m3u8"},{"name":"19","slug":"19","filename":"Lệnh Truy Nã tập 19#20 # tiếng Việt # Cổ Thiên Lạc, Viên Khiết Doanh, Trần Pháp Dung# TVB 1997","link_embed":"https://vip.opstream13.com/share/5934c1ec0cd31e12bd9084d106bc2e32","link_m3u8":"https://vip.opstream13.com/20250917/8127_5934c1ec/index.m3u8"},{"name":"20","slug":"20","filename":"Lệnh Truy Nã tập 20#20 # tiếng Việt # Cổ Thiên Lạc, Viên Khiết Doanh, Trần Pháp Dung# TVB 1997","link_embed":"https://vip.opstream13.com/share/c3d96fbd5b1b45096ff04c04038fff5d","link_m3u8":"https://vip.opstream13.com/20250917/8128_c3d96fbd/index.m3u8"}]}],"time":"40 phút/tập","description":"<p>Tôi Không Chấp Nhận Tham Nhũng kể về một đội chống tham nhũng dưới sự lãnh đạo của một thanh tra trưởng tài ba Diệp Quốc Anh (Trần Thiếu Kỳ). Diệp Quốc Anh dẫn đầu một đội ngũ sĩ quan tinh nhuệ bao gồm thanh tra cấp cao giàu kinh nghiệm Lâm Chí Công (Trương Tiểu Huy); và bốn sinh viên mới tốt nghiệp đại học khác đang khao khát được vào cơ quan chống tham nhũng, Phương Trác Văn (Cổ Thiên Lạc), Khảm Minh Huy (Viên Huệ Văn); La Gia Kiệt (Hà Bảo San) mồ côi, cùng với Lưu Chí Sơn (Trương Ngọc Sơn) tốt bụng. Bộ phim hành động này ghi lại các phương thức hoạt động của ICAC để giải quyết các vụ hối lộ. Các vụ án bao gồm các sĩ quan cảnh sát nhận hối lộ để che đậy một nhà thổ, giao dịch nội gián giữa các nhà phát triển bất động sản và đại lý bất động sản, tham nhũng của lính cứu hỏa cũng như buôn bán vũ khí...</p>","tmdb":{"type":"tv","id":"97227","season":1,"vote_average":8.3,"vote_count":3},"modified":"2025-09-17T18:25:43.000Z","cast":["Cổ Thiên Lạc","Trương Triệu Huy","Trần Pháp Dung","Viên Khiết Doanh","Bao Fang","Timmy Ho Bo-Sang","Shirley Cheung Yuk-Shan","Gregory Charles Rivers","Danny Summer","Lee Ji-Kei","Lee Ka Keung","Lam King-Kong","Tăng Huệ Vân","Kwok Tak-San","Li Hung-Kit"],"director":[],"cast_meta":[{"name":"Cổ Thiên Lạc","name_vi"