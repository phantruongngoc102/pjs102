h tra cao cấp của Cục Điều tra tội phạm có tổ chức và xã hội đen, khi cùng điều tra một vụ án mà nạn nhân là ba nuôi của Phương Gia Tình (Huỳnh Trí Văn đóng). Gia Tình là ca sĩ phòng trà. Sau biến cố đó, Phong và Minh giúp cuộc sống của Tình ổn định trở lại. Ba người họ cũng gặp lại Trác Dĩ Phàm (Ngô Trác Hy đóng). Công việc luật sư khiến Phàm nhiều lần chạm trán Phong và Minh.\n\nPhương thức, thủ đoạn hoạt động của các cá nhân, tổ chức phạm tội ngày càng tinh vi, xảo quyệt. Quá trình điều tra, Phong và Minh nhận thấy nhiều vụ án dính líu đến thương gia Trác Đình Quang (Huỳnh Trí Hiền đóng). Oái ăm, ông lại là người thân của Phàm.","tmdb_id":210773,"cast":["Huỳnh Tông Trạch","Ngô Trác Hy","Vương Hạo Tín","Sisley Choi Si-Pui","Mandy Wong","Hồ Định Hân","Đàm Tuấn Ngạn","Lâm Hạ Vy","Trần Triển Bằng","Ben Wong Chi-Yin","Derek Kwok Jing-Hung","Alex Fong Lik-Sun","Cao Quân Hiền","Hugo Wong","Thái Khiết"],"director":["Kwok-Keung Wong"],"keywords":[],"tmdb":{"type":"tv","id":"210773","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Huỳnh Tông Trạch","name_vi":"Huỳnh Tông Trạch","name_original":"Bosco Wong Chung-Chak","tmdb_id":144586,"profile":"https://image.tmdb.org/t/p/w500/o6RGUQXQRobk2PhoTc6zqpOC9yr.jpg","tmdb_url":"https://www.themoviedb.org/person/144586"},{"name":"Ngô Trác Hy","name_vi":"Ngô Trác Hy","name_original":"Ron Ng Cheuk-Hai","tmdb_id":1222249,"profile":"https://image.tmdb.org/t/p/w500/rhT0EL5LYYLZIyS3Aax6MakEE9e.jpg","tmdb_url":"https://www.themoviedb.org/person/1222249"},{"name":"Vương Hạo Tín","name_vi":"Vương Hạo Tín","name_original":"Vincent Wong Ho-Shun","tmdb_id":1690917,"profile":"https://image.tmdb.org/t/p/w500/tjV6ap01OzpQZq4Wzi42nXQ3aBX.jpg","tmdb_url":"https://www.themoviedb.org/person/1690917"},{"name":"Sisley Choi Si-Pui","name_vi":null,"name_original":"Sisley Choi Si-Pui","tmdb_id":1545561,"profile":"https://image.tmdb.org/t/p/w500/kMoFQdV3Do1kIuDMq2dYOYNrMZ2.jpg","tmdb_url":"https://www.themoviedb.org/person/1545561"},{"name"