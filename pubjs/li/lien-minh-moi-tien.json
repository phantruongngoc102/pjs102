/f319ba8aa8a10c4d0df2b8acf127be64","link_m3u8":"https://vip.opstream12.com/20250224/25364_f319ba8a/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream12.com/share/2ee48d7685054b85f9e9d9b8b67c404f","link_m3u8":"https://vip.opstream12.com/20250224/25365_2ee48d76/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream12.com/share/0d1e0d602ebcba3dec4cff58832c7181","link_m3u8":"https://vip.opstream12.com/20250224/25366_0d1e0d60/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream12.com/share/c3c7377014553b7643f4f43a6f679360","link_m3u8":"https://vip.opstream12.com/20250224/25367_c3c73770/index.m3u8"}]}],"description":"Nội dung phim nói về thế giới tài chính, khi lòng tham trỗi dậy, con người sẽ bị đồng tiền chi phối.\n\nNghiên cứu sinh Harry Tào Gia Thanh (do Huỳnh Đình Phong đóng) tham gia nhóm đầu tư cổ phiếu của Cổ Đại Sư – Cổ Bách Vinh (do Âu Dương Vĩ Hào đóng) và bị lừa hết tiền. Thanh tập hợp những người bị hại là công chức nghỉ hưu Simon Hà Đức Tín (do Tưởng Chí Quang đóng), bà nội trợ Katty Đỗ Ỷ Kỳ (do Thang Lạc Văn đóng) và huấn luyện viên thể hình Hook Khu Lực Cần (do Diêu Hoành Viễn đóng) cùng nhau đòi lại số tiền bị lừa.\n\nHọ thành lập liên minh moi tiền - OPM, viết tắt là Other People’s Money. Đây là đòn bẩy sử dụng tiền của người khác để phân tán rủi ro, nhà đầu tư sử dụng công cụ này khi đang cần tiền làm ăn mà họ chưa có tiền. Sau khi Cổ Bách Vinh bị họ lừa tiền thì ông cũng tham gia vào liên minh để thực hiện nhiều phi vụ lừa đảo khác.","tmdb_id":201464,"cast":["Telford Wong","Akai Lee","Terence Tung","Roxanne Tong","Benjamin Au-Yeung Wai-Ho","Bowie Cheung","Phó Gia Lợi","Bella Lam Wing Tung","Hugo Wong","Chloe So Ho-Yee","Tyson Chak","Eddie Pang Wai-On","Snow Suen","Parkman Wong Pak-Man","Lucas Yiu Wang-Yuen"],"director":["Man Sum Kwan","Shu-ming Kwan"],"keywords":[],"tmdb":{"type":"tv","id":"201464","season":1,"vote_average":4,"vote_count":1},"cast_meta":[{"name":"Telford Wong","name_vi":null,"name