{"id":"6238651d3d016a3b67181397","title":"Life with Father","origin_name":"Life with Father","slug":"life-with-father","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/li/life-with-father.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/li/life-with-father.webp","year":1947,"type":"single","genre":[{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Life with Father","link_embed":"https://vip.opstream14.com/share/77369e37b2aa1404f416275183ab055f","link_m3u8":"https://vip.opstream14.com/20220320/1907_f116b00f/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Ngày Clarence (William Powell), là một chuyên gia bất mãn từ những năm 1880 của thành phố New York của mình. Vợ Vinnie (Irene Dunne), là người đứng đầu thực sự của hộ gia đình. Câu chuyện giai thoại, bao gồm các chi tiết như Clarence (Jimmy Lydon), sự lãng mạn của con trai cả với Great Out-of-Towner Mary (Elizabeth Taylor). Vinnie cố gắng để có được người chồng headstrong được rửa tội, nếu không anh ta sẽ không bao giờ có thể vào vương quốc của Thiên Chúa.</p>","tmdb":{"type":"movie","id":"41465","season":null,"vote_average":6.725,"vote_count":69},"modified":"2024-10-27T10:38:13.000Z","cast":["William Powell","Irene Dunne","Elizabeth Taylor","Edmund Gwenn","Zasu Pitts","Jimmy Lydon","Emma Dunn","Moroni Olsen","Elisabeth Risdon","Derek Scott","Johnny Calkins","Martin Milner","Heather Wilde","Monte Blue","Mary Field"],"director":["Michael Curtiz"],"cast_meta":[{"name":"William Powell","name_vi":null,"name_original":"William Powell","tmdb_id":32428,"profile":"https:/