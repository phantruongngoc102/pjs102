7.6,"vote_count":7},"modified":"2022-05-20T02:53:09.000Z","cast":["Lâm Nhất","Tăng Lê","Thái Văn Tịnh"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Lâm Nhất","name_vi":null,"name_original":"Lâm Nhất"},{"name":"Tăng Lê","name_vi":null,"name_original":"Tăng Lê"},{"name":"Thái Văn Tịnh","name_vi":null,"name_original":"Thái Văn Tịnh"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/li/linh-lung.json"}