m3u8":"https://vip.opstream90.com/20251216/20257_5843342c/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream90.com/share/b720817bd7b15afc1ae856121ebc71d1","link_m3u8":"https://vip.opstream90.com/20251217/20333_b720817b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream90.com/share/9544120004d9a4b193af053574037993","link_m3u8":"https://vip.opstream90.com/20251218/20420_95441200/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream90.com/share/d3dc22ad3ee79f300ae1c20bc9554d87","link_m3u8":"https://vip.opstream90.com/20251219/20507_d3dc22ad/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream90.com/share/6ad352975d2f1649b553212e0b61731f","link_m3u8":"https://vip.opstream90.com/20251220/20658_6ad35297/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream90.com/share/94fa408dabe453246eb240f198322336","link_m3u8":"https://vip.opstream90.com/20251221/20725_94fa408d/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream90.com/share/c310688b6d82ca7ea9c1889ccc3416ee","link_m3u8":"https://vip.opstream90.com/20251222/20759_c310688b/index.m3u8"}]}],"description":"<p>Vào thời Dân quốc, dân chúng còn u mê, mê tín những chuyện quỷ thần hoang đường. Lý Mộc Đôn là thợ mộc giỏi nhất Vụ Thành, tinh thông cổ thư “Lỗ Ban Bí Thuật”. Tương truyền cuốn sách này chia thành hai quyển thượng và hạ: quyển thượng nghiên cứu nghệ thuật làm mộc, còn quyển hạ lại ghi chép những tà thuật kỳ bí khó lường. Vụ Thành bất ngờ xảy ra án cô dâu mất tích, nguyên nhân cái chết quái dị khiến dư luận xôn xao, nhiều người nghi ngờ chính Lý Mộc Đôn đã dùng tà thuật làm điều ác. Để chứng minh sự trong sạch của mình, Lý Mộc Đôn cùng cảnh thám Dương Tông và pháp y Tô Thanh Vân đã điều tra rõ ngọn ngành, cuối cùng phát hiện hung thủ chẳng qua chỉ lợi dụng bí thuật bố trí cơ quan để ngụy tạo hiện tượng thần bí đánh lừa thiên hạ. Ba người phối hợp hết sức ăn ý, liên tiếp phá thành công các vụ án: vụ án trụ sống, vụ án con rối gỗ giết người, vụ án phu xe,... Tất cả các vụ án này đều có mối liên hệ rắc rối với Vu Hàm, sư đệ của Lý Mộc Đôn. Khi Đốc quân qua đời, Vụ Thành lại xuất hiện chuỗi án mạng liên hoàn, gây chấn động toàn thành. Lý Mộc Đôn cùng hai người bạn được giao trọng trách, đấu trí đấu dũng với Vu Hàm, cuối cùng vạch trần toàn bộ chân tướng. Họ dùng hành động để chứng minh rằng chính nghĩa nhất định chiến thắng sự ngu muội và bóng tối, đồng thời kế thừa và phát huy tinh thần coi trọng sự thật, bài trừ mê tín trong văn hóa truyền thống Trung Hoa.</p>","tmdb_id":307535,"cast":["Lai Xi","Peng Yaqi","Mao Kuanren"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"307535","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lai Xi","name_vi":null,"name_original":"Lai Xi","tmdb_id":2493434,"profile":"https://image.tmdb.org/t/p/w500/s9KRKxiCBnz9uJhvQ1PkcQxJhfy.jpg","tmdb_url":"https://www.themoviedb.org/person/2493434"},{"name":"Peng Yaqi","name_vi":null,"name_original":"Peng Yaqi","tmdb_id":3063201,"profile":"https://image.tmdb.org/t/p/w500/sH3S6fGcgaXeZaVO82PmCMESmwm.jpg","tmdb_url":"https://www.themoviedb.org/person/3063201"},{"name":"Mao Kuanren","name_vi":null,"name_original":"Mao Kuanren","tmdb_id":5343258,"profile":"https://image.tmdb.org/t/p/w500/b5KrYWaZ8G39FnPcE7NKlGYK8zY.jpg","tmdb_url":"https://www.themoviedb.org/person/5343258"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/lo/lo-ban-di-van-luc.json"}