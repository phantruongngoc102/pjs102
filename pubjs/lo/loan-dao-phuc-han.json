stream14.com/share/392c071fb32b1da665da55ceda711c43","link_m3u8":"https://vip.opstream14.com/20230406/34910_074b68ef/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/ed751ee258c09fb19a4c915a239c9189","link_m3u8":"https://vip.opstream14.com/20230406/34911_80de85fb/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/0173e8d8b1d94a355b440fb67388f532","link_m3u8":"https://vip.opstream14.com/20230406/34912_01134288/index.m3u8"}]}],"description":"<p>Cây Loan đao nổi tiếng giang hồ ai có được nó sẽ có nhiều tham vọng. Khi xưa Nhậm Thiên Hành - giáo chủ ma giáo đã dùng nó giết người hàng loạt nên võ lầm đã cử Tạ Hiểu Phong của thần kiếm sôn trang đi đàm đạo với y nhằm đem lại bình yêu cho trung nguyên, nhưng vì lí do gì đó mà trong một đêm cả thần kiếm sơn trang cùng ma giáo biến mất. Phim Loan Đao Phục Hận bắt đầu mối thù hận khác khi Tần Khả Tình phụng mệnh của Liễu Nhược Tùng tiếp cận Đinh Bằng bằng tình yêu để lấy trộm bí kíp võ công để đánh bại anh. Sau khi bị đánh rơi xuống biển Đinh Bằng đã được cứu từ đây anh quen biết và cưới Thanh Thanh. Anh và Thanh Thanh trở về trung nguyên khi được cha của Thanh Thanh tặng Loan đao. Phim Loan Đao Phục Hận bắt đầu việc trả thù hai người năm xưa đã hại anh. Hậu quả là Thanh Thanh bị mù do ân oán của anh…</p>","tmdb_id":15580,"cast":["Cổ Thiên Lạc","Ôn Bích Hà","Noel Leung","Trương Triệu Huy","Chang Yi","Wong Wai","Cheng Lui","Mickey Chu Kin-Kwan","Ying Li","Leung Yuen-Jing","Lương Kiện Bình","Kwan Ching","Lý Thành Xương","Kwok Tak-San","Chan Min-Leung"],"director":["Đang cập nhật"],"keywords":[],"tmdb":{"type":"tv","id":"15580","season":1,"vote_average":6.2,"vote_count":6},"cast_meta":[{"name":"Cổ Thiên Lạc","name_vi":"Cổ Thiên Lạc","name_original":"Louis Koo","tmdb_id":78875,"profile":"https://image.tmdb.org/t/p/w500/yQuDBTzm7xWlJICNvl20OmcJP80.jpg","tmdb_url":"https://www.themoviedb.org/person/78875"},{"name":"Ôn Bích Hà","name_vi":"Ôn Bích Hà","name_original"