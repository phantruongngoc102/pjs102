stream16.com/share/1c5581e1bb072092bdfdad5312de26a3","link_m3u8":"https://vip.opstream16.com/20231128/38226_c3fe99c2/index.m3u8"}]}],"description":"<p><i>Lúc này, đứng đầu khu Pháp trị là Phùng Kính Nghiêu. Số phận xô đẩy Văn Cường gặp gỡ con gái Phùng Kính Nghiêu là Phùng Trình Trình. Tuy là con gái cưng của ông trùm sừng sỏ nhất đất Thượng Hải nhưng tâm tính Trình Trình rất mực hiền lành và trong sáng. Được Văn Cường nhiều lần giúp đỡ, Trình Trình đem lòng yêu mến anh. Ngoài mặt Văn Cường luôn tỏ ra lạnh lùng với cô nhưng tâm trí anh đã có hình ảnh của người con gái nhu mì, dịu dàng ấy. Oái oăm thay, Đinh Lực cũng thầm yêu thương Trình Trình. Trình Trình không hề hay biết gì, cô vẫn ân cần quan tâm, chăm sóc Văn Cường bằng tất cả tấm chân tình. Cảm động trước tình yêu của cô, Văn Cường đã về “đầu quân” cho Phùng Kính Nghiêu, kéo theo Đinh Lực. Bản tính vốn chính trực nên Hứa Văn Cường nhiều lần không đồng ý với cách làm việc gian ác của Phùng Kính Nghiêu. Tình yêu của anh và Trình Trình vì thế cũng gặp không ít trở ngại.</i></p>","tmdb_id":125911,"cast":["Trịnh Thiếu Thu","Pat Poon","Trần Cẩm Hồng","Trịnh Du Linh","Lâm Gia Đống","Adia Chan","Noel Leung","Lui Fong","La Gia Lương","Lâm Bảo Di","Tăng Chí Vĩ","Florence Kwok Siu-Wan","La Gia Anh","Lý Long Cơ","Lý Gia Thanh"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"125911","season":1,"vote_average":8,"vote_count":1},"cast_meta":[{"name":"Trịnh Thiếu Thu","name_vi":"Trịnh Thiếu Thu","name_original":"Adam Cheng Siu-Chow","tmdb_id":82401,"profile":"https://image.tmdb.org/t/p/w500/KHy7b3kAXP05VGcdsPy3Qf34GM.jpg","tmdb_url":"https://www.themoviedb.org/person/82401"},{"name":"Pat Poon","name_vi":null,"name_original":"Pat Poon","tmdb_id":1772642,"profile":"https://image.tmdb.org/t/p/w500/s8gWIlOq9sfnSQufNdZydpkkdvK.jpg","tmdb_url":"https://www.themoviedb.org/person/1772642"},{"name":"Trần Cẩm Hồng","name_vi":"Trần Cẩm Hồng","name_original":"Sunny Chan Kam-Hung","tmdb_id":548050,"profile":"https://image.tmdb.org/t