h đánh bại linh hồn bóng tối. Câu chuyện tình yêu giữa 2 con người và 1 \"linh hồn\" sẽ kết thúc ra sao? Liệu con người hay quỷ dữ sẽ chiến thắng?</p>","tmdb":{"type":"tv","id":"89063","season":1,"vote_average":8,"vote_count":1},"modified":"2022-10-17T19:33:36.000Z","cast":["Siwat Chotchaicharin","Nuengthida Sophon","Akarat Nimitchai","Ohm Atshar Nampan","Arisara Wongchalee","Natapat Wipataradachtragoon","Linpita Jindapoo","Kalaya Lerdkasemsap","Ratree Wittawat","Chartchai Ngamsan","Passakorn Ponlaboon","Pattarapol Kantapoj"],"director":[],"cast_meta":[{"name":"Siwat Chotchaicharin","name_vi":null,"name_original":"Siwat Chotchaicharin","tmdb_id":3406038,"profile":"https://image.tmdb.org/t/p/w500/sOUSGeqVTxIZwJUjdNluqzdW1Qe.jpg","tmdb_url":"https://www.themoviedb.org/person/3406038"},{"name":"Nuengthida Sophon","name_vi":null,"name_original":"Nuengthida Sophon","tmdb_id":1105573,"profile":"https://image.tmdb.org/t/p/w500/l1ZkKeF0vUDsDECuWjUGIrVfoTU.jpg","tmdb_url":"https://www.themoviedb.org/person/1105573"},{"name":"Akarat Nimitchai","name_vi":"Akarat Nimitchai","name_original":"Akarat Nimitchai","tmdb_id":3406040,"profile":"https://image.tmdb.org/t/p/w500/jVAgnLdf4HHMbMEVmjUl7cYNoFT.jpg","tmdb_url":"https://www.themoviedb.org/person/3406040"},{"name":"Ohm Atshar Nampan","name_vi":null,"name_original":"Ohm Atshar Nampan","tmdb_id":2594843,"profile":"https://image.tmdb.org/t/p/w500/ajiE9NVm2IlDlKZBDCUZq1a6ft8.jpg","tmdb_url":"https://www.themoviedb.org/person/2594843"},{"name":"Arisara Wongchalee","name_vi":null,"name_original":"Arisara Wongchalee","tmdb_id":1203876,"profile":"https://image.tmdb.org/t/p/w500/p8KgolBImhMDs12qjzYiuYo9iUM.jpg","tmdb_url":"https://www.themoviedb.org/person/1203876"},{"name":"Natapat Wipataradachtragoon","name_vi":null,"name_original":"Natapat Wipataradachtragoon","tmdb_id":3237948,"profile":"https://image.tmdb.org/t/p/w500/iVd4che6TjndvDVfcESEgHc4OVa.jpg","tmdb_url":"https://www.themoviedb.org/person/3237948"},{"name":"Linpita Jindapoo",