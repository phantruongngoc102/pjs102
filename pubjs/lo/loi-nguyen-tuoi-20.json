.com/20230516/27239_33e54355/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/a2be3baee3bcf8792aab206b21ad7f69","link_m3u8":"https://vip.opstream10.com/20230529/27435_fc7b0a47/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/e3aba3971c560bcd3591124675a8fb57","link_m3u8":"https://vip.opstream10.com/20230529/27436_11adcfc8/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/d95a2fa315683f22cfa4713558f64dfe","link_m3u8":"https://vip.opstream10.com/20230529/27437_45a7b239/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream10.com/share/1cbb2344a50511f9ea581e66c5cc54f7","link_m3u8":"https://vip.opstream10.com/20230529/27438_ee307f8d/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream10.com/share/67f3c822a32053681b2c45736b4da971","link_m3u8":"https://vip.opstream10.com/20230529/27439_8b55520f/index.m3u8"}]}],"description":"<p>So Won sinh năm 1981, vì vậy hiện nay cô ấy đã bước sang độ tuổi bốn mươi, nhưng khi cô ấy tròn 20 tuổi vào năm 2000, cô ấy đã gặp một phù thủy trong một cơ hội tình cờ. So Won bị phù thủy nguyền rủa vì đã từ chối lời đề nghị của phù thủy, và lời nguyền là \"sống như một người phụ nữ 20 tuổi suốt đời còn lại\". Ban đầu, cô ấy nghĩ đó sẽ là một điều may mắn nhưng sau đó chịu đựng đau đớn khi mất đi những người thân yêu và không đạt được tiến bộ. Một ngày nọ, cô ấy tìm thấy một bức ảnh và thấy phù thủy trong đó, vì vậy cô ấy đến một khu nghỉ dưỡng mà cô ấy đã nhìn thấy trong phong cảnh của bức ảnh. Để giải thoát khỏi lời nguyền, cô ấy lén vào làm nhân viên khu nghỉ dưỡng và gặp gỡ Kang Hyun và Sang Wook ở đó. Mối quan hệ của họ sẽ phát triển như thế nào, và liệu cô ấy có thành công trong việc gỡ bỏ lời nguyền của mình hay không?</p>","tmdb_id":224966,"cast":[],"director":[],"keywords":[],"tmdb":{"id":224966},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/lo/loi-nguyen-tuoi-20.json"}