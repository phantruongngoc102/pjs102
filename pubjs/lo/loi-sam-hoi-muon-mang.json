ream14.com/20220705/17218_d9e0745f/index.m3u8"},{"name":"19","slug":"19","filename":"Lời sám hối muộn màng tập 19 (tiếng Việt) - Đàm Tuấn Ngạn, Trần Sơn Thông, Huỳnh Trí Văn - TVB 2020","link_embed":"https://vip.opstream14.com/share/bbd24387cfc440ae2aa2a88ae96a4a79","link_m3u8":"https://vip.opstream14.com/20220705/17221_99976685/index.m3u8"},{"name":"20","slug":"20","filename":"Lời sám hối muộn màng tập 20 (tiếng Việt) - Đàm Tuấn Ngạn, Trần Sơn Thông, Huỳnh Trí Văn - TVB 2020","link_embed":"https://vip.opstream14.com/share/e376d5d818f7665946b0a88c7632e311","link_m3u8":"https://vip.opstream14.com/20220705/17220_c88b0b89/index.m3u8"}]}],"time":"42 phút/tập","description":"<p>Mười tám năm trước, Lâm Lãng Sinh (do Đàm Tuấn Ngạn đóng), Thẩm Kính Nhất (do Trần Sơn Thông đóng) và Tạ Gia Phú (do Hà Viễn Đông đóng) vẫn còn là những cậu thiếu niên vô ưu. Họ cùng sống trong khu tập thể phức tạp, nhiều thành phần bất hảo. Một lần, nhóm của Sanh cùng bốn thiếu niên khác xảy ra xung đột với tay côn đồ, lông bông, tên Hồ Khải Tư. Cuối cùng, họ vô ý làm Tư chết. Bảy chàng trai trẻ vì quá sợ hãi, đã bỏ xứ ra đi, mỗi người một ngả, coi như chưa từng quen biết...</p>","tmdb":{"type":"tv","id":"102505","season":1,"vote_average":8,"vote_count":2},"modified":"2022-07-05T16:27:46.000Z","cast":["Trần Sơn Thông","Đàm Tuấn Ngạn","Katy Kung","Đàm Khải Kỳ","Triệu Hi Lạc","Tào Vĩnh Liêm","Lâm Khải Ân"],"director":[],"cast_meta":[{"name":"Trần Sơn Thông","name_vi":"Trần Sơn Thông","name_original":"Joel Chan","tmdb_id":1218777,"profile":"https://image.tmdb.org/t/p/w500/sBVL7GLD2K6UF9FkzhamMMopyjn.jpg","tmdb_url":"https://www.themoviedb.org/person/1218777"},{"name":"Đàm Tuấn Ngạn","name_vi":"Đàm Tuấn Ngạn","name_original":"Shaun Tam Chun-Yin","tmdb_id":1173383,"profile":"https://image.tmdb.org/t/p/w500/iFIuZ0AJznHAQ6C3fFJUlaCTIgQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1173383"},{"name":"Katy Kung","name_vi":null,"name_original":"Katy Kung","tmdb_id":1622984,"profile":"https://image.tmd