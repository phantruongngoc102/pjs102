.opstream13.com/share/e5b0663c1dad4751e0ce728f4a6cf9b5","link_m3u8":"https://vip.opstream13.com/20251124/19369_e5b0663c/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream13.com/share/623040922099375a93bfbd8b3234d997","link_m3u8":"https://vip.opstream13.com/20251124/19370_62304092/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream13.com/share/dbd0ff34821a2eecbc2826e03a6809ed","link_m3u8":"https://vip.opstream13.com/20251124/19371_dbd0ff34/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream13.com/share/85aa96d070f948fc891f02bacbddb48f","link_m3u8":"https://vip.opstream13.com/20251124/19372_85aa96d0/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream13.com/share/14cd06dc182d6ef43dfc5395b5aded78","link_m3u8":"https://vip.opstream13.com/20251124/19373_14cd06dc/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream13.com/share/5f7fbfa87db626dbef11e97fedc56f67","link_m3u8":"https://vip.opstream13.com/20251124/19374_5f7fbfa8/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream13.com/share/841db5759f578ab2f06de12d410c1b8e","link_m3u8":"https://vip.opstream13.com/20251124/19375_841db575/index.m3u8"}]}],"description":"<p><i>Lời thì thầm từ quá khứ</i> nói về Lan (Phan Minh Huyền) cùng những uẩn khúc xoay quanh cái chết bất ngờ của người chồng sắp cưới Tuấn (Tiến Lộc). Sau khi người mình yêu mất đi, cô luôn sống trong tâm trạng dằn vặt, đau khổ. Linh hồn Tuấn sau đó hiện về, cho biết anh chết nhưng chưa thể siêu thoát vì còn quá nhiều điều chưa thực hiện được. Lan quyết định sẽ cùng Kiên (Thanh Sơn) và Đạt (Chí Nhân) - hai người bạn thân của Tuấn - thực hiện nốt những việc chưa hoàn thành của anh. Chính trong thời gian này, Lan đã hiểu thêm nhiều góc khuất, những mảng sáng - tối trong con người Tuấn và những người xung quanh cô…</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/lo/loi-thi-tham-tu-qua-khu.json","tmdb_checked":false}