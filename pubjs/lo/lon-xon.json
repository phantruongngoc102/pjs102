ndex.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/00a88476f623e4b554a2277fa4de42a0","link_m3u8":"https://vip.opstream10.com/20230531/27459_8703845c/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream13.com/share/6ea9ab1baa0efb9e19094440c317e21b","link_m3u8":"https://vip.opstream13.com/20230607/29_6f9a8e03/index.m3u8"}]}],"description":"<p>Gia đình Servet, chuyển từ Eskişehir đến Istanbul vì lý do gia đình, bước vào một môi trường hoàn toàn khác. Cố gắng thích nghi với môi trường tại trường đại học tư thục mà họ bắt đầu, cặp song sinh Kerem và Ece sẽ gặp những người không giống mình, trong khi họ đang trên đường trưởng thành trong những nỗi đau lớn dần, họ cũng sẽ bước vào một hành trình dài mang tên tuổi trẻ, nơi họ họ sẽ bị cuốn theo những mưu cầu, sai lầm và sự phấn khích của mối tình đầu muốn khám phá chính mình.<br>Trong khi cặp song sinh đang bị thử thách với những cơn đau ngày càng lớn, khi cha của họ là Harun buộc phải trở về nhà của cha mình, nơi ông đã không đặt chân đến trong 25 năm, mối hận thù giữa cha và con trai sẽ khiến cả gia đình căng thẳng với những tính toán sâu sắc. Mẹ của họ, Beliz, sẽ bước vào một thời kỳ mới mà bà sẽ khám phá bản thân.<br>Khi ông của cặp song sinh Asaf và bà của họ Ayla bắt đầu sống chung dưới một mái nhà với các con trai và cháu của họ 25 năm sau, họ sẽ nhận ra rằng sự trưởng thành và trưởng thành kéo dài suốt đời với những xung đột mà họ sẽ bước vào.</p>","tmdb_id":213059,"cast":["Mert Yazıcıoğlu","Hafsanur Sancaktutan","Aslıhan Malbora","Aytaç Şaşmaz","Necip Memili","Nur Fettahoğlu","Ali Önsöz","Beste Can Sağlam","Umut Kaya","Barış Başar","Cem Karacakaya","Murat Kapu","Meral Çetinkaya","Metin Coşkun"],"director":["Deniz Yorulmazer"],"keywords":[],"tmdb":{"type":"tv","id":"213059","season":1,"vote_average":8.5,"vote_count":2},"cast_meta":[{"name":"Mert Yazıcıoğlu","name_vi":null,"name_original":"Mert Yazıcıoğlu","tmdb_id":1554460,"profile":"https://image.tmdb.org/t/p/w500/9Q