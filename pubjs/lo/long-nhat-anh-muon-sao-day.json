g thì có vô số vấn đề đang chờ họ cùng nhau giải quyết.</p>","tmdb_id":80538,"cast":["Hou Peishan","Anson Qiu","Ngụy Triết Minh","Su Yuhang","Bai Hui Zi","Qiao Shiyu","Li Shengjia","Mai Wulan","Chen Che","Zhang Keyuan","Rain Lau Yuk-Chui","Zhang Shuangli","Wang Yimo","Chen Yanli","Wang Meng"],"director":["Zhou Yao Yi Kuan"],"keywords":[],"tmdb":{"type":"tv","id":"80538","season":1,"vote_average":7.8,"vote_count":11},"cast_meta":[{"name":"Hou Peishan","name_vi":null,"name_original":"Hou Peishan","tmdb_id":2486579,"profile":"https://image.tmdb.org/t/p/w500/p2jhXj4sFcWHSgYvoZYp6cQZxAx.jpg","tmdb_url":"https://www.themoviedb.org/person/2486579"},{"name":"Anson Qiu","name_vi":null,"name_original":"Anson Qiu","tmdb_id":2486580,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2486580"},{"name":"Ngụy Triết Minh","name_vi":"Ngụy Triết Minh","name_original":"Miles Wei","tmdb_id":1914924,"profile":"https://image.tmdb.org/t/p/w500/vR3Jr5DQULKi0ndD6mG1uo7lTnz.jpg","tmdb_url":"https://www.themoviedb.org/person/1914924"},{"name":"Su Yuhang","name_vi":null,"name_original":"Su Yuhang","tmdb_id":4519224,"profile":"https://image.tmdb.org/t/p/w500/pVKCMmqop3Nn6gvVILKGVtVQuBa.jpg","tmdb_url":"https://www.themoviedb.org/person/4519224"},{"name":"Bai Hui Zi","name_vi":null,"name_original":"Bai Hui Zi","tmdb_id":4519226,"profile":"https://image.tmdb.org/t/p/w500/qnv0tBWrBXyFQgrCas50CVtapJs.jpg","tmdb_url":"https://www.themoviedb.org/person/4519226"},{"name":"Qiao Shiyu","name_vi":null,"name_original":"Qiao Shiyu","tmdb_id":2199334,"profile":"https://image.tmdb.org/t/p/w500/5TN4UEZkNezqIeBSUuNYmaNveCe.jpg","tmdb_url":"https://www.themoviedb.org/person/2199334"},{"name":"Li Shengjia","name_vi":null,"name_original":"Li Shengjia","tmdb_id":4074873,"profile":"https://image.tmdb.org/t/p/w500/tEa4hbHXe6ZdGdzk1tLDrSx87Iu.jpg","tmdb_url":"https://www.themoviedb.org/person/4074873"},{"name":"Mai Wulan","name_vi":null,"name_original":"Mai Wulan","tmdb_id":4519230,"profile":"https://image.