0330/37015_dea27c5b/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/e5b48cd740459076e51b98c3fd80d225","link_m3u8":"https://vip.opstream15.com/20230330/37016_ef09e200/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/07044df9f0dc1d12e08825ac86cc9f6d","link_m3u8":"https://vip.opstream15.com/20230330/37018_321f3d2b/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/6afe0837f8aac5e0a2a7fa5161b07b56","link_m3u8":"https://vip.opstream15.com/20230330/37019_9933fea1/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/7fc2e837c73d955ce1144ab2d5d765a7","link_m3u8":"https://vip.opstream15.com/20230330/37021_42af6c8c/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream15.com/share/25607716f949b4cfd9254853c997c507","link_m3u8":"https://vip.opstream15.com/20230330/37022_301b7f87/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream15.com/share/2b99581c579d192b4b78c4a879b6e2e1","link_m3u8":"https://vip.opstream15.com/20230330/37024_fea1f9b8/index.m3u8"}]}],"description":"<p>Tống Viễn Phong là đội trưởng đội cảnh sát hình sự một khu xa xôi ở thành phố Hải Thành của tỉnh Liêu Ninh, sinh ra trong một gia đình gốc cảnh sát, bố là phó giám đốc sở công an thành phố, nhưng lại không tin tưởng năng lực của con trai mình. Một lần Tống Viễn Phong trên đường đến sở cảnh sát tình cờ thấy một băng nhóm bán thuốc phiện đang đánh nhau, Tống Viễn Phong cùng cộng sự của mình là Vương Tấn đã bắt được ngay tại đó 1 nghi phạm. Trong lúc hai người đang chờ đồng đội trợ giúp thì tên đó đã thoát được chạy trốn. Chính sự xung đột lần này của băng nhóm tội phạm đã giúp cho cảnh sát mở ra hàng loạt vụ án ở Hải Thành. Tống Viễn Phong vì làm nghi phạm bỏ trốn không chỉ bị cha mình khiển trách mà còn phải chuyển đến đội chuyên án cục thành phố, dưới sự chế giễu của đồng đội, cùng với việc theo dõi sát sao, cuối cùng, băng đản buôn ma túy của Phùng Quân bị tiêu diệt. Qua vụ án lần này, Tống Viễn Phong cũng hiểu được dụng tâm và nỗi khổ của cha mình.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/lo/lost.json"}