11.com/share/a308d4c57b421c5b161897f6fe80dea6","link_m3u8":"https://vip.opstream11.com/20220612/30074_4f959dc5/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/cd0e9d013a5bb2fce93b3e4c26877d6b","link_m3u8":"https://vip.opstream11.com/20220612/30075_ab159da7/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/6b18d371703cf5221bc39c1a03a3be64","link_m3u8":"https://vip.opstream11.com/20220612/30076_af1b654b/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/a1b2e04c65e8fa74ba1e50a429b828ca","link_m3u8":"https://vip.opstream11.com/20220612/30077_1f995af8/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream11.com/share/b532f0f8baa4651aac8ccd180dcba01d","link_m3u8":"https://vip.opstream11.com/20220612/30078_b03e92c0/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream11.com/share/68c20262d2657796f56d2101e46b3e73","link_m3u8":"https://vip.opstream11.com/20220612/30079_abe1d296/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream11.com/share/e29b0e21fb5035674413d42d83931ca9","link_m3u8":"https://vip.opstream11.com/20220612/30080_882d9f88/index.m3u8"}]}],"description":"<p>Lữ Bố Và Điêu Thuyền lấy bối cảnh những năm cuối triều nhà Hán, gian thần nắm quyền, thái sư Đổng Trác tàn bạo, sớm có ý đồ tạo phản. Lã Bố là nghĩa tử của hắn, dũng mãnh phi thường, càng khiến cho Đổng Trác như hổ thêm cánh. Tư đồ Vương Doãn là người vì nước vì dân, muốn tiêu diệt Đổng Trác để trừ họa. Vương Doãn tình cờ gặp ca kỹ Điêu Thiền trong phủ khi mới 18 tuổi, tài sắc vẹn toàn, ca hay múa giỏi. Biết được Điêu Thiền là một người chí khí, sẵn sàng xả thân cứu quốc, Vương Doãn vui mừng nhận ngay làm nghĩa nữ. Sau đó ông nghĩ ra “liên hoàn kế”, dùng Điêu Thuyền làm mồi nhử để dụ dỗ cha con Đổng Trác, Lã Bố, nhằm chia rẽ tình cảm cha con họ.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/lu/lu-bo-va-dieu-thuyen.json","tmdb_checked":false}