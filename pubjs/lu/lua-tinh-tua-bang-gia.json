3u8":"https://vip.opstream10.com/20250228/28901_9da26ee4/index.m3u8"},{"name":"33","slug":"33","filename":"Lửa Tình Tựa Băng Giá - Tập 33","link_embed":"https://vip.opstream10.com/share/9a985e5d14e44dc2c97d12877dd7cd8c","link_m3u8":"https://vip.opstream10.com/20250228/28913_9a985e5d/index.m3u8"},{"name":"34","slug":"34","filename":"Lửa Tình Tựa Băng Giá - Tập 34","link_embed":"https://vip.opstream10.com/share/be6d9b9d8e0d77f5d77f534687f46691","link_m3u8":"https://vip.opstream10.com/20250228/28914_be6d9b9d/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Plubpla làm nghề viết văn phải tự mình chăm sóc em trai mình, Tong mà không có sự giúp đỡ của Treepradub, chị cả của họ, người đã kết hôn với một người đàn ông giàu có và chưa bao giờ giúp đỡ cô. Một ngày nọ, Tong cãi nhau với anh trai của Pheem, người sau đó bị Tong đánh bất tỉnh và bất tỉnh bởi Tong. Điều này khiến Plubpla và Pheem gặp nhau, và cuộc gặp gỡ đầu tiên của họ là thảm họa khi cô tát anh ta vào mặt. Tuy nhiên, Plubpla đang ở thế bất lợi vì vụ tấn công của chị gái mình, vì vậy Pheem đã đưa ra lời đề nghị trở thành người phụ nữ của anh ta để cứu anh trai cô.</p>","tmdb":{"type":"tv","id":"273643","season":1,"vote_average":0,"vote_count":0},"modified":"2025-03-14T11:20:20.000Z","cast":["Yotsawat Tawapee","Mookda Narinrak","Chanakan Poonsiriwong","Yanissa Diratorn","Santiraj Kulnoppakiet","Pattharapong Watkamee","Nasamon Niyomdecha","Natthapat Jiraphawasut","Amena Pinit","Parita Chairak","Kochakorn Nimakorn","Phutharit Prombandal","Passorn Leowrakwong","Patthama Panthong","Panadda Komaratat"],"director":["Intanon Ratanakarn"],"cast_meta":[{"name":"Yotsawat Tawapee","name_vi":null,"name_original":"Yotsawat Tawapee","tmdb_id":3294119,"profile":"https://image.tmdb.org/t/p/w500/oEhco9gGsYh5skWYlOJ6g1frlsN.jpg","tmdb_url":"https://www.themoviedb.org/person/3294119"},{"name":"Mookda Narinrak","name_vi":null,"name_original":"Mookda Narinrak","tmdb_id":2855792,"profile":"https://image.tmdb.org/t/p/w500/oENKwCO