{"id":"62b5d8713e39f9843cacc662","title":"Luật Chiến Tranh","origin_name":"Rules of Engagement","slug":"luat-chien-tranh","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/lu/luat-chien-tranh.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/lu/luat-chien-tranh.webp","year":2000,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2238e0fc277084dfd291","name":"Tâm Lý","slug":"tam-ly"},{"id":"620a2253e0fc277084dfd339","name":"Chiến Tranh","slug":"chien-tranh"},{"id":"620a2293e0fc277084dfd489","name":"Phiêu Lưu","slug":"phieu-luu"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620a2370e0fc277084dfd91e","name":"Anh","slug":"anh"},{"id":"620a2381e0fc277084dfd9c6","name":"Canada","slug":"canada"},{"id":"620e0e8fd9648f114cde77f7","name":"Đức","slug":"duc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"luat-chien-tranh-rules-of-engagement","link_embed":"https://vip.opstream12.com/share/d39d59c114b33bb5e40238a65a2ec09b","link_m3u8":"https://vip.opstream12.com/20220624/21822_7ecc93ae/index.m3u8"}]}],"time":"","description":"<p>Tòa Đại sứ Mỹ ở Yemen bị dân chúng biểu tình tấn công và đã xảy ra đọ súng giữa quân nổi loạn và binh sĩ Mỹ. Trung tá Terry được lệnh dẫn 1 toán thủy quân lục chiến đến giải vây và di tản nhân viên ra khỏi nơi nguy hiểm. Nhưng kế hoạch không như mong muốn mặc dù tính mạng gia đình ngài Đại sứ và quốc kỳ Mỹ đã an toàn. Ông phải ra lệnh bắn vào những người biểu tình. Cuối cùng là 83 người chết và hơn 100 người bị thương và họ không có vũ khí trong tay. Một cuộc điều tra và Childers được đưa ra tòa án binh. Nhưng sự thật này ra sao ? Phải chăng Childers sai hay là có nguyên nhân nào khác khi mà 1 vị sĩ quan cấp cao của thuỷ quân lục chiến lại phá vỡ luật giao chiến?</p>","tmdb":{"type":"movie","id":"10479","season":null,"vote_average":6.249,"vote_count":770},"modified":"2022-06-24T15:29:53.000Z","cast":["Tommy Lee Jones","Samuel L. Jackson","Guy Pearce","Ben Kingsley","Bruce Greenwood","Anne Archer","Blair Underwood","Philip Baker Hall","Dale Dye","Amidou","Mark Feuerstein","Nicky Katt","Ryan Hurst","John Speredakos","Baoan Coleman"],"director":["William Friedkin"],"cast_meta":[{"name":"Tommy Lee Jones","name_vi":null,"name_original":"Tommy Lee Jones","tmdb_id":2176,"profile":"https://image.tmdb.org/t/p/w500/mCiZNRAzbnPojJEZwVZWLw9kzxR.jpg","tmdb_url":"https://www.themoviedb.org/person/2176"},{"name":"Samuel L. Jackson","name_vi":null,"name_original":"Samuel L. Jackson","tmdb_id":2231,"profile":"https://image.tmdb.org/t/p/w500/AiAYAqwpM5xmiFrAIeQvUXDCVvo.jpg","tmdb_url":"https://www.themoviedb.org/person/2231"},{"name":"Guy Pearce","name_vi":null,"name_original":"Guy Pearce","tmdb_id":529,"profile":"https://image.tmdb.org/t/p/w500/vTqk6Nh3WgqPubkS23eOlMAwmwa.jpg","tmdb_url":"https://www.themoviedb.org/person/529"},{"name":"Ben Kingsley","name_vi":null,"name_original":"Ben Kingsley","tmdb_id":2282,"profile":"https://image.tmdb.org/t/p/w500/vQtBqpF2HDdzbfXHDzR4u37i1Ac.jpg","tmdb_url":"https://www.themoviedb.org/person/2282"},{"name":"Bruce Greenwood","name_vi":null,"name_original":"Bruce Greenwood","tmdb_id":21089,"profile":"https://image.tmdb.org/t/p/w500/AmfylDaijUHq8cHMq002xfkW7Vk.jpg","tmdb_url":"https://www.themoviedb.org/person/21089"},{"name":"Anne Archer","name_vi":null,"name_original":"Anne Archer","tmdb_id":10427,"profile":"https://image.tmdb.org/t/p/w500/y1uFANprVvJ9cCqVKSl0umIpIXw.jpg","tmdb_url":"https://www.themoviedb.org/person/10427"},{"name":"Blair Underwood","name_vi":null,"name_original":"Blair Underwood","tmdb_id":56871,"profile":"https://image.tmdb.org/t/p/w500/3e6my8gZYS3L2OP4ZTN1psQDYIT.jpg","tmdb_url":"https://www.