Hỷ và Khang tỏ ra hiểu nhau hơn và trở thành một cặp bài trùng. Khang đã giúp Hỷ tìm lại được năng lực và ý chí chiến đấu ban đầu để cùng với các đồng nghiệp khác như Chu Lai Đệ, \"Con cào cào\", Phật Gia phá tan nhiều vụ trọng án: \"Tử Vân Sơn Bá Vương\", \"Bão Táp Học Đường\", \"Phong Ba Ngư Trường\" và \"Anh Hùng Ảo Ảnh\".","tmdb":{"type":"tv","id":"109426","season":1,"vote_average":7,"vote_count":1},"modified":"2025-09-17T18:18:39.000Z","cast":["Trần Hạo Dân","Ngô Nghị Tướng","Thiệu Mỹ Kỳ","Denise Ho Wan-Si","Lê Diệu Tường","Louisa So Yuk-Wah","Winnie Yeung Yuen-Yee","Celine Ma","Marco Ngai Chun-Git","Tạ Thiên Hoa","Hàn Mã Lợi","Lạc Ứng Quân","La Lạc Lâm","La Quân Tả","Leung Wing-Lam"],"director":[],"cast_meta":[{"name":"Trần Hạo Dân","name_vi":"Trần Hạo Dân","name_original":"Benny Chan Ho-Man","tmdb_id":1314817,"profile":"https://image.tmdb.org/t/p/w500/cGNOprzxJntHcg6db0HZOdyCZX8.jpg","tmdb_url":"https://www.themoviedb.org/person/1314817"},{"name":"Ngô Nghị Tướng","name_vi":"Ngô Nghị Tướng","name_original":"Ben Ng Ngai-Cheung","tmdb_id":227806,"profile":"https://image.tmdb.org/t/p/w500/b8XO9X0e1nO0iQ9jpxLuhE7Imhv.jpg","tmdb_url":"https://www.themoviedb.org/person/227806"},{"name":"Thiệu Mỹ Kỳ","name_vi":"Thiệu Mỹ Kỳ","name_original":"Maggie Shiu Mei-Kei","tmdb_id":1173600,"profile":"https://image.tmdb.org/t/p/w500/smUbYgh0zhsCba0nz8Nmb3ODOeP.jpg","tmdb_url":"https://www.themoviedb.org/person/1173600"},{"name":"Denise Ho Wan-Si","name_vi":null,"name_original":"Denise Ho Wan-Si","tmdb_id":126849,"profile":"https://image.tmdb.org/t/p/w500/5RIM6xAHErSeSyZX0HK7tPthgpX.jpg","tmdb_url":"https://www.themoviedb.org/person/126849"},{"name":"Lê Diệu Tường","name_vi":"Lê Diệu Tường","name_original":"Wayne Lai Yiu-Cheung","tmdb_id":123654,"profile":"https://image.tmdb.org/t/p/w500/qm3knPxzkZPgq2SVo1ZTru7MkIM.jpg","tmdb_url":"https://www.themoviedb.org/person/123654"},{"name":"Louisa So Yuk-Wah","name_vi":null,"name_original":"Louisa So Yuk-Wah","tmdb_id":1222763,"profile":