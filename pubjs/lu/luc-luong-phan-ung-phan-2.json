16.com/share/8dcedd6884e553e55dfb6298a6f6cd94","link_m3u8":"https://vip.opstream16.com/20250812/45400_8dcedd68/index.m3u8"},{"name":"32","slug":"32","filename":"Phim TVB Lực Lượng Phản Ứng II (Armed Reaction II) 32#32 # Âu Dương Chấn Hoa, Quan Vịnh Hà # 2000","link_embed":"https://vip.opstream16.com/share/d26ae53c9441b24e4286842b32b98637","link_m3u8":"https://vip.opstream16.com/20250812/45401_d26ae53c/index.m3u8"}]}],"time":"45 phút/tập","description":"Là một bộ phim truyền hình hiện đại của Hong Kong năm 1998 lấy đề tài về nữ cảnh sát được sản xuất bởi đài TVB với sự tham gia của Âu Dương Chấn Hoa, Quan Vịnh Hà, Đằng Lệ Danh, Ngụy Tuấn Kiệt, Chu Mễ Mễ.  Sau thành công của phần đầu tiên, phim được làm tiếp thêm 3 phần (Lực Lượng Phản Ứng II, Lực Lượng Phản Ứng III và Lực Lượng Phản Ứng IV).  Phim lấy bối cảnh trước khi Hong Kong được trao trả lại cho Trung Quốc và xoay quanh cuộc sống của 2 nữ cảnh sát là Chu Tố Nga và Trần Tam Nguyên tại Sở Cảnh sát Hong Kong.","tmdb":{"type":"tv","id":"4957","season":2,"vote_average":8,"vote_count":7},"modified":"2025-08-12T16:14:33.000Z","cast":["Tuyên Huyên","Trần Hào","Đặng Lệ Minh","La Trọng Khiêm","Gloria Tang","Hứa Thiệu Hùng","Hồng Vĩnh Thành","Fred Cheng Chun-Hung","Hải Tuấn Kiệt","Leo Kwan"],"director":[],"cast_meta":[{"name":"Tuyên Huyên","name_vi":"Tuyên Huyên","name_original":"Jessica Hsuan","tmdb_id":230777,"profile":"https://image.tmdb.org/t/p/w500/3hp9D2B1Y7L7imPUHCpHiNgxSY.jpg","tmdb_url":"https://www.themoviedb.org/person/230777"},{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Đặng Lệ Minh","name_vi":"Đặng Lệ Minh","name_original":"Joyce Tang Lai-Ming","tmdb_id":1223072,"profile":"https://image.tmdb.org/t/p/w500/rCGjxrs3HeRoOhzqbAwCucV12qo.jpg","tmdb_url":"https://www.themoviedb.org/person/1223072"},{"name":"La Trọng Khiêm","name_vi":"