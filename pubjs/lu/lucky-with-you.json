stic change in his lifestyle. Yet to find the right person in a vast crowd is a fortune of three lifetimes.","tmdb":{"type":"tv","id":"154105","season":1,"vote_average":7.5,"vote_count":8},"modified":"2025-04-19T08:32:29.000Z","cast":["Wang Likun","Hoàng Cảnh Du","Cheng Cheng","Vương Sách","Tương Long","Qian Jie","Qi Jie","Jiang Qinyun","Wang Zitong","Shi Jing Yi","Lin Xuepiao","Zhang Keying","Wang Mohan","Wang Tianfang","Xu Yukun"],"director":["刘雪松"],"cast_meta":[{"name":"Wang Likun","name_vi":null,"name_original":"Wang Likun","tmdb_id":1251113,"profile":"https://image.tmdb.org/t/p/w500/8Gg85w3dqNmHX0InQu9797kF8NE.jpg","tmdb_url":"https://www.themoviedb.org/person/1251113"},{"name":"Hoàng Cảnh Du","name_vi":"Hoàng Cảnh Du","name_original":"Johnny Huang","tmdb_id":1816461,"profile":"https://image.tmdb.org/t/p/w500/mc7HlXJU0Sr5WkodEHS3csaxi6E.jpg","tmdb_url":"https://www.themoviedb.org/person/1816461"},{"name":"Cheng Cheng","name_vi":null,"name_original":"Cheng Cheng","tmdb_id":3361189,"profile":"https://image.tmdb.org/t/p/w500/eHmNAxcvd9sgy0K42YdkZnjm5CI.jpg","tmdb_url":"https://www.themoviedb.org/person/3361189"},{"name":"Vương Sách","name_vi":"Vương Sách","name_original":"Wang Ce","tmdb_id":2359900,"profile":"https://image.tmdb.org/t/p/w500/R6escfRQgFNP4n62Z9ESX3Kpkt.jpg","tmdb_url":"https://www.themoviedb.org/person/2359900"},{"name":"Tương Long","name_vi":"Tương Long","name_original":"Jiang Long","tmdb_id":2970787,"profile":"https://image.tmdb.org/t/p/w500/hA1cl7W79METFqHv8Vf4JfPxkbI.jpg","tmdb_url":"https://www.themoviedb.org/person/2970787"},{"name":"Qian Jie","name_vi":null,"name_original":"Qian Jie","tmdb_id":3058179,"profile":"https://image.tmdb.org/t/p/w500/7DsNedp5OuiEROelSx9MuvBDMe8.jpg","tmdb_url":"https://www.themoviedb.org/person/3058179"},{"name":"Qi Jie","name_vi":null,"name_original":"Qi Jie","tmdb_id":2328777,"profile":"https://image.tmdb.org/t/p/w500/nMWMKQ15r54Z6bAmQEOxvDOmqid.jpg","tmdb_url":"https://www.themoviedb.org/person/2328777"},{"name":