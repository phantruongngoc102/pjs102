m3u8"}]}],"time":"45 phút/tập","description":"Lưỡng Bất Nghi kể về hoàng hậu xuất thân nhà quan võ, không giỏi cầm kỳ thi hoạ nhưng binh võ lại không thua ai. Nàng bước vào hoàng cung bị vua lạnh nhạt nhiều năm, chịu đủ loại uất ức. Nhưng đến một ngày, tai nạn nhỏ xảy ra, nàng phát hiện... Mình bị đổi thân thể với Hoàng thượng rồi!!! Sau khi đổi thân thể, hoàng hậu giúp hoàng thượng thượng triều, xuất binh đánh trận. Hoàng thượng giúp nàng quản lý hậu cung, mọi hiểu lầm dần được xoá bỏ. Đế hậu thân mật hơn xưa.","tmdb":{"type":"tv","id":"220306","season":1,"vote_average":7,"vote_count":4},"modified":"2025-04-02T11:02:30.000Z","cast":["Cecilia Boey","Trương Hạo Duy","Ma Li","Cao Junxiang","Vu Ba","Miao Haojun","Lin Zilu"],"director":["Hà Chấn Hoa","Lan Siêu"],"cast_meta":[{"name":"Cecilia Boey","name_vi":null,"name_original":"Cecilia Boey","tmdb_id":2037564,"profile":"https://image.tmdb.org/t/p/w500/5Uk3Y6RbwzsQ3xLBCWwmv3zntGo.jpg","tmdb_url":"https://www.themoviedb.org/person/2037564"},{"name":"Trương Hạo Duy","name_vi":"Trương Hạo Duy","name_original":"Zhang Haowei","tmdb_id":2619965,"profile":"https://image.tmdb.org/t/p/w500/bDjAlf80pDTK10ru3jkMV4R2W9b.jpg","tmdb_url":"https://www.themoviedb.org/person/2619965"},{"name":"Ma Li","name_vi":null,"name_original":"Ma Li","tmdb_id":2300712,"profile":"https://image.tmdb.org/t/p/w500/e0i0dL9Wz8Zq4dqpyB2PFIxyM8k.jpg","tmdb_url":"https://www.themoviedb.org/person/2300712"},{"name":"Cao Junxiang","name_vi":null,"name_original":"Cao Junxiang","tmdb_id":2649250,"profile":"https://image.tmdb.org/t/p/w500/hAUu6GgPZBiKZ8LzuKPbNd4gbH6.jpg","tmdb_url":"https://www.themoviedb.org/person/2649250"},{"name":"Vu Ba","name_vi":"Vu Ba","name_original":"Apollo Yu","tmdb_id":237593,"profile":"https://image.tmdb.org/t/p/w500/rQslbjYAvS6Ek7Hdas0wYx6B2T0.jpg","tmdb_url":"https://www.themoviedb.org/person/237593"},{"name":"Miao Haojun","name_vi":null,"name_original":"Miao Haojun","tmdb_id":2448081,"profile":"https://image.tmdb.org/t/p/w500/eMCk