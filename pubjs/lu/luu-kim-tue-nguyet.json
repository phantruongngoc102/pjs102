6","link_m3u8":"https://vip.opstream14.com/20220326/3196_33a47ca7/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/721e7285b298cde5b3d0c973ed8d7b63","link_m3u8":"https://vip.opstream14.com/20220326/3197_70433865/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream14.com/share/b08354f3688c4e4e8c52c207d7d5b8c3","link_m3u8":"https://vip.opstream14.com/20220326/3198_01a29168/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream14.com/share/b59307fdacf7b2db12ec4bd5ca1caba8","link_m3u8":"https://vip.opstream14.com/20220326/3199_21305e06/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream14.com/share/731ae30af8750c2d28720ea3c1f8c2b1","link_m3u8":"https://vip.opstream14.com/20220326/3200_2a331009/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream14.com/share/24ec8468b67314c2013d215b77034476","link_m3u8":"https://vip.opstream14.com/20220326/3201_ae2af2ed/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream14.com/share/799de6d3dae4c924142cf245a1d7f703","link_m3u8":"https://vip.opstream14.com/20220326/3203_62d61838/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream14.com/share/640258597cbc50037072712f964cf5d8","link_m3u8":"https://vip.opstream14.com/20220326/3204_1e81145c/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream14.com/share/9ef2ed4b7fd2c810847ffa5fa85bce38","link_m3u8":"https://vip.opstream14.com/20220326/3205_314c6e05/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream14.com/share/211ed78fe91938b90f84a51944b08d5a","link_m3u8":"https://vip.opstream14.com/20220326/3206_76ee152a/index.m3u8"}]}],"description":"<p>Tưởng Nam Tôn và Chu Tỏa Tỏa, hai cô gái sống ở Thượng Hải những thập niên 90 của thế kỷ trước, tuy có hoàn cảnh gia đình và tính cách khác nhau nhưng cùng xinh đẹp và thông minh. Thuở thiếu thời, vì gia đình gặp cảnh éo le nên Tỏa Tỏa đã được gia đình Nam Tôn chìa tay giúp đỡ, từ đó đặt nền móng cho tình bạn bền bỉ của hai người. Sau khi bước vào đời, trong lúc Chu Tỏa Tỏa chìm nổi trong sự nghiệp, Tưởng Nam Tôn lại tiếp tục theo đuổi việc học hành và bắt đầu yêu đương. Từ đó, hai người đã nếm trải tất cả các hương vị của cuộc sống, dìu dắt nhau để có được những năm tháng vàng son của riêng mình.</p>","tmdb_id":115479,"cast":[],"director":[],"keywords":[],"tmdb":{"id":115479},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/lu/luu-kim-tue-nguyet.json"}