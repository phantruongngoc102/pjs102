,"filename":"City-of-Streamer-tap-34","link_embed":"https://vip.opstream16.com/share/352407221afb776e3143e8a1a0577885","link_m3u8":"https://vip.opstream16.com/20220305/877_d8170ae8/index.m3u8"},{"name":"35","slug":"35","filename":"City-of-Streamer-tap-35","link_embed":"https://vip.opstream16.com/share/dd8eb9f23fbd362da0e3f4e70b878c16","link_m3u8":"https://vip.opstream16.com/20220305/878_b1ea8182/index.m3u8"},{"name":"36","slug":"36","filename":"City-of-Streamer-tap-36","link_embed":"https://vip.opstream16.com/share/d516b13671a4179d9b7b458a6ebdeb92","link_m3u8":"https://vip.opstream16.com/20220305/879_59d7eb52/index.m3u8"},{"name":"37","slug":"37","filename":"City-of-Streamer-tap-37","link_embed":"https://vip.opstream16.com/share/1f50893f80d6830d62765ffad7721742","link_m3u8":"https://vip.opstream16.com/20220305/880_5d4b3fe7/index.m3u8"},{"name":"38","slug":"38","filename":"City-of-Streamer-tap-38","link_embed":"https://vip.opstream16.com/share/7504adad8bb96320eb3afdd4df6e1f60","link_m3u8":"https://vip.opstream16.com/20220305/881_cb419762/index.m3u8"},{"name":"39","slug":"39","filename":"City-of-Streamer-tap-39","link_embed":"https://vip.opstream16.com/share/6c3cf77d52820cd0fe646d38bc2145ca","link_m3u8":"https://vip.opstream16.com/20220305/882_a7dfd0ed/index.m3u8"},{"name":"40","slug":"40","filename":"City-of-Streamer-tap-40","link_embed":"https://vip.opstream16.com/share/210f760a89db30aa72ca258a3483cc7f","link_m3u8":"https://vip.opstream16.com/20220305/883_2464c0af/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim lấy bối cảnh Thượng Hải vào đầu thế kỷ trước, khi quân phiệt phân tranh, quần hùng nổi dậy, tư tưởng cách mạng nổi lên mạnh mẽ.</p><p>Trong phim Hứa Nguỵ Châu vai Dung Gia Thượng - một thiếu gia lãnh đạm, kiêu ngạo, ngoài lạnh trong nóng. Anh luôn có cảm giác lạc lõng giữa đám đông, chỉ khi Phùng Thế Chân xuất hiện thì cô đã trở thành 1 ngoại lệ của cuộc đời anh.</p><p>Cảnh Điềm vai Phùng Thế Chân, người con gái nhìn có vẻ lịch sự nho nhã, yếu đuối, nhưng thực chất là người bình tĩnh, can đảm, tâm tư tinh tế, là một học bá. Cô một thân một mình ẩn náu trong Dung Gia, thận trọng tiếp cận, dần dần trở thành 'Ngụy Anh Lạc phiên bản Trung Hoa Dân Quốc', bằng một cách thầm lặng đã làm cho nhà họ Dung sụp đổ.</p>","tmdb":{"type":"tv","id":"155472","season":1,"vote_average":5.8,"vote_count":7},"modified":"2022-06-08T09:07:59.000Z","cast":["Cảnh Điềm","Timmy Xu","Kinh Siêu","Hải Linh","Chi Jia","Vương Nhất Phi","Mi Mi","Mã Văn Viễn","Chen Sixu"],"director":["Jin Chen","Gan Lu"],"cast_meta":[{"name":"Cảnh Điềm","name_vi":"Cảnh Điềm","name_original":"Jing Tian","tmdb_id":1151657,"profile":"https://image.tmdb.org/t/p/w500/nNlM15XOEJU8A1dKuGEnN7NgxEy.jpg","tmdb_url":"https://www.themoviedb.org/person/1151657"},{"name":"Timmy Xu","name_vi":null,"name_original":"Timmy Xu","tmdb_id":1591362,"profile":"https://image.tmdb.org/t/p/w500/mntBCVt07NMqVafuBKOc9kCFl9U.jpg","tmdb_url":"https://www.themoviedb.org/person/1591362"},{"name":"Kinh Siêu","name_vi":"Kinh Siêu","name_original":"Jing Chao","tmdb_id":1528926,"profile":"https://image.tmdb.org/t/p/w500/6dsz8k3gcXPWRYBpszQyldmT8b.jpg","tmdb_url":"https://www.themoviedb.org/person/1528926"},{"name":"Hải Linh","name_vi":"Hải Linh","name_original":"Hai Ling","tmdb_id":1599900,"profile":"https://image.tmdb.org/t/p/w500/zIvCjzsRIDbLOXd4dy7xlxDht2f.jpg","tmdb_url":"https://www.themoviedb.org/person/1599900"},{"name":"Chi Jia","name_vi":null,"name_original":"Chi Jia","tmdb_id":1210973,"profile":"https://image.tmdb.org/t/p/w500/agfOJWbkvTN8Lig0r9U9w7KQOnp.jpg","tmdb_url":"https://www.themoviedb.org/person/1210973"},{"name":"Vương Nhất Phi","name_vi":"Vương Nhất Phi","name_original":"Wang Yifei","tmdb_id":2124835,"profile":"https://image.tmdb.org/t/p/w500/5GMQ3wbzY8ClycCZXNrkZ3pGoyg.jpg","tmdb_url":"https://www.themoviedb.org/person/2124835"},{"name":"Mi Mi","name_vi":null,"name_original":"Mi Mi","tmdb