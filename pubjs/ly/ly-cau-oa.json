5/49320_e820c40d/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/48a52d5cf371cff4f7f3988a5b577780","link_m3u8":"https://vip.opstream15.com/20250216/49360_48a52d5c/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/723d8c61fce870c3474d080313a4a2fd","link_m3u8":"https://vip.opstream15.com/20250217/49417_723d8c61/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/fc3b60165411bb4ca7b0f03fecc0cdb5","link_m3u8":"https://vip.opstream15.com/20250218/49444_fc3b6016/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/063068a3d11612dff48d7c3b1ac21146","link_m3u8":"https://vip.opstream15.com/20250219/49470_063068a3/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream15.com/share/7ef6079edd98eeec1e24f71b5278eed8","link_m3u8":"https://vip.opstream15.com/20250220/49483_7ef6079e/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream15.com/share/3b7c17c796b407aa4e9b6e239195fa49","link_m3u8":"https://vip.opstream15.com/20250221/49547_3b7c17c7/index.m3u8"}]}],"description":"<p>Vận may giàu sang ập đến bất ngờ, anh công nhân nghèo Lý Cẩu Oa vô tình bước chân vào thế giới của gia đình giàu có, chỉ với mục đích đòi lại công bằng cho người anh em. Nhưng không ngờ tất cả lại là một âm mưu giết người được tính toán kỹ lưỡng. Sự xuất hiện của anh đã châm ngòi cho cuộc chiến thừa kế của tập đoàn Đông Xán, ba người con nhà họ Trương lao vào đấu đá không khoan nhượng, âm mưu chồng chất. Lý Cẩu Oa tầm ngẩm tầm ngầm mà đấm chết voi, từng bước thâm nhập vào vòng xoáy hiểm ác. Đối mặt với đám người lòng lang dạ sói này, anh như một con gián đánh mãi không chết, vượt qua nghịch cảnh hết lần này đến lần khác. Cuối cùng, Lý Cẩu Oa theo đuổi chính nghĩa đã lật đổ kim tự tháp quyền lực, phá được tình thế nan giải.</p><p>&nbsp;</p>","tmdb_id":276618,"cast":["Li Junting","Cola Yao","Yang Yimo","Zhang Tianjing","Zhou Yao","Zhang Xuan