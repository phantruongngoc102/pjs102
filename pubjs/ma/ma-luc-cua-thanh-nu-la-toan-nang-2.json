ip.opstream16.com/20231219/39583_8303cd92/index.m3u8"}]}],"time":"23 phút/tập","description":"Sei, một nhân viên văn phòng 20 tuổi, được triệu tập đến một thế giới khác sau khi hoàn thành công việc làm thêm giờ của mình. Nhưng người đã triệu hồi cô ấy nhìn vào mặt cô ấy và nói, &quot;Đây không phải là Thánh&quot;. Việc bỏ bê này có chơi không !?\n\nSei rời cung điện hoàng gia và che dấu danh hiệu thánh của mình. Cô bắt đầu làm việc tại một phòng thí nghiệm, nơi cô ấy làm thuốc và mỹ phẩm. Cô ta sử dụng ma thuật của mình để ban cho những yêu cầu của mọi người và từ từ mọi người bắt đầu nghi ngờ rằng cô ấy là một vị thánh…\n\nSei có thể tận hưởng cuộc sống thế giới khác mơ mộng của mình mà không có danh hiệu thánh của mình bị phát hiện không ?!","tmdb":{"type":"tv","id":"115236","season":1,"vote_average":7.846,"vote_count":117},"modified":"2024-09-11T12:07:04.000Z","cast":["Yui Ishikawa","Takahiro Sakurai","Takuya Eguchi","Yusuke Kobayashi","Taku Yashiro","Kana Ichinose","Reina Ueda","Yuuichirou Umehara"],"director":[],"cast_meta":[{"name":"Yui Ishikawa","name_vi":null,"name_original":"Yui Ishikawa","tmdb_id":1224288,"profile":"https://image.tmdb.org/t/p/w500/2y1y1W4q8UIR0Vbs4NNvc7722XT.jpg","tmdb_url":"https://www.themoviedb.org/person/1224288"},{"name":"Takahiro Sakurai","name_vi":null,"name_original":"Takahiro Sakurai","tmdb_id":9705,"profile":"https://image.tmdb.org/t/p/w500/8s8owcKmpRAuhzEGjSdRpztthUg.jpg","tmdb_url":"https://www.themoviedb.org/person/9705"},{"name":"Takuya Eguchi","name_vi":null,"name_original":"Takuya Eguchi","tmdb_id":1248374,"profile":"https://image.tmdb.org/t/p/w500/hPPhUp0mM65Lc87Q8WXUEmGQAXx.jpg","tmdb_url":"https://www.themoviedb.org/person/1248374"},{"name":"Yusuke Kobayashi","name_vi":null,"name_original":"Yusuke Kobayashi","tmdb_id":1350418,"profile":"https://image.tmdb.org/t/p/w500/y4ukKDSobZJNuB4H3k89hkrKCDC.jpg","tmdb_url":"https://www.themoviedb.org/person/1350418"},{"name":"Taku Yashiro","name_vi":null,"name_original":"Taku Yashir