vip.opstream14.com/20220402/5143_f8f36931/index.m3u8"},{"name":"16","slug":"16","filename":"ma-nu-dang-yeu-tap-16","link_embed":"https://vip.opstream14.com/share/c9319967c038f9b923068dabdf60cfe3","link_m3u8":"https://vip.opstream14.com/20220402/5144_6a2b48fd/index.m3u8"}]}],"time":"1H5M38S","description":"<p>Na Bong Sun có tính cách vô cùng nhút nhát và thiếu tự tin, cũng không có bất kì bạn thân nào, và cô là một trợ lý nấu ăn tại nhà hàng Sun nhưng luôn bị khiển trách trong công việc. Cô thỉnh thoảng nhìn thấy ma, nhờ có ngoại là pháp sư. Một ngày nọ, Bong Sun bị nhập bởi hồn ma trinh nữ tên là Shin Soon Ae. Để bù đắp cho sự thiếu thốn tình cảm trong cuộc đời ngắn ngủi, Soon Ae quyết định quyến rũ nhiều người đàn ông khác bằng các nhập vào các cô gái, và cô tìm gái cô gái hoàn hảo là Bong Sun. Ông chủ Bong Sun là một ngôi sao đầu bếp kiêu ngạo Kang Sun Woo, người mà cô yêu thầm. Sun-woo vẫn chưa quên được cô bạn gái cũ, nhưng khi Bong Sun dường như thoát khỏi sự nhút nhát của mình và đột nhiên trở nên tự tin, năng động, cuối cùng cô đã lọt vào mắt anh.</p>","tmdb":{"type":"tv","id":"63119","season":1,"vote_average":8.083,"vote_count":138},"modified":"2023-07-13T10:30:26.000Z","cast":["Park Bo-young","Cho Jung-seok","Lim Ju-hwan","Kim Seul-gi","Kwak Si-yang","Park Jung-ah","Lee Hak-ju","Kang Ki-young","Choi Min-chul","Oh Eui-sik","Lee Dae-yeon","Shin Hye-sun","Shin Eun-kyung","Lee Jung-eun","Tae Hang-ho"],"director":["Liu Zai Yuan"],"cast_meta":[{"name":"Park Bo-young","name_vi":"Park Bo-young","name_original":"Park Bo-young","tmdb_id":83036,"profile":"https://image.tmdb.org/t/p/w500/x1LNh8i8XmO3oqNYzRslzYj1VoZ.jpg","tmdb_url":"https://www.themoviedb.org/person/83036"},{"name":"Cho Jung-seok","name_vi":null,"name_original":"Cho Jung-seok","tmdb_id":1223316,"profile":"https://image.tmdb.org/t/p/w500/pVZHsNj31fNMyWixqg26TA9HjU1.jpg","tmdb_url":"https://www.themoviedb.org/person/1223316"},{"name":"Lim Ju-hwan","name_vi":null,"name_original":"Lim Ju-hwan","tmdb_id":122