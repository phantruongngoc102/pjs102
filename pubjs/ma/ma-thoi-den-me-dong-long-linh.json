m/20220608/19311_1c392d8e/index.m3u8"},{"name":"18","slug":"18","filename":"ma-thoi-den-me-dong-long-linh-thuyet-minh-candle-in-the-tomb-the-lost-caverns-tap-18","link_embed":"https://vip.opstream15.com/share/97cc7b6c7b91cf6b4718df7341c89d20","link_m3u8":"https://vip.opstream15.com/20220608/19312_88e5b027/index.m3u8"}]}],"time":"36 phút/tập","description":"<p>Phim kể về một chiếc hài thêu hoa đến từ vùng quê Thiểm Tây, đã dẫn các Mô Kim hiệu úy vào một ngôi mộ cổ bỏ hoang từ thời Đường. Không ngờ, trong mộ lại còn có mộ. U hồn của ngôi mộ cổ Tây Chu đã chặn hết mọi lối ra. Và không ai biết, Thang Huyền hồn là con đường sẽ dẫn xuống họ xuống địa ngục hay là đi vào bóng đêm vô tận? Ra khỏi mộ cổ Tây Chu, trên lưng những kẻ sống sót sau chuyến đi thành cổ Tinh Tuyệt bỗng dưng xuất hiện một dấu ấn hình con mắt. Đó phải chăng là một lời nguyền từ mấy ngàn năm trước? Bởi Giáo sư Tôn, người duy nhất giải được bí mật, vừa nhìn thấy dấu hiệu ấy đã vô cùng kinh hãi, chỉ thốt lên: “Thiên cơ không thể tiết lộ…”</p>","tmdb":{"type":"tv","id":"101306","season":1,"vote_average":8,"vote_count":20},"modified":"2022-06-08T16:55:50.000Z","cast":["Pan Yueming","Khương Triều","Trương Vũ Kỳ","Tong Lei","Cao Vỹ Quang","Cao Hùng","Zhou Xiaoou","Hu Ming","Vương Khôi Dung","Shu Yaoxuan","Zach Ireland","Chen Youwang","Zhang Jinan","Ji Haixing","Lý Tông Lâm"],"director":["Fei Zhenxiang"],"cast_meta":[{"name":"Pan Yueming","name_vi":null,"name_original":"Pan Yueming","tmdb_id":138734,"profile":"https://image.tmdb.org/t/p/w500/xxFTAdA2Nsiz5YRCwGer6MVXOzT.jpg","tmdb_url":"https://www.themoviedb.org/person/138734"},{"name":"Khương Triều","name_vi":"Khương Triều","name_original":"Jiang Chao","tmdb_id":235521,"profile":"https://image.tmdb.org/t/p/w500/q7Y4kNRkIK1GrfCZSuP7GqRKw85.jpg","tmdb_url":"https://www.themoviedb.org/person/235521"},{"name":"Trương Vũ Kỳ","name_vi":"Trương Vũ Kỳ","name_original":"Zhang Yuqi","tmdb_id":74947,"profile":"https://image.tmdb.org/t/p/w500/8hB76EhyawwiNCzjPp2IfmONG3l.