11.com/share/c862b02975932127779faae44decffb4","link_m3u8":"https://vip.opstream11.com/20220402/8725_31c693f4/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Mã Vĩnh Trinh - Ma Yong Zhen xoay quanh cuộc đời nhiều biến cố của chàng trai trẻ Mã Vĩnh Trinh rời quê nghèo Sơn Đông lên Thượng Hải tìm kiếm giấc mơ đổi đời. Khi mới đến đây, anh đã trải qua rất nhiều gian nan, nhưng sau cùng đã gây dựng được một địa bàn riêng tại nơi phồn hoa này. Tuy nhiên, các thế lực xấu xa không dung nạp được Mã Vĩnh Trinh chính nghĩa, vì vậy ở bến Thượng Hải đã diễn ra một cuộc chiến giữa cái thiện và cái ác làm rung động lòng người.</p>","tmdb":{"type":"tv","id":"94932","season":1,"vote_average":0,"vote_count":0},"modified":"2023-07-14T10:36:05.000Z","cast":["Hà Gia Kính","Phạm Băng Băng","Trình Phối Phối"],"director":["Cúc Giác Lượng"],"cast_meta":[{"name":"Hà Gia Kính","name_vi":"Hà Gia Kính","name_original":"Kenny Ho Ka-King","tmdb_id":109506,"profile":"https://image.tmdb.org/t/p/w500/6gQZYCr0ts1NAfCDNboxkNCA0L6.jpg","tmdb_url":"https://www.themoviedb.org/person/109506"},{"name":"Phạm Băng Băng","name_vi":"Phạm Băng Băng","name_original":"Fan Bingbing","tmdb_id":64439,"profile":"https://image.tmdb.org/t/p/w500/pV2wYJiiPd6cgHK580PKD0GM4Dc.jpg","tmdb_url":"https://www.themoviedb.org/person/64439"},{"name":"Trình Phối Phối","name_vi":"Trình Phối Phối","name_original":"Cheng Pei-Pei","tmdb_id":1624,"profile":"https://image.tmdb.org/t/p/w500/jp33KMCMjy08FQWAtxhvJS2tHnn.jpg","tmdb_url":"https://www.themoviedb.org/person/1624"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/ma-vinh-trinh.json"}