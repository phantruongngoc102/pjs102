199_70dc85de/index.m3u8"},{"name":"6","slug":"6","filename":"MaVovaConRe.1080P.H264.e06.LT","link_embed":"https://vip.opstream11.com/share/f3080aa38ed82ae4810217565ece7706","link_m3u8":"https://vip.opstream11.com/20241018/55200_f3080aa3/index.m3u8"},{"name":"7","slug":"7","filename":"MaVovaConRe.1080P.H264.e07.LT","link_embed":"https://vip.opstream11.com/share/2a5572e1be8bd528a8b2c223800e7eb0","link_m3u8":"https://vip.opstream11.com/20241018/55201_2a5572e1/index.m3u8"},{"name":"8","slug":"8","filename":"MaVovaConRe.1080P.H264.e08.LT","link_embed":"https://vip.opstream11.com/share/fb9f8f83fb66696d2116baa8955f4b55","link_m3u8":"https://vip.opstream11.com/20241018/55202_fb9f8f83/index.m3u8"},{"name":"9","slug":"9","filename":"MaVovaConRe.1080P.H264.e09.LT","link_embed":"https://vip.opstream11.com/share/aa9b367b1bad2cef8573a5d92bc2fd3f","link_m3u8":"https://vip.opstream11.com/20241018/55203_aa9b367b/index.m3u8"},{"name":"10","slug":"10","filename":"MaVovaConRe.1080P.H264.e10.LT","link_embed":"https://vip.opstream11.com/share/995ecd5d1184eb7a6c6c1cad6f442476","link_m3u8":"https://vip.opstream11.com/20241018/55204_995ecd5d/index.m3u8"},{"name":"11","slug":"11","filename":"MaVovaConRe.1080P.H264.e11End.LT","link_embed":"https://vip.opstream11.com/share/b8c7803cae4625f5a77592749e5d6fff","link_m3u8":"https://vip.opstream11.com/20241018/55213_b8c7803c/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Bộ phim hài ngắn độc lập về môi trường \"Bà, Má, Con Rể\" mô tả một gia đình ba thế hệ, làm thế nào để hòa thuận trong xã hội ngày nay, nó đầy ấm áp và vui nhộn, với các nhân vật và câu chuyện mà bạn và tôi đã quen thuộc. Ba thế hệ của gia đình họ Ngô sống chung một nhà, và mẹ vợ Gu Xiaoman [Xian Yin] sống với con gái Wu Guobang [Huang Kaixin], con rể Wu Jinhui [Liu Jiang] và cháu gái Wu Yingyin [Pan Fangfang]. Bang là người mạnh dạn, có tình cảm, kế thừa công việc kinh doanh của cha, chăm sóc một gian hàng bằng xương bằng thịt, tuy nhiên, anh chồng lại là một người mẹ chồng, là người trì hoãn và đảm việc nhà có nề nếp. Hai người có tính cách khác nhau, nhưng họ không thể bổ sung cho nhau. Cô con gái Yin bị ảnh hưởng bởi suy nghĩ của những người phụ nữ lớn từ khi còn nhỏ, có tính cách độc lập và chuyên tâm vào sự nghiệp của mình, cô sống tại nhà họ Ngô sau khi kết hôn với bạn trai Li Zhixin [Zhang Weijian]. Xin cảm thấy không thoải mái với gia đình nữ quyền này, và hết lần này đến lần khác cùng với ông nội Hui bắt đầu một cuộc cách mạng, kết quả cuộc hôn nhân của hai cặp đôi được thắp lên! Xin anh trai Li Zhiwei [do Liu Qingyun thủ vai] là người vô tư và vô tư, làm việc trong một nhà để xe, và phát triển mối quan hệ với Si You Huizhong [do Luo Huijuan thủ vai] trên Yin Shangang, nhưng do sự khác biệt về địa vị giữa hai người, những lời đàm tiếu giữa bạn bè vô hình trung đối với người khác Áp lực khiến họ gặp vô vàn trở ngại.</i></p>","tmdb":{"type":"tv","id":"225748","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-18T14:07:24.000Z","cast":["Trương Vệ Kiện","Lưu Thanh Vân","Jacqueline Law Wai-Guen","Poon Fong-Fong","Wong Hoi-Yan","Lưu Giang","Seung Yee","Hung Chiu","Gary Ho Kwai-Lam","Châu Hải My"],"director":["Lương Gia Thụ"],"cast_meta":[{"name":"Trương Vệ Kiện","name_vi":"Trương Vệ Kiện","name_original":"Dicky Cheung Wai-Kin","tmdb_id":83489,"profile":"https://image.tmdb.org/t/p/w500/b2a2h0Xz4pDk7B0WDFADvzc5S1g.jpg","tmdb_url":"https://www.themoviedb.org/person/83489"},{"name":"Lưu Thanh Vân","name_vi":"Lưu Thanh Vân","name_original":"Sean Lau Ching-wan","tmdb_id":940339,"profile":"https://image.tmdb.org/t/p/w500/ecxJyPA6EPDG2AXomVJORaN4qLZ.jpg","tmdb_url":"https://www.themoviedb.org/person/940339"},{"name":"Jacqueline Law Wai-Guen","name_vi":null,"name_original":"Jacqueline Law Wai-Guen","tmdb_id":1361817,"profile":"https://image.tmdb.org/t/p/w500/uEZCTKgW4CTO0ALAhzAZUfKVgXt.jpg","tmdb_url":"https://www.themoviedb.org/person/1361817"},{"name":"Poon Fong-Fong","name_vi":null,"name_original":"Poon Fong-Fong","tmdb_i