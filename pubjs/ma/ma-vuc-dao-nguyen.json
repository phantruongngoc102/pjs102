muốn bảo vệ nhóm, chỉ giết những người muốn truy sát họ, nhưng thực sự Thanh Vân và Bạch là 2 gian tế tham gia ma vực để điều tra. Mộ Dung Bạch đã cho thủ lĩnh uống thuốc độc mà chết, lúc này Thanh Vân mới phát hiện ra Phó Thiên Sơn là cha ruột của mình nên đã đứng lên lãnh đạo ma vực.</i></p>","tmdb":{"type":"tv","id":"107900","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-23T10:43:53.000Z","cast":["Lưu Đức Hoa","Angie Chiu Nga-Chi","Ngô Khải Hoa","Elaine Chow Sau-Lan","Sek Kin","Chu Tit-Wo","Wong Wan-Choi","Lisa Lui Yau-Wai","Yeung Chak-Lam","Lau Suk-Yee"],"director":["Vương Thiên Lâm"],"cast_meta":[{"name":"Lưu Đức Hoa","name_vi":"Lưu Đức Hoa","name_original":"Andy Lau","tmdb_id":25246,"profile":"https://image.tmdb.org/t/p/w500/z9R2yerjfgxwDWIH8sjiS0hhcre.jpg","tmdb_url":"https://www.themoviedb.org/person/25246"},{"name":"Angie Chiu Nga-Chi","name_vi":null,"name_original":"Angie Chiu Nga-Chi","tmdb_id":327585,"profile":"https://image.tmdb.org/t/p/w500/tCaMjfyoDronfODreMxusKfQyj.jpg","tmdb_url":"https://www.themoviedb.org/person/327585"},{"name":"Ngô Khải Hoa","name_vi":"Ngô Khải Hoa","name_original":"Lawrence Ng Kai-Wah","tmdb_id":122818,"profile":"https://image.tmdb.org/t/p/w500/nOgwDEg0QSavgTo9mscVSkKTpLa.jpg","tmdb_url":"https://www.themoviedb.org/person/122818"},{"name":"Elaine Chow Sau-Lan","name_vi":null,"name_original":"Elaine Chow Sau-Lan","tmdb_id":1195439,"profile":"https://image.tmdb.org/t/p/w500/gUqhk8swXk6qDTkv5sL9lP8vdfK.jpg","tmdb_url":"https://www.themoviedb.org/person/1195439"},{"name":"Sek Kin","name_vi":null,"name_original":"Sek Kin","tmdb_id":65971,"profile":"https://image.tmdb.org/t/p/w500/aFf4n1OvDtCgrI4i3dNJktAaHkv.jpg","tmdb_url":"https://www.themoviedb.org/person/65971"},{"name":"Chu Tit-Wo","name_vi":null,"name_original":"Chu Tit-Wo","tmdb_id":1575541,"profile":"https://image.tmdb.org/t/p/w500/mMrzg1XHDfGvkRXCW6xlzCOxgOz.jpg","tmdb_url":"https://www.themoviedb.org/person/1575541"},{"name":"Wong Wan-Choi","name_vi":null,"