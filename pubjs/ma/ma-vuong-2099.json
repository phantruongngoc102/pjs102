ấn thân vào con đường đầy chông gai, thậm chí là phải trở thành người đứng đầu của giới \"streamer\".</p>","tmdb":{"type":"tv","id":"234538","season":1,"vote_average":7.75,"vote_count":32},"modified":"2025-05-19T11:10:39.000Z","cast":["Hino Satoshi","Miku Ito","Hana Hishikawa","Daisuke Namikawa","Masaya Matsukaze","Shizuka Itoh"],"director":[],"cast_meta":[{"name":"Hino Satoshi","name_vi":"Hino Satoshi","name_original":"Satoshi Hino","tmdb_id":224413,"profile":"https://image.tmdb.org/t/p/w500/8ZJIiwIVF2zDyyFr7oXewj0eEuu.jpg","tmdb_url":"https://www.themoviedb.org/person/224413"},{"name":"Miku Ito","name_vi":"Miku Ito","name_original":"Miku Ito","tmdb_id":1530921,"profile":"https://image.tmdb.org/t/p/w500/kP7JBvveQO9ucYpmOvUNcW5RLAp.jpg","tmdb_url":"https://www.themoviedb.org/person/1530921"},{"name":"Hana Hishikawa","name_vi":null,"name_original":"Hana Hishikawa","tmdb_id":2864386,"profile":"https://image.tmdb.org/t/p/w500/epCzuP9ZmBMonKK2Z6FOKoq2b7k.jpg","tmdb_url":"https://www.themoviedb.org/person/2864386"},{"name":"Daisuke Namikawa","name_vi":null,"name_original":"Daisuke Namikawa","tmdb_id":110665,"profile":"https://image.tmdb.org/t/p/w500/iw0X8oDutxaBAri3Ifga8nhdUJK.jpg","tmdb_url":"https://www.themoviedb.org/person/110665"},{"name":"Masaya Matsukaze","name_vi":null,"name_original":"Masaya Matsukaze","tmdb_id":934841,"profile":"https://image.tmdb.org/t/p/w500/tUd3ybETFz4hBGLnaqt3VreGeDJ.jpg","tmdb_url":"https://www.themoviedb.org/person/934841"},{"name":"Shizuka Itoh","name_vi":null,"name_original":"Shizuka Itoh","tmdb_id":571993,"profile":"https://image.tmdb.org/t/p/w500/n47YvFPlJzl8HnsoDBtM8SUqG8q.jpg","tmdb_url":"https://www.themoviedb.org/person/571993"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/ma-vuong-2099.json"}