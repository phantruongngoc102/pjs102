63f4d0/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/b29c5090440079d0121f4973000eeba5","link_m3u8":"https://vip.opstream14.com/20221217/28561_6e7474bb/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/cdd7da5c0696e931cef4d22f7b0cb58c","link_m3u8":"https://vip.opstream14.com/20221217/28562_8758d78c/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream14.com/share/06ac68cc0db1c6c3992eb55812168e55","link_m3u8":"https://vip.opstream14.com/20221218/28597_209e465b/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream14.com/share/48699cb3676ece50d68d3e1ebe2e03d7","link_m3u8":"https://vip.opstream14.com/20221218/28598_2a6b9336/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream14.com/share/c45b876541ee45037b6ba8c7af1608ac","link_m3u8":"https://vip.opstream14.com/20221219/28632_d6ee5787/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream14.com/share/dd397459f8f50e4cd7c5e9d77b8b19f1","link_m3u8":"https://vip.opstream14.com/20221219/28633_c0b8b6f3/index.m3u8"}]}],"description":"<p>\"Mặc Bạch\" do Vương Nham làm đạo diễn, là một bộ phim tình cảm ngọt ngào với sự tham gia của Trương Tuyết Nghênh, Tất Văn Quân, Quách Phẩm Siêu, Đại Tư. Bộ phim được chuyển thể từ tiểu thuyết \"Đại Thần Phu Nhân Nhà Ngài Lại AFK Rồi\" của tác giả Đại Quất Miêu, Bộ phim chủ yếu xoay quanh câu chuyện tình yêu của gà mờ Lục Hoàn Hoàn và đại thần Hàn Kinh Mạc. Lục Hoàn Hoàn vì trượt tay trong trò chơi mà lỡ đâm bay đại thần đứng đầu toàn server \"Mặc Bạch Chi Gian\" . Thực ra Lục Hoàn Hoàn ngoài đời luôn theo dõi tác phẩm của Hàn Kinh Mạc nhưng một lần cô lại bị anh tạt nước mà từ đó hay người trở thành kẻ thù. Nhưng Lục Hoàn Hoàn không thể ngờ được Mặc Bạch Chi Gian lại chính là Hàn Kinh Mạc, dù ngoài đời hay là trong game thì anh vẫn luôn bên cô cả hai từ thế giới game đến hiện thực, họ yêu nhau và hiện thực hóa ước mơ diễn xuất của mình.</p>","tmdb