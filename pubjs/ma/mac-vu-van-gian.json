64e8c9d3f72f86829","link_m3u8":"https://vip.opstream17.com/20240623/12941_938336e7/index.m3u8"}]}],"description":"<p>Phim kể về con gái huyện lệnh là Tiết Phương Phi đang sống hạnh phúc, sung túc thì gặp phải biến cố, mất đi hết thảy. Ân nhân cứu mạng cô là con gái trung thư lệnh, Khương Lê đã nhờ Tiết Phương Phi đóng giả thân phận quay trở về kinh thành, nhờ vào sự giúp đỡ của Tiêu quốc công Tiêu Hoành và mọi người, cô đã khắc phục được muôn vàn nguy hiểm khó khăn, không ngừng cố gắng chống lại sự bất công. Cuối cùng Tiết Phương Phi đã cứu được người cha vô tình bị đẩy vào ngục, đồng thời giúp Tiêu Hoành bảo vệ chính nghĩa, bảo vệ bách tính muôn dân, và có lại được cuộc sống tốt đẹp.</p><p>&nbsp;</p>","tmdb_id":236033,"cast":["Ngô Cẩn Ngôn","Vương Tinh Việt","Trần Hâm Hải","Lương Vĩnh Kỳ","Trần Kiều Ân","Lưu Tá Ninh","Lý Mộng","Dương Siêu Việt","Zhang Yao","Hà Phụng Thiên","Triệu Gia Mẫn","Ngãi Mễ","Trần Vũ Hiền"],"director":["Bai Yunmo","Ma ShiGe","Lü Haojiji"],"keywords":[],"tmdb":{"type":"tv","id":"236033","season":1,"vote_average":8.2,"vote_count":39},"cast_meta":[{"name":"Ngô Cẩn Ngôn","name_vi":"Ngô Cẩn Ngôn","name_original":"Wu Jinyan","tmdb_id":2091760,"profile":"https://image.tmdb.org/t/p/w500/f3TigKaQis7ciGJpovK9J7QGXIx.jpg","tmdb_url":"https://www.themoviedb.org/person/2091760"},{"name":"Vương Tinh Việt","name_vi":"Vương Tinh Việt","name_original":"Wang Xingyue","tmdb_id":3157355,"profile":"https://image.tmdb.org/t/p/w500/mi4dqtBt53fRpRWFTgCf9GHgOA7.jpg","tmdb_url":"https://www.themoviedb.org/person/3157355"},{"name":"Trần Hâm Hải","name_vi":"Trần Hâm Hải","name_original":"Chen Xinhai","tmdb_id":3989428,"profile":"https://image.tmdb.org/t/p/w500/1Io0Q04kmGzgTHjYrDFHrsRTpAv.jpg","tmdb_url":"https://www.themoviedb.org/person/3989428"},{"name":"Lương Vĩnh Kỳ","name_vi":"Lương Vĩnh Kỳ","name_original":"Liang Yongqi","tmdb_id":4621564,"profile":"https://image.tmdb.org/t/p/w500/qMTdWNBc5pzPyMDp7SMr6g8YzX2.jpg","tmdb_url":"https://www.themoviedb.org/person/4621