̀ một gia đình có dòng dõi Nho học nổi tiếng, trong gia đình các con cái đều là người giỏi văn đàn, có tiếng tăm từ sớm. Chỉ có duy nhất người con gái thứ ba Tống Trúc, ngoại trừ ngoại hình ưa nhìn thì không thừa hưởng từ cha mẹ mình bất kì ưu điểm nào.</p><p>&nbsp;</p>","tmdb_id":242496,"cast":["Tiêu Yến","Trạch Tử Lộ","Thịnh Anh Hào","Chung Lệ Lệ","Yu Xiaolei","Sun Zihang","Lou Xinyue","Deng Zhihao","Ge Si","Pingyou Yang","Miao Yu","Yu Ziyang","Zheng Xiaoning","Liao Pengfei","Hu Ming"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"242496","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Tiêu Yến","name_vi":"Tiêu Yến","name_original":"Xiao Yan","tmdb_id":2229742,"profile":"https://image.tmdb.org/t/p/w500/h5PFW2h56ZVS8P0b61sU1mwGXSr.jpg","tmdb_url":"https://www.themoviedb.org/person/2229742"},{"name":"Trạch Tử Lộ","name_vi":"Trạch Tử Lộ","name_original":"Zhai Zilu","tmdb_id":2442001,"profile":"https://image.tmdb.org/t/p/w500/yv18GqjdBKid5geIzH7gA2HNbYQ.jpg","tmdb_url":"https://www.themoviedb.org/person/2442001"},{"name":"Thịnh Anh Hào","name_vi":"Thịnh Anh Hào","name_original":"Sheng Yinghao","tmdb_id":2660693,"profile":"https://image.tmdb.org/t/p/w500/8ALMtD9mfG3h3IDuLZV7F84AI7z.jpg","tmdb_url":"https://www.themoviedb.org/person/2660693"},{"name":"Chung Lệ Lệ","name_vi":"Chung Lệ Lệ","name_original":"Zhong Lili","tmdb_id":2876779,"profile":"https://image.tmdb.org/t/p/w500/npfc7abyPKD7f7sXuuEm27MvTm4.jpg","tmdb_url":"https://www.themoviedb.org/person/2876779"},{"name":"Yu Xiaolei","name_vi":null,"name_original":"Yu Xiaolei","tmdb_id":4729520,"profile":"https://image.tmdb.org/t/p/w500/bwFXOom8c0ilqzdT1fAdYRyGdyl.jpg","tmdb_url":"https://www.themoviedb.org/person/4729520"},{"name":"Sun Zihang","name_vi":null,"name_original":"Sun Zihang","tmdb_id":2787658,"profile":"https://image.tmdb.org/t/p/w500/eAdhS2xFNkLPabatN32RBEgoZTB.jpg","tmdb_url":"https://www.themoviedb.org/person/27