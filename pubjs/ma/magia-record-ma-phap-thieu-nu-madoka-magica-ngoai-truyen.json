t đầu....</p>","tmdb_id":94523,"cast":["Momo Asakura","Sora Amamiya","Shiina Natsukawa","Yui Ogura","Ayane Sakura","Ayaka Ohashi","Kaori Ishihara","Mikako Komatsu","Kana Hanazawa"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"94523","season":1,"vote_average":6.9,"vote_count":78},"cast_meta":[{"name":"Momo Asakura","name_vi":null,"name_original":"Momo Asakura","tmdb_id":1530922,"profile":"https://image.tmdb.org/t/p/w500/gdzYEujO3I5nZCyAx95Mo47fZ86.jpg","tmdb_url":"https://www.themoviedb.org/person/1530922"},{"name":"Sora Amamiya","name_vi":null,"name_original":"Sora Amamiya","tmdb_id":1325034,"profile":"https://image.tmdb.org/t/p/w500/4ZZcdFH4QgbIC8AeJ3BLG1ue7G5.jpg","tmdb_url":"https://www.themoviedb.org/person/1325034"},{"name":"Shiina Natsukawa","name_vi":null,"name_original":"Shiina Natsukawa","tmdb_id":1492991,"profile":"https://image.tmdb.org/t/p/w500/nywEk8MfRpKhbpDJBg9Gr0WRMJE.jpg","tmdb_url":"https://www.themoviedb.org/person/1492991"},{"name":"Yui Ogura","name_vi":null,"name_original":"Yui Ogura","tmdb_id":1057990,"profile":"https://image.tmdb.org/t/p/w500/vUuyLWde2CEd5G0oqeEzzFE6qqA.jpg","tmdb_url":"https://www.themoviedb.org/person/1057990"},{"name":"Ayane Sakura","name_vi":null,"name_original":"Ayane Sakura","tmdb_id":992869,"profile":"https://image.tmdb.org/t/p/w500/yPbTmntASE9psPIMhNGU5oo6vIH.jpg","tmdb_url":"https://www.themoviedb.org/person/992869"},{"name":"Ayaka Ohashi","name_vi":null,"name_original":"Ayaka Ohashi","tmdb_id":1256547,"profile":"https://image.tmdb.org/t/p/w500/2nvtejsD4sc6QNlPhGedKvr3VS1.jpg","tmdb_url":"https://www.themoviedb.org/person/1256547"},{"name":"Kaori Ishihara","name_vi":null,"name_original":"Kaori Ishihara","tmdb_id":1071391,"profile":"https://image.tmdb.org/t/p/w500/6L8Y52WSpky0iMMa0YYT67CaAQg.jpg","tmdb_url":"https://www.themoviedb.org/person/1071391"},{"name":"Mikako Komatsu","name_vi":null,"name_original":"Mikako Komatsu","tmdb_id":1281498,"profile":"https://image.tmdb.org/t/p/w500/13tQEZ1tLdOmi7oGoRJ4xep1ODQ