stream12.com/share/9b531edcbb1a4a81e667cd8acce6b8ab","link_m3u8":"https://vip.opstream12.com/20251110/29891_9b531edc/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/96a0d70498272acfee21d3dbae846113","link_m3u8":"https://vip.opstream12.com/20251110/29892_96a0d704/index.m3u8"}]}],"description":"<p>Cốt truyện xoay quanh mối quan hệ phức tạp và những ân oán trong giang hồ giữa hai cô gái xinh đẹp và tài năng: Quân Ỷ La và Thẩm Tư Như, cùng với hai người đàn ông định mệnh: Mộc Thịnh và Lâm Sơ Nhất.<br>Quân Ỷ La là tiểu thư đài các của gia đình bề thế, nhưng lại đem lòng yêu Mộc Thịnh, thiếu chủ Mộc gia có chí lớn. Hai người hẹn ước ngày Mộc Thịnh thành đạt sẽ quay về kết hôn.<br>Tuy nhiên, số phận trớ trêu khiến Ỷ La bị cuốn vào vòng xoáy của giang hồ và kết hôn với Lâm Sơ Nhất, người đàn ông yêu thương cô thật lòng và muốn che chở cho cô. Khi Mộc Thịnh quay về, anh đã cưới Thẩm Tư Như – người vốn là cô nhi sống nhờ nhà Ỷ La – làm vợ.</p>","tmdb_id":206937,"cast":["Hoắc Tư Yến","Chung Hán Lương","Feifei Sun","Hà Thịnh Minh","Trần Kiện Phong","Đặng Tụy Văn","Lưu Tùng Nhân","Phùng Thiệu Phong","Vương Hiểu Thần"],"director":["Viên Anh Minh","Vương Thiếu Kiệt"],"keywords":[],"tmdb":{"type":"tv","id":"206937","season":1,"vote_average":6,"vote_count":1},"cast_meta":[{"name":"Hoắc Tư Yến","name_vi":"Hoắc Tư Yến","name_original":"Huo Siyan","tmdb_id":147705,"profile":"https://image.tmdb.org/t/p/w500/cq5plUagaqNS0aYFSjWft44BJYJ.jpg","tmdb_url":"https://www.themoviedb.org/person/147705"},{"name":"Chung Hán Lương","name_vi":"Chung Hán Lương","name_original":"Wallace Chung","tmdb_id":1183233,"profile":"https://image.tmdb.org/t/p/w500/mDJQSyCQdPW2lJDbY46udu0161n.jpg","tmdb_url":"https://www.themoviedb.org/person/1183233"},{"name":"Feifei Sun","name_vi":null,"name_original":"Feifei Sun","tmdb_id":2390490,"profile":"https://image.tmdb.org/t/p/w500/d0NzseczIqezrJIAXKkSzeAyx9L.jpg","tmdb_url":"https://www.themoviedb.org/person/2390490"},{"name":"Hà Th