.opstream12.com/20220323/4887_3f07fe9d/index.m3u8"},{"name":"07","slug":"07","filename":"No.1-For-You-tap-07","link_embed":"https://vip.opstream12.com/share/0b846c55b4bde6baae8c12a2e53ae8c7","link_m3u8":"https://vip.opstream12.com/20220323/4888_5e4e73d9/index.m3u8"}]}],"time":"25 phút / tập","description":"<p>Lúc nào cũng bị người khác chèn ép là cảm giác thế nào? Châu Thư Dật trừng mắt nhìn bảng thành tích của cả lớp trong tay, cậu lại một lần nữa trông thấy cái tên Cao Sĩ Đức đè lên đầu mình. Cậu không hiểu, kể từ năm lớp năm khi người này bước vào cuộc đời cậu, vị trí thứ nhất đã bỏ cậu mà đi, để cậu từ “luôn là số một” trở thành “số hai vạn năm”… Cuối cùng, đến năm lớp 12 thì cậu không chịu đựng nổi nữa. Châu Thư Dật cười trộm, tốt lắm, vào đại học là đường ai nấy đi, cuối cùng họ cũng có thể không gặp lại nhau nữa rồi! Châu Thư Dật vui sướng đón chào cuộc sống đại học, cậu vào câu lạc bộ bơi lội mà mình yêu thích nhất, lúc nào cũng được tán tụng. Nào ngờ, trước khi tốt nghiệp, trong một cuộc thi dành cho sinh viên mới gia nhập câu lạc bộ, cậu lại thấy Cao Sĩ Đức xuất hiện. Lần này, không những chưa kịp đoạt giải quán quân trước mặt đàn chị mà mình yêu thầm, cậu còn bị ngã xuống nước, chuột rút suýt nữa chết đuối. Châu Thư Dật chỉ có ba chữ… Thật – muốn – chết! Sau đó cậu lại phát hiện ra đàn chị hẹn hò với cậu bạn thân nhất của mình, cậu càng muốn đập đầu vào gối tự sát, quả nhiên cứ gặp Cao Sĩ Đức là không có chuyện gì tốt đẹp! Cậu không biết trời đất rộng lớn như vậy, tại sao đi đến đâu Cao Sĩ Đức cũng bám theo cậu. Người đó nói… “Tôi luôn dõi theo cậu”, vậy muốn dõi theo đến lúc nào mới chịu buông tha cho cậu đây?</p>","tmdb":{"type":"tv","id":"116175","season":1,"vote_average":7.6,"vote_count":36},"modified":"2023-05-04T18:01:37.000Z","cast":["YU","Sam Lin","Ray Chang","Richard Lee","Moon Lee","Hsia Teng-hung","Shih Chih-tian","Eriku Yoza","Evan Luo"],"director":["Jui-Chih Chiang"],"cast_meta":[{"name":"YU","name_vi":null,"name_original":"YU","tmdb_id":3066