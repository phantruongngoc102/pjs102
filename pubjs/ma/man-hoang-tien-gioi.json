hiện tại. Sau đó, nhờ một hành động thiện mà hắn được đại tiểu thư của Chu phủ và sư huynh của cô ấy để ý tới. Họ đưa hắn tới Chu phủ để trải qua thử thách. Sau cố gắng không ngừng và may mắn có được một vài cơ duyên, hắn đã trở thành đệ tử ngoại môn của Huyền Tâm Tông và bắt đầu hành trình tu tiên của mình.</p>","tmdb_id":273299,"cast":["Gu Jiangshan","Mace","Yan Ning","Xiang Xu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"273299","season":1,"vote_average":7,"vote_count":2},"cast_meta":[{"name":"Gu Jiangshan","name_vi":null,"name_original":"Gu Jiangshan","tmdb_id":2532243,"profile":"https://image.tmdb.org/t/p/w500/9AHZohwKutKWdsexJDbfFf1SP6i.jpg","tmdb_url":"https://www.themoviedb.org/person/2532243"},{"name":"Mace","name_vi":null,"name_original":"Mace","tmdb_id":3838953,"profile":"https://image.tmdb.org/t/p/w500/tTiTunzRP0Hw6VqnUtm8cafKSAT.jpg","tmdb_url":"https://www.themoviedb.org/person/3838953"},{"name":"Yan Ning","name_vi":null,"name_original":"Yan Ning","tmdb_id":3900469,"profile":"https://image.tmdb.org/t/p/w500/ktlujr9S3g1GgR4wFlXbUK9Pfz0.jpg","tmdb_url":"https://www.themoviedb.org/person/3900469"},{"name":"Xiang Xu","name_vi":null,"name_original":"Xiang Xu","tmdb_id":2723047,"profile":"https://image.tmdb.org/t/p/w500/hE2BnMQ7KoGyEyM3fNPCWzALLCk.jpg","tmdb_url":"https://www.themoviedb.org/person/2723047"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/man-hoang-tien-gioi.json"}