_m3u8":"https://vip.opstream10.com/20220421/9584_52752bad/index.m3u8"},{"name":"35","slug":"35","filename":"manh-phi-gia-dao-thuyet-minh-mengfei-comes-across-tap-35","link_embed":"https://vip.opstream10.com/share/07dd4d5a72f5740ef0f035f201951476","link_m3u8":"https://vip.opstream10.com/20220421/9586_cd975d4a/index.m3u8"},{"name":"36","slug":"36","filename":"manh-phi-gia-dao-thuyet-minh-mengfei-comes-across-tap-36","link_embed":"https://vip.opstream10.com/share/68bc9477d0f2c908eed9498bf926d89e","link_m3u8":"https://vip.opstream10.com/20220421/9587_2dfb928f/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ Manh (Kim Thần đóng) bước vào chốn thâm cung vào thời kỳ Tùy Đường. Không muốn sống cuộc đời giam lỏng, số phận bị định đoạt, Bộ Manh giả vờ bị bệnh để tránh chuyện chính trị và làm bạn tốt với các phu nhân quan lại trong cung điện. Nhưng rồi một ngày, hoàng đế (Uông Đông Thành đóng) có xung đột với cha của Bộ Manh, chàng tìm đến nàng để trút giận. Tuy nhiên, chàng thấy mình ngày càng bị thu hút bởi Bộ Manh. Với cá tính không chịu khuất phục của nàng, vị hoàng đế không những giận thêm mà còn thương nhớ, chàng thường tạo cớ để 2 người có cơ hội bên nhau.</p>","tmdb":{"type":"tv","id":"80602","season":1,"vote_average":5.7,"vote_count":3},"modified":"2023-06-30T19:21:07.000Z","cast":["Uông Đông Thành","Kim Thần","Lưu Quán Lân","Hàn Cửu Nặc","Thang Mộng Giai","Shen Yao","Zhang Haiyu","Qu Aohui","Li Da Chuan","Li Jiawen"],"director":["Trâu Tập Thành"],"cast_meta":[{"name":"Uông Đông Thành","name_vi":"Uông Đông Thành","name_original":"Jiro Wang","tmdb_id":1222313,"profile":"https://image.tmdb.org/t/p/w500/wDCGA83FXXIL9LfD7xEyOeVkfl1.jpg","tmdb_url":"https://www.themoviedb.org/person/1222313"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Lưu Quán Lân","name_vi":"Lưu Quán Lân","name_origi