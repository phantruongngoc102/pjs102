16bd13b1b","link_m3u8":"https://vip.opstream15.com/20220421/6644_9f45bbba/index.m3u8"},{"name":"54","slug":"54","filename":"manh-the-thuc-than-thuyet-minh-cinderella-chef-tap-54","link_embed":"https://vip.opstream15.com/share/2d36b5821f8affc6868b59dfc9af6c9f","link_m3u8":"https://vip.opstream15.com/20220421/6654_583720c7/index.m3u8"},{"name":"55","slug":"55","filename":"manh-the-thuc-than-thuyet-minh-cinderella-chef-tap-55","link_embed":"https://vip.opstream15.com/share/3a37abdeefe1dab1b30f7c5c7e581b93","link_m3u8":"https://vip.opstream15.com/20220421/6669_8a5b9d9c/index.m3u8"},{"name":"56","slug":"56","filename":"manh-the-thuc-than-thuyet-minh-cinderella-chef-tap-56","link_embed":"https://vip.opstream15.com/share/a1e865a9b1065392ed6035d8ccd072d9","link_m3u8":"https://vip.opstream15.com/20220421/6671_e1f78350/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim Manh Thê Thực Thần: nói về Hạ Thuần Dư vốn xuất thân từ gia thế quyền quý, được Dụ Vương uỷ thác, thâm nhập vào hắc phong trại làm nội ứng, mục đích là giúp Dụ Vương tìm ra chứng cứ mà hắc phong trại cấu kết với thái tử. Nhưng trong khi tiếp xúc với Bạch Sùng ở hắc phong trại, tình huynh đệ ngày một thêm sâu, đứng trước 2 sự lựa chọn khó khăn là tình nghĩa và quốc gia, người phụ nữ thành thị hiện đại Diệp Gia Dao bất ngờ thông qua thiên thạch thần kỳ xuyên không về Hoài Tống, trở thành Diệp Cẩn Huyên con gái của tri phủ Diệp Bỉnh Hoài, nhưng lại bị bắt cóc lên hắc phong trại, bị Bạch Sùng coi là công cụ để thăm dò điều tra Hạ Thuần Dư, đưa vào động phòng cùng Hạ Thuần Dư. Trong tình thế hiểm ác, Diệp Gia Dao thông qua tài nghệ nấu ăn và tư duy hiện đại của mình , lần lượt biến nguy thành an, còn trở nên có tên tuổi trong giới ẩm thực. Bộ phim thông qua những tình tiết hài hước gây cười và những đấu tranh xung đột mãnh liệt, đã cho thấy tình yêu mãnh liệt đôi lứa và tình nghĩa huynh đệ quý báu.</p>","tmdb":{"type":"tv","id":"79574","season":1,"vote_average":8.2,"vote_count":9},"modified":"2023-06-30T19: