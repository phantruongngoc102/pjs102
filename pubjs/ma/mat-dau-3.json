f89fe","link_m3u8":"https://vip.opstream11.com/20220818/35825_38a433cb/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/475fe344558ed5c6e41b4bf1f330bc49","link_m3u8":"https://vip.opstream11.com/20220818/35826_cc7ce0cf/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/be96d1cff30b8d93ca9a824d9408e1c8","link_m3u8":"https://vip.opstream11.com/20220818/35827_bbd9f10e/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/dc2975799aeb838479c3cea296015bce","link_m3u8":"https://vip.opstream11.com/20220818/35828_a7d4b08a/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream11.com/share/0ef4d5ae8ae4dcf531c4257754d5dde6","link_m3u8":"https://vip.opstream11.com/20220818/35829_d0632363/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream11.com/share/e4698785c2dd62a17bad5d0cb3d3e9ee","link_m3u8":"https://vip.opstream11.com/20220818/35830_d331f61f/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream11.com/share/fcccb4e7caa070417729cdb35bb71918","link_m3u8":"https://vip.opstream11.com/20220818/35831_3473385d/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream11.com/share/7ff17e7aa3064d218ef36ab0557414df","link_m3u8":"https://vip.opstream11.com/20220818/35833_545f92e3/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream11.com/share/7bf3fbacc7fe74b379f7767efc372329","link_m3u8":"https://vip.opstream11.com/20220818/35834_f1bb442d/index.m3u8"}]}],"description":"<p>Tiết Gia Cường (Lâm Phong đóng) tiếp tục cùng CIB (Cục Tình Báo Hình Sự) thi hành nhiệm vụ truy bắt nhiều tội phạm khác nhau, trong khi đó Trác Khải (Miêu Kiều Vỹ đóng) vì 3 năm trước đã bắn kẻ đầu não của tập đoàn tội phạm là Tiền Thụy An bị thương nên bị phán 3 năm tù giam. Sau khi mãn hạn tù, anh chọn mở quán cà phê cùng vợ mình là Mạc Tiễn Tình (Giang Mỹ Nghi đóng) để sinh sống ổn định nhưng lại phải đối mặt với nguy cơ bị đám người hắc bang truy sát. Mặt khác, Tổng Thanh Tra của CIB là Chương Kỷ Tư (Huỳnh Trí Văn đóng) và nội gián trước đây của Trác Khải là Trịnh Thục Mai (Huỳnh Thúy Như đóng) nghi ngờ rằng Trác Khải có ý định gia nhập hắc đạo, nên bí mật điều tra quan hệ giữa Trác Khải và đám người của hắc đạo... Gia Cường cùng Trác Khải điều tra vụ án buôn bán người phi pháp, Trưởng phòng điều tra của Cục Bảo An (SIA) là Vi Tác Vinh (Mã Quốc Minh đóng) cũng hợp lực phá án. Khoa tình báo mới được thành lập của Cục Bảo An mời Từ Thiên Đường (Viên Vỹ Hào đóng) gia nhập, Trác Khải ở chốn giang hồ tham gia vào đại hội tuyển cử của bang hội. Kẻ cùng hội cùng thuyền ngày trước lại dùng thân phận khác tham gia ứng tuyển, Trác Khải lần nữa gặp lại lão đối thủ lẽ ra đã bị Gia Cường bắn chết là Đàm Hoan Hỉ (Hứa Thiệu Hùng đóng) và phát hiện ra thân phận thật sự của Vi Tác Vinh chính là Ngụy Đức Lễ, em trai của kẻ địch ngày trước - Ngụy Đức Tín. Hắn ta đang lên kế hoạch báo thù mọi người, trong khi mọi người đang hợp lực điều tra, vạch trần một thế lực hắc ám khổng lồ thì ngay lúc đó lại có một trận sóng gió đang từ từ ập tới...</p>","tmdb_id":204032,"cast":["Lâm Phong","Miêu Kiều Vỹ","Mã Quốc Minh","Viên Vỹ Hào","Huỳnh Trí Văn","Huỳnh Thúy Như"],"director":["Tô Vạn Thông"],"keywords":[],"tmdb":{"type":"tv","id":"204032","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lâm Phong","name_vi":null,"name_original":"Lâm Phong"},{"name":"Miêu Kiều Vỹ","name_vi":null,"name_original":"Miêu Kiều Vỹ"},{"name":"Mã Quốc Minh","name_vi":null,"name_original":"Mã Quốc Minh"},{"name":"Viên Vỹ Hào","name_vi":null,"name_original":"Viên Vỹ Hào"},{"name":"Huỳnh Trí Văn","name_vi":null,"name_original":"Huỳnh Trí Văn"},{"name":"Huỳnh Thúy Như","name_vi":null,"name_original":"Huỳnh Thúy Như"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/mat-dau-3.json"}