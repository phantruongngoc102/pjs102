pstream15.com/20230428/38467_2900974e/index.m3u8"}]}],"time":"57 phút/tập","description":"<p>Phần sáu bắt đầu vài tháng sau phần cuối của mùa trước, khi Gallaghers chuẩn bị cho một mùa đông dài khác ở Chicago. Frank vẫn đang thương tiếc cho sự mất mát to lớn của mình, trong khi sự trân trọng cuộc sống mà anh mới tìm thấy đang khiến gia đình Gallaghers phát hoảng. Mùa này không chỉ chứng kiến những cơn gió bắc cực từ Hồ Michigan thổi qua Southside. Carl hết tuổi vị thành niên. Trong khi Fiona đấu tranh với Ian vẫn chưa ổn định để uống thuốc của anh ấy, cô ấy cũng gặp phải một tình huống khác đang rình rập khi Debbie đối mặt với một bộ phim truyền hình về bà mẹ trẻ con hoàn toàn mới.</p>","tmdb":{"type":"tv","id":"34307","season":6,"vote_average":8.2,"vote_count":3176},"modified":"2023-04-30T08:07:47.000Z","cast":["William H. Macy","Jeremy Allen White","Ethan Cutkosky","Shanola Hampton","Steve Howey","Emma Kenney","Christian Isaiah","Cameron Monaghan","Noel Fisher","Kate Miner"],"director":[],"cast_meta":[{"name":"William H. Macy","name_vi":null,"name_original":"William H. Macy","tmdb_id":3905,"profile":"https://image.tmdb.org/t/p/w500/hdVEGSrP8qWlJnt0v5vSVcGOjy7.jpg","tmdb_url":"https://www.themoviedb.org/person/3905"},{"name":"Jeremy Allen White","name_vi":null,"name_original":"Jeremy Allen White","tmdb_id":206905,"profile":"https://image.tmdb.org/t/p/w500/zKk4vmDeUexdevtt6wm8WdMQ1TG.jpg","tmdb_url":"https://www.themoviedb.org/person/206905"},{"name":"Ethan Cutkosky","name_vi":null,"name_original":"Ethan Cutkosky","tmdb_id":132213,"profile":"https://image.tmdb.org/t/p/w500/fHa86X7KypnIB1koWXTTyErpRuI.jpg","tmdb_url":"https://www.themoviedb.org/person/132213"},{"name":"Shanola Hampton","name_vi":null,"name_original":"Shanola Hampton","tmdb_id":110531,"profile":"https://image.tmdb.org/t/p/w500/4wDdVm3HgBJm9AhMNS0I6MZidBH.jpg","tmdb_url":"https://www.themoviedb.org/person/110531"},{"name":"Steve Howey","name_vi":null,"name_original":"Steve Howey","tmdb_id":81388,"profi