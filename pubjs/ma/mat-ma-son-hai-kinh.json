abcdc8f26faaa44e79476af2f0","link_m3u8":"https://vip.opstream12.com/20260203/32414_5928ecab/index.m3u8"}]}],"description":"<p>Giữa chốn giang hồ mênh mông đầy máu lửa, đao kiếm vô tình, Hữu Thân Bất Phá, hoàng tử nước Thương, ra tay như sấm chớp, cứu mạng Giang Ly, đệ tử Thái Nhất Tông, trong khoảnh khắc sinh tử. Một người mang thân phận hoàng tộc, một kẻ xuất thân tông môn, vốn chẳng chung đường, vậy mà chỉ sau một trận đao kiếm, đã xem nhau như tri kỷ. Từ đó, hai người sóng vai bước vào Đại Hoang Nguyên, nơi luật lệ chỉ được viết bằng thép lạnh và máu tươi. Họ cải trang trà trộn vào thương đội, vượt qua thiên kiếp giáng xuống như trời phạt, bị mãnh thú rình rập giữa đêm tối, lại nhiều lần vung kiếm đối đầu bọn cường đạo hung tàn. Mỗi lần thoát chết, tình nghĩa càng thêm bền chặt. Một lần vì nghĩa mà ra tay cứu mỹ nhân, số phận hai người càng bị cuốn sâu vào vòng xoáy giang hồ.</p>","tmdb_id":238685,"cast":["Gao Sihang","Sang Yuze","Mao Yongcheng","Xie Yunlin","Huang Xiangyu","Yu Kailong"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"238685","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Gao Sihang","name_vi":null,"name_original":"Gao Sihang","tmdb_id":4764177,"profile":"https://image.tmdb.org/t/p/w500/8IIPqT9juefSHsO5F48rTysnv7p.jpg","tmdb_url":"https://www.themoviedb.org/person/4764177"},{"name":"Sang Yuze","name_vi":null,"name_original":"Sang Yuze","tmdb_id":3718822,"profile":"https://image.tmdb.org/t/p/w500/yJNmML2PlTPz4uzBIaNJYy5ELTg.jpg","tmdb_url":"https://www.themoviedb.org/person/3718822"},{"name":"Mao Yongcheng","name_vi":null,"name_original":"Mao Yongcheng","tmdb_id":4784622,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4784622"},{"name":"Xie Yunlin","name_vi":null,"name_original":"Xie Yunlin","tmdb_id":4784890,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4784890"},{"name":"Huang Xiangyu","name_vi":null,"name_original":"Huang Xiangyu","tmdb_id":3171092,"profile":"https://image.tmdb.org/t/p/w500/q