ream15.com/share/937e55950b2f7c61e80237f72dafc94b","link_m3u8":"https://vip.opstream15.com/20241228/46337_937e5595/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/0d0e8e5e5c83563a3d17a84f9c763733","link_m3u8":"https://vip.opstream15.com/20241228/46338_0d0e8e5e/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/73c55bc944ff08322761ffc22fcf10c1","link_m3u8":"https://vip.opstream15.com/20250106/47077_73c55bc9/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream15.com/share/712c8121a80ee679a08243f86dbd64ae","link_m3u8":"https://vip.opstream15.com/20250106/47078_712c8121/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream15.com/share/bea6f48261d29b0dba555367e277f670","link_m3u8":"https://vip.opstream15.com/20250106/47079_bea6f482/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream15.com/share/1b3792d7a5971736e7dd4932c8c20f74","link_m3u8":"https://vip.opstream15.com/20250106/47080_1b3792d7/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream15.com/share/a128c87f5f533b784a2c3f5064b3cdea","link_m3u8":"https://vip.opstream15.com/20250106/47081_a128c87f/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream15.com/share/d29a8d2929a392319e84dcc21046ca9d","link_m3u8":"https://vip.opstream15.com/20250106/47082_d29a8d29/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream15.com/share/3f16df3165aeb4df25222b804214ca97","link_m3u8":"https://vip.opstream15.com/20250106/47083_3f16df31/index.m3u8"}]}],"description":"<p>Vào thời Bắc Tống, tại góc phố Tước Nhi ở Biện Lương, có một gia đình năm người với tính cách trái ngược: Triệu Bất Ưu, Ôn Duyệt và các thành viên khác. Triệu Bất Ưu vốn chỉ là một tiểu lại cấp thấp tại Đại Lý Tự, chỉ mong muốn sống một cuộc sống bình dị, trái lại vợ anh, Ôn Duyệt, luôn ôm mộng mua nhà tậu ruộng. Dù thường xuyên tranh cãi, gia đình họ vẫn giữ được không khí ấm áp, đầy ắp tiếng cười. Một sự cố bất ngờ đã kéo cả gia đình vào vụ án \"Thuyền Mai\" chấn động, họ bước vào hành trình vừa phá giải những vụ án bí ẩn, vừa giải quyết hàng loạt vấn đề gia đình nảy sinh. Trong quá trình này, các thành viên dần hiểu và chấp nhận nhau hơn, cùng nhau trưởng thành và vượt qua muôn vàn khó khăn. Khi từng vụ án được làm sáng tỏ, mọi manh mối đều dẫn đến một \"Đại thiện nhân Giang Nam\".</p><p>&nbsp;</p>","tmdb_id":252904,"cast":["Bạch Bách Hà","Trương Tụng Văn","Chu Nhất Vi","Hou Yansong","Trương Diệu","Hí Dương","Lin Jiachuan","Shi An","Hách Phú Thân","Hao Han","Lý Nãi Văn","Hải Nhất Thiên","Trương Hinh Dư"],"director":["杨帆"],"keywords":[],"tmdb":{"type":"tv","id":"252904","season":1,"vote_average":6.9,"vote_count":11},"cast_meta":[{"name":"Bạch Bách Hà","name_vi":"Bạch Bách Hà","name_original":"Bai Baihe","tmdb_id":588057,"profile":"https://image.tmdb.org/t/p/w500/4cEIvt6etPrWzXn59W5GgnijNIG.jpg","tmdb_url":"https://www.themoviedb.org/person/588057"},{"name":"Trương Tụng Văn","name_vi":"Trương Tụng Văn","name_original":"Zhang Songwen","tmdb_id":1086250,"profile":"https://image.tmdb.org/t/p/w500/rz1mKSiuV5LuY0l0Y6HRGJGBeED.jpg","tmdb_url":"https://www.themoviedb.org/person/1086250"},{"name":"Chu Nhất Vi","name_vi":"Chu Nhất Vi","name_original":"Zhou Yiwei","tmdb_id":1174685,"profile":"https://image.tmdb.org/t/p/w500/vvHVmjIhMIS7baQsmj5z0cy7hz1.jpg","tmdb_url":"https://www.themoviedb.org/person/1174685"},{"name":"Hou Yansong","name_vi":null,"name_original":"Hou Yansong","tmdb_id":2613636,"profile":"https://image.tmdb.org/t/p/w500/gBD72JE65lXVPJLHglF7xnfLroK.jpg","tmdb_url":"https://www.themoviedb.org/person/2613636"},{"name":"Trương Diệu","name_vi":"Trương Diệu","name_original":"Zhang Yao","tmdb_id":2190492,"profile":"https://image.tmdb.org/t/p/w500/9CWNqoFsbjZlLAknEpmA0K5p6KL.jpg","tmdb_url":"https://www.themoviedb.org/person/2190492"},{"name":"Hí Dương","name_vi":"Hí Dương","name_original":"Xia Meng","tmdb_id":3091307,"profile":"https://image.tm