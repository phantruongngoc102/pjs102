com/share/efaaba7b6a9f5030033337074884b7e0","link_m3u8":"https://vip.opstream13.com/20251125/19607_efaaba7b/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/fb2a60d35f7623b1045f0cf59156fdbc","link_m3u8":"https://vip.opstream13.com/20251125/19608_fb2a60d3/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/d7d1b0e1c2ba164a103f995abd07662f","link_m3u8":"https://vip.opstream13.com/20251125/19609_d7d1b0e1/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream13.com/share/23caa86a7dadfef1317f9af86bd135e1","link_m3u8":"https://vip.opstream13.com/20251125/19610_23caa86a/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream13.com/share/d8cda2f35a02ca459421ded6f9a5e868","link_m3u8":"https://vip.opstream13.com/20251125/19611_d8cda2f3/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream13.com/share/e5f3045e4478665d73a7f8a89ef4782e","link_m3u8":"https://vip.opstream13.com/20251126/19891_e5f3045e/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream13.com/share/2babf18a3e44fc9fbd14151d2caa8c91","link_m3u8":"https://vip.opstream13.com/20251125/19612_2babf18a/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream13.com/share/b210215075f68e712aa3d04c9269aea8","link_m3u8":"https://vip.opstream13.com/20251125/19613_b2102150/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream13.com/share/b54610023aec2ff8ce90f49fd969249b","link_m3u8":"https://vip.opstream13.com/20251126/19892_b5461002/index.m3u8"}]}],"description":"<p><i>Mặt nạ gương</i> xoay quanh Hoa (Lương Thu Trang), một nữ nhà văn theo đuổi dòng truyện trinh thám đã gây dựng được một thương hiệu ăn khách mang tên “Sát Nhân K”. Mọi chuyện bắt đầu khi Hoa tìm kiếm chất liệu cho phần tiếp theo của bộ truyện là một vụ án mạng xảy ra trong thẩm mỹ viện. Quá trình tìm kiếm tư liệu cho sản phẩm tưởng tượng của mình đã vô tình khiến Hoa mắc vào một vụ án đặc biệt. Trớ trêu thay, vụ án đặc biệt đó lại là của gia đình cô. Bí ẩn về cái chết của mẹ ruột cùng bà Diễm (Ngọc Lan) – mẹ kế của Hoa cũng lần lượt bị phơi bày.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/mat-na-guong-phim-viet-nam.json"}