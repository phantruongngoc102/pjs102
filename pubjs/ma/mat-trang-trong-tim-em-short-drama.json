0d864147c8067a041322410bbbbb2c30","link_m3u8":"https://vip.opstream-short.com/20251107/12583_0d864147/index.m3u8"},{"name":"60","slug":"60","link_embed":"https://vip.opstream-short.com/share/5cba6e74e996a4b1d7534b6bdc8ee5f6","link_m3u8":"https://vip.opstream-short.com/20251107/12584_5cba6e74/index.m3u8"},{"name":"61","slug":"61","link_embed":"https://vip.opstream-short.com/share/4bea6954f150dffe36b732708adb1a2b","link_m3u8":"https://vip.opstream-short.com/20251107/12585_4bea6954/index.m3u8"},{"name":"62","slug":"62","link_embed":"https://vip.opstream-short.com/share/a7ea034186e14fb5f7b37cf664893cd2","link_m3u8":"https://vip.opstream-short.com/20251107/12586_a7ea0341/index.m3u8"},{"name":"63","slug":"63","link_embed":"https://vip.opstream-short.com/share/831018fbdda35bd2f37044ed4187ce7f","link_m3u8":"https://vip.opstream-short.com/20251107/12587_831018fb/index.m3u8"},{"name":"64","slug":"64","link_embed":"https://vip.opstream-short.com/share/df7c2b3c3966426c14e4b3005c931eb1","link_m3u8":"https://vip.opstream-short.com/20251107/12588_df7c2b3c/index.m3u8"},{"name":"65","slug":"65","link_embed":"https://vip.opstream-short.com/share/ff111e4a5406ed4024a901c57e811167","link_m3u8":"https://vip.opstream-short.com/20251107/12589_ff111e4a/index.m3u8"}]}],"description":"<p>Dương Vọng Nguyệt, thánh nữ của Thánh Hỏa Giáo, có địa vị đặc biệt trong giang hồ nơi chính tà đối lập. Sau khi thoát chết trong một biến cố lớn, cô hóa thân thành một cô gái mồ côi nghèo khó. Dương Thanh, trưởng lão của môn phái chính đạo danh tiếng, gánh vác trọng trách duy hộ chính đạo và bảo vệ công lý giang hồ. Sau khi tái sinh, Dương Vọng Nguyệt muốn thực hiện tâm nguyện xưa và làm quen với Dương Thanh. Ban đầu, vì lập trường chính tà khác biệt và nhiều hiểu lầm, hai người nghi ngờ lẫn nhau. Tuy nhiên, qua những lần tiếp xúc, họ dần dần buông bỏ thành kiến và nảy sinh tình cảm. Cuối cùng, hai người cùng nhau trong giang hồ, không chỉ hợp sức tiêu diệt đại ma đầu thực sự mà còn hóa giải thù hận nhiều năm giữa Thánh Hỏa Giáo và các môn phái chính đạo, mang lại hòa bình cho giang hồ.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/mat-trang-trong-tim-em-short-drama.json","tmdb_checked":false}