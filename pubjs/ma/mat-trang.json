 thoát ra, tìm đến hiện trường vụ tai nạn và thấy có một Sam Bell khác đang nằm trong xe. Sam ngạc nhiên tột cùng, quyết định đưa Sam kia về chữa trị và tìm hiểu những điều bí ẩn.","tmdb":{"type":"movie","id":"17431","season":null,"vote_average":7.566,"vote_count":6097},"modified":"2023-10-17T09:36:16.000Z","cast":["Sam Rockwell","Kevin Spacey","Dominique McElligott","Rosie Shaw","Adrienne Shaw","Kaya Scodelario","Benedict Wong","Matt Berry","Malcolm Stewart","Robin Chalk"],"director":["Duncan Jones"],"cast_meta":[{"name":"Sam Rockwell","name_vi":null,"name_original":"Sam Rockwell","tmdb_id":6807,"profile":"https://image.tmdb.org/t/p/w500/afYhNpLwpa65Yy0Q0g00FNFhzx5.jpg","tmdb_url":"https://www.themoviedb.org/person/6807"},{"name":"Kevin Spacey","name_vi":null,"name_original":"Kevin Spacey","tmdb_id":1979,"profile":"https://image.tmdb.org/t/p/w500/nPrUZDEbGQe6jwpVbHKJCXsMd7r.jpg","tmdb_url":"https://www.themoviedb.org/person/1979"},{"name":"Dominique McElligott","name_vi":null,"name_original":"Dominique McElligott","tmdb_id":115146,"profile":"https://image.tmdb.org/t/p/w500/67WjmwIlPkt6Q6DANkMN1HjWha5.jpg","tmdb_url":"https://www.themoviedb.org/person/115146"},{"name":"Rosie Shaw","name_vi":null,"name_original":"Rosie Shaw","tmdb_id":115147,"profile":"https://image.tmdb.org/t/p/w500/t798QpTlVOk3kUcf5Xm3TlNjVeV.jpg","tmdb_url":"https://www.themoviedb.org/person/115147"},{"name":"Adrienne Shaw","name_vi":null,"name_original":"Adrienne Shaw","tmdb_id":115149,"profile":"https://image.tmdb.org/t/p/w500/c62K2PlWXNtnOsnYnJ874H5UaQS.jpg","tmdb_url":"https://www.themoviedb.org/person/115149"},{"name":"Kaya Scodelario","name_vi":null,"name_original":"Kaya Scodelario","tmdb_id":115150,"profile":"https://image.tmdb.org/t/p/w500/uVp7VarM5GX08hfCEGt63OM5c5c.jpg","tmdb_url":"https://www.themoviedb.org/person/115150"},{"name":"Benedict Wong","name_vi":null,"name_original":"Benedict Wong","tmdb_id":30082,"profile":"https://image.tmdb.org/t/p/w500/yYfLyrC2CE6vBWSJfkpuVKL2POM.jpg","tm