e/e990939764541b9ff6da7657325ca346","link_m3u8":"https://vip.opstream11.com/20230915/47253_13679418/index.m3u8"},{"name":"33","slug":"33","filename":"Sunshine by My Side 2023 EP33","link_embed":"https://vip.opstream11.com/share/c73f4d8f3e0c84920eef1464c4c73cb8","link_m3u8":"https://vip.opstream11.com/20230915/47254_78c18ebd/index.m3u8"},{"name":"34","slug":"34","filename":"Mặt Trời Rực Rỡ Bên Tôi Tập 34","link_embed":"https://vip.opstream11.com/share/08612affa873f5a75ec90115a5d7b8fc","link_m3u8":"https://vip.opstream11.com/20230916/47362_812be80c/index.m3u8"},{"name":"35","slug":"35","filename":"Mặt Trời Rực Rỡ Bên Tôi Tập 35","link_embed":"https://vip.opstream11.com/share/55e666f6c1d818430f1a5ddcca4ab724","link_m3u8":"https://vip.opstream11.com/20230916/47363_872f57b0/index.m3u8"},{"name":"36","slug":"36","filename":"Sunshine by My Side 2023 EP36","link_embed":"https://vip.opstream11.com/share/2c75db7849c08cf7e84dd2538c4e2f85","link_m3u8":"https://vip.opstream11.com/20230917/47443_1d5705ac/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim truyền hình \"Mặt trời rực rỡ ở bên tôi\" là một bộ phim tình cảm đô thị do Tống Hiểu Phi đạo diễn đạo, Lý Tiêu và Khương Vô Cập làm biên kịch, cùng sự tham gia của các diễn viên Tiêu Chiến, Bạch Bách Hà, Điền Vũ, Chu Châu.</p><p>Giản Băng (do Bạch Bách Hà thủ vai) là một đạo diễn quảng cáo nổi tiếng trong ngành, Thịnh Dương (do Tiêu Chiến thủ vai) là một người mới vào ngành. Hai người tình cờ gặp nhau tại một nhà hàng - một người vừa mới li hôn, một người đang yêu thầm, hai kẻ xa lạ cứ thế quấn quýt nhau, bắt đầu một chặng đường tình yêu, trưởng thành kỳ diệu và lãng mạn. Với sự ủng hộ của Thịnh Dương, Giản Băng đã lấy lại niềm tin vào cuộc sống và tình yêu. Nhờ sự hướng dẫn và động viên từ Giản Băng, Thịnh Dương từ một chàng trai trẻ ngây thơ và vụng về, khẳng định được bản thân và trưởng thành. Hai người chữa lành vết thương lòng cho đối phương, cùng trưởng thành và dần bồi đắp tình cảm. Tuy nhiên lại không thoát khỏi hiện thực, đối mặt với sự khác biệt về địa vị, kinh nghiệm,sự phản đối từ gia đình và tin đồn trong công việc, Giản Băng và Thịnh Dương đã phó thác tương lai cho thời gian định đoạt. Ba năm đã làm cho hai người trưởng thành và thay đổi. Họ đã dành nhiều \"lần đầu tiên\" của cuộc đời cho nhau, và chính sự tin tưởng và trải nghiệm đó đã khiến cho họ trở thành những người tốt hơn, sau nhiều lần lạc bước, họ lại trở về bên nhau.</p>","tmdb":{"type":"tv","id":"233571","season":1,"vote_average":4.8,"vote_count":6},"modified":"2024-10-30T14:09:29.000Z","cast":["Tiêu Chiến","Bạch Bách Hà","Điền Vũ","Chu Châu","Viên Văn Khang","Liu Xun","Hướng Hàm Chi","Ngô Hạnh Kiện","Dai Lele","Han Qiuchi"],"director":["Song Xiao Fei"],"cast_meta":[{"name":"Tiêu Chiến","name_vi":"Tiêu Chiến","name_original":"Xiao Zhan","tmdb_id":2084790,"profile":"https://image.tmdb.org/t/p/w500/468n73j2sSJIbfZvsIZvDpvUaS8.jpg","tmdb_url":"https://www.themoviedb.org/person/2084790"},{"name":"Bạch Bách Hà","name_vi":"Bạch Bách Hà","name_original":"Bai Baihe","tmdb_id":588057,"profile":"https://image.tmdb.org/t/p/w500/4cEIvt6etPrWzXn59W5GgnijNIG.jpg","tmdb_url":"https://www.themoviedb.org/person/588057"},{"name":"Điền Vũ","name_vi":"Điền Vũ","name_original":"Tian Yu","tmdb_id":1397566,"profile":"https://image.tmdb.org/t/p/w500/hltc7NNhaBpD45nVqhC1dPkoVuB.jpg","tmdb_url":"https://www.themoviedb.org/person/1397566"},{"name":"Chu Châu","name_vi":"Chu Châu","name_original":"Zhu Zhu","tmdb_id":1077356,"profile":"https://image.tmdb.org/t/p/w500/rg8OPxvu2xc1Y6YA0paaOBrCX2z.jpg","tmdb_url":"https://www.themoviedb.org/person/1077356"},{"name":"Viên Văn Khang","name_vi":"Viên Văn Khang","name_original":"Yuan Wenkang","tmdb_id":99690,"profile":"https://image.tmdb.org/t/p/w500/auB9ZHfxdiSoJIYGu1PvblPulTm.jpg","tmdb_url":"https://www.themoviedb.org/person/99690"},{"name":"Liu Xun","name_vi":null,"name_original":"Liu Xun","tmdb_id":2461691,"profile":"https://image.tmdb.org/t/p/w500/kltFWIXmNDSm