g chủ trại heo phải xoay sở trong thế giới xa hoa của tập đoàn Kim Thị. Cả hai bắt đầu một cuộc sống hoàn toàn mới…","tmdb":{"type":"tv","id":"282906","season":1,"vote_average":6,"vote_count":1},"modified":"2025-03-13T14:13:05.000Z","cast":["Lu Yunfeng","Hứa Hiểu Nặc","Ma Jiaming","Peng Yihang"],"director":[],"cast_meta":[{"name":"Lu Yunfeng","name_vi":null,"name_original":"Lu Yunfeng","tmdb_id":2500602,"profile":"https://image.tmdb.org/t/p/w500/1JdMTEJUuk8nxENyFs2TcqLJx0C.jpg","tmdb_url":"https://www.themoviedb.org/person/2500602"},{"name":"Hứa Hiểu Nặc","name_vi":"Hứa Hiểu Nặc","name_original":"Xu Xiaonuo","tmdb_id":2378292,"profile":"https://image.tmdb.org/t/p/w500/7i9HVcCtXDDRfsub5kkJJOvkkrC.jpg","tmdb_url":"https://www.themoviedb.org/person/2378292"},{"name":"Ma Jiaming","name_vi":null,"name_original":"Ma Jiaming","tmdb_id":2230291,"profile":"https://image.tmdb.org/t/p/w500/z7BJ9OV3vJmquaIF1T3GSxsaLgX.jpg","tmdb_url":"https://www.themoviedb.org/person/2230291"},{"name":"Peng Yihang","name_vi":null,"name_original":"Peng Yihang","tmdb_id":4826754,"profile":"https://image.tmdb.org/t/p/w500/bsDDX5T1xLRAAASzkrGxVQksepG.jpg","tmdb_url":"https://www.themoviedb.org/person/4826754"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ma/may-man-sap-den.json"}