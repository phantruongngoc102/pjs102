{"id":"63bb80f41c13612130d8f8a1","title":"Mị Ảnh Cuồng Hoa","origin_name":"the killing angels","slug":"mi-anh-cuong-hoa","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/mi/mi-anh-cuong-hoa.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/mi/mi-anh-cuong-hoa.webp","year":2022,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"mi-anh-cuong-hoa-2022","link_embed":"https://vip.opstream14.com/share/55ee5c15eb1a32098c52677a974abcd5","link_m3u8":"https://vip.opstream14.com/20230109/29182_a2e95702/index.m3u8"}]}],"time":"80 Phút","description":"<p>Lâm Gia Anh cùng chị gái nương tựa lẫn nhau, từ nhỏ đã sống dưới ảnh hưởng của các lãnh chúa. Thỉnh thoảng bắt gặp cảnh chị gái bị lãnh chúa Mã Thế Kiệt và những người khác truy sát, tận mắt chứng kiến chị mình bị áp bức nhưng không thể làm gì được. Lúc này, Hà Mỹ Tử xuất hiện, dáng người yêu kiều và kỹ năng độc đáo, khi đó Lâm Gia Anh mới biết được chị gái mình là thành viên đội đặc công nữ của Hà Mỹ Tử, cô lập tức quyết định gia nhập đội đặc công của Hà Mỹ Tử. Trong cơ sở huấn luyện, Lâm Gia Anh và các chị em khác đã cùng học các kỹ năng khác nhau, vượt qua một loạt các bài kiểm tra khắc nghiệt và đồng thời thiết lập tình bạn sâu sắc. Lâm Gia Anh bước ra khỏi căn cứ huấn luyện và bắt đầu thực hiện các nhiệm vụ, phải đối mặt với những thách thức lớn hơn. Đối mặt với sự vướng mắc và đau khổ bên trong, cô bắt đầu nghi ngờ tổ chức huấn luyện bí mật này, và cuối cùng đã tiết lộ bí mật của tổ chức này sau màn sương mù.</p>","tmdb":{"type":"movie","id":"1063564","season":null,"vote_average":0,"vote_count":0},"modified":"2025-04-19T10:19:01.000Z","cast":["Từ Đông Đông","Sun Cong","Trương Vĩnh Cương","Ge Tian","Meiling Jin","Hoàng Đào"],"director":["Xu Liang"],"cast_meta":[{"name":"Từ Đông Đông","name_vi":"Từ Đông Đông","name_original":"Xu Dongdong","tmdb_id":1822751,"profile":"https://image.tmdb.org/t/p/w500/nV1wWx7nzt8kOdvoNNWDdCZEUsl.jpg","tmdb_url":"https://www.themoviedb.org/person/1822751"},{"name":"Sun Cong","name_vi":null,"name_original":"Sun Cong","tmdb_id":1674368,"profile":"https://image.tmdb.org/t/p/w500/myjYrrqXM92v0G4b4nkRRo4wps2.jpg","tmdb_url":"https://www.themoviedb.org/person/1674368"},{"name":"Trương Vĩnh Cương","name_vi":"Trương Vĩnh Cương","name_original":"Hei Zi","tmdb_id":1258371,"profile":"https://image.tmdb.org/t/p/w500/b7coEiCPXOwkIj92WGxK8zcCP6r.jpg","tmdb_url":"https://www.themoviedb.org/person/1258371"},{"name":"Ge Tian","name_vi":null,"name_original":"Ge Tian","tmdb_id":2123472,"profile":"https://image.tmdb.org/t/p/w500/h2CUtRzRAq6VrfsyqgHYUa5wzaq.jpg","tmdb_url":"https://www.themoviedb.org/person/2123472"},{"name":"Meiling Jin","name_vi":null,"name_original":"Meiling Jin","tmdb_id":3131522,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3131522"},{"name":"Hoàng Đào","name_vi":"Hoàng Đào","name_original":"Huang Tao","tmdb_id":2950162,"profile":"https://image.tmdb.org/t/p/w500/hdDvTSyrQN95uRuq0AgcoCDJuDc.jpg","tmdb_url":"https://www.themoviedb.org/person/2950162"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/mi/mi-anh-cuong-hoa.json"}