eam12.com/share/5b5bbd3170c560829391c3db7265ee9b","link_m3u8":"https://vip.opstream12.com/20220430/13409_85f87e98/index.m3u8"},{"name":"38A","slug":"38a","link_embed":"https://vip.opstream12.com/share/728c1ca931886472c471607b9f763e2d","link_m3u8":"https://vip.opstream12.com/20220430/13411_c8ae0dc4/index.m3u8"},{"name":"38B","slug":"38b","link_embed":"https://vip.opstream12.com/share/52af145bae0067bdc52f7363b5a851f4","link_m3u8":"https://vip.opstream12.com/20220430/13412_937203be/index.m3u8"}]}],"description":"<p>Fahmai chuyển đến nhà Arthit sau khi bố mẹ cô qua đời. Cô biết mình sẽ bị đuổi ra khỏi nhà nên một ngày nọ, cô lập kế hoạch đưa Arthit lên giường. Tuy vậy, Arthit chạy thoát khỏi nhà và gặp tai nạn. Anh sống sót nhưng lòng căm thù cô ngày càng lớn. Cô được chuyển ra nước ngoài sống, 4 năm sau cô trở về vì lời hứa với bố mẹ anh. Cô nghĩ rằng thời gian đã chữa lành vết thương, nhưng thay vào đó mọi chuyện còn tồi tệ hơn.</p>","tmdb_id":113392,"cast":["Prin Suparat","Supassara Thanachart","Prama Imanothai","Sirilak Kwong","Kejmanee Wattanasin","Khunakorn Kirdpan"],"director":["Chudapa Chantakett"],"keywords":[],"tmdb":{"type":"tv","id":"113392","season":1,"vote_average":9.8,"vote_count":8},"cast_meta":[{"name":"Prin Suparat","name_vi":null,"name_original":"Prin Suparat","tmdb_id":1256327,"profile":"https://image.tmdb.org/t/p/w500/lo6zChxhJrIGYaSZV46IG1K98Rw.jpg","tmdb_url":"https://www.themoviedb.org/person/1256327"},{"name":"Supassara Thanachart","name_vi":null,"name_original":"Supassara Thanachart","tmdb_id":1389949,"profile":"https://image.tmdb.org/t/p/w500/eGb18J9zaxTruSuQ53QU0KJsQoa.jpg","tmdb_url":"https://www.themoviedb.org/person/1389949"},{"name":"Prama Imanothai","name_vi":null,"name_original":"Prama Imanothai","tmdb_id":1279079,"profile":"https://image.tmdb.org/t/p/w500/byeJEMug8vHFKNgJFhWpfWS6K82.jpg","tmdb_url":"https://www.themoviedb.org/person/1279079"},{"name":"Sirilak Kwong","name_vi":null,"name_original":"Sirilak Kwong","tmdb_id":3659650,"prof