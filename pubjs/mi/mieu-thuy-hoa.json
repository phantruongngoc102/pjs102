b09a37f0a0c1e11e01d8619b93a","link_m3u8":"https://vip.opstream17.com/20240515/7776_e4ac6e90/index.m3u8"},{"name":"17","slug":"","filename":"MieuThuyHoa.E17","link_embed":"https://vip.opstream17.com/share/412decf7f56202004e18650fb2db5897","link_m3u8":"https://vip.opstream17.com/20240515/7775_4f775d55/index.m3u8"},{"name":"18","slug":"","filename":"MieuThuyHoa.E18","link_embed":"https://vip.opstream17.com/share/c1619d2ad66f7629c12c87fe21d32a58","link_m3u8":"https://vip.opstream17.com/20240515/7774_c9b69e91/index.m3u8"},{"name":"19","slug":"","filename":"MieuThuyHoa.E19","link_embed":"https://vip.opstream17.com/share/09eb27dec1a45d92f229228204ea7201","link_m3u8":"https://vip.opstream17.com/20240515/7773_640fb0e9/index.m3u8"},{"name":"20","slug":"","filename":"MieuThuyHoa.E20End","link_embed":"https://vip.opstream17.com/share/36e51f22c86d237a5bb2e3451f8a7072","link_m3u8":"https://vip.opstream17.com/20240515/7772_5cbbeede/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Phương Đức, một nhà buôn giàu có nổi tiếng, trong một lần tình cờ lỡ đụng chạm và gây ra sự hiểu lầm với Miêu Thúy Hoa. Miêu Thúy Hoa là con gái duy nhất của võ sư Miêu Hiển, Miêu Thúy Hoa có võ công cao cường lại có lòng nghĩa hiệp và chút ương ngạnh. Một lần vì bênh vực lẽ phải, Miêu Thúy Hoa đã giao đấu với con trai của viên quan Tổng Đốc địa phương, tên công tử bột này bị tai nạn qua đời, khiến cho quan Tổng Đốc rắp tâm trả thù Miêu Thúy Hoa. Phương Đức tình cờ biết được nên ra tay cứu Miêu Thúy Hoa bằng cách nhận là ý trung nhân. Vì Phương Đức quen biết với nhiều người trong Hoàng Thất nên quan Tổng Đốc không làm gì được, nhưng Thái Hậu lại sủng ái Phương Đức mới thí hôn Miêu Thúy Hoa cho Phương Đức. Sự việc rắc rối từ đây!! Miêu Thúy Hoa về làm vợ Tư bất đắc dĩ !! Tại đây có cô em gái của người vợ cả quá cố tính tình trẻ con, hay ganh tị và đem lòng yêu thương anh rễ Phương Đức nên luôn ganh ghét Miêu Thúy Hoa. Cô vợ 2, tối ngày tìm cách chọc phá Miêu Thúy Hoa, luôn tỏ ra hiểu biết thực chất ko biết gì, và nhất là chỉ giỏi sai vặt. Cô vợ 3, tính khí khái, do là con nhà võ nên rất hợp với Miêu Thúy Hoa, nhưng luôn “bỏ quên bộ óc trong phòng” (theo lời bà vợ 2 ) và rất nghe lời bà vợ 2 !! Vì thế trong nhà Phương Đức luôn có chuyện xảy ra… Nhiều tình tiết cười đau bụng bắt nguồn từ đây !!</i></p>","tmdb":{"type":"tv","id":"86615","season":1,"vote_average":7.4,"vote_count":5},"modified":"2024-12-27T11:37:58.000Z","cast":["Quan Vịnh Hà","Giang Hoa","Lý Gia Thanh","Trần Thiểu Hà","Cheung Fung-Lei","Huệ Anh Hồng","Rain Lau Yuk-Chui","Lý Gia Đỉnh","Lưu Giang","Helen Ma Hoi-Lun","Lau Kar-Wing","Chim Bing-Hei","Mạch Gia Luân","Trương Tùng Chi","Hạ Bình"],"director":["Tiêu Hiển Huy"],"cast_meta":[{"name":"Quan Vịnh Hà","name_vi":"Quan Vịnh Hà","name_original":"Esther Kwan Wing-Ho","tmdb_id":979045,"profile":"https://image.tmdb.org/t/p/w500/mMJpoUGwEyPloyuzTWijQuJav3p.jpg","tmdb_url":"https://www.themoviedb.org/person/979045"},{"name":"Giang Hoa","name_vi":"Giang Hoa","name_original":"Kwong Wa","tmdb_id":1223075,"profile":"https://image.tmdb.org/t/p/w500/khRCfzElV914ibRTeNECKLwBHXJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1223075"},{"name":"Lý Gia Thanh","name_vi":"Lý Gia Thanh","name_original":"Dickson Lee Kar-Sing","tmdb_id":1134944,"profile":"https://image.tmdb.org/t/p/w500/vqYmEyR72RyvkbOP14GeGCek4NU.jpg","tmdb_url":"https://www.themoviedb.org/person/1134944"},{"name":"Trần Thiểu Hà","name_vi":"Trần Thiểu Hà","name_original":"Cherie Chan Siu-Ha","tmdb_id":1415241,"profile":"https://image.tmdb.org/t/p/w500/2owQ2KC7FxqeI1xWbfZwomsWbjF.jpg","tmdb_url":"https://www.themoviedb.org/person/1415241"},{"name":"Cheung Fung-Lei","name_vi":null,"name_original":"Cheung Fung-Lei","tmdb_id":1346929,"profile":"https://image.tmdb.org/t/p/w500/797T8Vm74Xn6TsgjkWhgUIvUnxk.jpg","tmdb_url":"https://www.themoviedb.org/person/1346929"},{"name":"Huệ Anh Hồng","name_vi":"Huệ Anh Hồng","name_original":"Kara Hui Ying-Hung","tmdb_id":84205,"profile":"https://image.tmdb.org/t/p