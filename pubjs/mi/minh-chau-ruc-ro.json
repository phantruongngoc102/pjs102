b025f2f8/index.m3u8"},{"name":"30","slug":"30","filename":"Minh Châu Rực Rỡ - Praomook (Phát Song Song) - Tập 30","link_embed":"https://vip.opstream11.com/share/657b96f0592803e25a4f07166fff289a","link_m3u8":"https://vip.opstream11.com/20220403/8979_1613570c/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Minh Châu Rực Rỡ - Praomook xoay quanh cô gái trẻ tên Praomook đam mê nghề DJ, nhận các show diễn để kiếm tiền trả nợ. Trong khi đó, Chalunthorn là một thiếu gia nhà giàu khét tiếng. Cặp đôi vô tình gây duyên nợ khi Chalunthorn tới xem Praomook biểu diễn. Hóa ra, Praomook lại chính là cô gái năm xưa mà Chalunthorn từng ghét bỏ. Trải qua nhiều hiểu lầm, cả hai cùng nhau tạo nên câu chuyện tình yêu đẹp và đầy cảm xúc.</p>","tmdb":{"type":"tv","id":"125381","season":1,"vote_average":8,"vote_count":6},"modified":"2022-05-24T03:23:46.000Z","cast":["Nawasch Phupantachsee","Nalinthip Sakulongumpai","Khunnarong Pratesrat","Ranchrawee Uakoolwarawat","Nichakoon Khajornborirak","Kanyaphak Pongsak","Jakapan Puttha","Warit Tipgomut","Benjawan Artner","Mayurin Pongpudpunth","Thanakrit Saengvanich","Nithi Smuthkochorn","Vannisa Sriwichian","Ratawan Aomtisong"],"director":["Saratswadee Wongsomphet"],"cast_meta":[{"name":"Nawasch Phupantachsee","name_vi":null,"name_original":"Nawasch Phupantachsee","tmdb_id":2189941,"profile":"https://image.tmdb.org/t/p/w500/85OUxjEbUTiJ83ysxrJXqvyQEY8.jpg","tmdb_url":"https://www.themoviedb.org/person/2189941"},{"name":"Nalinthip Sakulongumpai","name_vi":null,"name_original":"Nalinthip Sakulongumpai","tmdb_id":2395334,"profile":"https://image.tmdb.org/t/p/w500/A6P2TE1t1QolD9dCCRgprfYz7W5.jpg","tmdb_url":"https://www.themoviedb.org/person/2395334"},{"name":"Khunnarong Pratesrat","name_vi":null,"name_original":"Khunnarong Pratesrat","tmdb_id":3215748,"profile":"https://image.tmdb.org/t/p/w500/3E8AQYKy2VJKRTcXp3rFMHhO2dz.jpg","tmdb_url":"https://www.themoviedb.org/person/3215748"},{"name":"Ranchrawee Uakoolwarawat","name_vi":null,"name_original