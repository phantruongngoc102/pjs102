ame":"31","slug":"31","filename":"minh-nguyet-tung-chieu-giang-dong-han-thuyet-minh-the-moon-brightens-for-you-tap-31","link_embed":"https://vip.opstream15.com/share/51c807b4fe8dfbe0e36373fb415d2e65","link_m3u8":"https://vip.opstream15.com/20220605/18822_a7a48b26/index.m3u8"},{"name":"32","slug":"32","filename":"minh-nguyet-tung-chieu-giang-dong-han-thuyet-minh-the-moon-brightens-for-you-tap-32","link_embed":"https://vip.opstream15.com/share/2425ad56cc45acbd2fc44f149d69a9b8","link_m3u8":"https://vip.opstream15.com/20220605/18824_3b1b8f9e/index.m3u8"},{"name":"33","slug":"33","filename":"minh-nguyet-tung-chieu-giang-dong-han-thuyet-minh-the-moon-brightens-for-you-tap-33","link_embed":"https://vip.opstream15.com/share/c9663f86bdfd6137c73121a550887aa4","link_m3u8":"https://vip.opstream15.com/20220605/18826_2757b3ff/index.m3u8"},{"name":"34","slug":"34","filename":"minh-nguyet-tung-chieu-giang-dong-han-thuyet-minh-the-moon-brightens-for-you-tap-34","link_embed":"https://vip.opstream15.com/share/3930fd50d70d5c2b3ec09a08e2370851","link_m3u8":"https://vip.opstream15.com/20220605/18828_700d0d4f/index.m3u8"},{"name":"35","slug":"35","filename":"minh-nguyet-tung-chieu-giang-dong-han-thuyet-minh-the-moon-brightens-for-you-tap-35","link_embed":"https://vip.opstream15.com/share/0006aabe0ba47a35c0b0bf6596f85159","link_m3u8":"https://vip.opstream15.com/20220605/18829_2d49915f/index.m3u8"},{"name":"36","slug":"36","filename":"minh-nguyet-tung-chieu-giang-dong-han-thuyet-minh-the-moon-brightens-for-you-tap-36","link_embed":"https://vip.opstream15.com/share/77bb909a2d2ea5c42602592012e43474","link_m3u8":"https://vip.opstream15.com/20220605/18831_95c608cd/index.m3u8"}]}],"time":"45M17S","description":"<p>Chiến Thanh Hoằng là con gái của phó võ lâm minh chủ Chiến Phá Địch, từ nhỏ đã bị cấm tham gia vào chuyện giang hồ. Đại hội võ lâm sắp tới gần, Chiến Thanh Hoằng giấu người nhà lén chạy xuống núi quyết chí giành lấy ngôi vị minh chủ. Chiến Thanh Hoằng với mấy chiêu võ mèo cào đã kết thân được với con cháu sĩ tộc ôn nhu nho nhã Ôn Hựu, vô tình giúp cho con trai của võ lâm mình chủ Lâm Phóng giành được ngôi vị. Ba người bắt đầu xông pha giang hồ, dẹp loạn giữa các môn phái. Nhưng đối diện với hàng loạt những đả kích người thân chết thảm, tình yêu chia cách, bằng hữu phản bội khiến Chiến Thanh Hoằng sinh lòng căm hận, may có Ôn Ninh ở bên, giúp quay về chính đạo, từng bước hiểu sâu hơn về sự hiệp nghĩa, và cũng từ đó có được tình yêu.</p>","tmdb":{"type":"tv","id":"111148","season":1,"vote_average":6,"vote_count":1},"modified":"2023-04-11T19:26:12.000Z","cast":["Hình Phi","Vu Mông Lung","Mễ Nhiệt","Ma Yue","Zhang Kaitai","Zhang Xuehan","Ma Xier","Trịnh Phồn Tinh","He Junhao"],"director":["Lan Hai Han","Wang Fei"],"cast_meta":[{"name":"Hình Phi","name_vi":"Hình Phi","name_original":"Xing Fei","tmdb_id":1737082,"profile":"https://image.tmdb.org/t/p/w500/pQaUc5pJRaGwD8iwwzY1Z2YbrEj.jpg","tmdb_url":"https://www.themoviedb.org/person/1737082"},{"name":"Vu Mông Lung","name_vi":"Vu Mông Lung","name_original":"Yu Menglong","tmdb_id":1599857,"profile":"https://image.tmdb.org/t/p/w500/xBiX3svunAbFMZ3skJwLt8Z1F6Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1599857"},{"name":"Mễ Nhiệt","name_vi":"Mễ Nhiệt","name_original":"Merxat","tmdb_id":1982964,"profile":"https://image.tmdb.org/t/p/w500/y7lTmzX6rWBlMBfF6zep0FFDV9Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1982964"},{"name":"Ma Yue","name_vi":null,"name_original":"Ma Yue","tmdb_id":2945601,"profile":"https://image.tmdb.org/t/p/w500/yd1HzMNw4dV512vXZpqZD0Hxhhi.jpg","tmdb_url":"https://www.themoviedb.org/person/2945601"},{"name":"Zhang Kaitai","name_vi":null,"name_original":"Zhang Kaitai","tmdb_id":2809076,"profile":"https://image.tmdb.org/t/p/w500/83cX3TlEfLC0ux1vdllNiDv2hXn.jpg","tmdb_url":"https://www.themoviedb.org/person/2809076"},{"name":"Zhang Xuehan","name_vi":null,"name_original":"Zhang Xuehan","tmdb_id":3217776,"profile":"https://image.tmdb.org/t/p/w500/aXfoQ1d203yKGIcFNYxWxXaktg7.jpg