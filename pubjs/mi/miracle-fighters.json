{"id":"621e26ca3fb21848d197484b","title":"Miracle Fighters","origin_name":"Miracle Fighters","slug":"miracle-fighters","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/mi/miracle-fighters.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/mi/miracle-fighters.webp","year":1982,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"},{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a2347e0fc277084dfd876","name":"Hồng Kông","slug":"hong-kong"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"miracle-fighters-1982","link_embed":"https://vip.opstream11.com/share/71a3cb155f8dc89bf3d0365288219936","link_m3u8":"https://vip.opstream11.com/20220301/677_81d618f6/index.m3u8"}]}],"time":"1H40M52S","description":"<p>Cựu Vệ binh Hoàng gia Kao buộc phải chạy trốn khi cấp trên không thể chấp nhận việc anh ta là một người Mãn Châu kết hôn với một phụ nữ Hán. Một hoàng tử trẻ đã vô tình bị giết khi bắt cóc cậu bé để giúp cậu trốn thoát. 14 năm sau, Kao giờ là một kẻ say xỉn mang trong mình cảm giác tội lỗi, đang sống với một đứa trẻ mồ côi tên là Shu Geng. Hai cặp vợ chồng phù thủy già hay cãi vã, Old Man và Old Spinster, luôn cạnh tranh với nhau về những vấn đề nhỏ nhặt nhất. Không lâu sau, kẻ thù truyền kiếp của Kao, Socerer Bat mạnh mẽ, đã tìm ra tung tích của anh ta và giết chết anh ta. Mang trong mình những tham vọng xấu xa, Sorcerer Bat buộc Shu Geng đóng giả hoàng tử muộn màng, với ý định một ngày nào đó anh ta có thể cai trị cùng với vị vua sắp trở thành. Shu Geng cố gắng trốn thoát, giữa cuộc gặp gỡ kỳ lạ với chú hề trong lọ, và gặp hai cặp vợ chồng pháp sư cãi lộn thậm chí còn xa lạ, những người dạy cho anh ta nghề của họ.</p>","tmdb":{"type":"movie","id":"74262","season":null,"vote_average":7.3,"vote_count":27},"modified":"2024-12-31T15:39:23.000Z","cast":["Yuen Yat-Choh","Lương Gia Nhân","Yuen Cheung-Yan","Brandy Yuen Jan-Yeung","Cao Hùng","Yuen Shun-Yi","Huang Ha","Tino Wong"],"director":["Woo-ping Yuen"],"cast_meta":[{"name":"Yuen Yat-Choh","name_vi":null,"name_original":"Yuen Yat-Choh","tmdb_id":83679,"profile":"https://image.tmdb.org/t/p/w500/45g23jL9uKrublSZ4SKtGG0S9oi.jpg","tmdb_url":"https://www.themoviedb.org/person/83679"},{"name":"Lương Gia Nhân","name_vi":"Lương Gia Nhân","name_original":"Bryan Leung Kar-Yan","tmdb_id":227782,"profile":"https://image.tmdb.org/t/p/w500/541tNiNCEGnfjTqQPC9QNiSAsmZ.jpg","tmdb_url":"https://www.themoviedb.org/person/227782"},{"name":"Yuen Cheung-Yan","name_vi":null,"name_original":"Yuen Cheung-Yan","tmdb_id":65975,"profile":"https://image.tmdb.org/t/p/w500/sI8Dr2Icy31xRiODXPThiK6XkYv.jpg","tmdb_url":"https://www.themoviedb.org/person/65975"},{"name":"Brandy Yuen Jan-Yeung","name_vi":null,"name_original":"Brandy Yuen Jan-Yeung","tmdb_id":1088190,"profile":"https://image.tmdb.org/t/p/w500/c9tIXDpswVWNnvCqwubVclSZO3g.jpg","tmdb_url":"https://www.themoviedb.org/person/1088190"},{"name":"Cao Hùng","name_vi":"Cao Hùng","name_original":"Eddy Ko Hung","tmdb_id":612216,"profile":"https://image.tmdb.org/t/p/w500/1Zsn0zSmo5AS5p527XDaZvD0i3y.jpg","tmdb_url":"https://www.themoviedb.org/person/612216"},{"name":"Yuen Shun-Yi","name_vi":null,"name_original":"Yuen Shun-Yi","tmdb_id":65976,"profile":"https://image.tmdb.org/t/p/w500/3DLtcPAMGnexk0GifXo1UVRmatX.jpg","tmdb_url":"https://www.themoviedb.org/person/65976"},{"name":"Huang Ha","name_vi":null,"name_original":"Huang Ha","tmdb_id":238412,"profile":"https://image.tmdb.org/t/p/w500/nBMkenMpVUFutnZ2tEXITEhfhTi.jpg","tmdb_url":"https://www.themovie