9bed43bd/index.m3u8"},{"name":"21-24","slug":"21-24","filename":"Vo Lam Ngoai Su 21-24 DVD9","link_embed":"https://vip.opstream17.com/share/8ce8ac3252f7a8981a64d5a473e48ea0","link_m3u8":"https://vip.opstream17.com/20240613/11643_6bc40158/index.m3u8"},{"name":"25-28","slug":"25-28","filename":"Vo Lam Ngoai Su 25-28 DVD9","link_embed":"https://vip.opstream17.com/share/ac8645c4e666d447670bebf90cf8fbc2","link_m3u8":"https://vip.opstream17.com/20240613/11646_6bab8b44/index.m3u8"},{"name":"29-32","slug":"29-32","filename":"Vo Lam Ngoai Su 29-32 DVD9","link_embed":"https://vip.opstream17.com/share/9e246510e26d4747c94a2ee2f122d2a8","link_m3u8":"https://vip.opstream17.com/20240613/11648_5821123a/index.m3u8"},{"name":"33-36","slug":"33-36","filename":"Vo Lam Ngoai Su 33-36 DVD9","link_embed":"https://vip.opstream17.com/share/800d7c5998783ff37a6125f825db6247","link_m3u8":"https://vip.opstream17.com/20240613/11650_0a2042a6/index.m3u8"},{"name":"37-40","slug":"37-40","filename":"Vo Lam Ngoai Su 37-40 DVD9","link_embed":"https://vip.opstream17.com/share/0dc23b6a0e4abc39904388dd3ffadcd1","link_m3u8":"https://vip.opstream17.com/20240613/11653_2480a0fc/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Thời đó, trên giang hồ có 1 người tên Châu Bảo Quý, lấy vợ là Lý Mi Nương và đã sinh ra 1 đứa con gái đặt tên là Châu Thất Thất. Bọn họ sống ở Nhân Nghĩa sơn trang. Đó cũng là nơi mà 3 thiếu niên giang hồ: Thẩm Lãng, Hùng Miêu Nhi và Vương Liên Hoa quen biết nhau. Tuy trẻ tuổi, nhưng họ cũng biết fân biệt trắng đen, phải trái. Khi ấy, 1 tên ma đầu trong võ lâm là Khoái Hoạt vương đã phái thủ hạ đến Nhân Nghĩa sơn trang để đón Châu Thất Thất về, vì tưởng Châu Thất Thất là Lý Mi Nương (mẹ của thất Thất) - ái thê của mình đã qua đời 18 năm về trước. 3 người Thẩm Lãng, Hùng Miêu Nhi và Vương Liên Hoa quyết định bảo vệ Thất Thất. Sau đó, Thẩm Lãng đã cứu thoát 1 người từ tay Khoái Hoạt Vương tên là Bạch Phi Phi, Thẩm Lãng tưởng Phi Phi ko biết võ công nhưng thực sự, cô ấy rất giỏi.Sau đó,2 người yêu nhau, nhưng mẹ của Bạch Phi Phi-Bạch Tịnh ko đồng ý, nhưng trước sau như 1, tấm lòng của Thẩm Lãng với Phi Phi ko hề thay đổi...Môt câu chuyện vừa hài vừa bi, ân oán giang hồ 18 năm, làm hại 3 người phụ nữ nhưng cuối cùng lại cho ra 1 kết thúc tốt đẹp. Tất cả âu cũng là duyên phận.</i></p>","tmdb":{"type":"tv","id":"97762","season":1,"vote_average":7.5,"vote_count":2},"modified":"2024-12-27T11:36:35.000Z","cast":["Zhang Yanyan","Wang Jianxin","Ke Shi","Huỳnh Hải Băng","Vương Diễm","Zhu Hongjia","Nhạc Dược Lợi","Dai Chunrong","Trương Tấn","Wan Hongjie","Cheng Sihan","Lý Thiến","Zhuo Fan"],"director":["Mộng Kế","Vương Dĩ"],"cast_meta":[{"name":"Zhang Yanyan","name_vi":null,"name_original":"Zhang Yanyan","tmdb_id":2920461,"profile":"https://image.tmdb.org/t/p/w500/kjz9dl25oi1stWmb7TVnBSBP51y.jpg","tmdb_url":"https://www.themoviedb.org/person/2920461"},{"name":"Wang Jianxin","name_vi":null,"name_original":"Wang Jianxin","tmdb_id":3153859,"profile":"https://image.tmdb.org/t/p/w500/uGiruqz2AinOsxy0z9OzsVUAQYR.jpg","tmdb_url":"https://www.themoviedb.org/person/3153859"},{"name":"Ke Shi","name_vi":null,"name_original":"Ke Shi","tmdb_id":3153864,"profile":"https://image.tmdb.org/t/p/w500/6ZMcwjSINtq7qQXxBkXDQMhuCAD.jpg","tmdb_url":"https://www.themoviedb.org/person/3153864"},{"name":"Huỳnh Hải Băng","name_vi":"Huỳnh Hải Băng","name_original":"Huang Haibing","tmdb_id":557428,"profile":"https://image.tmdb.org/t/p/w500/vDyKX8JoQOS1rmNLfROH9txSpfo.jpg","tmdb_url":"https://www.themoviedb.org/person/557428"},{"name":"Vương Diễm","name_vi":"Vương Diễm","name_original":"Wang Yan","tmdb_id":2041041,"profile":"https://image.tmdb.org/t/p/w500/tYdzpRs98LQ0qMZJgwl6FBnzzKZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2041041"},{"name":"Zhu Hongjia","name_vi":null,"name_original":"Zhu Hongjia","tmdb_id":2117342,"profile":"https://image.tmdb.org/t/p/w500/a3HOWvcHawEICTsj1KLFFPDzt75.jpg","tmdb_url":"https://www.themoviedb.org/person/2117342"},{"name":"Nhạc Dược Lợi","