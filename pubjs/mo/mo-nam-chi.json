:"https://vip.opstream16.com/20220304/688_47cb8e63/index.m3u8"},{"name":"35","slug":"35","filename":"mo-nam-chi-tap-35","link_embed":"https://vip.opstream16.com/share/07a96b1f61097ccb54be14d6a47439b0","link_m3u8":"https://vip.opstream16.com/20220304/689_183c3c42/index.m3u8"},{"name":"36","slug":"36","filename":"mo-nam-chi-tap-36","link_embed":"https://vip.opstream16.com/share/c06d06da9666a219db15cf575aff2824","link_m3u8":"https://vip.opstream16.com/20220304/690_d89d55a3/index.m3u8"},{"name":"37","slug":"37","filename":"mo-nam-chi-tap-37","link_embed":"https://vip.opstream16.com/share/10a5ab2db37feedfdeaab192ead4ac0e","link_m3u8":"https://vip.opstream16.com/20220304/691_e72419ee/index.m3u8"},{"name":"38","slug":"38","filename":"mo-nam-chi-tap-38","link_embed":"https://vip.opstream16.com/share/e555ebe0ce426f7f9b2bef0706315e0c","link_m3u8":"https://vip.opstream16.com/20220304/692_c713748c/index.m3u8"},{"name":"39","slug":"39","filename":"mo-nam-chi-tap-39","link_embed":"https://vip.opstream16.com/share/53e3a7161e428b65688f14b84d61c610","link_m3u8":"https://vip.opstream16.com/20220304/693_ca28ddca/index.m3u8"},{"name":"40","slug":"40","filename":"mo-nam-chi-tap-40","link_embed":"https://vip.opstream16.com/share/5487315b1286f907165907aa8fc96619","link_m3u8":"https://vip.opstream16.com/20220304/694_6a8ae2a7/index.m3u8"}]}],"time":"42M","description":"<p>Mộ Nam Chi (Gia Nam Truyện) là bộ phim xoay quanh câu chuyện của nữ chính là Quận chúa Khương Bảo Ninh (Cục Tịnh Y đảm nhận) người bị hạ độc chết ở kiếp trước sau khi được gả cho hoàng đế nhưng bị lạnh nhạt, tiếp đến khi lên làm thái hậu nhiếp chính thì bị hãm hại.</p><p>Sau khi được trọng sinh, Bảo Ninh luôn ám ảnh với mọi chuyện xảy ra với mình nên nàng chỉ muốn sống một cuộc đời bình yên bên người thân và bạn bè. Nhờ vào sự thông minh cùng năng lực của bản thân nên nàng đã cân bằng mọi thế lực triều đình và cuối cùng có được hạnh phúc. Người đồng hành cùng Khương Bảo Ninh chính là Lý Khiêm (Tăng Thuấn Hy đóng), người yêu say đắm nữ chính Gia Nam Truyện ở kiếp trước nhưng sau khi trọng sinh thì anh quyết định khiến nàng trở về bên mình.</p>","tmdb":{"type":"tv","id":"128723","season":1,"vote_average":7.5,"vote_count":6},"modified":"2022-07-17T12:28:07.000Z","cast":["Cúc Tịnh Y","Tăng Thuấn Hy","Uông Trác Thành","Vương Nhất Đình","Lý Quân Nhuệ","Li Yizhen","Bạch Hân Di","Kuma","Chen Yutong","Hua Wen","Lục Đình Ngọc"],"director":["Zhi Lei"],"cast_meta":[{"name":"Cúc Tịnh Y","name_vi":"Cúc Tịnh Y","name_original":"Ju Jingyi","tmdb_id":1686990,"profile":"https://image.tmdb.org/t/p/w500/xbyH30PEsDMFf1JP3BNYCegkDLP.jpg","tmdb_url":"https://www.themoviedb.org/person/1686990"},{"name":"Tăng Thuấn Hy","name_vi":"Tăng Thuấn Hy","name_original":"Joseph Zeng","tmdb_id":1803092,"profile":"https://image.tmdb.org/t/p/w500/hfMNwzZv7SxJ6d8gk8rhPZdg4C8.jpg","tmdb_url":"https://www.themoviedb.org/person/1803092"},{"name":"Uông Trác Thành","name_vi":"Uông Trác Thành","name_original":"Wang Zhuocheng","tmdb_id":2387789,"profile":"https://image.tmdb.org/t/p/w500/il9dYQ15Bs9U6iAZXfS2IsXPMvm.jpg","tmdb_url":"https://www.themoviedb.org/person/2387789"},{"name":"Vương Nhất Đình","name_vi":"Vương Nhất Đình","name_original":"Wang Yiting","tmdb_id":2850866,"profile":"https://image.tmdb.org/t/p/w500/2Snv38YItpx3bQ4BMhDViHSh7qN.jpg","tmdb_url":"https://www.themoviedb.org/person/2850866"},{"name":"Lý Quân Nhuệ","name_vi":"Lý Quân Nhuệ","name_original":"Li Yunrui","tmdb_id":2306608,"profile":"https://image.tmdb.org/t/p/w500/lmWu3qwmdwGv9qmcS3vbjj5Bkao.jpg","tmdb_url":"https://www.themoviedb.org/person/2306608"},{"name":"Li Yizhen","name_vi":null,"name_original":"Li Yizhen","tmdb_id":3148327,"profile":"https://image.tmdb.org/t/p/w500/pRhWyH5XJLbV3PXvgR7Q50noIOe.jpg","tmdb_url":"https://www.themoviedb.org/person/3148327"},{"name":"Bạch Hân Di","name_vi":"Bạch Hân Di","name_original":"Bai Xinyi","tmdb_id":3177229,"profile":"https://image.tmdb.org/t/p/w500/tyrGlYLxIZG4zRrzc6hdufV7BYY.jpg","tmdb_url":"https://www.themov