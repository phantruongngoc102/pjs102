stream90.com/share/550843601db9a6ce932d3cc285f98d78","link_m3u8":"https://vip.opstream90.com/20260416/29603_55084360/index.m3u8"}]}],"description":"<p>Quỷ Vương tài năng xuất chúng, Hà Tư Mộ, bất ngờ gặp vị tướng trẻ tuổi, Đoàn Húc, trong lúc nghỉ ngơi tìm kiếm thức ăn. Vị tướng trẻ tuổi này, người mang theo một món đồ thuộc về một người nào đó trong quá khứ của Hà Tư Mộ, dường như không phải là Đoàn Húc thật. Qua những trao đổi tế nhị, họ dần khám phá ra quá khứ đen tối và những khát vọng ẩn giấu trong lòng Đoàn Húc. Đổi lại, Đoàn Húc khám phá ra sự kiên định và cô đơn mà Hà Tư Mộ đã phải chịu đựng. Mặc dù tuổi thọ ngắn ngủi của một người phàm, không quá một trăm năm, và hồn ma bốn trăm tuổi vẫn giữ nguyên hình dạng của một cô gái trẻ, họ vẫn chống lại sự trôi chảy không ngừng của thời gian bằng tình yêu của mình.</p>","tmdb_id":258865,"cast":["Địch Lệ Nhiệt Ba","Trần Phi Vũ","Ngụy Triết Minh","Trương Lệ","Cao Hàn","Dương Hật Tử"],"director":["秦榛"],"keywords":[],"tmdb":{"type":"tv","id":"258865","season":1,"vote_average":7.5,"vote_count":6},"cast_meta":[{"name":"Địch Lệ Nhiệt Ba","name_vi":"Địch Lệ Nhiệt Ba","name_original":"Dilraba Dilmurat","tmdb_id":1557698,"profile":"https://image.tmdb.org/t/p/w500/bLa0rBHdZ4Su1l5Xh0cY4mTB70Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1557698"},{"name":"Trần Phi Vũ","name_vi":"Trần Phi Vũ","name_original":"Arthur Chen","tmdb_id":2165598,"profile":"https://image.tmdb.org/t/p/w500/rP046czFxScpvRiinBAwJtc3302.jpg","tmdb_url":"https://www.themoviedb.org/person/2165598"},{"name":"Ngụy Triết Minh","name_vi":"Ngụy Triết Minh","name_original":"Miles Wei","tmdb_id":1914924,"profile":"https://image.tmdb.org/t/p/w500/vR3Jr5DQULKi0ndD6mG1uo7lTnz.jpg","tmdb_url":"https://www.themoviedb.org/person/1914924"},{"name":"Trương Lệ","name_vi":"Trương Lệ","name_original":"Zhang Li","tmdb_id":1993060,"profile":"https://image.tmdb.org/t/p/w500/eEvYNGg8NnyQlH1wWUcXdWvDEMB.jpg","tmdb_url":"https://www.themoviedb.org/person/1993060"},{"name":"Ca