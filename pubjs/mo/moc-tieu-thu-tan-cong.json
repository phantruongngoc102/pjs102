819b08eb4deecf01","link_m3u8":"https://vip.opstream14.com/20230104/29061_129f39e0/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/4b89ca473f73d62423a27511b3dce122","link_m3u8":"https://vip.opstream14.com/20230104/29062_db2ffae8/index.m3u8"}]}],"description":"<p>Cả gia đình Mộc Thị, doanh nghiệp đứng đầu ngành dịch vụ ăn uống, gặp tai nạn ngoài ý muốn ở nước ngoài. Nhị tiểu thư Mộc Ly nhận tim cấy ghép từ chị mình, thay người chị song sinh hóa thân thành một cô nàng thông minh lanh lợi được mọi người thích, hòng tiếp cận anh rể tương lai Mặc Thần, người khởi xướng việc thu mua tập đoàn Mộc Thị như tin đồn trên mạng, để âm thầm điều tra chân tướng vụ án, nhưng lại phát hiện hàng tấn bí mật phía sau vụ thu mua này. Hai người ômý đồ riêng mà thăm dò, hóa giải hết nguy cơ này đến nguy cơ khác, cuối cùng phát hiện đối thủ bí mật đứng đằng sau, lần theo manh mối tra được chân tướng vụ tai nạn xe, xóa bỏ ân oán.Từ đó, hai người bắt tay chống lại kẻ thù thật sự đằng sau, đồng thời bắt đầu khoảng thời gian tán tỉnh và được tán tỉnh đến là vui vẻ, cuối cùng Mộc Ly không chỉ “hốt” được chàng sếp tổng ngang ngược mà còn bắt được tất cả những kẻ hãm hại gia đình cô ra chịu sự trừng trị của pháp luật.</p>","tmdb_id":213518,"cast":["Wang Peihan","Han Donglin","Hao Yitong"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"213518","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Wang Peihan","name_vi":null,"name_original":"Wang Peihan","tmdb_id":3167092,"profile":"https://image.tmdb.org/t/p/w500/rPRbBYhDnDqbx3rrTouoKCkcPTh.jpg","tmdb_url":"https://www.themoviedb.org/person/3167092"},{"name":"Han Donglin","name_vi":null,"name_original":"Han Donglin","tmdb_id":2642151,"profile":"https://image.tmdb.org/t/p/w500/u3aXwq4jAAx737WDXV6aUZRMKSH.jpg","tmdb_url":"https://www.themoviedb.org/person/2642151"},{"name":"Hao Yitong","name_vi":null,"name_original":"Hao Yitong","tmdb_id":3764568,"profile":null,"tmdb_url":"https://www.themoviedb