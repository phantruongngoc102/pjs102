 Anhyeon - một người đầy quyết tâm và thẳng thắn. Với tính cách mạnh mẽ cùng tài năng trong công việc, Yoon Jin không ngại ngần đưa ra những nhận xét thẳng thắn cho mọi người, dù họ có địa vị cao trong xã hội. Tuy nhiên, chính vì lí do này khiến cô trước đó đã bị sa thải vì không thể nhắm mắt làm ngơ trước những sự việc bất công.","tmdb_id":234590,"cast":["Ji Sung","Jeon Mi-do","Lee Hyun So","Kwon Yul","Kim Kyung-nam","Lee Sang-jun","Jung Yoo-min","Jung Soon-won","Yoon Na-moo","Seo Yi-ra","Jeong Jae-kwang","Cha Yeob","Lee Kang-wook","Cho Han-gyeol","Kim Min-ju"],"director":["Kim Moon-kyo"],"keywords":[],"tmdb":{"type":"tv","id":"234590","season":1,"vote_average":8,"vote_count":21},"cast_meta":[{"name":"Ji Sung","name_vi":null,"name_original":"Ji Sung","tmdb_id":132180,"profile":"https://image.tmdb.org/t/p/w500/6RBiKyGLczeCrgnu1tfw5URRvEg.jpg","tmdb_url":"https://www.themoviedb.org/person/132180"},{"name":"Jeon Mi-do","name_vi":null,"name_original":"Jeon Mi-do","tmdb_id":2539185,"profile":"https://image.tmdb.org/t/p/w500/5di7RaZamjLPRqSVlvjUlXgVKm4.jpg","tmdb_url":"https://www.themoviedb.org/person/2539185"},{"name":"Lee Hyun So","name_vi":null,"name_original":"Lee Hyun So","tmdb_id":4914404,"profile":"https://image.tmdb.org/t/p/w500/aqxYIkZRoiNa55633iUFeiRXqvf.jpg","tmdb_url":"https://www.themoviedb.org/person/4914404"},{"name":"Kwon Yul","name_vi":null,"name_original":"Kwon Yul","tmdb_id":1564168,"profile":"https://image.tmdb.org/t/p/w500/rE7kLmUVFxeRqUUMFW8gr5nGi07.jpg","tmdb_url":"https://www.themoviedb.org/person/1564168"},{"name":"Kim Kyung-nam","name_vi":null,"name_original":"Kim Kyung-nam","tmdb_id":2033236,"profile":"https://image.tmdb.org/t/p/w500/8aj45J8AoEnidX08NlgY9l4foE8.jpg","tmdb_url":"https://www.themoviedb.org/person/2033236"},{"name":"Lee Sang-jun","name_vi":null,"name_original":"Lee Sang-jun","tmdb_id":3156313,"profile":"https://image.tmdb.org/t/p/w500/kmc1v6MRTtAshBIM55lcZtulAMt.jpg","tmdb_url":"https://www.themoviedb.org/person/3156313"},{"name"