":"https://vip.opstream11.com/20220412/13769_31df7882/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/65d141290a7de8a5c5ad8c972e8e6eff","link_m3u8":"https://vip.opstream11.com/20220412/13770_0a2acf8c/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/3894de97e081b06e5749a83e6bed2399","link_m3u8":"https://vip.opstream11.com/20220412/13771_bb6b5694/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/2ff87ef2c8e0ec43f54888b94b9d5d05","link_m3u8":"https://vip.opstream11.com/20220412/13772_5b8c6d73/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/c2aa4a54d4c5f5728e121f37b40472b9","link_m3u8":"https://vip.opstream11.com/20220412/13773_a8a92aaf/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream11.com/share/74707d064c4eeda12c3bf2f1807a7198","link_m3u8":"https://vip.opstream11.com/20220412/13774_1d9afa45/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream11.com/share/26fcf9e127023b55bc1dab3feacf45a8","link_m3u8":"https://vip.opstream11.com/20220412/13775_57832892/index.m3u8"}]}],"description":"<p>Phim kể câu chuyện về thiên tài âm nhạc trẻ tuổi Lee Sun Jae (Yoo Ah In). Nhờ sự giúp sức của Oh Hye Won (Kim Hee Ae) mà anh đã nhận ra khả năng của mình. Thế nhưng cũng từ đó, một chuyện tình bí mật và đầy nguy hiểm giữa cả hai bắt đầu hình thành. Mối tình bí mật không nằm ngoài kịch bản “tình yêu chị em” quen thuộc của Hàn Quốc, nhưng đây là lần đầu tiên những nhà làm phim truyền hình nước này thực sự nhấn mạnh vào khoảng cách tuổi tác của các nhân vật. Bởi thay vì chỉ kém 5 đến 10 tuổi như các phim khác, tác phẩm chọn một nhân vật ở độ tuổi đôi mươi và một nhận vật ở độ tuổi bốn mươi, trở thành yếu tố chính của cuộc tình. Một điều đặc biệt nữa, khác hẳn với các bộ phim khác là lần đầu tiên khán giả Hàn Quốc nhìn vào mối quan hệ tình cảm này ở góc độ đạo đức: cả hai người đều ngoại tình.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/mo/moi-tinh-bi-mat.json","tmdb_checked":false}