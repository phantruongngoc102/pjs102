cabd7fab013c7e6","link_m3u8":"https://vip.opstream13.com/20251125/19733_0b9bae10/index.m3u8"},{"name":"15","slug":"15","filename":"Món Quà Của Cha S01E15","link_embed":"https://vip.opstream13.com/share/07a97691a99801434b7f82702b14cbc6","link_m3u8":"https://vip.opstream13.com/20251125/19734_07a97691/index.m3u8"},{"name":"16","slug":"16","filename":"Món Quà Của Cha S01E16","link_embed":"https://vip.opstream13.com/share/c38cf856aaa37c92ed68f0fa57265730","link_m3u8":"https://vip.opstream13.com/20251125/19735_c38cf856/index.m3u8"},{"name":"17","slug":"17","filename":"Món Quà Của Cha S01E17","link_embed":"https://vip.opstream13.com/share/5e5b2d99a9a070119580c5bf49e90bb4","link_m3u8":"https://vip.opstream13.com/20251125/19736_5e5b2d99/index.m3u8"},{"name":"18","slug":"18","filename":"Món Quà Của Cha S01E18","link_embed":"https://vip.opstream13.com/share/f1eba978f8a36c92875063b46fd7e3a1","link_m3u8":"https://vip.opstream13.com/20251125/19737_f1eba978/index.m3u8"},{"name":"19","slug":"19","filename":"Món Quà Của Cha S01E19","link_embed":"https://vip.opstream13.com/share/a1231cf8c00e5608fc395813fe56afc3","link_m3u8":"https://vip.opstream13.com/20251125/19738_a1231cf8/index.m3u8"},{"name":"20","slug":"20","filename":"Món Quà Của Cha S01E20","link_embed":"https://vip.opstream13.com/share/efbff9ca2fa30ffe3d58261df8aa3a82","link_m3u8":"https://vip.opstream13.com/20251125/19739_efbff9ca/index.m3u8"},{"name":"21","slug":"21","filename":"Món Quà Của Cha S01E21","link_embed":"https://vip.opstream13.com/share/273e185673e56fa2bbd050bb6218b3a3","link_m3u8":"https://vip.opstream13.com/20251125/19740_273e1856/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Món quà của cha</i> kể về cuộc sống của ông Nhân (Võ Hoài Nam) và ba người con của ông là Trọng Nghĩa (Tuấn Tú), Diệu Thảo (Nguyễn Ngọc Huyền) và Trọng Hiếu (Lưu Duy Khánh). Ông Nhân làm nghề đóng quan tài, vớt xác chết đuối ở vùng quê, một mình nuôi các con khôn lớn. Sau này, con trai cả là Trọng Nghĩa lập gia đình, con gái út là Diệu Thảo học năm cuối thanh nhạc trên thành phố, ông Nhân sống ở quê cùng con trai út. Mỗi người con của ông Nhân đều có những lúc không thể hiểu hết được tấm lòng của cha gây phiền muộn cho đấng sinh thành, nhưng cuối cùng, trong hành trình trưởng thành, trải qua bao khó khăn, họ đã nhận ra được tình yêu vô bờ của cha, sự hy sinh không đòi hỏi đáp đền.</p>","tmdb":{"type":"tv","id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2025-11-28T15:03:30.000Z","cast":["Võ Hoài Nam","Minh Hòa","Tuấn Tú","Nguyễn Hương Giang","Nguyễn Ngọc Huyền","Lưu Duy Khánh"],"director":["Vũ Minh Trí"],"cast_meta":[{"name":"Võ Hoài Nam","name_vi":null,"name_original":"Võ Hoài Nam"},{"name":"Minh Hòa","name_vi":null,"name_original":"Minh Hòa"},{"name":"Tuấn Tú","name_vi":null,"name_original":"Tuấn Tú"},{"name":"Nguyễn Hương Giang","name_vi":null,"name_original":"Nguyễn Hương Giang"},{"name":"Nguyễn Ngọc Huyền","name_vi":null,"name_original":"Nguyễn Ngọc Huyền"},{"name":"Lưu Duy Khánh","name_vi":null,"name_original":"Lưu Duy Khánh"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/mo/mon-qua-cua-cha.json"}