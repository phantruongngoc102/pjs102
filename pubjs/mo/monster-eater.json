ộc phiêu lưu \"Ăn thịt quái vật\" của Rude bắt đầu, nơi anh ta có được những kỹ năng mới chỉ bằng cách ăn thịt kẻ thù của mình!</p>","tmdb_id":310921,"cast":["Makoto Furukawa","Yuki Nakashima"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"310921","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Makoto Furukawa","name_vi":null,"name_original":"Makoto Furukawa","tmdb_id":1319218,"profile":"https://image.tmdb.org/t/p/w500/inLmBZhrqXeE9wlViyK28ocKJSw.jpg","tmdb_url":"https://www.themoviedb.org/person/1319218"},{"name":"Yuki Nakashima","name_vi":null,"name_original":"Yuki Nakashima","tmdb_id":2140829,"profile":"https://image.tmdb.org/t/p/w500/zFFDjAZ0Bj2lmjBBcGdDMYUm2yG.jpg","tmdb_url":"https://www.themoviedb.org/person/2140829"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/mo/monster-eater.json"}