en tị, âm thầm điều tra. Mặt khác, sự trở lại của Chung Linh khiến kẻ nặng tình với Hàn Đông Lai là Lâm Hạ Tịch phát điên, lại âm mưu hãm hại lần nữa. Cha ruột của Khả Nhạc là ai? Mối tình xưa liệu có cơ hội tái hợp?","tmdb":{"type":"tv","id":"231484","season":1,"vote_average":8,"vote_count":3},"modified":"2025-03-23T09:36:13.000Z","cast":["Vương Hạo Hiên","Song Meina","Li Yichen","Qin Zimo","Ma Qiuzi","Liu Hanyu","Ma Qiuyuan"],"director":[],"cast_meta":[{"name":"Vương Hạo Hiên","name_vi":"Vương Hạo Hiên","name_original":"Wang Haoxuan","tmdb_id":2387797,"profile":"https://image.tmdb.org/t/p/w500/pIGexLCWDyXkMRFFXWPfJFHxsA9.jpg","tmdb_url":"https://www.themoviedb.org/person/2387797"},{"name":"Song Meina","name_vi":null,"name_original":"Song Meina","tmdb_id":4189295,"profile":"https://image.tmdb.org/t/p/w500/rEU5Hp40DpvoeGkW43VmBwZA9vy.jpg","tmdb_url":"https://www.themoviedb.org/person/4189295"},{"name":"Li Yichen","name_vi":null,"name_original":"Li Yichen","tmdb_id":4189298,"profile":"https://image.tmdb.org/t/p/w500/i5cSRgUhdldVCwiwORYfCpOv9nF.jpg","tmdb_url":"https://www.themoviedb.org/person/4189298"},{"name":"Qin Zimo","name_vi":null,"name_original":"Qin Zimo","tmdb_id":4189296,"profile":"https://image.tmdb.org/t/p/w500/3m0lZTLMyaZip7GIKr88i98CdtL.jpg","tmdb_url":"https://www.themoviedb.org/person/4189296"},{"name":"Ma Qiuzi","name_vi":null,"name_original":"Ma Qiuzi","tmdb_id":3240268,"profile":"https://image.tmdb.org/t/p/w500/bdoX7VYIeqYWH2Vx9Nwa4WrcChG.jpg","tmdb_url":"https://www.themoviedb.org/person/3240268"},{"name":"Liu Hanyu","name_vi":null,"name_original":"Liu Hanyu","tmdb_id":4189299,"profile":"https://image.tmdb.org/t/p/w500/6UO65wUbZyDbAkGNbUmniWQecOu.jpg","tmdb_url":"https://www.themoviedb.org/person/4189299"},{"name":"Ma Qiuyuan","name_vi":null,"name_original":"Ma Qiuyuan","tmdb_id":4189297,"profile":"https://image.tmdb.org/t/p/w500/3DHCYG1jPIC62Y0gunfaXTncP8J.jpg","tmdb_url":"https://www.themoviedb.org/person/4189297"}],"keywords":[],"pubjs_url":"ht