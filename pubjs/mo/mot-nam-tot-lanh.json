{"id":"6691f49c3d45d6d07a179fdf","title":"Một Năm Tốt Lành","origin_name":"A Good Year","slug":"mot-nam-tot-lanh","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/mo/mot-nam-tot-lanh.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/mo/mot-nam-tot-lanh.webp","year":2006,"type":"single","genre":[{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620a2370e0fc277084dfd91e","name":"Anh","slug":"anh"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"A.Good.Year.2006.1080p.Bluray.DD+5.1.x264-c0kE","link_embed":"https://vip.opstream90.com/share/b5b41fac0361d157d9673ecb926af5ae","link_m3u8":"https://vip.opstream90.com/20240711/502_b5b41fac/index.m3u8"}]}],"time":"117 Phút","description":"Cậu bé Max Skinner (cha mẹ đã chết) dành kỳ nghỉ hè học cách trân trọng những điều tốt đẹp hơn trong cuộc sống tại vườn nho của chú Henry ở miền đông nam nước Pháp. 25 năm sau, Max là một thương nhân thành công nhưng kiêu ngạo. Sau nhiều năm không liên lạc với chú Henry, Max Skinner nhận được tin báo rằng Henry đã qua đời, vì vậy Max thừa hưởng một tòa lâu đài và vườn nho ở Provence. Ông dành vài ngày ở đó, để hoàn tất thủ tục và bán đi tất cả.  Tuy nhiên, có những nhân vật mới xuất hiện làm thay đổi mọi kế hoạch của Max. Có thể khiến Max thay đổi theo chiều hướng xấu đi hay tốt lên? Bộ phim được phát hành tại Anh vào tháng 10/2006 và tại Mỹ vào tháng 11 năm 2006 bởi 20th Century Fox. Bộ phim thu về hơn 42,1 triệu USD so với ngân sách 35 triệu USD. Bộ phim nhận được đề cử Giải thưởng phê bình dành cho Nam diễn viên trẻ xuất sắc nhất và Giải thưởng vệ tinh cho Quay phim xuất sắc nhất. A Good Year được phát hành trên DVD năm 2007 bởi 20th Century Fox Home Entertainment.","tmdb":{"type":"movie","id":"9726","season":null,"vote_average":6.669,"vote_count":1593},"modified":"2024-07-13T10:29:32.000Z","cast":["Russell Crowe","Albert Finney","Marion Cotillard","Abbie Cornish","Didier Bourdon","Tom Hollander","Freddie Highmore","Isabelle Candelier","Archie Panjabi","Rafe Spall","Richard Coyle","Valeria Bruni Tedeschi","Kenneth Cranham","Daniel Mays","Giannina Facio"],"director":["Ridley Scott"],"cast_meta":[{"name":"Russell Crowe","name_vi":null,"name_original":"Russell Crowe","tmdb_id":934,"profile":"https://image.tmdb.org/t/p/w500/uxiXuVH4vNWrKlJMVVPG1sxAJFe.jpg","tmdb_url":"https://www.themoviedb.org/person/934"},{"name":"Albert Finney","name_vi":null,"name_original":"Albert Finney","tmdb_id":3926,"profile":"https://image.tmdb.org/t/p/w500/a2qJxu55s97ySRdjsy2ywIXJvhf.jpg","tmdb_url":"https://www.themoviedb.org/person/3926"},{"name":"Marion Cotillard","name_vi":null,"name_original":"Marion Cotillard","tmdb_id":8293,"profile":"https://image.tmdb.org/t/p/w500/biitzOF0GffIqFYLyOPkoiaOngQ.jpg","tmdb_url":"https://www.themoviedb.org/person/8293"},{"name":"Abbie Cornish","name_vi":null,"name_original":"Abbie Cornish","tmdb_id":37260,"profile":"https://image.tmdb.org/t/p/w500/AgIA8uPnwySIbqaPjr5jEXwZbS.jpg","tmdb_url":"https://www.themoviedb.org/person/37260"},{"name":"Didier Bourdon","name_vi":null,"name_original":"Didier Bourdon","tmdb_id":59031,"profile":"https://image.tmdb.org/t/p/w500/llffnXLuelL2gCu6LFH7aPiva4f.jpg","tmdb_url":"https://www.themoviedb.org/person/59031"},{"name":"Tom Hollander","name_vi":null,"name_original":"Tom Hollander","tmdb_id":2441,"profile":"https://image.tmdb.org/t/p/w500/cqZiJsImFZ6TaeShRRg49AZ9TyT.jpg","tmdb_url":"https://www.themoviedb.org/person/2441"},{"name":"Freddie Highmore","name_vi":null,"name_original":"Freddie Highmore","tmdb_id":1281,"profile":"https://image.tmdb.