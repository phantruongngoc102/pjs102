vẫn phải đi\", ở đoạn kết của câu chuyện, liệu những người yêu nhau có thể nên duyên trọn vẹn?</p><p>&nbsp;</p>","tmdb_id":280916,"cast":["Trần Tinh Húc","Vương Ngọc Văn","Mã Tư Siêu","Zeng Mengxue"],"director":["Lin Tzu-Ping"],"keywords":[],"tmdb":{"type":"tv","id":"280916","season":1,"vote_average":9,"vote_count":3},"cast_meta":[{"name":"Trần Tinh Húc","name_vi":"Trần Tinh Húc","name_original":"Chen Xingxu","tmdb_id":2243681,"profile":"https://image.tmdb.org/t/p/w500/coASvXYBdg4xTrW7W46ZQmfkwxk.jpg","tmdb_url":"https://www.themoviedb.org/person/2243681"},{"name":"Vương Ngọc Văn","name_vi":"Vương Ngọc Văn","name_original":"Wang Yuwen","tmdb_id":1836775,"profile":"https://image.tmdb.org/t/p/w500/lVmpKpml6evG5gWciRELbgdhvII.jpg","tmdb_url":"https://www.themoviedb.org/person/1836775"},{"name":"Mã Tư Siêu","name_vi":"Mã Tư Siêu","name_original":"Ma Sichao","tmdb_id":2638626,"profile":"https://image.tmdb.org/t/p/w500/xyMLF0ehbXOQpH0ibBCylrNKxlA.jpg","tmdb_url":"https://www.themoviedb.org/person/2638626"},{"name":"Zeng Mengxue","name_vi":null,"name_original":"Zeng Mengxue","tmdb_id":2163142,"profile":"https://image.tmdb.org/t/p/w500/hqbH32t4wHqk62z8a2zoy2gNPop.jpg","tmdb_url":"https://www.themoviedb.org/person/2163142"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/mo/mot-tinh-yeu-bat-ngo-den.json"}