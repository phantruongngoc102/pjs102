f439cb3e/index.m3u8"},{"name":"24","slug":"24","filename":"mot-van-lan-cuu-anh-tap-24","link_embed":"https://vip.opstream14.com/share/37160db944a57234ac9bf1ea9e99ae58","link_m3u8":"https://vip.opstream14.com/20220518/12129_3a703ea0/index.m3u8"}]}],"time":"34M57S","description":"<p>Ông chủ độc địa tự luyến Bạch Chân Tương liên tục chết vì sự oán hận của nhân viên. Mỗi lần anh ta chết, thời gian đều được lặp lại vào cùng một ngày, điều này khiến nhân viên của anh là Lí Lộ Đa bị mắc kẹt trong một vòng thời gian lặp lại. Để thoát ra khỏi vòng lặp thời gian, Lộ Đa phải tiếp xúc nhiều với sếp khiến cô phát điên, cô cố gắng làm thay đổi sếp, giải cứu anh ấy cho đến tận khi đã phải lòng anh.</p>","tmdb":{"type":"tv","id":"198194","season":1,"vote_average":5,"vote_count":1},"modified":"2022-05-18T13:11:05.000Z","cast":["White-K","Trương Nhã Khâm","Cảnh Nghiệp Đình","Alvin Cao","Xu Xinwen","Zhao Xin","Kong Lianshun","Tôn Nghệ Ninh","Wang Shuyi","Triệu Kha","Dong Kefei","Zhou Pu","Trương Thần Quang","Xunzimo Liu","Zhou Hengyu"],"director":["Deng An Ning"],"cast_meta":[{"name":"White-K","name_vi":null,"name_original":"White-K","tmdb_id":1627281,"profile":"https://image.tmdb.org/t/p/w500/t7Hi7qYnXPaeehR7K5rbf0hHX0B.jpg","tmdb_url":"https://www.themoviedb.org/person/1627281"},{"name":"Trương Nhã Khâm","name_vi":"Trương Nhã Khâm","name_original":"Zhang Yaqin","tmdb_id":1971604,"profile":"https://image.tmdb.org/t/p/w500/mBsq8Vch45vbJ78m6Hlf9ryoTnr.jpg","tmdb_url":"https://www.themoviedb.org/person/1971604"},{"name":"Cảnh Nghiệp Đình","name_vi":"Cảnh Nghiệp Đình","name_original":"Geng Yeting","tmdb_id":3123528,"profile":"https://image.tmdb.org/t/p/w500/zgJ9vQDpqFCOae0ia5tP2h3LNu4.jpg","tmdb_url":"https://www.themoviedb.org/person/3123528"},{"name":"Alvin Cao","name_vi":null,"name_original":"Alvin Cao","tmdb_id":2033758,"profile":"https://image.tmdb.org/t/p/w500/zdQPU9FhEPSuNP71UcJ5Nw6UW0N.jpg","tmdb_url":"https://www.themoviedb.org/person/2033758"},{"name":"Xu Xinwen","name_vi":null