5068901da92473666256e6e5b","link_m3u8":"https://vip.opstream11.com/20220319/3132_f338a6ae/index.m3u8"},{"name":"24","slug":"24","filename":"mua-he-cua-huong-bac-ha-tap-24","link_embed":"https://vip.opstream11.com/share/7221e5c8ec6b08ef6d3f9ff3ce6eb1d1","link_m3u8":"https://vip.opstream11.com/20220319/3133_ad494b1b/index.m3u8"}]}],"time":"22M37S","description":"<p>Cô gái múa ba lê Đồng Tịch phải giã từ thành phố lớn để trở về thị trấn nhỏ ở quê nhà do mẹ bị điều chuyển công tác.&nbsp;Cô muốn nhân cơ hội chuyển trường che giấu tính cách mạnh mẽ của mình nhưng nào ngờ lại bị thanh mai trúc mã Lâm Nam Nhất thân quen từ nhỏ nhìn thấu.&nbsp;Một người muốn đóng kịch, một người muốn vạch trần, từ liên tục hiểu lầm đến giúp đỡ lẫn nhau, cặp đôi oan gia này dần dần thấu hiểu và dựa dẫm vào nhau hơn trong cuộc sống thường ngày cùng bạn bè ở thị trấn.Tuy nhiên, Đồng Tịch vô tình biết được Lâm Nam Nhất chính là nam thần truyện tranh mà cô ngưỡng mộ bấy lâu...&nbsp;Khi những bối rối trên con đường theo đuổi ước mơ chạm phải những rung động đầu đời ngây ngô, trong trẻo, mối lương duyên tiền định này sẽ viết nên câu chuyện thanh xuân ngọt ngào vui vẻ trong mùa hè này.Và giữa họ còn rất nhiều những cuộc hội ngộ và chia ly...</p>","tmdb":{"type":"tv","id":"128927","season":1,"vote_average":8,"vote_count":2},"modified":"2022-05-30T09:21:51.000Z","cast":["Ni Kexin","Trần Hạc Nhất","Zhang Yinuo","Xie Zecheng","Han Xinyu","Sen Zhuang","Chen Ruifeng","Wang Han"],"director":["MosChen","Mi Bao"],"cast_meta":[{"name":"Ni Kexin","name_vi":null,"name_original":"Ni Kexin","tmdb_id":2834896,"profile":"https://image.tmdb.org/t/p/w500/q63EgVzqogK2t6QIMjW66IQPOFH.jpg","tmdb_url":"https://www.themoviedb.org/person/2834896"},{"name":"Trần Hạc Nhất","name_vi":"Trần Hạc Nhất","name_original":"Chen Heyi","tmdb_id":2972064,"profile":"https://image.tmdb.org/t/p/w500/86nzG9p1WfL3OS2Q4L5cOHIkwwh.jpg","tmdb_url":"https://www.themoviedb.org/person/2972064"},{"name":"Zhang Yinuo","name_vi":null,"name_original"