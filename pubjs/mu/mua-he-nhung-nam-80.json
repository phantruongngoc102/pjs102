b4","link_m3u8":"https://vip.opstream90.com/20260228/26081_a383d5fd/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream90.com/share/116e195af1954fe5253cf0a55f07ef48","link_m3u8":"https://vip.opstream90.com/20260301/26130_116e195a/index.m3u8"}]}],"description":"<p>Nhà họ Trịnh và nhà họ Vương vốn đã có mối hiềm khích từ trước. Thế nhưng, vào cuối mùa hạ những năm 80, một biến cố tình cờ lại khiến vận mệnh của hai gia đình lần nữa đan xen. Sau khi bị mất việc ở nhà máy, con gái thứ nhà họ Vương, Vương Ánh Dung lâm vào cảnh lao đao: nuôi lợn thất bại, khởi nghiệp làm giấm cũng không suôn sẻ. Trên suốt chặng đường gian nan ấy, cô luôn nhận được sự giúp đỡ âm thầm từ con trai cả nhà họ Trịnh là Trịnh Mân Giang. Lửa gần rơm lâu ngày cũng bén, giữa họ dần nảy sinh tình cảm sâu đậm. Cuối cùng, những khúc mắc giữa hai gia đình được hóa giải. Mối thâm thù năm xưa khép lại, nhường chỗ cho ngày vui khi hai nhà kết thành thông gia.</p>","tmdb_id":313473,"cast":["Khương Chi Nam","Wang Haozhen","Jin Long","Wang Junzhe","Yang Xinran"],"director":["Lin Qing"],"keywords":[],"tmdb":{"type":"tv","id":"313473","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Khương Chi Nam","name_vi":"Khương Chi Nam","name_original":"Jiang Zhinan","tmdb_id":3591475,"profile":"https://image.tmdb.org/t/p/w500/znwM7ZJTSCHzrewH3vuiIlPSfiU.jpg","tmdb_url":"https://www.themoviedb.org/person/3591475"},{"name":"Wang Haozhen","name_vi":null,"name_original":"Wang Haozhen","tmdb_id":2398805,"profile":"https://image.tmdb.org/t/p/w500/nzi0X3wpz5ISXRWnVmn2D0W9a2Y.jpg","tmdb_url":"https://www.themoviedb.org/person/2398805"},{"name":"Jin Long","name_vi":null,"name_original":"Jin Long","tmdb_id":5361179,"profile":"https://image.tmdb.org/t/p/w500/iRgwH7K80ZlB1adSz4wQpaOSIcK.jpg","tmdb_url":"https://www.themoviedb.org/person/5361179"},{"name":"Wang Junzhe","name_vi":null,"name_original":"Wang Junzhe","tmdb_id":3335367,"profile":"https://image.tmdb.org/t/p/w500/u385UVrkE2SUURheU8LhKt9W