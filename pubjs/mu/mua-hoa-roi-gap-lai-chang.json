4da224e","link_m3u8":"https://vip.opstream90.com/20250524/6357_df3aebc6/index.m3u8"}]}],"description":"Mùa Hoa Rơi Gặp Lại Chàng xoay quanh mối duyên nợ 3 kiếp của tiểu yêu hoa sơn Hồng Ngưng (Viên Băng Nghiên) và Thượng thần Cẩm Tú (Lưu Học Nghĩa). Hồng Ngưng phải lòng Cẩm Tú từ ánh nhìn đầu tiên, và để có thể ở bên cạnh chàng mà nàng đã quyết tâm tu tiên. Thế nhưng trải qua nhiều biến cố và tổn thương, Cẩm Tú lại nên duyên với tiên nữ khác, còn Hồng Ngưng buông bỏ, rơi vào vòng luân hồi. Đến lúc biết hối hận, Cẩm Tú quyết định quay về quá khứ để cứu lấy Hồng Ngưng.","tmdb_id":204160,"cast":["Lưu Học Nghĩa","Hồ Ý Hoàn","Ngao Thụy Bằng","Hứa Hiểu Nặc","Yang Lin","Jing Yanjun","Wang Shimeng","Pan Feiyang"],"director":["Yvonne Yang","Zhao Lijun"],"keywords":[],"tmdb":{"type":"tv","id":"204160","season":1,"vote_average":8.3,"vote_count":3},"cast_meta":[{"name":"Lưu Học Nghĩa","name_vi":"Lưu Học Nghĩa","name_original":"Liu Xueyi","tmdb_id":2084467,"profile":"https://image.tmdb.org/t/p/w500/zJG3K9Ey4EJp9p2wu88UchkgRG0.jpg","tmdb_url":"https://www.themoviedb.org/person/2084467"},{"name":"Hồ Ý Hoàn","name_vi":"Hồ Ý Hoàn","name_original":"Hu Yixuan","tmdb_id":2164832,"profile":"https://image.tmdb.org/t/p/w500/vOa4szQkowRT34eNPvjwwJKqBAN.jpg","tmdb_url":"https://www.themoviedb.org/person/2164832"},{"name":"Ngao Thụy Bằng","name_vi":"Ngao Thụy Bằng","name_original":"Ao Ruipeng","tmdb_id":2798208,"profile":"https://image.tmdb.org/t/p/w500/ixekaZD5T0rkc518UZtadioBX9z.jpg","tmdb_url":"https://www.themoviedb.org/person/2798208"},{"name":"Hứa Hiểu Nặc","name_vi":"Hứa Hiểu Nặc","name_original":"Xu Xiaonuo","tmdb_id":2378292,"profile":"https://image.tmdb.org/t/p/w500/7i9HVcCtXDDRfsub5kkJJOvkkrC.jpg","tmdb_url":"https://www.themoviedb.org/person/2378292"},{"name":"Yang Lin","name_vi":null,"name_original":"Yang Lin","tmdb_id":3099878,"profile":"https://image.tmdb.org/t/p/w500/ldvuEZQi8mqliT8FytdItcHV6DP.jpg","tmdb_url":"https://www.themoviedb.org/person/3099878"},{"name":"Jing Yanjun"