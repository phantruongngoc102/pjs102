iai tầng gia đình. Mười năm sau, Sầm Tư Viễn đã trở thành tổng giám đốc tập đoàn cà phê, sắp cưới minh tinh Tô Bái Bái; còn Lâm Miểu Miểu lại trở thành thư kí đắc lực của mẹ anh. Một cuộc khủng hoảng thương mại khiến cả hai lại cùng nhau hợp tác, chân tướng và tình cũ đồng thời lộ ra. Họ cùng nhau vượt qua trở ngại và cuối cùng tái hợp.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"292810","season":1,"vote_average":6.5,"vote_count":2},"modified":"2025-07-16T18:32:31.000Z","cast":["Hà Xưởng Hy","Ji Shuyi","Pan Zijian","Guo Jiayu","Ma Fei","Huang Yixuan"],"director":["林森"],"cast_meta":[{"name":"Hà Xưởng Hy","name_vi":"Hà Xưởng Hy","name_original":"He Changxi","tmdb_id":2864044,"profile":"https://image.tmdb.org/t/p/w500/rUv6sbT9t4KQ2l2l9y7FACpPatG.jpg","tmdb_url":"https://www.themoviedb.org/person/2864044"},{"name":"Ji Shuyi","name_vi":null,"name_original":"Ji Shuyi","tmdb_id":3844785,"profile":"https://image.tmdb.org/t/p/w500/lZDPFOgpdjuqmwhRBG8G3aNuTXK.jpg","tmdb_url":"https://www.themoviedb.org/person/3844785"},{"name":"Pan Zijian","name_vi":null,"name_original":"Pan Zijian","tmdb_id":2788706,"profile":"https://image.tmdb.org/t/p/w500/pmncBV4I0qfQlawm7Ibghxc9LnZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2788706"},{"name":"Guo Jiayu","name_vi":null,"name_original":"Guo Jiayu","tmdb_id":4352412,"profile":"https://image.tmdb.org/t/p/w500/olnvUUlHPsPXFoe7YAvfkKdKiEx.jpg","tmdb_url":"https://www.themoviedb.org/person/4352412"},{"name":"Ma Fei","name_vi":null,"name_original":"Ma Fei","tmdb_id":4391182,"profile":"https://image.tmdb.org/t/p/w500/yxVnS4jToA4e6byYvN99w2J06Ll.jpg","tmdb_url":"https://www.themoviedb.org/person/4391182"},{"name":"Huang Yixuan","name_vi":null,"name_original":"Huang Yixuan","tmdb_id":5573489,"profile":"https://image.tmdb.org/t/p/w500/50lB9A4DtU2yzc4xqPCKqyzpY80.jpg","tmdb_url":"https://www.themoviedb.org/person/5573489"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/mu/muoi-n