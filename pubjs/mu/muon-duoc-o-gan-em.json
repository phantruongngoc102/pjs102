ững lớp vỏ ngụy trang ấy bỗng chốc vướng vào cuộc đời nhau. Họ giằng xé, đối đầu, rồi lại cứu rỗi lẫn nhau. Những vết sẹo trong lòng dần được phơi bày, và cũng chính họ lại trở thành liều thuốc dịu dàng nhất chữa lành cho nhau.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"288888","season":1,"vote_average":7.5,"vote_count":2},"modified":"2025-05-24T11:13:30.000Z","cast":["Liu Xiaobei","Bubble Zhu","Li Ruotian","Wu Bowei","Chen Jianing","Chen Siyu","Hu Xiaolong","Lv Yihao","Liu Haoyuan"],"director":["Jackie Zhang"],"cast_meta":[{"name":"Liu Xiaobei","name_vi":null,"name_original":"Liu Xiaobei","tmdb_id":4515680,"profile":"https://image.tmdb.org/t/p/w500/t7ORvESrEq0K2n1ognceKdeAorQ.jpg","tmdb_url":"https://www.themoviedb.org/person/4515680"},{"name":"Bubble Zhu","name_vi":null,"name_original":"Bubble Zhu","tmdb_id":2986720,"profile":"https://image.tmdb.org/t/p/w500/rpomNHimsSigy8ECVWBVRz2x9XL.jpg","tmdb_url":"https://www.themoviedb.org/person/2986720"},{"name":"Li Ruotian","name_vi":null,"name_original":"Li Ruotian","tmdb_id":2719784,"profile":"https://image.tmdb.org/t/p/w500/LTTUq5xm5l4x52Gvv8Lkbp8YBG.jpg","tmdb_url":"https://www.themoviedb.org/person/2719784"},{"name":"Wu Bowei","name_vi":null,"name_original":"Wu Bowei","tmdb_id":4859650,"profile":"https://image.tmdb.org/t/p/w500/cW0zjQR42XmaZnrwSY2UEBunXNN.jpg","tmdb_url":"https://www.themoviedb.org/person/4859650"},{"name":"Chen Jianing","name_vi":null,"name_original":"Chen Jianing","tmdb_id":4105925,"profile":"https://image.tmdb.org/t/p/w500/sMyfJlQ1w9DJZqF18VGuA89VGNZ.jpg","tmdb_url":"https://www.themoviedb.org/person/4105925"},{"name":"Chen Siyu","name_vi":null,"name_original":"Chen Siyu","tmdb_id":5477871,"profile":"https://image.tmdb.org/t/p/w500/fJKDHAO1fyj1jLHN66PeKPE8BUa.jpg","tmdb_url":"https://www.themoviedb.org/person/5477871"},{"name":"Hu Xiaolong","name_vi":null,"name_original":"Hu Xiaolong","tmdb_id":5369341,"profile":"https://image.tmdb.org/t/p/w500/3rOno0b7QnUNS0dynogFHGef545.jpg","tmdb_url":"https:/