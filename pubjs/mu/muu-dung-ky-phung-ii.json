hare/2e1e29f5fc4f906c2145acc6840b29ff","link_m3u8":"https://vip.opstream13.com/20251104/17198_2e1e29f5/index.m3u8"},{"name":"19","slug":"19","filename":"TVB Mưu Dũng Kỳ Phùng II (The Gentle Crackdown II) 19#20 # Mã Tuấn Vỹ, Lê Diệu Tường # 2008","link_embed":"https://vip.opstream13.com/share/f7c0dc716cd86f8d162c366d370baf14","link_m3u8":"https://vip.opstream13.com/20251104/17199_f7c0dc71/index.m3u8"},{"name":"20","slug":"20","filename":"TVB Mưu Dũng Kỳ Phùng II (The Gentle Crackdown II) 20#20 # Mã Tuấn Vỹ, Lê Diệu Tường # 2008","link_embed":"https://vip.opstream13.com/share/6222d5fd70abd4fe144a1df81fc2ea98","link_m3u8":"https://vip.opstream13.com/20251104/17200_6222d5fd/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Mất cha từ nhỏ, nữ bảo vệ nông trại Trần Thế Miêu dần trở thành một người phụ nữ thẳng thắn và quyết đoán, luôn nỗ lực hết mình để bảo vệ ngôi làng quê hương. Chính sự chân thành đã giúp cô nhận được sự kính trọng của toàn thể dân làng huyện Lương Thiều. Một ngày nọ, cô nhầm lẫn vị quan nông dân mới được bổ nhiệm Tạ Hoàng Thượng là một tên trộm, và từ đó hai người trở thành kẻ thù không đội trời chung. Sau khi Thế Miêu cứu Hoàng Thượng khỏi bị vu oan, và họ bắt đầu dành nhiều thời gian bên nhau hơn, Thế Miêu dần nảy sinh tình cảm với Hoàng Thượng.</p>","tmdb":{"type":"tv","id":"15916","season":1,"vote_average":7,"vote_count":1},"modified":"2025-11-05T08:55:11.000Z","cast":["Mã Tuấn Vỹ","Trịnh Hy Di","Lê Diệu Tường","Ha Yue","La Quán Lan","Savio Tsang","Mạch Trường Thanh","Johnson Lee Sze-Chit","Elaine Yiu","Lý Quốc Lân","Mimi Chu Mai-Mai","Lý Thành Xương","Sunny Tai Yiu-Ming","Akai Lee","Isaac Ng Man-Sang"],"director":[],"cast_meta":[{"name":"Mã Tuấn Vỹ","name_vi":"Mã Tuấn Vỹ","name_original":"Steven Ma Chun-Wai","tmdb_id":1233285,"profile":"https://image.tmdb.org/t/p/w500/q60svjeSi9KpyZCwhnwwy6iy8Qs.jpg","tmdb_url":"https://www.themoviedb.org/person/1233285"},{"name":"Trịnh Hy Di","name_vi":"Trịnh Hy Di","name_original":"Yumiko Cheng Hei-Yi","tm