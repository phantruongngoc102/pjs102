com/share/6b34a8bba1dd1aaa9ac3fc1235f21f39","link_m3u8":"https://vip.opstream16.com/20250816/46001_6b34a8bb/index.m3u8"},{"name":"27","slug":"27","filename":"Phim TVB Mưu Sinh (Hidden Treasures) 27#30 # Âu Dương Chấn Hoa, Quách Thiện Ni # 2005","link_embed":"https://vip.opstream16.com/share/dbcdb9431af5649fbbe406021ac2dab2","link_m3u8":"https://vip.opstream16.com/20250816/46002_dbcdb943/index.m3u8"},{"name":"28","slug":"28","filename":"Phim TVB Mưu Sinh (Hidden Treasures) 28#30 # Âu Dương Chấn Hoa, Quách Thiện Ni # 2005","link_embed":"https://vip.opstream16.com/share/98b8bfc1a714a2b84af2b8a57fd7dc2c","link_m3u8":"https://vip.opstream16.com/20250816/46003_98b8bfc1/index.m3u8"},{"name":"29","slug":"29","filename":"Phim TVB Mưu Sinh (Hidden Treasures) 29#30 # Âu Dương Chấn Hoa, Quách Thiện Ni # 2005","link_embed":"https://vip.opstream16.com/share/bdb253b49526c46fc0002d521a469b20","link_m3u8":"https://vip.opstream16.com/20250816/46004_bdb253b4/index.m3u8"},{"name":"30","slug":"30","filename":"Phim TVB Mưu Sinh (Hidden Treasures) 30#30 # Âu Dương Chấn Hoa, Quách Thiện Ni # 2005","link_embed":"https://vip.opstream16.com/share/ea7f2f9471927458f88b04f4b1832b2a","link_m3u8":"https://vip.opstream16.com/20250816/46005_ea7f2f94/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Phố Apliu là biểu tượng của Hồng Kông. Cùng với những thăng trầm của nền kinh tế Hồng Kông, nơi đây cũng trải qua thời kỳ hoàng kim thịnh vượng và trở thành một thị trường buôn bán đồ cũ. Trước cuộc khủng hoảng tài chính, cửa hàng âm thanh cao cấp của Đới Thiếu Lương là cửa hàng lớn nhất phố Alia. Người bạn của anh, Thành Đại Trí, sở hữu khối tài sản ròng hơn chục triệu đô la nhờ đầu cơ. Sau cuộc khủng hoảng tài chính, công việc kinh doanh của Thiếu Lương sa sút, Đại Trí rơi vào cảnh nợ nần chồng chất. Chỉ có hai người bạn, Quan Băng Nhân, là người thực tế và không bị ảnh hưởng. Tuy xuất thân khác nhau, nhưng họ lại có một tình bạn thân thiết. Yêu bóng đá, một đội bóng ba người, thậm chí còn được mệnh danh là \"Ba anh hùng Vịt\" trong quận.</p>","tmdb":{"type":"tv","id":"109837","season":1,"vote_average":6,"vote_count":2},"modified":"2025-08-17T18:14:01.000Z","cast":["Âu Dương Chấn Hoa","Quách Thiện Ni","Hướng Hải Lam","Lê Diệu Tường","Dương Tư Kỳ","Ellesmere Choi","Lai Suen","Candy Chiu Ching-Yee","Lâm Thục Mẫn","Rosanne Lui Shan","Diêu Doanh Doanh","Jacky Wong Shu-Hei","Hứa Thiệu Hùng","Vương Tuấn Đường","Celine Ma"],"director":[],"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Quách Thiện Ni","name_vi":"Quách Thiện Ni","name_original":"Sonija Kwok Sin-Nae","tmdb_id":1223071,"profile":"https://image.tmdb.org/t/p/w500/UPKGvicMcTMLHZ0vuc49sV0BoG.jpg","tmdb_url":"https://www.themoviedb.org/person/1223071"},{"name":"Hướng Hải Lam","name_vi":"Hướng Hải Lam","name_original":"Anne Heung Hoi-Lam","tmdb_id":1222765,"profile":"https://image.tmdb.org/t/p/w500/slQuz6prpWCW6KRefXlQ4gMEyHX.jpg","tmdb_url":"https://www.themoviedb.org/person/1222765"},{"name":"Lê Diệu Tường","name_vi":"Lê Diệu Tường","name_original":"Wayne Lai Yiu-Cheung","tmdb_id":123654,"profile":"https://image.tmdb.org/t/p/w500/qm3knPxzkZPgq2SVo1ZTru7MkIM.jpg","tmdb_url":"https://www.themoviedb.org/person/123654"},{"name":"Dương Tư Kỳ","name_vi":"Dương Tư Kỳ","name_original":"Shirley Yeung Sze-Kei","tmdb_id":1233366,"profile":"https://image.tmdb.org/t/p/w500/xAZ36bayNij4diOzIm4HAkLcBMz.jpg","tmdb_url":"https://www.themoviedb.org/person/1233366"},{"name":"Ellesmere Choi","name_vi":"Ellesmere Choi","name_original":"Ellesmere Choi","tmdb_id":1238939,"profile":"https://image.tmdb.org/t/p/w500/z7KjfOqnNG59Pc3K5RyvCDtGp4l.jpg","tmdb_url":"https://www.themoviedb.org/person/1238939"},{"name":"Lai Suen","name_vi":null,"name_original":"Lai Suen","tmdb_id":2429574,"profile":"https://image.tmdb.org/