0f92ed067c95e","link_m3u8":"https://vip.opstream10.com/20220420/9079_5119b8ad/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream10.com/share/f655e8f9339af2b629ebed05b585423a","link_m3u8":"https://vip.opstream10.com/20220420/9082_024b44c5/index.m3u8"}]}],"description":"<p>Bộ phim Mỹ Ly Cách Cách một câu chuyện tình bắt đầu là sự hiểu lầm, kết thúc cũng là sự hiểu lầm, đó là câu chuyện tình yêu của Mỹ Ly cách cách ngang bướng của Mông Cổ và Tĩnh Hiên trong phim Khuynh Thành Tuyệt Luyến. Khi Mỹ Ly tới Bắc Khinh vì một sự hiểu lầm nên quen biết với Tĩnh Hiên, từ đó họ có tình cảm sâu nặng với nhau dù không biết thân phận thật của nhau. Rồi chuyện tình cảm của hai người bị Thái phúc tấn – mẹ của Mỹ Ly kiệt lịch phản đối. Trong lúc đang đấu tranh cho tình yêu của mình thì họ lại gặp môt hiểu lầm làm họ mất lòng tin và xa nhau. Dù xa nhau nhưng trái tim họ luôn hướng về nhau với một tình yêu bất diệt. Phim Khuynh Thành Tuyệt Luyến có sự tham gia của tân tiểu yến từ Lý Thạnh và Tứ a ca của cung tỏa tâm ngọc Hà Thịnh Minh.</p>","tmdb_id":69601,"cast":[],"director":[],"keywords":[],"tmdb":{"id":69601},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/my/my-ly-cach-cach.json"}