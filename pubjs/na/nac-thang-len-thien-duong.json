/410_6ea11e97/index.m3u8"},{"name":"38","slug":"38","filename":"Nấc Thang Lên Thiên Đường - Stairway to Heaven - Tập 38","link_embed":"https://vip.opstream12.com/share/a96b65a721e561e1e3de768ac819ffbb","link_m3u8":"https://vip.opstream12.com/20220218/409_f108746b/index.m3u8"},{"name":"39","slug":"39","filename":"Nấc Thang Lên Thiên Đường - Stairway to Heaven - Tập 39","link_embed":"https://vip.opstream12.com/share/0d0fd7c6e093f7b804fa0150b875b868","link_m3u8":"https://vip.opstream12.com/20220218/408_1d457bea/index.m3u8"},{"name":"40","slug":"40","filename":"Nấc Thang Lên Thiên Đường - Stairway to Heaven - Tập 40","link_embed":"https://vip.opstream12.com/share/f4f6dce2f3a0f9dada0c2b5b66452017","link_m3u8":"https://vip.opstream12.com/20220218/407_cafcbc11/index.m3u8"}]}],"time":"30 phút/tập","description":"<p>Nấc thang lên thiên đường là một câu chuyện buồn, xoay quanh cuộc sống của bốn người trẻ trong quá trình đi đến thiên đường hạnh phúc của đời mình. Đó là một Han Jung Seo hiền lành, thánh thiện như một thiên thần. Cô có bên mình một tuổi thơ bình yên hạnh phúc với cuộc sống đầy đủ vật chất, cùng sự yêu thương của người bạn trai thân thiết từ thuở nhỏ. Đó là một Cha Song Joo sinh trưởng trong một gia đình giàu có, là một Han Yoo Ri đầy toan tính với một tuổi thơ bất hạnh, là Han Tae Hwa với một “cái tôi” mạnh mẽ ẩn bên trong vẻ lầm lì, ít nói, nhưng lại rất tình cảm.</p>","tmdb":{"type":"tv","id":"5178","season":1,"vote_average":8.1,"vote_count":1162},"modified":"2023-03-30T17:53:52.000Z","cast":["Kwon Sang-woo","Choi Ji-woo","Shin Hyun-jun","Kim Tae-hee","Lee Hwi-hyang","Park Shin-hye","Baek Sung-hyun","Ha Jae-yeong","Kim Ji-sook","Jung Han-yong"],"director":[],"cast_meta":[{"name":"Kwon Sang-woo","name_vi":null,"name_original":"Kwon Sang-woo","tmdb_id":1233094,"profile":"https://image.tmdb.org/t/p/w500/sXWZ82ph4ZPPG9kv2x6nXha1Kk4.jpg","tmdb_url":"https://www.themoviedb.org/person/1233094"},{"name":"Choi Ji-woo","name_vi":null,"name_original":"Choi Ji-woo","tmdb_