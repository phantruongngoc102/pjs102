505/11971_631e77a8/index.m3u8"},{"name":"73","slug":"73","link_embed":"https://vip.opstream10.com/share/6d79e030371e47e6231337805a7a2685","link_m3u8":"https://vip.opstream10.com/20220505/11972_e88c954e/index.m3u8"},{"name":"74","slug":"74","link_embed":"https://vip.opstream10.com/share/fa587ec2731aab9f2952622e89088d4b","link_m3u8":"https://vip.opstream10.com/20220505/11975_44d6c596/index.m3u8"}]}],"description":"<p>Phim Năm Ấy Hoa Nở Trăng Vừa Tròn - Nothing Gold Can Stay 2017: Chu Doanh từ một cô gái giang hồ bỗng dung được \"đổi đời\", trở thành con dâu nhà họ Ngô và vướng vào những rắc rối của gia tộc. Sánh vai bên cô lần này là \"trai đẹp một con\" Trần Hiểu, anh vào vai Thẩm Tinh Di, một thiếu gia bồng bột, nông nổi vì Chu Doanh mà dần thay đổi thành một người đàn ông cương nghị nhưng trọng tình.</p>","tmdb_id":73625,"cast":[],"director":[],"keywords":[],"tmdb":{"id":73625},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/na/nam-ay-hoa-no-trang-vua-tron.json"}