i khách sạn Nam Đình, từ đó liên tiếp gặp phải những sự việc kỳ quái. Không những không thể rời khỏi khách sạn để đi nhập học, lại còn chạm trán với Vương gia Dận Đình bí ẩn đã sống hơn ba trăm năm… Cao Ảnh không chỉ phải đối phó với biết bao tai họa do Thái Tuế mang đến, mà còn phải đối diện với nỗi sợ trong chính tâm hồn mình, để rồi đứng lên chiến đấu, bảo vệ những người quan trọng!</p>","tmdb_id":297092,"cast":["Sun Lulu","Wei Chao","Wu Haitao","Yue Cu","Ji Guanlin","Ajie"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"297092","season":1,"vote_average":8.5,"vote_count":2},"cast_meta":[{"name":"Sun Lulu","name_vi":null,"name_original":"Sun Lulu","tmdb_id":3434824,"profile":"https://image.tmdb.org/t/p/w500/ktTUzFsYoFCCYN64m7EV9CTogiZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3434824"},{"name":"Wei Chao","name_vi":null,"name_original":"Wei Chao","tmdb_id":2199340,"profile":"https://image.tmdb.org/t/p/w500/aPYAEWrS1lb1UYwCFejIcJOOGSU.jpg","tmdb_url":"https://www.themoviedb.org/person/2199340"},{"name":"Wu Haitao","name_vi":null,"name_original":"Wu Haitao","tmdb_id":5731324,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5731324"},{"name":"Yue Cu","name_vi":null,"name_original":"Yue Cu","tmdb_id":3721440,"profile":"https://image.tmdb.org/t/p/w500/q4Xejn2gc4FP84YR9Cjrz8D557b.jpg","tmdb_url":"https://www.themoviedb.org/person/3721440"},{"name":"Ji Guanlin","name_vi":null,"name_original":"Ji Guanlin","tmdb_id":1674211,"profile":"https://image.tmdb.org/t/p/w500/l0gh3dtxCloqdKZZ9NZnrm3kums.jpg","tmdb_url":"https://www.themoviedb.org/person/1674211"},{"name":"Ajie","name_vi":null,"name_original":"Ajie","tmdb_id":1674221,"profile":"https://image.tmdb.org/t/p/w500/AaXR7HBOkyrLlM93cycAt6i9NDE.jpg","tmdb_url":"https://www.themoviedb.org/person/1674221"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/na/nam-dinh-coc-vi.json"}