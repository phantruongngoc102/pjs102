1ed6a21/index.m3u8"},{"name":"33","slug":"33","filename":"Nam Lai Bắc Vãng - Ep33","link_embed":"https://vip.opstream17.com/share/1e6e0a04d20f50967c64dac2d639a577","link_m3u8":"https://vip.opstream17.com/20240223/1100_49838ee5/index.m3u8"},{"name":"34","slug":"34","filename":"Nam Lai Bắc Vãng - Ep34","link_embed":"https://vip.opstream17.com/share/c667d53acd899a97a85de0c201ba99be","link_m3u8":"https://vip.opstream17.com/20240223/1102_d37a1c16/index.m3u8"},{"name":"35","slug":"35","filename":"Nam Lai Bắc Vãng - Ep35","link_embed":"https://vip.opstream17.com/share/a42a596fc71e17828440030074d15e74","link_m3u8":"https://vip.opstream17.com/20240223/1194_b5f8d78b/index.m3u8"},{"name":"36","slug":"36","filename":"Nam Lai Bắc Vãng - Ep36","link_embed":"https://vip.opstream17.com/share/0188e8b8b014829e2fa0f430f0a95961","link_m3u8":"https://vip.opstream17.com/20240223/1195_5f04ffe3/index.m3u8"},{"name":"37","slug":"37","filename":"Nam Lai Bắc Vãng - Ep37","link_embed":"https://vip.opstream17.com/share/286674e3082feb7e5afb92777e48821f","link_m3u8":"https://vip.opstream17.com/20240225/1297_f5ae8950/index.m3u8"},{"name":"38","slug":"38","filename":"Nam Lai Bắc Vãng - Ep38","link_embed":"https://vip.opstream17.com/share/a51fb975227d6640e4fe47854476d133","link_m3u8":"https://vip.opstream17.com/20240225/1298_aba3a742/index.m3u8"},{"name":"39","slug":"39","filename":"Nam Lai Bắc Vãng - Ep39","link_embed":"https://vip.opstream17.com/share/4c22bd444899d3b6047a10b20a2f26db","link_m3u8":"https://vip.opstream17.com/20240225/1328_0f785b4a/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>\"Nam Lai Bắc Vãng\" là một bộ phim truyền hình thể loại tình cảm lịch sử do Trịnh Hiểu Long (\"Hậu Cung Chân Hoàn Truyện\") và Lưu Chương Mục (\"Hành Động Phá Băng\") đồng đạo diễn. Phim có sự tham gia của Bạch Kính Đình (\"Tân Xuyên Nhật Thường\"), Kim Thần (\"Được Ăn Cả Ngã Về Không\"), và Đinh Dũng Đại (\"Phong Thần 1: Tam Bộ Khúc\") đảm nhận các vai chính. Vào cuối thập kỷ 1970, trên chuyến tàu hơi nước từ Ninh Dương đến cáp Nhĩ Tân, Uông Tân (do Bạch Kính Đình thủ vai), một thanh niên làm công việc kiểm soát trên tàu, đang chăm chỉ thực hiện nhiệm vụ giữ trật tự giữa đám đông hối hả. Anh nhầm lẫn Mã Khôi (do Đinh Dũng Đại thủ vai), một cựu cảnh sát đường sắt là một kẻ đang chạy trốn, cả hai mở đầu một mối quan hệ thầy trò không mấy dễ dàng. Từ việc ban đầu không thích nhau, đến sự đồng cảm và tôn trọng lẫn nhau, Uông Tân và Mã Khôi đồng lòng chiến đấu tại tuyến đầu của cảnh sát đường sắt.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"233973","season":1,"vote_average":7.1,"vote_count":11},"modified":"2024-02-25T21:43:28.000Z","cast":["Bạch Kính Đình","Đinh Dũng Đại","Kim Thần","Tả Tiểu Thanh","Lưu Quân","Jiang Yan","Hu Ke","Nghê Đại Hồng","Lý Nãi Văn","Ren Zhengbin","Zhang Ruihan","Tang Xu","Vương Kính Tùng","Ngô Việt","Ning Li"],"director":["Xiaolong Zheng","Liu Zhangmu"],"cast_meta":[{"name":"Bạch Kính Đình","name_vi":"Bạch Kính Đình","name_original":"Bai Jingting","tmdb_id":1672869,"profile":"https://image.tmdb.org/t/p/w500/b3kmtLVQtgywB1QKWYHoNLsdqSO.jpg","tmdb_url":"https://www.themoviedb.org/person/1672869"},{"name":"Đinh Dũng Đại","name_vi":"Đinh Dũng Đại","name_original":"Ding Yongdai","tmdb_id":1194773,"profile":"https://image.tmdb.org/t/p/w500/hB1xrY9K0jwhWsbLEbsJl55h98T.jpg","tmdb_url":"https://www.themoviedb.org/person/1194773"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Tả Tiểu Thanh","name_vi":"Tả Tiểu Thanh","name_original":"Zuo Xiaoqing","tmdb_id":143824,"profile":"https://image.tmdb.org/t/p/w500/5Ar0HaoKWpxxItnjY8XVBiNiNxv.jpg","tmdb_url":"https://www.themoviedb.org/person/143824"},{"name":"Lưu Quân","name_vi":"Lưu Quân","name_original":"Liu Jun","tmdb_id":1613668,"profile":"https://image.tmdb.org/t/p/w500/g7xtMSpT23VHplyPYx0rkEI3ZTO.jpg","tmdb_url":"https://www.