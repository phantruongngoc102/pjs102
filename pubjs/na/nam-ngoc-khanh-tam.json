7.com/share/886ad506e0c115cf590d18ebb6c26561","link_m3u8":"https://vip.opstream17.com/20240605/10214_aaf27f66/index.m3u8"}]}],"time":"38 phút/tập","description":"<p>Thiên kim cao quý của thừa tướng, Mai Ngọc Phiến và thần trộm Tiểu Đậu Tử là hai cô gái mang hai tính cách và thân phận khác xa nhau, đã tạo nên bao câu chuyện dở khóc dở cười trong quá trình trao đổi cuộc đời cho nhau. Hãy xem thiên kim thừa tướng Mai Ngọc Phiến sẽ làm thế nào để tán đổ thái tử Nam Cung Diệu của nước Tịch Tây bằng sức hút trái ngược của \"thần trộm bá đạo\". Và liệu thái tử Nam Cung Diệu lạnh lùng lại còn mắc chứng rối loạn ám ảnh cưỡng chế có thể phá vỡ lời tiên đoán của quốc sư Bạch Diệp rằng nước Tịch Tây sẽ bị hủy diệt bởi tình yêu của thái tử, cuối cùng không phụ nước nhà chẳng phụ nàng hay không?</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"254243","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-08T10:57:18.000Z","cast":["Yang Haoming","Trương Miểu Di"],"director":[],"cast_meta":[{"name":"Yang Haoming","name_vi":null,"name_original":"Yang Haoming","tmdb_id":3093627,"profile":"https://image.tmdb.org/t/p/w500/ifNLuYSYXwvUFedLl2dBGSSn6dZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3093627"},{"name":"Trương Miểu Di","name_vi":"Trương Miểu Di","name_original":"Zhang Miaoyi","tmdb_id":3372607,"profile":"https://image.tmdb.org/t/p/w500/bjXOIPJG7dIsFrBiPXMBcJPbMWN.jpg","tmdb_url":"https://www.themoviedb.org/person/3372607"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/na/nam-ngoc-khanh-tam.json"}