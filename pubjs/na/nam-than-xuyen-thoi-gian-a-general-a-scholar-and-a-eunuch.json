"},{"name":"31","slug":"31","filename":"NamThan Xuyen Thoi Gian s01e31","link_embed":"https://vip.opstream15.com/share/9e7dc95c541eb2d8bf26affe1089821f","link_m3u8":"https://vip.opstream15.com/20250102/46730_9e7dc95c/index.m3u8"},{"name":"32","slug":"32","filename":"NamThan Xuyen Thoi Gian s01e32End","link_embed":"https://vip.opstream15.com/share/f6aed15f2be438a3eb192c8ae3a1436c","link_m3u8":"https://vip.opstream15.com/20250102/46731_f6aed15f/index.m3u8"}]}],"time":"60 phút/tập","description":"Nam Thần Xuyên Thời Gian kể về 3 vị nam thần thời nhà Minh là Viên Sùng Hoán, Tả Quang Đầu cùng Lý Tấn Trung đã vô tình vượt thời gian không gian 400 năm đến thời hiện đại. Ban đầu họ vô cùng hoang mang, khi nhìn trên tivi thấy cô minh tinh rất giống Quách Thiến vị thái tử phi mất tích nên 3 người quyết tâm đi tìm và bị Phương Huệ Chi lừa gạt ký vào hợp đồng lao động làm đầu bếp cho nhà hàng của cô ta. Với tài nghệ nấu ăn xuất chúng của Tấn Trung chằng mấy chốc giúp nhà hàng trở nên nổi tiếng . Ba nam thần vẫn cô gắng tìm tung tích của thái tử phi, khi họ đọc sách lịch sữ thì biết được kết cuộc số phận của mình, lúc này thời khắc trở về thời nhà Minh đã đến liệu họ có trở về hay không? Mời các bạn đón xem Nam Thần Xuyên Thời Gian .","tmdb":{"type":"tv","id":"73341","season":1,"vote_average":8,"vote_count":1},"modified":"2025-01-02T18:19:56.000Z","cast":["Tiêu Chính Nam","Grace Wong","Tào Vĩnh Liêm","Hà Quảng Bái","Timothy Cheng Chi-Sing","Kristal Tin Yui-Nei","Khương Đại Vệ","Rebecca Zhu Chenli","Vi Gia Hùng"],"director":[],"cast_meta":[{"name":"Tiêu Chính Nam","name_vi":"Tiêu Chính Nam","name_original":"Edwin Siu","tmdb_id":1059226,"profile":"https://image.tmdb.org/t/p/w500/bPEjnmBPWTZcrWQklkqcT1bUQwb.jpg","tmdb_url":"https://www.themoviedb.org/person/1059226"},{"name":"Grace Wong","name_vi":null,"name_original":"Grace Wong","tmdb_id":1255467,"profile":"https://image.tmdb.org/t/p/w500/2PsYpSJsnof2I7ncBMhd4m1hWta.jpg","tmdb_url":"https://www.themoviedb.org/person/1255467"},{"n