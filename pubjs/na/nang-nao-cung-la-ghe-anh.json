ho phép mình được hẹn hò với cả hai người!?</p>","tmdb":{"type":"tv","id":"113137","season":1,"vote_average":7.2,"vote_count":73},"modified":"2025-06-11T13:36:14.000Z","cast":["Junya Enoki","Ayane Sakura","Azumi Waki","Ayana Taketatsu","Rie Takahashi","Aoi Koga"],"director":[],"cast_meta":[{"name":"Junya Enoki","name_vi":null,"name_original":"Junya Enoki","tmdb_id":1606164,"profile":"https://image.tmdb.org/t/p/w500/vBnNL3Jqy0zkS3ZgsXZmvDM9Dfz.jpg","tmdb_url":"https://www.themoviedb.org/person/1606164"},{"name":"Ayane Sakura","name_vi":null,"name_original":"Ayane Sakura","tmdb_id":992869,"profile":"https://image.tmdb.org/t/p/w500/yPbTmntASE9psPIMhNGU5oo6vIH.jpg","tmdb_url":"https://www.themoviedb.org/person/992869"},{"name":"Azumi Waki","name_vi":null,"name_original":"Azumi Waki","tmdb_id":1647634,"profile":"https://image.tmdb.org/t/p/w500/nxm4DLWv0BOcK2owvAz5yafSAXj.jpg","tmdb_url":"https://www.themoviedb.org/person/1647634"},{"name":"Ayana Taketatsu","name_vi":null,"name_original":"Ayana Taketatsu","tmdb_id":1072776,"profile":"https://image.tmdb.org/t/p/w500/5JyZSnHwP18DIcVSqlGUwccA2WE.jpg","tmdb_url":"https://www.themoviedb.org/person/1072776"},{"name":"Rie Takahashi","name_vi":null,"name_original":"Rie Takahashi","tmdb_id":1492982,"profile":"https://image.tmdb.org/t/p/w500/aeB7z0cBTASdjKOjQriBAO6hYq4.jpg","tmdb_url":"https://www.themoviedb.org/person/1492982"},{"name":"Aoi Koga","name_vi":null,"name_original":"Aoi Koga","tmdb_id":2251986,"profile":"https://image.tmdb.org/t/p/w500/uVpwheVV4aPROyY1toYv3v5HSPD.jpg","tmdb_url":"https://www.themoviedb.org/person/2251986"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/na/nang-nao-cung-la-ghe-anh.json"}