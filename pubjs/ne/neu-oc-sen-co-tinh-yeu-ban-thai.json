k_m3u8":"https://vip.opstream11.com/20230716/45856_f879b8ae/index.m3u8"},{"name":"15","slug":"15","filename":"When a Snail Falls in Love 2023 EP15","link_embed":"https://vip.opstream11.com/share/6726f851d9de8f7d76c143b1e025a9b6","link_m3u8":"https://vip.opstream11.com/20230716/45857_19378b9e/index.m3u8"},{"name":"16","slug":"16","filename":"When a Snail Falls in Love 2023 EP16","link_embed":"https://vip.opstream11.com/share/ce10b99820f24fb3dc769a4f9fb67672","link_m3u8":"https://vip.opstream11.com/20230716/45858_0373f1e6/index.m3u8"},{"name":"17","slug":"17","filename":"When a Snail Falls in Love 2023 EP17","link_embed":"https://vip.opstream11.com/share/dbcdb9431af5649fbbe406021ac2dab2","link_m3u8":"https://vip.opstream11.com/20230722/46002_85dd70b1/index.m3u8"},{"name":"18","slug":"18","filename":"When a Snail Falls in Love 2023 EP18","link_embed":"https://vip.opstream11.com/share/98b8bfc1a714a2b84af2b8a57fd7dc2c","link_m3u8":"https://vip.opstream11.com/20230722/46003_fffc7795/index.m3u8"},{"name":"19","slug":"19","filename":"When a Snail Falls in Love 2023 EP19","link_embed":"https://vip.opstream11.com/share/bdb253b49526c46fc0002d521a469b20","link_m3u8":"https://vip.opstream11.com/20230722/46004_83ec7eef/index.m3u8"},{"name":"20","slug":"20","filename":"When a Snail Falls in Love 2023 EP20","link_embed":"https://vip.opstream11.com/share/ea7f2f9471927458f88b04f4b1832b2a","link_m3u8":"https://vip.opstream11.com/20230722/46005_3457d551/index.m3u8"}]}],"time":"50 phút/tập","description":"<p>Wita là lính mới thiên tài trong nghiên cứu tâm lý. Trong đầu cô ấy như thể có một chiếc máy tính đang vận hành thần tốc, đây chính là năng khiếu bẩm sinh của cô gái ốc sên. Khi mới vào đội cảnh sát, cô phải đối mặt với việc bị đuổi khỏi đội vì thể lực không đạt yêu cầu. Chỉ có cảnh sát Prat giúp được cô ấy. Vì thế Wita nghĩ mọi cách xin Prat nhận cô làm học trò. Prat là đội trưởng Đội điều tra án đặc biệt của Cục cảnh sát, là thần thám hàng đầu trong đội cảnh sát, kinh nghiệm xử lý vụ án phong phú, võ nghệ hơn người. Ban đầu Prat không hề có thiện cảm với Wita, hai người có khác biệt lớn trong quan điểm phá án, nhưng sau khi cả hai bắt tay phá một loạt vụ án, Prat nảy sinh tình cảm với cô học trò thông minh ngây thơ của mình. Nhưng cô gái chậm chạp như “ốc sên” này không nhận được tín hiệu tình yêu. Khi hai người vừa tình cảm vừa phá án, vụ “giết người hàng loạt” yên ắng đã lâu lại xuất hiện, cuối cùng hai người nhận ra tình cảm đối với nhau trong quá trình điều tra nguy hiểm. Song lúc này, vụ án Luge mà Prat canh cánh trong lòng cũng được khởi động lại, cặp tình nhân nắm tay nhau bước vào hành trình tìm hung thủ đầy khó khăn, nguy hiểm.</p>","tmdb":{"type":"tv","id":"229776","season":1,"vote_average":7.2,"vote_count":4},"modified":"2025-03-23T09:41:27.000Z","cast":["Thassapak Hsu","Zuvapit Traipornworakit","Nat Thewphaingam","Klaokaew Sinteppadon","Sirinart Sugandharat","Ratchapong Anomakiti","Pleo Sirisuwan","Rapeewish Sangiamwong","Achita Sikamana","Bhumibhat Thavornsiri","Jamnong Piyachot"],"director":["Songsak Mongkolthong"],"cast_meta":[{"name":"Thassapak Hsu","name_vi":null,"name_original":"Thassapak Hsu","tmdb_id":1910848,"profile":"https://image.tmdb.org/t/p/w500/qhzw3jHkraonN80FukA2yBltLbX.jpg","tmdb_url":"https://www.themoviedb.org/person/1910848"},{"name":"Zuvapit Traipornworakit","name_vi":null,"name_original":"Zuvapit Traipornworakit","tmdb_id":3275004,"profile":"https://image.tmdb.org/t/p/w500/3H3Usa5OAJBs6dO3sG5AL7QGHu6.jpg","tmdb_url":"https://www.themoviedb.org/person/3275004"},{"name":"Nat Thewphaingam","name_vi":null,"name_original":"Nat Thewphaingam","tmdb_id":1259623,"profile":"https://image.tmdb.org/t/p/w500/nfadHM8FpJtgiIhXhW7FyK9Kr1m.jpg","tmdb_url":"https://www.themoviedb.org/person/1259623"},{"name":"Klaokaew Sinteppadon","name_vi":null,"name_original":"Klaokaew Sinteppadon","tmdb_id":1276336,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1276336"},{"name":"Sirinart Sugandharat","name_vi":null,"name_or