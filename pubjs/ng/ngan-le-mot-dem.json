ng Lăng Thất rất thích anh chàng đồng nghiệp Bách Hải (Đặng Luân) nhưng lại không dám bày tỏ tình cảm.</p>","tmdb_id":80374,"cast":[],"director":[],"keywords":[],"tmdb":{"id":80374},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/ngan-le-mot-dem.json"}