.opstream12.com/share/c928d38c5e85028940fbf707e6d20c7d","link_m3u8":"https://vip.opstream12.com/20251111/29957_c928d38c/index.m3u8"},{"name":"15","slug":"15","filename":"Ngạo Thế Tuyệt Kiếm - S01E15 - 1993(1)","link_embed":"https://vip.opstream12.com/share/8b7496b0d4f85eb60f8c70fc494c9983","link_m3u8":"https://vip.opstream12.com/20251111/29958_8b7496b0/index.m3u8"},{"name":"16","slug":"16","filename":"Ngạo Thế Tuyệt Kiếm - S01E16 - 1993(1)","link_embed":"https://vip.opstream12.com/share/a1fdbc71f5161bbdc010209c018587d3","link_m3u8":"https://vip.opstream12.com/20251111/29959_a1fdbc71/index.m3u8"},{"name":"17","slug":"17","filename":"Ngạo Thế Tuyệt Kiếm - S01E17 - 1993(1)","link_embed":"https://vip.opstream12.com/share/7b0e861aacb92e74f2ea443d7c626b53","link_m3u8":"https://vip.opstream12.com/20251111/29960_7b0e861a/index.m3u8"},{"name":"18","slug":"18","filename":"Ngạo Thế Tuyệt Kiếm - S01E18 - 1993(1)","link_embed":"https://vip.opstream12.com/share/3542b3cfea2422668353ada28e15463e","link_m3u8":"https://vip.opstream12.com/20251111/29961_3542b3cf/index.m3u8"},{"name":"19","slug":"19","filename":"Ngạo Thế Tuyệt Kiếm - S01E19 - 1993(1)","link_embed":"https://vip.opstream12.com/share/2d00ce98adf1abcedcf3cecb0859343a","link_m3u8":"https://vip.opstream12.com/20251111/29962_2d00ce98/index.m3u8"},{"name":"20","slug":"20","filename":"Ngạo Thế Tuyệt Kiếm - S01E20 - 1993(1)","link_embed":"https://vip.opstream12.com/share/592b06020a3ed41d1320aba4928daf8d","link_m3u8":"https://vip.opstream12.com/20251111/29963_592b0602/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Cốt truyện xoay quanh cuộc đời của Mộ Dung Kiếm Thu, một thanh niên trẻ tuổi mang trong mình dòng máu vương giả và có một thân thế bí ẩn. Anh là người có tài năng võ thuật xuất chúng nhưng lại sống ẩn dật để tránh xa những tranh chấp giang hồ và cung đình. Kiếm Thu bị cuốn vào một vòng xoáy ân oán giang hồ và tranh chấp quyền lực hoàng tộc khi anh vô tình phát hiện ra thân phận thật sự của mình và phải đối đầu với những thế lực muốn lật đổ ngai vàng. Trong hành trình này, Kiếm Thu gặp gỡ và có mối quan hệ phức tạp với hai cô gái: Thượng Quan Thất Thất và Lăng Tương Nhược. Đồng thời, anh cũng phải đối đầu với Kiếm Ma (Trương Triệu Huy đóng), một nhân vật bí ẩn và có võ công cao cường. Phim khai thác những chủ đề về sự lựa chọn giữa quyền lực và tình yêu, giữa trách nhiệm giang hồ và bổn phận gia tộc.</p>","tmdb":{"type":"tv","id":"109017","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-12T21:03:51.000Z","cast":["Thang Chấn Nghiệp","Strawberry Yeung Yuk-Mui","Tiffany Lau Yuk-Ting"],"director":["Đang cập nhật (Giám chế: Lưu Sĩ Dụ)"],"cast_meta":[{"name":"Thang Chấn Nghiệp","name_vi":"Thang Chấn Nghiệp","name_original":"Kent Tong Chun-Yip","tmdb_id":1254216,"profile":"https://image.tmdb.org/t/p/w500/r6p6QSyynm0b1WZ5H9PCh5jR9sy.jpg","tmdb_url":"https://www.themoviedb.org/person/1254216"},{"name":"Strawberry Yeung Yuk-Mui","name_vi":null,"name_original":"Strawberry Yeung Yuk-Mui","tmdb_id":551898,"profile":"https://image.tmdb.org/t/p/w500/qYe4jZdOkHnNINlSNC7wXaD6m7V.jpg","tmdb_url":"https://www.themoviedb.org/person/551898"},{"name":"Tiffany Lau Yuk-Ting","name_vi":null,"name_original":"Tiffany Lau Yuk-Ting","tmdb_id":1358812,"profile":"https://image.tmdb.org/t/p/w500/zi7jiT5rpqnhwJRjx8TMnyV0zA7.jpg","tmdb_url":"https://www.themoviedb.org/person/1358812"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ng/ngao-the-tuyet-kiem.json"}