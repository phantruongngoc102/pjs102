.com/20220612/20310_1425b1c8/index.m3u8"},{"name":"20","slug":"20","filename":"ngay-xua-ngay-xua-phan-1-once-upon-a-time-season-1-tap-20","link_embed":"https://vip.opstream15.com/share/8c8ee26d59b77a94dc6747a41e7c3af0","link_m3u8":"https://vip.opstream15.com/20220612/20311_48f7a4e7/index.m3u8"},{"name":"21","slug":"21","filename":"ngay-xua-ngay-xua-phan-1-once-upon-a-time-season-1-tap-21","link_embed":"https://vip.opstream15.com/share/ca9f9c4764430f980dca8d70e29d8e5e","link_m3u8":"https://vip.opstream15.com/20220612/20313_b12de6c3/index.m3u8"},{"name":"22","slug":"22","filename":"ngay-xua-ngay-xua-phan-1-once-upon-a-time-season-1-tap-22","link_embed":"https://vip.opstream15.com/share/c7af4a506117907c565f6ffe58bec4f1","link_m3u8":"https://vip.opstream15.com/20220612/20315_35c14b81/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim kể về cô gái làm nghề thu hồi nợ 28 tuổi Emma Swan bị sốc khi Henry, đứa con trai được cô cho đi 10 năm về trước vì không có khả năng nuôi nấng, tuyệt vọng đến nhờ cô giúp đỡ. Henry tin tằng, Emma là con gái thất lạc của Bạch Tuyết và Hoàng Tử Bạch Mã, người được gửi đi khỏi rừng ma thuật để tránh lời nguyền của mụ hoàng hậu độc ác. Emma không tin vào những câu chuyện của Henry, nhưng cô nhận thấy rằng, StoryBrooke, Maine, thị trấn của Henry, có thể ẩn giấu một bí mật lớn hơn những gì mà người ta đang thấy. Bởi vì StoryBrooke là nơi mà tất cả các nhân vật cổ tích kinh điển bị đóng băng trong thời gian và mất hết những ký ức trước đây - bao gồm cả hoàng hậu độc ác, giờ là Regina, thị trưởng của StoryBrooke và là mẹ nuôi của Henry...</p>","tmdb":{"type":"tv","id":"39272","season":1,"vote_average":7.385,"vote_count":2421},"modified":"2022-06-12T18:12:44.000Z","cast":["Lana Parrilla","Colin O'Donoghue","Robert Carlyle","Gabrielle Anwar","Dania Ramirez","Mekia Cox","Andrew J. West","Alison Fernández"],"director":[],"cast_meta":[{"name":"Lana Parrilla","name_vi":null,"name_original":"Lana Parrilla","tmdb_id":177231,"profile":"https://ima