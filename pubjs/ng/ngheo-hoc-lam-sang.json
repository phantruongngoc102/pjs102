b21b3f9c62b1857f4a0e81","link_m3u8":"https://vip.opstream16.com/20230323/33344_65092a88/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/b4315f87bc8e2180eb73465d8f5a5cd5","link_m3u8":"https://vip.opstream16.com/20230323/33345_b7ba4093/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/dcba1d5501221f3f36e1c123974f7ca7","link_m3u8":"https://vip.opstream16.com/20230323/33346_3914eea1/index.m3u8"}]}],"description":"<p>Tại Hồng Kông, việc sở hữu một căn nhà là vô cùng khó, có người dành cả đời cũng không thể. Năm 2008 xảy ra khủng hoảng tài chính, Xa Chí Minh (do Lâm Mẫn Thông đóng) phải bán căn nhà lớn. Sau 14 năm, dù Minh làm cửa hàng trưởng ở siêu thị, tiết kiệm từng đồng nhưng vẫn chưa mua được nhà, chỉ có thể thuê nhà của ông chủ. Vợ của Minh là Mạc Văn Tuệ (do Giang Mỹ Nghi đóng) cũng luôn mong ước có một căn nhà. Tuệ làm công theo giờ tại nhà giàu có, nên đã cùng gia đình mình liên tục chụp ảnh ở nơi đây rồi đăng lên mạng xã hội khoe khoang.</p>","tmdb_id":209736,"cast":["Andrew Lam","Bào Khởi Tịnh","Giang Mỹ Nghi","Quách Bách Nghiên","Yuki Law","Bella Lam Wing Tung","Đinh Tử Lãng","Viên Văn Kiệt","Heidi Chu","King Lam","Martin Lau Ka-Chung","Dương Chứng Hoa","Carmaney Wong","Andy Shiu Cheuk-Yiu","Kitterick Yiu"],"director":["Kwan Shu-ming"],"keywords":[],"tmdb":{"type":"tv","id":"209736","season":1,"vote_average":10,"vote_count":2},"cast_meta":[{"name":"Andrew Lam","name_vi":null,"name_original":"Andrew Lam","tmdb_id":1467340,"profile":"https://image.tmdb.org/t/p/w500/idJYl0WIo0gHjVd3BLmEaQsmb5y.jpg","tmdb_url":"https://www.themoviedb.org/person/1467340"},{"name":"Bào Khởi Tịnh","name_vi":"Bào Khởi Tịnh","name_original":"Nina Paw Hei-Ching","tmdb_id":1035980,"profile":"https://image.tmdb.org/t/p/w500/wQFuXG8F4LIMcO2vtH5IxBGE5wx.jpg","tmdb_url":"https://www.themoviedb.org/person/1035980"},{"name":"Giang Mỹ Nghi","name_vi":"Giang Mỹ Nghi","name_original":"Elena Kong Mei-Yee","tmdb_id":236195,"pro