ream12.com/share/cc18000b67cb813af111404b90b21019","link_m3u8":"https://vip.opstream12.com/20251110/29819_cc18000b/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/ec450d5fa45d2aefb861309e1f063b78","link_m3u8":"https://vip.opstream12.com/20251110/29820_ec450d5f/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/4744015f38ee03ef7f62f60a5017907c","link_m3u8":"https://vip.opstream12.com/20251110/29821_4744015f/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/8b42d3eeb4da1f29ee08dedd7855a0ed","link_m3u8":"https://vip.opstream12.com/20251110/29822_8b42d3ee/index.m3u8"}]}],"description":"<p>Thập niên 30, tình hình chính trị Quảng Châu gặp nhiều biến động, tệ nạn xã hội mặc sức hoành hành. Do thị trường kinh doanh á phiện thu lợi béo bở, chính phủ đương thời quyết định thành lập cục cấm thuốc phiện, mang danh nghĩa cấm nhưng thực chất là công khai tiếp tay cho việc kinh doanh ngầm mặt hàng này. Trịnh Cửu Muội (do Đặng Tuỵ Văn đóng) là con gái của một trùm bán á phiện và trở về để tiếp quản việc kinh doanh của gia đình. Cảnh sát trưởng Lưu Tỉnh (do Lê Diệu Tường đóng) và Cửu Muội là hai nhân vật chính, đối đầu với nhau nhưng sau đó phát triển mối quan hệ tình cảm. Khi Quảng Châu bị chiếm đóng bởi quân Nhật, Cửu Muội bị hãm hại và Lưu Tỉnh cùng cô vượt qua những khó khăn đen tối nhất của cuộc đời.</p>","tmdb_id":33667,"cast":["Lê Diệu Tường","Đặng Tụy Văn","Huỳnh Hạo Nhiên","Ngao Gia Niên","Hồ Định Hân","Nhạc Hoa","Mạch Trường Thanh","Trần Pháp Lai","Susan Tse Suet-Sum","Ben Wong Chi-Yin","Huệ Anh Hồng","Quách Phong","Trương Tùng Chi","Lỗ Chấn Thuận","Giang Mỹ Nghi"],"director":["Lý Thiêm Thắng"],"keywords":[],"tmdb":{"type":"tv","id":"33667","season":1,"vote_average":8.9,"vote_count":9},"cast_meta":[{"name":"Lê Diệu Tường","name_vi":"Lê Diệu Tường","name_original":"Wayne Lai Yiu-Cheung","tmdb_id":123654,"profile":"https://image.tmdb.org/t/p/w500/qm3knPxzkZPgq2SVo1ZTru7M