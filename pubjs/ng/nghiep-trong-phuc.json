/index.m3u8"},{"name":"44A","slug":"44a","filename":"nghiep-trong-phuc-buang-bai-bun-tap-44A","link_embed":"https://vip.opstream11.com/share/d42f619034d73616dabde1ed098739c2","link_m3u8":"https://vip.opstream11.com/20220615/30705_7255a2fb/index.m3u8"},{"name":"44B","slug":"44b","filename":"nghiep-trong-phuc-buang-bai-bun-tap-44B","link_embed":"https://vip.opstream11.com/share/af6e8730844faa627625a6c3fa98f0fc","link_m3u8":"https://vip.opstream11.com/20220615/30706_95811adf/index.m3u8"}]}],"time":"60 phút / tập","description":"<p>Dok Rak từ cô gái bình thường, bị gia đình gán nợ và trở thành vợ bé của ông chủ nhà giàu. Bước chân vào hào môn, cuộc đời cô bắt đầu là chuỗi ngày tranh giành tình yêu và tài sản. Kể cả phải chà đạp lên người khác hay làm người khác tổn thương, thì Dok Rak cũng sẵn sàng làm để đạt được mục đích của mình. Đâu sẽ là cái giá mà Dok Rak phải trả cho những gì mình gây ra?</p>","tmdb":{"type":"tv","id":"210303","season":1,"vote_average":0,"vote_count":0},"modified":"2025-06-01T11:16:39.000Z","cast":["Kamolchanok Komoltithi","Sirilak Pongchoke","Khets Thunthup","Anuchit Sapanpong","Joon Cholrudee Amornluk","Thitiwat Ritprasert","Sarut Vichitrananda","Dilok Thongwattana","Savitree Samipak","Usanee Wattana","Sukavin Keawpikul","Chartchai Ngamsan"],"director":[],"cast_meta":[{"name":"Kamolchanok Komoltithi","name_vi":null,"name_original":"Kamolchanok Komoltithi","tmdb_id":4203201,"profile":"https://image.tmdb.org/t/p/w500/cGy0VN8dVB3zM0AipbKqkfy7gNP.jpg","tmdb_url":"https://www.themoviedb.org/person/4203201"},{"name":"Sirilak Pongchoke","name_vi":null,"name_original":"Sirilak Pongchoke","tmdb_id":3980470,"profile":"https://image.tmdb.org/t/p/w500/i8puYOMBFJtPTjCjxOsz5vOV6i.jpg","tmdb_url":"https://www.themoviedb.org/person/3980470"},{"name":"Khets Thunthup","name_vi":null,"name_original":"Khets Thunthup","tmdb_id":1352701,"profile":"https://image.tmdb.org/t/p/w500/yzClKZJZ9gsZ2zgmp2srVQ59uaC.jpg","tmdb_url":"https://www.themoviedb.org/person/1352701"}