//vip.opstream15.com/20220503/10917_41abf852/index.m3u8"},{"name":"41","slug":"41","filename":"ngoc-lau-xuan-thuyet-minh-song-of-youth-tap-41","link_embed":"https://vip.opstream15.com/share/447b0408b80078338810051bb38b177f","link_m3u8":"https://vip.opstream15.com/20220503/10919_d3078e7d/index.m3u8"},{"name":"42","slug":"42","filename":"ngoc-lau-xuan-thuyet-minh-song-of-youth-tap-42","link_embed":"https://vip.opstream15.com/share/9a4d6e8685bd057e4f68930bd7c8ecc0","link_m3u8":"https://vip.opstream15.com/20220503/10921_195cbbd6/index.m3u8"},{"name":"43","slug":"43","filename":"ngoc-lau-xuan-thuyet-minh-song-of-youth-tap-43","link_embed":"https://vip.opstream15.com/share/1e04b969bf040acd252e1faafb51f829","link_m3u8":"https://vip.opstream15.com/20220503/10923_4bbab5a9/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim lấy bối cảnh triều đại nhà Minh vào thời vua Khánh Long, Lâm gia bị vu oan là một quan tham và buộc tội chết, tiểu thư Lâm Thiếu Xuân (Bạch Lộc) rơi vào cảnh tan cửa nát nhà, người thân không còn. Để có thể tiếp tục sống, Lâm Thiếu Xuân đã phải theo một gánh hát mãi nghệ để học kịch. Trong một buổi biểu diễn, Thiếu Xuân đã gặp thiếu gia giàu có Tôn Ngọc Lâu (Vương Nhất Triết) và thiếu gia nhà họ Tôn đã yêu Thiếu Xuân ngay từ cái nhìn đầu tiên.</p><p>Lâm Thiếu Xuân quyết minh oan cho cha nên cô đã giả trang thành nam để có thể tham gia thi cử nhưng lại không không thể vượt qua được vì phải nghiệm thân. Tôn Ngọc Lâu thấy vậy nên luôn âm thầm tìm cách giúp đỡ cô, cuối cùng mối oan ức của cha cô đã được hóa giải. Từ đó tình cảm của hai người thêm bền chặt nhưng lại nhận được sự phản đối từ phía Tôn gia vì Tôn gia biết được thân phận của Lâm Thiếu Xuân. Tôn Ngọc Lâu cương quyết không từ bỏ mối lương duyên này.</p><p>Lâm Thiếu Xuân là một phụ nữ kiên cường, chỉ trong một thời gian ngắn cô đã trở thành một nữ thương nhân thành đạt. Đúng lúc này thì Tôn gia lâm vào cảnh sa sút, Thiếu Xuân đã không ngần ngại gả vào Tôn gia, tình cảm thêm bền chặt với Tôn Ngọc Lâu. Sau khi kết hôn, một Thiếu Xuân linh hoạt và khéo léo đã hòa giải được các mối quan hệ trong gia đình chồng, nhận được sự yêu mến của mọi người. Nhưng khi giải quyết được những khúc mắc này thì cô lại phát hiện người thực sự tham ô trong vụ án của cha cô năm xưa chính là bố chồng mình – Tôn Tốn. Thiếu Xuân và Tôn Ngọc Lâu sẽ đối diện và giải quyết sự thật này như thế nào?</p>","tmdb":{"type":"tv","id":"129782","season":1,"vote_average":7.1,"vote_count":7},"modified":"2022-07-03T02:00:04.000Z","cast":["Bạch Lộc","Vương Nhất Triết","Kim Thần","Zheng Qiuhong","Lý Gia Kỳ","He Lei","Xương Long","Lưu Mẫn","Trịnh Khải","Hu Xiaoting","Zhu Zhiling","Liang Yongni"],"director":["Bai Yunmo"],"cast_meta":[{"name":"Bạch Lộc","name_vi":"Bạch Lộc","name_original":"Bai Lu","tmdb_id":1879666,"profile":"https://image.tmdb.org/t/p/w500/aRcUVDRO2wewQe0NXJ0RfzSgvUa.jpg","tmdb_url":"https://www.themoviedb.org/person/1879666"},{"name":"Vương Nhất Triết","name_vi":"Vương Nhất Triết","name_original":"Wang Yizhe","tmdb_id":2500629,"profile":"https://image.tmdb.org/t/p/w500/9iZnc0JBMzsZW8VbRqfXA3ijru1.jpg","tmdb_url":"https://www.themoviedb.org/person/2500629"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Zheng Qiuhong","name_vi":null,"name_original":"Zheng Qiuhong","tmdb_id":2247235,"profile":"https://image.tmdb.org/t/p/w500/dqK5vy1976ftNN2f0S3TEYY63Nq.jpg","tmdb_url":"https://www.themoviedb.org/person/2247235"},{"name":"Lý Gia Kỳ","name_vi":"Lý Gia Kỳ","name_original":"Jackie Li","tmdb_id":2796119,"profile":"https://image.tmdb.org/t/p/w500/wlwqQJSsTTzEks2HWgjCTRiD99Q.jpg","tmdb_url":"https://www.themoviedb.org/person/2796119"},{"name":"He Lei","name_vi":null,"name_original":"He Lei","tmdb_id":2870984,"profile":"https://image.tmdb.org/t/p/w500/y1tozJAoVBHWn1U4YCNNArVodxM.jpg","tmdb_url":"https://www.themovi