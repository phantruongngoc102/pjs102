com/20230818/46633_8e532152/index.m3u8"}]}],"description":"Ngôi Trường Bí Ẩn - Homeschool xoay quanh một ngôi trường nội trú nằm giữa một khu rừng hẻo lánh. Ba năm một lần, trường chọn những học sinh mới đáp ứng các tiêu chí của họ, mỗi thế hệ bao gồm không quá mười ba học sinh. Các sinh viên dành tổng cộng ba năm tại trường. Ngôi trường nhằm thu hút những sinh viên giàu có với chương trình giảng dạy độc đáo và tất cả những tiện nghi như ở nhà. Tuy nhiên, Home School có vẻ giống một nhà tù hơn là một trường học với những quy tắc nghiêm ngặt và sự cô lập hoàn toàn.","tmdb_id":223824,"cast":["Kay Lertsittichai","Hirunkit Changkham","Chayapol Jutamas","Chayakorn Jutamas","Atthaphan Phunsawat","Jirawat Sutivanichsak","Rachanun Mahawan","Ramida Jiranorraphat","Wachirawit Ruangwiwat","Juthapich Indrajundra","Pattranite Limpatiyakorn","Benyapa Jeenprasom","Sureeyares Yakares","Thanathat Tanjararak","Noppol Gomarachun"],"director":["Fon Kanittha Kwunyoo"],"keywords":[],"tmdb":{"type":"tv","id":"223824","season":1,"vote_average":8.6,"vote_count":29},"cast_meta":[{"name":"Kay Lertsittichai","name_vi":null,"name_original":"Kay Lertsittichai","tmdb_id":2636836,"profile":"https://image.tmdb.org/t/p/w500/nraE2K8vG6UyeQepKeOKbPiP4ls.jpg","tmdb_url":"https://www.themoviedb.org/person/2636836"},{"name":"Hirunkit Changkham","name_vi":null,"name_original":"Hirunkit Changkham","tmdb_id":3335144,"profile":"https://image.tmdb.org/t/p/w500/sboNGsJqA2fLzeIzTHZBBrrphUc.jpg","tmdb_url":"https://www.themoviedb.org/person/3335144"},{"name":"Chayapol Jutamas","name_vi":null,"name_original":"Chayapol Jutamas","tmdb_id":2768165,"profile":"https://image.tmdb.org/t/p/w500/c5KegksWK57mSYQGccwMeqpmGNn.jpg","tmdb_url":"https://www.themoviedb.org/person/2768165"},{"name":"Chayakorn Jutamas","name_vi":null,"name_original":"Chayakorn Jutamas","tmdb_id":2729028,"profile":"https://image.tmdb.org/t/p/w500/zXZeUQR0NaCHcnEEOIDYDMgAZZX.jpg","tmdb_url":"https://www.themoviedb.org/person/2729028"},{"name":"Attha