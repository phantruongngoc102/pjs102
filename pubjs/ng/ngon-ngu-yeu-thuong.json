 dần. Một thế giới mới đã mở ra cho cả Yuki và Itsuomi khi họ bắt đầu tìm hiểu về cuộc sống của nhau.","tmdb":{"type":"tv","id":"230059","season":1,"vote_average":7.979,"vote_count":97},"modified":"2024-03-16T21:49:00.000Z","cast":["Sumire Morohoshi","Yu Miyazaki","Takeo Otsuka","Kaede Hondo","Ryota Osaka","Nao Toyama","Tasuku Hatanaka"],"director":[],"cast_meta":[{"name":"Sumire Morohoshi","name_vi":null,"name_original":"Sumire Morohoshi","tmdb_id":1254135,"profile":"https://image.tmdb.org/t/p/w500/6AoZkW7NxgsWXkoCkTGDSgFcyao.jpg","tmdb_url":"https://www.themoviedb.org/person/1254135"},{"name":"Yu Miyazaki","name_vi":null,"name_original":"Yu Miyazaki","tmdb_id":2689189,"profile":"https://image.tmdb.org/t/p/w500/pUoMRla6E1MaQVZ8Z6CEX1oWzCU.jpg","tmdb_url":"https://www.themoviedb.org/person/2689189"},{"name":"Takeo Otsuka","name_vi":null,"name_original":"Takeo Otsuka","tmdb_id":1279666,"profile":"https://image.tmdb.org/t/p/w500/wqeAMR0HOGUPBXz0TCNxDR51cQy.jpg","tmdb_url":"https://www.themoviedb.org/person/1279666"},{"name":"Kaede Hondo","name_vi":null,"name_original":"Kaede Hondo","tmdb_id":1779027,"profile":"https://image.tmdb.org/t/p/w500/11BcHnuJYrOZhIftgUiQqfm7TK6.jpg","tmdb_url":"https://www.themoviedb.org/person/1779027"},{"name":"Ryota Osaka","name_vi":null,"name_original":"Ryota Osaka","tmdb_id":1324468,"profile":"https://image.tmdb.org/t/p/w500/d2TGy8Qkxe90tGDr9MCXFGkhbPl.jpg","tmdb_url":"https://www.themoviedb.org/person/1324468"},{"name":"Nao Toyama","name_vi":null,"name_original":"Nao Toyama","tmdb_id":1168909,"profile":"https://image.tmdb.org/t/p/w500/6WJDd1z946yFfZBgpC7dWi0FyQw.jpg","tmdb_url":"https://www.themoviedb.org/person/1168909"},{"name":"Tasuku Hatanaka","name_vi":null,"name_original":"Tasuku Hatanaka","tmdb_id":1256915,"profile":"https://image.tmdb.org/t/p/w500/xPDqoxAia1ShoVC2aMS2ZDPDWzG.jpg","tmdb_url":"https://www.themoviedb.org/person/1256915"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@ma