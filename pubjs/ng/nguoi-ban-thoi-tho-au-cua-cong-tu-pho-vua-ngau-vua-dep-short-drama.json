a sự hợp tác và cuối cùng tìm thấy hạnh phúc bên nhau.","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-ban-thoi-tho-au-cua-cong-tu-pho-vua-ngau-vua-dep-short-drama.json","tmdb_checked":false}