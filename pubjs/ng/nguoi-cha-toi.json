0220406/10611_9bd31094/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/5b708c065dfab38528050a84d852bf13","link_m3u8":"https://vip.opstream11.com/20220406/10610_ece54b21/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/b5dd0e4351a65a23e2a13bf0483fe8cc","link_m3u8":"https://vip.opstream11.com/20220406/10612_9987cba9/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/e69ccd834405b002add6e2ff6664496d","link_m3u8":"https://vip.opstream11.com/20220406/10613_18351eb2/index.m3u8"}]}],"description":"<p>Phim là câu chuyện kể về cuộc đấu tranh của một người đàn ông trung niên, người đưa ra quyết định trở thành “kẻ xấu” để trở thành một người cha tốt. Jang Hyuk sẽ đảm nhận vai diễn Yoo Ji Chul, một cựu vô địch quyền anh bất khả chiến bại, cũng là một người chồng và người cha. Cuộc đời của anh bất ngờ trở thành địa ngục sau một biến cố, Yoo Ji Chul phải vật lộn với cuộc sống hàng ngày cho đến khi anh uống phải một viên thuốc bí ẩn. Viên thuốc này đã khiến anh thay đổi, giúp anh quay trở lại với hào quang của một tay đấm quyền Anh huyền thoại.​</p>","tmdb_id":82464,"cast":[],"director":[],"keywords":[],"tmdb":{"id":82464},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-cha-toi.json"}