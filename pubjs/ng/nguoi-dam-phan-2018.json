tream11.com/share/a714b6bada5e4ad469abf003c9d2c3d8","link_m3u8":"https://vip.opstream11.com/20220619/31581_fe2696a0/index.m3u8"}]}],"time":"45 phút","description":"<p>Người Đàm Phán xoay quanh một nhà đàm phán lạnh lùng, cứng rắn tên Đồng Vi (Dương Mịch). Trong một buổi đàm phán dự án thương mại, Đồng Vi gặp gỡ Tạ Hiểu Phi (Hoàng Tử Thao). Tưởng anh chỉ là một người như mình, cô không ngờ rằng Tạ Hiểu Phi là người thừa kế duy nhất của một tập đoàn lớn. Hai người thường xuyên xảy ra tranh cãi gay gắt. Tuy nhiên, sự khác biệt lại trở thành điểm kết nối để Đồng Vi cùng Tạ Hiểu Phi rơi vào lưới tình.</p>","tmdb":{"type":"tv","id":"72977","season":1,"vote_average":6.9,"vote_count":4},"modified":"2022-06-19T14:06:42.000Z","cast":["Dương Mịch","Huang Zitao","Quách Phẩm Siêu","Mao Lâm Lâm","Chúc Tự Đan","Lai Nghệ","Lý Đông Hằng","Li Tingting","Yu Yonghai","Zhu Yaying"],"director":["Lưu Nhất Chí"],"cast_meta":[{"name":"Dương Mịch","name_vi":"Dương Mịch","name_original":"Yang Mi","tmdb_id":572043,"profile":"https://image.tmdb.org/t/p/w500/lPQ9RgOj5hY5AYRJ8G1CedjdCGz.jpg","tmdb_url":"https://www.themoviedb.org/person/572043"},{"name":"Huang Zitao","name_vi":null,"name_original":"Huang Zitao","tmdb_id":1468979,"profile":"https://image.tmdb.org/t/p/w500/m2Ivm5otWKbDtW2e6SgxBL2dS8t.jpg","tmdb_url":"https://www.themoviedb.org/person/1468979"},{"name":"Quách Phẩm Siêu","name_vi":"Quách Phẩm Siêu","name_original":"Dylan Kuo","tmdb_id":128040,"profile":"https://image.tmdb.org/t/p/w500/qQxjcDG5qJhn7Ril2JVEcEN1Wej.jpg","tmdb_url":"https://www.themoviedb.org/person/128040"},{"name":"Mao Lâm Lâm","name_vi":"Mao Lâm Lâm","name_original":"Nikita Mao","tmdb_id":1518223,"profile":"https://image.tmdb.org/t/p/w500/3dAutF22fOmde3BZag3VbRWTodi.jpg","tmdb_url":"https://www.themoviedb.org/person/1518223"},{"name":"Chúc Tự Đan","name_vi":"Chúc Tự Đan","name_original":"Zhu Xudan","tmdb_id":1838200,"profile":"https://image.tmdb.org/t/p/w500/bfqvBRuDi56O2WB1Hvg6IPeITlm.jpg","tmdb_url":"https://www.the