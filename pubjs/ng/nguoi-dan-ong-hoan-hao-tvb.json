14.com/20230131/30038_47230295/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream14.com/share/eb8957cfa91a0992d3570d7fac93cb8e","link_m3u8":"https://vip.opstream14.com/20230131/30039_e0becbb9/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/08388373d6f6fe7435ad0e42297111ec","link_m3u8":"https://vip.opstream14.com/20230131/30040_51583db0/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/a83d567f09e542dbe66a7e1a9430504a","link_m3u8":"https://vip.opstream14.com/20230131/30041_cdcd45a8/index.m3u8"}]}],"description":"<p>Mã Đức Chung từng làm vệ sĩ cho các nhân vật quan trọng trước khi làm diễn viên. Trong phim “Người đàn ông hoàn hảo”, Mã Đức Chung có dịp thể hiện tài năng làm vệ sĩ của mình. Dương Nhật Chính (do Mã Đức Chung đóng) từng là thành viên của G4 và đội Phi Hổ, là nhân tài trong giới vệ sĩ. Anh được bạn thân Hạ Trung Thu (do Từ Vinh đóng) giới thiệu làm vệ sĩ cho đại gia Tưởng Định Thiên (do Trương Quốc Cường đóng). Với tính cách lạnh lùng, các đồng nghiệp trong công ty vệ sĩ đều không thích Chính. Chính gặp rắc rối với Lại Hoằng Trí (do Âu Thoại Vĩ đóng), La Thiếu Na (do Dương Trác Na đóng) và Phù Tuấn (do Tào Vĩnh Liêm đóng). Mặt khác, Chính không có lòng tin với hôn nhân, anh không thích sự ràng buộc. Ngay cả cô út của Chính là Dương Phi Vân (do Trần Tự Dao đóng) cũng chịu thua tính cách này của anh.</p>","tmdb_id":214327,"cast":["Joe Ma Tak-Chung","Lý Giai Tâm","Tào Vĩnh Liêm","Yoyo Chen Chi-Yiu","Ngô Vĩ Hào","Tsui Wing","Triệu Hi Lạc","Griselda Yeung","Jack Wu","Trương Quốc Cường","Âu Thụy Vỹ","Edith Au","Phùng Tố Ba","Fanny Ip","Niklas Lam"],"director":["Terrence Leung King-yiu"],"keywords":[],"tmdb":{"type":"tv","id":"214327","season":1,"vote_average":10,"vote_count":1},"cast_meta":[{"name":"Joe Ma Tak-Chung","name_vi":null,"name_original":"Joe Ma Tak-Chung","tmdb_id":227805,"profile":"https://image.tmdb.org/t/p/w500/oK0d0kFPwSNKtlcBNbDqt6ExVYa.jpg","tmdb_url":"