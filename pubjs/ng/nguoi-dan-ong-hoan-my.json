12.com/share/650bbf5d3ffa2b7d9b8b36d62d667ced","link_m3u8":"https://vip.opstream12.com/20251118/30352_650bbf5d/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/6a12f449790ed7be96d77aa4c7d9c1c1","link_m3u8":"https://vip.opstream12.com/20251118/30353_6a12f449/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/5231f53ee04409d2d652039077794382","link_m3u8":"https://vip.opstream12.com/20251118/30354_5231f53e/index.m3u8"}]}],"description":"<p>Bác sĩ Trương Thuận Quân là một bác sĩ thẩm mỹ nổi tiếng, có kỹ năng xuất sắc và luôn tự hào về khả năng tạo nên vẻ đẹp hoàn hảo cho bệnh nhân. Tuy nhiên, sau một tai nạn, anh không còn có thể phẫu thuật được nữa và quyết định rời bỏ ngành y. Trong thời gian đó, anh gặp Lý Vân Dư – một phụ nữ thông minh, mạnh mẽ, có cái nhìn rất khác về cái đẹp và hạnh phúc.</p><p>Mối quan hệ giữa hai người ban đầu đầy mâu thuẫn nhưng dần dần nảy sinh tình cảm. Phim khám phá khái niệm “người đàn ông hoàn hảo” và cho thấy rằng hạnh phúc không nằm ở ngoại hình mà ở sự thấu hiểu và chấp nhận lẫn nhau.</p>","tmdb_id":80161,"cast":["Fan Hsiao-Fan","Guo Chris","Pink Yang","Calvin Lee","Tien Hsin","Weber Yang"],"director":["Lưu Quang Huy"],"keywords":[],"tmdb":{"type":"tv","id":"80161","season":1,"vote_average":6.5,"vote_count":2},"cast_meta":[{"name":"Fan Hsiao-Fan","name_vi":null,"name_original":"Fan Hsiao-Fan","tmdb_id":2063441,"profile":"https://image.tmdb.org/t/p/w500/byOH0y1DsZpBpjPOLmc6lSZh0m6.jpg","tmdb_url":"https://www.themoviedb.org/person/2063441"},{"name":"Guo Chris","name_vi":null,"name_original":"Guo Chris","tmdb_id":2063442,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2063442"},{"name":"Pink Yang","name_vi":null,"name_original":"Pink Yang","tmdb_id":1179173,"profile":"https://image.tmdb.org/t/p/w500/6NHAp1ERfuGcRY9siZTYClMOFMS.jpg","tmdb_url":"https://www.themoviedb.org/person/1179173"},{"name":"Calvin Lee","name_vi":null,"name_original":"Calvin Lee","tmdb_