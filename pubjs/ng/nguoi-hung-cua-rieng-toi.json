.com/share/b9937273f2b46912b56d09c8faa7da23","link_m3u8":"https://vip.opstream15.com/20220426/8635_c948cec2/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/44821f701cc30140043698441975b284","link_m3u8":"https://vip.opstream15.com/20220426/8637_4cf186c0/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream15.com/share/6f780a0221033e49ffec2199ba1d74b2","link_m3u8":"https://vip.opstream15.com/20220426/8636_35230c7b/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream15.com/share/e3978ba7ecdecc63be5f5bf0281a0ed6","link_m3u8":"https://vip.opstream15.com/20220426/8639_e9bfd782/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream15.com/share/5c376f6d20024c7448dcc13bdf090086","link_m3u8":"https://vip.opstream15.com/20220426/8638_c739dcac/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream15.com/share/0912d0f15f1394268c66639e39b26215","link_m3u8":"https://vip.opstream15.com/20220426/8642_7e759e06/index.m3u8"}]}],"description":"<p>Vì đánh mất nên người ta mới khát khao \"nơi mình thuộc về\" và \"sự gắn kết\". Masahiro luôn ghét \"anh hùng\" vì họ chưa bao giờ xuất hiện trước mắt cậu. Và rồi tên đầu gấu ấy gặp gỡ với \"Kẻ giết gấu\" Kousuke. Masahiro luôn khát khao một nơi mà cậu thuộc về, còn Kousuke luôn muốn giang rộng đôi tay dịu dàng. Cảm xúc rực rỡ ẩn chứa trong sự ấm áp họ dành cho nhau. Phim còn kể về câu chuyện giữa Kensuke và Hasekura. Tuyệt giao vì đã không giữ được lời hứa mãi bên nhau, nhưng cả hai đều không thể quên và luôn muốn gặp lại nhau một lần nữa. Những tâm hồn lướt qua nhau và trở nên gắn kết.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-hung-cua-rieng-toi.json"}