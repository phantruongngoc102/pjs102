0cd63626","link_m3u8":"https://vip.opstream17.com/20240218/848_f4845a9c/index.m3u8"},{"name":"13","slug":"13","filename":"Người hùng tia chớp_S09E13_Thế giới mới_ Phần 4","link_embed":"https://vip.opstream17.com/share/fe8c15fed5f808006ce95eddb7366e35","link_m3u8":"https://vip.opstream17.com/20240218/849_9d5d0eb9/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Sau khi đánh bại Reverse Flash một lần và mãi mãi, Barry Allen và Iris West-Allen đang kết nối lại và ngày càng thân thiết hơn bao giờ hết. Nhưng khi một nhóm Rogue chết chóc tràn vào Thành phố Trung tâm do một mối đe dọa mới mạnh mẽ dẫn đầu, The Flash và nhóm của anh một lần nữa phải bất chấp những khó khăn bất khả thi để cứu lấy thế giới. Nhưng khi The Rogues bị đánh bại, một kẻ thù nguy hiểm mới trỗi dậy thách thức di sản anh hùng của Barry Allen. Và trong trận chiến vĩ đại nhất từ trước đến nay, Barry và Team Flash sẽ bị đẩy đến giới hạn của mình để cứu Central City lần cuối.</p>","tmdb":{"type":"tv","id":"60735","season":9,"vote_average":7.767,"vote_count":11489},"modified":"2024-02-18T21:35:33.000Z","cast":["Grant Gustin","Candice Patton","Danielle Panabaker","Danielle Nicolet","Kayla Compton","Brandon McKnight","Jon Cor"],"director":[],"cast_meta":[{"name":"Grant Gustin","name_vi":null,"name_original":"Grant Gustin","tmdb_id":122616,"profile":"https://image.tmdb.org/t/p/w500/kEGU1gGySIe63lyL7AnwXEw4rQn.jpg","tmdb_url":"https://www.themoviedb.org/person/122616"},{"name":"Candice Patton","name_vi":null,"name_original":"Candice Patton","tmdb_id":212700,"profile":"https://image.tmdb.org/t/p/w500/t9YV7TTQXkDWLmoHx8Mu3OUHqsP.jpg","tmdb_url":"https://www.themoviedb.org/person/212700"},{"name":"Danielle Panabaker","name_vi":null,"name_original":"Danielle Panabaker","tmdb_id":31838,"profile":"https://image.tmdb.org/t/p/w500/faX0EDc44GL5ZcsEcxTOBcfWpCP.jpg","tmdb_url":"https://www.themoviedb.org/person/31838"},{"name":"Danielle Nicolet","name_vi":null,"name_original":"Danielle Nicolet","tmdb_i