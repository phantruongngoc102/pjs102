67_df938132/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/96a93ba89a5b5c6c226e49b88973f46e","link_m3u8":"https://vip.opstream17.com/20240302/1766_479e27d9/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/f48c04ffab49ff0e5d1176244fdfb65c","link_m3u8":"https://vip.opstream17.com/20240307/2036_203b29b3/index.m3u8"}]}],"description":"<p><i>Câu chuyện 500 năm về trước, Uyển Lan là một yêu tinh già, có 2 con gái là Chân Trân và Khánh Du. Đến năm 2020, do đi đầu thai trễ nên bà trở thành một bé gái 10 tuổi. Để sum họp chung mái nhà, Chân Trân đành nhận Uyển Lan làm con nuôi. Bí mật này chỉ có 2 cô con gái cùng bà giúp việc Mai Liên được biết. Trớ trêu là 500 năm nay họ vẫn giữ quan hệ mẹ con, chủ tớ nên với kiếp này vẫn không có gì thay đổi. Uyển Lan bất đắc dĩ trở thành một bà mẹ nhí.</i><br><i>Bà già trong lốt trẻ em vừa ngây thơ vừa già dặn, sử dụng phép thuật đôi khi khá tùy tiện, gây những hiểu lầm đáng tiếc cho những người bình thường chung quanh. Tuy hành xử ngoài khuôn phép và trật tự thông thường của đời sống, nhưng bà mẹ vẫn giữ được phẩm chất của một bậc sinh thành. Bà luôn lo lắng hết mình cho sự an nguy, niềm vui, hạnh phúc trong cuộc đời của 2 cô con gái, dù vốn dĩ trong kiếp sống hiện tại họ hơn tuổi của mình.</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-me-nhi.json"}