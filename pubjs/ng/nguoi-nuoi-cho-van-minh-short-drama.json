m đốc Thôi Minh Phú không trả thêm 30 triệu nhân dân tệ tiền thách cưới, không biết rằng \"bà già lừa đảo\" mà họ làm bị thương chính là mẹ chồng tương lai.</p>","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-12T09:48:28.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ng/nguoi-nuoi-cho-van-minh-short-drama.json","keywords":[],"tmdb_checked":false}