bed":"https://vip.opstream13.com/share/e5fb0b05fdfd999b0ccd29aec3b22627","link_m3u8":"https://vip.opstream13.com/20260217/22455_e5fb0b05/index.m3u8"},{"name":"27","slug":"27","link_embed":"https://vip.opstream13.com/share/0693df4aa5de496ff23d0ae36e50c276","link_m3u8":"https://vip.opstream13.com/20260217/22456_0693df4a/index.m3u8"},{"name":"28","slug":"28","link_embed":"https://vip.opstream13.com/share/ce4803f46af6cc63c81bde4fa8996638","link_m3u8":"https://vip.opstream13.com/20260217/22457_ce4803f4/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream13.com/share/2ec189dffa38b370a90ab64599937111","link_m3u8":"https://vip.opstream13.com/20260217/22458_2ec189df/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream13.com/share/6e7222ccc5a07f592132ef871b58e08d","link_m3u8":"https://vip.opstream13.com/20260217/22459_6e7222cc/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream13.com/share/1f7eb1415d86eae96d8058babc672e05","link_m3u8":"https://vip.opstream13.com/20260217/22460_1f7eb141/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream13.com/share/c182dc5c90dc87dfee9cd309c33f19b3","link_m3u8":"https://vip.opstream13.com/20260217/22461_c182dc5c/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream13.com/share/d1dc3835945431feade7f56194520559","link_m3u8":"https://vip.opstream13.com/20260217/22462_d1dc3835/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream13.com/share/59bf3958a6ff253e596c3a9bb9ecd1f2","link_m3u8":"https://vip.opstream13.com/20260217/22463_59bf3958/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream13.com/share/9c8780d93f7077ed38cdc242778f7fdc","link_m3u8":"https://vip.opstream13.com/20260217/22464_9c8780d9/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream13.com/share/11af6b055e34d4ab516d9cea9c12a359","link_m3u8":"https://vip.opstream13.com/20260217/22465_11af6b05/index.m3u8"}]}],"description":"<p>\"Người Phiên Dịch Của Chúng Tôi\" là bộ phim tình cảm do đạo diễn Trương Đồng chỉ đạo, với sự tham gia của Tống Thiến (đóng phim \"Phong Khởi Lạc Dương\") và Trần Tinh Húc (đóng phim \"Đông Cung\") làm vai chính. Ngoài ra, còn có sự xuất hiện của Phí Khải Minh (đóng phim \"Vụ Án Lụa Duyên Dưới Kính Hiển Vi của Đại Minh\"), Lâm Tử Lộ (đóng phim \"Thế Giới Mới Của Bà\"), và Ư Sa Sa (đóng phim \"Thế Giới Mới Của Bà\").<br>Câu chuyện xoay quanh Lâm Tây, một chuyên gia phiên dịch xuất sắc và cuộc gặp gỡ lại với người yêu cũ Tiêu Nhất Thành. Tám năm trước, để theo đuổi giấc mơ nghề nghiệp mà mẹ cô chưa thể hoàn thành, Lâm Tây chấp nhận chia tay với Tiêu Nhất Thành để trở thành một chuyên gia phiên dịch tại Liên Hợp Quốc. Sau tám năm, Lâm Tây đã trở thành chuyên gia phiên dịch hàng đầu và \"Nữ Hoàng Hiệu Suất\" trẻ nhất tại Hoa Thanh, trong khi Tiêu Nhất Thành đã trở thành Giám đốc Công nghệ hàng đầu tại Language World.<br>Để chiếm lấy hợp đồng của Tiêu Nhất Thành, Lâm Tây phải đối đầu với anh. Mặc dù ban đầu có vẻ như Tiêu Nhất Thành đang trả thù, nhưng anh không chỉ là tàn nhẫn mà còn dành tình cảm cho cô. Trong quá trình làm việc và tiếp xúc, tình cảm mạnh mẽ từ quá khứ của họ được nhen nhóm trở lại. Tiêu Nhất Thành dần hiểu rõ về lý do chia tay của Lâm Tây và thấy nỗ lực không ngừng của cô trên con đường theo đuổi giấc mơ. Anh quyết định trở thành điểm tựa vững chắc cho cô, động viên và ở bên khi cô gặp khó khăn.<br>Qua sự thấu hiểu và đồng lòng, hai người cuối cùng trở thành đôi và thực hiện giấc mơ nghề nghiệp đại diện cho đất nước.</p>","tmdb_id":240439,"cast":["Tống Thiến","Trần Tinh Húc","Phí Khải Minh","Lin Zilu","Toa Vu Vu"],"director":["Zhang Tong"],"keywords":[],"tmdb":{"type":"tv","id":"240439","season":1,"vote_average":6.5,"vote_count":2},"cast_meta":[{"name":"Tống Thiến","name_vi":"Tống Thiến","name_original":"Victoria Song","tmdb_id":1255268,"profile":"https://image.tmdb.org/t/p/w500/xOrFdPmJXdmuSSMAF12AwSDpHw3.jpg","tmdb_url":"https://www.themoviedb.org/person/1255268"},{"name":"Trần Tinh Húc","name_vi":"Trần Tinh Húc","name_original":"Chen Xingxu","tmdb_id":2243681,"profile":"https://image.tmdb.org/t/p/w500/coASvXYBdg4xTrW7W46ZQmfkwxk.jpg","tmdb_url":"https://www.themoviedb.org/person/2243681"},{"name":"Phí Khải Minh","name_vi":"Phí Khải Minh","name_original":"Fei Qiming","tmdb_id":2633279,"profile":"https://image.tmdb.org/t/p/w500/iOK3rNtt0bUrDOw5bYoohE3rfiA.jpg","tmdb_url":"https://www.themoviedb.org/person/2633279"},{"name":"Lin Zilu","name_vi":null,"name_original":"Lin Zilu","tmdb_id":4022769,"profile":"https://image.tmdb.org/t/p/w500/ytBnpQnazbbpJbQBgB4tQH01Bq8.jpg","tmdb_url":"https://www.themoviedb.org/person/4022769"},{"name":"Toa Vu Vu","name_vi":"Toa Vu Vu","name_original":"Yu Shasha","tmdb_id":1978518,"profile":"https://image.tmdb.org/t/p/w500/dBYiEiEdBcelmuJbF4AlP5oiCSe.jpg","tmdb_url":"https://www.themoviedb.org/person/1978518"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-phien-dich-cua-chung-toi.json"}