ình của cô lại không hoàn hảo như bề ngoài, cô và bà mẹ chồng hung hăng nảy sinh nhiều mâu thuẫn vì chuyện sinh con, người em họ San San càng muốn ngồi không hưởng lộc, đồng thời quyến rũ thành công anh rể Vương Hải. San San, Vương Hải và mẹ chồng hợp tác bày mưu hãm hại Lương Tĩnh cho cô ra đi với hai bàn tay trắng. Lương Tĩnh vạch trần âm mưu, cô phẫn nộ và bắt đầu trả đũa thật cay nghiệt. Cô đè bẹp San San ở mọi mặt, trừng trị mẹ chồng, lại lên kế hoạch tỉ mỉ để giành lấy cổ phần công ty và bất động sản của Vương Hải. Vương Hải cùng đường bí lối muốn hại chết Lương Tĩnh, cuối cùng San San tỉnh ngộ, kéo Vương Hải chết chung.","tmdb":{"type":"tv","id":"241980","season":1,"vote_average":0,"vote_count":0},"modified":"2023-12-30T13:30:41.000Z","cast":["Yu San"],"director":[],"cast_meta":[{"name":"Yu San","name_vi":null,"name_original":"Yu San","tmdb_id":4519765,"profile":"https://image.tmdb.org/t/p/w500/apLeZOPe5lwj4f3iDneHr2UnmzN.jpg","tmdb_url":"https://www.themoviedb.org/person/4519765"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-phu-nu-chi-mang.json"}