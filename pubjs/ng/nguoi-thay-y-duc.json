om/20230111/28999_57ed4200/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/8cc3d0d6ce79806cac8e6ac80e3b4cdb","link_m3u8":"https://vip.opstream16.com/20230111/29000_f0f41c70/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/8d0e8d50eb0bad1727b38382d4fa42ef","link_m3u8":"https://vip.opstream16.com/20230111/29002_df0b9cf6/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream16.com/share/11a5b5ef81cff76a0a1f3d042f635df3","link_m3u8":"https://vip.opstream16.com/20230111/29006_534776b7/index.m3u8"}]}],"description":"<p>Người Thầy Y Đức là bộ phim truyền hình Hàn Quốc được giới phê bình đánh giá cao, đồng thời rất thành công về mặt thương mại với sự tham gia của Yoo Yeon Seok và Seo Hyn Jin. Kang Dong Joo là một bác sĩ có khát khao trở thành người vượt trội nhất, và Yoo Seo Jung là một nữ bác sĩ nỗ lực không ngừng để được mọi người công nhận. Họ không có điểm chung nào trước đó cho đến khi cả hai gặp được vị bác sĩ tài ba nhưng kỳ quặc, Kim Sa Bu. Từ đó hai người bắt đầu hiểu ý nghĩa thực sự của cuộc sống và tình yêu.</p>","tmdb_id":68398,"cast":[],"director":[],"keywords":[],"tmdb":{"id":68398},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ng/nguoi-thay-y-duc.json"}