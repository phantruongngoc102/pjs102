am15.com/share/fe9592afe24c33559773fd2f6e46c2fb","link_m3u8":"https://vip.opstream15.com/20221112/28069_634a9d20/index.m3u8"}]}],"description":"<p>Sau trận động đất ở Tây Xuyên, luật sư Luo Ben đã đến đó để tìm em gái của mình, Luo Yuan. Đây là lần đầu tiên anh gặp đội cứu hộ phi lợi nhuận do Đội trưởng Thanh Sơn dẫn đầu và sau đó anh gặp lại kẻ thù cũ Zhan Yan. Luo Ben vô cùng ấn tượng trước sự hỗ trợ lẫn nhau của người dân ở các khu vực bị ảnh hưởng và sự hy sinh của các nhân viên cứu hộ. Anh cũng rất ấn tượng trước kỹ năng y học tuyệt vời và lòng vị tha của Zhan Yan. Luo Ben, Xiong Fei, Zhou Mingming, Ding Dingding và những người mới khác tham gia đội cứu hộ phi lợi nhuận Yuanfang, dưới sự huấn luyện nghiêm ngặt của Đội trưởng Qingshan, và trở thành thành viên đội cứu hộ, họ tham gia nhiều lần vào các hoạt động cứu hộ khác nhau vì động đất , hỏa hoạn, chết đuối, bão. Bước ra khỏi phương hướng của cuộc sống, dùng mạng sống của mình cứu sống, thông qua lễ rửa tội trong thảm họa và cuối cùng họ trở thành những người ưu tú cứu hộ.</p>","tmdb_id":212267,"cast":["La Vân Hi","Ngô Thiến","Lý Minh Đức","Li Tingting","Xu Shaoying","Yang Anqi","Rock Ji"],"director":["Zhang Tong"],"keywords":[],"tmdb":{"type":"tv","id":"212267","season":1,"vote_average":6,"vote_count":3},"cast_meta":[{"name":"La Vân Hi","name_vi":"La Vân Hi","name_original":"Luo Yunxi","tmdb_id":2085450,"profile":"https://image.tmdb.org/t/p/w500/5tLqAOPTV3RnHLDLvJEYlYhJBLs.jpg","tmdb_url":"https://www.themoviedb.org/person/2085450"},{"name":"Ngô Thiến","name_vi":"Ngô Thiến","name_original":"Janice Wu","tmdb_id":1677008,"profile":"https://image.tmdb.org/t/p/w500/zNw2OQbHC343epJkSgR3FUHGWmA.jpg","tmdb_url":"https://www.themoviedb.org/person/1677008"},{"name":"Lý Minh Đức","name_vi":"Lý Minh Đức","name_original":"Li Mingde","tmdb_id":2727869,"profile":"https://image.tmdb.org/t/p/w500/chyIdYAmXBBHjC2f9GyNVhtNVkV.jpg","tmdb_url":"https://www.themoviedb.org/person/2727869"},{"name":"Li Tingting","name_vi":null,"na