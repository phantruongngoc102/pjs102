 sáng tạo của tuổi trẻ. Mâu thuẫn, âm mưu và tham vọng biến cả gia đình thành chiến trường không khoan nhượng trong cuộc chiến tranh giành vị trí Người Thừa Kế Số 1.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"297263","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-23T22:44:19.000Z","cast":["Sinjai Plengpanich","Kathaleeya McIntosh","Saksit Tangthong","Tonkhao Chayuth Nitichakorn","Akaravin Nanthipat","Porapat Srikajorndecha","Son Pannathorn Anankittilert","Pawarada Viravan","Sanya Kunakorn","Khunakon Puraso","Amarin Nitipon","Vasin Asvanarunat","Puma Pupapop Komolchote","Ausadaporn Siriwattanakul","Ornjira Lamwilai"],"director":["Sant Srikaewlaw"],"cast_meta":[{"name":"Sinjai Plengpanich","name_vi":null,"name_original":"Sinjai Plengpanich","tmdb_id":565528,"profile":"https://image.tmdb.org/t/p/w500/aKhbILxNLfWjSUa2WPMU5Jjd7yA.jpg","tmdb_url":"https://www.themoviedb.org/person/565528"},{"name":"Kathaleeya McIntosh","name_vi":null,"name_original":"Kathaleeya McIntosh","tmdb_id":2602113,"profile":"https://image.tmdb.org/t/p/w500/krFK6KNTlMbexFXeGNygZ9OFsSk.jpg","tmdb_url":"https://www.themoviedb.org/person/2602113"},{"name":"Saksit Tangthong","name_vi":null,"name_original":"Saksit Tangthong","tmdb_id":1023314,"profile":"https://image.tmdb.org/t/p/w500/qHPKu4JfcwQkHIH4U4rY9JH4awb.jpg","tmdb_url":"https://www.themoviedb.org/person/1023314"},{"name":"Tonkhao Chayuth Nitichakorn","name_vi":null,"name_original":"Tonkhao Chayuth Nitichakorn","tmdb_id":3169439,"profile":"https://image.tmdb.org/t/p/w500/5D8hiOnCOOEx1Drfdm3RcKPcc1M.jpg","tmdb_url":"https://www.themoviedb.org/person/3169439"},{"name":"Akaravin Nanthipat","name_vi":null,"name_original":"Akaravin Nanthipat","tmdb_id":3435634,"profile":"https://image.tmdb.org/t/p/w500/jG505DaIR8cnbbxd6tkBg9Q97ke.jpg","tmdb_url":"https://www.themoviedb.org/person/3435634"},{"name":"Porapat Srikajorndecha","name_vi":null,"name_original":"Porapat Srikajorndecha","tmdb_id":2091163,"profile":"https://image.tmdb.org/t/p/