u8":"https://vip.opstream14.com/20220821/20491_62196e82/index.m3u8"},{"name":"47","slug":"47","filename":"Người Tình Của Tôi - I Have a Lover - 2015 Tập 47","link_embed":"https://vip.opstream14.com/share/170fd2435f6b10aa2b0f9a64ee2b9bff","link_m3u8":"https://vip.opstream14.com/20220821/20492_952be103/index.m3u8"},{"name":"48","slug":"48","filename":"Người Tình Của Tôi - I Have a Lover - 2015 Tập 48","link_embed":"https://vip.opstream14.com/share/99e104da4f384281f6a46925e49821b2","link_m3u8":"https://vip.opstream14.com/20220821/20493_258f6b3f/index.m3u8"},{"name":"49","slug":"49","filename":"Người Tình Của Tôi - I Have a Lover - 2015 Tập 49","link_embed":"https://vip.opstream14.com/share/7c0ffb7232b77166913c3e8dec47ad07","link_m3u8":"https://vip.opstream14.com/20220821/20494_ff578403/index.m3u8"},{"name":"50","slug":"50","filename":"Người Tình Của Tôi - I Have a Lover - 2015 Tập 50-End","link_embed":"https://vip.opstream14.com/share/715a4f8bb21abbd684d51711fa65b830","link_m3u8":"https://vip.opstream14.com/20220821/20495_e7b1f1e8/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Hae Kang và Yong Ki là anh em sinh đôi đã bị chia cắt cách đây 30 năm. Hae Kang từng là một luật sư có gia đình hạnh phúc nhưng sau khi con gái chết, cuộc hôn nhân của cô bắt đầu đổ vỡ. Chồng cô, Jin Eon, con trai của một công ty dược phẩm lớn, bị quyến rũ bởi Seol Ri xinh đẹp, trẻ đẹp và quyết định ly hôn với Hae Kang. Yong Ki mặt khác là một góa phụ mang thai, cuộc đời của côbị đe dọa trong khi cố gắng khám phá sự thật đằng sau cái chết của chồng cô. Trong khi Yong Ki bỏ chạy, cô tình cờ đổi xe với Hae Kang khiến những người theo dõi cô nhầm lẫn danh tính của Hae Kang nên họ cố gắng giết cô. Hae Kang cuối cùng bị mất trí nhớ và sống với Baek Seok, người nghĩ rằng cô ấy là mối tình đầu của Yong Ki. Sự ngây thơ và vui vẻ của Baek Seok khiến cô cảm động và cô tìm thấy hạnh phúc bên anh nhưng khi gặp lại chồng cũ, trái tim cô bắt đầu rung động.</p>","tmdb":{"type":"tv","id":"63692","season"