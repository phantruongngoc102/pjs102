6e7ea702fee5415","link_m3u8":"https://vip.opstream14.com/20230414/35402_54ec2994/index.m3u8"},{"name":"33","slug":"33","filename":"Romance of a Twin Flower EP33","link_embed":"https://vip.opstream14.com/share/ab29fe6d1217894ad5cd4e77c34855e7","link_m3u8":"https://vip.opstream14.com/20230414/35408_a786ff4e/index.m3u8"},{"name":"34","slug":"34","filename":"Romance of a Twin Flower EP34","link_embed":"https://vip.opstream14.com/share/d1aecc83b16d6eb76039fd5cad6d77a9","link_m3u8":"https://vip.opstream14.com/20230414/35409_b31a1b71/index.m3u8"},{"name":"35","slug":"35","filename":"Romance of a Twin Flower EP35","link_embed":"https://vip.opstream14.com/share/7d54b4aa7cf58b91cfdeb51b235739b2","link_m3u8":"https://vip.opstream14.com/20230414/35410_be2288c0/index.m3u8"},{"name":"36","slug":"36","filename":"Romance of a Twin Flower EP36","link_embed":"https://vip.opstream14.com/share/16a50d670cfa9afa1ebd0022240fb0f9","link_m3u8":"https://vip.opstream14.com/20230414/35411_59198ac5/index.m3u8"},{"name":"37","slug":"37","filename":"Romance of a Twin Flower EP37","link_embed":"https://vip.opstream14.com/share/35f27037d233966a4a849da1e3123cb9","link_m3u8":"https://vip.opstream14.com/20230414/35412_5082873a/index.m3u8"},{"name":"38","slug":"38","filename":"Romance of a Twin Flower EP38","link_embed":"https://vip.opstream14.com/share/3846f5ae211da371800d278073470dd0","link_m3u8":"https://vip.opstream14.com/20230414/35413_041c5cbe/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Quý Mạn lớn lên ở Hải Phường từ nhỏ, vốn là một thiếu nữ vô lo, không ngờ trong một lần vào kinh chơi lại gặp chuyện ngoài ý muốn, sau khi tỉnh lại Quý Mạn bỗng mất trí nhớ và trở thành phu nhân của Mạch Ngọc hầu Ninh Ngọc Hiên. Ninh Ngọc Hiên là thiếu niên anh tài, được Hoàng đế coi trọng, vẫn luôn âm thầm điều tra manh mối về kẻ thù giết cha. Quý Mạn bị coi là đại phu nhân hung ác hay đố kỵ Nhiếp Tang Du, bị Ninh Ngọc Hiên nhốt vào Tư Quá Các. Để thoát khỏi hoàn cảnh khó khăn, Quý Mạn trở mình nhờ việc bán \"Thư Ngân Cao\", rồi lại cứu phu quân trước mặt Hoàng thượng, được phong cáo mệnh phu nhân nhị phẩm. Ninh Ngọc Hiên điều tra ra manh mối về kẻ thù giết cha khi tiêu diệt thổ phỉ, lại bị người ta hãm hại nhốt vào nhà lao, bị sung quân đến Hải Phường. Sau khi đến Hải Phường, Ninh Ngọc Hiên và Quý Mạn liên tục đánh bại hai kẻ ác thống trị Hải Phường. Dưới sự quản lý của Ninh Ngọc Hiên, Hải Phường phát triển rực rỡ. Quý Mạn cũng kinh doanh tiệm son phấn Hạo Tuyết Đường với bạn bè. Trên hành trình này, tình cảm giữa Ninh Ngọc Hiên và Quý Mạn đã sớm trở nên sâu đậm. Khi hai người bái đường thành thân, thân thế của Quý Mạn bỗng nhiên bị vạch trần. Đối mặt với chuyện cũ, lần này họ sẽ lựa chọn thế nào...</p>","tmdb":{"type":"tv","id":"207429","season":1,"vote_average":6,"vote_count":4},"modified":"2025-04-03T10:23:02.000Z","cast":["Bành Tiểu Nhiễm","Đinh Vũ Hề","Dịch Đại Thiên","Hà Xưởng Hy","Giả Nãi Na","La Thu Vận","Aliyah","Phó Gia"],"director":["Ze Xie"],"cast_meta":[{"name":"Bành Tiểu Nhiễm","name_vi":"Bành Tiểu Nhiễm","name_original":"Peng Xiaoran","tmdb_id":2243680,"profile":"https://image.tmdb.org/t/p/w500/koH1Nk2jvYxUVKwRIoEFJsZwgNF.jpg","tmdb_url":"https://www.themoviedb.org/person/2243680"},{"name":"Đinh Vũ Hề","name_vi":"Đinh Vũ Hề","name_original":"Ding Yuxi","tmdb_id":2493492,"profile":"https://image.tmdb.org/t/p/w500/ellcOuCs2mo1Oh9zO2Qhb0OoZ4d.jpg","tmdb_url":"https://www.themoviedb.org/person/2493492"},{"name":"Dịch Đại Thiên","name_vi":"Dịch Đại Thiên","name_original":"Yi Daqian","tmdb_id":2288957,"profile":"https://image.tmdb.org/t/p/w500/ndoTYEzy44C3Gwp8z863iALbf0u.jpg","tmdb_url":"https://www.themoviedb.org/person/2288957"},{"name":"Hà Xưởng Hy","name_vi":"Hà Xưởng Hy","name_original":"He Changxi","tmdb_id":2864044,"profile":"https://image.tmdb.org/t/p/w500/rUv6sbT9t4KQ2l2l9y7FACpPatG.jpg","tmdb_url":"https://www.themoviedb.org/person/2864044"},{"name":"Giả Nãi Na","name_vi":"Giả Nãi Na","name_original":"Ganana","tmdb_id":3649564,"profile":"https