//vip.opstream13.com/share/70d31b87bd021441e5e6bf23eb84a306","link_m3u8":"https://vip.opstream13.com/20250909/6994_70d31b87/index.m3u8"}]}],"time":"45 phút/tập","description":"Sau khi bị Phi và những người bạn phát giác, anh ta bỏ rơi vợ con, chuyến đến nội lục sống cùng hồng nhan tri kỷ. Phi như từ thiên đường rơi xuống vực thẳm, thất nghiệp và một mình nuôi con. Cô phải cho thuê một phần căn hộ mình đang sống để trang trải qua ngày. Vị khách hào phóng, chịu chi tiền thuê hết gian phòng trọ của Phi là Vinh Hạo Điền (do Châu Bách Hào đóng). Anh ta vốn chỉ muốn theo dõi cô người yêu cũ, sống ở căn hộ đối diện với Phi. Kể từ đó, giữa Phi và Điền thường xuyên cãi vã do khác biệt về nếp sinh hoạt, quan điểm sống. Nhưng, chính mối quan hệ oan gia dở khóc dở cười này đã khiến hai trái tim đau thương tìm lại được hạnh phúc...","tmdb":{"type":"tv","id":"95815","season":1,"vote_average":7,"vote_count":2},"modified":"2025-09-22T14:17:09.000Z","cast":["Dương Thiên Hoa","Châu Bách Hào","Trần Vỹ","Rebecca Zhu Chenli","Huỳnh Hạo Nhiên","Maggie Yu","Jonathan Wong Chi-Hin","Hồng Vĩnh Thành","Eva Lai","Viên Văn Kiệt","Trương Quốc Cường","Lily Leung Shun-Yin","Ngô Nhược Hy"],"director":[],"cast_meta":[{"name":"Dương Thiên Hoa","name_vi":"Dương Thiên Hoa","name_original":"Miriam Yeung Chin-Wah","tmdb_id":56863,"profile":"https://image.tmdb.org/t/p/w500/3NgovoC2nnHOFq7vr6j7m6URS7V.jpg","tmdb_url":"https://www.themoviedb.org/person/56863"},{"name":"Châu Bách Hào","name_vi":"Châu Bách Hào","name_original":"Pakho Chau","tmdb_id":1123831,"profile":"https://image.tmdb.org/t/p/w500/yhCcx2GXlIhrppiVW6vkbmIiNRX.jpg","tmdb_url":"https://www.themoviedb.org/person/1123831"},{"name":"Trần Vỹ","name_vi":"Trần Vỹ","name_original":"Alice Chan Wai","tmdb_id":1021936,"profile":"https://image.tmdb.org/t/p/w500/wxRBCvpATXZ5y4ejR7JrSChmS3N.jpg","tmdb_url":"https://www.themoviedb.org/person/1021936"},{"name":"Rebecca Zhu Chenli","name_vi":null,"name_original":"Rebecca Zhu Chenli","tmdb_id":985095,"profile"