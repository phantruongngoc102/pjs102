/20220304/550_95680e5a/index.m3u8"},{"name":"6","slug":"6","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-6","link_embed":"https://vip.opstream15.com/share/7f24d240521d99071c93af3917215ef7","link_m3u8":"https://vip.opstream15.com/20220304/551_7341c09d/index.m3u8"},{"name":"7","slug":"7","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-7","link_embed":"https://vip.opstream15.com/share/94c7bb58efc3b337800875b5d382a072","link_m3u8":"https://vip.opstream15.com/20220304/552_e4064f4e/index.m3u8"},{"name":"8","slug":"8","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-8","link_embed":"https://vip.opstream15.com/share/f387624df552cea2f369918c5e1e12bc","link_m3u8":"https://vip.opstream15.com/20220304/553_11ee0b3d/index.m3u8"},{"name":"9","slug":"9","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-9","link_embed":"https://vip.opstream15.com/share/5e388103a391daabe3de1d76a6739ccd","link_m3u8":"https://vip.opstream15.com/20220304/554_af63786e/index.m3u8"},{"name":"10","slug":"10","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-10","link_embed":"https://vip.opstream15.com/share/15de21c670ae7c3f6f3f1f37029303c9","link_m3u8":"https://vip.opstream15.com/20220304/555_f6022f78/index.m3u8"},{"name":"11","slug":"11","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-11","link_embed":"https://vip.opstream15.com/share/11b921ef080f7736089c757404650e40","link_m3u8":"https://vip.opstream15.com/20220304/556_50b78baa/index.m3u8"},{"name":"12","slug":"12","filename":"nguoi-yeu-day-mi-luc-cua-toi-tap-12","link_embed":"https://vip.opstream15.com/share/6e2713a6efee97bacb63e52c54f0ada0","link_m3u8":"https://vip.opstream15.com/20220304/557_6e6f46df/index.m3u8"}]}],"time":"27M6S","description":"<p>Phim bắt đầu từ chủ tịch tập đoàn Yujie - Xinruila, người độc đoán hợp tác với người pha chế bí ẩn ở Mirage Bar để giải quyết cuộc khủng hoảng của công ty phát sóng trực tiếp. Lý do chấp thuận lời đề nghị của anh được cho là vì thua cược nên anh phải làm việc bán thời gian trong quán bar.</p><p>Sau một thời gian tiếp xúc với nhau Xinruila bất ngờ phát hiện ra rằng anh chàng pha chế đó chính là người yêu thuở nhỏ của mình là Wen Qi, đã hơn 10 hơn trở về trước nhưng vì diện mạo lúc lớn thay đổi cùng tên của cũng đã được nên cả hai không nhận ra nhau khi mới gặp. Thực chất cả hai đã có mối tình đậm sâu và hiểu ý nhau đến mức không thể lìa xa, nhưng vì một sự hiểu lầm mà họ đã buông tay nhau. Giờ đây Xinruila không hiểu tại sao Wen Qi lại đổi tên và họ của mình? Câu chuyện Người Yêu Đầy Mị Lực Của Tôi chính thức một lần nữa bắt đầu giữa hai con người này.</p><p>Đến khi tình cảm của cặp đôi chính gương vỡ lại lành chưa kịp vui mừng và tận hưởng khoảng thời gian hạnh phúc thì bất ngờ cả hai đối mặt với khủng hoảng của công ty. Cả hai cùng nhau bắt tay nhau khôi phục lại danh tiếng của công ty, trong quá trình bảo vệ họ hâm nóng tình cảm cho nhau, họ trở nên yêu nhau đậm sâu hơn.</p>","tmdb":{"type":"tv","id":"136784","season":1,"vote_average":0,"vote_count":0},"modified":"2025-06-06T11:22:05.000Z","cast":["Fang Xiaodong","Tào Phỉ Nhiên","Zhang Ju Ju","Qu Yicheng","Zhang Qidanya","Hạ Khai Lãng"],"director":["He Kai"],"cast_meta":[{"name":"Fang Xiaodong","name_vi":null,"name_original":"Fang Xiaodong","tmdb_id":3505987,"profile":"https://image.tmdb.org/t/p/w500/ex0zF12LkqFu4mbYUOkSr6ABxlF.jpg","tmdb_url":"https://www.themoviedb.org/person/3505987"},{"name":"Tào Phỉ Nhiên","name_vi":"Tào Phỉ Nhiên","name_original":"Cao Feiran","tmdb_id":3278808,"profile":"https://image.tmdb.org/t/p/w500/pNWkUCshzAP6PM0TymRHL81XbQX.jpg","tmdb_url":"https://www.themoviedb.org/person/3278808"},{"name":"Zhang Ju Ju","name_vi":null,"name_original":"Zhang Ju Ju","tmdb_id":3278810,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3278810"},{"name":"Qu Yicheng","name_vi":null,"name_original":"Qu Yicheng","tmdb_id":3190873,"profile":"https://image.tmdb.org/t/p/w500/i0FOEEwYQ3n0rhZZKdAfVV0Uw7q.jpg","tmdb_url":"https://www.themoviedb.org/person/3190873"},{"name":"Zhang Qidanya","name_vi":null,"name_original":"Zhang 