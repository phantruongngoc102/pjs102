4","link_embed":"https://vip.opstream13.com/share/8f4576ad85410442a74ee3a7683757b3","link_m3u8":"https://vip.opstream13.com/20240709/4648_ccee76e4/index.m3u8"}]}],"time":"15 phút/tập","description":"<p>Hơn mười năm trước, một bản đồ kho báu đã dẫn đến sự diệt vong của gia tộc Li, một quan đại thần của triều đại trước đây. Hơn mười năm sau, đứa trẻ mồ côi Li Yunzhi mang theo hận thù trở về. Phá hoại cuộc hôn nhân của Ye Wan, anh ta cẩn thận giăng bẫy với công chúa hiện tại Ye Lingyue để cùng mình đến hoàng tử yandere Song Chen để chờ trả thù. Sau nhiều lần thử thách, anh ta dần dần phát hiện ra đối phương trông giống như một người bạn cũ từ thời thơ ấu.. . Người khổ hạnh che giấu cảm xúc của mình và không biết gì, người bị cám dỗ, bạo dâm là điều cấm kỵ, và luôn có một tương lai tươi sáng. Ye Lingyue và Li Yunzhi vừa là kẻ thù vừa là bạn, mối quan hệ của họ dần trở nên sâu sắc hơn. Họ sát cánh cùng nhau vượt qua mọi trở ngại, nhưng với sự diệt vong của gia tộc Wan và Ye, bí mật về bản đồ kho báu và trao đổi danh tính cũng được tiết lộ. ...</p>","tmdb":{"type":"tv","id":"254164","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-05T11:19:05.000Z","cast":["Quách Già Nam","Sun Yiran","Huang Yunyun","Min Xinghan"],"director":["Xi Zi"],"cast_meta":[{"name":"Quách Già Nam","name_vi":"Quách Già Nam","name_original":"Guo Jianan","tmdb_id":2931793,"profile":"https://image.tmdb.org/t/p/w500/njxfZ965jk0rCHcG2YCzmQgdJAT.jpg","tmdb_url":"https://www.themoviedb.org/person/2931793"},{"name":"Sun Yiran","name_vi":null,"name_original":"Sun Yiran","tmdb_id":4606152,"profile":"https://image.tmdb.org/t/p/w500/oibAsppIrQDBdtg2hdIouUk6MsV.jpg","tmdb_url":"https://www.themoviedb.org/person/4606152"},{"name":"Huang Yunyun","name_vi":null,"name_original":"Huang Yunyun","tmdb_id":3181657,"profile":"https://image.tmdb.org/t/p/w500/hbWs7oHJrInJ1koEVXRwDEf2IGl.jpg","tmdb_url":"https://www.themoviedb.org/person/3181657"},{"name":"Min Xinghan","name_vi":null,"name_original":"Min Xingh