hort.com/20251107/14067_f4cfab79/index.m3u8"},{"name":"72","slug":"72","link_embed":"https://vip.opstream-short.com/share/ab394288aed46588bdc90bf4b541ec0d","link_m3u8":"https://vip.opstream-short.com/20251107/14068_ab394288/index.m3u8"},{"name":"73","slug":"73","link_embed":"https://vip.opstream-short.com/share/75144d9c8780608425dd34bfaf7b96f0","link_m3u8":"https://vip.opstream-short.com/20251107/14069_75144d9c/index.m3u8"},{"name":"74","slug":"74","link_embed":"https://vip.opstream-short.com/share/3ee7811d398ae2240f5d3f0684ecb8d3","link_m3u8":"https://vip.opstream-short.com/20251107/14070_3ee7811d/index.m3u8"},{"name":"75","slug":"75","link_embed":"https://vip.opstream-short.com/share/cccb7ec704e828b99068ec1b9cf1fc03","link_m3u8":"https://vip.opstream-short.com/20251107/14071_cccb7ec7/index.m3u8"}]}],"description":"<p>An Tâm bất ngờ tái sinh về năm 1990, mang thai và bị gia đình đuổi khỏi nhà. Với tài nấu ăn siêu việt và tầm nhìn độc đáo, cô mở một nhà hàng nhỏ trên đường Hoàng Hà. Đối mặt với côn đồ đòi tiền bảo kê, sự đàn áp của đối thủ và tin đồn thị phi, An Tâm ứng phó mạnh mẽ, thể hiện óc kinh doanh tuyệt vời và tinh thần kiên cường. Trong quá trình điều hành nhà hàng, cô nhận nuôi Kiều Kiều - người giúp việc bị vu khống, và gặp Đồng Quang Ngôn bí ẩn. Khi kinh doanh ngày càng thịnh vượng, nhà hàng của cô thu hút sự chú ý của các đối thủ cạnh tranh.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nha-hang-cua-toi-tren-duong-hoang-ha-short-drama.json","tmdb_checked":false}