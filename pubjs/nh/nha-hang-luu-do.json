s://vip.opstream90.com/20251105/16906_068190ee/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream90.com/share/47cc8fbdaeacd8c1d9fe325b11e0287e","link_m3u8":"https://vip.opstream90.com/20251105/16907_47cc8fbd/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream90.com/share/726bd18c52afc248015dcdbc463c6f85","link_m3u8":"https://vip.opstream90.com/20251106/17007_726bd18c/index.m3u8"}]}],"description":"<p>Minh Lượng, một sinh viên tốt nghiệp học viện mỹ thuật, vì mẹ nuôi bị bệnh nặng nên đã từ bỏ cơ hội tiếp tục học lên cao, thay mẹ gánh vác việc kinh doanh nhà hàng Lựu Đỏ. Minh Lượng tháo vát giải quyết những vấn đề phát sinh và đưa Lựu Đỏ trở thành một nhà hàng cực kỳ chất lượng. Trong quá trình ấy, anh không chỉ trưởng thành, chững chạc hơn, mà còn tích lũy được thêm sức mạnh để phát triển trên con đường nghệ thuật. Trong thời gian ấy, anh tình cờ gặp lại Cổ Lệ Na Nhĩ - cô bạn thanh mai trúc mã độc lập, mạnh mẽ thời thơ ấu. Hai người đã chữa lành những tổn thương cho nhau, cùng nhau trưởng thành, và cuối cùng trở thành người yêu, tri kỷ của nhau trong hành trình tiếp theo của cuộc đời.</p><p>&nbsp;</p>","tmdb_id":301422,"cast":["Bai Yufan","Giả Nãi Na","Đồ Tùng Nham","Lưu Nhuế Lân","Wang He","Cao Chí Đình","Alima","Abdukerim Abliz","Xiong Ruiling","Jiang Yihao","Lin Yongjian"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"301422","season":1,"vote_average":9,"vote_count":1},"cast_meta":[{"name":"Bai Yufan","name_vi":null,"name_original":"Bai Yufan","tmdb_id":2973248,"profile":"https://image.tmdb.org/t/p/w500/oYSpkzTHRirZUbSCrxgC0KfCd9g.jpg","tmdb_url":"https://www.themoviedb.org/person/2973248"},{"name":"Giả Nãi Na","name_vi":"Giả Nãi Na","name_original":"Ganana","tmdb_id":3649564,"profile":"https://image.tmdb.org/t/p/w500/hJewJ9TR2tCm7Gmv4ZXZkQjRPF.jpg","tmdb_url":"https://www.themoviedb.org/person/3649564"},{"name":"Đồ Tùng Nham","name_vi":"Đồ Tùng Nham","name_original":"Tu Songyan","tmdb_id":2276453,"profile":"https