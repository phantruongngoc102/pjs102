 thường người nông thôn như Triệu Tình. Sau khi hỏi han kỹ lưỡng, Triệu Tình chọn tin tưởng các em và cùng giải quyết vấn đề, cuối cùng sự thật được sáng tỏ.","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-07T09:43:33.000Z","cast":[],"director":[],"cast_meta":[],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nhan-danh-tinh-yeu-short-drama.json"}