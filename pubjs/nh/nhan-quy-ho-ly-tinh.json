ae6/index.m3u8"}]}],"time":"44 phút/tập","description":"<p><i>Yến Thái Thần trong lúc đối phó với Linh Sơn Hồ Ly đã quen biết với Lãnh Thu Luyện của Thiên Dao Cung. Thu Luyện vốn là gái giả trai, quấn quýt bên Thái Thần lâu ngày phát sinh tình cảm nhưng không thể tỏ bày. Hồ yêu sai Hồ Tương Tương hành thích Thái Thần, nào ngờ Tương và Thần lại đem lòng yêu nhau... Sát thủ Thạch Tam Lam bị thủ lãnh quỷ đao cửu u đuổi giết vì có tướng mạo giống sư đệ của Thái Thần là Lăng Thiên Vũ. Tam Lang vì tránh sự truy sát mới giả dạng Thiên Vũ nào ngờ Thiên Vũ lại là kẻ sát hại sư mẫu phản bội sư môn...</i></p>","tmdb":{"type":"tv","id":"109854","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-07T19:10:27.000Z","cast":["Ngô Đại Dung","Lily Chung Suk-Wai","Sher Ng Wing-Hung","Âu Thụy Vỹ","Ga-Bo Tsui","Chan On-ying","Chu Tit-Wo","Mạch Tử Vân","Amy Wu Mei-Yee","Lee Hoi-Sang","Lâm Vỹ Thần","Huỳnh Đức Bân","Chang Kin-Ming","Lạc Ứng Quân","Lương Kiện Bình"],"director":["Dương Cẩm Tuyền"],"cast_meta":[{"name":"Ngô Đại Dung","name_vi":"Ngô Đại Dung","name_original":"Hugo Ng Doi-Yung","tmdb_id":1187932,"profile":"https://image.tmdb.org/t/p/w500/1FNy7eOKdfjQcKT1aIjv6G0akTs.jpg","tmdb_url":"https://www.themoviedb.org/person/1187932"},{"name":"Lily Chung Suk-Wai","name_vi":null,"name_original":"Lily Chung Suk-Wai","tmdb_id":548052,"profile":"https://image.tmdb.org/t/p/w500/aXq9i924gUsurXwvltMbr5Wr0E4.jpg","tmdb_url":"https://www.themoviedb.org/person/548052"},{"name":"Sher Ng Wing-Hung","name_vi":null,"name_original":"Sher Ng Wing-Hung","tmdb_id":1374622,"profile":"https://image.tmdb.org/t/p/w500/91j4W8sKUjxl5khiFsAFFOYOKTr.jpg","tmdb_url":"https://www.themoviedb.org/person/1374622"},{"name":"Âu Thụy Vỹ","name_vi":"Âu Thụy Vỹ","name_original":"Jimmy Au Shui-Wai","tmdb_id":1365933,"profile":"https://image.tmdb.org/t/p/w500/67TWZynh4dEKpWX4J80QDBOfaT9.jpg","tmdb_url":"https://www.themoviedb.org/person/1365933"},{"name":"Ga-Bo Tsui","name_vi":null,"name_original":"Ga-Bo Tsui","t