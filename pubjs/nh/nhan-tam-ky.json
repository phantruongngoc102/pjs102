_m3u8":"https://vip.opstream17.com/20240708/14612_7817a086/index.m3u8"}]}],"description":"\"Nhan Tâm Ký\" là bộ phim cổ trang tình cảm do Vu Trung Trung (tác phẩm \"Nửa Là Đường Mật, Nửa Là Đau Thương\") làm đạo diễn, với sự tham gia của La Vân Hi (tác phẩm \"Hương Mật Tựa Khói Sương\") và Tống Dật (tác phẩm \"Khánh Dư Niên - Phần 1\") trong vai trò diễn viên chính. Bộ phim kể về câu chuyện lãng mạn định mệnh giữa Giang Tâm Bạch (La Vân Hi thủ vai) - vị quận vương lạnh lùng mắc chứng mù mặt, quyết tâm tiêu diệt \"Quế Thảo\" trên khắp thiên hạ, và Nhan Nam Tinh (Tống Dật thủ vai) - nữ du y nhiệt huyết \"biến hình\" mỗi tháng một lần. Cả hai cùng nhau phiêu lưu giang hồ để tìm kiếm tình yêu, qua đó truyền tải ý nghĩa thật sự của tình yêu – dung mạo tuy quan trọng nhưng không thể so sánh với sự đồng điệu trong tâm hồn.","tmdb_id":252396,"cast":["La Vân Hi","Tống Dật","Trần Dao","Thừa Lũy","Hoàng Nhật Oánh","Cổ Tử Thành","Quản Tử Tịnh","Đặng Khải","Đường Tằng","Huỳnh Tiểu Lội","Hồng Nghiêu","Ôn Tranh Vanh","Hà Trung Hoa","Nhạc Dược Lợi","Cao Weiyu"],"director":["Yu Chung-chung","Xu Ling Ling"],"keywords":[],"tmdb":{"type":"tv","id":"252396","season":1,"vote_average":9,"vote_count":4},"cast_meta":[{"name":"La Vân Hi","name_vi":"La Vân Hi","name_original":"Luo Yunxi","tmdb_id":2085450,"profile":"https://image.tmdb.org/t/p/w500/5tLqAOPTV3RnHLDLvJEYlYhJBLs.jpg","tmdb_url":"https://www.themoviedb.org/person/2085450"},{"name":"Tống Dật","name_vi":"Tống Dật","name_original":"Song Yi","tmdb_id":1877119,"profile":"https://image.tmdb.org/t/p/w500/10IcNNHWQ7WGktAcfDtClJnapUo.jpg","tmdb_url":"https://www.themoviedb.org/person/1877119"},{"name":"Trần Dao","name_vi":"Trần Dao","name_original":"Chen Yao","tmdb_id":1865921,"profile":"https://image.tmdb.org/t/p/w500/9sqEtFKYtPZ5InwqmfX6qVOYNKV.jpg","tmdb_url":"https://www.themoviedb.org/person/1865921"},{"name":"Thừa Lũy","name_vi":"Thừa Lũy","name_original":"Ryan Cheng","tmdb_id":3093089,"profile":"https://image.tmdb.org/t/p/w500/mN45m