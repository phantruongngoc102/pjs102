h được điều đến một cấp trên mới là Luật. Cả hai không mấy hợp nhau, và cùng để ý đến Phương, hướng dẫn viên du lịch, mặc dù Luật đã có vợ nhưng gia đình anh không mấy hạnh phúc. Thái cùng Tuệ, em gái Tống, sau khi kết hôn cũng xảy ra không ít mâu thuẫn. Mỗi người đều mang trong mình một mẩu chuyện đời khác nhau nhưng trong công việc họ luôn cố gắng hết sức để bảo vệ trị an cho Hong Kong.</i></p>","tmdb":{"type":"tv","id":"33890","season":1,"vote_average":5,"vote_count":1},"modified":"2024-08-30T20:05:42.000Z","cast":["Huỳnh Nhật Hoa","La Gia Lương","Trần Cẩm Hồng","Lê Tư","Bonnie Chiu Hok-Yee","Trần Diệu Anh","Joe Ma Tak-Chung","Karen Tong Bo-Yue","Yvonne Lam Yee-Man","Vi Gia Hùng","Josie Ho","Quách Khả Doanh","Lưu Triệu Minh","Pak Yan","Choi Kwok-Hing"],"director":["Thích Kỳ Nghĩa"],"cast_meta":[{"name":"Huỳnh Nhật Hoa","name_vi":"Huỳnh Nhật Hoa","name_original":"Felix Wong Yat-Wah","tmdb_id":71655,"profile":"https://image.tmdb.org/t/p/w500/9HooA3aF764XKYU8GUxO4P7v5gZ.jpg","tmdb_url":"https://www.themoviedb.org/person/71655"},{"name":"La Gia Lương","name_vi":"La Gia Lương","name_original":"Gallen Lo Ka-Leung","tmdb_id":1223043,"profile":"https://image.tmdb.org/t/p/w500/6ZCTOMeRktYL7iTEz7lg7N3XXPc.jpg","tmdb_url":"https://www.themoviedb.org/person/1223043"},{"name":"Trần Cẩm Hồng","name_vi":"Trần Cẩm Hồng","name_original":"Sunny Chan Kam-Hung","tmdb_id":548050,"profile":"https://image.tmdb.org/t/p/w500/pUMJUtdpFutN7uHk7yPw11iwAbh.jpg","tmdb_url":"https://www.themoviedb.org/person/548050"},{"name":"Lê Tư","name_vi":"Lê Tư","name_original":"Gigi Lai Chi","tmdb_id":67224,"profile":"https://image.tmdb.org/t/p/w500/1lAKx9141UsF506bXGRLEaDztjO.jpg","tmdb_url":"https://www.themoviedb.org/person/67224"},{"name":"Bonnie Chiu Hok-Yee","name_vi":null,"name_original":"Bonnie Chiu Hok-Yee","tmdb_id":1381143,"profile":"https://image.tmdb.org/t/p/w500/o5VVtpww8nYUA0flxqqeJ2FCNZz.jpg","tmdb_url":"https://www.themoviedb.org/person/1381143"},{"name":"Trần Diệu Anh","name_vi":"Trần D