dex.m3u8"},{"name":"24","slug":"24","filename":"Nhất Đao Phong Nguyệt - Tập 24---2025","link_embed":"https://vip.opstream90.com/share/6ae948577c0bd7c07f4e74b4745f74a8","link_m3u8":"https://vip.opstream90.com/20250724/9377_6ae94857/index.m3u8"}]}],"time":"12 phút/tập","description":"<p>Tống Vi Vi là con gái của đại tướng số một nước Trần. Vì muốn báo thù cho cha và rửa mối hận mất nước, cô cải trang thành Ôn Nhu - em gái được sủng ái nhất của hoàng tử Ôn Tri Uyên nước Lương, chỉ để tiếp cận và trả thù hắn. Thế nhưng trong quá trình ở bên nhau, cô dần chiếm được lòng tin của Ôn Tri Uyên, thậm chí khiến hắn thật lòng yêu cô. Với sự trợ giúp của Ôn Tri Bạch - người đang tranh đoạt ngôi vị với Ôn Tri Uyên, nàng từng bước phá vỡ toàn bộ thế cục do Ôn Tri Uyên sắp đặt, cuối cùng thành công ngăn chặn con đường xưng đế của hắn và tự tay báo thù cho cha mình. Thế nhưng, chính lúc đó nàng mới nhận ra Ôn Tri Uyên thực sự đã yêu nàng chân thành, còn \"bạch nguyệt quang\" trong lòng nàng thì vẫn luôn âm thầm bảo vệ nàng từ đầu đến cuối…</p>","tmdb":{"type":"tv","id":"295782","season":1,"vote_average":6,"vote_count":1},"modified":"2025-07-24T11:14:42.000Z","cast":["Aaron Deng","Zhang Changning","Li Mingxu","Shang Xuan","Yang Helin","Ma Ge"],"director":[],"cast_meta":[{"name":"Aaron Deng","name_vi":null,"name_original":"Aaron Deng","tmdb_id":2688400,"profile":"https://image.tmdb.org/t/p/w500/u4Wb5rsVnJZ3Xz7Okv5pA7oqoSF.jpg","tmdb_url":"https://www.themoviedb.org/person/2688400"},{"name":"Zhang Changning","name_vi":null,"name_original":"Zhang Changning","tmdb_id":5008036,"profile":"https://image.tmdb.org/t/p/w500/pylzO3eV0Dw19Dq0BQKVbTqOSlV.jpg","tmdb_url":"https://www.themoviedb.org/person/5008036"},{"name":"Li Mingxu","name_vi":null,"name_original":"Li Mingxu","tmdb_id":4028019,"profile":"https://image.tmdb.org/t/p/w500/wj9xhF0hTgvFfK8DHqocUI13btZ.jpg","tmdb_url":"https://www.themoviedb.org/person/4028019"},{"name":"Shang Xuan","name_vi":null,"name_original":"Shang Xuan","tmdb_id"