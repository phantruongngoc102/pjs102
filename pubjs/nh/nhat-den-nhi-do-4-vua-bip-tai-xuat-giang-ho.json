332584/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream17.com/share/0740bb92e583cd2b88ec7c59f985cb41","link_m3u8":"https://vip.opstream17.com/20240607/10709_065c18e1/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/e360367584297ee8d2d5afa709cd440e","link_m3u8":"https://vip.opstream17.com/20240607/10708_0e5866f5/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/e8ad3f3f04296aa9be9de71a674e3769","link_m3u8":"https://vip.opstream17.com/20240607/10707_6dc75b63/index.m3u8"}]}],"description":"<p><i>Vào một ngày năm 1928, Đổ Thần Trung Quốc Long Tứ ra tù và đi đến Thượng Hải với hai bàn tay trắng. Trên chuyến xe lửa đến Thượng Hải, ngồi cùng toa với Long Tứ toàn là những tay cờ bạc lừng danh trong làng bịp. Cũng trên chuyến xe đó, trong toa xe đó, những ân oán của luật hè phố mạnh được yếu thua bắt đầu manh nha. Long Tứ và đám người kia kết làm anh em, thề có phú cùng hưởng, có họa cùng mang, đến Thượng Hải đánh thiên hạ. Một rừng không thể hai cọp, một giang sơn không thể có hai lãnh chúa. Cây càng cao thì gió càng mạnh. Giữa huynh đệ với nhau, ai mất, ai được, ai hơn, ai thua?</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nhat-den-nhi-do-4-vua-bip-tai-xuat-giang-ho.json"}