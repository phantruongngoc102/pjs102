f9d85/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream13.com/share/c0f48c8ab1b8e41d825d24714e851659","link_m3u8":"https://vip.opstream13.com/20251108/17452_c0f48c8a/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/71014f3b2f3b8f52e2d6ee2304db7e95","link_m3u8":"https://vip.opstream13.com/20251108/17453_71014f3b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/302101902bd9140427edc0c41e139782","link_m3u8":"https://vip.opstream13.com/20251108/17454_30210190/index.m3u8"}]}],"description":"<p>Bộ phim kể về câu chuyện đã tồn tại trong dân gian nhiều năm, đó là mỗi khi trên bầu trời xuất hiện ngôi sao Lang Ma thì trong dân gian Lang Ma xuất hiện và hoành hành khắp nơi. Lúc này Bảo Diệp Linh Tiêu nhìn thấy sao Lang Ma xuất hiện và sau khi điều tra, ông cho rằng người tên là Hà Triển Bang chính là loài ma quái nên cùng nghĩa sĩ giang hồ đuổi cùng diệt tận buộc ông phải xuống vực núi cao để tránh bị loạn đao phân thây. Ông để lại một đứa con gái tên là Hà Chí Thanh, cô gái được nuôi dưỡng tại Quỹ Mạt Cốc bởi một đôi thần y phu phụ. Nhưng Bạch Thiên Hành lại quan sát những vì sao, vì am hiểu tinh tú nên ông biết Lang Ma không phải là Hà Triển Bang, ông định điều tra ngọn ngành thì bất ngờ bị truy sát, chỉ kịp mang theo đứa con trai còn bé bỏng tên là Long trốn chạy. 16 năm sau Long đã thành một thanh niên, anh lên đường truy tìm Lang Ma thật sự cùng với hậu nhân của những người trong cuộc năm xưa.</p>","tmdb_id":108414,"cast":["Lưu Đức Hoa","Thiệu Mỹ Kỳ","Newton Lai Hon-Chi","Chu Tit-Wo","La Lan","Lưu Đan","Amy Wu Mei-Yee","Hứa Thiệu Hùng"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"108414","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lưu Đức Hoa","name_vi":"Lưu Đức Hoa","name_original":"Andy Lau","tmdb_id":25246,"profile":"https://image.tmdb.org/t/p/w500/z9R2yerjfgxwDWIH8sjiS0hhcre.jpg","tmdb_url":"https://www.themoviedb.org/person/25246"},{"name":"T