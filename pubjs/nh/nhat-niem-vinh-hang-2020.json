":1,"vote_average":8.9,"vote_count":16},"cast_meta":[{"name":"Su Shangqing","name_vi":null,"name_original":"Su Shangqing","tmdb_id":1674213,"profile":"https://image.tmdb.org/t/p/w500/mbTikaoO6lPtiHwJB1PzAqxYE27.jpg","tmdb_url":"https://www.themoviedb.org/person/1674213"},{"name":"Li Shimeng","name_vi":null,"name_original":"Li Shimeng","tmdb_id":2463716,"profile":"https://image.tmdb.org/t/p/w500/i7hKjBsuxiMHuj3v68yWhbLXNbi.jpg","tmdb_url":"https://www.themoviedb.org/person/2463716"},{"name":"Guo Haoran","name_vi":null,"name_original":"Guo Haoran","tmdb_id":2031481,"profile":"https://image.tmdb.org/t/p/w500/oKJpFKdCLRzcaTH8kWYNjYczfWb.jpg","tmdb_url":"https://www.themoviedb.org/person/2031481"},{"name":"Qiao Shiyu","name_vi":null,"name_original":"Qiao Shiyu","tmdb_id":2199334,"profile":"https://image.tmdb.org/t/p/w500/5TN4UEZkNezqIeBSUuNYmaNveCe.jpg","tmdb_url":"https://www.themoviedb.org/person/2199334"},{"name":"Chen Zhangtaikang","name_vi":null,"name_original":"Chen Zhangtaikang","tmdb_id":2463708,"profile":"https://image.tmdb.org/t/p/w500/wU0gWYTNIqK37wn2c8VmSlYImSw.jpg","tmdb_url":"https://www.themoviedb.org/person/2463708"},{"name":"Shuai Guan","name_vi":null,"name_original":"Shuai Guan","tmdb_id":2720416,"profile":"https://image.tmdb.org/t/p/w500/1rTmvuKnSKQs2DqDTKfWBWaIOmi.jpg","tmdb_url":"https://www.themoviedb.org/person/2720416"},{"name":"Ma Cheng","name_vi":null,"name_original":"Ma Cheng","tmdb_id":2508435,"profile":"https://image.tmdb.org/t/p/w500/a6vob4kODHlktSWET3TtBCp8Z4t.jpg","tmdb_url":"https://www.themoviedb.org/person/2508435"},{"name":"Shuang Zhao","name_vi":null,"name_original":"Shuang Zhao","tmdb_id":3848033,"profile":"https://image.tmdb.org/t/p/w500/wFQgKpyd8CdNKtoX1LwlPPQWlzq.jpg","tmdb_url":"https://www.themoviedb.org/person/3848033"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nhat-niem-vinh-hang-2020.json"}