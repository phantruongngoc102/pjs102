b7ecfd5d2086402935","link_m3u8":"https://vip.opstream15.com/20250103/46802_5f38506e/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Đại Lý Tự chính Nam Phong Ý và nữ nha nhân Mộng Tây Châu vì án gặp nhau, kết làm sư đồ cùng bắt yêu. Khi tình cảm giữa hai người dần sâu đậm, yêu vương Mộng Tây Châu hiện thế bị tâm ma mê hoặc khống chế. Nam Phong Ý cũng phát hiện trong cơ thể mình có yêu đan của Mộng Tây Châu đã mất nhiều năm. Để cứu người yêu, Nam Phong Ý mổ đan trả lại, và dùng hết sinh mệnh cuối cùng cùng Mộng Tây Châu liên thủ kháng cự, trả lại tự do cho những sinh linh vô tội.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"261011","season":1,"vote_average":8.5,"vote_count":2},"modified":"2025-01-03T11:46:52.000Z","cast":["Vu Mông Lung","Li Zixuan","June Wu","Chung Lệ Lệ","Hà Hoa","Phùng Lệ Quân"],"director":["Tian Mai"],"cast_meta":[{"name":"Vu Mông Lung","name_vi":"Vu Mông Lung","name_original":"Yu Menglong","tmdb_id":1599857,"profile":"https://image.tmdb.org/t/p/w500/xBiX3svunAbFMZ3skJwLt8Z1F6Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1599857"},{"name":"Li Zixuan","name_vi":null,"name_original":"Li Zixuan","tmdb_id":3091322,"profile":"https://image.tmdb.org/t/p/w500/2P9n2dwqRXFx5InDfxdNLsN6NAn.jpg","tmdb_url":"https://www.themoviedb.org/person/3091322"},{"name":"June Wu","name_vi":null,"name_original":"June Wu","tmdb_id":1842337,"profile":"https://image.tmdb.org/t/p/w500/wNLFI18YOnOKjOsiVDi7mSwVTWK.jpg","tmdb_url":"https://www.themoviedb.org/person/1842337"},{"name":"Chung Lệ Lệ","name_vi":"Chung Lệ Lệ","name_original":"Zhong Lili","tmdb_id":2876779,"profile":"https://image.tmdb.org/t/p/w500/npfc7abyPKD7f7sXuuEm27MvTm4.jpg","tmdb_url":"https://www.themoviedb.org/person/2876779"},{"name":"Hà Hoa","name_vi":"Hà Hoa","name_original":"He Hua","tmdb_id":1973971,"profile":"https://image.tmdb.org/t/p/w500/lfKLBNaDKC32YqPwRknhOg4ZFHh.jpg","tmdb_url":"https://www.themoviedb.org/person/1973971"},{"name":"Phùng Lệ Quân","name_vi":"Phùng Lệ Quân","name_origina