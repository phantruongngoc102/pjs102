656e","link_m3u8":"https://vip.opstream90.com/20251213/20012_6eab78f1/index.m3u8"}]}],"description":"<p>Sinh viên thiên tài Lâm Đông Phong được chính phủ tuyển dụng để lãnh đạo một nhóm nghiên cứu đặc biệt về phản ứng tổng hợp hạt nhân có kiểm soát sau khi các lý thuyết trực tuyến của anh được quốc tế chú ý. Khi đang nỗ lực hướng tới một đột phá khoa học mang tính đột phá, anh phải đối mặt với sự phá hoại từ các đối thủ cạnh tranh, sự giám sát nội bộ nghiêm ngặt, và những căng thẳng mà nó gây ra cho mối quan hệ của anh với bạn gái Trịnh Vạn Trí.</p>","tmdb_id":307163,"cast":["Wang Jiaxuan","Tian Tianyi","Li Anqi","Meng Tianyin","Zhang Yunqing","Zheng Xiaomao"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"307163","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Wang Jiaxuan","name_vi":null,"name_original":"Wang Jiaxuan","tmdb_id":4015041,"profile":"https://image.tmdb.org/t/p/w500/hbDBOaNLIS08BKiG4k7GiHOHF6n.jpg","tmdb_url":"https://www.themoviedb.org/person/4015041"},{"name":"Tian Tianyi","name_vi":null,"name_original":"Tian Tianyi","tmdb_id":5743368,"profile":"https://image.tmdb.org/t/p/w500/4UxkdnCcMqQXWlyxeIn4o33fUuW.jpg","tmdb_url":"https://www.themoviedb.org/person/5743368"},{"name":"Li Anqi","name_vi":null,"name_original":"Li Anqi","tmdb_id":5849874,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5849874"},{"name":"Meng Tianyin","name_vi":null,"name_original":"Meng Tianyin","tmdb_id":5521998,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5521998"},{"name":"Zhang Yunqing","name_vi":null,"name_original":"Zhang Yunqing","tmdb_id":5715770,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5715770"},{"name":"Zheng Xiaomao","name_vi":null,"name_original":"Zheng Xiaomao","tmdb_id":2876433,"profile":"https://image.tmdb.org/t/p/w500/oZRX0BTJmph7RFzEhbo8oXKYe9x.jpg","tmdb_url":"https://www.themoviedb.org/person/2876433"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubj