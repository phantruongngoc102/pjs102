ghĩa. Trong quá trình xóa bỏ mê tín dị đoan của người đời, hai người dần trở thành anh em tốt, sống chết có nhau.</p>","tmdb":{"type":"tv","id":"154207","season":1,"vote_average":3.5,"vote_count":2},"modified":"2022-06-14T13:42:29.000Z","cast":["Trương Vũ Kiếm","Lương Khiết","Wu Chongxuan","Liao Yinyue","Ma Li"],"director":["Triệu Tuấn Khải"],"cast_meta":[{"name":"Trương Vũ Kiếm","name_vi":"Trương Vũ Kiếm","name_original":"Zhang Yujian","tmdb_id":2153506,"profile":"https://image.tmdb.org/t/p/w500/shy21Z8rfTcITRGUFpzCs8k0AQ7.jpg","tmdb_url":"https://www.themoviedb.org/person/2153506"},{"name":"Lương Khiết","name_vi":"Lương Khiết","name_original":"Liang Jie","tmdb_id":1855300,"profile":"https://image.tmdb.org/t/p/w500/pYYvBkKizMO8vulvZNNdqEkEYPL.jpg","tmdb_url":"https://www.themoviedb.org/person/1855300"},{"name":"Wu Chongxuan","name_vi":null,"name_original":"Wu Chongxuan","tmdb_id":3155364,"profile":"https://image.tmdb.org/t/p/w500/q3ApJks5TKfLJdvQblzZHnTp70c.jpg","tmdb_url":"https://www.themoviedb.org/person/3155364"},{"name":"Liao Yinyue","name_vi":null,"name_original":"Liao Yinyue","tmdb_id":2529344,"profile":"https://image.tmdb.org/t/p/w500/sRVuCqyk2x6Ro2UxpVtR1A5k6ow.jpg","tmdb_url":"https://www.themoviedb.org/person/2529344"},{"name":"Ma Li","name_vi":null,"name_original":"Ma Li","tmdb_id":2300712,"profile":"https://image.tmdb.org/t/p/w500/e0i0dL9Wz8Zq4dqpyB2PFIxyM8k.jpg","tmdb_url":"https://www.themoviedb.org/person/2300712"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nhiet-huyet-than-tham.json"}