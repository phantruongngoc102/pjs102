tream13.com/share/970627414218ccff3497cb7a784288f5","link_m3u8":"https://vip.opstream13.com/20250909/7011_97062741/index.m3u8"},{"name":"19","slug":"19","filename":"TVB Như Lai Thần Chưởng Tái Chiến Giang Hồ 19#20 # tiếng Việt # Quan Lễ Kiệt, Thái Thiếu Phân # 1993","link_embed":"https://vip.opstream13.com/share/55fd1368113e5a675e868c5653a7bb9e","link_m3u8":"https://vip.opstream13.com/20250909/7012_55fd1368/index.m3u8"},{"name":"20","slug":"20","filename":"TVB Như Lai Thần Chưởng Tái Chiến Giang Hồ 20#20 # tiếng Việt # Quan Lễ Kiệt, Thái Thiếu Phân # 1993","link_embed":"https://vip.opstream13.com/share/e894d787e2fd6c133af47140aa156f00","link_m3u8":"https://vip.opstream13.com/20250909/7013_e894d787/index.m3u8"}]}],"time":"45 phút/tập","description":"Như Lai Thần Chưởng là 1 võ thuật cao siêu, sau khi Long Kiếm Phi dùng môn chưởng này để đánh bại Thiên Tàn Cước thì ẩn cư và cấm con cháu luyện tập võ công này để tránh sự chém giết trong giang hồ. 70 năm sau con cháu của Phi là Long Kiếm Sinh trưởng thành, tuy không biết võ nghệ nhưng với sự thông minh lanh lợi, Sinh vẫn có thể lăn lộn trong giang hồ. Trong lúc đó thì bỗng Như Lai Thần Trưởng tái xuất giang hồ và công khai khiêu chiến với ngũ đại phái nhằm xưng bá võ lâm. Ngũ đại phái tưởng Sinh chính là kẻ đó nên truy sát Sinh, đồng thời hung thủ chính là Hòa Vân vì muốn đoạt lấy bí quyết của chiêu thứ 9 cũng truy sát Sinh ... Trong khi bị truy sát Sinh gặp nhiều duyên cơ, nên võ công tiến bộ vượt bậc cuối cùng Sinh phát hiện được bí quyết của Như Lai Thần Chưởng đánh bại Hòa Vân ...","tmdb":{"type":"tv","id":"94905","season":1,"vote_average":8.5,"vote_count":2},"modified":"2025-09-22T14:17:48.000Z","cast":["Eddie Kwan Lai-Kit","Thái Thiếu Phân","Giang Hân Yến","Lưu Gia Huy","Catherine Hung Yan","Johnny Ngan","Yeung Tak-Si","Âu Thụy Vỹ","La Lan","Lý Long Cơ","Kwan Ching","La Lạc Lâm","La Mãng","Phùng Tố Ba","Vương Duy Đức"],"director":[],"cast_meta":[{"name":"Eddie Kwan Lai-Kit","name_vi":null,"name_original":"Eddie Kw