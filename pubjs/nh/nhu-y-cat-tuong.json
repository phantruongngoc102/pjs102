ex.m3u8"},{"name":"34","slug":"34","filename":"Như Ý Cát Tường 2003_34","link_embed":"https://vip.opstream12.com/share/ce737c887b558e8467dede8ca59029eb","link_m3u8":"https://vip.opstream12.com/20250925/28185_ce737c88/index.m3u8"},{"name":"35","slug":"35","filename":"Như Ý Cát Tường 2003_35","link_embed":"https://vip.opstream12.com/share/add6ab8551d16aa6fbe68c50f740cc94","link_m3u8":"https://vip.opstream12.com/20250925/28186_add6ab85/index.m3u8"},{"name":"36","slug":"36","filename":"Như Ý Cát Tường 2003_36","link_embed":"https://vip.opstream12.com/share/f52a97aeb3db83504088d414ae36a7b9","link_m3u8":"https://vip.opstream12.com/20250925/28187_f52a97ae/index.m3u8"}]}],"time":"45 phút/tập","description":"A broad comedy set in the Ching Dynasty, The Luckiest Man is Dai, the only son of a very rich family from the rural area. Frustrated by the village’s tolerance of men having multiple wives, Dai vows to be faithful to only one woman. But as luck would have it, Dai ends up having two wives himself. However, this is just the beginning of a string of unusual adventures for Dai, Which include his friendship with the young Ching Emperor! The Luckiest Man is a lighthearted historical fable about fidelity, true love, and the irony of destiny.\n\n(Source: yesasia.com)","tmdb":{"type":"tv","id":"107809","season":1,"vote_average":7,"vote_count":4},"modified":"2025-09-27T15:11:58.000Z","cast":["Quan Vịnh Hà","Xue Jianing","Yongxuan Yan","Yuan Hong","Trương Vệ Kiện","Trần Hảo","Darren Lim","Zhang Ruijia","Nhạc Dược Lợi","张柏俊","周岚","郭亮","Cuiyun Li","Xiaoyan Huang"],"director":["Fung Pak Yuen","Wai-Ming Wong"],"cast_meta":[{"name":"Quan Vịnh Hà","name_vi":"Quan Vịnh Hà","name_original":"Esther Kwan Wing-Ho","tmdb_id":979045,"profile":"https://image.tmdb.org/t/p/w500/mMJpoUGwEyPloyuzTWijQuJav3p.jpg","tmdb_url":"https://www.themoviedb.org/person/979045"},{"name":"Xue Jianing","name_vi":null,"name_original":"Xue Jianing","tmdb_id":2065137,"profile":"https://image.tmdb.org/t/p/w500/pDhfKQo