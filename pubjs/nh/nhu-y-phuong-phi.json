eam13.com/share/121f6f951ebe28c187c975e6c17c081d","link_m3u8":"https://vip.opstream13.com/20251206/21316_121f6f95/index.m3u8"}]}],"description":"<p>Nhị tiểu thư Phó Dung bỗng dưng có năng lực nhìn thấy tương lai qua giấc mơ sau một cơn bạo bệnh. Sau khi có năng lực Phó Dung đã biết trước được việc bản thân mình sắp tới sẽ gặp tai họa và một trong số đó chính là bị gả cho Túc Vương Từ Tấn. Chưa dừng ở mức phải lấy một tên mà mình không hề có tình cảm, nàng còn sẽ bị tuẫn táng (tục chôn người sống theo người chết) cùng hắn. Không để cho số phận đưa đẩy mình, Phó Dung quyết thay đổi nó bằng cách trốn tránh quyết không gả cho Từ Tấn. Và rồi nàng lại không ngờ rằng Từ Tấn cũng có năng lực nhìn thấy được tương lai qua giấc mơ giống như nàng, dù biết trước kết cục nhưng hắn vẫn truy tìm Phó Dung với mong muốn được bù đắp cho nàng một tình yêu đúng nghĩa.</p>","tmdb_id":111615,"cast":["Cúc Tịnh Y","Trương Triết Hạn","Liu Yichang","Vương Hữu Thạc"],"director":["Kin-lung Lam","Tony"],"keywords":[],"tmdb":{"type":"tv","id":"111615","season":1,"vote_average":7.111,"vote_count":10},"cast_meta":[{"name":"Cúc Tịnh Y","name_vi":"Cúc Tịnh Y","name_original":"Ju Jingyi","tmdb_id":1686990,"profile":"https://image.tmdb.org/t/p/w500/xbyH30PEsDMFf1JP3BNYCegkDLP.jpg","tmdb_url":"https://www.themoviedb.org/person/1686990"},{"name":"Trương Triết Hạn","name_vi":"Trương Triết Hạn","name_original":"Zhang Zhehan","tmdb_id":1940475,"profile":"https://image.tmdb.org/t/p/w500/t6wqEQsktu9ojCoQv3YmmklpeTM.jpg","tmdb_url":"https://www.themoviedb.org/person/1940475"},{"name":"Liu Yichang","name_vi":null,"name_original":"Liu Yichang","tmdb_id":2609007,"profile":"https://image.tmdb.org/t/p/w500/sfYQAiJY1y5Y0X6kCyiIePiRrjG.jpg","tmdb_url":"https://www.themoviedb.org/person/2609007"},{"name":"Vương Hữu Thạc","name_vi":"Vương Hữu Thạc","name_original":"Wang Youshuo","tmdb_id":2097508,"profile":"https://image.tmdb.org/t/p/w500/ckuIZ8UNalPr6BoPsbou1s3X5z9.jpg","tmdb_url":"https://www.themoviedb.org/person/20