ream11.com/share/dcd38e1b67396751a80e9e69f5ccf1b1","link_m3u8":"https://vip.opstream11.com/20220508/23847_f156fcaa/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream11.com/share/8dd99f719edf43e07427cc78a3549648","link_m3u8":"https://vip.opstream11.com/20220508/23848_ae148749/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream11.com/share/6481ebf1168330ca0f7bb56c51c5630f","link_m3u8":"https://vip.opstream11.com/20220508/23849_ece1986a/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream11.com/share/bab2a4505dc27efff8e4c894be13c29d","link_m3u8":"https://vip.opstream11.com/20220508/23850_51ee3dfa/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream11.com/share/bd45d8a6bb9dbb92510b15c3cf2d4a7a","link_m3u8":"https://vip.opstream11.com/20220508/23851_78c5976d/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream11.com/share/11ecb0a77c9ccfd461881ce6b8338411","link_m3u8":"https://vip.opstream11.com/20220508/23852_00c9f3c3/index.m3u8"}]}],"description":"<p>Izumi Norimoto và Kazusa Onodera giống như 2 chị em ruột, cùng chơi cùng cười với nhau khi còn nhỏ. Nhưng khi lên cấp 2, cùng với những thay đổi của cơ thể, Kazusa bắt đầu nhìn Izumi theo một cách khác. Và không may thay, những nữ sinh khác cũng nhìn Izumi như cách Kazusa đang nhìn cậu. Quá mệt mỏi, Kazusa đã quyết định giữ khoảng cách với Izumi khi cả 2 vào trung học. Tuy nhiên, sau khi tham gia vào câu lạc văn học, tâm trí của cô đã hoàn toàn được lấp đầy bởi những người bạn ở đây. Mọi giáo viên trong trường học đều e ngại và từ chối nhận làm cố vấn cho câu lạc bộ văn học bởi hoạt động đọc to những cảnh quan hệ tình dục trong tiểu thuyết của câu lạc bộ. Với trái tim đang loạn nhịp và nguy cơ câu lạc bộ văn học phải giải tán, 5 cô gái sẽ phải làm gì để không đánh mất chính mình và câu lạc bộ văn học đây?</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nhung-co-gai-trong-thoi-ki-ngo-ngao.json"}