5.com/share/022deef5f842e7b026e57398f3964a7d","link_m3u8":"https://vip.opstream15.com/20220503/10969_cb956663/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream15.com/share/51a93b1b7421fc7ca001d7793eadb53b","link_m3u8":"https://vip.opstream15.com/20220503/10970_56080c2f/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/164fbf608021ece8933758ee2b28dd7d","link_m3u8":"https://vip.opstream15.com/20220503/10971_947be837/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream15.com/share/234b941e88b755b7a72a1c1dd5022f30","link_m3u8":"https://vip.opstream15.com/20220503/10972_60e93309/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream15.com/share/b1c14790bce31f481f50e49de3542a85","link_m3u8":"https://vip.opstream15.com/20220503/10973_fc261d24/index.m3u8"}]}],"description":"<p>Trong cái thế giới đầy tăm tối nơi mà niềm tin thì mù quáng còn kiến thức thì lại xa xỉ, đã sản sinh một người đàn ông vĩ đại, người đã chiến đấu để đem lại sự tự do về kiến thức, về hiểu biết cho mọi người. Seri này sẽ kể về cuộc đời và sự nghiệp của Leonardo da Vinci, về những bất công, khổ cực và cả những niềm vui mà một người thiên tài như ông đã trải qua. Ông là một kẻ dị giáo, người chống lại những sai lầm của tôn giáo. Một đội quân bí mật đang cố gắng lật đổ cái xã hội đầy hào nhoáng mà nhơ nhuốc ấy. Một người con trai khao khát tình cảm với người cha của mình. Ông thấy con người mình đang trong một cơn bão được ấp ủ từ nhiều thế kỉ qua. Một cuộc chiến giữa sự thật và dối trá, tôn giáo và lý trí, quá khứ và tương lai...</p>","tmdb_id":40293,"cast":[],"director":[],"keywords":[],"tmdb":{"id":40293},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nh/nhung-con-quy-cua-da-vinci-phan-3.json"}