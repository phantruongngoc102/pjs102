{"id":"623c6ec180a88d9a484be9a9","title":"Những Nhà Văn Tự Do","origin_name":"Freedom Writers","slug":"nhung-nha-van-tu-do","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/nh/nhung-nha-van-tu-do.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/nh/nhung-nha-van-tu-do.webp","year":2007,"type":"single","genre":[{"id":"620a2238e0fc277084dfd291","name":"Tâm Lý","slug":"tam-ly"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620e0e8fd9648f114cde77f7","name":"Đức","slug":"duc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Những Nhà Văn Tự Do","link_embed":"https://vip.opstream10.com/share/1ef91c212e30e14bf125e9374262401f","link_m3u8":"https://vip.opstream10.com/20220324/1684_bd093006/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Đó là năm 1994 tại Long Beach, California. Erin Gruwell duy tâm chỉ mới bắt đầu công việc giảng dạy đầu tiên của mình, đó là giáo viên tiếng Anh và sinh viên năm thứ hai tại trường trung học Woodrow Wilson, hai năm trước, đã thực hiện một chương trình tích hợp tự nguyện. Đối với nhiều giáo viên hiện tại, sự tích hợp đã hủy hoại trường học, có vị học thuật Stellar trước đây đã được thay thế bằng nhiều sinh viên sẽ may mắn khi tốt nghiệp hoặc thậm chí là biết chữ. Mặc dù đã chọn trường về mục đích vì chương trình tích hợp, Erin không chuẩn bị cho bản chất của lớp học của cô, người có học sinh sống theo các thế hệ của các quy tắc đạo đức nghiêm ngặt của việc bảo vệ tất cả các chi phí. Nhiều người đang ở trong các băng đảng và hầu hết tất cả đều biết ai đó đã bị giết bởi bạo lực băng đảng. Người Latin ghét những người Campuchia ghét người da đen và vân vân. Người duy nhất học sinh ghét nhiều hơn là cô Gruwell. Cho đến khi Erin giữ một cuộc thảo luận chưa được thực hiện về một ổ đĩa gần đây, bằng cách bắn chết rằng cô ấy bắt đầu hoàn toàn để hiểu những gì cô ấy chống lại. Và đó không phải là cho đến khi cô ấy cung cấp một nhiệm vụ viết một tạp chí hàng ngày - sẽ không được chấm điểm, và sẽ vẫn chưa đọc được bởi cô ấy trừ khi họ chọn - rằng các sinh viên bắt đầu mở ra cho cô ấy. Khi Erin cố gắng hơn và khó hơn để có các nguồn lực được cung cấp để giảng dạy đúng cách (thường dẫn đến việc cô ấy cần phải trả tiền cho họ thông qua công việc thứ hai và thứ ba), cô ấy có vẻ phải đối mặt với sự kháng cự lớn hơn, đặc biệt là từ các đồng nghiệp của cô ấy, chẳng hạn như Margaret Campbell, Phần đầu của cô, người sống theo các quy định và thấy những nguồn lực như một sự lãng phí và Brian Gelford, người sẽ bảo vệ vị trí \"tư nhân\" của mình về việc dạy các lớp Honours Honours hoàn toàn. Erin cũng thấy rằng công việc giảng dạy của cô đang đặt một căng thẳng cho cuộc hôn nhân của mình với Scott Casey, một người đàn ông dường như đã mất cách lý tưởng của riêng mình trong cuộc sống.</p>","tmdb":{"type":"movie","id":"1646","season":null,"vote_average":7.922,"vote_count":2369},"modified":"2023-09-24T12:18:45.000Z","cast":["Hilary Swank","Patrick Dempsey","Scott Glenn","Imelda Staunton","April Hernandez Castillo","Mario","Kristin Herrera","Jaclyn Ngan","Sergio Montalvo","Jason Finn","Deance Wyatt","Vanetta Smith","Gabriel Chavarria","Hunter Parrish","Antonio García"],"director":["Richard LaGravenese"],"cast_meta":[{"name":"Hilary Swank","name_vi":null,"name_original":"Hilary Swank","tmdb_id":448,"profile":"https://image.tmdb.org/t/p/w500/uin6aAehUGpPCiJCaSjZG8B7M7d.jpg","tmdb_url":"https://www.themoviedb.org/person/448"},{"name":"Patrick Dempsey","name_vi":null,"name_original":"Patrick Dempsey","tmdb_id":18352,"profile":"https://image.tmdb.org/t/p/w500/2PpaYtXdaDmNi3jap4qPIdyVesL.jpg","tmdb_url":"https://www.themoviedb.org/person/18352"},{"name":"Scott Glenn","name_vi":null,"name_original":"Scott Glenn","tmdb_id":349,"profile":"https://image.tmdb.org/t/p/w500/8DHORod2l6ZFS9KR0gNAAM3WZfI.jpg","tmdb_url":"https://www.themoviedb.org/person/349"},{"name":"Imelda Staunton","name_vi":null,"name_original":"Imelda Staunton","tmdb_id":11356,"profile":"https://image.tmdb.org/t/p/w500/96LYLMnUOWZ4DFXEeQPItNsxzEP.jpg","tmdb_url":"https://www.themoviedb.org/person/11356"},{"name":"April Hernandez Castillo","name_vi":null,"name_original":"April Hernandez Castillo","tmdb_id":18353,"profile":"https://image.tmdb.org/t/p/w500/lElddc3ZK3XYrgfg5SkxrLYhvmm.jpg","tmdb_url":"https://www.themoviedb.org/person/18353"},{"name":"Mario","name_vi":null,"name_original":"Mario","tmdb_id":58961,"profile":"https://image.tmdb.org/t/p/w500/xSGbdak61CPiY26pBnD88ekRbcj.jpg","tmdb_url":"https://www.themoviedb.org/person/58961"},{"name":"Kristin Herrera","name_vi":null,"name_original":"Kristin Herrera","tmdb_id":35229,"profile":"https://image.tmdb.org/t/p/w500/sZrtXma96gJEniWq0njdX6td5QT.jpg","tmdb_url":"https://www.themoviedb.org/person/35229"},{"name":"Jaclyn Ngan","name_vi":null,"name_original":"Jaclyn Ngan","tmdb_id":35238,"profile":"https://image.tmdb.org/t/p/w500/wMVd2U881qmHgkUtF1YXJqgDhB7.jpg","tmdb_url":"https://www.themoviedb.org/person/35238"},{"name":"Sergio Montalvo","name_vi":null,"name_original":"Sergio Montalvo","tmdb_id":35239,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/35239"},{"name":"Jason Finn","name_vi":null,"name_original":"Jason Finn","tmdb_id":994886,"profile":"https://image.tmdb.org/t/p/w500/wBBfNJN6Frb7jAvDIHXn562UmOg.jpg","tmdb_url":"https://www.themoviedb.org/person/994886"},{"name":"Deance Wyatt","name_vi":null,"name_original":"Deance Wyatt","tmdb_id":35230,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/35230"},{"name":"Vanetta Smith","name_vi":null,"name_original":"Vanetta Smith","tmdb_id":35237,"profile":null,"tmdb_url":"https://www.themoviedb.org/pers