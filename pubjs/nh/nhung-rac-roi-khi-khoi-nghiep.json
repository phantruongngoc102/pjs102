g giúp đỡ nhau, vượt qua sự lạnh lẽo của tình yêu, tình bạn và tình thân...</p>","tmdb_id":117760,"cast":["Lâm Tâm Như","Ivy Chen","Jian Man-shu","Khưu Trạch","Li Yuanyuan","JC Lin","Alan Kuo","Chris Wang","Lý Lập Quần","Pauline Lan","Yen Yi-wen","Lin Chih-ju","Oscar Chiu","Rexen Cheng","Chen Chia-kuei"],"director":["許肇任","Feng Rui"],"keywords":[],"time":"44M48S","tmdb":{"type":"tv","id":"117760","season":1,"vote_average":6.3,"vote_count":6},"cast_meta":[{"name":"Lâm Tâm Như","name_vi":"Lâm Tâm Như","name_original":"Ruby Lin","tmdb_id":113311,"profile":"https://image.tmdb.org/t/p/w500/jhATD1TKubFUbaHnwtRXVvmq3sW.jpg","tmdb_url":"https://www.themoviedb.org/person/113311"},{"name":"Ivy Chen","name_vi":null,"name_original":"Ivy Chen","tmdb_id":126776,"profile":"https://image.tmdb.org/t/p/w500/h2C6e67v7ULbYOF9Bj09Q9UxSQY.jpg","tmdb_url":"https://www.themoviedb.org/person/126776"},{"name":"Jian Man-shu","name_vi":null,"name_original":"Jian Man-shu","tmdb_id":1261136,"profile":"https://image.tmdb.org/t/p/w500/lias9SVpB67mQsrvESwDNEAlDKa.jpg","tmdb_url":"https://www.themoviedb.org/person/1261136"},{"name":"Khưu Trạch","name_vi":"Khưu Trạch","name_original":"Roy Chiu","tmdb_id":1240922,"profile":"https://image.tmdb.org/t/p/w500/127xWzEkBLNlNko4FIBB18AOc4L.jpg","tmdb_url":"https://www.themoviedb.org/person/1240922"},{"name":"Li Yuanyuan","name_vi":null,"name_original":"Li Yuanyuan","tmdb_id":2867405,"profile":"https://image.tmdb.org/t/p/w500/nHWZ3PucUQW9uG10uia015FFEkC.jpg","tmdb_url":"https://www.themoviedb.org/person/2867405"},{"name":"JC Lin","name_vi":null,"name_original":"JC Lin","tmdb_id":1907471,"profile":"https://image.tmdb.org/t/p/w500/i9EP9fLy62SEIx3FWsFypE8Z714.jpg","tmdb_url":"https://www.themoviedb.org/person/1907471"},{"name":"Alan Kuo","name_vi":null,"name_original":"Alan Kuo","tmdb_id":993833,"profile":"https://image.tmdb.org/t/p/w500/g8IxQtqtNrthAGCgGI7H5aGXcAr.jpg","tmdb_url":"https://www.themoviedb.org/person/993833"},{"name":"Chris Wang","name_vi":null,"n