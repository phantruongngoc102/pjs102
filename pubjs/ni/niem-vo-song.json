2ba/index.m3u8"},{"name":"31","slug":"31","filename":"(Thuyết Minh  Vietsub) A.Moment.But.Forever.S01E31.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB (1)","link_embed":"https://vip.opstream90.com/share/7d571e5c15bad5ef8c4352ce7a1d9e78","link_m3u8":"https://vip.opstream90.com/20250408/3977_7d571e5c/index.m3u8"},{"name":"32","slug":"32","filename":"(Thuyết Minh  Vietsub) A.Moment.But.Forever.S01E32.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB (1)","link_embed":"https://vip.opstream90.com/share/a8badd37c221a3f19d9ad0ac2196849a","link_m3u8":"https://vip.opstream90.com/20250408/3978_a8badd37/index.m3u8"},{"name":"33","slug":"33","filename":"(Thuyết Minh  Vietsub) A.Moment.But.Forever.S01E33.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB (1)","link_embed":"https://vip.opstream90.com/share/a58616464d14208b2677a084f5d7456f","link_m3u8":"https://vip.opstream90.com/20250408/3979_a5861646/index.m3u8"},{"name":"34","slug":"34","filename":"(Thuyết Minh  Vietsub) A.Moment.But.Forever.S01E34.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB (1)","link_embed":"https://vip.opstream90.com/share/a0443c8c8c3372d662e9173c18faaa2c","link_m3u8":"https://vip.opstream90.com/20250408/3982_a0443c8c/index.m3u8"},{"name":"35","slug":"35","filename":"(Thuyết Minh  Vietsub) A.Moment.But.Forever.S01E35.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB (1)","link_embed":"https://vip.opstream90.com/share/5e4450dc93010bbeea7cd28eba296850","link_m3u8":"https://vip.opstream90.com/20250408/3983_5e4450dc/index.m3u8"},{"name":"36","slug":"36","filename":"(Thuyết Minh  Vietsub) A.Moment.But.Forever.S01E36.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB (1)","link_embed":"https://vip.opstream90.com/share/7059b7dea43da04fd342088d7c1698f0","link_m3u8":"https://vip.opstream90.com/20250408/3984_7059b7de/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>\"Niệm Vô Song\" là bộ phim kiếm hiệp tình yêu do Quách Hổ đạo diễn, có sự tham gia của Đường Yên và Lưu Học Nghĩa. Bộ phim dựa trên tiểu thuyết \"Thiên Hạ Vô Song\" của Thập Tứ Lang, kể về thánh nữ Vô Song hạ phàm để ám sát Nguyên Trọng - Tộc trưởng của Hồ tộc, nhằm đem thánh vật của thần giới trở về. Tuy nhiên, cô phát hiện ra rằng có những bí mật ẩn giấu trong việc này. Trong quá trình điều tra, cả hai rơi vào lưới tình, tay nắm bàn tay lưu lại truyền kỳ cho nhân giới. Cuộc chiến giữa thần và ma, Sơ Thần Thái Hòa nhờ có cổ vật \"Thần Thủ\" mới phong ấn được Ma Thần. Nhưng \"Thần Thủ\" lại bị chặt đứt và rơi xuống nhân gian, Thái Hòa cùng các thần khác chìm vào ngủ yên. Từ đó, thế nhân không còn thấy dấu vết của thần. Nhân cơ hội đó tộc Chiến Quỷ đã phát động chiến tranh, Nguyên Trọng của Hồ tộc đã giành được \"Thần Thủ\" để đánh bại gia Chiến Quỷ, mở ra một thời thịnh thế vang danh. Từ đó, Hồ tộc trở thành Hậu Thần mới được thế nhân tôn sùng. Thiên Thần Vô Song được ủy thác từ thần giới, hóa thân thành thiếu nữ thế nhân và gia nhập Hồ tộc để làm người hầu của Nguyên Trọng. Mục tiêu của cô là lấy lại \"Thần Thủ\". Nhưng Vô Song phát hiện ra rằng Nguyên Trọng, người có thể chống lại \"Thần Thủ\" lại bị tộc nhân vu oan và xa lánh. Lòng cô đau như cắt, quyết định bảo vệ Nguyên Trọng, giải thoát cho anh và cùng anh trải qua những khoảnh khắc cuối cùng của cuộc đời mình. Trong khi đó, Nguyên Trọng lại có ý định riêng - trốn thoát và phá hủy thế giới. Sự trở lại của tộc chiến quỷ gây ra sự hoang mang bên trong Hồ tộc. Nguyên Trọng tận dụng cơ hội để mở phong ấn. Nhưng trên bước đường này, anh đã được Vô Song cảm hóa. Cuối cùng hai người thổ lộ tình cảm và thấu hiểu lòng nhau. Theo đó, nam chính bị phản diện lợi dụng tình cảm này để tự cắt mất bàn tay thần. Vô Song cũng rơi vào chiếc bẫy của phản diện. Tựu lại, Nguyên Trọng cứu được Vô Song, hai người cùng nhau đánh bại Hàn Nữ và khôi phục trật tự thế giới.</p>","tmdb":{"type":"tv","id":"235611","season":1,"vote_average":6.6,"vote_count":8},"modified":"2025-04-08T19:44:20.000Z","cast":["Đường Yên","Lưu Học Nghĩa","Quách Hiểu Đình","Vương Hoằng Nghị","Châu Kha Vũ","Trương Lệ"],"director":["Hồ Quốc"],"cast_meta":[{"name":"Đường Yên","name_vi":"Đường Yên","name_original":"Tang Yan","tmdb_id":99691,"profile":"https://image.tmdb.org/t/p/w500/eW3F16Namf5EoCmeWaTdkd3ncoH.jpg","tmdb_url":"https://www.themoviedb.org/person/99691"},{"name":"Lưu Học Nghĩa","name_vi":"Lưu Học Nghĩa","name_original":"Liu Xueyi","tmdb_id":2084467,"profile":"https://image.tmdb.org/t/p/w500/zJG3K9Ey4EJp9p2wu88UchkgRG0.jpg","tmdb_url":"https://www.themoviedb.org/person/2084467"},{"name":"Quách Hiểu Đình","name_vi":"Quách Hiểu Đình","name_original":"Guo Xiaoting","tmdb_id":1513376,"profile":"https://image.tmdb.org/t/p/w500/3u7cgGNe0s35FhjuOnNfytiJ0Z8.jpg","tmdb_url":"https://www.themoviedb.org/person/1513376"},{"name":"Vương Hoằng Nghị","name_vi":"Vương Hoằng Nghị","name_original":"Wang Hongyi","tmdb_id":3715156,"profile":"https://image.tmdb.org/t/p/w500/6rUH7NxarCBHRDbSmtPisgJq7pn.jpg","tmdb_url":"https://www.themoviedb.org/person/3715156"},{"name":"Châu Kha Vũ","name_vi":"Châu Kha Vũ","name_original":"Daniel Zhou","tmdb_id":2986719,"profile":"https://image.tmdb.org/t/p/w500/vbouvEZoWedKOg7F7GK4UF46yyM.jpg","tmdb_url":"https://www.themoviedb.org/person/2986719"},{"name":"Trương Lệ","name_vi":"Trương Lệ","name_original":"Zhang Li","tmdb_id":1993060,"profile":"https://image.tmdb.org/t/p/w500/eEvYNGg8NnyQlH1wWUcXdWvDEMB.jpg","tmdb_url":"https://www.themoviedb.org/person/1993060"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ni/niem-vo-song.json"}