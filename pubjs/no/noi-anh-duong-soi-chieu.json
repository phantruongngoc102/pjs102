 Wol có tiếp tục yêu Kim Yoo Wol trong một thân xác mới?</p>","tmdb_id":89765,"cast":["Oh Chang-seok","Yoon So-Yi","Choi Sung-jae","Ha Si-eun","Ji Chan","Jung Han-yong","Lee Duk-hee"],"director":["Kim Won Yong"],"keywords":[],"tmdb":{"type":"tv","id":"89765","season":1,"vote_average":6.5,"vote_count":2},"cast_meta":[{"name":"Oh Chang-seok","name_vi":null,"name_original":"Oh Chang-seok","tmdb_id":1066220,"profile":"https://image.tmdb.org/t/p/w500/k28KzPVKgVrZWZA7KwURX6duuS9.jpg","tmdb_url":"https://www.themoviedb.org/person/1066220"},{"name":"Yoon So-Yi","name_vi":null,"name_original":"Yoon So-Yi","tmdb_id":77281,"profile":"https://image.tmdb.org/t/p/w500/dSTDaq16vscz06UmV58dH3nIEkr.jpg","tmdb_url":"https://www.themoviedb.org/person/77281"},{"name":"Choi Sung-jae","name_vi":null,"name_original":"Choi Sung-jae","tmdb_id":1798502,"profile":"https://image.tmdb.org/t/p/w500/9HtUUsa1YJzmKkdm8kBgR3tjK9C.jpg","tmdb_url":"https://www.themoviedb.org/person/1798502"},{"name":"Ha Si-eun","name_vi":null,"name_original":"Ha Si-eun","tmdb_id":2046478,"profile":"https://image.tmdb.org/t/p/w500/lQcBXTWfvA7lXFcv1wtWMtr7i1Y.jpg","tmdb_url":"https://www.themoviedb.org/person/2046478"},{"name":"Ji Chan","name_vi":null,"name_original":"Ji Chan","tmdb_id":2323038,"profile":"https://image.tmdb.org/t/p/w500/c0jt2MoFMM3fCuzpiuK6OLgAPbR.jpg","tmdb_url":"https://www.themoviedb.org/person/2323038"},{"name":"Jung Han-yong","name_vi":null,"name_original":"Jung Han-yong","tmdb_id":147588,"profile":"https://image.tmdb.org/t/p/w500/mgdMp6oS2w3QogcvvEwGofrdgKf.jpg","tmdb_url":"https://www.themoviedb.org/person/147588"},{"name":"Lee Duk-hee","name_vi":null,"name_original":"Lee Duk-hee","tmdb_id":6119419,"profile":"https://image.tmdb.org/t/p/w500/wt6H5kocGrlWRIrkrnayj5LeK89.jpg","tmdb_url":"https://www.themoviedb.org/person/6119419"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/no/noi-anh-duong-soi-chieu.json"}