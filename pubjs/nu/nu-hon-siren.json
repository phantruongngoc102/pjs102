u Seol-ah là <strong>kẻ sát nhân</strong>, hay chỉ là <strong>nạn nhân của một âm mưu đen tối</strong>, trước khi chính mạng sống của anh trở thành cái giá phải trả cho sự thật.</p>","tmdb":{"type":"tv","id":"310800","season":1,"vote_average":6.688,"vote_count":24},"modified":"2026-04-09T20:23:00.000Z","cast":["Park Min-young","Wi Ha-jun","Kim Jung-hyun","Han Jun-woo","Kong Seong-ha","Hong Gi-jun","Kim Keum-soon","Ha Seok-jin","Yoon Jong-hoon","Jung Eui-jae","Kim Dong-jun","Heo Jae-ho","Lee Elijah","Jung Lael","Song Lee-woo"],"director":["소재현","김철규"],"cast_meta":[{"name":"Park Min-young","name_vi":null,"name_original":"Park Min-young","tmdb_id":1234603,"profile":"https://image.tmdb.org/t/p/w500/5Op0Gx0DULFLHtGdWVdqnYdwkAS.jpg","tmdb_url":"https://www.themoviedb.org/person/1234603"},{"name":"Wi Ha-jun","name_vi":null,"name_original":"Wi Ha-jun","tmdb_id":1557181,"profile":"https://image.tmdb.org/t/p/w500/tEZuIaMESdBw4LfNq3vshGR4VlP.jpg","tmdb_url":"https://www.themoviedb.org/person/1557181"},{"name":"Kim Jung-hyun","name_vi":null,"name_original":"Kim Jung-hyun","tmdb_id":1619435,"profile":"https://image.tmdb.org/t/p/w500/6SN5PBj1ycfY4o9HlLK4joS5f1F.jpg","tmdb_url":"https://www.themoviedb.org/person/1619435"},{"name":"Han Jun-woo","name_vi":null,"name_original":"Han Jun-woo","tmdb_id":2699059,"profile":"https://image.tmdb.org/t/p/w500/uVxc53lfW7mhb4pOEMtJQ9ytp32.jpg","tmdb_url":"https://www.themoviedb.org/person/2699059"},{"name":"Kong Seong-ha","name_vi":null,"name_original":"Kong Seong-ha","tmdb_id":3329897,"profile":"https://image.tmdb.org/t/p/w500/u6qDnQ2EdtA3HDwtHfTrk969DPR.jpg","tmdb_url":"https://www.themoviedb.org/person/3329897"},{"name":"Hong Gi-jun","name_vi":null,"name_original":"Hong Gi-jun","tmdb_id":2467107,"profile":"https://image.tmdb.org/t/p/w500/jSWU103gfGXoLRYynQexdGHVnhf.jpg","tmdb_url":"https://www.themoviedb.org/person/2467107"},{"name":"Kim Keum-soon","name_vi":null,"name_original":"Kim Keum-soon","tmdb_id":2441975,"profile":"https://image.tmdb