share/45ddfa251d2530f6865be72a998b03dc","link_m3u8":"https://vip.opstream11.com/20220412/13815_20a84e04/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream11.com/share/43b136e4e130934ebda7768e3e728671","link_m3u8":"https://vip.opstream11.com/20220412/13816_2b0e3054/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream11.com/share/2aaee6030450367cb4236c87570c25a9","link_m3u8":"https://vip.opstream11.com/20220412/13817_5fd02aa1/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream11.com/share/a5dcd040486a679c3f649e721d8351dc","link_m3u8":"https://vip.opstream11.com/20220412/13818_89ee8a4d/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream11.com/share/29cb2d8a436d82bf5dbcca7ea09edc5c","link_m3u8":"https://vip.opstream11.com/20220412/13819_0758068e/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream11.com/share/51934729f32d36841a17e43e9390483a","link_m3u8":"https://vip.opstream11.com/20220412/13820_da7c4777/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream11.com/share/4ef5a564be51e55d5a1b86168a99f528","link_m3u8":"https://vip.opstream11.com/20220412/13821_d77b454d/index.m3u8"},{"name":"47","slug":"47","link_embed":"https://vip.opstream11.com/share/4ab3564cc099eb3b31a16042f06bd31e","link_m3u8":"https://vip.opstream11.com/20220412/13822_abe97a6f/index.m3u8"}]}],"description":"<p>Liễu Thanh Dương là một người yêu xe mô tô, anh đã cứu Trần Nhất Phàm trong một cuộc đua xe. Cùng lúc đó, ba của Thanh Dương qua đời, để lại một món nợ, anh và mẹ phải đến công trường xây dựng để sinh sống. Trần Nhất Phàm đã cứu anh và tuyển anh vào làm việc tại tập đoàn bất động sản Minh Đức. Được thúc đẩy bởi ý thức trách nhiệm phải chăm sóc mẹ và trả hết nợ, Thanh Dương cố gắng chăm chỉ làm việc và dần trưởng thành. Tập đoàn Minh Đức có nguy cơ bị nuốt chửng bởi bốn đối thủ cạnh tranh lớn, Liễu Thanh Dương đã nhờ Mai Đạo viễn tái xuất để cứu lấy tập đoàn Minh Đức. Mai Đạo Viễn chọn Thanh Dương làm người đại diện của mình. Mai Đạo Viễn dạy Liễu Thanh Dương môn võ Thái Cực - Thôi Thủ - để anh có thể hiểu được đạo lý làm người và chân lý trong kinh doanh.</p>","tmdb_id":87713,"cast":[],"director":[],"keywords":[],"tmdb":{"id":87713},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/nu/nu-nhan-cua-toi-la-quyen-su.json"}