":"https://vip.opstream90.com/20240827/3157_2b45e8d6/index.m3u8"},{"name":"6","slug":"6","filename":"Nữ Thám Tử Sherlock - Phần 1 - EP6","link_embed":"https://vip.opstream90.com/share/55d99a37b2e1badba7c8df4ccd506a88","link_m3u8":"https://vip.opstream90.com/20240827/3158_55d99a37/index.m3u8"},{"name":"7","slug":"7","filename":"Nữ Thám Tử Sherlock - Phần 1 - EP7","link_embed":"https://vip.opstream90.com/share/99ef04eb612baf0e86671a5109e22154","link_m3u8":"https://vip.opstream90.com/20240827/3159_99ef04eb/index.m3u8"},{"name":"8","slug":"8","filename":"Nữ Thám Tử Sherlock - Phần 1 - EP8","link_embed":"https://vip.opstream90.com/share/9808ae38758804501ca3fc0697050e03","link_m3u8":"https://vip.opstream90.com/20240827/3160_9808ae38/index.m3u8"}]}],"time":"60 phút/tập","description":"Lấy bối cảnh tại thành phố Tokyo thời hiện đại, hai nhân vật mang tính biểu tượng: Thám tử Sherlock Holmes và bác sỹ John Watson sẽ do hai nữ ngôi sao xinh đẹp người Nhật thủ vai - Yuko Takeuchi (trong vai Sherlock) và Shihori Janjiya (trong vai bác sĩ Wato Tachibana). Trong phiên bản Nhật này, nữ thám tử Sherlock (do diễn viên Yuko Takeuchi thủ vai) là một cô gái sinh ra tại Anh và quay trở lại Nhật Bản sinh sống. Vẫn giữ nguyên sự “lạnh lùng” và “lập dị” của nhân vật Sherlock nam, nữ thám tử Sherlock - nhà cố vấn điều tra cho cảnh sát địa phương “trung thành” với mái tóc ngắn và phong cách thời trang áo măng tô dáng dài cổ dựng. Thế nhưng, ẩn sâu bên trong cô gái lạ lùng này là óc quan sát tuyệt vời và khả năng phán đoán tài tình. Mồ côi cả cha lẫn mẹ từ năm 7 tuổi, Sherlock trở nên thờ ơ với mọi thứ và mọi người xung quanh mình.","tmdb":{"type":"tv","id":"79347","season":1,"vote_average":6.913,"vote_count":40},"modified":"2024-08-28T14:52:50.000Z","cast":["Yuko Takeuchi","Shihori Kanjiya","Kenichi Takitoh","Yukiyoshi Ozawa","Ran Ito","Tomoya Nakamura","Ryohei Otani","Yuki Saito"],"director":[],"cast_meta":[{"name":"Yuko Takeuchi","name_vi":null,"name_original":"Yuko Takeuchi","tmdb_id":277