pstream16.com/20220403/5827_9758ddd3/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>\"Oh My Venus” kể câu chuyện xoay quanh nàng luật sư thừa cân đang ra sức lấy lại vóc dáng. Cô tình cờ gặp một huấn luyện viên thể hình trái ngược về mọi mặt. Trong quá trình tập luyện để giảm cân, hai người đã cùng nhau hàn gắn những vết thương lòng và từ đó nảy sinh tình cảm. Bộ phim tình cảm hài này sẽ đề cao tình yêu dựa trên vẻ đẹp tâm hồn hơn là vẻ lung linh bên ngoài. So Ji Sub sẽ vào vai huấn luyện viên thể hình nổi tiếng và có gia thế giàu có, tên Kim Young Ho. Shin Min Ah sẽ vào vai nàng luật sư Kang Joo Eun, cô gái từng được rất nhiều người theo đuổi và vô cùng xinh đẹp.</p>","tmdb":{"type":"tv","id":"64320","season":1,"vote_average":8.082,"vote_count":377},"modified":"2023-07-10T10:02:14.000Z","cast":["So Ji-sub","Shin Min-a","Jung Gyu-woon","Yoo In-young","Sung Hoon","Henry Lau","Ban Hyo-jung","Choi Il-hwa","Choi Jin-ho","Jin Kyung","Kim Jung-tae","Cho Eun-ji","Kwon Ki-sun","Jung Hye-sung","Lee Seung-ho"],"director":["Kim Hyung-Suk"],"cast_meta":[{"name":"So Ji-sub","name_vi":null,"name_original":"So Ji-sub","tmdb_id":932821,"profile":"https://image.tmdb.org/t/p/w500/oEdXNo3ohtldtIW6DMFPpvMYW4g.jpg","tmdb_url":"https://www.themoviedb.org/person/932821"},{"name":"Shin Min-a","name_vi":null,"name_original":"Shin Min-a","tmdb_id":116175,"profile":"https://image.tmdb.org/t/p/w500/6CjxjYvZBuvbAQTcuoPb8EeVrUI.jpg","tmdb_url":"https://www.themoviedb.org/person/116175"},{"name":"Jung Gyu-woon","name_vi":null,"name_original":"Jung Gyu-woon","tmdb_id":1257639,"profile":"https://image.tmdb.org/t/p/w500/zgg2Xy4fGrBdRUefAN7eNVvcxON.jpg","tmdb_url":"https://www.themoviedb.org/person/1257639"},{"name":"Yoo In-young","name_vi":null,"name_original":"Yoo In-young","tmdb_id":1222951,"profile":"https://image.tmdb.org/t/p/w500/x0vOHmoA04xhImosJ2o4UOXxJxh.jpg","tmdb_url":"https://www.themoviedb.org/person/1222951"},{"name":"Sung Hoon","name_vi":null,"name_original":"Sung Hoon","tmdb_i