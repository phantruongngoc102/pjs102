ử. Những trải nghiệm tình cảm khác nhau ấy đã mang đến cho Thẩm Trác Nhiên sự trưởng thành mới. Những suy ngẫm của ông về tình yêu và cuộc sống cũng ảnh hưởng đến các thành viên trong gia đình luôn bên ông trên suốt chặng đường ấy.</p><p>&nbsp;</p>","tmdb_id":273117,"cast":["Trương Quốc Lập","Đồng Đại Vĩ","Mai Đình","Hứa Đệ","Zhou Yemang","Yang Tongshu","Yan Xiaopin","Ding Jiali","Ô Quân Mai","Zheng Weili","Wang Zhener","Shen Jiani","Qi Huan","Hàn Đồng Sinh","Niu Piao"],"director":["董富来"],"keywords":[],"tmdb":{"type":"tv","id":"273117","season":1,"vote_average":8.2,"vote_count":4},"cast_meta":[{"name":"Trương Quốc Lập","name_vi":"Trương Quốc Lập","name_original":"Zhang Guoli","tmdb_id":543178,"profile":"https://image.tmdb.org/t/p/w500/hNNFegPLSulMnqMWrlYtJmuob9k.jpg","tmdb_url":"https://www.themoviedb.org/person/543178"},{"name":"Đồng Đại Vĩ","name_vi":"Đồng Đại Vĩ","name_original":"Tong Dawei","tmdb_id":1031246,"profile":"https://image.tmdb.org/t/p/w500/rU2KjybHgkoeNeuLwoh5dYn6E2M.jpg","tmdb_url":"https://www.themoviedb.org/person/1031246"},{"name":"Mai Đình","name_vi":"Mai Đình","name_original":"Mei Ting","tmdb_id":131343,"profile":"https://image.tmdb.org/t/p/w500/90RGl03U4aRAHmpUuDMsal3NzSi.jpg","tmdb_url":"https://www.themoviedb.org/person/131343"},{"name":"Hứa Đệ","name_vi":"Hứa Đệ","name_original":"Xu Di","tmdb_id":2472971,"profile":"https://image.tmdb.org/t/p/w500/2Oo9R5lAIB98QfehaqgtEyEz7FZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2472971"},{"name":"Zhou Yemang","name_vi":null,"name_original":"Zhou Yemang","tmdb_id":554855,"profile":"https://image.tmdb.org/t/p/w500/jxYMVVHD2NqoUO9Lz2hXM3fsXi9.jpg","tmdb_url":"https://www.themoviedb.org/person/554855"},{"name":"Yang Tongshu","name_vi":null,"name_original":"Yang Tongshu","tmdb_id":2088240,"profile":"https://image.tmdb.org/t/p/w500/cXHOQDjJ193EWJm31jH5CJKuw2r.jpg","tmdb_url":"https://www.themoviedb.org/person/2088240"},{"name":"Yan Xiaopin","name_vi":null,"name_original":"Yan Xiaopin","tmdb_id":135899