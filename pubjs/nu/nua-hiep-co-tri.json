pstream12.com/20220620/21064_bdf102e3/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Nửa Hiệp Cơ Trí - Be Yourself kể về câu chuyện của 4 cô gái trẻ vừa bước vào cánh cửa đại học cùng những trải nghiệm và sự trưởng thành của họ. Bốn cô gái gồm: cô nàng tomboy bướng bỉnh Hạ Lãng Lãng, cô nàng nhà giàu xinh đẹp Phàn Tiêu Vũ, cô nàng \"mang bệnh công chúa\" Hoàng Phủ Thục Mẫn, và cô nàng nghiêm túc Dương Gia Thiến. Họ cùng nhau bắt đầu cuộc sống đại học vui vẻ nhưng cũng không ít va chạm và trưởng thành đã hiểu rõ về nhau, trở thành những người bạn thân thiết.</p>","tmdb":{"type":"tv","id":"129349","season":1,"vote_average":6.6,"vote_count":10},"modified":"2022-06-20T15:19:44.000Z","cast":["Vivienne Tien","Thẩm Nguyệt","Chương Nhược Nam","Zhang Xinyi","Liang Jingkang","Trạch Tử Lộ","Đinh Quán Sâm","Lý Giai Hàng","Zhang Zhihao","Ngô Hạnh Kiện"],"director":["Li Zhi"],"cast_meta":[{"name":"Vivienne Tien","name_vi":null,"name_original":"Vivienne Tien","tmdb_id":2762135,"profile":"https://image.tmdb.org/t/p/w500/iIMSjySpkMhgxIm1rzMJb089GUG.jpg","tmdb_url":"https://www.themoviedb.org/person/2762135"},{"name":"Thẩm Nguyệt","name_vi":"Thẩm Nguyệt","name_original":"Shen Yue","tmdb_id":1922808,"profile":"https://image.tmdb.org/t/p/w500/za5X2mJ8Q38jjo07ON0l3bP96AR.jpg","tmdb_url":"https://www.themoviedb.org/person/1922808"},{"name":"Chương Nhược Nam","name_vi":"Chương Nhược Nam","name_original":"Zhang Ruonan","tmdb_id":2174697,"profile":"https://image.tmdb.org/t/p/w500/7qFHUBL4qUusjOb4aCACYBKcb6C.jpg","tmdb_url":"https://www.themoviedb.org/person/2174697"},{"name":"Zhang Xinyi","name_vi":null,"name_original":"Zhang Xinyi","tmdb_id":3296267,"profile":"https://image.tmdb.org/t/p/w500/tCmbICMC5qlldY3oR07nqc42snW.jpg","tmdb_url":"https://www.themoviedb.org/person/3296267"},{"name":"Liang Jingkang","name_vi":null,"name_original":"Liang Jingkang","tmdb_id":2050467,"profile":"https://image.tmdb.org/t/p/w500/jUWaJovGOZOdk2IbZGmZ0GeyVRH.jpg","tmdb_url":"https://www.themoviedb.org/