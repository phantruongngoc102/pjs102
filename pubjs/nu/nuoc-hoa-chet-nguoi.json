y thần kinh thị giác của anh, họ đã yêu nhau. Một cuộc hôn nhân tưởng chừng hạnh phúc bỗng chốc trở nên đen tối ...... Sự thật về gia đình và tình yêu sẽ được hé lộ.</p>","tmdb":{"type":"tv","id":"206295","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-12T14:39:54.000Z","cast":["Zhao Qiyue","Chiang Yun-Lin"],"director":[],"cast_meta":[{"name":"Zhao Qiyue","name_vi":null,"name_original":"Zhao Qiyue","tmdb_id":3630048,"profile":"https://image.tmdb.org/t/p/w500/87shn7QQpRZKyWZ2r9TXAUfkLF.jpg","tmdb_url":"https://www.themoviedb.org/person/3630048"},{"name":"Chiang Yun-Lin","name_vi":null,"name_original":"Chiang Yun-Lin","tmdb_id":1833060,"profile":"https://image.tmdb.org/t/p/w500/jpwWoVLRIOQYpLrRZx5MFl2KgQ4.jpg","tmdb_url":"https://www.themoviedb.org/person/1833060"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/nu/nuoc-hoa-chet-nguoi.json"}