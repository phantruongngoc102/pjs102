 hệt như những gì được viết trong sách của Lu Nanyi, do đó Lu Nanyi có liên quan đến vụ giết người. Chức vụ chính thức mới của Lin Qingqiu là điều đầu tiên khiến anh trở thành kẻ tình nghi. Người yêu cũ của anh trở thành kẻ tình nghi khi gặp nhau.","tmdb_id":257593,"cast":["Đinh Gia Văn","Hoàng Nghị","Shang Xuan","Dong Yu","Wen Yuan","Wang Kaiyi","Chen Siche","Liu Haoxin","Huang Fei","Yang Xiaobo","Jin Wang"],"director":["Yang Shitao"],"keywords":[],"tmdb":{"type":"tv","id":"257593","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Đinh Gia Văn","name_vi":"Đinh Gia Văn","name_original":"Ding Jiawen","tmdb_id":3148201,"profile":"https://image.tmdb.org/t/p/w500/3QEQBnMWQob7TYDUNK3cpLtkGIb.jpg","tmdb_url":"https://www.themoviedb.org/person/3148201"},{"name":"Hoàng Nghị","name_vi":"Hoàng Nghị","name_original":"Huang Yi","tmdb_id":2338685,"profile":"https://image.tmdb.org/t/p/w500/5psVJsMLVEtsRs3tvd0vTuZ0SbX.jpg","tmdb_url":"https://www.themoviedb.org/person/2338685"},{"name":"Shang Xuan","name_vi":null,"name_original":"Shang Xuan","tmdb_id":4015027,"profile":"https://image.tmdb.org/t/p/w500/cHGrmY6BCdY2JWkEyblKmt0AHwb.jpg","tmdb_url":"https://www.themoviedb.org/person/4015027"},{"name":"Dong Yu","name_vi":null,"name_original":"Dong Yu","tmdb_id":3856093,"profile":"https://image.tmdb.org/t/p/w500/foel7GmKxu08wkOm8874s2KmCUC.jpg","tmdb_url":"https://www.themoviedb.org/person/3856093"},{"name":"Wen Yuan","name_vi":null,"name_original":"Wen Yuan","tmdb_id":2972066,"profile":"https://image.tmdb.org/t/p/w500/xSY1S6IyRKvAgj4sEGfQ9nXSik4.jpg","tmdb_url":"https://www.themoviedb.org/person/2972066"},{"name":"Wang Kaiyi","name_vi":null,"name_original":"Wang Kaiyi","tmdb_id":3667343,"profile":"https://image.tmdb.org/t/p/w500/26RBj21YXPgJvg58j31pZPLWhXU.jpg","tmdb_url":"https://www.themoviedb.org/person/3667343"},{"name":"Chen Siche","name_vi":null,"name_original":"Chen Siche","tmdb_id":3563569,"profile":"https://image.tmdb.org/t/p/w500/xl7UFHMZo4lxCXh6BNzvuWUhx4.jpg