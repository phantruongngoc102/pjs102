6.com/share/e0980b732d8f6b121b777eb204f94b30","link_m3u8":"https://vip.opstream16.com/20231204/38606_0807d319/index.m3u8"},{"name":"25","slug":"25","filename":"Nương Tử Tại Thượng - Ep25","link_embed":"https://vip.opstream16.com/share/fb3176bfa58b2e438f42411a2fb3443d","link_m3u8":"https://vip.opstream16.com/20231204/38607_4b0b96b3/index.m3u8"},{"name":"26","slug":"26","filename":"Nương Tử Tại Thượng - Ep26","link_embed":"https://vip.opstream16.com/share/4eefea4fc77f6a79afe6a2e4b0898d84","link_m3u8":"https://vip.opstream16.com/20231204/38609_3b529d21/index.m3u8"},{"name":"27","slug":"27","filename":"Nương Tử Tại Thượng - Ep27","link_embed":"https://vip.opstream16.com/share/394b2ea01aac6d1546deb0c976216f3a","link_m3u8":"https://vip.opstream16.com/20231204/38608_44e7dfb3/index.m3u8"},{"name":"28","slug":"28","filename":"Nương Tử Tại Thượng - Ep28","link_embed":"https://vip.opstream16.com/share/a849796db8f46701f8e41b0586a09fae","link_m3u8":"https://vip.opstream16.com/20231204/38610_0edf5974/index.m3u8"},{"name":"29","slug":"29","filename":"Nương Tử Tại Thượng - Ep29","link_embed":"https://vip.opstream16.com/share/daae8b587ebc4e6cfe21abf4d9b9e772","link_m3u8":"https://vip.opstream16.com/20231204/38611_4a05bb1c/index.m3u8"},{"name":"30","slug":"30","filename":"Nương Tử Tại Thượng - Ep30","link_embed":"https://vip.opstream16.com/share/2c361c16489a6af9c09c1d8fa13d2d03","link_m3u8":"https://vip.opstream16.com/20231204/38612_1eb102ff/index.m3u8"}]}],"time":"10 phút/tập","description":"<p>Ở kinh thành, người đứng đầu cửa hàng thuốc Tần Thảo Đường là Tần Trọng Lâu và đại tướng quân Vân Tử Long cùng nhau xin ý kiến của Hoàng đế về việc xin ban hôn với con gái của Mạc gia y quán. Tuy nhiên, trong Mạc gia có hai người con gái, con gái cả là Mạc Tĩnh Dư và người con thứ là con gái vợ lẽ tên là Mạc Bán Hạ. Hoàng đế ra lệnh cho họ chọn vận may bằng cách rút được chiếc túi may mắn để quyết định ai là sẽ làm vợ chồng ai. Tần Trọng Lâu bị bệnh ở chân, nghe nói Mạc Tĩnh Dư có tài nghệ y thuật cao, rất mong muốn cô ấy có thể chữa khỏi cho mình. Trong khi đó Vân Tử Long lại mang trong mình một mối thù sâu sắc, cha của anh đã phạm sai lầm trong một lần vận chuyển quân dược, cả gia đình bị kết tội, anh là người duy nhất sống sót, và lô dược liệu đó là do Mạc Tương gửi từ Mạc gia y quán gửi đến. Anh nghe nói Mạc Tương rất yêu quý Mạc Bán Hạ nên muốn lợi dụng cô để lấy bằng chứng cho thấy Mạc Tương đã cố tình gài bẫy Vân gia, trả thù cho cả gia đình. Để chọn đúng người mình muốn, Tần Trọng Lâu đã hối lộ người có khả năng can thiệp vào túi may mắn. Tuy nhiên, ý trời ko muốn vậy, túi may mắn vẫn bị chọn sai, Tần Trọng Lâu kết hôn với Mạc Bán Hạ, còn Vân Tử Long phải lấy Mạc Tĩnh Dư. Hai cặp vợ chồng bất đắc dĩ bắt đầu cuộc sống hôn nhân và sau khi kết hôn, họ phát hiện ra rằng họ rất hợp nhau...</p>","tmdb":{"type":"tv","id":"240657","season":1,"vote_average":0,"vote_count":0},"modified":"2023-12-04T13:31:50.000Z","cast":["Yu Zhongli","Zhao Yilin","Lei Haoxiang","Yuan Mingze","Ding Kai","Li Ruotian","Zhang Ruien","Xie Hongtao"],"director":[],"cast_meta":[{"name":"Yu Zhongli","name_vi":null,"name_original":"Yu Zhongli","tmdb_id":3256623,"profile":"https://image.tmdb.org/t/p/w500/kWtG9MofIpYK8j4lNpj1xxotehi.jpg","tmdb_url":"https://www.themoviedb.org/person/3256623"},{"name":"Zhao Yilin","name_vi":null,"name_original":"Zhao Yilin","tmdb_id":4406419,"profile":"https://image.tmdb.org/t/p/w500/lAcpGedsD2yzHplkBnUBo5BH190.jpg","tmdb_url":"https://www.themoviedb.org/person/4406419"},{"name":"Lei Haoxiang","name_vi":null,"name_original":"Lei Haoxiang","tmdb_id":3844511,"profile":"https://image.tmdb.org/t/p/w500/vXEmF0q6iKPe4rxnpHMVMHZ3W3S.jpg","tmdb_url":"https://www.themoviedb.org/person/3844511"},{"name":"Yuan Mingze","name_vi":null,"name_original":"Yuan Mingze","tmdb_id":4389291,"profile":"https://image.tmdb.org/t/p/w500/gqMpl19rajx8zvXYS9qmn2EY1vr.jpg","tmdb_url":"https://www.themoviedb.org/person/4389291"},{"name":"Ding Kai","name_vi":null,"name_original":"Di