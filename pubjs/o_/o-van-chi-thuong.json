. Cảnh sát lần theo các manh mối, phát hiện mối liên hệ giữa ba vụ án lớn: mất tích, giết người và buôn ma túy, từ đó lần ra mạng lưới tổ chức tội phạm phức tạp và những bí mật ẩn giấu đằng sau nó. Đội điều tra Tam Hợp hợp lực, phá án thành công, toàn bộ tội phạm đều bị bắt giữ.","tmdb":{"type":"tv","id":"252572","season":1,"vote_average":7.5,"vote_count":6},"modified":"2025-04-12T11:15:47.000Z","cast":["Tôn Lệ","La Tấn","Đinh Quán Sâm","Lý Tiểu Nhiễm","Vương Tử Dị","Huang Man","Yiying Liu","Kaavie Wong"],"director":["Qing Hua"],"cast_meta":[{"name":"Tôn Lệ","name_vi":"Tôn Lệ","name_original":"Sun Li","tmdb_id":52898,"profile":"https://image.tmdb.org/t/p/w500/12JSX18m5yzoNpLCTLQ104CUslf.jpg","tmdb_url":"https://www.themoviedb.org/person/52898"},{"name":"La Tấn","name_vi":"La Tấn","name_original":"Luo Jin","tmdb_id":1115666,"profile":"https://image.tmdb.org/t/p/w500/qP8nQt2PpHh19odhuhUXqGqdEO9.jpg","tmdb_url":"https://www.themoviedb.org/person/1115666"},{"name":"Đinh Quán Sâm","name_vi":"Đinh Quán Sâm","name_original":"Ding Guansen","tmdb_id":1780717,"profile":"https://image.tmdb.org/t/p/w500/iuf2pu3drbiYMsqW3DEIbpxaPt8.jpg","tmdb_url":"https://www.themoviedb.org/person/1780717"},{"name":"Lý Tiểu Nhiễm","name_vi":"Lý Tiểu Nhiễm","name_original":"Li Xiaoran","tmdb_id":78870,"profile":"https://image.tmdb.org/t/p/w500/9pSHVIZGud98a6lYEPr7LHmagBc.jpg","tmdb_url":"https://www.themoviedb.org/person/78870"},{"name":"Vương Tử Dị","name_vi":"Vương Tử Dị","name_original":"Wang Ziyi","tmdb_id":1016316,"profile":"https://image.tmdb.org/t/p/w500/6xOEI8NnQuvRwe6nSDXYGAamKzO.jpg","tmdb_url":"https://www.themoviedb.org/person/1016316"},{"name":"Huang Man","name_vi":null,"name_original":"Huang Man","tmdb_id":3093272,"profile":"https://image.tmdb.org/t/p/w500/sIv8K2FpOdhBUclAMGwty8vMO6C.jpg","tmdb_url":"https://www.themoviedb.org/person/3093272"},{"name":"Yiying Liu","name_vi":null,"name_original":"Yiying Liu","tmdb_id":2405949,"profile":"https://image.tmdb.org/t/p/w500/l29G3fUb4o1YlL