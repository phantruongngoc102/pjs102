ip.opstream90.com/20260307/26644_612b1105/index.m3u8"}]}],"description":"<p>Mọi chuyện bắt đầu từ một sự cố dở khóc dở cười liên quan đến chiếc chum thần! Để che giấu lỗi lầm, Vệ Long cùng hai người bạn lên đường sửa chum, nào ngờ lại bị cuốn vào âm mưu gián điệp rối ren, rồi lạc bước đến chốn thế ngoại đào nguyên. Tại đây, nhờ \"bảo vật thông cống\" thần kỳ, họ bất ngờ bắt đầu hành trình khởi nghiệp giữa thời cổ đại. Khi âm mưu đen tối chạm trán tinh hoa ẩm thực, khi tình yêu vướng phải những hiểu lầm oái oăm, ba cây hài này đã dùng món tôm hùm đất tê cay để viết nên một huyền thoại cổ trang cực kỳ hoang đường!</p>","tmdb_id":313958,"cast":["Wang Chengsi","Wei Zixin","Gao Tianni","Chang Susheng","Liu Yihong"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"313958","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Wang Chengsi","name_vi":null,"name_original":"Wang Chengsi","tmdb_id":2029011,"profile":"https://image.tmdb.org/t/p/w500/nIZhWUvPfE7pTnKdlud8iFJdhqQ.jpg","tmdb_url":"https://www.themoviedb.org/person/2029011"},{"name":"Wei Zixin","name_vi":"Wei Zixin","name_original":"Wei Zixin","tmdb_id":3094484,"profile":"https://image.tmdb.org/t/p/w500/bNqFs9jJWJZ4xmZNOpxe4KN5trh.jpg","tmdb_url":"https://www.themoviedb.org/person/3094484"},{"name":"Gao Tianni","name_vi":null,"name_original":"Gao Tianni","tmdb_id":4659924,"profile":"https://image.tmdb.org/t/p/w500/7FErlx0evNHOO9apYHrJZweJs7B.jpg","tmdb_url":"https://www.themoviedb.org/person/4659924"},{"name":"Chang Susheng","name_vi":null,"name_original":"Chang Susheng","tmdb_id":5278370,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5278370"},{"name":"Liu Yihong","name_vi":null,"name_original":"Liu Yihong","tmdb_id":3037040,"profile":"https://image.tmdb.org/t/p/w500/3laibBI6wa7ozK8ZwZQTRYB7Onb.jpg","tmdb_url":"https://www.themoviedb.org/person/3037040"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/oa/oan-gia-duong-tom.json"}