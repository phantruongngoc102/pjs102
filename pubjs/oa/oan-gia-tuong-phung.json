","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-26T17:55:31.000Z","cast":["Âu Dương Chấn Hoa","Đặng Tụy Văn","Derek Kwok Jing-Hung","Hứa Thiệu Hùng","La Tử Dật","Oscar Leung Lit-Wai","Mimi Lo","La Lạc Lâm","Vương Hạo Tín","Kenneth Ma Kwok-Ming"],"director":["Trương Càn Văn"],"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Đặng Tụy Văn","name_vi":"Đặng Tụy Văn","name_original":"Sheren Tang Shui-Man","tmdb_id":997296,"profile":"https://image.tmdb.org/t/p/w500/sJ9nrY567ikJ4c2T5wxxuVTB9Ft.jpg","tmdb_url":"https://www.themoviedb.org/person/997296"},{"name":"Derek Kwok Jing-Hung","name_vi":null,"name_original":"Derek Kwok Jing-Hung","tmdb_id":140479,"profile":"https://image.tmdb.org/t/p/w500/cFypay2ZkDNThKVgpighp9msAfk.jpg","tmdb_url":"https://www.themoviedb.org/person/140479"},{"name":"Hứa Thiệu Hùng","name_vi":"Hứa Thiệu Hùng","name_original":"Benz Hui Siu-Hung","tmdb_id":63582,"profile":"https://image.tmdb.org/t/p/w500/bgC8VLG8bBdbQTuiHQtjFlEXo6E.jpg","tmdb_url":"https://www.themoviedb.org/person/63582"},{"name":"La Tử Dật","name_vi":"La Tử Dật","name_original":"Lo Chung-Him","tmdb_id":237032,"profile":"https://image.tmdb.org/t/p/w500/dAc0eHm0CWBBu7L8KD84RrHAZyo.jpg","tmdb_url":"https://www.themoviedb.org/person/237032"},{"name":"Oscar Leung Lit-Wai","name_vi":null,"name_original":"Oscar Leung Lit-Wai","tmdb_id":1143685,"profile":"https://image.tmdb.org/t/p/w500/ftnBNSi7RriYNkHarXrh5ExA74s.jpg","tmdb_url":"https://www.themoviedb.org/person/1143685"},{"name":"Mimi Lo","name_vi":null,"name_original":"Mimi Lo","tmdb_id":1233365,"profile":"https://image.tmdb.org/t/p/w500/7adlBu98duQrsYe7MfJ8AAt9WMf.jpg","tmdb_url":"https://www.themoviedb.org/person/1233365"},{"name":"La Lạc Lâm","name_vi":"La Lạc Lâm","name_original":"Law Lok-Lam","tmdb_