 chết của mình.</p>","tmdb_id":238309,"cast":["Akhamsiri Suwanasuk","Wongsakorn Paramatthakorn","Nuengthida Sophon","Phuripan Sapsangsawat","Nonny Nutcha Jeka","Songsit Rungnopakunsi","Pympan Chalayanacupt","Sueangsuda Lawanprasert","Sakaojai Poonsawatd","Amarin Nitipon","Partith Pisitkul","Aerin Yuktadatta","Chanon Thibkanok","Nuttanee Sittisamarn","Wichai Jongprasitporn"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"238309","season":1,"vote_average":7,"vote_count":1},"cast_meta":[{"name":"Akhamsiri Suwanasuk","name_vi":null,"name_original":"Akhamsiri Suwanasuk","tmdb_id":1342941,"profile":"https://image.tmdb.org/t/p/w500/6IWrlZp9Q3xOaRmw11BHWDVcI3L.jpg","tmdb_url":"https://www.themoviedb.org/person/1342941"},{"name":"Wongsakorn Paramatthakorn","name_vi":null,"name_original":"Wongsakorn Paramatthakorn","tmdb_id":1343980,"profile":"https://image.tmdb.org/t/p/w500/e1Dn8c5FBbFfLrvbT8hak3de9eA.jpg","tmdb_url":"https://www.themoviedb.org/person/1343980"},{"name":"Nuengthida Sophon","name_vi":null,"name_original":"Nuengthida Sophon","tmdb_id":1105573,"profile":"https://image.tmdb.org/t/p/w500/l1ZkKeF0vUDsDECuWjUGIrVfoTU.jpg","tmdb_url":"https://www.themoviedb.org/person/1105573"},{"name":"Phuripan Sapsangsawat","name_vi":null,"name_original":"Phuripan Sapsangsawat","tmdb_id":4208595,"profile":"https://image.tmdb.org/t/p/w500/u32JicGwqsfp6xFeozSTHHELVnG.jpg","tmdb_url":"https://www.themoviedb.org/person/4208595"},{"name":"Nonny Nutcha Jeka","name_vi":null,"name_original":"Nonny Nutcha Jeka","tmdb_id":3422916,"profile":"https://image.tmdb.org/t/p/w500/xqGyaqG1SUnCCYymjTKguAmSQAm.jpg","tmdb_url":"https://www.themoviedb.org/person/3422916"},{"name":"Songsit Rungnopakunsi","name_vi":null,"name_original":"Songsit Rungnopakunsi","tmdb_id":1259528,"profile":"https://image.tmdb.org/t/p/w500/6sh6H6UYyUDPxw3gPXzdp2ERy4m.jpg","tmdb_url":"https://www.themoviedb.org/person/1259528"},{"name":"Pympan Chalayanacupt","name_vi":null,"name_original":"Pympan Chalayanacupt","tmdb_id"