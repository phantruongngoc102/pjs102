34e00b6c6bbcfe77e1f6","link_m3u8":"https://vip.opstream15.com/20220530/17542_21592146/index.m3u8"},{"name":"37","slug":"37","filename":"oc-sen-va-chim-vang-anh-thuyet-minh-symphonys-romance-tap-37","link_embed":"https://vip.opstream15.com/share/441db0432de328365adeae37fbee3920","link_m3u8":"https://vip.opstream15.com/20220530/17545_b294e7ad/index.m3u8"},{"name":"38","slug":"38","filename":"oc-sen-va-chim-vang-anh-thuyet-minh-symphonys-romance-tap-38","link_embed":"https://vip.opstream15.com/share/e99a32fb7acdb9a11bdbe01dd37c2767","link_m3u8":"https://vip.opstream15.com/20220530/17547_896dbf8c/index.m3u8"},{"name":"39","slug":"39","filename":"oc-sen-va-chim-vang-anh-thuyet-minh-symphonys-romance-tap-39","link_embed":"https://vip.opstream15.com/share/d1ee896289d2e2ed272e9b45a2860492","link_m3u8":"https://vip.opstream15.com/20220530/17550_d9588d39/index.m3u8"},{"name":"40","slug":"40","filename":"oc-sen-va-chim-vang-anh-thuyet-minh-symphonys-romance-tap-40","link_embed":"https://vip.opstream15.com/share/de713869d1db126cff30a1fc0e990962","link_m3u8":"https://vip.opstream15.com/20220530/17552_fdfc5cbf/index.m3u8"}]}],"time":"","description":"<p>Phim kể về khi hai thiên tài âm nhạc đối cực gặp nhau, chuyện gì sẽ xảy ra? Chà, thật là thảm họa. Trong manga gốc, nam chính Lý Trăn Ngôn – vai diễn được Trương Tân Thành đảm nhận trong phiên bản Hoa ngữ được hình dung là thể loại người chơi các bản nhạc không sai một dấu chấm trên bảng tổng phổ trong khi nữ chính Phương Tiểu Oa (Lâm Doãn) thì “chơi nhạc” bằng tai và thường xuyên phá cách. Điều này dẫn đến nhiều cuộc đụng độ giữa hai nhân vật. Phương Tiểu Oa ngay lập tức phải lòng đàn anh đẹp trai. Trong khi đó, mặc dù họ đối lập nhau, Lý Trăn Ngôn vẫn bị thu hút bởi cách chơi piano của Phương Tiểu Oa. Khi hai người tìm hiểu nhau, họ giúp khắc phục những khiếm khuyết của nhau. Lý Trăn Ngôn vô thức chăm sóc Phương Tiểu Oa và giúp cô nhận ra tài năng piano của mình. Phương Tiểu Oa có một mối quan hệ yêu-ghét với piano do chấn thương thời thơ ấu với một giáo viên nghiêm khắc.</p>","tmdb":{"type":"tv","id":"104983","season":1,"vote_average":8,"vote_count":2},"modified":"2022-06-06T19:23:31.000Z","cast":["Trương Tân Thành","Lâm Duẫn","Ning Li","Ning Huanyu","Ye Tingran","Ching Yang Chen","Liu Qianwen","Tino Bao"],"director":["Liu Jun Jie"],"cast_meta":[{"name":"Trương Tân Thành","name_vi":"Trương Tân Thành","name_original":"Zhang Xincheng","tmdb_id":2027708,"profile":"https://image.tmdb.org/t/p/w500/mpCVPsEvnMUkmMd1IN1xsBJpk7r.jpg","tmdb_url":"https://www.themoviedb.org/person/2027708"},{"name":"Lâm Duẫn","name_vi":"Lâm Duẫn","name_original":"Lin Yun","tmdb_id":1574909,"profile":"https://image.tmdb.org/t/p/w500/9ZxXUlMAH6gylhswGHOGO1YAQPJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1574909"},{"name":"Ning Li","name_vi":null,"name_original":"Ning Li","tmdb_id":987205,"profile":"https://image.tmdb.org/t/p/w500/afb9OxvJ1SrSPlIraX0HqIeil5l.jpg","tmdb_url":"https://www.themoviedb.org/person/987205"},{"name":"Ning Huanyu","name_vi":null,"name_original":"Ning Huanyu","tmdb_id":2187096,"profile":"https://image.tmdb.org/t/p/w500/xDe5mPTvdYKNkY99Dq5O9sCEvXg.jpg","tmdb_url":"https://www.themoviedb.org/person/2187096"},{"name":"Ye Tingran","name_vi":null,"name_original":"Ye Tingran","tmdb_id":4096338,"profile":"https://image.tmdb.org/t/p/w500/e9MPoUimpEv4RpbnmPfW0Q8WGLl.jpg","tmdb_url":"https://www.themoviedb.org/person/4096338"},{"name":"Ching Yang Chen","name_vi":null,"name_original":"Ching Yang Chen","tmdb_id":3311119,"profile":"https://image.tmdb.org/t/p/w500/jY6duMvge3m09LYd5iweqcbvFVu.jpg","tmdb_url":"https://www.themoviedb.org/person/3311119"},{"name":"Liu Qianwen","name_vi":null,"name_original":"Liu Qianwen","tmdb_id":2407929,"profile":"https://image.tmdb.org/t/p/w500/grNWcmcPeZxHCqmQLOyshrlqY2A.jpg","tmdb_url":"https://www.themoviedb.org/person/2407929"},{"name":"Tino Bao","name_vi":null,"name_original":"Tino Bao","tmdb_id":1400584,"profile":null,"tmdb_url":"https://www.themoviedb.org/person