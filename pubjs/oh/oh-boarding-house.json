vip.opstream12.com/20220406/8126_5ceac0c2/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream12.com/share/5934c1ec0cd31e12bd9084d106bc2e32","link_m3u8":"https://vip.opstream12.com/20220406/8127_3dc8bba5/index.m3u8"}]}],"description":"<p>Bộ phim xoay quanh tình bạn và tình yêu của 5 chàng trai ở chung dưới mái nhà trọ. Sau khi bị sa thải và bị lừa mất tiền đặt cọc nhà, Seol Won đã không chốn nương thân nên quay về nhà trọ của mẹ, thay mẹ quản lý nhà trọ. Trong căn nhà trọ hiện đang có Jae Woo, em họ Seol Won với khả năng ăn như hạm, và Ye Min, một kẻ điên vô cùng nhạy cảm như chính cái tên của mình. Đồng thời nhà trọ đón thêm những vị khách mới đó là Cheol Su, thầy chủ nhiệm của Jae Woo, và Bong Deok, một đàn em thân thiết rất thích Seol Won. Ngày đầu tiên Cheol Su tới đã vô tình cứu mạng Seol Won nên anh rất cảm kích và luôn muốn tìm cách để trả ơn Cheol Su. Đối diện với sự nhiệt tình thái quá của Seol Won, Cheol Su cảm thấy rất khó chịu và luôn tìm cách trốn tránh. Tuy nhiên, Cheol Su cũng dần cảm động trước Seol Won và cả hai bắt đầu rơi vào lưới tình, điều này làm cho Bong Deok, một người thích thầm Seol Won từ rất lâu rất đau khổ.</p>","tmdb_id":158149,"cast":["Shin Yong-seok","Lim Sung-kyun","Shin Ki-hwan","Kim Hee-jung","Hojin","Han Seo-wool"],"director":["Park Eun-joo"],"keywords":[],"cast_meta":[{"name":"Shin Yong-seok","name_vi":null,"name_original":"Shin Yong-seok","tmdb_id":3435658,"profile":"https://image.tmdb.org/t/p/w500/2ZCYgD7ZBUzlrwSLOGSmiBbLWWE.jpg","tmdb_url":"https://www.themoviedb.org/person/3435658"},{"name":"Lim Sung-kyun","name_vi":null,"name_original":"Lim Sung-kyun","tmdb_id":3038166,"profile":"https://image.tmdb.org/t/p/w500/gnpQKjkjU742I3ryfffHfPQv73N.jpg","tmdb_url":"https://www.themoviedb.org/person/3038166"},{"name":"Shin Ki-hwan","name_vi":null,"name_original":"Shin Ki-hwan","tmdb_id":3730102,"profile":"https://image.tmdb.org/t/p/w500/jGVbYDvBRK51m9pamHdIkwDw8mY.jpg","tmdb_url":"https://www.themoviedb.org/person/373