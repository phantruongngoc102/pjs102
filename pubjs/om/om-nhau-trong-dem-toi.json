a5867fc85840757","link_m3u8":"https://vip.opstream17.com/20240812/16631_19a3ce66/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/dc4781e4d7949791a2c973340de4a010","link_m3u8":"https://vip.opstream17.com/20240813/16745_e74de0de/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/93f8e322bb6adffeeb33a85d95c52316","link_m3u8":"https://vip.opstream17.com/20240813/16746_9e386b6e/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/ead8e65817265dd1346c3d2b2ba251c5","link_m3u8":"https://vip.opstream17.com/20240814/16768_1f4b241e/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/48229fd6aa4328151e40bda429d8e182","link_m3u8":"https://vip.opstream17.com/20240814/16769_ca131ac0/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream17.com/share/948ba1dc8cc4cc26e5d9d4f358660c2d","link_m3u8":"https://vip.opstream17.com/20240815/16788_86a5c357/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream17.com/share/1e53b79716f96e36c06132ddb9cd53d9","link_m3u8":"https://vip.opstream17.com/20240815/16787_80913979/index.m3u8"}]}],"description":"<p>Trong một lần du lịch ở nước ngoài, Ôn Hề vô tình bị đưa đến võ đài ngầm của ông Giả, ông trùm đứng sau bọn cho vay nặng lãi, trở thành một chiến lợi phẩm dành cho người chiến thắng trong cuộc đấu. Người cuối cùng giành được Ôn Hề là một chàng trai người gốc Hoa trẻ tuổi và bí ẩn, Từ Triết Thanh. Ông Giả rất thích tài đánh của Từ Triết Thanh, dùng uy và quyền để ép anh ở lại phục vụ mình. Nhưng ông ta không biết, thân phận thật sự của Từ Triết Thanh là một cố vấn an ninh cá nhân đến đây để giải cứu Ôn Hề. Sau khi trải qua nhiều nguy hiểm, cả hai cùng nhau trốn thoát khỏi sự kiểm soát của ông Giả. Ba năm sau, chị gái song sinh Ôn Hảo của Ôn Hề đột ngột qua đời. Cô quyết định thay chị gái đến công ty G.E. để tìm ra sự thật và bất ngờ gặp lại Từ Triết Thanh. Hai người thuộc hai phe khác nhau, nhưng họ lại bị ảnh hưởng bởi những cảm xúc trong quá khứ. Lần này, liệu hai người có thể cùng nắm tay nhau một lần nữa để vượt qua bóng tối của màn đêm và bên nhau đón khoảnh khắc hạnh phúc...?</p><p>&nbsp;</p>","tmdb_id":254993,"cast":["Ren Yunjie","Phương Cẩn"],"director":["Chen Jiajie"],"keywords":[],"tmdb":{"type":"tv","id":"254993","season":1,"vote_average":7.788,"vote_count":26},"cast_meta":[{"name":"Ren Yunjie","name_vi":null,"name_original":"Ren Yunjie","tmdb_id":3793267,"profile":"https://image.tmdb.org/t/p/w500/9yIMhFEvh2lEAqB4c9qImzS7kxx.jpg","tmdb_url":"https://www.themoviedb.org/person/3793267"},{"name":"Phương Cẩn","name_vi":"Phương Cẩn","name_original":"Fang Jin","tmdb_id":3541107,"profile":"https://image.tmdb.org/t/p/w500/zyFWHwiQkUoxD4gwhsJqXUIdaP8.jpg","tmdb_url":"https://www.themoviedb.org/person/3541107"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/om/om-nhau-trong-dem-toi.json"}