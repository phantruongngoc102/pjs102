{"id":"623344ae3c735a9a446e048c","title":"One piece: Omatsuri danshaku to himitsu no shima","origin_name":"One piece: Omatsuri danshaku to himitsu no shima","slug":"one-piece-omatsuri-danshaku-to-himitsu-no-shima","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/on/one-piece-omatsuri-danshaku-to-himitsu-no-shima.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/on/one-piece-omatsuri-danshaku-to-himitsu-no-shima.webp","year":2005,"type":"hoathinh","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"}],"country":[{"id":"620a2307e0fc277084dfd726","name":"Nhật Bản","slug":"nhat-ban"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"1","slug":"1","filename":"One piece: Omatsuri danshaku to himitsu no shima","link_embed":"https://vip.opstream14.com/share/0966289037ad9846c5e994be2a91bafa","link_m3u8":"https://vip.opstream14.com/20220317/1396_9ba5738c/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Cướp biển mũ rơm đã nhận được một quảng cáo trên một hòn đảo giải trí. Tất cả những lời đề nghị có vẻ đầy hứa hẹn, vì vậy họ đi thuyền đến hòn đảo để có cơ hội đá lại và thư giãn từ hành trình của họ trên Line Line. Trang web của khu nghỉ mát trông giống như một giấc mơ trở thành sự thật. Chỉ những anh hùng của chúng tôi thấy mình được chào đón bởi người đứng đầu đảo: Baron Omatsuri. Ông yêu cầu tất cả 7 người trong số họ để cạnh tranh trong một loạt các cuộc thi để thư giãn được cấp của họ. Luffy chấp nhận thử thách, và tất cả họ đều thấy hòn đảo này không phải là trung bình. Tuy nhiên, có một bí ẩn bị che khuất trên thiên đường giải trí. Chẳng hạn như tại sao mũ rơm cướp biển, khách du lịch duy nhất xung quanh? Và tại sao Baron giữ hoa duy nhất của hòn đảo?</p>","tmdb":{"type":"movie","id":"44729","season":null,"vote_average":7.2,"vote_count":228},"modified":"2025-08-21T13:01:49.000Z","cast":["Son Hyun-joo","Kim Sang-joong","Go Joon-hee","Kim Sung-ryung","Ryu Seung-su","Park Hyo-ju","Kang Shin-il","Lee Yong-woo","Jang Shin-young","Lee Re","Jeon No-min","Park Keun-hyong","Song Jae-ho","Jo Jae-yun","Lee Hye-in"],"director":["Cho Nam-guk","Jin Hyuk"],"cast_meta":[{"name":"Son Hyun-joo","name_vi":null,"name_original":"Son Hyun-joo","tmdb_id":1015873,"profile":"https://image.tmdb.org/t/p/w500/v4uRXAf6Vq2rsgdgcyQeEL3qnf1.jpg","tmdb_url":"https://www.themoviedb.org/person/1015873"},{"name":"Kim Sang-joong","name_vi":null,"name_original":"Kim Sang-joong","tmdb_id":84910,"profile":"https://image.tmdb.org/t/p/w500/udcxh8bqXLy9rGpqE9S994JdQEP.jpg","tmdb_url":"https://www.themoviedb.org/person/84910"},{"name":"Go Joon-hee","name_vi":null,"name_original":"Go Joon-hee","tmdb_id":1073874,"profile":"https://image.tmdb.org/t/p/w500/ksilFsztYt9Ojp2cbMk75nxumOS.jpg","tmdb_url":"https://www.themoviedb.org/person/1073874"},{"name":"Kim Sung-ryung","name_vi":null,"name_original":"Kim Sung-ryung","tmdb_id":930417,"profile":"https://image.tmdb.org/t/p/w500/sPB8ySlzfJWNedISwugRWEBABIY.jpg","tmdb_url":"https://www.themoviedb.org/person/930417"},{"name":"Ryu Seung-su","name_vi":null,"name_original":"Ryu Seung-su","tmdb_id":1243892,"profile":"https://image.tmdb.org/t/p/w500/x9XcfwqcXNpk2hIrP6qeR0DDkOs.jpg","tmdb_url":"https://www.themoviedb.org/person/1243892"},{"name":"Park Hyo-ju","name_vi":null,"name_original":"Park Hyo-ju","tmdb_id":939135,"profile":"https://image.tmdb.org/t/p/w500/gD3tfx1uy6TfoIHdBxhVIzIDcy4.jpg","tmdb_url":"https://www.themoviedb.org/person/939135"},{"name":"Kang Shin-il","name_vi":null,"name_original":"Kang Shin-il","tmdb_id":109060,"profile":"https://image.tmdb.org/t/p/w500/iQhXXV8Wsv2ZHifZqaIm1fJsW7F.jpg","tmdb_url":"https://www.themoviedb.org/person/109060"},{"name":"Lee Yong-woo