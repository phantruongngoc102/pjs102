nh một người bố tốt, biết chăm lo cho gia đình. Cuối cùng vợ của anh ta cũng trở về đoàn tụ với gia đình.</p>","tmdb":{"type":"tv","id":"112141","season":1,"vote_average":0,"vote_count":0},"modified":"2023-06-12T14:15:10.000Z","cast":["Sa Dật","Hu Ke","Lý Giai Hàng","Li Jinming","Han Li","Trương Hy Viện","Wang BoGu","Lương Gia Nhân","Mu Liyan","Ba Tu","Su Jin","Zeng Hongsheng","Li Youwei","Li Chang","Dang Haoyu"],"director":["Mạc Quán Chi"],"cast_meta":[{"name":"Sa Dật","name_vi":"Sa Dật","name_original":"Sha Yi","tmdb_id":235518,"profile":"https://image.tmdb.org/t/p/w500/ip9GpE5RhxBzqlbbVX0DwktOlss.jpg","tmdb_url":"https://www.themoviedb.org/person/235518"},{"name":"Hu Ke","name_vi":null,"name_original":"Hu Ke","tmdb_id":544790,"profile":"https://image.tmdb.org/t/p/w500/3LMCJlrifOO1Me47sjeQ3xAu22o.jpg","tmdb_url":"https://www.themoviedb.org/person/544790"},{"name":"Lý Giai Hàng","name_vi":"Lý Giai Hàng","name_original":"Li Jiahang","tmdb_id":1260866,"profile":"https://image.tmdb.org/t/p/w500/fiVqFXt65U2AQooaAgm65eArH34.jpg","tmdb_url":"https://www.themoviedb.org/person/1260866"},{"name":"Li Jinming","name_vi":null,"name_original":"Li Jinming","tmdb_id":1756786,"profile":"https://image.tmdb.org/t/p/w500/wflRMVGeDhAOdTzsN8lndrhpNat.jpg","tmdb_url":"https://www.themoviedb.org/person/1756786"},{"name":"Han Li","name_vi":null,"name_original":"Han Li","tmdb_id":2510887,"profile":"https://image.tmdb.org/t/p/w500/8UCclOWGbW8YXdg8Y9URnYi1iLK.jpg","tmdb_url":"https://www.themoviedb.org/person/2510887"},{"name":"Trương Hy Viện","name_vi":"Trương Hy Viện","name_original":"Zhang Xiyuan","tmdb_id":2324407,"profile":"https://image.tmdb.org/t/p/w500/f8mPDDFEqhIe72bXqeTss2MOH8e.jpg","tmdb_url":"https://www.themoviedb.org/person/2324407"},{"name":"Wang BoGu","name_vi":null,"name_original":"Wang BoGu","tmdb_id":2341095,"profile":"https://image.tmdb.org/t/p/w500/95ntkFCD6EwrjITjiFDbCusKfbS.jpg","tmdb_url":"https://www.themoviedb.org/person/2341095"},{"name":"Lương Gia Nhân","name_vi":