cũng như chính quyền sở tại. Song song với cuộc truy tìm nhân đạo ấy, một cuộc truy tìm đuổi bắt khác gay cấn hơn, xảy đến từ một tên tội phạm, kẻ đã ngớ ngẩn hoặc đúng hơn, bất cẩn trao vali 50 triệu crown vào tay cụ già này. Nhưng một người đã sống qua một thế kỷ thì không dễ gì tóm cụ ta được.","tmdb":{"type":"movie","id":"145247","season":null,"vote_average":6.812,"vote_count":990},"modified":"2023-04-19T16:08:28.000Z","cast":["Robert Gustafsson","Iwar Wiklander","David Wiberg","Mia Skäringer","Jens Hultén","Sven Lönn","Bianca Cruzeiro","Alan Ford","Simon Säppenen","Kerry Shale","Miglen Mirtchev","Lateef Lovejoy","Manuel Dubra","David Shackleton","Johan Rheborg"],"director":["Felix Herngren"],"cast_meta":[{"name":"Robert Gustafsson","name_vi":null,"name_original":"Robert Gustafsson","tmdb_id":74699,"profile":"https://image.tmdb.org/t/p/w500/uiNOp6QjVjaQTDJjbAtpNgZQXQr.jpg","tmdb_url":"https://www.themoviedb.org/person/74699"},{"name":"Iwar Wiklander","name_vi":null,"name_original":"Iwar Wiklander","tmdb_id":282449,"profile":"https://image.tmdb.org/t/p/w500/s0EjghuTpefXlof3AvRDNZOkuzA.jpg","tmdb_url":"https://www.themoviedb.org/person/282449"},{"name":"David Wiberg","name_vi":null,"name_original":"David Wiberg","tmdb_id":1314260,"profile":"https://image.tmdb.org/t/p/w500/hcob7OvvtwG107j2suu5Z0GYAqt.jpg","tmdb_url":"https://www.themoviedb.org/person/1314260"},{"name":"Mia Skäringer","name_vi":null,"name_original":"Mia Skäringer","tmdb_id":135692,"profile":"https://image.tmdb.org/t/p/w500/382hw1VL4x7cTl8kxnRRsavCoXB.jpg","tmdb_url":"https://www.themoviedb.org/person/135692"},{"name":"Jens Hultén","name_vi":null,"name_original":"Jens Hultén","tmdb_id":92429,"profile":"https://image.tmdb.org/t/p/w500/iw8oSLUaKl0zjjwRHXkpeGmtAfk.jpg","tmdb_url":"https://www.themoviedb.org/person/92429"},{"name":"Sven Lönn","name_vi":null,"name_original":"Sven Lönn","tmdb_id":1314261,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1314261"},{"name":"Bianca Cruzeiro","name_