óng đài MBC năm 1999. Tác phẩm gây tiếng vang khắp châu Á khi tái hiện thành công tình người, tình đời trong xã hội Nam Triều Tiên (Hàn Quốc) giai đoạn 1937-1955 nhiều bất ổn. Chiến tranh xảy ra liên miên khiến nhiều gia đình ly tán vì nạn đói và bệnh dịch suốt gần hai thập kỷ.</p>","tmdb_id":96689,"cast":["Trịnh Tắc Sĩ","Huỳnh Quang Lượng","Trần Vỹ","Eliza Sam","Trần Sơn Thông","Mat Yeung","Uyển Quỳnh Đan","Jin Gang","La Lạc Lâm","Lý Thành Xương","Ada Wong Chi-Hom"],"director":["Jang Yong Woo"],"keywords":[],"tmdb":{"type":"tv","id":"96689","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trịnh Tắc Sĩ","name_vi":"Trịnh Tắc Sĩ","name_original":"Kent Cheng Jak-Si","tmdb_id":65966,"profile":"https://image.tmdb.org/t/p/w500/a1ebM3aLwYkPckPzc9FgfW2xTsZ.jpg","tmdb_url":"https://www.themoviedb.org/person/65966"},{"name":"Huỳnh Quang Lượng","name_vi":"Huỳnh Quang Lượng","name_original":"Tommy Wong","tmdb_id":1135394,"profile":"https://image.tmdb.org/t/p/w500/4vcp6AtQpaW5LrAwkDudVy6ibUt.jpg","tmdb_url":"https://www.themoviedb.org/person/1135394"},{"name":"Trần Vỹ","name_vi":"Trần Vỹ","name_original":"Alice Chan Wai","tmdb_id":1021936,"profile":"https://image.tmdb.org/t/p/w500/wxRBCvpATXZ5y4ejR7JrSChmS3N.jpg","tmdb_url":"https://www.themoviedb.org/person/1021936"},{"name":"Eliza Sam","name_vi":null,"name_original":"Eliza Sam","tmdb_id":1688880,"profile":"https://image.tmdb.org/t/p/w500/cBjklXUuITK69b75HaEVltOdwnC.jpg","tmdb_url":"https://www.themoviedb.org/person/1688880"},{"name":"Trần Sơn Thông","name_vi":"Trần Sơn Thông","name_original":"Joel Chan","tmdb_id":1218777,"profile":"https://image.tmdb.org/t/p/w500/sBVL7GLD2K6UF9FkzhamMMopyjn.jpg","tmdb_url":"https://www.themoviedb.org/person/1218777"},{"name":"Mat Yeung","name_vi":null,"name_original":"Mat Yeung","tmdb_id":1588970,"profile":"https://image.tmdb.org/t/p/w500/1YLrCj101GPUsYFRW6MNrUnY06x.jpg","tmdb_url":"https://www.themoviedb.org/person/1588970"},{"name":"Uyển Quỳnh Đan","name_vi":"Uyển Quỳnh Đan"