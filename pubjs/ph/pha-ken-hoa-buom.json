n định của cả hai trái tim.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"294625","season":1,"vote_average":8,"vote_count":1},"modified":"2025-10-15T14:07:52.000Z","cast":["Minh Gia Gia","Sun Zihang","Wang Xiaoshi","Ning Xianzhou","Li Bingbing"],"director":["Zhou Xiao"],"cast_meta":[{"name":"Minh Gia Gia","name_vi":"Minh Gia Gia","name_original":"Ming Jiajia","tmdb_id":3704716,"profile":"https://image.tmdb.org/t/p/w500/eHtb6uehxwrW8RIeemV0idHAtIN.jpg","tmdb_url":"https://www.themoviedb.org/person/3704716"},{"name":"Sun Zihang","name_vi":null,"name_original":"Sun Zihang","tmdb_id":2787658,"profile":"https://image.tmdb.org/t/p/w500/eAdhS2xFNkLPabatN32RBEgoZTB.jpg","tmdb_url":"https://www.themoviedb.org/person/2787658"},{"name":"Wang Xiaoshi","name_vi":null,"name_original":"Wang Xiaoshi","tmdb_id":3808972,"profile":"https://image.tmdb.org/t/p/w500/vTELk5BbLymGUskDpWL1U4hFABB.jpg","tmdb_url":"https://www.themoviedb.org/person/3808972"},{"name":"Ning Xianzhou","name_vi":null,"name_original":"Ning Xianzhou","tmdb_id":3159735,"profile":"https://image.tmdb.org/t/p/w500/a7mu4ri7Lcuy89m0LUTpnQrBg74.jpg","tmdb_url":"https://www.themoviedb.org/person/3159735"},{"name":"Li Bingbing","name_vi":null,"name_original":"Li Bingbing","tmdb_id":4967466,"profile":"https://image.tmdb.org/t/p/w500/n5TILayPsUleJwpXbOseAQtFO5K.jpg","tmdb_url":"https://www.themoviedb.org/person/4967466"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ph/pha-ken-hoa-buom.json"}