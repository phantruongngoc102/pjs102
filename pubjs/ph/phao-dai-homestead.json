19/32405_3cab6b8b/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream10.com/share/9191b0a3b4c41e6732dbb644bd52d6fc","link_m3u8":"https://vip.opstream10.com/20260120/32421_9191b0a3/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/3c9857798a0f7d6128d3c292102b5730","link_m3u8":"https://vip.opstream10.com/20260121/32432_3c985779/index.m3u8"}]}],"description":"<p>Câu chuyện Homestead: The Series diễn ra sau khi một quả bom hạt nhân nổ gần Los Angeles dẫn đến sự sụp đổ xã hội tại Hoa Kỳ, tiếp nối ngay sau bộ phim điện ảnh Homestead đã ra mắt năm 2024. Cựu lính đặc nhiệm Jeff Eriksson (Bailey Chase) cùng gia đình và nhóm người tị nạn tìm đến Homestead - một khu trú ẩn kiên cố miền núi do Ian và Jenna Ross xây dựng để sinh tồn. Họ phải đối mặt với khủng hoảng thực phẩm, xung đột nội bộ và kẻ thù từ bên ngoài. Homestead: The Series là một dự án hấp dẫn với sự hòa trộn giữa chân thực của phim hành động hậu tận thế, và chiều sâu tâm lý, đạo đức và tín ngưỡng. Nếu bạn thích xem phim thể loại sinh tồn đậm tính nhân văn, với các xung đột gia đình, lãnh đạo, bảo vệ cộng đồng và tín ngưỡng, đây là lựa chọn đáng để thử.</p>","tmdb_id":256106,"cast":["Jill Wagner","Dawn Olivieri","Charles Esten","Bailey Chase","Sam Page","Kearran Giovanni","Tyler Lofton"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"256106","season":1,"vote_average":6.3,"vote_count":10},"cast_meta":[{"name":"Jill Wagner","name_vi":null,"name_original":"Jill Wagner","tmdb_id":82943,"profile":"https://image.tmdb.org/t/p/w500/6OTQW5rdxIWnHWlnvdjAPXWFpfB.jpg","tmdb_url":"https://www.themoviedb.org/person/82943"},{"name":"Dawn Olivieri","name_vi":null,"name_original":"Dawn Olivieri","tmdb_id":92614,"profile":"https://image.tmdb.org/t/p/w500/tet7ZVbzhLWwT44m9j94folyl5N.jpg","tmdb_url":"https://www.themoviedb.org/person/92614"},{"name":"Charles Esten","name_vi":null,"name_original":"Charles Esten","tmdb_id":157412,"profile":"https://image.tmdb.org/t/p/w500/pd5Z0x