ink_embed":"https://vip.opstream17.com/share/d5c186983b52c4551ee00f72316c6eaa","link_m3u8":"https://vip.opstream17.com/20240306/1992_9301bd31/index.m3u8"}]}],"time":"40 phút/tập","description":"<p>Người phụ nữ mạnh mẽ, quyền lực trong nhà Kiều Hải Vân từng lập ra quy định, mỗi năm Tết đến mọi người bắt buộc phải về nhà ăn Tết, từ trước đến nay chưa từng có ai phá vỡ quy tắc này, cho đến khi Lý Y Cẩm người cháu ngoan ngoãn nhất bỗng dưng đi ngược lại truyền thống, đến nhà bạn trai ăn Tết, gây nên mâu thuẫn trong gia tộc. Kiều Hải Vân có ba người con gái, người con gái cả Mạnh Minh Vỹ không phải con ruột, vì khuyết tật ở chân dẫn đến tự ti nên luôn mong con gái thành tài, quan hệ giữa hai người vô cùng căng thẳng, nhưng cuối cùng họ đã hiểu được nỗi khổ của nhau, hiểu được rằng giữ một khoảng cách thích hợp mới là cách hay nhất để gìn giữ mối quan hệ mẹ con. Người con gái thứ hai Mạnh Uyển Thanh được coi là có mối quan hệ hoàn hảo với đứa con gái học giỏi Đào Xu Na, nhưng hai người từng chia sẻ với nhau mọi điều lại vô tình phát hiện ra bí mật của nhau.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"245652","season":1,"vote_average":7.5,"vote_count":2},"modified":"2024-03-06T20:43:17.000Z","cast":["Xu Fan","Mã Tư Thuần","Liang Jing","Lý Tiểu Nhiễm","Song Chunli","Li Chengru","Lưu Quân","Tôn Thiến","Vương Thiên Thần","Song Ningfeng","Trần Tĩnh Khả","Chuan Ding","Wu Shile","Zhao Xin","Geng Le"],"director":[],"cast_meta":[{"name":"Xu Fan","name_vi":null,"name_original":"Xu Fan","tmdb_id":130985,"profile":"https://image.tmdb.org/t/p/w500/pmpW5uYJr6GZZKFK1AJGYZz3y4F.jpg","tmdb_url":"https://www.themoviedb.org/person/130985"},{"name":"Mã Tư Thuần","name_vi":"Mã Tư Thuần","name_original":"Ma Sichun","tmdb_id":1476994,"profile":"https://image.tmdb.org/t/p/w500/lBaMftRfwBOoKeEg76ooqfffZTw.jpg","tmdb_url":"https://www.themoviedb.org/person/1476994"},{"name":"Liang Jing","name_vi":null,"name_original":"Liang Jing","tmdb_id":130866,"profile":"https://image.tmdb.org/t/p/w500/6EHpFtHS