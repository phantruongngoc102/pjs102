25_c456abfa/index.m3u8"},{"name":"27","slug":"27","filename":"phap-su-vo-tam-3-thuyet-minh-wu-xin-the-monster-killer-3-thuyet-minh-tap-27","link_embed":"https://vip.opstream15.com/share/0da54aa0b1ee702d0c45af548b1a54c7","link_m3u8":"https://vip.opstream15.com/20220424/7926_9231a053/index.m3u8"},{"name":"28","slug":"28","filename":"phap-su-vo-tam-3-thuyet-minh-wu-xin-the-monster-killer-3-thuyet-minh-tap-28","link_embed":"https://vip.opstream15.com/share/3dcaf04c357c577a857f3ffadc555f9b","link_m3u8":"https://vip.opstream15.com/20220424/7927_94e7b816/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim Pháp Sư Vô Tâm 2 - Wu Xin: The Monster Killer 2 (2017): Vô Tâm là một người mang trong mình khả năng không già đi, không chết. Không biết mình là ai, đến từ đâu, khả năng kỳ lạ dường như cũng không phải là vinh viễn, Vô Tâm cứ thế phiêu bạt trong dòng thời gian. Nếu một người có khả năng đó thì hoặc là có thể làm nên những chuyện kinh thiên động địa, hoặc là phải khổ sở cùng quẫn ăn xin đên cả vạn năm. Vô Tâm, số quá nhọ, rơi vào trường hợp thứ 2. Ẩn cư nơi thâm sơn cùng cốc đến 300 năm, đến thời dân quốc đói quá phải bò xuống núi kiếm ăn, đóng giả làm hòa thượng đến thành Hạ Huyền</p>","tmdb":{"type":"tv","id":"64532","season":3,"vote_average":8.25,"vote_count":11},"modified":"2025-06-18T09:55:34.000Z","cast":["Trần Dao","Hàn Đông Quân","Kim Thần","Vương Ngạn Lâm","Mike Angelo","Mỹ Hàn"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Trần Dao","name_vi":"Trần Dao","name_original":"Chen Yao","tmdb_id":1865921,"profile":"https://image.tmdb.org/t/p/w500/9sqEtFKYtPZ5InwqmfX6qVOYNKV.jpg","tmdb_url":"https://www.themoviedb.org/person/1865921"},{"name":"Hàn Đông Quân","name_vi":"Hàn Đông Quân","name_original":"Elvis Han","tmdb_id":1541647,"profile":"https://image.tmdb.org/t/p/w500/r3b5X3gHqHStLnBcs51L7QqraKp.jpg","tmdb_url":"https://www.themoviedb.org/person/1541647"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"htt