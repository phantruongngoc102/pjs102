10/12722_31087955/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/b26be92d375bc16823077bd874693e9c","link_m3u8":"https://vip.opstream11.com/20220410/12721_7a4e13a8/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/1ea83680196dbebca4f47216650521ed","link_m3u8":"https://vip.opstream11.com/20220410/12723_b8db473a/index.m3u8"}]}],"description":"<p>Pháp Sư Vô Tâm - The Monster Killer được cải biên từ tiểu thuyết mạng cùng tên của nhà văn Ni La, kể về pháp sư Vô Tâm mang trong mình khả năng bất tử, không có hơi thở, không có nhịp tim hành tẩu giang hồ trảm yêu trừ ma, vô tình gặp được thiếu nữ Nguyệt Nha - cô gái đang chạy trốn cuộc hôn nhân của mình - liền rơi vào câu chuyện tình yêu thời loạn thế. Vì mưu sinh, hai người đã xin đến nhà của Cố đại nhân để bắt ma, không ngờ do bất cẩn đã động chạm vào cơ mật, giải thoát phong ấn trăm năm của yêu nhân Nhạc Khởi La. Cũng từ đó, Khởi La đem lòng yêu mến Vô Tâm, tìm đủ mọi cách để sát hại người mà Vô Tâm thương yêu - Nguyệt Nha. Vô Tâm bi hận, quyết tâm phong ấn Nhạc Khởi La, sau đó từ biệt Cố đại nhân, một mình tiêu diêu nhân gian.</p>","tmdb_id":64532,"cast":[],"director":[],"keywords":[],"tmdb":{"id":64532},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ph/phap-su-vo-tam.json"}