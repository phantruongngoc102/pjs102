98bbb52a7e04d92abeff3080d","link_m3u8":"https://vip.opstream12.com/20220625/22129_212ecbf5/index.m3u8"},{"name":"26A","slug":"26a","link_embed":"https://vip.opstream12.com/share/2ff053bc45688d7fc628eb4bd8b9417d","link_m3u8":"https://vip.opstream12.com/20220625/22128_f27c1d11/index.m3u8"},{"name":"26B","slug":"26b","link_embed":"https://vip.opstream12.com/share/19fadb255d5df879f17dc1cfb7d9969d","link_m3u8":"https://vip.opstream12.com/20220625/22127_8456de51/index.m3u8"}]}],"description":"<p>Cậu sinh viên pháp y vừa mới tốt nghiệp Tần Minh trở về quê để điều tra cái chết bí ẩn của mẹ. Quá trình thu thập chứng cứ đã vô tình dẫn Tần Minh đến một vụ án mạng khác. Cùng một lúc phải giải quyết hai vụ án, Tần Minh không còn cách nào khác là phải cầu cứu chính quyền địa phương. Với sự giúp đỡ của nhóm cảnh sát cùng nhân viên khám nghiệm tử thi An Nhiên, Lâm Đào, Hoàn Hoàn, các vụ án dần dần được lật mở, hé lộ một âm mưu cực lớn đằng sau đó.</p>","tmdb_id":202461,"cast":["Trương Diệu","Tang Min","Bành Sở Việt","Leslie Ma","Shao Feng","Zhang Yan Qi"],"director":["Shi Lei"],"keywords":[],"tmdb":{"type":"tv","id":"202461","season":1,"vote_average":5.5,"vote_count":4},"cast_meta":[{"name":"Trương Diệu","name_vi":"Trương Diệu","name_original":"Zhang Yao","tmdb_id":2190492,"profile":"https://image.tmdb.org/t/p/w500/9CWNqoFsbjZlLAknEpmA0K5p6KL.jpg","tmdb_url":"https://www.themoviedb.org/person/2190492"},{"name":"Tang Min","name_vi":null,"name_original":"Tang Min","tmdb_id":2461692,"profile":"https://image.tmdb.org/t/p/w500/p3z0UoSZ4uQRAq9KDRNe0vphuID.jpg","tmdb_url":"https://www.themoviedb.org/person/2461692"},{"name":"Bành Sở Việt","name_vi":"Bành Sở Việt","name_original":"Peng Chuyue","tmdb_id":2084794,"profile":"https://image.tmdb.org/t/p/w500/q2sFfZZHdK2z8DhNd8ziVLpGSMZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2084794"},{"name":"Leslie Ma","name_vi":null,"name_original":"Leslie Ma","tmdb_id":2625134,"profile":"https://image.tmdb.org/t/p/w500/dE4Y7RAOWuOtrcMuT927Cp6GlFN