ream10.com/20220506/12126_31431d51/index.m3u8"},{"name":"14","slug":"14","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-14","link_embed":"https://vip.opstream10.com/share/8a2bd3e7515b99c88006a6956bc284e9","link_m3u8":"https://vip.opstream10.com/20220506/12130_55cfd9c5/index.m3u8"},{"name":"15","slug":"15","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-15","link_embed":"https://vip.opstream10.com/share/37e01843867c460c5db02b0e58a6f236","link_m3u8":"https://vip.opstream10.com/20220506/12133_2b4f89d2/index.m3u8"},{"name":"16","slug":"16","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-16","link_embed":"https://vip.opstream10.com/share/14f9518c8b937874621f29425161acec","link_m3u8":"https://vip.opstream10.com/20220506/12134_dc6265ba/index.m3u8"},{"name":"17","slug":"17","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-17","link_embed":"https://vip.opstream10.com/share/63566593593fddb72f294a2d7e84ae13","link_m3u8":"https://vip.opstream10.com/20220506/12137_d190c0d5/index.m3u8"},{"name":"18","slug":"18","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-18","link_embed":"https://vip.opstream10.com/share/4163634d39ec5b1d3e126f44619243b2","link_m3u8":"https://vip.opstream10.com/20220506/12138_1c9cdd11/index.m3u8"},{"name":"19","slug":"19","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-19","link_embed":"https://vip.opstream10.com/share/c5c548e462f63499be7e59ff9f3d8e40","link_m3u8":"https://vip.opstream10.com/20220506/12139_3f4a30d1/index.m3u8"},{"name":"20","slug":"20","filename":"phap-y-tan-minh-medical-examiner-dr-qin-tap-20","link_embed":"https://vip.opstream10.com/share/87ca4eb840b6f78e3b6d6b418c0fef40","link_m3u8":"https://vip.opstream10.com/20220506/12142_d03231ee/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim Pháp Y Tần Minh - Medical Examiner Dr. Qin 2016: chuyển thể từ tiểu thuyết cùng tên, \"Bàn tay có quỷ vạn kiếp bất phục, nhân gian thái bình tồn tại Phật tâm. Kéo lớp chỉ tơ phân giải tiếng nói của tử thi, nhìn rõ mọi việc rửa sạch oan tình\". Tần Minh là pháp y tuấn tú, cao lãnh, có thâm niên cao trong lĩnh vực giải phẩu tử thi, năng lực logic vô cùng mạnh, tâm tư kín đáo. Thường rất dễ dàng tìm thấy những manh mói bị bỏ quên trên thi thể nạn nhân, điều tra vì vụ án, cung cấp những manh mối mới quan trọng cho việc phá án. \"Câu chuyện của người chết\" kết giao với anh, anh chính là \"Qủy thủ Phật tâm\".</p>","tmdb":{"type":"tv","id":"68095","season":1,"vote_average":7.706,"vote_count":17},"modified":"2023-06-17T19:44:37.000Z","cast":["Trương Nhược Quân","Jiao Junyan","Lý Hiện","Qian Bo","Qu Jingjing","Yu Mingjia","Hu Chang Lin","Wang Chuang"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Trương Nhược Quân","name_vi":"Trương Nhược Quân","name_original":"Zhang Ruoyun","tmdb_id":1675905,"profile":"https://image.tmdb.org/t/p/w500/dnNTcRc58ikoJ0JihisgXYTwr75.jpg","tmdb_url":"https://www.themoviedb.org/person/1675905"},{"name":"Jiao Junyan","name_vi":null,"name_original":"Jiao Junyan","tmdb_id":1353694,"profile":"https://image.tmdb.org/t/p/w500/bYgmlpj2hEg1CHIFTTYoAzacCfZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1353694"},{"name":"Lý Hiện","name_vi":"Lý Hiện","name_original":"Li Xian","tmdb_id":1384277,"profile":"https://image.tmdb.org/t/p/w500/ntLuULsNhPr9fBzV9ZLBY3URJ5t.jpg","tmdb_url":"https://www.themoviedb.org/person/1384277"},{"name":"Qian Bo","name_vi":null,"name_original":"Qian Bo","tmdb_id":1377794,"profile":"https://image.tmdb.org/t/p/w500/9IUPYwY58v2kapgtYsSe2MXfXuo.jpg","tmdb_url":"https://www.themoviedb.org/person/1377794"},{"name":"Qu Jingjing","name_vi":null,"name_original":"Qu Jingjing","tmdb_id":1545797,"profile":"https://image.tmdb.org/t/p/w500/bVUWwqam6mGzFndmEYFJa31TVZU.jpg","tmdb_url":"https://www.themoviedb.org/person/1545797"},{"name":"Yu Mingjia","name_vi":null,"name_original":"Yu Mingjia","tmdb_id":1912832,"profile":"https://image.tmdb.org/t/p/w500/vnTYJHvGIpjXZcB0oIa4zMxzF8r.jpg","tmdb_url":"https://www.themoviedb.org/person/19128