d8/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream90.com/share/1cea227cb2ca29383f916aef863a2dd8","link_m3u8":"https://vip.opstream90.com/20251213/20043_1cea227c/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream90.com/share/149a11285a240705355ff4fe66dc3731","link_m3u8":"https://vip.opstream90.com/20251214/20114_149a1128/index.m3u8"}]}],"description":"<p>Thạch Phi Phàm, một chàng trai mê lịch sử sống ở thời hiện đại, bất ngờ xuyên qua giấc mộng đến Đại Nam Triều, trở thành công tử trùng tên trứ danh ăn chơi lêu lổng. Để giữ vững cơ nghiệp nhà họ Thạch, hắn bề ngoài ngông cuồng tiêu tiền như nước, nhưng sau lưng lại âm thầm vận dụng kiến thức hiện đại để xoay chuyển thời cuộc. Từ khuấy đảo thị trường tơ lụa để trở thành phú hộ khét tiếng, phá giải âm mưu của người Khương, cứu Trưởng Công chúa khỏi hiểm cảnh, đến trừ khử thân vương tâm địa độc ác, vì thế mà hắn dần được Hoàng đế ngầm tín nhiệm. Khi được điều tới Tây Sơn để chấn chỉnh quân đội, kẻ từng bị coi thường năm ấy lại chậm rãi lột xác, âm thầm nắm giữ binh quyền.</p><p>&nbsp;</p>","tmdb_id":306916,"cast":["Phó Vỹ Luân","Yuan Yi","Hồ Vân Hạo","Gao Guangze","Pan Yue","Zhao Xu Ansheng"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"306916","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Phó Vỹ Luân","name_vi":"Phó Vỹ Luân","name_original":"Fu Weilun","tmdb_id":3065225,"profile":"https://image.tmdb.org/t/p/w500/mfoiw8LCBDQW6WJGpXy89p1vC6U.jpg","tmdb_url":"https://www.themoviedb.org/person/3065225"},{"name":"Yuan Yi","name_vi":null,"name_original":"Yuan Yi","tmdb_id":3304353,"profile":"https://image.tmdb.org/t/p/w500/btN5wjb55kWbll1R5zjV6jb2NEX.jpg","tmdb_url":"https://www.themoviedb.org/person/3304353"},{"name":"Hồ Vân Hạo","name_vi":"Hồ Vân Hạo","name_original":"Hu Yunhao","tmdb_id":2371440,"profile":"https://image.tmdb.org/t/p/w500/hpAM8rpi8w8ip9Aro1EVmpP821G.jpg","tmdb_url":"https://www.themoviedb.org/person/2371440"},{"name":"Gao Guangze",