30","filename":"phi-thien-than-ky-the-dance-in-the-sky-tap-30","link_embed":"https://vip.opstream11.com/share/1bb5dc166a3dd535de9fb463e487a03c","link_m3u8":"https://vip.opstream11.com/20220423/18983_28ce6bb9/index.m3u8"},{"name":"31","slug":"31","filename":"phi-thien-than-ky-the-dance-in-the-sky-tap-31","link_embed":"https://vip.opstream11.com/share/1dc7b8d3a70a972cda120ec7ebb61012","link_m3u8":"https://vip.opstream11.com/20220423/18984_b54c5881/index.m3u8"},{"name":"32","slug":"32","filename":"phi-thien-than-ky-the-dance-in-the-sky-tap-32","link_embed":"https://vip.opstream11.com/share/ad1c145ebcbfebe02e9107405d585cee","link_m3u8":"https://vip.opstream11.com/20220423/18985_48b968f7/index.m3u8"},{"name":"33","slug":"33","filename":"phi-thien-than-ky-the-dance-in-the-sky-tap-33","link_embed":"https://vip.opstream11.com/share/b5c480f68b9454070586dd8151546e16","link_m3u8":"https://vip.opstream11.com/20220423/18986_d9a9f21f/index.m3u8"}]}],"time":"45 phút","description":"<p>Phi Thiên Thần Ký là bộ phim được Trung Quốc sản xuất với sự tham gia diễn xuất của nhiều diễn viên Hàn Quốc.Phi Thiên Thần Ký xoay quanh cuộc đời của Lưu Trần Hạ. Cha của Lưu Trần Hạ mất lúc anh còn nhỏ và anh được truyền lại bí kíp Phi Thiên Thần Ký hội tụ đầy đủ tuyệt học võ thuật kiếm phái. Khi cha bị giết, Trần Hạ được Quách Tạng đưa đi bỏ trốn và nuôi dưỡng cho đến lớn. Hai mươi năm sau, Trần Hạ trở thành một thanh niên cường tráng và đầy sinh khí, anh đã học được cảnh giới cao của kiếm thuật và trở thành vô song kiếm pháp. Thế nhưng, anh hùng không qua được ải mỹ nhân, và Trần Hạ cũng như vậy. Trần Hạ yêu một người con gái nhưng nghiệt ngã thay, đó lại là con gái của kẻ thù giết cha mình khi xưa. Trần Hạ vẫn ôm trong lòng mối hận thù đó và quyết tâm trả thù.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-06-29T18:31:35.000Z","cast":["Park Ji Yoon","Kim Kang Woo","Park Shin Hye","Park Jin Woo","Lee Jong Hyuk"],"director":["Yoon Sang Ho"],"cast_m