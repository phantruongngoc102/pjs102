ng ở bên Sở Nhất Phàm.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ph/phi-thuong-short-drama.json","tmdb_checked":false}