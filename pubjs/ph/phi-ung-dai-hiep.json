://vip.opstream17.com/share/003bed21fddc817050c8fa11897fe660","link_m3u8":"https://vip.opstream17.com/20240820/17382_f736a317/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/6dce2d065c96e556331c1407a7491c7d","link_m3u8":"https://vip.opstream17.com/20240820/17383_f8ea1b27/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/e419ad025df62fbc3cc87331f5bf56cd","link_m3u8":"https://vip.opstream17.com/20240820/17384_78245879/index.m3u8"}]}],"description":"<p><i>Đinh gia nhiều đời làm nghề truy nã tội phạm, truyền nhân tôn xưng là Phi Ưng. Một người thần bí bỏ ra số tiền lớn ủy thác Đinh Lam truy bắt tàn dư của Bái Nguyệt Giáo. Trong lúc điều tra Lam bị rơi vào sự an bài ép cùng tiểu thư Nghê Thiên Nhi, ngược với dự đoán Lam, Lam đã tìm cách bỏ trốn. Lam gặp được tuyệt sắc danh kỹ Tố Tố, đem lòng yêu thương cuối cùng mới biết nàng chính là người thần bí. Trong ngày Lam và Tố Tố thành thân, Nghê Lão bị Tứ Đại Ác Nhân giết chết, lúc này Tố Tố mới biết mình chính là truyền nhân của Bái Nguyệt Giáo. Mang nối huyết thù nàng luyện thành Tuyệt Tình Đao, cuối cùng bị danh sĩ truy sát. Lam vì cứu nàng bị quy tội cấu kết ma giáo khiến nhà tan cửa nát…</i></p>","tmdb_id":109734,"cast":["Trịnh Thiếu Thu","Angie Chiu Nga-Chi","Trần Ngọc Liên","Stephen Tung Wai","Yiu Wai","Quan Hải Sơn","Isabella Wong","Dao-Hung Lee","Quách Phong","Tô Hạnh Tuyền","Miêu Kiều Vỹ","Lily Ng Lai-Chu","Lưu Đan","Alan Chan Kwok-Kuen","Mark Cheung Lui"],"director":["Lý Đình Luân"],"keywords":[],"tmdb":{"type":"tv","id":"109734","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trịnh Thiếu Thu","name_vi":"Trịnh Thiếu Thu","name_original":"Adam Cheng Siu-Chow","tmdb_id":82401,"profile":"https://image.tmdb.org/t/p/w500/KHy7b3kAXP05VGcdsPy3Qf34GM.jpg","tmdb_url":"https://www.themoviedb.org/person/82401"},{"name":"Angie Chiu Nga-Chi","name_vi":null,"name_original":"Angie Chiu Nga-Chi","tmdb_id":327585,"profile":"https://image.tmdb.o