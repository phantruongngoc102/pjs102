re/0b6cf75f58aca50278bdcfc9c46576f4","link_m3u8":"https://vip.opstream16.com/20221022/24557_c7bd6bc0/index.m3u8"},{"name":"41","slug":"41","filename":"phien-dich-vien-xinh-dep--eps-tap-41","link_embed":"https://vip.opstream16.com/share/7b4f363a4a6eae200c5096791b87dcf2","link_m3u8":"https://vip.opstream16.com/20221022/24558_682cc510/index.m3u8"},{"name":"42","slug":"42","filename":"phien-dich-vien-xinh-dep--eps-tap-42","link_embed":"https://vip.opstream16.com/share/64744829a161fdb5d0fb42af83c627cd","link_m3u8":"https://vip.opstream16.com/20221022/24559_fd54deac/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phiên Dịch Viên Xinh Đẹp do Hoàng Hiên và Dương Mịch đảm nhận vai chính. Phim kể về Kiều Phi - nữ thạc sĩ khoa tiếng Pháp từ nhỏ đã mơ ước lớn lên trở thành một phiên dịch viên chuyên nghiệp. Một lần tình cờ, cô đã quen biết với anh chàng Trình Gia Dương - một thiên tài phiên dịch. Và bởi vì đang trốn tránh bạn trai cũ Cao Gia Minh nên Kiều Phi và Gia Dương đã trở thành oan gia ngõ hẹp. Không ngờ, ngày hôm sau trong cuộc phỏng vấn tuyển dụng phiên dịch, Kiều Phi phát hiện ra Gia Dương chính là vị giám khảo phỏng vấn.</p>","tmdb":{"type":"tv","id":"68043","season":1,"vote_average":6.25,"vote_count":4},"modified":"2022-10-23T11:31:03.000Z","cast":["Dương Mịch","Hoàng Hiên","Cao Vỹ Quang","Zhou Qiqi","Trương Vân Long","Sierra Li","Lý Đông Hằng"],"director":["Vương Nghênh"],"cast_meta":[{"name":"Dương Mịch","name_vi":"Dương Mịch","name_original":"Yang Mi","tmdb_id":572043,"profile":"https://image.tmdb.org/t/p/w500/lPQ9RgOj5hY5AYRJ8G1CedjdCGz.jpg","tmdb_url":"https://www.themoviedb.org/person/572043"},{"name":"Hoàng Hiên","name_vi":"Hoàng Hiên","name_original":"Huang Xuan","tmdb_id":1376106,"profile":"https://image.tmdb.org/t/p/w500/dedh0tG92cerVlFOJRX3YRBI3Lk.jpg","tmdb_url":"https://www.themoviedb.org/person/1376106"},{"name":"Cao Vỹ Quang","name_vi":"Cao Vỹ Quang","name_original":"Gao Weiguang","tmdb_id":1686321,"profile":"https://image.tmdb.org/t/p/w500/iJE