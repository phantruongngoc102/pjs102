am14.com/share/28513c6ecd19265370792e81561c6011","link_m3u8":"https://vip.opstream14.com/20220908/21210_bbcfe815/index.m3u8"}]}],"description":"<p>Vào lúc nửa đêm trong Lễ hội Phật giáo (Ngày cạo đầu và Đêm trăng tròn), 6 thần tượng nổi tiếng là Kacha, Boon, Zee, Talay, Tommy và Mark đã đến địa điểm do công ty DnD sắp xếp. Họ tập trung ở đây để tập luyện cho chương trình biểu diễn lớn đầu tiên trong năm của họ. Nhưng không ai ngờ rằng, tại căn phòng màu đỏ gạch này, họ đã gặp Rose, một linh hồn đã sống ở đây hơn 200 năm. Cô là một linh hồn cô đơn, điên cuồng, bị ám ảnh bởi những bộ phim truyền hình và ngượng ngùng khi gặp được những idol này. Giữa họ xảy ra một loạt những sự hỗn loạn. Tình huống vừa bất ngờ ngoài sức tưởng tượng, vừa kỳ quái và vui nhộn. Sự kiện bí ẩn trong ngôi nhà màu đỏ gạch buộc 6 thanh niên này buộc phải bắt đầu cuộc phiêu lưu mạo hiểm của mình để tìm hiểu xem những điều đã xảy ra với họ là ma ám thật, hay chỉ là trong sự tưởng tượng của họ...</p>","tmdb_id":204176,"cast":["Pinyadar Salinvarradar","Pruk Panich","Talay Sanguandikul","Siwat Jumlongkul","Noppanut Guntachai","Nontanun Anchuleepradit","Sittichok Pueakpoolpol","Setthanan Manunapichu","Nipaporn Thititanakarn","Rina Chatamonchai","Channarong Khuntee-tao"],"director":["David Bigander"],"keywords":[],"tmdb":{"type":"tv","id":"204176","season":1,"vote_average":9,"vote_count":1},"cast_meta":[{"name":"Pinyadar Salinvarradar","name_vi":null,"name_original":"Pinyadar Salinvarradar","tmdb_id":2073911,"profile":"https://image.tmdb.org/t/p/w500/89dauZlcbtejcMUQnQVlkkDO2Ey.jpg","tmdb_url":"https://www.themoviedb.org/person/2073911"},{"name":"Pruk Panich","name_vi":null,"name_original":"Pruk Panich","tmdb_id":2417467,"profile":"https://image.tmdb.org/t/p/w500/9Ox28Hi7KRLJs72KymmSwbpG7t4.jpg","tmdb_url":"https://www.themoviedb.org/person/2417467"},{"name":"Talay Sanguandikul","name_vi":null,"name_original":"Talay Sanguandikul","tmdb_id":2567319,"profile":"https://image.tmdb.org/t/p/w500/5Xa3X8qYcwG