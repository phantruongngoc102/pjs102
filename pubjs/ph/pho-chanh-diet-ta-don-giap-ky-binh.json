71","season":1,"vote_average":0,"vote_count":0},"modified":"2023-10-01T14:22:54.000Z","cast":["Huỳnh Nhật Hoa","Đặng Tụy Văn","Thương Thiên Nga","Newton Lai Hon-Chi","Lisa Lui Yau-Wai","Hứa Thiệu Hùng","Liêu Khải Trí","Lạc Ứng Quân","Cheng Ka-Sang","La Lan","Ngô Mạnh Đạt","Cao Hùng","Tam Chuen-Hing"],"director":["Lý Huệ Dân"],"cast_meta":[{"name":"Huỳnh Nhật Hoa","name_vi":"Huỳnh Nhật Hoa","name_original":"Felix Wong Yat-Wah","tmdb_id":71655,"profile":"https://image.tmdb.org/t/p/w500/9HooA3aF764XKYU8GUxO4P7v5gZ.jpg","tmdb_url":"https://www.themoviedb.org/person/71655"},{"name":"Đặng Tụy Văn","name_vi":"Đặng Tụy Văn","name_original":"Sheren Tang Shui-Man","tmdb_id":997296,"profile":"https://image.tmdb.org/t/p/w500/sJ9nrY567ikJ4c2T5wxxuVTB9Ft.jpg","tmdb_url":"https://www.themoviedb.org/person/997296"},{"name":"Thương Thiên Nga","name_vi":"Thương Thiên Nga","name_original":"Kiki Sheung","tmdb_id":1588963,"profile":"https://image.tmdb.org/t/p/w500/pr43xrvugDA6fjlsjfeyqKUEUjg.jpg","tmdb_url":"https://www.themoviedb.org/person/1588963"},{"name":"Newton Lai Hon-Chi","name_vi":null,"name_original":"Newton Lai Hon-Chi","tmdb_id":1374601,"profile":"https://image.tmdb.org/t/p/w500/c72zuZdBwkmejCruFh28IgyxBJH.jpg","tmdb_url":"https://www.themoviedb.org/person/1374601"},{"name":"Lisa Lui Yau-Wai","name_vi":null,"name_original":"Lisa Lui Yau-Wai","tmdb_id":1178955,"profile":"https://image.tmdb.org/t/p/w500/uoqoJmvFeIgQkMKBYy9G04IuclA.jpg","tmdb_url":"https://www.themoviedb.org/person/1178955"},{"name":"Hứa Thiệu Hùng","name_vi":"Hứa Thiệu Hùng","name_original":"Benz Hui Siu-Hung","tmdb_id":63582,"profile":"https://image.tmdb.org/t/p/w500/bgC8VLG8bBdbQTuiHQtjFlEXo6E.jpg","tmdb_url":"https://www.themoviedb.org/person/63582"},{"name":"Liêu Khải Trí","name_vi":"Liêu Khải Trí","name_original":"Liu Kai-Chi","tmdb_id":116423,"profile":"https://image.tmdb.org/t/p/w500/tOqH5blJzabTfM9dk6EWQ6uIDz7.jpg","tmdb_url":"https://www.themoviedb.org/person/116423"},{"name":"Lạc Ứng Quân","name_vi":