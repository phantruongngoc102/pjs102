 Thuân","name_vi":"Tôn Thần Thuân","name_original":"Sun Chenjun","tmdb_id":2830737,"profile":"https://image.tmdb.org/t/p/w500/2QAr710FGLb65bFmHEjQcHK09VS.jpg","tmdb_url":"https://www.themoviedb.org/person/2830737"},{"name":"Hồ Diệc Dao","name_vi":"Hồ Diệc Dao","name_original":"Hu Yiyao","tmdb_id":4284315,"profile":"https://image.tmdb.org/t/p/w500/6Evom0l5JFJvZr4dNh2xlIq1nMX.jpg","tmdb_url":"https://www.themoviedb.org/person/4284315"},{"name":"Wang Xingwei","name_vi":null,"name_original":"Wang Xingwei","tmdb_id":2612007,"profile":"https://image.tmdb.org/t/p/w500/ogIeggyCJOb84nSNSa1v6By8EM4.jpg","tmdb_url":"https://www.themoviedb.org/person/2612007"},{"name":"Qiao Jingwen","name_vi":null,"name_original":"Qiao Jingwen","tmdb_id":3456395,"profile":"https://image.tmdb.org/t/p/w500/gg2cqPOQy3JjASF9DDkopNHM5Le.jpg","tmdb_url":"https://www.themoviedb.org/person/3456395"},{"name":"Lei Shu","name_vi":null,"name_original":"Lei Shu","tmdb_id":4876372,"profile":"https://image.tmdb.org/t/p/w500/j3bPbWi8CvzUk36q5pAJpkuOV6H.jpg","tmdb_url":"https://www.themoviedb.org/person/4876372"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ph/pho-nhan.json"}