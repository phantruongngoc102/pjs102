iption":"<p>Xoay quanh câu chuyện tình cảm của một anh chàng CEO Tiêu Hàn và cô nàng MC nổi tiếng trong giới showbiz Diệp Phồn Tinh. Họ là những người trẻ nhiệt huyết với trái tim yêu chân thành, họ âm thầm trao nhau những tình cảm chân thành nhất, không phô trương vì sợ ảnh hưởng đến công việc của người bạn gái. Phồn Tinh có một quá khứ không mấy tốt đẹp và người mẹ bị mắc bệnh tâm thần, nhiều khi thần trí không ổn định...</p>","tmdb":{"type":"tv","id":"127090","season":1,"vote_average":0,"vote_count":0},"modified":"2022-05-31T17:14:28.000Z","cast":["Qi Wei","Ngô Kỳ Long","Zuo Hang","Ren Yankai","Wang Fei","Đặng Tụy Văn","Wei Lai","吴华新"],"director":["Vicky Wong"],"cast_meta":[{"name":"Qi Wei","name_vi":null,"name_original":"Qi Wei","tmdb_id":1276002,"profile":"https://image.tmdb.org/t/p/w500/hNczmTxWQsdlbHrAkPlyixLPmH3.jpg","tmdb_url":"https://www.themoviedb.org/person/1276002"},{"name":"Ngô Kỳ Long","name_vi":"Ngô Kỳ Long","name_original":"Nicky Wu","tmdb_id":559987,"profile":"https://image.tmdb.org/t/p/w500/kVSCQ27NmxpSBjUmKQpdgqzGvqs.jpg","tmdb_url":"https://www.themoviedb.org/person/559987"},{"name":"Zuo Hang","name_vi":null,"name_original":"Zuo Hang","tmdb_id":2572156,"profile":"https://image.tmdb.org/t/p/w500/dxbgjn8RdmiM3libJ3nRAwt1Je4.jpg","tmdb_url":"https://www.themoviedb.org/person/2572156"},{"name":"Ren Yankai","name_vi":null,"name_original":"Ren Yankai","tmdb_id":1832633,"profile":"https://image.tmdb.org/t/p/w500/mAp597xMMNDLhXCp1xRwieA00J.jpg","tmdb_url":"https://www.themoviedb.org/person/1832633"},{"name":"Wang Fei","name_vi":null,"name_original":"Wang Fei","tmdb_id":3817661,"profile":"https://image.tmdb.org/t/p/w500/3ScW94qdTQb4Q3GZqyjkk6csWl9.jpg","tmdb_url":"https://www.themoviedb.org/person/3817661"},{"name":"Đặng Tụy Văn","name_vi":"Đặng Tụy Văn","name_original":"Sheren Tang Shui-Man","tmdb_id":997296,"profile":"https://image.tmdb.org/t/p/w500/sJ9nrY567ikJ4c2T5wxxuVTB9Ft.jpg","tmdb_url":"https://www.themoviedb.org/person/997296"},{"name":"Wei La