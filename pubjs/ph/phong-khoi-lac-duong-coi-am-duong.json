nh thần chính nghĩa, can đảm, trong một thế giới hỗn loạn.</p>","tmdb_id":931217,"cast":["Nan Sheng","Zhang Jiahang","Diana Dai","Zhang Chunzhong","Wu Chunyi","Naomen Eerdeni","Han Mengwu","Li Ping'an","Li Shiyan"],"director":["Dai Yilin"],"keywords":["风起洛阳之阴阳界"],"cast_meta":[{"name":"Nan Sheng","name_vi":null,"name_original":"Nan Sheng","tmdb_id":1515836,"profile":"https://image.tmdb.org/t/p/w500/zzTNpt86b7tpfgqpckYkHExfIzK.jpg","tmdb_url":"https://www.themoviedb.org/person/1515836"},{"name":"Zhang Jiahang","name_vi":null,"name_original":"Zhang Jiahang","tmdb_id":3066607,"profile":"https://image.tmdb.org/t/p/w500/5RUafogKryEgp7mmKZD9ft8Fr4.jpg","tmdb_url":"https://www.themoviedb.org/person/3066607"},{"name":"Diana Dai","name_vi":null,"name_original":"Diana Dai","tmdb_id":2521010,"profile":"https://image.tmdb.org/t/p/w500/hQOrTybFRipdOF02T4UfTtWGwSB.jpg","tmdb_url":"https://www.themoviedb.org/person/2521010"},{"name":"Zhang Chunzhong","name_vi":null,"name_original":"Zhang Chunzhong","tmdb_id":1611492,"profile":"https://image.tmdb.org/t/p/w500/iw6dzpP1TV1fHOhSbNRkOkS4XJR.jpg","tmdb_url":"https://www.themoviedb.org/person/1611492"},{"name":"Wu Chunyi","name_vi":null,"name_original":"Wu Chunyi","tmdb_id":2982510,"profile":"https://image.tmdb.org/t/p/w500/xYfsZoZcwDHGvSmN6xN7zQ1tOik.jpg","tmdb_url":"https://www.themoviedb.org/person/2982510"},{"name":"Naomen Eerdeni","name_vi":null,"name_original":"Naomen Eerdeni","tmdb_id":2211206,"profile":"https://image.tmdb.org/t/p/w500/zWoUp9KpTW2l2LLXRV4EE49PQEM.jpg","tmdb_url":"https://www.themoviedb.org/person/2211206"},{"name":"Han Mengwu","name_vi":null,"name_original":"Han Mengwu","tmdb_id":3025365,"profile":"https://image.tmdb.org/t/p/w500/ovN75PtDeSgcFq2l1nEKa8gHgbf.jpg","tmdb_url":"https://www.themoviedb.org/person/3025365"},{"name":"Li Ping'an","name_vi":null,"name_original":"Li Ping'an","tmdb_id":2696443,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2696443"},{"name":"Li Shiyan","name_vi":null,"name_origin