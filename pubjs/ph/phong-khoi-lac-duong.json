12},"modified":"2023-05-22T18:37:43.000Z","cast":["Hoàng Hiên","Vương Nhất Bác","Tống Thiến","Tống Dật","Lưu Đoan Đoan","Yong Mei","Zhang Duo","Trương Lệ","Trương Hy Lâm","Cao Thự Quang","Ninh Văn Đồng","Feng Hui","Tương Long","Han Shuai","Zhang Junming"],"director":["Tạ Trạch"],"cast_meta":[{"name":"Hoàng Hiên","name_vi":"Hoàng Hiên","name_original":"Huang Xuan","tmdb_id":1376106,"profile":"https://image.tmdb.org/t/p/w500/dedh0tG92cerVlFOJRX3YRBI3Lk.jpg","tmdb_url":"https://www.themoviedb.org/person/1376106"},{"name":"Vương Nhất Bác","name_vi":"Vương Nhất Bác","name_original":"Wang Yibo","tmdb_id":1594612,"profile":"https://image.tmdb.org/t/p/w500/5akr656RvJX8hl1pa1qZckfiQeF.jpg","tmdb_url":"https://www.themoviedb.org/person/1594612"},{"name":"Tống Thiến","name_vi":"Tống Thiến","name_original":"Victoria Song","tmdb_id":1255268,"profile":"https://image.tmdb.org/t/p/w500/xOrFdPmJXdmuSSMAF12AwSDpHw3.jpg","tmdb_url":"https://www.themoviedb.org/person/1255268"},{"name":"Tống Dật","name_vi":"Tống Dật","name_original":"Song Yi","tmdb_id":1877119,"profile":"https://image.tmdb.org/t/p/w500/10IcNNHWQ7WGktAcfDtClJnapUo.jpg","tmdb_url":"https://www.themoviedb.org/person/1877119"},{"name":"Lưu Đoan Đoan","name_vi":"Lưu Đoan Đoan","name_original":"Liu Duanduan","tmdb_id":2610694,"profile":"https://image.tmdb.org/t/p/w500/9f839TXRckHQnMckQuZbxej77go.jpg","tmdb_url":"https://www.themoviedb.org/person/2610694"},{"name":"Yong Mei","name_vi":null,"name_original":"Yong Mei","tmdb_id":572086,"profile":"https://image.tmdb.org/t/p/w500/eV9HqX66KpY3badNQT03df2wOiS.jpg","tmdb_url":"https://www.themoviedb.org/person/572086"},{"name":"Zhang Duo","name_vi":null,"name_original":"Zhang Duo","tmdb_id":2759503,"profile":"https://image.tmdb.org/t/p/w500/n6XlynBaTL5eOY0xezAxDI0pKWT.jpg","tmdb_url":"https://www.themoviedb.org/person/2759503"},{"name":"Trương Lệ","name_vi":"Trương Lệ","name_original":"Zhang Li","tmdb_id":1993060,"profile":"https://image.tmdb.org/t/p/w500/eEvYNGg8NnyQlH1wWUcXdWvDEMB.j