":"19","filename":"PhongKhoiLungTay-19","link_embed":"https://vip.opstream16.com/share/5e8900c415afdd93abdc76e826e3a51f","link_m3u8":"https://vip.opstream16.com/20230412/33829_e510beea/index.m3u8"},{"name":"20","slug":"20","filename":"PhongKhoiLungTay-20","link_embed":"https://vip.opstream16.com/share/5dddaf9d765767a1a9fbce4362325e89","link_m3u8":"https://vip.opstream16.com/20230412/33830_ba6e2235/index.m3u8"},{"name":"21","slug":"21","filename":"PhongKhoiLungTay-21","link_embed":"https://vip.opstream16.com/share/8d05cb6ec0e2376c67e241be21b9ab6b","link_m3u8":"https://vip.opstream16.com/20230412/33831_97584495/index.m3u8"},{"name":"22","slug":"22","filename":"PhongKhoiLungTay-22","link_embed":"https://vip.opstream16.com/share/b6112307fe321db79a00e9632a8b87cd","link_m3u8":"https://vip.opstream16.com/20230412/33832_f8d211a4/index.m3u8"},{"name":"23","slug":"23","filename":"PhongKhoiLungTay-23","link_embed":"https://vip.opstream16.com/share/75a4f927be158aa885fea8c355d01af3","link_m3u8":"https://vip.opstream16.com/20230412/33833_7e5c4b9b/index.m3u8"},{"name":"24","slug":"24","filename":"PhongKhoiLungTay-24","link_embed":"https://vip.opstream16.com/share/b754a30717cd71d8944a731e26b113f0","link_m3u8":"https://vip.opstream16.com/20230412/33834_dd772408/index.m3u8"}]}],"time":"45 phút/tập","description":"Phong Khởi Lũng Tây kể về câu chuyện trong thời kỳ cuộc chiến giữa Ngụy và Thục khi mà quân Thục đã đánh bại quân Ngụy bằng nỏ do họ chế tạo. Để có được vũ khí lợi hại này, nhà Ngụy đã cử rất nhiều gián điệp xâm nhập vào vương quốc Thục và đánh cắp nó. Trần Cung và Tuân Hủ là những gián điệp của quân Thục đã xâm nhập vào vương quốc Ngụy trong nhiều năm. Sau khi biết kế hoạch của Ngụy, họ quyết định rằng cần phải ngăn chặn điều đó. Trần Cung tiếp tục ở lại nước Ngụy, trong khi Tuân Hủ trở về nước Thục và ngăn chặn kế hoạch đánh cắp thiết kế đồng thời tìm ra nội gián trong cục tình báo của Ngụy. Trần Công sau đó cũng kết thúc nhiệm vụ gián điệp và trở về Thục. Trải qua nhiều thử thách, cuối cùng sự thật đằng sau \\\"kế hoạch Thanh Bình\\\" cũng bại lộ. Trước gia đình và đất nước, Tuân Hủ và Trần Công đã đưa ra lựa chọn đúng đắn vào thời điểm thích hợp, hóa giải âm mưu thâm độc của kẻ thù, giữ vững sự ổn định và thống nhất của đất nước.","tmdb":{"type":"tv","id":"136548","season":1,"vote_average":6.9,"vote_count":14},"modified":"2025-04-13T10:37:05.000Z","cast":["Trần Khôn","Bạch Vũ","Nhiếp Viễn","Doãn Chú Thắng","Chang Yuan","Angelababy","Tôn Di","Yu Haoming","Wang Xiao","Zhang Xiaochen","Dương Triệt"],"director":["Lu Yang"],"cast_meta":[{"name":"Trần Khôn","name_vi":"Trần Khôn","name_original":"Chen Kun","tmdb_id":109809,"profile":"https://image.tmdb.org/t/p/w500/8Ma3koAYXGXE6y2IfrBZME7BC05.jpg","tmdb_url":"https://www.themoviedb.org/person/109809"},{"name":"Bạch Vũ","name_vi":"Bạch Vũ","name_original":"Bai Yu","tmdb_id":1698814,"profile":"https://image.tmdb.org/t/p/w500/9CWqaJKh4IlJZ60SwqkOMXNAroL.jpg","tmdb_url":"https://www.themoviedb.org/person/1698814"},{"name":"Nhiếp Viễn","name_vi":"Nhiếp Viễn","name_original":"Nie Yuan","tmdb_id":1251627,"profile":"https://image.tmdb.org/t/p/w500/mI99d1TAys4QztwiPaw0AlAZQ59.jpg","tmdb_url":"https://www.themoviedb.org/person/1251627"},{"name":"Doãn Chú Thắng","name_vi":"Doãn Chú Thắng","name_original":"Yin Zhusheng","tmdb_id":1174659,"profile":"https://image.tmdb.org/t/p/w500/5MuK3eCMOR3b5WANNGMeFbqXlJI.jpg","tmdb_url":"https://www.themoviedb.org/person/1174659"},{"name":"Chang Yuan","name_vi":null,"name_original":"Chang Yuan","tmdb_id":1985025,"profile":"https://image.tmdb.org/t/p/w500/ux4dSMHiIjRpCGawfpJkiE6spDI.jpg","tmdb_url":"https://www.themoviedb.org/person/1985025"},{"name":"Angelababy","name_vi":"Angelababy","name_original":"AngelaBaby","tmdb_id":150899,"profile":"https://image.tmdb.org/t/p/w500/gbnjGrNhlvGu1sXhcm0J2IW0orD.jpg","tmdb_url":"https://www.themoviedb.org/person/150899"},{"name":"Tôn Di","name_vi":"Tôn Di","name_original":"Sun Yi","tmdb_id":1689011,"profile":"https://image.tmd