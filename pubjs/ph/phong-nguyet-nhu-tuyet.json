3202_023daaae/index.m3u8"},{"name":"24","slug":"24","filename":"PHONG NGUYỆT NHƯ TUYẾT - Ep24","link_embed":"https://vip.opstream17.com/share/799de6d3dae4c924142cf245a1d7f703","link_m3u8":"https://vip.opstream17.com/20240325/3203_a5901111/index.m3u8"}]}],"time":"10 phút/tập","description":"<p>Để hóa giải vòng lặp lời nguyền luân hồi rồi lại chết thảm cho người thương Tô Tiểu Hoàn, Hồ yêu Bá Cừu đã một mình chịu đựng nỗi cô độc ngàn năm, chín kiếp yêu trong đọa đày. Kiếp này, cả nhà Tô Tiểu Hoàn đều chết thảm dưới tay Bá Cừu. Tô Tiểu Hoàn lưu lạc đầu đường xó chợ từ khi còn nhỏ, nếm trải hết thói đời bạc bẽo, sống lay lắt gian nan nhờ tính cách trơ lì không để ý sĩ diện. Về sau, cô bị Thái tử phế truất của tiền triều là Hiên Viên Thanh Xuyên lợi dụng, đưa vào hoàng cung, gài đến bên cạnh Hồ yêu vang danh tàn bạo khát máu, chờ cơ hội báo thù. Không ngờ định mệnh lại khiến cô phải lòng Hồ yêu lúc nào không hay. Kiếp này, để phá vỡ gông xiềng của số phận, Bá Cừu lựa chọn không nhận lại người mình yêu, quyết hy sinh bản thân, dùng tình yêu chân thành nhất cảm hóa đất trời, cuối cùng đã hóa giải được lời nguyền của Tô Tiểu Hoàn.</p>","tmdb":{"type":"tv","id":"235878","season":1,"vote_average":7.2,"vote_count":4},"modified":"2024-07-18T15:44:24.000Z","cast":["Li Jiaqi","Tả Diệp","Xiang Xin","Wang Hongxin"],"director":[],"cast_meta":[{"name":"Li Jiaqi","name_vi":null,"name_original":"Li Jiaqi","tmdb_id":1207608,"profile":"https://image.tmdb.org/t/p/w500/irRmvwQmWDaKJ270nZSSdSYGyrt.jpg","tmdb_url":"https://www.themoviedb.org/person/1207608"},{"name":"Tả Diệp","name_vi":"Tả Diệp","name_original":"Zuo Ye","tmdb_id":3331196,"profile":"https://image.tmdb.org/t/p/w500/zPz1aTYz4ObizCG1NE2wcHvlYAO.jpg","tmdb_url":"https://www.themoviedb.org/person/3331196"},{"name":"Xiang Xin","name_vi":null,"name_original":"Xiang Xin","tmdb_id":3885682,"profile":"https://image.tmdb.org/t/p/w500/uTlqf8bXQvYOfL98M5hprIDTO5c.jpg","tmdb_url":"https://www.themoviedb.org/person/3885682"},{"name":"Wang H