om/share/db639185398d079ec797dcaa27598f0b","link_m3u8":"https://vip.opstream12.com/20220514/15708_948a6e59/index.m3u8"},{"name":"64B","slug":"64b","link_embed":"https://vip.opstream12.com/share/809c21abeab1b61fa578f1bc473aa3eb","link_m3u8":"https://vip.opstream12.com/20220514/15709_29a81e1c/index.m3u8"},{"name":"65A","slug":"65a","link_embed":"https://vip.opstream12.com/share/06b5f6218cc47f55b40a9c165b39c10b","link_m3u8":"https://vip.opstream12.com/20220514/15711_7bced60a/index.m3u8"},{"name":"65B","slug":"65b","link_embed":"https://vip.opstream12.com/share/e3db3d2c4e2856dcb72526473106baa5","link_m3u8":"https://vip.opstream12.com/20220514/15710_81109f71/index.m3u8"},{"name":"66A","slug":"66a","link_embed":"https://vip.opstream12.com/share/13fdf5cb75985771d5caef11c8551248","link_m3u8":"https://vip.opstream12.com/20220514/15712_f2a6239d/index.m3u8"},{"name":"66B","slug":"66b","link_embed":"https://vip.opstream12.com/share/1ee42f91b329feebf2cd3dadd8a704f2","link_m3u8":"https://vip.opstream12.com/20220514/15713_847eb93f/index.m3u8"}]}],"description":"<p>Phù Dao hoàng hậu có nội dung xoay quanh Mạnh Phù Dao (Dương Mịch) - một cô gái kiên cường, túc trí đa mưu vì muốn thu thập “mật lệnh” của Ngũ Châu mà phải trải qua muôn vàn hiểm nguy. Trên đường lang bạt, nàng gặp gỡ Trưởng Tôn Vô Cực (Nguyễn Kinh Thiên) và được chàng hết lòng giúp đỡ. Sát cánh bên nhau, hai người cùng chung sức bình ổn mưu đồ soán vị của Nhiếp chính vương nước Thái Uyên, dẹp yên giặc phương nam xâm phạm nước Vô Cực, lại liên thủ với Liệt vương Chiến Bắc Dã của nước Thiên Sát đoạt lại vương quyền, công bố thân phận Toàn Cơ nữ vương của Phù Dao.</p>","tmdb_id":76814,"cast":["Dương Mịch","Nguyễn Kinh Thiên","Cao Vỹ Quang","Lại Nghệ","Lưu Dịch Quân","Hồ Khả"],"director":["Dương Văn Quân","Tạ Trạch","Lý Tài"],"keywords":[],"time":"45 phút","tmdb":{"type":"tv","id":"76814","season":1,"vote_average":7.947,"vote_count":19},"cast_meta":[{"name":"Dương Mịch","name_vi":null,"name_original":"Dương Mịch"},{"name":"