29513_2346a7d2/index.m3u8"},{"name":"35","slug":"35","filename":"Unchained Love EP35","link_embed":"https://vip.opstream16.com/share/d75741b309bf39d3ef6be3b23990eeaf","link_m3u8":"https://vip.opstream16.com/20230120/29574_2f58c4ed/index.m3u8"},{"name":"36","slug":"36","filename":"Unchained Love EP36","link_embed":"https://vip.opstream16.com/share/1fae41f41823dafacc197c3f5121128e","link_m3u8":"https://vip.opstream16.com/20230120/29575_cc340230/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ Âm Lâu (Trần Ngọc Kỳ) là một nhân tài vừa lọt qua vòng tuyển tú lại không may nhận được chỉ thị sẽ bị tuẫn táng theo Tiên đế. Thế nhưng trong cái rủi lại có cái may, nàng được tân hoàng nhìn trúng và được Tiêu Đạc (Vương Hạc Đệ) cứu mạng sau đó an bài cho sống trong Tiêu phủ. Ngày qua ngày Âm Lâu và Tiêu Đạc chung sống cùng nhau đã dần nảy sinh tình cảm, nhưng cả hai cũng chỉ đành chôn chặt trong lòng vì trở ngại thân phận. Đối mặt với trùng trùng gian truân trắc trở, sự chèn ép của tân hoàng và bí mật đằng sau thân phận của Tiêu Đạt, liệu vận mệnh của bộ đôi sẽ đi về đâu và họ sẽ có một cái kết có hậu?</p>","tmdb":{"type":"tv","id":"210291","season":1,"vote_average":6,"vote_count":8},"modified":"2025-04-07T09:09:12.000Z","cast":["Vương Hạc Đệ","Trần Ngọc Kỳ","Hà Nhuận Đông","Tăng Lê","Hạc Thu","Vương Lịch Hâm","Quan Sướng","Han Yiting","Trình Tử","Kang Kang","Li Donghe"],"director":["Ngô Cường"],"cast_meta":[{"name":"Vương Hạc Đệ","name_vi":"Vương Hạc Đệ","name_original":"Dylan Wang","tmdb_id":2050456,"profile":"https://image.tmdb.org/t/p/w500/x05cU32ATgu1ekqoySAvF84TmCZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2050456"},{"name":"Trần Ngọc Kỳ","name_vi":"Trần Ngọc Kỳ","name_original":"Chen Yuqi","tmdb_id":2085448,"profile":"https://image.tmdb.org/t/p/w500/zRPQ7suBiQoCUEzt9BHtzKkxSAx.jpg","tmdb_url":"https://www.themoviedb.org/person/2085448"},{"name":"Hà Nhuận Đông","name_vi":"Hà Nhuận Đông","name_original":"Peter Ho","tmdb_id":2337443,"profile":"https://image