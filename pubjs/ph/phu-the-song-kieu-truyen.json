pstream14.com/share/8ba9f7401e1f60f3024ad195d4a24d8e","link_m3u8":"https://vip.opstream14.com/20220708/17682_9b3e8adb/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phù thế song kiều truyện lấy bối cảnh thời Hậu Chu, gia đình họ Phù là tâm điểm chú ý của thiên hạ với lời tiên tri nổi tiếng: Một trong những người con gái của gia đình Phù sẽ trở thành Hoàng hậu trong tương lai, và hai chị em họ Phù, họ sẽ gián tiếp phá hủy ngai vàng. Dưới hoàn cảnh trớ trêu, hai chị em nhà họ Phù lại rơi vào lưới tình của hai người đàn ông đối đầu nhau. Giữa \"thủy triều\" đen tối trong nhà Chu, hai chị em Phù Kim Trản (Lý Nghệ Đồng) và Phù Ngọc Trản (Mạnh Tử Nghĩa) không quên dòng máu chảy trong người mình khi cả hai là chị em ruột, họ cùng nhau bảo vệ sự thống trị của nhà Chu.</p>","tmdb":{"type":"tv","id":"110723","season":1,"vote_average":8.6,"vote_count":5},"modified":"2022-07-08T10:03:37.000Z","cast":["Lý Trị Đình","Mạnh Tử Nghĩa","Lý Nghệ Đồng","Uông Trác Thành","Ren Youlun","Zhong Qi","Chen Yingdan","Zhao Jia Rui","Hua Wen","Cao Xu","Chen Guoliang"],"director":["Lam Chí Vỹ","Hoàng Gia Huy"],"cast_meta":[{"name":"Lý Trị Đình","name_vi":"Lý Trị Đình","name_original":"Aarif Rahman","tmdb_id":148881,"profile":"https://image.tmdb.org/t/p/w500/qRA9oEDweIFhN0yZ4YTynJjkMdz.jpg","tmdb_url":"https://www.themoviedb.org/person/148881"},{"name":"Mạnh Tử Nghĩa","name_vi":"Mạnh Tử Nghĩa","name_original":"Meng Ziyi","tmdb_id":2128468,"profile":"https://image.tmdb.org/t/p/w500/R1cfuT9TQ2Xc7hsQHWzbzN0sbA.jpg","tmdb_url":"https://www.themoviedb.org/person/2128468"},{"name":"Lý Nghệ Đồng","name_vi":"Lý Nghệ Đồng","name_original":"Li Yitong","tmdb_id":3219664,"profile":"https://image.tmdb.org/t/p/w500/8QMAIQ9JhmemLCAMh8MbbeUhDfM.jpg","tmdb_url":"https://www.themoviedb.org/person/3219664"},{"name":"Uông Trác Thành","name_vi":"Uông Trác Thành","name_original":"Wang Zhuocheng","tmdb_id":2387789,"profile":"https://image.tmdb.org/t/p/w500/il9dYQ15Bs9U6iAZXfS2IsXPMvm.jpg","tmdb_url":"https://www