//vip.opstream15.com/share/dff828a2db2702a3b0d2790e23acd705","link_m3u8":"https://vip.opstream15.com/20220805/26225_3d855715/index.m3u8"},{"name":"7","slug":"7","filename":"Phù thủy có thật_S01E07_2022-08-06","link_embed":"https://vip.opstream14.com/share/489dca82b123cc23aa7500ea13028679","link_m3u8":"https://vip.opstream14.com/20220813/20089_ca323d83/index.m3u8"},{"name":"8","slug":"8","filename":"Phù thủy có thật_S01E08_2022-08-13","link_embed":"https://vip.opstream14.com/share/bf1c2d09a5b6e5182f66180ce8294ca9","link_m3u8":"https://vip.opstream14.com/20220819/20383_c6b7297b/index.m3u8"},{"name":"9","slug":"9","filename":"Phù thủy có thật_S01E09_2022-08-20","link_embed":"https://vip.opstream15.com/share/022a50d5a53f9f27b285e58d37441bdd","link_m3u8":"https://vip.opstream15.com/20220826/26594_642342ee/index.m3u8"},{"name":"10","slug":"10","filename":"Phù thủy có thật_S01E10_Tập 10","link_embed":"https://vip.opstream14.com/share/a6953af76df8ac424ed91eecfe6bf582","link_m3u8":"https://vip.opstream14.com/20220903/20991_7fd93d02/index.m3u8"},{"name":"11","slug":"11","filename":"Phù thủy có thật_S01E11_2022-09-03","link_embed":"https://vip.opstream14.com/share/fbff791ef0770855e599ea6f87d41653","link_m3u8":"https://vip.opstream14.com/20220910/21240_8758edac/index.m3u8"},{"name":"12","slug":"12","filename":"Phù thủy có thật_S01E12_10_09_2022","link_embed":"https://vip.opstream15.com/share/28d8e465d7d573b25255f5d56750faef","link_m3u8":"https://vip.opstream15.com/20220916/26771_d88204b9/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Ba người bạn nữ, đến từ những hoàn cảnh hoàn toàn khác nhau, gặp phải kẻ thù mà họ muốn giết. Gong Ma Ri là một bà nội trợ có cuộc sống viên mãn bên chồng và con gái. Khi cô ấy phát hiện ra người bạn đời của mình ngoại tình, cô ấy đã tìm một phương pháp thay thế để kết thúc cuộc hôn nhân của mình.</p><p>Chae Hee Soo là con dâu trong một gia đình tài phiệt. Cuộc sống hôn nhân của cô ấy không suôn sẻ. Cô ấy không chỉ phải chiều mẹ chồng, người đau khổ về thể xác và đau khổ khỏi bệnh Alzheimer, cô cũng phải chịu đựng sự thờ ơ lạnh nhạt của chồng đối với cô khi cô phải vật lộn để mang thai. Một ngày nọ, mẹ chồng của Hee Soo đưa ra lời đề nghị đáng sợ nhưng đầy hấp dẫn.</p><p>Chồng của Yang Jin A là một người xấu. Sau khi chết, Jin A thu được một số tiền đáng kể từ hợp đồng bảo hiểm nhân thọ của mình. Với số tiền đó, cô có thể tận hưởng một lối sống mà trước đây cô không quen. Thay vì. cô luôn canh chừng trong cơn gió chướng của mình, lo lắng sợ ai đó sẽ lấy mất nó.</p>","tmdb":{"type":"tv","id":"157236","season":1,"vote_average":4.2,"vote_count":12},"modified":"2025-05-23T13:42:55.000Z","cast":["Lee Yu-ri","Lee Min-young","Yoon So-Yi","Jung Sang-hoon","Kim Young-jae","Ryu Yeon-seok","Kim Sa-Kwon","Gi So-you"],"director":["Kim Yun Chul"],"cast_meta":[{"name":"Lee Yu-ri","name_vi":null,"name_original":"Lee Yu-ri","tmdb_id":592257,"profile":"https://image.tmdb.org/t/p/w500/i3Xh6ZJ3FT1Qk0moqBCDJnt5LMj.jpg","tmdb_url":"https://www.themoviedb.org/person/592257"},{"name":"Lee Min-young","name_vi":null,"name_original":"Lee Min-young","tmdb_id":1574624,"profile":"https://image.tmdb.org/t/p/w500/wDkzoPsSJCvcmZxyVz576FaRgus.jpg","tmdb_url":"https://www.themoviedb.org/person/1574624"},{"name":"Yoon So-Yi","name_vi":null,"name_original":"Yoon So-Yi","tmdb_id":77281,"profile":"https://image.tmdb.org/t/p/w500/dSTDaq16vscz06UmV58dH3nIEkr.jpg","tmdb_url":"https://www.themoviedb.org/person/77281"},{"name":"Jung Sang-hoon","name_vi":null,"name_original":"Jung Sang-hoon","tmdb_id":1715383,"profile":"https://image.tmdb.org/t/p/w500/grYaUj88IUp95AF4MhQgtv3FUxs.jpg","tmdb_url":"https://www.themoviedb.org/person/1715383"},{"name":"Kim Young-jae","name_vi":null,"name_original":"Kim Young-jae","tmdb_id":135850,"profile":"https://image.tmdb.org/t/p/w500/wSgDPw6fSGgrwJLO0QaITbS758L.jpg","tmdb_url":"https://www.themoviedb.org/person/135850"},{"name":"Ryu Yeon-seok","name_vi":null,"name_original":"Ryu Yeon-seok","tmdb_id":3417958,"pro