re/725cfc5f5f64a26e5c0265610989af10","link_m3u8":"https://vip.opstream11.com/20240919/53038_725cfc5f/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/4731930038e535c8a92a63282a1bdf7f","link_m3u8":"https://vip.opstream11.com/20240919/53039_47319300/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/86dca97feed370ca40f5c9e5b66e354c","link_m3u8":"https://vip.opstream11.com/20240919/53040_86dca97f/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/75bba14f3b9c2c2fbaab30d94e502d54","link_m3u8":"https://vip.opstream11.com/20240919/53041_75bba14f/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream11.com/share/8847f8243bea41c5145872e904631d71","link_m3u8":"https://vip.opstream11.com/20240919/53042_8847f824/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream11.com/share/f706d04e4f5dd59a8e4dde3ad238dfe9","link_m3u8":"https://vip.opstream11.com/20240919/53043_f706d04e/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream11.com/share/dfd470399dd8e7b31005ee16cb15dc37","link_m3u8":"https://vip.opstream11.com/20240919/53044_dfd47039/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream11.com/share/38da564a24ac6d5fe2577c2e76a12125","link_m3u8":"https://vip.opstream11.com/20240919/53045_38da564a/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream11.com/share/05d9db6cc7255ba5026bb187960a3abc","link_m3u8":"https://vip.opstream11.com/20240919/53046_05d9db6c/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream11.com/share/68addc821b387ab5cc91c846b627a586","link_m3u8":"https://vip.opstream11.com/20240919/53047_68addc82/index.m3u8"},{"name":"39","slug":"39","link_embed":"https://vip.opstream11.com/share/6742bca83e6da85a60aeec23591f3ff0","link_m3u8":"https://vip.opstream11.com/20240919/53048_6742bca8/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream11.com/share/8f3711e4d3e3b05b3f4bb7caa55e204a","link_m3u8":"https://vip.opstream11.com/20240919/53049_8f3711e4/index.m3u8"}]}],"description":"<p><i>Phượng Hoàng Lửa kể về cuộc chiến giữa Thiên Ma tộc và Bái Điểu tộc. ‟Song đầu quái thú‟ thao túng Thiên Ma tộc tiến công Bái Điểu tộc, khiến cho Bái Điểu tộc thương vong nặng nề. Thần nhân Ảo Ba công tử liền đánh thức ‟Thiên niên thần thú‟ Đô Đô đang ngủ say trong hồ tỉnh dậy để bảo vệ Phụng Hoàng Thần nữ là thần hộ mệnh của Bái Điểu tộc, nhưng Đô Đô lại vô tình bị ‟Hiệp đạo‟ Chung Hào (Miêu Kiều Vỹ đóng) bắt giữ. Ngoài ra, Phụng Hoàng Thần nữ Mai Cơ do đang mang thai sắp sinh nên suy giảm công lực, sau khi vội sinh ra 1 quả trứng trong chiến loạn, đã phạm vào cấm kỵ không phải đêm trăng tròn mà buộc phải lột xác thành Hỏa Phụng Hoàng để quyết chiến 1 trận sinh tử với Thiên Ma. Hỏa Phụng Hoàng cố gắng hết sức đánh lui Thiên Ma, làm y bị thương nhốt vào mạng nhện, Thiên Ma muốn phá kén ra ngoài, nhất thiết phải uống máu phụng hoàng, vì vậy con gái của Phụng Hoàng Thần nữ trở thành mục tiêu của Thiên Ma. Con gái mới sinh của Phụng Hoàng Thần Nữ là Mai Ngâm Sương (Phan Nghinh Tử đóng) được trưởng lão Bái Điểu tộc hiệp trợ chạy trốn, trên đường gặp phải sự truy đuổi của Thiên Ma tộc, trước khi chết trưởng lão phó thác con gái Phụng Hoàng Thần nữ cho con trai nuôi tên A Hồng. Không ngờ A Hồng bị Xà Ma nữ của Thiên Ma tộc khống chế nên ngộ thương Mai Ngâm Sương rồi bỏ đi. Mai Ngâm Sương vì muốn truy tìm A Hồng mà tình cờ rơi vào ổ cường đạo của Chung Hào...</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ph/phung-hoang-than-nu.json"}