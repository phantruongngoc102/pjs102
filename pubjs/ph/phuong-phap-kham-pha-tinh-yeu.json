bd50eea3abfa3d46109e0a9e9407654c","link_m3u8":"https://vip.opstream11.com/20230706/45668_83667f65/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/7289106c3ebccb21877f9a50b697e761","link_m3u8":"https://vip.opstream11.com/20230713/45780_070c0db5/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/7b7bd53ba5107cf5fb2c2a51dd887c95","link_m3u8":"https://vip.opstream11.com/20230713/45781_5db5bde8/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/4c6be8f4276bc158da4fb5e9202fc1ec","link_m3u8":"https://vip.opstream11.com/20230721/45983_b8c36bff/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/e44ad2329e7fabf14c09cac531ae50aa","link_m3u8":"https://vip.opstream11.com/20230721/45984_42dc1cff/index.m3u8"}]}],"description":"<p>Nữ tiến sĩ địa chất học Tô Kỷ Thời vì bố mẹ ly hôn từ khi cô còn nhỏ nên thiếu thốn tình thương gia đình, do đó trong lòng cô rất xem trọng tình cảm gia đình. Sau khi trưởng thành, cô chọn chuyên ngành địa chất học và để bảo vệ ước mơ của người thân, cô bắt đầu thử học các chuyên ngành khác nhau, trải nghiệm những cuộc sống khác nhau. Trong quá trình này, Tô Kỷ Thời có duyên làm quen với Mục Hưu Luân, một doanh nhân trẻ cũng đam mê địa chất. Mục Hưu Luân tuy là trẻ mồ côi nhưng cha mẹ nuôi của anh lại coi anh như con ruột, chỉ có điều doanh nghiệp do Mục Hưu Luân quản lý vẫn giữ lối tư duy truyền thống, những ý tưởng đổi mới của anh luôn bị các nhà lãnh đạo cấp cao phản đối, trong đó đứng đầu là chú hai. Việc thúc đẩy nghiên cứu khoáng vật mới cũng gặp nhiều khó khăn, nhưng Tô Kỷ Thời vẫn luôn cung cấp những kiến thức chuyên môn về khoáng vật để giúp Mục Hưu Luân. Trong quá trình quen biết, Tô Kỷ Thời và Mục Hưu Luân dần bước vào trái tim của nhau, hai người nương tựa lẫn nhau, giúp nhau chữa lành tâm hồn, đồng thời thúc đẩy nghiên cứu khoáng vật mới, cùng nhau bắt đầu hành trình mới trong cuộc đời.</p>","tmdb_id":229217,"cast":["Cecilia Boey","Cao Hãn Vũ","Thừa Lũy","Lin Zilu","Zang Yi Ren"],"director":["Yu Qiu"],"keywords":[],"tmdb":{"type":"tv","id":"229217","season":1,"vote_average":6.5,"vote_count":4},"cast_meta":[{"name":"Cecilia Boey","name_vi":null,"name_original":"Cecilia Boey","tmdb_id":2037564,"profile":"https://image.tmdb.org/t/p/w500/5Uk3Y6RbwzsQ3xLBCWwmv3zntGo.jpg","tmdb_url":"https://www.themoviedb.org/person/2037564"},{"name":"Cao Hãn Vũ","name_vi":"Cao Hãn Vũ","name_original":"Gao Hanyu","tmdb_id":1803094,"profile":"https://image.tmdb.org/t/p/w500/fqtMdBF1DDp5SgOj3z4Lvr53HiL.jpg","tmdb_url":"https://www.themoviedb.org/person/1803094"},{"name":"Thừa Lũy","name_vi":"Thừa Lũy","name_original":"Ryan Cheng","tmdb_id":3093089,"profile":"https://image.tmdb.org/t/p/w500/mN45mgpV6TkttOt7zOIGv2u3H0S.jpg","tmdb_url":"https://www.themoviedb.org/person/3093089"},{"name":"Lin Zilu","name_vi":null,"name_original":"Lin Zilu","tmdb_id":4022769,"profile":"https://image.tmdb.org/t/p/w500/ytBnpQnazbbpJbQBgB4tQH01Bq8.jpg","tmdb_url":"https://www.themoviedb.org/person/4022769"},{"name":"Zang Yi Ren","name_vi":null,"name_original":"Zang Yi Ren","tmdb_id":3897113,"profile":"https://image.tmdb.org/t/p/w500/7nMHIYwGEEeY2tefAJvYOouAmpz.jpg","tmdb_url":"https://www.themoviedb.org/person/3897113"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ph/phuong-phap-kham-pha-tinh-yeu.json"}