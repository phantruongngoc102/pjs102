{"id":"64735c5f9b6b2c58a9f95a75","title":"Police Story: Lockdown","origin_name":"Police Story: Lockdown","slug":"police-story-lockdown","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/po/police-story-lockdown.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/po/police-story-lockdown.webp","year":2013,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a2335e0fc277084dfd822","name":"Đài Loan","slug":"dai-loan"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Police Story- Lockdown - Câu Chuyện Cảnh Sát - 2013","link_embed":"https://vip.opstream14.com/share/6502a9d5717121e00f902870c54647e4","link_m3u8":"https://vip.opstream14.com/20230528/36915_06d47cc9/index.m3u8"}]}],"time":"108 Phút","description":"Câu chuyện cảnh sát 2013 là tác phẩm điện ảnh mới đánh dấu sự trở lại với series cùng tên của Thành Long sau 10 năm. Phần đầu tiên của series ra lò năm 1985, các phần tiếp theo lần lượt trình làng vào năm 1988, 1992, 1996 và Tân câu chuyện cảnh sát năm 2004. Trong phim hành động mới, Thành Long vào vai chính Chung Văn, một cảnh sát chống tội phạm xuất sắc nhưng cuộc sống gia đình của anh lại không yên ấm. Nữ diễn viên xinh đẹp Cảnh Điềmđóng vai Miêu Miêu, cô con gái phản nghịch của Thành Long với mái tóc nhuộm đỏ, trang điểm đậm, xăm mình, hút thuốc uống rượu. Mâu thuẫn giữa hai cha con oan gia này dường như không thể tháo gỡ.","tmdb":{"type