/a7c2e56b94b4f46ec60a68e20b4e8f9c","link_m3u8":"https://vip.opstream11.com/20221227/40266_3d2f92a6/index.m3u8"},{"name":"12","slug":"12","filename":"Management of Novice Alchemist E12E12","link_embed":"https://vip.opstream11.com/share/f1f901606f26ef6fa343937bd99c23b7","link_m3u8":"https://vip.opstream11.com/20221227/40265_5131055f/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>\"Sarasa là một giả kim thuật sư non nớt lớn lên trong cô nhi viện, ước mơ của cô là có thể mở một cửa hàng nối gót bố mẹ đã khuất của mình. Sư phụ của Sarasa đã trao cho cô một cửa hiệu trống tại một ngôi làng gần biên giới nào đó, xem như quà mừng cô tốt nghiệp khỏi trường đào tạo. Sarasa vô cùng phấn khích khi có thể hoàn thành ước mơ sớm hơn dự định, nhưng thứ chờ đợi cô lại là một cửa hiệu vô cùng tồi tàn. Không quen với việc phải giao tiếp, phải thu thập nguyên liệu nguy hiểm và tiêu diệt quái vật!? Với hành trang là lượng kiến thức dồi dào và nguồn ma lực cao cường. Cùng với vũ khí và kiếm thuật được rèn dũa, Sarasa bắt đầu hành trình phấn đấu tại vùng đất xa lạ này. Cảm xúc và thuật giả kim được lan truyền thông qua việc quản lý cửa hàng, sẽ tạo ra cho cô những cuộc gặp gỡ và sinh ra những mối liên kết...\"</p>","tmdb":{"type":"tv","id":"133938","season":1,"vote_average":6.2,"vote_count":19},"modified":"2025-04-24T15:24:04.000Z","cast":["Kanon Takao","Hina Kino","Saori Onishi","Nanaka Suwa","Mitsuki Saiga","Ami Koshimizu"],"director":[],"cast_meta":[{"name":"Kanon Takao","name_vi":null,"name_original":"Kanon Takao","tmdb_id":1695709,"profile":"https://image.tmdb.org/t/p/w500/w3h6h9R29uRsOv01qbk94ym2msm.jpg","tmdb_url":"https://www.themoviedb.org/person/1695709"},{"name":"Hina Kino","name_vi":null,"name_original":"Hina Kino","tmdb_id":1597103,"profile":"https://image.tmdb.org/t/p/w500/iwq0VvY3q4MPfn5ZTjsthhNcuyd.jpg","tmdb_url":"https://www.themoviedb.org/person/1597103"},{"name":"Saori Onishi","name_vi":null,"name_original":"Saori Onishi","tmdb_id":1339189,"profile":"https://im