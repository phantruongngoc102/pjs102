3","link_m3u8":"https://vip.opstream12.com/20220322/4683_1ca6eed7/index.m3u8"}]}],"description":"<p>Quân Trang Thân Yêu (My Dear Guardian) là bộ phim kể về quá trình gặp gỡ, quen biết rồi yêu nhau giữa Lương Mục Trạch, thiếu tá có triển vọng nhất trong đại đội đặc chủng quân khu G và Hạ Sơ, bác sĩ của đội cứu trợ y tế nước ngoài. Họ cùng nhau vượt qua vụ bắt cóc khủng bố, tiêu diệt băng nhóm tội phạm đánh cắp bí mật quân sự, cuối cùng là quét sạch thế lực tội phạm, là câu chuyện lãng mạn của người lính vừa hoàn thành sứ mệnh quân sự vừa bảo vệ người mình yêu.</p>","tmdb_id":126723,"cast":["Hoàng Cảnh Du","Lý Thấm","Shu Yang","Nie Zihao","Jiang Yuan","Zhao Xun","Fu Chengpeng","Xu Honghao","Liu Xiaojie","Chung Lệ Lệ","Ao Yang","Guan Yajun"],"director":["Ji Tian Yi"],"keywords":[],"tmdb":{"type":"tv","id":"126723","season":1,"vote_average":7,"vote_count":14},"cast_meta":[{"name":"Hoàng Cảnh Du","name_vi":"Hoàng Cảnh Du","name_original":"Johnny Huang","tmdb_id":1816461,"profile":"https://image.tmdb.org/t/p/w500/mc7HlXJU0Sr5WkodEHS3csaxi6E.jpg","tmdb_url":"https://www.themoviedb.org/person/1816461"},{"name":"Lý Thấm","name_vi":"Lý Thấm","name_original":"Li Qin","tmdb_id":568304,"profile":"https://image.tmdb.org/t/p/w500/thak4pt7jCPbl2xx5HnFhkEE0Tu.jpg","tmdb_url":"https://www.themoviedb.org/person/568304"},{"name":"Shu Yang","name_vi":null,"name_original":"Shu Yang","tmdb_id":2287433,"profile":"https://image.tmdb.org/t/p/w500/ezMsYkqM2uLjaBkp4dP9dxSqL5H.jpg","tmdb_url":"https://www.themoviedb.org/person/2287433"},{"name":"Nie Zihao","name_vi":null,"name_original":"Nie Zihao","tmdb_id":2280277,"profile":"https://image.tmdb.org/t/p/w500/AtA2qpIxEInhADUG1rU8VAxvmrl.jpg","tmdb_url":"https://www.themoviedb.org/person/2280277"},{"name":"Jiang Yuan","name_vi":null,"name_original":"Jiang Yuan","tmdb_id":2027717,"profile":"https://image.tmdb.org/t/p/w500/GraLRhM9XqVABRLB52pbpy3Acp.jpg","tmdb_url":"https://www.themoviedb.org/person/2027717"},{"name":"Zhao Xun","name_vi":null,"name