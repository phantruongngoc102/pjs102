20250716/8881_76bba5ee/index.m3u8"},{"name":"22","slug":"22","filename":"Cẩm Tú Phương Hoa (Quốc Sắc Phương Hoa Phần 2) - Tập 22","link_embed":"https://vip.opstream90.com/share/74888d4e8f1b989420edfb5b19659c77","link_m3u8":"https://vip.opstream90.com/20250718/8987_74888d4e/index.m3u8"},{"name":"23","slug":"23","filename":"23","link_embed":"https://vip.opstream90.com/share/e8a69bf65aefc23d0f360ab695e9eac7","link_m3u8":"https://vip.opstream90.com/20250718/8985_e8a69bf6/index.m3u8"},{"name":"24","slug":"24","filename":"Cẩm Tú Phương Hoa (Quốc Sắc Phương Hoa Phần 2) Tập 24","link_embed":"https://vip.opstream90.com/share/3ba07b63865ffdcc83f484c6749df719","link_m3u8":"https://vip.opstream90.com/20250719/9034_3ba07b63/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Tiếp nối phần đầu Quốc Sắc Phương Hoa, Cẩm Tú Phương Hoa theo chân nữ thương nhân trồng hoa mẫu đơn Hà Duy Phương trong một bước ngoặt lớn của sự nghiệp lẫn cuộc đời. Cơ ngơi do cô vất vả xây dựng từ bàn tay trắng nay đã đứng vững, còn tài trồng hoa của cô thì càng ngày càng được nhiều người biết đến. Thế nhưng, ngay khi vừa chạm tay vào giấc mơ giàu có, một biến cố lớn lại xảy ra khiến cô quyết định rẽ sang con đường mới để mang đến lợi ích lớn lao hơn cho dân chúng và đồng thời tiếp tục bí mật giúp đỡ Tưởng Trường Dương chống lại âm mưu phản loạn của Ninh Vương.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"243083","season":2,"vote_average":7.2,"vote_count":15},"modified":"2025-07-19T17:19:28.000Z","cast":["Dương Tử","Lý Hiện","Ngụy Triết Minh","Trương Nhã Khâm","Đồ Tùng Nham","Guan Yue","Hứa Linh Nguyệt","Shen Mengchen","Đổng Khiết","Cổ Tử Thành","Qu Zheming","Zhang Lei","Đông Mộng Thực"],"director":["Ding Ziguang"],"cast_meta":[{"name":"Dương Tử","name_vi":"Dương Tử","name_original":"Yang Zi","tmdb_id":1696482,"profile":"https://image.tmdb.org/t/p/w500/20Nc1xnRFC5XGsb896ZxVNUOzFU.jpg","tmdb_url":"https://www.themoviedb.org/person/1696482"},{"name":"Lý Hiện","name_vi":"Lý Hiện","name_original":"Li Xian",