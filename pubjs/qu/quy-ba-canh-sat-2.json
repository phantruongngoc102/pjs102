.opstream10.com/share/27e9efa7a852bcaa4d9fe0791d2d37b1","link_m3u8":"https://vip.opstream10.com/20220527/17534_0cc081d7/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream10.com/share/2975c2a0df49e48104fc44a7838db7f7","link_m3u8":"https://vip.opstream10.com/20220527/17536_3fec360e/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream10.com/share/09d748adfe5109a59f214f25e80697d1","link_m3u8":"https://vip.opstream10.com/20220527/17537_09952186/index.m3u8"}]}],"description":"<p>Là câu chuyện sau khi Choi Young- Jin ( Kim Hee Ae ) cần có thời gian nghỉ việc , Ko Yoon Jung ( Kim Sung - Ryoung ) trở thành trưởng đội thám tử mới . Cô trở lại Hàn Quốc sau khi tập luyện với F.B.I. ở Mỹ. Kim Hee Ae cùng hầu hết diễn viên mùa 1 đã từ chối lời mời tiếp tục với Mrs. Cop 2. Người thay thế cho cô là \"mẹ Kim Tan\" Kim Sung Ryung, thủ vai Go Yoon Jung, một tân binh của đội phòng chống tội phạm, trở về Hàn sau quãng thời gian được FBI huấn luyện. Ngoài Kim Min Jong là người từng tham gia Mrs. Cop mùa đầu tiên, thì Kim Bum, Im Seul Ong (2AM) và Son Dam Bicũng là những cái tên được chú ý trong dự án lần này.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/qu/quy-ba-canh-sat-2.json","tmdb_checked":false}