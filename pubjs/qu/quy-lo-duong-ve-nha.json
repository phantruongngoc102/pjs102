me":"26","slug":"26","filename":"Quy Lo E26","link_embed":"https://vip.opstream14.com/share/241393669823fc88e479a88090df91c6","link_m3u8":"https://vip.opstream14.com/20230329/34275_56c41e4c/index.m3u8"},{"name":"27","slug":"27","filename":"Quy Lo E27","link_embed":"https://vip.opstream14.com/share/6ded8940f3bcd34111d2e673d4bf5780","link_m3u8":"https://vip.opstream14.com/20230329/34276_f1d67a74/index.m3u8"},{"name":"28","slug":"28","filename":"Quy Lo E28","link_embed":"https://vip.opstream14.com/share/7ca4d3846a7d9aad42da15d4289c7ada","link_m3u8":"https://vip.opstream14.com/20230331/34304_b560d62e/index.m3u8"},{"name":"29","slug":"29","filename":"Quy Lo E29","link_embed":"https://vip.opstream14.com/share/994d88a370250b303be16fc98bb5cdac","link_m3u8":"https://vip.opstream14.com/20230331/34305_3cfd567e/index.m3u8"},{"name":"30","slug":"30","filename":"Quy Lo E30","link_embed":"https://vip.opstream16.com/share/d15505e6d277a01b10c86b9137f57d69","link_m3u8":"https://vip.opstream16.com/20230331/33601_601690dd/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Quy Lộ do đạo diễn Từ Thúy Hoa chỉ đạo được chuyển thể từ bộ tiểu thuyết cùng tên của tác giả Mặc Bảo Phi Bảo với sự tham gia của Đàm Tùng Vận và Tỉnh Bách Nhiên. Bộ phim xoay quanh cặp đôi Quy Hiểu và Lộ Viêm Thần, là mối tình đầu của nhau, nhưng sau khi tốt nghiệp đại học Lộ Viêm Thần đi làm cảnh sát đặc nhiệm. Cùng lúc đó, gia đình Quy Hiểu xảy ra biến cố, tình yêu của họ cũng kết thúc từ đó. Mười năm sau, Quy Hiểu và Lộ Viêm Thần gặp lại và tái hợp, hai người đều nhận ra họ không thể kìm chế được sự khao khát tình yêu dành cho nhau. Thế nhưng cha mẹ của Lộ Viêm Thần lại sắp đặt hôn ước cho anh, và Lộ Viêm Thần đã quyết định đưa ra lựa chọn. Sau khi kết hôn, Viêm Thần bị thương trong một lần làm nhiệm vụ và hôn mê. Quy Hiểu mang thai chạy đến bên và sinh cho anh một đứa con gái, ở thành phố biên giới nơi anh làm nhiệm vụ suốt mười năm. Một gia đình ba người hạnh phúc bên nhau.&nbsp;</p>","tmdb":{"type":"tv","id":"214478","season":1,"vote_average":7.6,"vote_count":12},"modified":"2025-04-01T11:58:33.000Z","cast":["Tỉnh Bách Nhiên","Đàm Tùng Vận","Trương Bách Gia","Li Mincheng","Zhang Qiaoer","Zhang Enshuo","Wang Hao","Liang Tian","Ngưu Tuấn Phong","Sha Baoliang","Hải Linh","Lu Yupeng","Xu Rongzhen","Gong Rui","Wu Yufang"],"director":["Yu Cui Hua"],"cast_meta":[{"name":"Tỉnh Bách Nhiên","name_vi":"Tỉnh Bách Nhiên","name_original":"Jing Boran","tmdb_id":1094210,"profile":"https://image.tmdb.org/t/p/w500/vsXA4vbmlYDUmAAUuLBYQUUcMcF.jpg","tmdb_url":"https://www.themoviedb.org/person/1094210"},{"name":"Đàm Tùng Vận","name_vi":"Đàm Tùng Vận","name_original":"Tan Songyun","tmdb_id":1614218,"profile":"https://image.tmdb.org/t/p/w500/yYMnfaIix23U51z21EJhznq3DHN.jpg","tmdb_url":"https://www.themoviedb.org/person/1614218"},{"name":"Trương Bách Gia","name_vi":"Trương Bách Gia","name_original":"Zhang Bojia","tmdb_id":1989509,"profile":"https://image.tmdb.org/t/p/w500/npWWY3WIwYXItHJ0MGjAHsSKGZd.jpg","tmdb_url":"https://www.themoviedb.org/person/1989509"},{"name":"Li Mincheng","name_vi":null,"name_original":"Li Mincheng","tmdb_id":1396081,"profile":"https://image.tmdb.org/t/p/w500/oyoC8DiqEqiLO8Y8rjvZuJs0GTp.jpg","tmdb_url":"https://www.themoviedb.org/person/1396081"},{"name":"Zhang Qiaoer","name_vi":null,"name_original":"Zhang Qiaoer","tmdb_id":4030732,"profile":"https://image.tmdb.org/t/p/w500/yYMtFCQX7D4nn0CtBc0BktA4mUo.jpg","tmdb_url":"https://www.themoviedb.org/person/4030732"},{"name":"Zhang Enshuo","name_vi":null,"name_original":"Zhang Enshuo","tmdb_id":4117341,"profile":"https://image.tmdb.org/t/p/w500/lQhRqrp8biaWeZq5BZ8Xm42MDpU.jpg","tmdb_url":"https://www.themoviedb.org/person/4117341"},{"name":"Wang Hao","name_vi":null,"name_original":"Wang Hao","tmdb_id":3667973,"profile":"https://image.tmdb.org/t/p/w500/xI34uaHhrkYpng73QhxAJ5aGmvB.jpg","tmdb_url":"https://www.themoviedb.org/person/3667973"},{"name":"Liang Tian","name_vi":null,"name_original":"Liang Tian","tmdb_id":1172006,