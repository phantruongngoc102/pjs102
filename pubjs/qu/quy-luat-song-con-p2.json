re/ab00b14a2da2e3cdcc44f06265db6574","link_m3u8":"https://vip.opstream13.com/20250916/7966_ab00b14a/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/dab1263d1e6a88c9ba5e7e294def5e8b","link_m3u8":"https://vip.opstream13.com/20250916/7967_dab1263d/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/9dd30287dc5ffcfb4efb1e0521c3c8f8","link_m3u8":"https://vip.opstream13.com/20250916/7968_9dd30287/index.m3u8"}]}],"description":"Tân Vạn Quân (Mã Quốc Minh) là một chàng trai tốt bụng, xuất thân từ gia đình nghèo khó. Với suy nghĩ: “đứng trước pháp luật, mọi người đều bình đẳng”, Quân quyết tâm vào đại học, lấy cho được tấm bằng luật sư, để chứng minh điều đó.\n\nQuân không ngại dùng những cách thức khác người để giành chiến thắng trong các vụ kiện, nên được cấp trên trọng dụng, nhưng lại khiến các đồng nghiệp xa lánh. Chỉ có Trác Vĩ Danh (Trần Kiện Phong) là người duy nhất thích tác phong làm việc của Quân. Danh thường âm thầm giúp đỡ Quân, và họ trở thành bạn thân.\n\nPhong cách của Quân nhiều lần khiến Tôn Lợi Lợi (Quan Ân Na) bất mãn. Trong mắt Lợi, Quân chỉ là một tên lưu manh bê bối, thích đùa giỡn với tình yêu. Một lần Lợi bị trả thù suýt mất mạng, Quân kịp thời ra tay cứu giúp, từ đó hai người hiểu nhau hơn.\n\nKhi Lợi nhận ra mình yêu Quân, thì cô bắt buộc phải đến với Danh để cứu lấy sự nghiệp của cha mình. Không bao lâu sau, Danh phát hiện cô bạn cũ Trịnh Thể Ngọc (Lý Thi Vận) đã có mang giọt máu của mình…","tmdb_id":15955,"cast":["Kenneth Ma Kwok-Ming","Trần Kiện Phong","Ella Koon","Lý Tử Hùng","Trần Quốc Bang","Lý Thi Hoa","Rebecca Chan","Quách Phong","Ngao Gia Niên","Queenie Chu Wai-Man","Lee Ji-Kei","Karen Lee Choi-Ling","Sunny Tai Yiu-Ming","Meini Cheung","Daniel Kwok Cheuk Wah"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"15955","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Kenneth Ma Kwok-Ming","name_vi":null,"name_original":"Kenneth Ma Kwok-Ming","tmdb_id":12