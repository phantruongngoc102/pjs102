s://vip.opstream13.com/share/00126b47d5502dfb7d01f750ad23d813","link_m3u8":"https://vip.opstream13.com/20251101/16774_00126b47/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/d7ce5233d2702b91fbbe0cf16b19f573","link_m3u8":"https://vip.opstream13.com/20251101/16775_d7ce5233/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/789bbd3eb51e7315cf9995306bb399f5","link_m3u8":"https://vip.opstream13.com/20251101/16776_789bbd3e/index.m3u8"}]}],"description":"<p>Bộ phim Quyết Chiến Hoàng Thành xoay quanh lòng trung nghĩa, khí tiết của con dân nước Tống nói riêng và sự mục nát, thối rửa của triều đại nói chung. Tình yêu đôi lứa cũng được khai thác triệt để và giàu tính nhân văn. Trung lương của nước Tống – Nhạc Phi bị gian thần Tần Cối thông gian bán nước với người Kim hãm hại, Cao Hàn Tinh nổi tiếng với chiêu “Vạn Tinh Phi Hoa Hàng Tinh Nhất Điểm” vì cứu Nhạc Phi mà kết oán với Tần Cối. Quận Chúa của Kim quốc là Lãnh Nguyệt lén cha vào Tống quốc du ngoạn, trên đường nàng gặp và yêu Hàn Tinh. Lúc bấy giờ, Vua Tống Cao Tông muốn lôi kéo Cao gia về phe mình, nên đã gả công chúa Tịnh Khang cho Cao Hàn Tinh, nhưng Lãnh Nguyệt đã ngăn trở đám cưới của hai người diễn ra. Liễu Tàng Dương quyết chiến Cao Thiên Tinh – cha của Cao Hàn Tinh để trả thù cho cha bị ông giết hại năm xưa, nhưng Thiên Tinh đã bị người Kim giết chết. Do đó, Hàn Tinh phải thay cha quyết chiến với Tàng Dương. Công chúa Tịnh Khang biết rõ sự tình, cố gắng hòa giải cuộc quyết đấu ấy. Tống Cao Tông muốn loại trừ Hàn Tinh nên dùng độc kế khiến Hà Tinh phải khốn đốn tại nước Kim. Lúc này, Lãnh Nguyệt đã cứu Hàn Tinh bằng cách lấy anh làm chồng. Tình thế ép buộc, Hàn Tinh đành chấp nhận trở thành phò mã Kim quốc để thoát nạn nhưng trong lòng anh vẫn luôn nhớ về Tịnh Khang. Sau đó, Lãnh Nguyệt vì lấy thánh ấn của Vương gia để giúp Hàn Tinh trốn khỏi Kim quốc nên bị thương và dọc đường trở về Tống quốc thì chết. Hàn Tinh và Tịnh Khang công chúa trùng phùng nhưng lúc này đôi mắt anh lại bị mù.Tịnh Khang vì Hàn Tinh đã hy sinh đôi mắt của mình để cứu chữa cho anh …</p>","tmdb_id":108421,"cast":["Trịnh Thiếu Thu","Đặng Tụy Văn","Tse Ning","Lương Gia Nhân","Eddie Kwan Lai-Kit","Wong Yee Kam","Lạc Ứng Quân","Katherine Lau Ying-Hung","Lý Quốc Lân","Yeung Chak-Lam"],"director":["Mai Tiểu Thanh"],"keywords":[],"tmdb":{"type":"tv","id":"108421","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trịnh Thiếu Thu","name_vi":"Trịnh Thiếu Thu","name_original":"Adam Cheng Siu-Chow","tmdb_id":82401,"profile":"https://image.tmdb.org/t/p/w500/KHy7b3kAXP05VGcdsPy3Qf34GM.jpg","tmdb_url":"https://www.themoviedb.org/person/82401"},{"name":"Đặng Tụy Văn","name_vi":"Đặng Tụy Văn","name_original":"Sheren Tang Shui-Man","tmdb_id":997296,"profile":"https://image.tmdb.org/t/p/w500/sJ9nrY567ikJ4c2T5wxxuVTB9Ft.jpg","tmdb_url":"https://www.themoviedb.org/person/997296"},{"name":"Tse Ning","name_vi":null,"name_original":"Tse Ning","tmdb_id":2402111,"profile":"https://image.tmdb.org/t/p/w500/pPKRuF0fWVOnOiIDYDN4VEDdHHP.jpg","tmdb_url":"https://www.themoviedb.org/person/2402111"},{"name":"Lương Gia Nhân","name_vi":"Lương Gia Nhân","name_original":"Bryan Leung Kar-Yan","tmdb_id":227782,"profile":"https://image.tmdb.org/t/p/w500/541tNiNCEGnfjTqQPC9QNiSAsmZ.jpg","tmdb_url":"https://www.themoviedb.org/person/227782"},{"name":"Eddie Kwan Lai-Kit","name_vi":null,"name_original":"Eddie Kwan Lai-Kit","tmdb_id":1276972,"profile":"https://image.tmdb.org/t/p/w500/l3oirhWX6uLv2GuhIwtqn3K8r50.jpg","tmdb_url":"https://www.themoviedb.org/person/1276972"},{"name":"Wong Yee Kam","name_vi":null,"name_original":"Wong Yee Kam","tmdb_id":1631739,"profile":"https://image.tmdb.org/t/p/w500/6JmCeA7w2WslWVbo0pnnxBVaRSz.jpg","tmdb_url":"https://www.themoviedb.org/person/1631739"},{"name":"Lạc Ứng Quân","name_vi":"Lạc Ứng Quân","name_original":"Felix Lok Ying-Kwan","tmdb_id":127436,"profile":"https://image.tmdb.org/t/p/w500/4tVJDVbhH9LNiubcGJ8qDYiQznh.jpg","