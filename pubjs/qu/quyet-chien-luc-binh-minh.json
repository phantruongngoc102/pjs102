com/20220602/18285_f19260d2/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream15.com/share/e52c9599ea82e008745896110ba2804a","link_m3u8":"https://vip.opstream15.com/20220602/18286_9b54d3f8/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/04378bb0508f73687db537f0488cc1be","link_m3u8":"https://vip.opstream15.com/20220602/18287_e009272e/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/73091f523aa6c6f44674cdb664bf39b3","link_m3u8":"https://vip.opstream15.com/20220602/18288_d34b96b9/index.m3u8"}]}],"description":"<p>Phim lấy bối cảnh năm 1946, Trình Tường tiếp quản cục cảnh sát Cáp Nhĩ Tân Nguỵ Mãn, nhậm chức cục trưởng cục công an. Cáp Nhĩ Tân khi đó đang phải chịu sức ép về nhiều mặt: Quốc Dân Đảng đang chiếm giữ tại Trường Xuân có thể tiến vào tấn công Cáp Nhĩ Tân bất cứ lúc nào, tổ chức đặc vụ của địch ẩn thân trong bóng tối, thổ phỉ ác bá hoành hành, người nhật luôn rình thời cơ làm loạn. Trong nội bộ, các cán bộ công an đến từ nhiều nơi, suy nghĩ cũng như phương pháp làm việc đều khác nhau, dẫn đến bất hoà, chia rẽ. Công hội và nông hội cũng đang tranh luận xem ai sẽ là người lãnh đạo việc quản lý thành phố, trong khi tầng lớp lãnh đạo thành phố thiếu kinh nghiệm quản lý.</p>","tmdb_id":106466,"cast":[],"director":[],"keywords":[],"tmdb":{"id":106466},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/qu/quyet-chien-luc-binh-minh.json"}