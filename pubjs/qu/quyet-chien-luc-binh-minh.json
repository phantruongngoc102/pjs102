ẽ. Công hội và nông hội cũng đang tranh luận xem ai sẽ là người lãnh đạo việc quản lý thành phố, trong khi tầng lớp lãnh đạo thành phố thiếu kinh nghiệm quản lý.</p>","tmdb":{"type":"tv","id":"106466","season":1,"vote_average":0,"vote_count":0},"modified":"2022-06-07T16:20:20.000Z","cast":["Lưu Thi Thi","Vương Thiên Nguyên","Trương Hy Lâm","Cao Bingkun","Wang Huichun","Ren Zhengbin","Li Dong"],"director":["Lưu Giang"],"cast_meta":[{"name":"Lưu Thi Thi","name_vi":"Lưu Thi Thi","name_original":"Liu Shishi","tmdb_id":1185786,"profile":"https://image.tmdb.org/t/p/w500/yPyMTroHKKpK2g24o7920erAa3L.jpg","tmdb_url":"https://www.themoviedb.org/person/1185786"},{"name":"Vương Thiên Nguyên","name_vi":"Vương Thiên Nguyên","name_original":"Wang Qianyuan","tmdb_id":565378,"profile":"https://image.tmdb.org/t/p/w500/r6sF4jDBn3SJVNIPcVJNZKi2Ss1.jpg","tmdb_url":"https://www.themoviedb.org/person/565378"},{"name":"Trương Hy Lâm","name_vi":"Trương Hy Lâm","name_original":"Zhang Xilin","tmdb_id":2307499,"profile":"https://image.tmdb.org/t/p/w500/48ouTms4er8aeDZGtgUgj22Zp3D.jpg","tmdb_url":"https://www.themoviedb.org/person/2307499"},{"name":"Cao Bingkun","name_vi":null,"name_original":"Cao Bingkun","tmdb_id":1280710,"profile":"https://image.tmdb.org/t/p/w500/l4fjc7g4Lqy82r3asDS8FbAEDoa.jpg","tmdb_url":"https://www.themoviedb.org/person/1280710"},{"name":"Wang Huichun","name_vi":null,"name_original":"Wang Huichun","tmdb_id":2035977,"profile":"https://image.tmdb.org/t/p/w500/88eZIWZw4Fg6VvObNhBgFzftHNN.jpg","tmdb_url":"https://www.themoviedb.org/person/2035977"},{"name":"Ren Zhengbin","name_vi":null,"name_original":"Ren Zhengbin","tmdb_id":3017232,"profile":"https://image.tmdb.org/t/p/w500/kZg7x5oaPfWbv3IbwOktwmRY63Q.jpg","tmdb_url":"https://www.themoviedb.org/person/3017232"},{"name":"Li Dong","name_vi":null,"name_original":"Li Dong","tmdb_id":4117719,"profile":"https://image.tmdb.org/t/p/w500/ciQvJHv1yAZX1vcne6RRFHb4PaW.jpg","tmdb_url":"https://www.themoviedb.org/person/4117719"}],"keyw