{"id":"641e77adbe1ee82036a26ad5","title":"Robot & Frank","origin_name":"Robot & Frank","slug":"robot-and-frank","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ro/robot-and-frank.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ro/robot-and-frank.webp","year":2012,"type":"single","genre":[{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"},{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Robot & Frank - Rô Bốt Và Frank - 2012","link_embed":"https://vip.opstream14.com/share/39a3bf984fee57c76835745e7e59a062","link_m3u8":"https://vip.opstream14.com/20230325/34117_49f647c1/index.m3u8"}]}],"time":"85 Phút","description":"Frank già khó tính sống một mình. Thói quen của anh ấy bao gồm các chuyến thăm hàng ngày đến thư viện địa phương của anh ấy, nơi anh ấy có một ánh mắt lấp lánh dành cho thủ thư. Những đứa con lớn của ông quan tâm đến sức khỏe của cha chúng và mua cho ông một người máy chăm sóc. Ban đầu phản đối ý tưởng này, Frank nhanh chóng đánh giá cao những lợi ích của sự hỗ trợ của rô bốt - như những bữa ăn bổ dưỡng và một ngôi nhà sạch sẽ - và cuối cùng bắt đầu coi rô bốt của mình như một người bạn đồng hành thực sự. Với sự trợ giúp của người máy, niềm đam mê của Frank đối với nghề nghiệp cũ, bất hợp pháp của mình được khơi dậy, dù tốt hay xấu.","tmdb":{"type":"movie","id":"84329","season":null,"vote_average":6.907,"vote_count":1142},"modified":"2023-03-25T11:25:19.000Z","