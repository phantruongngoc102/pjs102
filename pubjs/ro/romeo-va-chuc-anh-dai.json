_m3u8":"https://vip.opstream16.com/20250810/45207_019344ff/index.m3u8"}]}],"time":"43 phút/tập","description":"Một đất nước xa xôi, một không gian không biết tên. Hai câu chuyện tình yêu kinh điển nhất tái hiện hoàn toàn mới. Yêu hận đan xen, phổ thành một tình khúc thê lương, oanh liệt.\n\n“Em tưởng đâu em phải từ bỏ tình yêu, nhưng thì ra bấy lâu, tình yêu không hề từ bỏ em”, đây là sự trải nghiệm đối với cuộc đời của Chúc Anh Đài.\n\n“Cho dù đêm tối dài như thế nào, ngày mới chắc chắn sẽ tới”, đây là thái độ làm người của Romeo.","tmdb":{"type":"tv","id":"236287","season":1,"vote_average":0,"vote_count":0},"modified":"2025-08-10T17:00:06.000Z","cast":["Trần Hào","Aimee Chan","Châu Gia Lạc","Kayan Yau","Giang Mỹ Nghi","Chiang Cho-Man","Timothy Cheng Chi-Sing","Felix Ng","Judy Kwong Kit-Ying","Tsui Wing","Kyle Lee"],"director":[],"cast_meta":[{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Aimee Chan","name_vi":null,"name_original":"Aimee Chan","tmdb_id":1566076,"profile":"https://image.tmdb.org/t/p/w500/gyPt1TdOTOb6EPlhyL0APZ6U6yG.jpg","tmdb_url":"https://www.themoviedb.org/person/1566076"},{"name":"Châu Gia Lạc","name_vi":"Châu Gia Lạc","name_original":"Kalok Chow","tmdb_id":2988172,"profile":"https://image.tmdb.org/t/p/w500/aVoKtpX69jMAJ0sgvBtbSp0bAWR.jpg","tmdb_url":"https://www.themoviedb.org/person/2988172"},{"name":"Kayan Yau","name_vi":null,"name_original":"Kayan Yau","tmdb_id":3386076,"profile":"https://image.tmdb.org/t/p/w500/ehAsQYXnb4UYhRJXKT9qnr1GjFy.jpg","tmdb_url":"https://www.themoviedb.org/person/3386076"},{"name":"Giang Mỹ Nghi","name_vi":"Giang Mỹ Nghi","name_original":"Elena Kong Mei-Yee","tmdb_id":236195,"profile":"https://image.tmdb.org/t/p/w500/8bN4miYaQ9YvqHedAah4bdHwZQB.jpg","tmdb_url":"https://www.themoviedb.org/person/236195"},{"name":"Ch