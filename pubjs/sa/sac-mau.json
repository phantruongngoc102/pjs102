ủa MICHELLE, KU CHUN CAU là người thầy của NICK. Vì mối quan hệ với KAU, NICK càng đặt nhiều kỳ vọng hơn vào MICHELLE.</p>","tmdb":{"type":"tv","id":"108233","season":1,"vote_average":0,"vote_count":0},"modified":"2025-08-04T16:37:29.000Z","cast":["Tạ Quân Hào","Hồ Hạnh Nhi","Đơn Lập Văn","Melissa Ng Mei-Heng","Kenneth Ma Kwok-Ming","Lạc Đạt Hoa","Lý Thái Hoa","Sharon Chan Man-Chi","Chris Lai","Lưu Giang","Ko Cheun-Man","Rosanne Lui Shan","Liêu Khải Trí","La Quán Lan","Edward Mok"],"director":[],"cast_meta":[{"name":"Tạ Quân Hào","name_vi":"Tạ Quân Hào","name_original":"Gardner Tse Kwan-Ho","tmdb_id":931254,"profile":"https://image.tmdb.org/t/p/w500/8foplz73k0LKh3iZVRE09D1XR5P.jpg","tmdb_url":"https://www.themoviedb.org/person/931254"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/938251"},{"name":"Đơn Lập Văn","name_vi":"Đơn Lập Văn","name_original":"Pal Sinn Lap-Man","tmdb_id":142644,"profile":"https://image.tmdb.org/t/p/w500/hRx1G9DtH7Vjo5vLZynbTFMFaD9.jpg","tmdb_url":"https://www.themoviedb.org/person/142644"},{"name":"Melissa Ng Mei-Heng","name_vi":null,"name_original":"Melissa Ng Mei-Heng","tmdb_id":1254988,"profile":"https://image.tmdb.org/t/p/w500/pppZuVpAI9diCIwzo6Jdpayt32E.jpg","tmdb_url":"https://www.themoviedb.org/person/1254988"},{"name":"Kenneth Ma Kwok-Ming","name_vi":null,"name_original":"Kenneth Ma Kwok-Ming","tmdb_id":1232198,"profile":"https://image.tmdb.org/t/p/w500/6DejZHB8htcmosNwuOGJeDUgfJr.jpg","tmdb_url":"https://www.themoviedb.org/person/1232198"},{"name":"Lạc Đạt Hoa","name_vi":"Lạc Đạt Hoa","name_original":"Ken Lok Tat-Wah","tmdb_id":1395297,"profile":"https://image.tmdb.org/t/p/w500/j1omPKdvfWNnDEoRc8Or7e8Zw1J.jpg","tmdb_url":"https://www.themoviedb.org/person/1395297"},{"name":"Lý Thái Hoa","name_vi":"Lý Thái Hoa","name_original":"Rain Lee Choi-Wah","tmdb_id":1236