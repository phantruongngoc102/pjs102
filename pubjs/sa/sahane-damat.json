8b63830","link_m3u8":"https://vip.opstream10.com/20221212/25793_1ab682a6/index.m3u8"},{"name":"7","slug":"7","filename":"Sahane Damat 7","link_embed":"https://vip.opstream10.com/share/78e2010baad1af028423f6b9db642f53","link_m3u8":"https://vip.opstream10.com/20221212/25794_783fc578/index.m3u8"},{"name":"8","slug":"8","filename":"Sahane Damat 8","link_embed":"https://vip.opstream10.com/share/d94c59b53ea6a9eec0a47ae789867098","link_m3u8":"https://vip.opstream10.com/20221212/25795_53a14d0c/index.m3u8"}]}],"time":"2h30p/tập","description":"<p>Melike là một cô gái trẻ và vụng về, cô còn hay nói dối. Melike cố gắng hết sức để trở thành một nhà báo thành công nhưng cô ấy đang ở rất xa ước mơ của mình. Cô ấy chỉ kiếm được nhiều hơn một chút từ mức lương tối thiểu và thậm chí gặp khó khăn khi trả tiền thuê nhà. Tuy nhiên, gia đình cô cho rằng cô không gặp khó khăn gì về tài chính. Trên hết, Melike có tình yêu đơn phương đối với bác sĩ phẫu thuật thẩm mỹ nổi tiếng Mehmet, người đang hẹn hò với Ilknur - sếp của Melike.</p><p>&nbsp;</p><p>Mehmet thậm chí không biết Melike. Nhưng, gia đình Melike cho rằng con gái Melike của họ và bác sĩ phẫu thuật thẩm mỹ nổi tiếng Mehmet đã hẹn hò được một thời gian và mới đính hôn.</p><p>Khi tham gia vào một vụ việc liên quan đến chú của Mehmet với tư cách là một nhà báo, vô tình Melike biết được bí mật liên quan đến chú của Mehmet. Nếu sự thật bị bại lộ thì ngay lập tức sự nghiệp của Mehmet cũng bị ảnh hưởng.</p><p>Không may, gia đình Melike đến thăm cô khiến mọi thứ trở nên phức tạp hơn. Melike chấp nhận im lặng giữ bí mật với điều kiện Mehmet phải cư xử như thể là vị hôn phu của cô.</p><p>Liệu Mehmet có chấp nhận làm như thể anh đã đính hôn với Melike?</p><p>&nbsp;Liệu Melike có thể giành được trái tim của Mehmet?</p><p>&nbsp;Liệu Melike có thực hiện được ước mơ trở thành một nhà báo nổi tiếng hay không?</p><p>Cả nhà mình hãy cùng chờ đón sự phát sóng của bộ phim&nbsp;</p><p>SAHANE DAMAT</p><p>&nbsp;Vietsub Full trên Ophim.TV để cùng nhau đi tìm lời giải đáp nhaa</p>","tmdb":{"type":"tv","id":"69336","season":1,"vote_average":6,"vote_count":4},"modified":"2023-09-05T02:44:15.000Z","cast":["Ali Ersan Duru","Mesut Yılmaz","Köksal Engür","Burcu Özberk","Anıl İlter","Leyla Göksun"],"director":["Rasit Celikezer"],"cast_meta":[{"name":"Ali Ersan Duru","name_vi":null,"name_original":"Ali Ersan Duru","tmdb_id":1730648,"profile":"https://image.tmdb.org/t/p/w500/cwQyKPYWVwAIIGsYpu9OG0PNIT2.jpg","tmdb_url":"https://www.themoviedb.org/person/1730648"},{"name":"Mesut Yılmaz","name_vi":null,"name_original":"Mesut Yılmaz","tmdb_id":2031283,"profile":"https://image.tmdb.org/t/p/w500/kdliaPexs9fB0isRmpo29mJ0tGh.jpg","tmdb_url":"https://www.themoviedb.org/person/2031283"},{"name":"Köksal Engür","name_vi":null,"name_original":"Köksal Engür","tmdb_id":46069,"profile":"https://image.tmdb.org/t/p/w500/hOyo9t25kYyepwOS6q1g3cSoOC3.jpg","tmdb_url":"https://www.themoviedb.org/person/46069"},{"name":"Burcu Özberk","name_vi":null,"name_original":"Burcu Özberk","tmdb_id":1522700,"profile":"https://image.tmdb.org/t/p/w500/wDhKUUR7pRzgVolACed0YnSozbL.jpg","tmdb_url":"https://www.themoviedb.org/person/1522700"},{"name":"Anıl İlter","name_vi":null,"name_original":"Anıl İlter","tmdb_id":1729255,"profile":"https://image.tmdb.org/t/p/w500/l5AIU6iU92CqBDQl3QSlrXa2xAv.jpg","tmdb_url":"https://www.themoviedb.org/person/1729255"},{"name":"Leyla Göksun","name_vi":null,"name_original":"Leyla Göksun","tmdb_id":1194097,"profile":"https://image.tmdb.org/t/p/w500/znvrh74rGIZsatzvHFQptOoKI6E.jpg","tmdb_url":"https://www.themoviedb.org/person/1194097"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/sa/sahane-damat.json"}