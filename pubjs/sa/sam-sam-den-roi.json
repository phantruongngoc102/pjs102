ip.opstream11.com/20220406/10409_ab18d6b0/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/848ef33f5e745846994a756f211e530b","link_m3u8":"https://vip.opstream11.com/20220406/10410_6032978c/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/2d5b53f80151aea5fef0722f8b1edf99","link_m3u8":"https://vip.opstream11.com/20220406/10411_49887d28/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/1b6171ff276542bd344c1600aaca6165","link_m3u8":"https://vip.opstream11.com/20220406/10412_f2b42864/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream11.com/share/ff12592a08c792faa97fd3d2dc40f1cd","link_m3u8":"https://vip.opstream11.com/20220406/10413_033f7168/index.m3u8"}]}],"description":"<p>Sam Sam Đến Rồi - Boss &amp; Me là bộ phim được cải biên từ tiểu thuyết tình yêu nổi tiếng của Cố Mạn: ‘Sam Sam đến đây ăn nào’. Nội dung xoay quanh chuyện tình lọ lem hoàng tử thời hiện đại, giữa ông chủ Phong Đằng đẹp trai, lạnh lùng nhưng không kém phần dịu dàng, trẻ con với cô nhân viên Sam Sam vụng về, ngốc nghếch nhưng đa sầu đa cảm. Sam Sam, cô gái có dòng máu hiếm, đã cứu được một mạng người. Không ngờ người đó chính là em gái chủ tịch tập đoàn nơi cô đang làm việc. Để cảm ơn Sam Sam, Phong Nguyệt- em gái Phong Đằng- ngày nào cũng chiên cơm gan heo cho Sam Sam, vô hình chung, vị chủ tịch hào hoa đẹp trai trở thành người đưa cơm cho cô. Qua nhiều lần tiếp xúc, Phong Đằng cũng dần bị thu hút bởi vẻ ngoài thánh thiện và tấm lòng lương thiện của cô. Nhưng khi hai người khó khăn lắm mới bộc lộ được tình cảm của mình, thì cô bạn gái thanh mai trúc mã - Lệ Trữ của Phong Đằng xuất hiện. Phát hiện Đằng đang theo đuổi Sam Sam, như một tất yêu cuộc đấu tranh để giành lấy trái tim của Phong Đằng xảy ra giữa hai cô gái... Đúng như tên gọi của tiểu thuyết ‘ Sam Sam đến đây ăn nào’, đạo diễn của phim đã đưa vào hàng loạt những hoạt cảnh ăn uống của các diễn viên chính. Người xem thực sự không thể kìm lòng nổi trước các món ăn màu sắc rực rỡ, hấp dẫn cùng những bữa ăn ngập tràn tình cảm của Phong Đằng và Sam Sam. Thêm vào đó là những tình huống hài hước, những cảnh quay lãng mãn, khiến cho bộ phim đang trở thành cơn sốt trong giới trẻ hiện nay.</p>","tmdb_id":61054,"cast":[],"director":[],"keywords":[],"tmdb":{"id":61054},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/sa/sam-sam-den-roi.json"}