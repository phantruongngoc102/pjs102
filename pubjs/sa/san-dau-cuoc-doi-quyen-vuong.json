me":"18","slug":"18","link_embed":"https://vip.opstream14.com/share/41f87c79a2fb369fdb2aa2a1060a9a83","link_m3u8":"https://vip.opstream14.com/20220706/17395_e56b19b0/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/612b768cef375638fa5bf6d0e88a9262","link_m3u8":"https://vip.opstream14.com/20220706/17399_09f47b9b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/be707b06fa79de553a95e394d0045909","link_m3u8":"https://vip.opstream14.com/20220706/17398_a2457882/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream14.com/share/132aea85729bd67ff2e38e5952abfd25","link_m3u8":"https://vip.opstream14.com/20220706/17397_7e684253/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream14.com/share/56e1930307652e14afbc3e75b8e54bdd","link_m3u8":"https://vip.opstream14.com/20220706/17401_0fc1da8f/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream14.com/share/38616a3812ca4dc2c99d0850ee16c13a","link_m3u8":"https://vip.opstream14.com/20220706/17400_1d39d78a/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream14.com/share/bbd529c3160b4c800103a27dd102a72a","link_m3u8":"https://vip.opstream14.com/20220706/17402_bc30a9e2/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream14.com/share/89a26a363b87a87ac6a94277e841b7f4","link_m3u8":"https://vip.opstream14.com/20220706/17403_bae23344/index.m3u8"}]}],"description":"<p>Sap Yat (Trịnh Gia Dĩnh) 1 nhà vô địch quyền Thái đã giải nghệ, có 1 đứa con trai 7 tuổi. Khi còn sống ở Thái Lan, anh từng thi đấu quyền Thái cá cược và từng đánh chết 1 người, do đó bị tuyên án tù. Sau khi được thả, anh giải nghệ và trở về Hồng Kông làm một bảo vệ bình thường. Sau đó anh trở lại với quyền Thái và gặp Huỳnh Hạo Nhiên. Hồ Định Hân trong vai một nữ quyền Thái câm điếc. Lúc đầu cô rất nghèo khó và bị thất nghiệp, tuy nhiên, Trịnh Gia Dĩnh đã đưa cô vào tham gia trong câu lạc bộ quyền Thái. Sau đó cô đam mê và phát triển năng khiếu trong môn thể thao này, Trịnh Gia Dĩnh là người huấn luyện cô trở thành nữ quyền Thái câm điếc đầu tiên. Cô sẽ có 1 mối tình lãng mạn với Trần Quốc Bang và họ sẽ dùng ngôn ngữ cơ thể để trao đổi với nhau. Huỳnh Hạo Nhiên vai Pat Ka Sing, một phó phòng xấu miệng, lười biếng và không suy nghĩ. Sau đó, anh gặp Trịnh Gia Dĩnh và bắt đầu luyện tập quyền Thái. Về sau trở thành 1 nhà vô địch quyền Thái trẻ….</p>","tmdb_id":56313,"cast":["Trịnh Gia Dĩnh","Huỳnh Hạo Nhiên","Natalie Tong","Lý Thi Hoa","Hồ Định Hân","Huỳnh Đức Bân","Florence Kwok Siu-Wan","Katy Kung","Trần Quốc Bang","Lưu Giang","Tiêu Chính Nam","Otto Chan Chi-Kin","Catherine Chau","Kate Tsui Tsz-Shan","Châu Thông"],"director":["Marco Wing-Yin Law"],"keywords":[],"tmdb":{"type":"tv","id":"56313","season":1,"vote_average":7.2,"vote_count":13},"cast_meta":[{"name":"Trịnh Gia Dĩnh","name_vi":"Trịnh Gia Dĩnh","name_original":"Kevin Cheng Ka-Wing","tmdb_id":1140044,"profile":"https://image.tmdb.org/t/p/w500/rzT8YmWjBRbrfXii9is8uZAbiBQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1140044"},{"name":"Huỳnh Hạo Nhiên","name_vi":"Huỳnh Hạo Nhiên","name_original":"Raymond Ho-Yin Wong","tmdb_id":123648,"profile":"https://image.tmdb.org/t/p/w500/wrs7gHK5Ykyae2okZbrQU9bgIKN.jpg","tmdb_url":"https://www.themoviedb.org/person/123648"},{"name":"Natalie Tong","name_vi":null,"name_original":"Natalie Tong","tmdb_id":1237978,"profile":"https://image.tmdb.org/t/p/w500/jZHpp0BOnVW3M0NqH3TVpj0oGo6.jpg","tmdb_url":"https://www.themoviedb.org/person/1237978"},{"name":"Lý Thi Hoa","name_vi":"Lý Thi Hoa","name_original":"Selena Lee","tmdb_id":1178843,"profile":"https://image.tmdb.org/t/p/w500/fHwTvf1qkwspkfPYEWP4rj1QKjE.jpg","tmdb_url":"https://www.themoviedb.org/person/1178843"},{"name":"Hồ Định Hân","name_vi":"Hồ Định Hân","name_original":"Nancy Wu","tmdb_id":1234856,"profile":"https://image.tmdb.org/t/p/w500/9HPuplvtWO5ODGX0IhNaZsssIi4.jpg","tmdb_url":"https://www.themoviedb.org/person/1234856"},