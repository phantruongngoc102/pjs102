68d69/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream10.com/share/594111d37c181b0b4751bce524a94c4b","link_m3u8":"https://vip.opstream10.com/20260123/32453_594111d3/index.m3u8"}]}],"description":"<p>Phim lấy bối cảnh tại một thị trấn hư cấu xinh đẹp ở Anh tên là Sanctuary vốn được biết đến là “nơi trú ẩn\" dành cho phù thủy, nơi mà những người có phép thuật được sống hòa bình cùng với người thường trong nhiều thế kỷ và được chấp nhận trong xã hội. Thị trấn Sanctuary vốn yên bình bỗng chốc trở nên đảo lộn khi một cầu thủ rugby nổi tiếng chết trong một \"tai nạn\" sau một bữa tiệc, và cái chết này nhanh chóng dẫn đến các cáo buộc liên quan đến Harper - con gái của phù thủy Sarah. Những định kiến và nỗi sợ hãi tiềm ẩn đối với phù thủy trỗi dậy, dẫn đến một cuộc săn phù thủy thời hiện đại. Sarah phải tìm cách minh oan cho con gái mình, đồng thời đối mặt với những bí mật đen tối đang dần bị phanh phui trong thị trấn.&nbsp;</p><p>Nếu bạn thích những bộ phim kỳ bí kết hợp với điều tra phá án, đây là một bộ phim rất đáng xem.</p>","tmdb_id":238585,"cast":["Elaine Cassidy","Hazel Doupe","Stephanie Levi-John","Clive Standen"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"238585","season":1,"vote_average":6.2,"vote_count":27},"cast_meta":[{"name":"Elaine Cassidy","name_vi":null,"name_original":"Elaine Cassidy","tmdb_id":20054,"profile":"https://image.tmdb.org/t/p/w500/4pJCUt9JhraPZ2HJoPxbyrbKy5N.jpg","tmdb_url":"https://www.themoviedb.org/person/20054"},{"name":"Hazel Doupe","name_vi":null,"name_original":"Hazel Doupe","tmdb_id":1546861,"profile":"https://image.tmdb.org/t/p/w500/72eUrm3lWQNO5p0tyimIkgHPDjs.jpg","tmdb_url":"https://www.themoviedb.org/person/1546861"},{"name":"Stephanie Levi-John","name_vi":null,"name_original":"Stephanie Levi-John","tmdb_id":2280650,"profile":"https://image.tmdb.org/t/p/w500/a662H8C5sSK8iZQeICpgxt69Fz4.jpg","tmdb_url":"https://www.themoviedb.org/person/2280650"},{"name":"Clive Standen","name_vi":null,"name_original