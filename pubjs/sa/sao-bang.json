e/a320d0ae50c7ab5860cc5e4e420b61f3","link_m3u8":"https://vip.opstream14.com/20221017/25330_b56294f7/index.m3u8"},{"name":"16A","slug":"16a","filename":"sao-bang-shooting-stars-thuyet minh-tap-16A","link_embed":"https://vip.opstream14.com/share/6a639c52538fd7bb3e1186724afbe9b2","link_m3u8":"https://vip.opstream14.com/20221017/25329_64b598a3/index.m3u8"},{"name":"16B","slug":"16b","filename":"sao-bang-shooting-stars-thuyet minh-tap-16B","link_embed":"https://vip.opstream14.com/share/e41a2904fbd8d91f369d26baeb1719b6","link_m3u8":"https://vip.opstream14.com/20221017/25331_29f1226b/index.m3u8"}]}],"time":"1:10","description":"<p>Bộ phim truyền hình Hàn Quốc \\\"Sao Băng\\\" được sản xuất bởi đạo diễn Lee Soo Hyun và biên kịch Choi Young Woo.\\nBộ phim lấy chủ đề về giới giải trí và các công ty quản lí, kể về câu chuyện các minh tinh như những ngôi sao không thể tự mình tỏa sáng trên bầu trời, chủ yếu là câu chuyện của những người làm việc ở hậu trường ngành giải trí, những con người làm việc chăm chỉ khổ cực sau những lùm xùm của các minh tinh.\\nLà câu chuyện từ thù hận đến tình yêu lãn mạn giữa Oh Han Byul là trưởng nhóm PR tại một công ty giải trí, và ngôi sao nổi tiếng Gong Tae Sung.\\nMột trưởng nhóm quan hệ công chúng tài giỏi có năng lực phản ứng tuyệt vời khi các scandal xảy ra, và một ngôi sao nổi tiếng trong làng giải trí, chuyện gì sẽ xảy ra giữa họ?\\nBộ phim có sự tham gia của các diễn viên Lee Sung Kyung và Kim Young Dae.</p>","tmdb":{"type":"tv","id":"136732","season":1,"vote_average":8.142,"vote_count":95},"modified":"2025-04-16T13:17:36.000Z","cast":["Lee Sung-kyung","Kim Young-dae","Yoon Jong-hoon","Kim Yoon-hye","Park So-jin","Lee Jung-shin","Ha Do-kwon","Lee Seung-hyub","Jeong Ji-an","Yun Sang-jeong","Kwon Han-sol","Shin Hyeon-seung","Lee Si-woo","Jin Ho-eun","Jang He-ryung"],"director":["Li Xiu Xian"],"cast_meta":[{"name":"Lee Sung-kyung","name_vi":null,"name_original":"Lee Sung-kyung","tmdb_id":1482876,"profile":"https://image.tmdb.org/t/p/w500/vgsn