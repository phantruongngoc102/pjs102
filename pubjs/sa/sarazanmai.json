ream10.com/20220614/20649_b1755987/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/5c64db62424a286a59daa6913b170a67","link_m3u8":"https://vip.opstream10.com/20220614/20650_9e1bed9e/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/e98c9ba97d1ad89461538b61127884ce","link_m3u8":"https://vip.opstream10.com/20220614/20651_8d40654f/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/ba979247885fff1bf52c5788244b492f","link_m3u8":"https://vip.opstream10.com/20220614/20652_670cfd6a/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream10.com/share/ee9aecd92c396ac1108ad72106a74dc2","link_m3u8":"https://vip.opstream10.com/20220614/20653_46fb95cc/index.m3u8"}]}],"description":"<p>Câu chuyện bắt đầu vào một ngày nọ, ba cậu học sinh sơ trung: Kazuki Yasaka, Toi Kuji, và Enta Jinai. Đã tình cờ gặp một sinh vật lạ có hình dáng giống Kappa. Sinh vật ấy tự xưng là hoàng tử của vương quốc Kappa cao quý, với tên gọi là Keppi. Với sức mạnh của mình, Keppi đã lấy cắp shirikodama của ba cậu bé và cả ba cậu bé đều đã bị biến thành Kappa. Theo truyền thuyết shirikodama là một bộ phận kì bí giấu trong hậu môn của mỗi người. Chỉ có cách duy nhất để ba cậu bé trở lại thành người là phải hoàn thành nhiệm vụ mà Keppi đã giao. Nếu không, cả ba sẽ biến thành Kappa mãi mãi.</p>","tmdb_id":86919,"cast":[],"director":[],"keywords":[],"tmdb":{"id":86919},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/sa/sarazanmai.json"}