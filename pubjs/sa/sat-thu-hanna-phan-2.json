ink_embed":"https://vip.opstream10.com/share/d715978fcc0396b4d67d7ef9a0edf1f9","link_m3u8":"https://vip.opstream10.com/20260110/32253_d715978f/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/5887aebfeedcde5c7a690992128111da","link_m3u8":"https://vip.opstream10.com/20260113/32321_5887aebf/index.m3u8"}]}],"description":"<p>Phần 2 bắt đầu khi Hanna đang ẩn náu cùng Clara, người bạn cùng cô thoát khỏi Utrax đã bị Utrax truy bắt trở lại và đưa vào The Meadows, một cơ sở tẩy não và huấn luyện sát thủ mới của tổ chức Utrax. Hanna quyết định ra tay giải cứu người bạn thân Clara, bất chấp nguy hiểm và có thể bị bắt lại. Câu chuyện diễn ra qua nhiều địa điểm: rừng Romania, Anh quốc, Mỹ cho đến Barcelona sôi động… xen lẫn hành động gay cấn, truy đuổi và âm mưu lớn hơn của Utrax (liên quan đến các mục tiêu chính trị). Kết thúc mùa 2 mở ra hướng đi mới cho mùa 3, với Hanna quyết định thâm nhập sâu hơn để phá hủy tổ chức từ bên trong.</p>","tmdb_id":54155,"cast":["Esmé Creed-Miles","Mireille Enos","Dermot Mulroney","Ray Liotta"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"54155","season":2,"vote_average":7.447,"vote_count":861},"cast_meta":[{"name":"Esmé Creed-Miles","name_vi":null,"name_original":"Esmé Creed-Miles","tmdb_id":79510,"profile":"https://image.tmdb.org/t/p/w500/hmGkEC4OWsyDe7ZGVkZ7e1RjViD.jpg","tmdb_url":"https://www.themoviedb.org/person/79510"},{"name":"Mireille Enos","name_vi":null,"name_original":"Mireille Enos","tmdb_id":175826,"profile":"https://image.tmdb.org/t/p/w500/zza8XezUz4I5Is55H2totMbGLeG.jpg","tmdb_url":"https://www.themoviedb.org/person/175826"},{"name":"Dermot Mulroney","name_vi":null,"name_original":"Dermot Mulroney","tmdb_id":20212,"profile":"https://image.tmdb.org/t/p/w500/zemTC606JcuMgIGbJMYAocrS5Gm.jpg","tmdb_url":"https://www.themoviedb.org/person/20212"},{"name":"Ray Liotta","name_vi":null,"name_original":"Ray Liotta","tmdb_id":11477,"profile":"https://image.tmdb.org/t/p/w500/rhaCUi04uEXDFvuPM5Drj1A