vip.opstream14.com/20220706/17432_7e6e23a4/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/230412c7a68201e0be2f5d4fb9d442b4","link_m3u8":"https://vip.opstream14.com/20220706/17435_aebda3be/index.m3u8"}]}],"description":"<p>Phim xoay quanh anh chàng sát thủ có tiếng tên Diêm Võ (Lê Diệu Tường), vốn từng là nỗi khiếp sợ của giới giang hồ trong suốt nhiều năm. Tuy nhiên, một ngày nọ biến cố ập đến gia đình Võ khi cả nhà anh bị truy sát, kết quả là vợ mất mạng còn cô con gái Diêm Tố Chi (Mạch Minh Thi) thì bị mù. Từ đó, Võ bắt đầu tin vào luật nhân – quả, dần dần phong độ sa sút, anh trở thành sát thủ hạng bét. Chính từ đây mà sát thủ Kiều Tinh (Trần Hào) vượt lên, trở thành kẻ giết thuê mạnh nhất với biệt danh Zero, vỏ bọc của anh ta là một ông chủ tiệm cà phê hiền lành. Không những thế, những nhân viên làm việc trong quán của Tinh cũng là thành phần lai lịch bất minh được bảo vệ bởi bề ngoài lành tính.</p>","tmdb_id":105390,"cast":["Lê Diệu Tường","Trần Hào","Lý Giai Tâm","Giang Mỹ Nghi","Katy Kung","Samantha Ko","Lý Thành Xương","Amy Fan","Timothy Cheng Chi-Sing","Louisa Mak","Brian Tse Tung Man","Kong Ka-Man","King Lam","Hà Viễn Đông","Kayee Tam"],"director":["Trần Duy Quán"],"keywords":[],"tmdb":{"type":"tv","id":"105390","season":1,"vote_average":6,"vote_count":2},"cast_meta":[{"name":"Lê Diệu Tường","name_vi":"Lê Diệu Tường","name_original":"Wayne Lai Yiu-Cheung","tmdb_id":123654,"profile":"https://image.tmdb.org/t/p/w500/qm3knPxzkZPgq2SVo1ZTru7MkIM.jpg","tmdb_url":"https://www.themoviedb.org/person/123654"},{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Lý Giai Tâm","name_vi":"Lý Giai Tâm","name_original":"Ali Lee","tmdb_id":2178314,"profile":"https://image.tmdb.org/t/p/w500/qTNxoSXSb9FgxkM4HeMeDowuQOR.jpg","tmdb_url":"https://www.themoviedb.org/p