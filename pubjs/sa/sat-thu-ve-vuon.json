_06d77b5b/index.m3u8"}]}],"time":"24 phút/tập","description":"Thời gian trôi qua thật yên bình đối với Sakamoto kể từ khi anh ấy rời khỏi thế giới ngầm. Anh ấy đang điều hành một cửa hàng nhỏ trong khu phố với người vợ xinh đẹp và đứa con của mình, và có vẻ hơi... phát tướng rồi. Nhưng một ngày nọ, một nhân vật từ quá khứ của anh ấy đến thăm và đưa ra một lời đề nghị mà anh ấy không thể từ chối: quay trở lại thế giới sát thủ hoặc là chết!","tmdb":{"type":"tv","id":"207332","season":1,"vote_average":8.108,"vote_count":265},"modified":"2025-09-23T17:26:27.000Z","cast":["Tomokazu Sugita","Nobunaga Shimazaki","Ayane Sakura","Nao Toyama","Hina Kino","Ryota Suzuki","Hanae Natsuki","Taku Yashiro","Saori Hayami","Hiroki Yasumoto","Hochu Otsuka","Daisuke Namikawa"],"director":[],"cast_meta":[{"name":"Tomokazu Sugita","name_vi":null,"name_original":"Tomokazu Sugita","tmdb_id":144655,"profile":"https://image.tmdb.org/t/p/w500/cv5zuPZySNsHXu24pjKLYCRzJ2J.jpg","tmdb_url":"https://www.themoviedb.org/person/144655"},{"name":"Nobunaga Shimazaki","name_vi":null,"name_original":"Nobunaga Shimazaki","tmdb_id":1210634,"profile":"https://image.tmdb.org/t/p/w500/qke5rZusHsjSlvB0NKlJ5dQF5D.jpg","tmdb_url":"https://www.themoviedb.org/person/1210634"},{"name":"Ayane Sakura","name_vi":null,"name_original":"Ayane Sakura","tmdb_id":992869,"profile":"https://image.tmdb.org/t/p/w500/yPbTmntASE9psPIMhNGU5oo6vIH.jpg","tmdb_url":"https://www.themoviedb.org/person/992869"},{"name":"Nao Toyama","name_vi":null,"name_original":"Nao Toyama","tmdb_id":1168909,"profile":"https://image.tmdb.org/t/p/w500/6WJDd1z946yFfZBgpC7dWi0FyQw.jpg","tmdb_url":"https://www.themoviedb.org/person/1168909"},{"name":"Hina Kino","name_vi":null,"name_original":"Hina Kino","tmdb_id":1597103,"profile":"https://image.tmdb.org/t/p/w500/iwq0VvY3q4MPfn5ZTjsthhNcuyd.jpg","tmdb_url":"https://www.themoviedb.org/person/1597103"},{"name":"Ryota Suzuki","name_vi":null,"name_original":"Ryota Suzuki","tmdb_id":2138291,"profile":"https://im