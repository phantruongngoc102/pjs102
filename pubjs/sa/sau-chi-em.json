ần lượt chào đón sáu cô con gái, nhưng một tai nạn xe cộ bất ngờ đã cướp đi sinh mạng của ông. Chị cả Hà Gia Lệ cùng bà nội Hà Văn Thị và mẹ Lưu Mỹ Tâm gánh vác trọng trách gia đình, giúp các em gái thành gia lập nghiệp.</p><p>&nbsp;</p>","tmdb_id":270851,"cast":["Mai Đình","Lục Nghị","Ô Quân Mai","Hề Mỹ Quyên","Lưu Quân","Ngô Thiến","Cao Lộ","Dĩnh Nhi","Tào Phỉ Nhiên","Lý Gia Kỳ","Đổng Khiết"],"director":["楼健"],"keywords":[],"tmdb":{"type":"tv","id":"270851","season":1,"vote_average":6.25,"vote_count":8},"cast_meta":[{"name":"Mai Đình","name_vi":"Mai Đình","name_original":"Mei Ting","tmdb_id":131343,"profile":"https://image.tmdb.org/t/p/w500/90RGl03U4aRAHmpUuDMsal3NzSi.jpg","tmdb_url":"https://www.themoviedb.org/person/131343"},{"name":"Lục Nghị","name_vi":"Lục Nghị","name_original":"Lu Yi","tmdb_id":127269,"profile":"https://image.tmdb.org/t/p/w500/tTSfUQBS2t7uBVw6sb65n35XC5B.jpg","tmdb_url":"https://www.themoviedb.org/person/127269"},{"name":"Ô Quân Mai","name_vi":"Ô Quân Mai","name_original":"Vivian Wu","tmdb_id":69033,"profile":"https://image.tmdb.org/t/p/w500/9eVO9mefla7stKGH67SAqmHyVya.jpg","tmdb_url":"https://www.themoviedb.org/person/69033"},{"name":"Hề Mỹ Quyên","name_vi":"Hề Mỹ Quyên","name_original":"Xi Meijuan","tmdb_id":145096,"profile":"https://image.tmdb.org/t/p/w500/53TwkgQmPes2Zq0LbjuOeg8fyUA.jpg","tmdb_url":"https://www.themoviedb.org/person/145096"},{"name":"Lưu Quân","name_vi":"Lưu Quân","name_original":"Liu Jun","tmdb_id":1613668,"profile":"https://image.tmdb.org/t/p/w500/g7xtMSpT23VHplyPYx0rkEI3ZTO.jpg","tmdb_url":"https://www.themoviedb.org/person/1613668"},{"name":"Ngô Thiến","name_vi":"Ngô Thiến","name_original":"Janice Wu","tmdb_id":1677008,"profile":"https://image.tmdb.org/t/p/w500/zNw2OQbHC343epJkSgR3FUHGWmA.jpg","tmdb_url":"https://www.themoviedb.org/person/1677008"},{"name":"Cao Lộ","name_vi":"Cao Lộ","name_original":"Gao Lu","tmdb_id":1630009,"profile":"https://image.tmdb.org/t/p/w500/q4ubJjkZoHV48CKc8FOZD3KZHXa.jpg","tmdb_url":"https