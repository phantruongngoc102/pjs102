024","link_embed":"https://vip.opstream16.com/share/7370a4e2d543e24ccc7714f12f3d83a4","link_m3u8":"https://vip.opstream16.com/20241119/41088_7370a4e2/index.m3u8"},{"name":"16","slug":"16","filename":"Sau Hôn Sự - Tập 16---2024","link_embed":"https://vip.opstream16.com/share/b431ca5b3fa29ad7cb53e91a19074f1e","link_m3u8":"https://vip.opstream16.com/20241119/41089_b431ca5b/index.m3u8"},{"name":"17","slug":"17","filename":"Sau Hôn Sự - Tập 17---2024","link_embed":"https://vip.opstream16.com/share/357a689f054e8c8b3ea30d0492c52932","link_m3u8":"https://vip.opstream16.com/20241119/41090_357a689f/index.m3u8"},{"name":"18","slug":"18","filename":"Sau Hôn Sự - Tập 18---2024","link_embed":"https://vip.opstream16.com/share/ad92301430dc5fe354e6d0b1946e537f","link_m3u8":"https://vip.opstream16.com/20241119/41091_ad923014/index.m3u8"},{"name":"19","slug":"19","filename":"Sau Hôn Sự - Tập 19---2024","link_embed":"https://vip.opstream16.com/share/9b27373ee26f5c75aa3ac8c862b21f08","link_m3u8":"https://vip.opstream16.com/20241119/41092_9b27373e/index.m3u8"},{"name":"20","slug":"20","filename":"Sau Hôn Sự - Tập 20---2024","link_embed":"https://vip.opstream16.com/share/c9ae486d4193a28218ebcf092e1a1659","link_m3u8":"https://vip.opstream16.com/20241119/41093_c9ae486d/index.m3u8"}]}],"time":"43 phút/tập","description":"Nội dung phim gồm bốn chương, với các chủ đề: “Ly hôn”, “Bất trung”, “Yêu nhầm” và “Sửa chữa”. Phan Thiện Nhân (La Trọng Khiêm) và Trương Minh Tâm (Trần Tự Dao) tiến tới hôn nhân, Tâm phát hiện chồng ngoại tình, khiến không khí gia đình ngột ngạt. Và khi quyết định ly hôn, con gái cũng chịu tổn thương sâu sắc. Cam Thành Quân (Lê Nặc Ý) – giảng viên nổi tiếng của một trung tâm dạy kèm, bạn thân của Nhân và Tâm. Quân vốn thích Tâm nhưng giấu kín. Quân thấy lựa chọn “chỉ yêu đương, không kết hôn” là đúng khi thấy Nhân và Tâm ly hôn. Lữ Tịnh Lâm (Lại Úy Linh) là người yêu của Quân lo sợ Quân sẽ có cơ hội đến với Tâm. Nữ biên kịch Lữ Tịnh Hải (Vương Mẫn Dịch) ngưỡng mộ Nhân & chủ động tiếp cận anh. Nhân vướng vào lưới tình & bị netizen công kích, còn Hải bị chửi mắng thậm tệ. Anh chàng quay phim tên Trình Thiên Huy (La Thiên Vũ) luôn bên cạnh Hải. Phim tạo nên cái nhìn đa chiều về cùng một vấn đề. Có khi miên man cảm xúc, có lúc đắng chát xoáy tận tâm can, lôi cuốn người xem.","tmdb":{"type":"tv","id":"246713","season":1,"vote_average":9,"vote_count":1},"modified":"2025-08-04T16:38:17.000Z","cast":["Yoyo Chen Chi-Yiu","La Tử Dật","Chris Lai","Joey Law","Winki Lai","Vương Mẫn Dịch","Toby Chan"],"director":[],"cast_meta":[{"name":"Yoyo Chen Chi-Yiu","name_vi":null,"name_original":"Yoyo Chen Chi-Yiu","tmdb_id":1240092,"profile":"https://image.tmdb.org/t/p/w500/nMUK7mGsqmxnHJIWtOOrBynV5QG.jpg","tmdb_url":"https://www.themoviedb.org/person/1240092"},{"name":"La Tử Dật","name_vi":"La Tử Dật","name_original":"Lo Chung-Him","tmdb_id":237032,"profile":"https://image.tmdb.org/t/p/w500/dAc0eHm0CWBBu7L8KD84RrHAZyo.jpg","tmdb_url":"https://www.themoviedb.org/person/237032"},{"name":"Chris Lai","name_vi":null,"name_original":"Chris Lai","tmdb_id":112986,"profile":"https://image.tmdb.org/t/p/w500/en9t651XkkOpdfIZRQdtqmZD6YG.jpg","tmdb_url":"https://www.themoviedb.org/person/112986"},{"name":"Joey Law","name_vi":null,"name_original":"Joey Law","tmdb_id":2392425,"profile":"https://image.tmdb.org/t/p/w500/njwnfhrrhXLZ2ELqasYVCIeQZzO.jpg","tmdb_url":"https://www.themoviedb.org/person/2392425"},{"name":"Winki Lai","name_vi":null,"name_original":"Winki Lai","tmdb_id":2064586,"profile":"https://image.tmdb.org/t/p/w500/bhg2Q2fS3sV9nkBpsyhLC2aq4ym.jpg","tmdb_url":"https://www.themoviedb.org/person/2064586"},{"name":"Vương Mẫn Dịch","name_vi":"Vương Mẫn Dịch","name_original":"Venus Wong Man-Yik","tmdb_id":937492,"profile":"https://image.tmdb.org/t/p/w500/ySEEfNsEIFj8mPb84lnyVVbfSB0.jpg","tmdb_url":"https://www.themoviedb.org/person/937492"},{"name":"Toby Chan","name_vi":null,"name_original":"Toby Chan","tmdb_id":2064596,"profile":"https://image.tmdb.org/t/p/w500/rB