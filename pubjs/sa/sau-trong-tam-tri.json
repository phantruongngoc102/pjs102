trở về từ nước ngoài, giữ chức phó khoa phẫu thuật thần kinh từ khi còn trẻ, chủ trương rằng công nghệ sẽ thay thế sức lao động, và công nghệ tiên tiến có thể chữa khỏi mọi bệnh tật.</p>","tmdb":{"type":"tv","id":"124486","season":1,"vote_average":7.5,"vote_count":2},"modified":"2025-10-27T10:17:02.000Z","cast":["Tian Muchen","Sun Sihan","Bai Yihong","Liu Qianwen","Cheng Ye","Fang Qingzhuo","Chang Rong","Zhao Yiji"],"director":[],"cast_meta":[{"name":"Tian Muchen","name_vi":null,"name_original":"Tian Muchen","tmdb_id":2048198,"profile":"https://image.tmdb.org/t/p/w500/d4tizRjOX8daPWSjjtGsXGMmTr.jpg","tmdb_url":"https://www.themoviedb.org/person/2048198"},{"name":"Sun Sihan","name_vi":null,"name_original":"Sun Sihan","tmdb_id":1416516,"profile":"https://image.tmdb.org/t/p/w500/89xLq3qMSvfugCjaPYjmUFSx2AR.jpg","tmdb_url":"https://www.themoviedb.org/person/1416516"},{"name":"Bai Yihong","name_vi":null,"name_original":"Bai Yihong","tmdb_id":2752818,"profile":"https://image.tmdb.org/t/p/w500/bZQA0Cm0dCZ487WAlVne0uPwaP0.jpg","tmdb_url":"https://www.themoviedb.org/person/2752818"},{"name":"Liu Qianwen","name_vi":null,"name_original":"Liu Qianwen","tmdb_id":2407929,"profile":"https://image.tmdb.org/t/p/w500/grNWcmcPeZxHCqmQLOyshrlqY2A.jpg","tmdb_url":"https://www.themoviedb.org/person/2407929"},{"name":"Cheng Ye","name_vi":null,"name_original":"Cheng Ye","tmdb_id":2601287,"profile":"https://image.tmdb.org/t/p/w500/sZr6woJ5O7tMRWt02lqTr5T2ida.jpg","tmdb_url":"https://www.themoviedb.org/person/2601287"},{"name":"Fang Qingzhuo","name_vi":null,"name_original":"Fang Qingzhuo","tmdb_id":1138372,"profile":"https://image.tmdb.org/t/p/w500/s8VwjmKCkTOjFcrVjUNroe6sGsR.jpg","tmdb_url":"https://www.themoviedb.org/person/1138372"},{"name":"Chang Rong","name_vi":null,"name_original":"Chang Rong","tmdb_id":1753664,"profile":"https://image.tmdb.org/t/p/w500/oFRsRdzeYVChRQ6r54DlThweF3G.jpg","tmdb_url":"https://www.themoviedb.org/person/1753664"},{"name":"Zhao Yiji","name_vi":null,"name_orig