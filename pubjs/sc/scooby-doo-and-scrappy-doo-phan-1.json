n nhạc gây cười của studio. Kênh cổ điển Boomerang của Cartoon Network chiếu lại loạt phim.</p>","tmdb":{"type":"tv","id":"6005","season":1,"vote_average":7.5,"vote_count":327},"modified":"2023-02-25T13:53:05.000Z","cast":["Casey Kasem","Don Messick"],"director":[],"cast_meta":[{"name":"Casey Kasem","name_vi":null,"name_original":"Casey Kasem","tmdb_id":16418,"profile":"https://image.tmdb.org/t/p/w500/59kecPxxPIO8uwzaRZAOSDE1l80.jpg","tmdb_url":"https://www.themoviedb.org/person/16418"},{"name":"Don Messick","name_vi":null,"name_original":"Don Messick","tmdb_id":16422,"profile":"https://image.tmdb.org/t/p/w500/iT3okvWCKy6RAdo6dbx09RP0I3p.jpg","tmdb_url":"https://www.themoviedb.org/person/16422"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/sc/scooby-doo-and-scrappy-doo-phan-1.json"}