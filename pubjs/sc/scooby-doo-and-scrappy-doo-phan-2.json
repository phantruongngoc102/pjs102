/vip.opstream15.com/20230220/34014_411ca8ff/index.m3u8"}]}],"description":"<p>Phiên bản gốc dài 30 phút của Scooby-Doo và Scrappy-Doo tạo thành phiên bản thứ tư của phim hoạt hình Hanna-Barbera sáng thứ bảy Scooby-Doo. Phim được công chiếu lần đầu vào ngày 22 tháng 9 năm 1979 và chạy một mùa trên ABC dưới dạng chương trình dài nửa giờ. Tổng cộng có mười sáu tập đã được sản xuất. Đây là loạt phim hoạt hình cuối cùng của Hanna-Barbera sử dụng bản nhạc gây cười của studio. Kênh cổ điển Boomerang của Cartoon Network chiếu lại loạt phim.</p>","tmdb_id":6005,"cast":["Casey Kasem","Don Messick"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"6005","season":2,"vote_average":7.5,"vote_count":327},"cast_meta":[{"name":"Casey Kasem","name_vi":null,"name_original":"Casey Kasem","tmdb_id":16418,"profile":"https://image.tmdb.org/t/p/w500/59kecPxxPIO8uwzaRZAOSDE1l80.jpg","tmdb_url":"https://www.themoviedb.org/person/16418"},{"name":"Don Messick","name_vi":null,"name_original":"Don Messick","tmdb_id":16422,"profile":"https://image.tmdb.org/t/p/w500/iT3okvWCKy6RAdo6dbx09RP0I3p.jpg","tmdb_url":"https://www.themoviedb.org/person/16422"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/sc/scooby-doo-and-scrappy-doo-phan-2.json"}