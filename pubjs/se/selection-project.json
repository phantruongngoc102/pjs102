dc05/index.m3u8"}]}],"time":"","description":"<p>SELECTION PROJECT là anime xoay quanh chủ đề thần tượng, âm nhạc, lấy bối cảnh về cuộc thi thử giọng thần tượng quốc gia tổ chức vào mùa hè hàng năm. Chín cô gái chiến thắng vòng loại cấp quận sẽ bước vào vòng thi thử giọng cuối cùng cấp quốc gia. Người nhận được nhiều bình chọn nhất từ khán giả tại buổi live sẽ giành chiến thắng. Liệu ai trong số chín người họ sẽ có được vương miện và trở thành một thần tượng thực thụ? Cuộc chiến đầy nhiệt huyết của những cô gái vừa là đối thủ, vừa là những người bạn hướng đến chung một giấc mơ sắp được vén màn.</p>","tmdb":{"type":"tv","id":"114202","season":1,"vote_average":6,"vote_count":9},"modified":"2022-05-20T08:05:34.000Z","cast":["Hinaki Yano","Saku Mizuno","Nozomi Nagumi","Ruri Arai","Hina Youmiya","Yuka Iwahashi","Mizuna Shirakawa","Miharu Hanai","Shino Shimoji","Saori Onishi","Daisuke Ono","Saori Hayami"],"director":[],"cast_meta":[{"name":"Hinaki Yano","name_vi":null,"name_original":"Hinaki Yano","tmdb_id":2774746,"profile":"https://image.tmdb.org/t/p/w500/AaooiskwaqifXbXAficRnHyfUvj.jpg","tmdb_url":"https://www.themoviedb.org/person/2774746"},{"name":"Saku Mizuno","name_vi":null,"name_original":"Saku Mizuno","tmdb_id":3004070,"profile":"https://image.tmdb.org/t/p/w500/u3OUaxIk8SHjEoudLA2UpKjwDX5.jpg","tmdb_url":"https://www.themoviedb.org/person/3004070"},{"name":"Nozomi Nagumi","name_vi":null,"name_original":"Nozomi Nagumi","tmdb_id":3004072,"profile":"https://image.tmdb.org/t/p/w500/fngrjOzvOhxxk5gAYg0JpZjIEd6.jpg","tmdb_url":"https://www.themoviedb.org/person/3004072"},{"name":"Ruri Arai","name_vi":null,"name_original":"Ruri Arai","tmdb_id":2855126,"profile":"https://image.tmdb.org/t/p/w500/dnVhAJaYqvzN4SQ3mghbXwF8a9v.jpg","tmdb_url":"https://www.themoviedb.org/person/2855126"},{"name":"Hina Youmiya","name_vi":null,"name_original":"Hina Youmiya","tmdb_id":2956795,"profile":"https://image.tmdb.org/t/p/w500/tOy21NTNnKuZG48JCL673tTP16z.jpg","tmdb_url":"https://www.themo