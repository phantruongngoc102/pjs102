i Shangri-La Frontier, anh đã bước vào game ngay lập tức và bỏ qua cả hướng dẫn mở đầu dành cho tân binh. Nhưng liệu lão làng game thủ \"rank thách đấu\" có thể phá đảo những gì đang tồn tại trong Shangri-La Frontier?","tmdb":{"type":"tv","id":"205050","season":2,"vote_average":8.068,"vote_count":184},"modified":"2025-03-30T20:38:41.000Z","cast":["Yuma Uchida","Azumi Waki","Yoko Hikasa","Makoto Koichi","Rina Hidaka","Akio Otsuka","Seiichiro Yamashita","Yumiri Hanamori","Sayaka Senbongi","Umeka Shouji","Asaki Yuikawa","Satomi Sato","Megumi Han"],"director":[],"cast_meta":[{"name":"Yuma Uchida","name_vi":null,"name_original":"Yuma Uchida","tmdb_id":1492992,"profile":"https://image.tmdb.org/t/p/w500/2otstbLfQ7MXuFt1X8MFOb4OIgd.jpg","tmdb_url":"https://www.themoviedb.org/person/1492992"},{"name":"Azumi Waki","name_vi":null,"name_original":"Azumi Waki","tmdb_id":1647634,"profile":"https://image.tmdb.org/t/p/w500/nxm4DLWv0BOcK2owvAz5yafSAXj.jpg","tmdb_url":"https://www.themoviedb.org/person/1647634"},{"name":"Yoko Hikasa","name_vi":null,"name_original":"Yoko Hikasa","tmdb_id":1072774,"profile":"https://image.tmdb.org/t/p/w500/mP3bj0s1gqJ6tCKFLhu4b1CkJj7.jpg","tmdb_url":"https://www.themoviedb.org/person/1072774"},{"name":"Makoto Koichi","name_vi":null,"name_original":"Makoto Koichi","tmdb_id":1645397,"profile":"https://image.tmdb.org/t/p/w500/2HhTnfV6x5nStC7zBnBqgh7r3HY.jpg","tmdb_url":"https://www.themoviedb.org/person/1645397"},{"name":"Rina Hidaka","name_vi":null,"name_original":"Rina Hidaka","tmdb_id":1116334,"profile":"https://image.tmdb.org/t/p/w500/7JupZGvqcq4dRxiTKpPxzg8NUS4.jpg","tmdb_url":"https://www.themoviedb.org/person/1116334"},{"name":"Akio Otsuka","name_vi":null,"name_original":"Akio Otsuka","tmdb_id":40451,"profile":"https://image.tmdb.org/t/p/w500/uH9oiqOOgrsz2zNnouVZ1qPzDyb.jpg","tmdb_url":"https://www.themoviedb.org/person/40451"},{"name":"Seiichiro Yamashita","name_vi":null,"name_original":"Seiichiro Yamashita","tmdb_id":1732278,"profile":"https://im