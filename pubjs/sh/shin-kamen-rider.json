","reboot","masked superhero","body modification","based on tv series","mysterious disappearance","body horror","henshin heroes","tokusatsu"],"tmdb":{"type":"movie","id":"813477","season":null,"vote_average":6.9,"vote_count":297},"cast_meta":[{"name":"Sosuke Ikematsu","name_vi":null,"name_original":"Sosuke Ikematsu","tmdb_id":1116510,"profile":"https://image.tmdb.org/t/p/w500/mNhgUAKfHdKQXhbhbAhKcRUHy30.jpg","tmdb_url":"https://www.themoviedb.org/person/1116510"},{"name":"Hamabe Minami","name_vi":"Hamabe Minami","name_original":"Minami Hamabe","tmdb_id":1516266,"profile":"https://image.tmdb.org/t/p/w500/eQN8N2chINckvQDiNqzDXI0v9vN.jpg","tmdb_url":"https://www.themoviedb.org/person/1516266"},{"name":"Tasuku Emoto","name_vi":null,"name_original":"Tasuku Emoto","tmdb_id":111639,"profile":"https://image.tmdb.org/t/p/w500/bWFDE4bXUQxmyUey6sA5S84A3vG.jpg","tmdb_url":"https://www.themoviedb.org/person/111639"},{"name":"Mirai Moriyama","name_vi":null,"name_original":"Mirai Moriyama","tmdb_id":87657,"profile":"https://image.tmdb.org/t/p/w500/1oEMeQHiR9D5hmmXlHkD78da9rW.jpg","tmdb_url":"https://www.themoviedb.org/person/87657"},{"name":"Nanase Nishino","name_vi":null,"name_original":"Nanase Nishino","tmdb_id":1741323,"profile":"https://image.tmdb.org/t/p/w500/8Y3OFMBXPmbfn94QSrSEN64lE0F.jpg","tmdb_url":"https://www.themoviedb.org/person/1741323"},{"name":"Toru Tezuka","name_vi":null,"name_original":"Toru Tezuka","tmdb_id":58609,"profile":"https://image.tmdb.org/t/p/w500/pTh4Dc2qqdzRLYaWXEUQZp8bScA.jpg","tmdb_url":"https://www.themoviedb.org/person/58609"},{"name":"Nao Omori","name_vi":null,"name_original":"Nao Omori","tmdb_id":58604,"profile":"https://image.tmdb.org/t/p/w500/5cydxO4jcAEt7K1u4ops71EhCdj.jpg","tmdb_url":"https://www.themoviedb.org/person/58604"},{"name":"Kanata Hongo","name_vi":null,"name_original":"Kanata Hongo","tmdb_id":114725,"profile":"https://image.tmdb.org/t/p/w500/5BUmrqD3nbER1XV3ASSwFZitwwv.jpg","tmdb_url":"https://www.themoviedb.org/person/114725"},{"