 nghệ sĩ biểu diễn theo đúng nghĩa của mình—nhưng con đường đó không dành cho phụ nữ.</p>","tmdb_id":66862,"cast":[],"director":[],"keywords":[],"tmdb":{"id":66862},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/sh/showa-genroku-rakugo-shinju.json"}