0230311/32932_cdd6fea5/index.m3u8"},{"name":"6","slug":"6","filename":"The Boys_S01E06_The Innocents","link_embed":"https://vip.opstream16.com/share/d82cc168f5c589abedc86f5bea6ac5e0","link_m3u8":"https://vip.opstream16.com/20230311/32933_8f076ade/index.m3u8"},{"name":"7","slug":"7","filename":"The Boys_S01E07_The Self-Preservation Society","link_embed":"https://vip.opstream16.com/share/71f0603a717117b0bc2df3f784862801","link_m3u8":"https://vip.opstream16.com/20230311/32934_e721c286/index.m3u8"},{"name":"8","slug":"8","filename":"The Boys_S01E08_You Found Me","link_embed":"https://vip.opstream16.com/share/de6f3928abff533f338ec3847320b0d1","link_m3u8":"https://vip.opstream16.com/20230311/32935_1250211d/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Lấy bối cảnh thế giới bị thống trị bởi các nhóm siêu anh hùng, trong đó nổi bật là The Seven. Sở hữu sức mạnh vượt trội, The Seven tin rằng mình đứng trên đỉnh thế giới, có thể làm bất cứ chuyện gì mà không sợ bị ai chống đối. Chính sự liều lĩnh của họ đã khiến nhân loại bao phen lâm nguy. Trước sự lộng hành của The Seven, CIA quyết định lập nên biệt đội đặc biệt mang tên The Boys. The Boys lãnh trách nhiệm theo sát các siêu anh hùng, can thiệp nếu họ gây ra chuyện xấu. Đương nhiên, The Seven chẳng hề hài lòng với chuyện này.</p>","tmdb":{"type":"tv","id":"76479","season":1,"vote_average":8.442,"vote_count":11563},"modified":"2023-03-12T14:18:59.000Z","cast":["Karl Urban","Jack Quaid","Antony Starr","Erin Moriarty","Jessie T. Usher","Laz Alonso","Chace Crawford","Tomer Capone","Karen Fukuhara","Nathan Mitchell","Colby Minifie","Susan Heyward","Valorie Curry","Daveed Diggs"],"director":[],"cast_meta":[{"name":"Karl Urban","name_vi":null,"name_original":"Karl Urban","tmdb_id":1372,"profile":"https://image.tmdb.org/t/p/w500/6CkZLwEJxfqqcJHyeXegMAvOlPh.jpg","tmdb_url":"https://www.themoviedb.org/person/1372"},{"name":"Jack Quaid","name_vi":null,"name_original":"Jack Quaid","tmdb_id":1030513,"profile":"https://image.tmdb