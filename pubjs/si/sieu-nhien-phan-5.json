opstream16.com/20230103/28657_0624f663/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/d5eeeb68551631bceacdeeb4e2a9d3c1","link_m3u8":"https://vip.opstream16.com/20230103/28656_358ddb0c/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/974e2945a18e0bfb8e3aa8becac3e65c","link_m3u8":"https://vip.opstream16.com/20230103/28655_ee0bb73e/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream16.com/share/b7d20eb3c83c02646cd3d927de1c36bf","link_m3u8":"https://vip.opstream16.com/20230103/28654_812d3e9a/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream16.com/share/638c1a4f003b46aad4aa5cf3f424d215","link_m3u8":"https://vip.opstream16.com/20230103/28653_7edd36ee/index.m3u8"}]}],"description":"<p>Dần hé mở cái kết của cuộc chiến giữa thiên đàng và địa ngục, xoay quanh cuộc đấu tranh để ngăn chặn Lucifer và cứu thế giới khỏi Apocalypse. Khi Sam vô tình phá vỡ con dấu cuối cùng – nơi giam giữ Lucifer ở dưới địa ngục, Lucifer trở nên mạnh nhất. Chưa thể đánh bại Lucifer, Sam và Dean đã đi theo con đường riêng của mỗi người. Trở về với cuộc sống bình thường, họ vẫn không thể nào sống yên ổn, các thế lực ma quỷ vẫn luôn đeo bám và nhiệm vụ giải cứu loài người đã thôi thúc họ lại đoàn tụ đi săn với nhau một lần nữa. Họ đã cùng nhau tiếp tục cuộc chiến chống lại Lucifer với sự giúp đỡ của các thiên thần, cùng với việc điều tra một chuỗi các vụ giết người rất lạ khi nạn dịch nhiễm vi rút ma quỷ đang gia tăng…Liệu họ có tiếp tục làm được những điều tưởng chừng không thể và số phận của họ sẽ ra sao trong cuộc chiến sinh tử lần này?</p>","tmdb_id":1622,"cast":[],"director":[],"keywords":[],"tmdb":{"id":1622},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/si/sieu-nhien-phan-5.json"}