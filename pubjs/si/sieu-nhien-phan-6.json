p.opstream11.com/20230110/41380_be8f68c7/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/c4202309735b5048a6579de2a879e4e1","link_m3u8":"https://vip.opstream11.com/20230110/41376_61c17610/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/ed37d732c48f5a4376c7cd585d82ab8f","link_m3u8":"https://vip.opstream11.com/20230110/41377_9ff19b99/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/ec0f87b9257fc1cc6276cfc1ce887d69","link_m3u8":"https://vip.opstream11.com/20230110/41378_140a22ea/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/f1178ff78a50fcb8de1f15d69a4c7c99","link_m3u8":"https://vip.opstream11.com/20230110/41379_36dc9804/index.m3u8"}]}],"description":"<p>Bắt đầu sau một năm Dean đã trở về cuộc sống hạnh phúc bên gia đình sau khi Lucifer đã trở lại địa ngục, nhưng Dean không hề hay biết rằng Sam không còn bị mắc kẹt trong địa ngục nữa, Sam đã trở về thế giới người sống nhưng linh hồn của anh lại bị giam giữ nơi địa ngục. Sam đã cùng với Samuel Campbell truy tìm và bắt sống con quái vật Alpha để lấy lại linh hồn của mình. Thời gian này thì những con quái vật, thiên thần và quỷ đã lang thang trong một cảnh vô luật lệ hỗn loạn, Dean lại bị kéo trở lại cuộc sống đi săn cũ của mình để giúp Sam tìm lại linh hồn. Cùng lúc đó, Crowel muốn dùng con quái vật Alpha để tìm được cánh cửa Luyện Ngục, hắn ta đã thỏa thuận với Castial - một thiên thần mang trong mình biết bao dã tâm. Vì thế Castiel đã làm một rào cản trong tinh thần Sam để ngăn chặn anh em nhà Winchester làm hỏng kế hoạch của hắn…Liệu Dean có giúp Sam lấy lại được linh hồn và ký ức của mình hay không? Và thiên thần Castiel thật sự là ai?</p>","tmdb_id":1622,"cast":[],"director":[],"keywords":[],"tmdb":{"id":1622},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/si/sieu-nhien-phan-6.json"}