n nào ?</p>","tmdb":{"type":"movie","id":"44571","season":null,"vote_average":4.764,"vote_count":163},"modified":"2022-05-13T16:06:00.000Z","cast":["Maggie Q","Sean Faris","Will Yun Lee"],"director":["Gordon Chan"],"cast_meta":[{"name":"Maggie Q","name_vi":null,"name_original":"Maggie Q"},{"name":"Sean Faris","name_vi":null,"name_original":"Sean Faris"},{"name":"Will Yun Lee","name_vi":null,"name_original":"Will Yun Lee"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/si/sinh-tu-chien.json"}