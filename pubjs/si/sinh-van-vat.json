b69a0b975b5bc34f344","link_m3u8":"https://vip.opstream13.com/20251204/20965_d26bc3c8/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream13.com/share/039d87b2e37052561a07a6066a88582e","link_m3u8":"https://vip.opstream13.com/20251204/20966_039d87b2/index.m3u8"}]}],"description":"<p>Bộ phim kể về câu chuyện tại vùng nông thôn Lỗ Nam, khắc họa hành trình biến động của mảnh đất và số phận con người trong giai đoạn lịch sử đầy sóng gió. Trọng tâm là câu chuyện trưởng thành đầy nghị lực của người phụ nữ, xen lẫn những mối tình sâu nặng, tạo nên bản anh hùng ca xúc động về tình yêu và lòng kiên cường. Giữa ách thống trị phong kiến khắc nghiệt, những người nông dân vật lộn từng ngày để sinh tồn, để vươn lên tìm ánh sáng tự do. Nhưng trên hết, phim đặc biệt khắc họa mối gắn bó máu thịt giữa con người và mảnh đất quê hương – thứ tình cảm thiêng liêng truyền từ thế hệ này sang thế hệ khác, như một lời thề không bao giờ dứt.</p>","tmdb_id":272485,"cast":["Dương Mịch","Âu Hào","Nghê Đại Hồng","Tần Hải Lộ","Hình Phi","Trương Thiên Dương","Zhang Haiyu","Lin Yongjian"],"director":["Liu Jiacheng"],"keywords":[],"tmdb":{"type":"tv","id":"272485","season":1,"vote_average":9,"vote_count":5},"cast_meta":[{"name":"Dương Mịch","name_vi":"Dương Mịch","name_original":"Yang Mi","tmdb_id":572043,"profile":"https://image.tmdb.org/t/p/w500/lPQ9RgOj5hY5AYRJ8G1CedjdCGz.jpg","tmdb_url":"https://www.themoviedb.org/person/572043"},{"name":"Âu Hào","name_vi":"Âu Hào","name_original":"Ou Hao","tmdb_id":1355667,"profile":"https://image.tmdb.org/t/p/w500/nHokLSjlWJB3Gwt3zBXUuBPvR77.jpg","tmdb_url":"https://www.themoviedb.org/person/1355667"},{"name":"Nghê Đại Hồng","name_vi":"Nghê Đại Hồng","name_original":"Ni Dahong","tmdb_id":17382,"profile":"https://image.tmdb.org/t/p/w500/flZaRTKOi24JMKNWWg67lybTgSc.jpg","tmdb_url":"https://www.themoviedb.org/person/17382"},{"name":"Tần Hải Lộ","name_vi":"Tần Hải Lộ","name_original":"Qin Hailu","tmdb_id":124992,"profile":"https://image.tmdb.org/t