s://vip.opstream11.com/share/5011c560a9233c63cf0e6cb6d06cf22c","link_m3u8":"https://vip.opstream11.com/20221203/38753_a9fbe2cd/index.m3u8"},{"name":"96","slug":"96","link_embed":"https://vip.opstream11.com/share/f72f05e91d583cf63ae47e955ca9c312","link_m3u8":"https://vip.opstream11.com/20221203/38752_61af0d71/index.m3u8"},{"name":"97","slug":"97","link_embed":"https://vip.opstream11.com/share/39413c8e064172834b2cca658a731119","link_m3u8":"https://vip.opstream11.com/20221203/38754_8609b62d/index.m3u8"},{"name":"98","slug":"98","link_embed":"https://vip.opstream11.com/share/54d49c7b12e6e1f3d41d0711bcabeb58","link_m3u8":"https://vip.opstream11.com/20221203/38755_e63556c0/index.m3u8"},{"name":"99","slug":"99","link_embed":"https://vip.opstream11.com/share/26d92ac258f0fbfa10e56184450c48fa","link_m3u8":"https://vip.opstream11.com/20221203/38756_643019b3/index.m3u8"},{"name":"100","slug":"100","link_embed":"https://vip.opstream11.com/share/35f48f3c40b10f6acbdd1cd1a8093252","link_m3u8":"https://vip.opstream11.com/20221203/38757_b0739267/index.m3u8"},{"name":"101","slug":"101","link_embed":"https://vip.opstream11.com/share/65793916d10b56afcf7a343e521b89df","link_m3u8":"https://vip.opstream11.com/20221203/38758_d42bccf0/index.m3u8"}]}],"description":"<p>Slam Dunk là câu chuyện xoay quanh nhân vật Hanamichi Sakuragi, vốn là học sinh cá biệt, cầm đầu một băng nhóm chuyên gây lộn. Hanamichi từng tỏ tình và bị từ chối 50 lần khi còn học cấp 2. Lên trung học, cậu ta gặp Haruko Akagi - cô gái trong mơ, và rất hạnh phúc khi cô không hề sợ cậu như những cô gái khác. Haruko Akagi, người phát hiện ra tố chất thể thao của Hanamichi, giới thiệu cậu cho đội bóng rổ Shohoku. Hanamichi do dự trước việc gia nhập đội bóng vì cậu chưa từng chơi bất kỳ môn thể thao nào và luôn nghĩ rằng bóng rổ chỉ dành cho những kẻ thua cuộc (cũng một phần vì cô gái thứ 50 từ chối cậu vì cô đã thích một anh chàng ở đội bóng rổ).</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/sl/slam-dunk.json"}