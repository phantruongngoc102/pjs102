onquerors Story - S01E30 - HanSoKieuHung 30","link_embed":"https://vip.opstream12.com/share/f1b824c353b9b2bb1327e0e72a05b6b9","link_m3u8":"https://vip.opstream12.com/20251115/30152_f1b824c3/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim tái hiện giai đoạn lịch sử loạn thế thời cuối Tần, khi Hạng Vũ và Lưu Bang nổi lên như hai anh hùng kiệt xuất, mỗi người mang chí lớn và con đường riêng để tranh đoạt thiên hạ. Hạng Vũ võ dũng vô song nhưng quá trọng tình nghĩa; trong khi Lưu Bang mưu trí, biết dùng người và kiên trì theo đuổi đại nghiệp. Giữa cuộc chiến tranh bá đồ vương, họ phải đối mặt với phản loạn, mưu kế, sự hy sinh của thuộc hạ và những mối tình đầy bi thương. “Sở Hán Kiêu Hùng” khắc họa một cách nhân văn và kịch tính hành trình hình thành nhà Hán, cùng bi kịch định mệnh của hai bậc anh hùng đối nghịch.</p>","tmdb":{"type":"tv","id":"32154","season":1,"vote_average":7.5,"vote_count":2},"modified":"2025-11-16T20:53:11.000Z","cast":["Trịnh Thiếu Thu","Giang Hoa","Trương Khả Di","Melissa Ng Mei-Heng","Lê Diệu Tường","Cerina da Graça","Ram Chiang Chi-Kwong","La Lạc Lâm","Lỗ Chấn Thuận","Vương Tuấn Đường","Kong Hon","Chen Hung-Lieh","Yu Chi-Ming","Ngải Uy","Timothy Cheng Chi-Sing"],"director":["Lee Tim-sing (Lý Thiêm Thăng)"],"cast_meta":[{"name":"Trịnh Thiếu Thu","name_vi":"Trịnh Thiếu Thu","name_original":"Adam Cheng Siu-Chow","tmdb_id":82401,"profile":"https://image.tmdb.org/t/p/w500/KHy7b3kAXP05VGcdsPy3Qf34GM.jpg","tmdb_url":"https://www.themoviedb.org/person/82401"},{"name":"Giang Hoa","name_vi":"Giang Hoa","name_original":"Kwong Wa","tmdb_id":1223075,"profile":"https://image.tmdb.org/t/p/w500/khRCfzElV914ibRTeNECKLwBHXJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1223075"},{"name":"Trương Khả Di","name_vi":"Trương Khả Di","name_original":"Maggie Cheung Ho-Yee","tmdb_id":125882,"profile":"https://image.tmdb.org/t/p/w500/2c4ILgnK12OMAGnLA9DhjwA93ko.jpg","tmdb_url":"https://www.themoviedb.org/person/125882"},{"name":"Melissa Ng Mei-Heng","