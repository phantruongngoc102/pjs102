346c8eab253450c0b3f19020048c427b","link_m3u8":"https://vip.opstream13.com/20251108/17592_346c8eab/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/c4e21b9d9df296ee17ddab3dbbc851f5","link_m3u8":"https://vip.opstream13.com/20251108/17593_c4e21b9d/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/a0e9cab17a035c5ad4c817c25188e195","link_m3u8":"https://vip.opstream13.com/20251108/17594_a0e9cab1/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream13.com/share/8efa2947340ebba3304c9a0374a037e7","link_m3u8":"https://vip.opstream13.com/20251108/17595_8efa2947/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream13.com/share/b86b8c4fa6f55a31dd1964bd374d654f","link_m3u8":"https://vip.opstream13.com/20251108/17596_b86b8c4f/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream13.com/share/07844316ab7bf7fb3e3378086ddd2ac5","link_m3u8":"https://vip.opstream13.com/20251108/17597_07844316/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream13.com/share/ed8b48e1c4539c20a31939ea517e043a","link_m3u8":"https://vip.opstream13.com/20251108/17598_ed8b48e1/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream13.com/share/ae64862963de122e67bd777f85f5bfb9","link_m3u8":"https://vip.opstream13.com/20251108/17599_ae648629/index.m3u8"}]}],"description":"<p>Trong một sự cố bất ngờ, Bạch Sùng Thực (do Âu Dương Chấn Hoa thủ vai) gặp Cái Anh Tĩnh (do Đường Tỏa Vân thủ vai), con gái của một nhân vật nổi tiếng trong ngành điện ảnh, Cái Lan. Do một số hiểu lầm giữa họ, họ đã có một cuộc gặp gỡ khá khó chịu. Bạch Sùng Thực thầm nuôi dưỡng tình cảm với chủ quán trà, Cố Chấn Thanh (do Trần Quốc Bành thủ vai), nhưng anh chọn cách chôn chặt tình cảm chân thành này sâu trong tim. Lam Quang Xương (do Tạ Thiên Hoa thủ vai) là một người dẫn chương trình thiếu nhi luôn mơ ước trở thành một ngôi sao điện ảnh. Tuy nhiên, xét theo hoàn cảnh hiện tại, có vẻ như giấc mơ của anh vẫn còn rất xa vời. Cái Lan nhìn thấy tiềm năng lớn ở Lam Quang Xương và ký hợp đồng với anh, hứa sẽ giúp anh trở thành ngôi sao. Thật không may, ngay sau khi hợp đồng được ký kết, Cái Lan đột ngột qua đời. Bất lực, Lam Quang Xương không còn cách nào khác ngoài việc đặt hy vọng thành công của mình vào Cái Anh Tĩnh.</p>","tmdb_id":109121,"cast":["Âu Dương Chấn Hoa","Đặng Tụy Văn","Tạ Thiên Hoa","Quảng Văn Tuân","Louis Yuen Siu-Cheung","Thang Doanh Doanh","Trần Quốc Bang","Uyển Quỳnh Đan","La Quân Tả","Leung Wing-Lam","Kong Hon","Pak Yan","Brianna Chan","Bowie Wu","Johnny Ngan"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"109121","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Đặng Tụy Văn","name_vi":"Đặng Tụy Văn","name_original":"Sheren Tang Shui-Man","tmdb_id":997296,"profile":"https://image.tmdb.org/t/p/w500/sJ9nrY567ikJ4c2T5wxxuVTB9Ft.jpg","tmdb_url":"https://www.themoviedb.org/person/997296"},{"name":"Tạ Thiên Hoa","name_vi":"Tạ Thiên Hoa","name_original":"Michael Tse Tin-Wah","tmdb_id":21912,"profile":"https://image.tmdb.org/t/p/w500/pOrspTGCQNIkZLOSklMgEVK7yU8.jpg","tmdb_url":"https://www.themoviedb.org/person/21912"},{"name":"Quảng Văn Tuân","name_vi":"Quảng Văn Tuân","name_original":"May Kwong Man-Chun","tmdb_id":1614092,"profile":"https://image.tmdb.org/t/p/w500/AmRPGtd3QDCAPZ4m4eeUQtnRLo3.jpg","tmdb_url":"https://www.themoviedb.org/person/1614092"},{"name":"Louis Yuen Siu-Cheung","name_vi":null,"name_original":"Louis Yuen Siu-Cheung","tmdb_id":579496,"profile":"https://image.tmdb.org/t/p/w500/9Ws35BMwo00MUOI53vCaLPhAdZ.jpg","tmdb_url":"https://www.themoviedb.org/person/579496"},{"name":"Thang Doanh Doanh","name_vi":"Thang Doanh Doanh","name_original":"Angela To