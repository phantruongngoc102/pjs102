m11.com/share/694d7355190adf16029c39d3cfd83e1b","link_m3u8":"https://vip.opstream11.com/20220704/34268_3a41022a/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/8e175535ca639d6fec9225e79dbf7699","link_m3u8":"https://vip.opstream11.com/20220704/34269_85ab3e5e/index.m3u8"}]}],"description":"<p>Chu Nguyên Chương truyền vị cho Doãn Văn, nhưng di chiếu lại biến mất một cách bí ẩn. Trong lúc điều tra tông tích của di chiếu, Ngạo Tiếu Phong đã quen biết mưu thần của Chu Đệ là Mã Tam Bảo. Tuy xuất thân có khác biệt nhưng cả hai vô cùng tán thưởng tài năng của đối phương. Về sau Tiếu Phong mất trí nhớ, sinh ra nghi ngờ với mọi người, chỉ cảm thấy thân quen với Tam Bảo và Chu Đệ. Về phần Chu Anh, cô luôn nghi ngờ Tiếu Phong có mưu đồ khác. Trong hành động tiêu diệt Chu Đệ, Tiếu Phong rơi vào hoàn cảnh vừa căm phẫn, vừa tự trách...</p>","tmdb_id":32467,"cast":["Trần Triển Bằng","Kate Tsui Tsz-Shan","Trần Kiện Phong","Lưu Gia Huy","Tạ Thiên Hoa","Trần Sơn Thông","Joe Ma Tak-Chung","Elanne Kwong Yeuk-Lam","Lưu Giang","Kaki Leung","Sire Ma","Viên Vỹ Hào","Carlo Ng Ka-Lok","Lý Gia Thanh","Ngải Uy"],"director":["Huỳnh Vĩ Thanh"],"keywords":[],"tmdb":{"type":"tv","id":"32467","season":1,"vote_average":1,"vote_count":1},"cast_meta":[{"name":"Trần Triển Bằng","name_vi":"Trần Triển Bằng","name_original":"Ruco Chan","tmdb_id":1238985,"profile":"https://image.tmdb.org/t/p/w500/jD9jx5wiF3Y0XYzvcCNC2oRBrvT.jpg","tmdb_url":"https://www.themoviedb.org/person/1238985"},{"name":"Kate Tsui Tsz-Shan","name_vi":null,"name_original":"Kate Tsui Tsz-Shan","tmdb_id":131256,"profile":"https://image.tmdb.org/t/p/w500/d1YkPN0x4o46Jz7ws5WowWgOoW8.jpg","tmdb_url":"https://www.themoviedb.org/person/131256"},{"name":"Trần Kiện Phong","name_vi":"Trần Kiện Phong","name_original":"Sammul Chan","tmdb_id":1222624,"profile":"https://image.tmdb.org/t/p/w500/emuTVeFoAewmALU0EVzpDxk3dEn.jpg","tmdb_url":"https://www.themoviedb.org/person/1222624"},{"name":"Lưu Gia Huy","name_vi":"L