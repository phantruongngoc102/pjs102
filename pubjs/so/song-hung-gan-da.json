p.opstream17.com/share/a20806b3c15ea015afefcf7e0800e978","link_m3u8":"https://vip.opstream17.com/20240726/15697_aa8d5d4e/index.m3u8"},{"name":"16","slug":"16","filename":"Song Hung Gan Da_16","link_embed":"https://vip.opstream17.com/share/1bdb197430d132e1c98805deb596caf2","link_m3u8":"https://vip.opstream17.com/20240726/15698_d44c55b0/index.m3u8"},{"name":"17","slug":"17","filename":"Song Hung Gan Da_17","link_embed":"https://vip.opstream17.com/share/bd78d16ede6ce1fbdfc2a648c943af72","link_m3u8":"https://vip.opstream17.com/20240726/15699_480f3c0c/index.m3u8"},{"name":"18","slug":"18","filename":"Song Hung Gan Da_18","link_embed":"https://vip.opstream17.com/share/beb6904ef6823ca532299ff3c4eee53f","link_m3u8":"https://vip.opstream17.com/20240726/15700_0d4ec0be/index.m3u8"},{"name":"19","slug":"19","filename":"Song Hung Gan Da_19","link_embed":"https://vip.opstream17.com/share/01cc1da1d5e00d6c7fb60943b4b03f68","link_m3u8":"https://vip.opstream17.com/20240726/15701_df3e080b/index.m3u8"},{"name":"20","slug":"20","filename":"Song Hung Gan Da_20.end","link_embed":"https://vip.opstream17.com/share/f1b6fac213a8baf8b794720639965fde","link_m3u8":"https://vip.opstream17.com/20240726/15702_a8a9b9ce/index.m3u8"}]}],"time":"43 phút/tập","description":"<p><i>Mười mấy năm về trước, cha của chị em Đổng Lam và Đổng Phi - một danh y tài giỏi - đã vướng phải trọng tội vì làm chết Âu Dương phu nhân trong lúc chữa trị. May thay, mẹ con Đổng Lam trốn thoát đến Đào Hoa Thôn hẻo lánh, sống cuộc đời mai danh ẩn tích. Cùng lúc đó, trên giang hồ thường xuyên xảy ra nhiều vụ cướp của giết người nguy hiểm do bọn \"Ngũ quỷ Thương Châu\" gây ra. Suốt mười mấy năm trời, quan phủ không hề bắt được bọn chúng và cũng chẳng điều tra được bọn chúng thật sự là ai? Từ nhỏ, Đổng Lam đã siêng năng, cần mẫn. Cô học được y thuật của cha và cả võ công của mẹ. Bây giờ, mỗi khi ra ngoài, cô thường cải nam trang và bắt Đổng Phi phải gọi cô là sư huynh để che dấu thân phận...</i></p>","tmdb":{"type":"tv","id":"109345","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-02T11:19:05.000Z","cast":["Ngô Trác Hy","Trần Kiện Phong","Mandy Lee Cho","Joyce Koi","Louisa So Yuk-Wah","Quách Phong","Savio Tsang","Nguyên Hoa","La Mãng","Angelina Lo","Ko Cheun-Man","Rachel Kan","La Quân Tả","Lau Gwai-Fong","Tăng Huệ Vân"],"director":["Lương Tài Viễn"],"cast_meta":[{"name":"Ngô Trác Hy","name_vi":"Ngô Trác Hy","name_original":"Ron Ng Cheuk-Hai","tmdb_id":1222249,"profile":"https://image.tmdb.org/t/p/w500/rhT0EL5LYYLZIyS3Aax6MakEE9e.jpg","tmdb_url":"https://www.themoviedb.org/person/1222249"},{"name":"Trần Kiện Phong","name_vi":"Trần Kiện Phong","name_original":"Sammul Chan","tmdb_id":1222624,"profile":"https://image.tmdb.org/t/p/w500/emuTVeFoAewmALU0EVzpDxk3dEn.jpg","tmdb_url":"https://www.themoviedb.org/person/1222624"},{"name":"Mandy Lee Cho","name_vi":null,"name_original":"Mandy Lee Cho","tmdb_id":4021841,"profile":"https://image.tmdb.org/t/p/w500/jmxqZQhtTVMXcCgnaFfu8PUwDQO.jpg","tmdb_url":"https://www.themoviedb.org/person/4021841"},{"name":"Joyce Koi","name_vi":null,"name_original":"Joyce Koi","tmdb_id":3051642,"profile":"https://image.tmdb.org/t/p/w500/zec8ktadcxH43X8DcrVpUIpTZ0Q.jpg","tmdb_url":"https://www.themoviedb.org/person/3051642"},{"name":"Louisa So Yuk-Wah","name_vi":null,"name_original":"Louisa So Yuk-Wah","tmdb_id":1222763,"profile":"https://image.tmdb.org/t/p/w500/AvNFl6AxHBSnKZ5zJnxn2P5AU4b.jpg","tmdb_url":"https://www.themoviedb.org/person/1222763"},{"name":"Quách Phong","name_vi":"Quách Phong","name_original":"Samuel Kwok Fung","tmdb_id":1416065,"profile":"https://image.tmdb.org/t/p/w500/ZsCpOKqMKARlOrjonsKW8CQQ6P.jpg","tmdb_url":"https://www.themoviedb.org/person/1416065"},{"name":"Savio Tsang","name_vi":null,"name_original":"Savio Tsang","tmdb_id":2064581,"profile":"https://image.tmdb.org/t/p/w500/7CMEmbU2Oet4xD2r7iPGW7eGFAO.jpg","tmdb_url":"https://www.themoviedb.org/person/2064581"},{"name":"Nguyên Hoa","name_vi":"Nguyên Hoa","name_original":"Yuen Wah"