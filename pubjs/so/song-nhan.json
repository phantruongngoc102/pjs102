ông Thương Khâm, chủ tịch Tập đoàn Tử Tinh.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"297239","season":1,"vote_average":8,"vote_count":2},"modified":"2025-08-24T11:36:20.000Z","cast":["Zhang Jijun","Ma Xiaoyu","Zhou Zixin","Yu Qian","Kevin Tan","Zhao Yi","Cong Xin"],"director":[],"cast_meta":[{"name":"Zhang Jijun","name_vi":null,"name_original":"Zhang Jijun","tmdb_id":2735559,"profile":"https://image.tmdb.org/t/p/w500/tHJYpHnpy6K6ud6hybCKjcmMw4M.jpg","tmdb_url":"https://www.themoviedb.org/person/2735559"},{"name":"Ma Xiaoyu","name_vi":null,"name_original":"Ma Xiaoyu","tmdb_id":4902977,"profile":"https://image.tmdb.org/t/p/w500/wsmszBdb7KzWQ0ZMGNhJuU5VvAZ.jpg","tmdb_url":"https://www.themoviedb.org/person/4902977"},{"name":"Zhou Zixin","name_vi":null,"name_original":"Zhou Zixin","tmdb_id":4394383,"profile":"https://image.tmdb.org/t/p/w500/2Z1sv1uyyym3NL0PcfPrWffzjai.jpg","tmdb_url":"https://www.themoviedb.org/person/4394383"},{"name":"Yu Qian","name_vi":null,"name_original":"Yu Qian","tmdb_id":5122880,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5122880"},{"name":"Kevin Tan","name_vi":null,"name_original":"Kevin Tan","tmdb_id":5113093,"profile":"https://image.tmdb.org/t/p/w500/4F1w3ogduHFwjZiFB6oeRF3qdGG.jpg","tmdb_url":"https://www.themoviedb.org/person/5113093"},{"name":"Zhao Yi","name_vi":null,"name_original":"Zhao Yi","tmdb_id":4993681,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4993681"},{"name":"Cong Xin","name_vi":null,"name_original":"Cong Xin","tmdb_id":5599197,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5599197"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/so/song-nhan.json"}