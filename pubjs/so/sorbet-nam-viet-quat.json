s://vip.opstream10.com/share/fb77fa236d1bb1ce3973d53b8576c3eb","link_m3u8":"https://vip.opstream10.com/20250909/30364_fb77fa23/index.m3u8"},{"name":"102","slug":"102","filename":"Nam Việt Quất - Tập 102","link_embed":"https://vip.opstream10.com/share/c8305bd51c307acac524d4db1358f39a","link_m3u8":"https://vip.opstream10.com/20250909/30368_c8305bd5/index.m3u8"},{"name":"103","slug":"103","filename":"Nam Việt Quất - Tập 103 (END)","link_embed":"https://vip.opstream10.com/share/9dff4e9a3dd78f2c4cfb49ea21b086f2","link_m3u8":"https://vip.opstream10.com/20250909/30369_9dff4e9a/index.m3u8"}]}],"time":"2h/tập","description":"<p>Kıvılcım (Evrim Alasya), một phụ nữ có học thức, thực tế và hiện đại, đã đứng vững sau khi ly hôn với chồng và nuôi dạy cả hai cô con gái theo những giá trị mà cô tin tưởng. Cô con gái út Çimen (Selin Türkmen) vẫn đang học trung học, trong khi cô con gái lớn Doğa (Sıla Türkoğlu) đang học nha khoa tại trường đại học. Mong muốn duy nhất của Kıvılcım là được nhìn thấy các con của mình thành công và hạnh phúc trong tương lai. Kıvılcım, người đã rất thất vọng khi Doğa kết hôn với bạn trai vào năm nhất đại học, đã trải qua cú sốc đầu đời khi con gái gặp gia đình chồng. Gia đình của chồng Doğa là Fatih (Doğukan Güngör) là một gia đình bảo thủ. Cô cho rằng con gái mình không thể sống với một gia đình có cái nhìn khác về cuộc sống như vậy. Nature tin rằng tình yêu của họ sẽ vượt qua mọi khác biệt. Đó là một câu chuyện tình yêu giữa hai gia đình cực đoan với cùng một sự thật nhưng cách thức khác nhau.</p>","tmdb":{"type":"tv","id":"213194","season":1,"vote_average":6.7,"vote_count":18},"modified":"2025-09-09T16:10:39.000Z","cast":["Evrim Alasya","Barış Kılıç","Ahmet Mümtaz Taylan","Emre Dinler","Ceren Yalazoğlu Karakoç","Aliye Uzunatağan","Feyza Civelek","Selin Türkmen","Erkan Avcı","Özge Borak","Seray Kaya","Yalçın Hafızoğlu","Özlem Çakar","Zeynep Parla","Hamdi Alkan"],"director":["Ketche"],"cast_meta":[{"name":"Evrim Alasya","name_vi":null,"name_original":"Evrim Alasya","tmdb_id":1522693,"profile":"https://image.tmdb.org/t/p/w500/q3DS5KwZ0vtxZxtQiM0pAIMgKjm.jpg","tmdb_url":"https://www.themoviedb.org/person/1522693"},{"name":"Barış Kılıç","name_vi":null,"name_original":"Barış Kılıç","tmdb_id":1533989,"profile":"https://image.tmdb.org/t/p/w500/2V4rYLRwEdUJkuHSW232TAJaqb5.jpg","tmdb_url":"https://www.themoviedb.org/person/1533989"},{"name":"Ahmet Mümtaz Taylan","name_vi":null,"name_original":"Ahmet Mümtaz Taylan","tmdb_id":230759,"profile":"https://image.tmdb.org/t/p/w500/7BcirImyPmuD8PxMVKPx6xefunW.jpg","tmdb_url":"https://www.themoviedb.org/person/230759"},{"name":"Emre Dinler","name_vi":null,"name_original":"Emre Dinler","tmdb_id":2869822,"profile":"https://image.tmdb.org/t/p/w500/4tQ6jB1N6XGeZDNVe8XzrZGyOiR.jpg","tmdb_url":"https://www.themoviedb.org/person/2869822"},{"name":"Ceren Yalazoğlu Karakoç","name_vi":null,"name_original":"Ceren Yalazoğlu Karakoç","tmdb_id":3225091,"profile":"https://image.tmdb.org/t/p/w500/fSOg6yGlwUipKLm9slAPXh0LlXo.jpg","tmdb_url":"https://www.themoviedb.org/person/3225091"},{"name":"Aliye Uzunatağan","name_vi":null,"name_original":"Aliye Uzunatağan","tmdb_id":1672905,"profile":"https://image.tmdb.org/t/p/w500/rrDB7El5o4KsNEGBEikueZIJbYG.jpg","tmdb_url":"https://www.themoviedb.org/person/1672905"},{"name":"Feyza Civelek","name_vi":null,"name_original":"Feyza Civelek","tmdb_id":2135960,"profile":"https://image.tmdb.org/t/p/w500/cIgVH7Qk0PMypnsBl1VyLJfZ5Vm.jpg","tmdb_url":"https://www.themoviedb.org/person/2135960"},{"name":"Selin Türkmen","name_vi":null,"name_original":"Selin Türkmen","tmdb_id":3993774,"profile":"https://image.tmdb.org/t/p/w500/zv3SMqxYZ9OG2amqJv2nASgkcAl.jpg","tmdb_url":"https://www.themoviedb.org/person/3993774"},{"name":"Erkan Avcı","name_vi":null,"name_original":"Erkan Avcı","tmdb_id":1052797,"profile":"https://image.tmdb.org/t/p/w500/2SQBu38Hx4Yx2PM7OdKgbdz5UCd.jpg","tmdb_url":"https://www.themoviedb.org/person/1052797"},{"name":"Özge Borak","name_vi":null,"name_origin