m10.com/20250815/30172_df624627/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream10.com/share/e2fd3d57e43d80a5df90a90a0da3bbf8","link_m3u8":"https://vip.opstream10.com/20250821/30228_e2fd3d57/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/a0318d32cb96f76323313e33d189b3ce","link_m3u8":"https://vip.opstream10.com/20250828/30272_a0318d32/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/94523b739a6ddbf7bb7d7d6c2a01bb96","link_m3u8":"https://vip.opstream10.com/20250904/30318_94523b73/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/ecc0ce00c4f2fe640cf948dc3ced7490","link_m3u8":"https://vip.opstream10.com/20250912/30398_ecc0ce00/index.m3u8"}]}],"description":"<p>\"Star Trek: Strange New Worlds\" mùa 3 tiếp tục theo chân phi hành đoàn tàu Enterprise trong hành trình khám phá các hành tinh mới, &nbsp;văn minh mới, và những thử thách cá nhân lẫn tập thể.<br>Mùa này mở đầu bằng phần kết của cao trào mùa trước, xoay quanh cuộc đối đầu căng thẳng với loài Gorn – một trong những hiểm họa lớn nhất cả đội ngũ từng đối mặt.&nbsp;<br>Bên cạnh yếu tố hành động, các cảnh chiến đấu vũ trụ và đề cao tinh thần đoàn kết được giới phê bình đánh giá là \"chất lượng điện ảnh\" cao, đáng thưởng thức trên màn ảnh rộng, phim còn mở rộng chiều sâu tâm lý nhân vật, đặc biệt trong các mối quan hệ như Spock – Chapel hay nội tâm của La’An.<br>Tổng thể, Strange New Worlds mùa 3 tiếp tục giữ vững tinh thần phiêu lưu cổ điển của Star Trek, &nbsp;đồng thời thử nghiệm với phong cách hiện đại, linh hoạt. &nbsp;Đây là lựa chọn phù hợp cho cả người hâm mộ lâu năm lẫn người mới bắt đầu muốn khám phá một trong những thương hiệu khoa học viễn tưởng lâu đời nhất thế giới.</p>","tmdb_id":103516,"cast":["Anson Mount","Ethan Peck","Jess Bush","Christina Chong","Celia Rose Gooding","Melissa Navia","Babs Olusanmokun","Martin Quinn","Rebecca Romijn"],"director":[],"keywords":[],"tmdb":{"type"