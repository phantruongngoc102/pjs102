.com/share/b785fe761717406e701b2a6d6dd4c9fb","link_m3u8":"https://vip.opstream16.com/20240108/40437_e8186e88/index.m3u8"},{"name":"04","slug":"04","link_embed":"https://vip.opstream16.com/share/c70542557778b1a76add4309be29e678","link_m3u8":"https://vip.opstream16.com/20240108/40436_be7e9980/index.m3u8"},{"name":"03","slug":"03","link_embed":"https://vip.opstream16.com/share/a03422c987126467d665a90315a33f20","link_m3u8":"https://vip.opstream16.com/20240108/40435_0476e80e/index.m3u8"},{"name":"02","slug":"02","link_embed":"https://vip.opstream16.com/share/41c3edcf6af07a5578bdb68b05c67564","link_m3u8":"https://vip.opstream16.com/20240108/40434_75f87d4a/index.m3u8"},{"name":"01","slug":"01","link_embed":"https://vip.opstream16.com/share/b9f15066c52a605f37bb90fe5dffbd6d","link_m3u8":"https://vip.opstream16.com/20240108/40433_e1663024/index.m3u8"}]}],"description":"<p>Sự chuyển mình hoa lệ thuộc thể loại phim bo hong kong hấp dẫn có nội dung nói về sau khi hồi phục từ 1 căn bệnh, ca sĩ Hoa Phương Ngưng nhận ra cuộc sống mình không trọn vẹn. Trải qua hai cuộc hôn nhân và có 3 người con, Hoa Phương Ngưng cảm thấy bản thân thật sự cô đơn. Lấy hết can đảm, Phương Ngưng bay đến Đài Loan để hàn gắn quan hệ với con gái lớn của chị-Phan Nam Tư . Tại Đài Loan, Phương Ngưng đã gặp được nhiếp ảnh gia La Bân Hán , hiện đang ở Đài Loan thăm quê hương của người vợ đã qua đời của anh-Minh Hà Được Bân Hán khuyến khích, Hoa Phương Ngưng quyết định thực hiện concert cuối cùng trong sự nghiệp để hát cho bạn bè và gia đình, tuy nhiên con gái nhỏ-Đường Hân (Sầm Lệ Hương) không mảy may quan tâm chuyện này….</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/su/su-chuyen-minh-hoa-le.json"}