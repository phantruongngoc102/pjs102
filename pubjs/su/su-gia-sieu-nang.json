u8"}]}],"time":"45 phút/tập","description":"<p>Ba người không quen biết xui xẻo gặp tai nạn thảm khốc cùng với nhau. Nhưng thần kỳ là họ không chết, mà sau tai nạn đó nhóm người còn bộc lộ năng lực siêu cường. Có người có khả năng ngưng đọng thời gian, người lại có thể trị liệu, người khác thì mình đồng da sắt. Kể từ đó, nhóm người vốn chẳng quen biết lại gắn kết với nhau theo cách đặc biệt nhất.</p><p><br>&nbsp;</p>","tmdb":{"type":"tv","id":"213236","season":1,"vote_average":7,"vote_count":3},"modified":"2025-04-13T10:38:28.000Z","cast":["Natalie Tong","Trần Triển Bằng","Grace Wong","Trần Sơn Thông","Lưu Dĩnh Tuyền","Lâm Tử Thiện","Sammy Sum Chun-Hin","Lưu Bội Nguyệt","Trương Quốc Cường","Kelly Ng","Âu Thụy Vỹ"],"director":["Đang cập nhật."],"cast_meta":[{"name":"Natalie Tong","name_vi":null,"name_original":"Natalie Tong","tmdb_id":1237978,"profile":"https://image.tmdb.org/t/p/w500/jZHpp0BOnVW3M0NqH3TVpj0oGo6.jpg","tmdb_url":"https://www.themoviedb.org/person/1237978"},{"name":"Trần Triển Bằng","name_vi":"Trần Triển Bằng","name_original":"Ruco Chan","tmdb_id":1238985,"profile":"https://image.tmdb.org/t/p/w500/jD9jx5wiF3Y0XYzvcCNC2oRBrvT.jpg","tmdb_url":"https://www.themoviedb.org/person/1238985"},{"name":"Grace Wong","name_vi":null,"name_original":"Grace Wong","tmdb_id":1255467,"profile":"https://image.tmdb.org/t/p/w500/2PsYpSJsnof2I7ncBMhd4m1hWta.jpg","tmdb_url":"https://www.themoviedb.org/person/1255467"},{"name":"Trần Sơn Thông","name_vi":"Trần Sơn Thông","name_original":"Joel Chan","tmdb_id":1218777,"profile":"https://image.tmdb.org/t/p/w500/sBVL7GLD2K6UF9FkzhamMMopyjn.jpg","tmdb_url":"https://www.themoviedb.org/person/1218777"},{"name":"Lưu Dĩnh Tuyền","name_vi":"Lưu Dĩnh Tuyền","name_original":"Tiffany Lau","tmdb_id":2858847,"profile":"https://image.tmdb.org/t/p/w500/po1xFwhloEw04VM0QJs09JAtal4.jpg","tmdb_url":"https://www.themoviedb.org/person/2858847"},{"name":"Lâm Tử Thiện","name_vi":"Lâm Tử Thiện","name_original":"Jazz Lam Tsz-Sin","tmdb_id":1132933,"pro