":1,"vote_average":0,"vote_count":0},"modified":"2025-03-09T07:18:33.000Z","cast":["Bai Xuhan","Fan Yining","Pan Xiaoxue","Zhu Chenhao","Hong Yutong","Yan Yaying"],"director":[],"cast_meta":[{"name":"Bai Xuhan","name_vi":null,"name_original":"Bai Xuhan","tmdb_id":4781229,"profile":"https://image.tmdb.org/t/p/w500/avWNVSQRl3qx7YiYBpzw0RU9Uod.jpg","tmdb_url":"https://www.themoviedb.org/person/4781229"},{"name":"Fan Yining","name_vi":null,"name_original":"Fan Yining","tmdb_id":3361158,"profile":"https://image.tmdb.org/t/p/w500/i4XWRax2XHRKnZArfctoJVtAMdI.jpg","tmdb_url":"https://www.themoviedb.org/person/3361158"},{"name":"Pan Xiaoxue","name_vi":null,"name_original":"Pan Xiaoxue","tmdb_id":4859554,"profile":"https://image.tmdb.org/t/p/w500/78P6KKVx6jGwh7FgD8MRcMKbTPw.jpg","tmdb_url":"https://www.themoviedb.org/person/4859554"},{"name":"Zhu Chenhao","name_vi":null,"name_original":"Zhu Chenhao","tmdb_id":4310714,"profile":"https://image.tmdb.org/t/p/w500/aB3iJe5yAlWAgKWcqyLmhLp954L.jpg","tmdb_url":"https://www.themoviedb.org/person/4310714"},{"name":"Hong Yutong","name_vi":null,"name_original":"Hong Yutong","tmdb_id":5273221,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5273221"},{"name":"Yan Yaying","name_vi":null,"name_original":"Yan Yaying","tmdb_id":5273222,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5273222"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/su/su-giac-ngo-cua-ba-noi-tro.json"}