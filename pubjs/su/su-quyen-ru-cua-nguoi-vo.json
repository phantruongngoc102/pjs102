//vip.opstream15.com/20221201/29068_83f3a06c/index.m3u8"},{"name":"126","slug":"126","filename":"su-quyen-ru-cua-nguoi-vo--eps-tap-126","link_embed":"https://vip.opstream15.com/share/ec4ecf2f2dc2d3314c1d4cbd433b632b","link_m3u8":"https://vip.opstream15.com/20221201/29069_b154050b/index.m3u8"},{"name":"127","slug":"127","filename":"su-quyen-ru-cua-nguoi-vo--eps-tap-127","link_embed":"https://vip.opstream15.com/share/b76f4e72625e1782dd4758a45cbc1cd6","link_m3u8":"https://vip.opstream15.com/20221201/29070_8dbcceab/index.m3u8"},{"name":"128","slug":"128","filename":"su-quyen-ru-cua-nguoi-vo--eps-tap-128","link_embed":"https://vip.opstream15.com/share/ba9353718aa3b1793b8a23d51e19ef15","link_m3u8":"https://vip.opstream15.com/20221201/29071_c6d3a62c/index.m3u8"},{"name":"129","slug":"129","filename":"su-quyen-ru-cua-nguoi-vo--eps-tap-129","link_embed":"https://vip.opstream15.com/share/ed5b4ad21f1090dc8bde85374a049f63","link_m3u8":"https://vip.opstream15.com/20221201/29072_beb3d68a/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>Xoay quanh cuộc sống đau khổ của nữ chính Goo Eun Jae (Jang Seo Hee đóng), người tốt nghiệp ngành trang điểm và luôn mơ ước trở thành chuyên gia làm đẹp. Cô phải tạm gác lại giấc mơ du học Pháp sau khi có thai với bạn trai Jung Gyo Bin (Byun Woo Min đóng) và kết hôn với anh này. Cuộc sống hôn nhân của Eun Jae sớm trở thành địa ngục khi cô bị sẩy thai và chịu cảnh mẹ chồng hắt hủi. Cùng lúc Eun Jae mang thai lần hai, một người bạn cũ của cô là Shin Ae Ri (Kim Seo Hyung đóng) trở về từ Pháp sau 5 năm xa xứ. Ae Ri là trẻ mồ từ hồi 7 tuổi, từng được bố mẹ Eun Jae cưu mang trong suốt 20 năm và cũng từng là bạn gái của anh trai Eun Jae, Goo Kang Jae (Choi Joon Yong đóng). Gyo Bin công khai ngoại tình với Ae Ri trước mặt Eun Jae, sau đó quyết định bỏ vợ đến với người tình. Đôi tình nhân còn lập mưu đẩy Eun Jae xuống biển để giết cả cô và cái thai trong bụng, với mục đích đoạt được tài sản trong di chúc của cha Gyo Bin, một doanh nhân giàu có. Sau vụ tai nạn, Eun Jae còn sống nhưng mất đi đứa con. Nhiều tháng sau, cô trở lại với khát vọng trả thù. Cô sống dưới tên của một cô gái khác, Min So Hee (Chae Young In đóng), người tự tử cùng ngày cô bị hại.</p>","tmdb":{"type":"tv","id":"18493","season":1,"vote_average":5,"vote_count":8},"modified":"2022-12-01T20:21:05.000Z","cast":["Jang Seo-hee","Byun Woo-min","Kim Seo-hyung","Lee Jae-hwang","Geum Bo-ra","Jung Ae-ri","Yoon Mi-ra"],"director":["Oh Se Kang"],"cast_meta":[{"name":"Jang Seo-hee","name_vi":null,"name_original":"Jang Seo-hee","tmdb_id":582555,"profile":"https://image.tmdb.org/t/p/w500/zxjXig4bOTxPlCvfNPrcRMA4Ixl.jpg","tmdb_url":"https://www.themoviedb.org/person/582555"},{"name":"Byun Woo-min","name_vi":null,"name_original":"Byun Woo-min","tmdb_id":1246953,"profile":"https://image.tmdb.org/t/p/w500/c66Jt6mJMJo8qM92IKmPesIyn6B.jpg","tmdb_url":"https://www.themoviedb.org/person/1246953"},{"name":"Kim Seo-hyung","name_vi":null,"name_original":"Kim Seo-hyung","tmdb_id":127706,"profile":"https://image.tmdb.org/t/p/w500/fiswmVfSLUVxGa6m7McdQXGZo6e.jpg","tmdb_url":"https://www.themoviedb.org/person/127706"},{"name":"Lee Jae-hwang","name_vi":null,"name_original":"Lee Jae-hwang","tmdb_id":1246954,"profile":"https://image.tmdb.org/t/p/w500/fMMJW54QSMogai3FLSH8vPstigH.jpg","tmdb_url":"https://www.themoviedb.org/person/1246954"},{"name":"Geum Bo-ra","name_vi":null,"name_original":"Geum Bo-ra","tmdb_id":1552872,"profile":"https://image.tmdb.org/t/p/w500/xiAF41pRedAw4qoBlXxRljmZ9mN.jpg","tmdb_url":"https://www.themoviedb.org/person/1552872"},{"name":"Jung Ae-ri","name_vi":null,"name_original":"Jung Ae-ri","tmdb_id":1257611,"profile":"https://image.tmdb.org/t/p/w500/e0yP43fpmV73EKYs0HgTQJ5KNP3.jpg","tmdb_url":"https://www.themoviedb.org/person/1257611"},{"name":"Yoon Mi-ra","name_vi":null,"name_original":"Yoon Mi-ra","tmdb_id":1079581,"profile":"https://image.tmdb.org/t/p/w500/72LmlDG7uTKcE3uwbjcNmLmpXRT.jpg","tmdb_url":"https://www.themoviedb.org/person/1079581"}],"keyw