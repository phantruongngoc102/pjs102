/20220502/11339_3fbbb431/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream10.com/share/93fb39474c51b8a82a68413e2a5ae17a","link_m3u8":"https://vip.opstream10.com/20220502/11340_77266b2e/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/9cd6f5566969fea878ff53054851191b","link_m3u8":"https://vip.opstream10.com/20220502/11342_72021a96/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/d7b0a6a743658d17efc4c53c31aa360c","link_m3u8":"https://vip.opstream10.com/20220502/11343_57585586/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/2e87d147292d4f2d0770cbd01562eb35","link_m3u8":"https://vip.opstream10.com/20220502/11344_f1ec51c1/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream10.com/share/11eba2991cc62daa4a85be5c0cfdae97","link_m3u8":"https://vip.opstream10.com/20220502/11347_ef9f32ff/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream10.com/share/00693ceec3aa42db186efa62ed8917d2","link_m3u8":"https://vip.opstream10.com/20220502/11348_eb7c3668/index.m3u8"}]}],"description":"<p>Câu truyện xoay quanh những Hiệp sĩ Pháp thuật – những người có thể sử dụng ma thuật và chiến đấu bằng thứ vũ khí được tạo ra bởi chính linh hồn của họ. Kurogane Ikki đã ghi danh vào học tại một ngôi trường dành cho những người như vậy, nhưng cậu lại bị coi là “một thất bại” hay “Hiệp sĩ tệ nhất” bởi không hề có kỹ năng sử dụng ma thuật. Thế rồi, một ngày nọ, Kurogane đã bị Stella – công chúa đến từ vương quốc khác, và cũng là người có thành tích đứng đầu của học viện – thách đấu. Trong trận đấu tay đôi này, “kẻ thua sẽ phải tuân theo người thắng suốt phần đời còn lại”, và hãy thử đoán xem ai đã chiến thắng?</p>","tmdb_id":67154,"cast":[],"director":[],"keywords":[],"tmdb":{"id":67154},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/su/su-thi-ve-mot-hiep-si-luu-ban.json"}