embed":"https://vip.opstream10.com/share/00693ceec3aa42db186efa62ed8917d2","link_m3u8":"https://vip.opstream10.com/20220502/11348_eb7c3668/index.m3u8"}]}],"time":"25 phút / tập","description":"<p>Câu truyện xoay quanh những Hiệp sĩ Pháp thuật – những người có thể sử dụng ma thuật và chiến đấu bằng thứ vũ khí được tạo ra bởi chính linh hồn của họ. Kurogane Ikki đã ghi danh vào học tại một ngôi trường dành cho những người như vậy, nhưng cậu lại bị coi là “một thất bại” hay “Hiệp sĩ tệ nhất” bởi không hề có kỹ năng sử dụng ma thuật. Thế rồi, một ngày nọ, Kurogane đã bị Stella – công chúa đến từ vương quốc khác, và cũng là người có thành tích đứng đầu của học viện – thách đấu. Trong trận đấu tay đôi này, “kẻ thua sẽ phải tuân theo người thắng suốt phần đời còn lại”, và hãy thử đoán xem ai đã chiến thắng?</p>","tmdb":{"type":"tv","id":"67154","season":1,"vote_average":7,"vote_count":141},"modified":"2023-06-25T19:19:00.000Z","cast":["Ryota Osaka","Shizuka Ishigami","Nao Toyama","Thiển Đầm Tấn Thái Lang","Yu Kobayashi","Hisako Kanemoto","Yoshitsugu Matsuoka","Mao Ichimichi","Megumi Han","Yoko Hikasa","Yoshimasa Hosoya"],"director":["Shin Oonuma"],"cast_meta":[{"name":"Ryota Osaka","name_vi":null,"name_original":"Ryota Osaka","tmdb_id":1324468,"profile":"https://image.tmdb.org/t/p/w500/d2TGy8Qkxe90tGDr9MCXFGkhbPl.jpg","tmdb_url":"https://www.themoviedb.org/person/1324468"},{"name":"Shizuka Ishigami","name_vi":null,"name_original":"Shizuka Ishigami","tmdb_id":1324650,"profile":"https://image.tmdb.org/t/p/w500/kXTYBI7skkVSjQ4eg49iEGblt3f.jpg","tmdb_url":"https://www.themoviedb.org/person/1324650"},{"name":"Nao Toyama","name_vi":null,"name_original":"Nao Toyama","tmdb_id":1168909,"profile":"https://image.tmdb.org/t/p/w500/6WJDd1z946yFfZBgpC7dWi0FyQw.jpg","tmdb_url":"https://www.themoviedb.org/person/1168909"},{"name":"Thiển Đầm Tấn Thái Lang","name_vi":"Thiển Đầm Tấn Thái Lang","name_original":"Shintaro Asanuma","tmdb_id":1247778,"profile":"https://image.tmdb.org/t/p/w500/5D2