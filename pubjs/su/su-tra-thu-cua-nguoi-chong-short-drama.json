khăn.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/su/su-tra-thu-cua-nguoi-chong-short-drama.json"}