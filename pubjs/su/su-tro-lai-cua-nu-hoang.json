:"https://vip.opstream13.com/share/1b742ae215adf18b75449c6e272fd92d","link_m3u8":"https://vip.opstream13.com/20250917/8106_1b742ae2/index.m3u8"},{"name":"24","slug":"24","filename":"Sự Trở Lại Của Nữ Hoàng - Tập 24---2025","link_embed":"https://vip.opstream13.com/share/7706d2dc2da6837340effd985dc620b6","link_m3u8":"https://vip.opstream13.com/20250917/8107_7706d2dc/index.m3u8"}]}],"time":"30 phút/tập","description":"Thừa kế của Tập đoàn Vân Hải, Từ Hải Mộng, kết hôn với trưởng tử của gia tộc Lộ. Sau khi cưới, hai vợ chồng lên đường đi hưởng tuần trăng mật ở nước ngoài, nhưng họ bất ngờ gặp phải tai nạn và chết đuối. Vào ngày tổ chức cuộc họp cổ đông của Tập đoàn Vân Hải, Từ Hải Mộng đột ngột quay trở lại, không chỉ phục sinh từ cõi chết mà còn mạnh mẽ xoay chuyển tình thế, chiếm lại quyền lực và giành lại Tập đoàn Vân Hải. Nhà họ Lộ vì sự kiện này mà trở mặt với Từ Hải Mộng, và cậu hai nhà họ Lộ Tư Vũ đối đầu từng bước một với cô, từ việc tìm hiểu thân phận thật sự đến nguyên nhân cái chết của anh trai. Sau nhiều lần đối đầu, dưới sự đan xen nguy hiểm của sự thật và kẻ sát nhân, Lộ Tư Du cuối cùng cũng khám phá ra sự thật về “tuần trăng mật chết chóc” — Từ Hải Mộng chính là người bị anh trai đẩy xuống vách núi, sống sót qua bao lần hiểm nguy, chỉ để đấu tranh giành lấy sự sống.","tmdb":{"type":"tv","id":"297519","season":1,"vote_average":6.667,"vote_count":3},"modified":"2025-09-17T11:44:02.000Z","cast":["Trương Nghệ Thượng","Ngô Tuấn Đình","Lương Tịnh Nhàn","Qu Yicheng","Zhang Yao","Li Zhifan"],"director":[],"cast_meta":[{"name":"Trương Nghệ Thượng","name_vi":"Trương Nghệ Thượng","name_original":"Zhang Yishang","tmdb_id":1764456,"profile":"https://image.tmdb.org/t/p/w500/eQifkkjJwicLVJOihYZyq0TcnUy.jpg","tmdb_url":"https://www.themoviedb.org/person/1764456"},{"name":"Ngô Tuấn Đình","name_vi":"Ngô Tuấn Đình","name_original":"Wu Junting","tmdb_id":3190369,"profile":"https://image.tmdb.org/t/p/w500/9B93eIghSmcbTWU59dUJqqWj7wv.jpg","tmdb_url":"https://www.the