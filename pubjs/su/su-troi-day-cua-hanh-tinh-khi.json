an và thoát khỏi thánh đường - đặt người đàn ông và vượn trên một khóa học va chạm có thể thay đổi hành tinh mãi mãi.</p>","tmdb":{"type":"movie","id":"61791","season":null,"vote_average":7.339,"vote_count":12520},"modified":"2024-10-08T10:10:29.000Z","cast":["Andy Serkis","James Franco","Freida Pinto","John Lithgow","Brian Cox","Tom Felton","Tyler Labine","Karin Konoval","Terry Notary","Christopher Gordon","Richard Ridings","Devyn Dalton","Jay Caputo","David Hewlett","David Oyelowo"],"director":["Rupert Wyatt"],"cast_meta":[{"name":"Andy Serkis","name_vi":null,"name_original":"Andy Serkis","tmdb_id":1333,"profile":"https://image.tmdb.org/t/p/w500/eNGqhebQ4cDssjVeNFrKtUvweV5.jpg","tmdb_url":"https://www.themoviedb.org/person/1333"},{"name":"James Franco","name_vi":null,"name_original":"James Franco","tmdb_id":17051,"profile":"https://image.tmdb.org/t/p/w500/bjmAntHGiibLZixH8nTNVBzaFQn.jpg","tmdb_url":"https://www.themoviedb.org/person/17051"},{"name":"Freida Pinto","name_vi":null,"name_original":"Freida Pinto","tmdb_id":76792,"profile":"https://image.tmdb.org/t/p/w500/tub18dfDNMxlempVIuPXh8fmZVs.jpg","tmdb_url":"https://www.themoviedb.org/person/76792"},{"name":"John Lithgow","name_vi":null,"name_original":"John Lithgow","tmdb_id":12074,"profile":"https://image.tmdb.org/t/p/w500/ajfuBSm1HuVqFJlbTmAlza62Xxr.jpg","tmdb_url":"https://www.themoviedb.org/person/12074"},{"name":"Brian Cox","name_vi":null,"name_original":"Brian Cox","tmdb_id":1248,"profile":"https://image.tmdb.org/t/p/w500/scSjbFCTRngXlkJRoKptM5kQGw7.jpg","tmdb_url":"https://www.themoviedb.org/person/1248"},{"name":"Tom Felton","name_vi":null,"name_original":"Tom Felton","tmdb_id":10993,"profile":"https://image.tmdb.org/t/p/w500/etmtUBzJ1i1XJTLS6MkotJFE1se.jpg","tmdb_url":"https://www.themoviedb.org/person/10993"},{"name":"Tyler Labine","name_vi":null,"name_original":"Tyler Labine","tmdb_id":51383,"profile":"https://image.tmdb.org/t/p/w500/uTg5k0mflhBju9Q1tOYmYDzdBu6.jpg","tmdb_url":"https://www.themoviedb