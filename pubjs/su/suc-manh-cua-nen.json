opstream12.com/share/2e04639133a2b42aa8e68e49a51fe039","link_m3u8":"https://vip.opstream12.com/20220627/22522_f8d2bb40/index.m3u8"},{"name":"21A","slug":"21a","filename":"suc-manh-cua-nen-raeng-tian-tap-21A","link_embed":"https://vip.opstream12.com/share/3fde502aa65e2ce159a2a255ac96f632","link_m3u8":"https://vip.opstream12.com/20220627/22523_db6c53d2/index.m3u8"},{"name":"21B","slug":"21b","filename":"suc-manh-cua-nen-raeng-tian-tap-21B","link_embed":"https://vip.opstream12.com/share/4e59c5d1cdd26cf09c95106c59ddfa9e","link_m3u8":"https://vip.opstream12.com/20220627/22524_bacd2d36/index.m3u8"},{"name":"22A","slug":"22a","filename":"suc-manh-cua-nen-raeng-tian-tap-22A","link_embed":"https://vip.opstream12.com/share/ea9c39a35857068756c18d8a47ac9c33","link_m3u8":"https://vip.opstream12.com/20220627/22525_b8d90132/index.m3u8"},{"name":"22B","slug":"22b","filename":"suc-manh-cua-nen-raeng-tian-tap-22B","link_embed":"https://vip.opstream12.com/share/9ff9f36ae38969dcf2b80b93bab62fea","link_m3u8":"https://vip.opstream12.com/20220627/22526_24ec79c2/index.m3u8"}]}],"time":"60 phút","description":"<p>Xem Phim Miễn Phí: Bộ phim Sức Mạnh Của Nến - Raeng Tian kể về Tiansee, cô gái xinh đẹp bỗng nhiên bị anh chàng bạn trai yêu nhau 7 năm “đá” ngay trong ngày kỉ niệm quen nhau chỉ vì “khi không còn tình cảm thì đường ai nấy đi”. Đó vốn dĩ là lời bao biện cho việc anh chàng đang đào mỏ cô nàng Ratikorn giàu có.Thất vọng và tổn thương, cô biến thành một người ghét cay ghét đắng đàn ông. Rồi một ngày nọ, trong lúc xúc động cô đã lái xe và gây tai nạn xe cho Tiwa – anh trai của Ratikorn.Tiansee vô tình biết được mối quan hệ giữa người đàn ông cô từng yêu đến điên dại – Ratikorn và Tiwa. Cô đã lợi dụng cơ hội trời cho này, lợi dụng Tiwa để trả thù Tee – người đàn ông đã phản bội cô.Nhưng lửa gần rơm lâu ngày cũng cháy, Tiansee dần phải lòng người đàn ông luôn quan tâm chăm sóc và nâng niu mình. Thế nhưng, khi sự thật được phơi bày, liệu tình yêu có đủ lớn để Tiwa chấp nhận được sự thật anh là con cờ trong công cuộc trả thù của cô?Câu trả lời sẽ có trong Raeng Tian – Sức Mạnh của Nến! (Tian tên của nữ chính có nghĩa là ngọn nến)</p>","tmdb":{"type":"tv","id":"93469","season":1,"vote_average":8,"vote_count":1},"modified":"2022-06-27T10:01:13.000Z","cast":["Chermarn Boonyasak","Wongsakorn Paramatthakorn","Ranya Siyanon","Nut Devahastin Na Ayutthaya","Yardthip Rajpal","Penpetch Benyakul","Patara Eksangkul"],"director":["Boom Runya Siyanon"],"cast_meta":[{"name":"Chermarn Boonyasak","name_vi":null,"name_original":"Chermarn Boonyasak","tmdb_id":69990,"profile":"https://image.tmdb.org/t/p/w500/ggtm4lJS6bcC0WiXipT7FsPaAZ1.jpg","tmdb_url":"https://www.themoviedb.org/person/69990"},{"name":"Wongsakorn Paramatthakorn","name_vi":null,"name_original":"Wongsakorn Paramatthakorn","tmdb_id":1343980,"profile":"https://image.tmdb.org/t/p/w500/e1Dn8c5FBbFfLrvbT8hak3de9eA.jpg","tmdb_url":"https://www.themoviedb.org/person/1343980"},{"name":"Ranya Siyanon","name_vi":null,"name_original":"Ranya Siyanon","tmdb_id":1259712,"profile":"https://image.tmdb.org/t/p/w500/dmwTS6sASl6vI1qrpsF07KGqPIa.jpg","tmdb_url":"https://www.themoviedb.org/person/1259712"},{"name":"Nut Devahastin Na Ayutthaya","name_vi":null,"name_original":"Nut Devahastin Na Ayutthaya","tmdb_id":1153073,"profile":"https://image.tmdb.org/t/p/w500/4KHTecNTUshnyap4wtjD7xhrvVC.jpg","tmdb_url":"https://www.themoviedb.org/person/1153073"},{"name":"Yardthip Rajpal","name_vi":null,"name_original":"Yardthip Rajpal","tmdb_id":1341680,"profile":"https://image.tmdb.org/t/p/w500/jHYmEM8nqeeMcLgieuEYlaoI25s.jpg","tmdb_url":"https://www.themoviedb.org/person/1341680"},{"name":"Penpetch Benyakul","name_vi":null,"name_original":"Penpetch Benyakul","tmdb_id":3286468,"profile":"https://image.tmdb.org/t/p/w500/fi7QnCFnt7SS2MiqT1QB7QPlYxH.jpg","tmdb_url":"https://www.themoviedb.org/person/3286468"},{"name":"Patara Eksangkul","name_vi":null,"name_original":"Patara Eksangkul","tmdb_id":2860552,"profile":"https://image.tmdb.org/t/p