àng tiên tên là Shall để làm vệ sĩ trên đường đến Lewiston. Ann bị giằng xé giữa việc giải thoát cho Shall và cần vệ sĩ trên những con đường nguy hiểm đến lễ hội.</p>","tmdb":{"type":"tv","id":"135335","season":1,"vote_average":7.143,"vote_count":28},"modified":"2024-11-02T10:39:42.000Z","cast":["Yuka Nukui","Masaaki Mizunaka","Rie Takahashi","Tomoaki Maeno","Takuma Terashima","Reiji Kawashima","Yuto Uemura","Kazuyuki Okitsu","Ayumi Mano","Aya Yamane","Minori Suzuki","Nobuhiko Okamoto","Koji Okino","Atsushi Tamaru","Shoya Chiba"],"director":[],"cast_meta":[{"name":"Yuka Nukui","name_vi":null,"name_original":"Yuka Nukui","tmdb_id":1922616,"profile":"https://image.tmdb.org/t/p/w500/bTFcrrgj9B8QAXa1NKqlsrdwWka.jpg","tmdb_url":"https://www.themoviedb.org/person/1922616"},{"name":"Masaaki Mizunaka","name_vi":null,"name_original":"Masaaki Mizunaka","tmdb_id":2376502,"profile":"https://image.tmdb.org/t/p/w500/cHb2pr4juxk8A3VTuDxgPWHM6WF.jpg","tmdb_url":"https://www.themoviedb.org/person/2376502"},{"name":"Rie Takahashi","name_vi":null,"name_original":"Rie Takahashi","tmdb_id":1492982,"profile":"https://image.tmdb.org/t/p/w500/aeB7z0cBTASdjKOjQriBAO6hYq4.jpg","tmdb_url":"https://www.themoviedb.org/person/1492982"},{"name":"Tomoaki Maeno","name_vi":null,"name_original":"Tomoaki Maeno","tmdb_id":1249235,"profile":"https://image.tmdb.org/t/p/w500/w3lEuXSbEyzzNyO3YnxsF6wm2N5.jpg","tmdb_url":"https://www.themoviedb.org/person/1249235"},{"name":"Takuma Terashima","name_vi":null,"name_original":"Takuma Terashima","tmdb_id":222350,"profile":"https://image.tmdb.org/t/p/w500/n5uCihb318AzQCT9gieMlI2ueYL.jpg","tmdb_url":"https://www.themoviedb.org/person/222350"},{"name":"Reiji Kawashima","name_vi":null,"name_original":"Reiji Kawashima","tmdb_id":2710568,"profile":"https://image.tmdb.org/t/p/w500/tJriYA3tctzKP3ZnAwsxkey9iyU.jpg","tmdb_url":"https://www.themoviedb.org/person/2710568"},{"name":"Yuto Uemura","name_vi":null,"name_original":"Yuto Uemura","tmdb_id":1247956,"profile":"https:/