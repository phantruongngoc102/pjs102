 5","link_embed":"https://vip.opstream17.com/share/0f0e0ddd3be45a94e4941c890a8ed1d1","link_m3u8":"https://vip.opstream17.com/20240712/14855_7bdfd956/index.m3u8"},{"name":"6","slug":"6","filename":"Isekai Suicide Squad 6","link_embed":"https://vip.opstream17.com/share/a41a6a3856ee3c8c2816d4828b64f560","link_m3u8":"https://vip.opstream17.com/20240725/15648_5c554e20/index.m3u8"},{"name":"7","slug":"7","filename":"Isekai Suicide Squad 7","link_embed":"https://vip.opstream17.com/share/0fbadcbe8b2b6612b48d0fe109db849b","link_m3u8":"https://vip.opstream17.com/20240725/15649_38178b9c/index.m3u8"},{"name":"8","slug":"8","filename":"Biệt Đội Cảm Tử Tại Dị Giới 8","link_embed":"https://vip.opstream17.com/share/637489250d6a28176d466c0aa567e65b","link_m3u8":"https://vip.opstream17.com/20240801/16002_f7104455/index.m3u8"},{"name":"9","slug":"9","filename":"Suicide Squad Isekai 9","link_embed":"https://vip.opstream11.com/share/73ba3f47a4cefcb80b3fd2a8122b21f9","link_m3u8":"https://vip.opstream11.com/20240902/52350_73ba3f47/index.m3u8"},{"name":"10","slug":"10","filename":"Suicide Squad Isekai 10","link_embed":"https://vip.opstream11.com/share/c86d9cab5741a9ce01b0403217f274ca","link_m3u8":"https://vip.opstream11.com/20240902/52351_c86d9cab/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Suicide Squad - Biệt Đội Cảm Tử phiên bản “dị giới” xoay quanh thành phố Gotham đầy rẫy tội phạm, trong đó, Amanda Waller, người đứng đầu A.R.G.U.S., đã tập hợp một nhóm tội phạm khét tiếng, gồm Harley Quinn, Deadshot, Peacemaker, Clayface, và King Shark để cùng thực hiện một nhiệm vụ hệ trọng tại chiều không gian đặc biệt. Theo đó, nhóm siêu phản diện này được gửi đến một dị giới kết nối với thế giới ban đầu thông qua một cánh cổng kì lạ. Đó là vùng đất của kiếm pháp và phép thuật, nơi quái vật và rồng cùng thống trị toàn bộ bầu trời rộng lớn. Với chất nổ chết người được gắn trên cổ mình, nhóm tội phạm không thể nào bỏ trốn, cũng như một khi nhiệm vụ thất bại, họ thậm chí không còn cơ hội trở lại thế giới của mình.</p>","tmdb":{"type":"tv","id":"229926","season":1,"vote_average":7.378,"vote_count":94},"modified":"2024-09-02T14:11:39.000Z","cast":["Anna Nagase","Reigo Yamaguchi","Takehito Koyasu","Jun Fukuyama","Subaru Kimura","Jun Fukushima","Seán Patrick Judge"],"director":[],"cast_meta":[{"name":"Anna Nagase","name_vi":null,"name_original":"Anna Nagase","tmdb_id":2889712,"profile":"https://image.tmdb.org/t/p/w500/748FmLCklgnN8hrlBZ4bNsF4zpk.jpg","tmdb_url":"https://www.themoviedb.org/person/2889712"},{"name":"Reigo Yamaguchi","name_vi":null,"name_original":"Reigo Yamaguchi","tmdb_id":2984090,"profile":"https://image.tmdb.org/t/p/w500/cPWeSJDyR7fF3xfvQ235Y3hAS3g.jpg","tmdb_url":"https://www.themoviedb.org/person/2984090"},{"name":"Takehito Koyasu","name_vi":null,"name_original":"Takehito Koyasu","tmdb_id":84508,"profile":"https://image.tmdb.org/t/p/w500/8uBkNDKPNmp9JWgMUI02NVyfhi1.jpg","tmdb_url":"https://www.themoviedb.org/person/84508"},{"name":"Jun Fukuyama","name_vi":null,"name_original":"Jun Fukuyama","tmdb_id":131563,"profile":"https://image.tmdb.org/t/p/w500/eT9eloyIaIkTvTqMmpcsAleP2hM.jpg","tmdb_url":"https://www.themoviedb.org/person/131563"},{"name":"Subaru Kimura","name_vi":null,"name_original":"Subaru Kimura","tmdb_id":1142780,"profile":"https://image.tmdb.org/t/p/w500/8o24ix4Lk9WduRXFDI6Nmip5Deq.jpg","tmdb_url":"https://www.themoviedb.org/person/1142780"},{"name":"Jun Fukushima","name_vi":null,"name_original":"Jun Fukushima","tmdb_id":115301,"profile":"https://image.tmdb.org/t/p/w500/xo2A4cr8TnhC9rLFxSQvhwCbIOw.jpg","tmdb_url":"https://www.themoviedb.org/person/115301"},{"name":"Seán Patrick Judge","name_vi":null,"name_original":"Seán Patrick Judge","tmdb_id":1886344,"profile":"https://image.tmdb.org/t/p/w500/bX6a363s7GPXD8D0PX1vyq2jcYv.jpg","tmdb_url":"https://www.themoviedb.org/person/1886344"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/su/suicide-squad-isekai.json"}