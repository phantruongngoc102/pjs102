ame":"Suỵt, Quốc Vương Đang Ngủ Đông - Tập 22---2025","link_embed":"https://vip.opstream90.com/share/e8542a04d734d0cae36d648b3f519e5c","link_m3u8":"https://vip.opstream90.com/20250322/3746_e8542a04/index.m3u8"},{"name":"23","slug":"23","filename":"Suỵt, Quốc Vương Đang Ngủ Đông - Tập 23---2025","link_embed":"https://vip.opstream90.com/share/d8847be3f7cc1b14e9173908bebb2106","link_m3u8":"https://vip.opstream90.com/20250322/3747_d8847be3/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Tác giả truyện tranh Vệ Chi bất ngờ vướng vào scandal, bị công ty tước mất bút danh và bản quyền tác phẩm. Chìm trong thất vọng, cô vô tình xem được một video về trượt tuyết ván đơn và bị tinh thần dũng cảm của các vận động viên cuốn hút. Điều đó đã thôi thúc cô bắt đầu lại từ đầu với một tác phẩm mới lấy chủ đề trượt tuyết.Vệ Chi lên đường đến khu trượt tuyết Bắc Sơn để tìm cảm hứng và tình cờ gặp huấn luyện viên Thiện Sùng. Trong quá trình luyện tập đầy vất vả, cô không chỉ rèn giũa ý chí kiên cường mà còn dần nảy sinh tình cảm với anh.Thiện Sùng từng là một vận động viên trượt tuyết chuyên nghiệp, nhưng vì em gái bị tàn tật và bản thân cũng bị chấn thương, anh buộc phải từ giã sự nghiệp theo ý nguyện của cha mẹ, nhưng trong tim mình, anh vẫn luôn giữ ngọn lửa đam mê dành cho bộ môn này.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"247207","season":1,"vote_average":6.7,"vote_count":10},"modified":"2025-03-22T13:32:27.000Z","cast":["Ngu Thư Hân","Lâm Nhất","Phí Khải Minh","Tăng Khả Ny","Hạ Hạo Nhiên","Hu Wenxuan","Vương Nhuận Trạch","Xu Shiyue","Zeng Youzhen","Xia Minghao","Chen Cheng","Liu Lingzhi","Sun Zihang","Liu Yangzi","Huang Xiaoge"],"director":["Lý Thanh Vinh"],"cast_meta":[{"name":"Ngu Thư Hân","name_vi":"Ngu Thư Hân","name_original":"Yu Shuxin","tmdb_id":2140103,"profile":"https://image.tmdb.org/t/p/w500/xQ2Bur9AEy0IX3qHMvLbr7tmTyD.jpg","tmdb_url":"https://www.themoviedb.org/person/2140103"},{"name":"Lâm Nhất","name_vi":"Lâm Nhất","name_original":"Lin Yi","tmdb_id":2312400,"profile":"https://image.tmdb.org/t/p/w500/u3QIY069pyR3IE7fZncPfHa5Ijf.jpg","tmdb_url":"https://www.themoviedb.org/person/2312400"},{"name":"Phí Khải Minh","name_vi":"Phí Khải Minh","name_original":"Fei Qiming","tmdb_id":2633279,"profile":"https://image.tmdb.org/t/p/w500/iOK3rNtt0bUrDOw5bYoohE3rfiA.jpg","tmdb_url":"https://www.themoviedb.org/person/2633279"},{"name":"Tăng Khả Ny","name_vi":"Tăng Khả Ny","name_original":"Jenny Zeng","tmdb_id":2376754,"profile":"https://image.tmdb.org/t/p/w500/c0iALcsclRIpkx0XGsbWWqvQIOx.jpg","tmdb_url":"https://www.themoviedb.org/person/2376754"},{"name":"Hạ Hạo Nhiên","name_vi":"Hạ Hạo Nhiên","name_original":"Xia Haoran","tmdb_id":3706826,"profile":"https://image.tmdb.org/t/p/w500/c2Wj7zXGQWiNlSrvWViNrhLjEnJ.jpg","tmdb_url":"https://www.themoviedb.org/person/3706826"},{"name":"Hu Wenxuan","name_vi":null,"name_original":"Hu Wenxuan","tmdb_id":4100985,"profile":"https://image.tmdb.org/t/p/w500/f0qFbQXFtD9WdpfS3kK0kLIpydX.jpg","tmdb_url":"https://www.themoviedb.org/person/4100985"},{"name":"Vương Nhuận Trạch","name_vi":"Vương Nhuận Trạch","name_original":"Wang Runze","tmdb_id":2164716,"profile":"https://image.tmdb.org/t/p/w500/oLQYPrZh7XLmRPHMUeuwibuAX28.jpg","tmdb_url":"https://www.themoviedb.org/person/2164716"},{"name":"Xu Shiyue","name_vi":null,"name_original":"Xu Shiyue","tmdb_id":3387839,"profile":"https://image.tmdb.org/t/p/w500/piSiV1Py8Ba6DZSe642DUcsLuIK.jpg","tmdb_url":"https://www.themoviedb.org/person/3387839"},{"name":"Zeng Youzhen","name_vi":null,"name_original":"Zeng Youzhen","tmdb_id":3303296,"profile":"https://image.tmdb.org/t/p/w500/m0Cw1LDKXmAMLgsvi5bUxxlDZgh.jpg","tmdb_url":"https://www.themoviedb.org/person/3303296"},{"name":"Xia Minghao","name_vi":null,"name_original":"Xia Minghao","tmdb_id":2576416,"profile":"https://image.tmdb.org/t/p/w500/v3VaKgOvROE9Rwe4nCu8cZy2Ln9.jpg","tmdb_url":"https://www.themoviedb.org/person/2576416"},{"name":"Chen Cheng","name_vi":null,"name_original":"Chen Cheng",