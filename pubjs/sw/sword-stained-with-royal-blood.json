m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream17.com/share/7ab8464df372307c1bcce9b2a043415a","link_m3u8":"https://vip.opstream17.com/20240708/14600_28d40dac/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream17.com/share/050b8cbe360fb66fe566aae25cd800df","link_m3u8":"https://vip.opstream17.com/20240708/14601_2f1ee715/index.m3u8"}]}],"description":"Bích huyết kiếm là tác phẩm thứ hai của Kim Dung, được viết vào năm 1956, lấy bối cảnh triều chính rối ren cuối thời nhà Minh ở Trung Hoa. Mang trong mình nỗi oan khuất của người cha anh hùng mà bạc mệnh, cậu bé Viên Thừa Chí lớn lên dưới sự bảo bọc của những thuộc hạ trung thành như Viên Sùng Hoán và người thầy kì quái Bát Tí Viên Hầu – chưởng môn phái Hoa Sơn. Tình cờ mà cậu có được cây Kim xà kiếm và bí quyết võ công thượng thừa. Nhưng cũng từ đó, cuộc đời cậu đã đổi khác : trở thành kẻ thù của một thế lực lớn trên giang hồ – phái Thạch Lương của Ôn Gia Bảo. Mọi chuyện ghê tởm, đáng khinh bỉ năm xưa lần lượt được phơi bày. Ôn Gia Bảo và Kim xà lang quân Hạ Tuyết Nghi có ân oán gì? Viên Thừa Chí sẽ xử trí ra sao trước tình cảm của Ôn Thanh – người con gái tội nghiệp của Kim xà lang quân, vị sư phụ chưa từng biết mặt của chàng và A Cửu – con gái của Sùng Trinh, kẻ đã trực tiếp hạ lệnh sát hại cha chàng?","tmdb_id":32020,"cast":["Feifei Sun","Jiao Vincent","Huỳnh Thánh Y","Bobby Dou","Hsiao Shu-shen","Mã Tô","Cao Hổ","Wang Weiguo"],"director":["Du Ji Gong"],"keywords":[],"tmdb":{"type":"tv","id":"32020","season":1,"vote_average":6.7,"vote_count":3},"cast_meta":[{"name":"Feifei Sun","name_vi":null,"name_original":"Feifei Sun","tmdb_id":2390490,"profile":"https://image.tmdb.org/t/p/w500/d0NzseczIqezrJIAXKkSzeAyx9L.jpg","tmdb_url":"https://www.themoviedb.org/person/2390490"},{"name":"Jiao Vincent","name_vi":null,"name_original":"Jiao Vincent","tmdb_id":1743474,"profile":"https://image.tmdb.org/t/p/w500/jFmtXYva1JA7A6enswnesuKoZuT.jpg","tmdb_url":"https://www.themoviedb.org/person/17434