 đồ sát không thương tiếc, đẩy thiên hạ đến bên bờ vực của đại loạn. Trong bối cảnh căng như dân đàn ấy, một người là Yên Ký Vũ, xuất thân là viện trưởng của Đình Vân đã đứng ra để dựng cờ khởi nghĩa, lấy danh là thống nhất võ lâm thiên hạ với tấm lòng trượng nghĩa và cũng do hắn sẽ là người lãnh đạo. Thời điểm đó thì một cậu thiếu niên vô danh Dương Thiết nhận được di mệnh của Đao Tông chí tôn nên đã dấn thân vào chốn võ hiệp giang hồ đề thực hiện nhiệm vụ của mình. Khốn khổ là cậu luôn bị truy đuổi, săn đánh không ngừng từ những kẻ thù xấu xa. Không ngần ngại gian khổ, Dương Thiết luôn nỗ lực để nâng cao trình độ của bản thân, đối đầu và đánh bại vô số kẻ thù và kết mối giao hảo với rất nhiều những vị đại hiệp trượng nghĩa.","tmdb_id":294747,"cast":["凃雄飞","Jiang Cong","吴鑫怡","Chen Dagang"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"294747","season":1,"vote_average":8.75,"vote_count":4},"cast_meta":[{"name":"凃雄飞","name_vi":null,"name_original":"凃雄飞","tmdb_id":5597252,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5597252"},{"name":"Jiang Cong","name_vi":null,"name_original":"Jiang Cong","tmdb_id":4834149,"profile":"https://image.tmdb.org/t/p/w500/65R2q1LVoXlL5NqhbDXPVHyPbq8.jpg","tmdb_url":"https://www.themoviedb.org/person/4834149"},{"name":"吴鑫怡","name_vi":null,"name_original":"吴鑫怡","tmdb_id":5597255,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5597255"},{"name":"Chen Dagang","name_vi":null,"name_original":"Chen Dagang","tmdb_id":4816115,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4816115"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ta/ta-la-dao-tong.json"}