ng đoạt lại ngai vàng khi Thái sư cố gắng tạo phản.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/ta-la-hoang-tu-bu-nhin-thoi-co-dai-short-drama.json","tmdb_checked":false}