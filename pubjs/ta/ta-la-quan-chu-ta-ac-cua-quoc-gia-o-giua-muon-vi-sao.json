u chuyện sai lệch về sự quản lý lãnh thổ ở quy mô thiên hà sẽ bắt đầu!</p>","tmdb_id":274737,"cast":["Hanae Natsuki","Reina Ueda","Takehito Koyasu","Mikako Komatsu","Ayana Taketatsu"],"director":[],"keywords":[],"cast_meta":[{"name":"Hanae Natsuki","name_vi":"Hanae Natsuki","name_original":"Natsuki Hanae","tmdb_id":1256603,"profile":"https://image.tmdb.org/t/p/w500/alTb0DlcPIbcwM08WSmxFai58sd.jpg","tmdb_url":"https://www.themoviedb.org/person/1256603"},{"name":"Reina Ueda","name_vi":null,"name_original":"Reina Ueda","tmdb_id":1452028,"profile":"https://image.tmdb.org/t/p/w500/2WV61uVU7y6XGYqNHLMpP0sApdu.jpg","tmdb_url":"https://www.themoviedb.org/person/1452028"},{"name":"Takehito Koyasu","name_vi":null,"name_original":"Takehito Koyasu","tmdb_id":84508,"profile":"https://image.tmdb.org/t/p/w500/8uBkNDKPNmp9JWgMUI02NVyfhi1.jpg","tmdb_url":"https://www.themoviedb.org/person/84508"},{"name":"Mikako Komatsu","name_vi":null,"name_original":"Mikako Komatsu","tmdb_id":1281498,"profile":"https://image.tmdb.org/t/p/w500/13tQEZ1tLdOmi7oGoRJ4xep1ODQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1281498"},{"name":"Ayana Taketatsu","name_vi":null,"name_original":"Ayana Taketatsu","tmdb_id":1072776,"profile":"https://image.tmdb.org/t/p/w500/5JyZSnHwP18DIcVSqlGUwccA2WE.jpg","tmdb_url":"https://www.themoviedb.org/person/1072776"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/ta-la-quan-chu-ta-ac-cua-quoc-gia-o-giua-muon-vi-sao.json"}