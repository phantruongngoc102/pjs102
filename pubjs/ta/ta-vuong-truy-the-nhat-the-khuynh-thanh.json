iúp đỡ của Tấn Vương, Tô Lạc đã đến thần điện để kiểm tra nhờ đó phát hiện ra cô là kì tài tu luyện hiếm gặp. Vì thế vô số người ích kỉ đã âm mưu giết chết cô, nhờ đó thân phận thần bí của cô cũng dần được hé lộ.</p>","tmdb_id":87210,"cast":["Tong Xinzhu","Hao Xianghai","Li Lanling","Shen Nianru","Li Xiaomeng","Liu Mingyue"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"87210","season":1,"vote_average":7.3,"vote_count":7},"cast_meta":[{"name":"Tong Xinzhu","name_vi":null,"name_original":"Tong Xinzhu","tmdb_id":2156485,"profile":"https://image.tmdb.org/t/p/w500/kZzS7YnlKqfLMi3GzC2pjRQmAIb.jpg","tmdb_url":"https://www.themoviedb.org/person/2156485"},{"name":"Hao Xianghai","name_vi":null,"name_original":"Hao Xianghai","tmdb_id":2207399,"profile":"https://image.tmdb.org/t/p/w500/mDGtY44WlZbk8pMmuzPToIommx4.jpg","tmdb_url":"https://www.themoviedb.org/person/2207399"},{"name":"Li Lanling","name_vi":null,"name_original":"Li Lanling","tmdb_id":1870042,"profile":"https://image.tmdb.org/t/p/w500/ejeFtmhRq12vJU7VfWySggmyh3y.jpg","tmdb_url":"https://www.themoviedb.org/person/1870042"},{"name":"Shen Nianru","name_vi":null,"name_original":"Shen Nianru","tmdb_id":2156487,"profile":"https://image.tmdb.org/t/p/w500/6K9iai6QCkF8Gc9DeUPOeESokM0.jpg","tmdb_url":"https://www.themoviedb.org/person/2156487"},{"name":"Li Xiaomeng","name_vi":null,"name_original":"Li Xiaomeng","tmdb_id":2121612,"profile":"https://image.tmdb.org/t/p/w500/1YzRTxk9u9MKiNqZctSnOQA6FUq.jpg","tmdb_url":"https://www.themoviedb.org/person/2121612"},{"name":"Liu Mingyue","name_vi":null,"name_original":"Liu Mingyue","tmdb_id":2156556,"profile":"https://image.tmdb.org/t/p/w500/kqh1vBsQ35b617dvd9jtvQ2ii7l.jpg","tmdb_url":"https://www.themoviedb.org/person/2156556"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/ta-vuong-truy-the-nhat-the-khuynh-thanh.json"}