/39443_0c5cf32a/index.m3u8"},{"name":"91","slug":"91","link_embed":"https://vip.opstream-short.com/share/2d821f9d210b3b0ec98f18bf84253c0f","link_m3u8":"https://vip.opstream-short.com/20251119/39444_2d821f9d/index.m3u8"},{"name":"92","slug":"92","link_embed":"https://vip.opstream-short.com/share/935e35865cbae77d52ea3dfd33edb576","link_m3u8":"https://vip.opstream-short.com/20251119/39445_935e3586/index.m3u8"},{"name":"93","slug":"93","link_embed":"https://vip.opstream-short.com/share/17e2f490c88a85e1a0872d7e5431e374","link_m3u8":"https://vip.opstream-short.com/20251119/39446_17e2f490/index.m3u8"},{"name":"94","slug":"94","link_embed":"https://vip.opstream-short.com/share/0db1fb75f1918668d1248e31ff9988f5","link_m3u8":"https://vip.opstream-short.com/20251119/39447_0db1fb75/index.m3u8"},{"name":"95","slug":"95","link_embed":"https://vip.opstream-short.com/share/cf8419577959c049da19a45e2e3da57f","link_m3u8":"https://vip.opstream-short.com/20251119/39448_cf841957/index.m3u8"},{"name":"96","slug":"96","link_embed":"https://vip.opstream-short.com/share/9008bcab767d69a3d185b4936687940e","link_m3u8":"https://vip.opstream-short.com/20251119/39449_9008bcab/index.m3u8"},{"name":"97","slug":"97","link_embed":"https://vip.opstream-short.com/share/444d8477c9764f0afff3f91ee5165019","link_m3u8":"https://vip.opstream-short.com/20251119/39450_444d8477/index.m3u8"},{"name":"98","slug":"98","link_embed":"https://vip.opstream-short.com/share/bdc31e3996f71d8f34782dda5ea48511","link_m3u8":"https://vip.opstream-short.com/20251119/39451_bdc31e39/index.m3u8"},{"name":"99","slug":"99","link_embed":"https://vip.opstream-short.com/share/4d1025a728b16caa6ca38ed00c663e68","link_m3u8":"https://vip.opstream-short.com/20251119/39452_4d1025a7/index.m3u8"}]}],"description":"<p>Tô Uyển Nhược rất cần tiền để điều trị bệnh bạch cầu cho em trai. Sau khi bị quấy rối ở quán bar nơi cô làm việc, cô được Lăng Vân và Phương Mộc cứu giúp nhưng mất việc làm. Lăng Vân đề nghị cô làm thư ký riêng 24 giờ với mức lương gấp mười lần - làm thư ký ban ngày và hâm nóng giường ban đêm. Không còn lựa chọn nào khác, Tô Uyển Nhược chấp nhận hợp đồng bất bình đẳng này và sống như người tình theo hợp đồng của anh ta trong năm năm, dần dần yêu anh ta. Tuy nhiên, Lăng Vân chỉ coi cô như đối tác hợp đồng và đồng ý kết hôn với Hứa Kiều, con gái của Tập đoàn Hứa, theo sự sắp xếp của mẹ. Khi Tô Uyển Nhược quyết định rời đi để có cuộc sống ổn định, Lăng Vân từ chối, tin rằng tiền là tất cả những gì cô quan tâm. Cô phát hiện mình có thai nhưng càng quyết tâm rời đi. Hứa Kiều ghen tị với những tin đồn nên làm nhục Tô Uyển Nhược trước công chúng và âm mưu cùng Lăng Ngữ Yên, em gái nuôi của Lăng Vân để bắt cóc Tô Thành, em trai của Tô Uyển Nhược. Do sai lầm, Tô Thành chết vì thương tích nặng và Tô Uyển Nhược mất đứa con. Quyết tâm trả thù, cô nhận được sự giúp đỡ từ Phương Mộc người đã yêu cô từ lần gặp đầu tiên nhưng tránh xa vì hạnh phúc của cô. Thấy Lăng Vân không thể làm cô hạnh phúc, Phương Mộc trở thành chỗ dựa vững chắc của cô, giúp báo thù và dạy kỹ năng tự vệ. Với sự giúp đỡ của Phương Mộc, Tô Uyển Nhược trở lại thế giới kinh doanh Dung Thành, có hệ thống tiêu diệt từng người đã làm tổn thương cô. Sau khi hoàn thành việc báo thù, cô chọn độc lập thay vì bất kỳ người đàn ông nào, thành lập công ty riêng để chứng minh sự độc lập và khả năng của phụ nữ.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/tai-sao-thu-ky-to-lai-nhu-vay-short-drama.json","tmdb_checked":false}