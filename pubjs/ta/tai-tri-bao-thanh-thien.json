c. Phần này còn có tên gọi khác là Tài Trí Bao Thanh Thiên, điều đáng tiếng nhất chính là không có sự tham gia của Triển Chiêu Thích Tiểu Long mà thay vào đó là vai diễn Triển Hộ Vệ của Lý Tông Hàn. Tuy nhiên, nam diễn viên họ Lý để thể hiện khá xuất sắc, hoàn thành tốt vai diễn cùng những màn võ thuật mãn nhãn.<br>&nbsp;</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-12-17T20:41:29.000Z","cast":["Vương Học Binh","Phạm Băng Băng","Lý Tông Hàn","Trần Bảo Quốc","Vương Cương","Lý Tiến Vinh","Hải Thanh","Vưu Dũng","Nhiếp Viễn","Ngô Khánh Triết","Lý Tiểu Nhiễm","Thẩm Ngạo Quân","Cao Hổ","Đới Xuân Vinh","Trác Phàm","Lâm Tịnh","Tông Phong Nham..."],"director":[],"cast_meta":[{"name":"Vương Học Binh","name_vi":null,"name_original":"Vương Học Binh"},{"name":"Phạm Băng Băng","name_vi":null,"name_original":"Phạm Băng Băng"},{"name":"Lý Tông Hàn","name_vi":null,"name_original":"Lý Tông Hàn"},{"name":"Trần Bảo Quốc","name_vi":null,"name_original":"Trần Bảo Quốc"},{"name":"Vương Cương","name_vi":null,"name_original":"Vương Cương"},{"name":"Lý Tiến Vinh","name_vi":null,"name_original":"Lý Tiến Vinh"},{"name":"Hải Thanh","name_vi":null,"name_original":"Hải Thanh"},{"name":"Vưu Dũng","name_vi":null,"name_original":"Vưu Dũng"},{"name":"Nhiếp Viễn","name_vi":null,"name_original":"Nhiếp Viễn"},{"name":"Ngô Khánh Triết","name_vi":null,"name_original":"Ngô Khánh Triết"},{"name":"Lý Tiểu Nhiễm","name_vi":null,"name_original":"Lý Tiểu Nhiễm"},{"name":"Thẩm Ngạo Quân","name_vi":null,"name_original":"Thẩm Ngạo Quân"},{"name":"Cao Hổ","name_vi":null,"name_original":"Cao Hổ"},{"name":"Đới Xuân Vinh","name_vi":null,"name_original":"Đới Xuân Vinh"},{"name":"Trác Phàm","name_vi":null,"name_original":"Trác Phàm"},{"name":"Lâm Tịnh","name_vi":null,"name_original":"Lâm Tịnh"},{"name":"Tông Phong Nham...","name_vi":null,"name_original":"Tông Phong Nham..."}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ta/tai-tri-bao-th