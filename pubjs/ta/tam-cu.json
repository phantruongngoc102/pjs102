n thức của cô về cuộc sống và gia đình bị lật đổ.</p>","tmdb_id":195378,"cast":["Hai Qing","Đồng Dao","Trương Tụng Văn","Phùng Thiệu Phong","Jie Bing","Lu Siyu","Tôn An Khả","Dong Qing","Wu Mian","Bai Fan","Yao Zhuojun","Han Yuqin","Zhou Haodong","Beibei Gao","Elaine Yi"],"director":[],"keywords":[],"cast_meta":[{"name":"Hai Qing","name_vi":null,"name_original":"Hai Qing","tmdb_id":1018563,"profile":"https://image.tmdb.org/t/p/w500/9QKqKPmT1vhjXpbrPkAhCprbf3R.jpg","tmdb_url":"https://www.themoviedb.org/person/1018563"},{"name":"Đồng Dao","name_vi":"Đồng Dao","name_original":"Tong Yao","tmdb_id":1298729,"profile":"https://image.tmdb.org/t/p/w500/darU7n51ym1dziYRwOtD10qiljn.jpg","tmdb_url":"https://www.themoviedb.org/person/1298729"},{"name":"Trương Tụng Văn","name_vi":"Trương Tụng Văn","name_original":"Zhang Songwen","tmdb_id":1086250,"profile":"https://image.tmdb.org/t/p/w500/rz1mKSiuV5LuY0l0Y6HRGJGBeED.jpg","tmdb_url":"https://www.themoviedb.org/person/1086250"},{"name":"Phùng Thiệu Phong","name_vi":"Phùng Thiệu Phong","name_original":"William Feng","tmdb_id":936431,"profile":"https://image.tmdb.org/t/p/w500/tSn5BIRw3Xdj3XYKIycjyNTgl49.jpg","tmdb_url":"https://www.themoviedb.org/person/936431"},{"name":"Jie Bing","name_vi":null,"name_original":"Jie Bing","tmdb_id":3028322,"profile":"https://image.tmdb.org/t/p/w500/pKI8yDzbWILokr3aMi0A43kN2rh.jpg","tmdb_url":"https://www.themoviedb.org/person/3028322"},{"name":"Lu Siyu","name_vi":null,"name_original":"Lu Siyu","tmdb_id":2802902,"profile":"https://image.tmdb.org/t/p/w500/tM2XW5lnbbGN4HwSNjr4poVmoRf.jpg","tmdb_url":"https://www.themoviedb.org/person/2802902"},{"name":"Tôn An Khả","name_vi":"Tôn An Khả","name_original":"Sun Anke","tmdb_id":2111586,"profile":"https://image.tmdb.org/t/p/w500/qvHUqczVNyBcvg2aUcK46Gs5M62.jpg","tmdb_url":"https://www.themoviedb.org/person/2111586"},{"name":"Dong Qing","name_vi":null,"name_original":"Dong Qing","tmdb_id":2027679,"profile":"https://image.tmdb.org/t/p/w500/p0T8AXfyHFbFdDCFzvxn