n thức của cô về cuộc sống và gia đình bị lật đổ.</p>","tmdb_id":195378,"cast":["Christina","Đồng Dao","Trương Tụng Văn","Phùng Thiệu Phong"],"director":["Hua-Tao Teng"],"keywords":[],"time":"45M54S","tmdb":{"type":"tv","id":"195378","season":1,"vote_average":8.5,"vote_count":2},"cast_meta":[{"name":"Christina","name_vi":null,"name_original":"Christina"},{"name":"Đồng Dao","name_vi":null,"name_original":"Đồng Dao"},{"name":"Trương Tụng Văn","name_vi":null,"name_original":"Trương Tụng Văn"},{"name":"Phùng Thiệu Phong","name_vi":null,"name_original":"Phùng Thiệu Phong"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/tam-cu.json"}