/share/d33c10c1a53c1e860a631c00f02d748a","link_m3u8":"https://vip.opstream13.com/20260227/22815_d33c10c1/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/e22ce4d908a59a1903c9c815ef4bfb03","link_m3u8":"https://vip.opstream13.com/20260227/22816_e22ce4d9/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/72fde87f1f5436457658bfc37ddaf9c6","link_m3u8":"https://vip.opstream13.com/20260227/22817_72fde87f/index.m3u8"}]}],"description":"<p>Wan Jiahe (Chen Jinhong) là một bác sĩ tâm thần. Anh rất yêu nghề của mình. Anh cũng tràn đầy niềm vui và tự hào vì có thể giúp đỡ người khác thoát khỏi bệnh tâm thần. Tuy nhiên, Wan Jiahe có thể chữa lành cho người khác, nhưng lại không thể chữa lành cho chính mình. Một tai nạn trong quá khứ đã khiến anh đầy sợ hãi về đàn ông và phụ nữ. Vì điều này, anh chưa bao giờ có được một mối tình lãng mạn ổn định và lâu dài kể từ khi còn nhỏ. Một cô gái tên Ying Lingshan (do Teng Li thủ vai) xuất hiện trong cuộc đời Wan Jiahe, và anh đã rất xúc động. Tuy nhiên, khi Wan Jiahe nghĩ rằng cuối cùng mình đã tìm thấy tình yêu đích thực, người bạn thân của anh là Zhang Zuyao (Jeong Jiaying) lại giở trò để giành lấy tình yêu của anh. Đồng thời, Ying Lingshan được phát hiện mắc bệnh tâm thần phân liệt. Dưới áp lực của tất cả các bên, liệu Wan Jiahe có thể vượt qua được nguy hiểm?</p>","tmdb_id":43423,"cast":["Đằng Lệ Danh","Trần Cẩm Hồng","Trịnh Gia Dĩnh","Cherie Kong","Âu Cẩm Đường","Fiona Wong","Fiona Yuen Choi-Wan","Natalie Tong","La Lạc Lâm","Phùng Tố Ba","Lâm Vỹ Thần","Lạc Ứng Quân","Kwong Joh-Fai","Hàn Mã Lợi","Hoàng Văn Tiêu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"43423","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Đằng Lệ Danh","name_vi":"Đằng Lệ Danh","name_original":"Joyce Tang Lai-Ming","tmdb_id":1223072,"profile":"https://image.tmdb.org/t/p/w500/rCGjxrs3HeRoOhzqbAwCucV12qo.jpg","tmdb_url":"https://www.themoviedb.org/person/1223072"},{"name