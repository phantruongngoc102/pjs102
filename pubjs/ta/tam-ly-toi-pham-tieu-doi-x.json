2_329b3f35/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream10.com/share/556950cd2810a798637000e9e438aac5","link_m3u8":"https://vip.opstream10.com/20220512/13611_2e1bf713/index.m3u8"}]}],"description":"<p>Phim Tâm Lý Tội Phạm: Tiểu Đội X - Visible Lie 2018: Được cải biên từ tiểu thuyết trinh thám kinh dị Ngụy án truy hung của tác giả Mạc Để Bài, truyện kể về bốn tổ tâm lý tội phạm của cục công an thành phố Nghi Khánh, sử dụng phương pháp IQ cao và phân tích tâm lý tội phạm để điều tra phá án, khám phá chân tướng sự việc.Dưới sự dẫn dắt của thiên tài tội phạm học – giáo sư Từ Lãng, tiểu đội X liên tiếp phá giải nhiều vụ án ly kỳ. Nhân vật Từ Lãng do Trương Siêu thủ diễn là tiến sĩ tội phạm học trường đại học Maryland, chuyên phân tích tâm lý phạm tội, được mệnh danh là “máy trắc nghiệm nói dối bằng xương bằng thịt” và “máy ghi chép di động”. Nhìn bề ngoài anh có thể bất cần, nhưng lại có khả năng đặc biệt là đọc được nội tâm của người khác và vạch trần những lời nói dối.</p>","tmdb_id":null,"cast":["Lý Thần Hạo","Mễ Lộ","Trương Siêu"],"director":["Đang cập nhật"],"keywords":[],"time":"","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lý Thần Hạo","name_vi":null,"name_original":"Lý Thần Hạo"},{"name":"Mễ Lộ","name_vi":null,"name_original":"Mễ Lộ"},{"name":"Trương Siêu","name_vi":null,"name_original":"Trương Siêu"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/tam-ly-toi-pham-tieu-doi-x.json"}