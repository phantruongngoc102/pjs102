_m3u8":"https://vip.opstream16.com/20230322/33259_055da307/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Thanh Hoan vốn là một đoá hoa diên vỹ bên bờ sông Quên, vô tình được thần quân Bạch Trạch điểm hoá, cũng vì vậy mà hai người phải lòng nhau, rơi vào luân hồi. Tam sinh tình kiếp, Bạch Trạch và Thanh Hoan trải qua biết bao lần bi hoan ly hợp, nếm trải đủ yêu hận tình thù, cuối cùng đã thấm đượm chữ \"tình\", có được mối tình tuyệt đẹp và cảm động lòng người.</p>","tmdb":{"type":"tv","id":"218560","season":1,"vote_average":7.333,"vote_count":3},"modified":"2025-04-03T10:38:43.000Z","cast":["Yang Ze","Lin Yanrou","Cao Junhao","Xu Shaohang"],"director":["Trần Nghị"],"cast_meta":[{"name":"Yang Ze","name_vi":null,"name_original":"Yang Ze","tmdb_id":2494668,"profile":"https://image.tmdb.org/t/p/w500/9CUVdHRklKsufhY0EiJfxcvdKi5.jpg","tmdb_url":"https://www.themoviedb.org/person/2494668"},{"name":"Lin Yanrou","name_vi":null,"name_original":"Lin Yanrou","tmdb_id":2295864,"profile":"https://image.tmdb.org/t/p/w500/wDy24dJ18N89kYfiDFLOf3OKccW.jpg","tmdb_url":"https://www.themoviedb.org/person/2295864"},{"name":"Cao Junhao","name_vi":null,"name_original":"Cao Junhao","tmdb_id":3708508,"profile":"https://image.tmdb.org/t/p/w500/jc2MKi1XNlXrtTcDGWJo5aWqq3O.jpg","tmdb_url":"https://www.themoviedb.org/person/3708508"},{"name":"Xu Shaohang","name_vi":null,"name_original":"Xu Shaohang","tmdb_id":2696467,"profile":"https://image.tmdb.org/t/p/w500/rWNPw4WOyGRbKeudmxWj3182K85.jpg","tmdb_url":"https://www.themoviedb.org/person/2696467"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ta/tam-sinh-duyen.json"}