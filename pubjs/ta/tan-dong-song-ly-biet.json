77b/index.m3u8"},{"name":"48","slug":"48","filename":"TanDongSongLyBiet.2001.1080p.48_2audioViet","link_embed":"https://vip.opstream17.com/share/1309167cce18f6973a67a702d7b799fe","link_m3u8":"https://vip.opstream17.com/20240812/16637_48977816/index.m3u8"},{"name":"49","slug":"49","filename":"TanDongSongLyBiet.2001.1080p.49End_2audioViet","link_embed":"https://vip.opstream17.com/share/b3432faaca931632a24fc96b3d1c71ef","link_m3u8":"https://vip.opstream17.com/20240812/16638_11c432a0/index.m3u8"}]}],"time":"50 phút/tập","description":"<p><i>Đầu những năm 1900, tại tỉnh Dong Bei, ở Ha Er Bin, Lục Chấn Hoa, còn được mọi người gọi là \"Báo đen\", là tổng trưởng nổi danh vào thời điểm đó. Fu Wen Pei là một cô gái bình thường xuất thân trong một gia đình trí thức. Trong một lần đang đi trên đường, cô vô tình ngã ngay trước mặt của Lục Chấn Hoa. Khoảnh khắc gặp gỡ ấy trở thành định mệnh của cuộc đời cô, Lục Chấn Hoa nhanh chóng hỏi cưới cô về làm vợ thứ 8 của ông và đám cưới được tổ chức ngay ngày hôm sau. Một năm sau, Lục Chấn Hoa gặp một người con gái khác tên là Wang Xue Qin, cô cũng lập tức được rước về nhà trở thành vợ thứ 9 và là người vợ cuối cùng…</i></p>","tmdb":{"type":"tv","id":"4308","season":1,"vote_average":7.55,"vote_count":20},"modified":"2024-08-12T15:56:04.000Z","cast":["Triệu Vy","Lâm Tâm Như","Cổ Cự Cơ","Tô Hữu Bằng","Gao Xin","Xu Xing","Khấu Chấn Hải","Wang Lin","Xu Lu","Cindy Lee","李郁","Le Jiatong"],"director":["Lý Bình"],"cast_meta":[{"name":"Triệu Vy","name_vi":"Triệu Vy","name_original":"Vicky Zhao","tmdb_id":77304,"profile":"https://image.tmdb.org/t/p/w500/tBtUIeGcc9sLV5IOMBfcTktvGio.jpg","tmdb_url":"https://www.themoviedb.org/person/77304"},{"name":"Lâm Tâm Như","name_vi":"Lâm Tâm Như","name_original":"Ruby Lin","tmdb_id":113311,"profile":"https://image.tmdb.org/t/p/w500/jhATD1TKubFUbaHnwtRXVvmq3sW.jpg","tmdb_url":"https://www.themoviedb.org/person/113311"},{"name":"Cổ Cự Cơ","name_vi":"Cổ Cự Cơ","name_original":"Leo Ku","tmdb_id":1236321,"profile":