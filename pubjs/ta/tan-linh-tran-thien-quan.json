{"id":"649e77d8fc04611a0553b11f","title":"Tần Lĩnh Trấn Thiên Quan","origin_name":"Qinling Town Tiancoffins","slug":"tan-linh-tran-thien-quan","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ta/tan-linh-tran-thien-quan.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ta/tan-linh-tran-thien-quan.webp","year":2023,"type":"single","genre":[{"id":"620a2293e0fc277084dfd489","name":"Phiêu Lưu","slug":"phieu-luu"},{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"tan-linh-tran-thien-quan-2023","link_embed":"https://vip.opstream11.com/share/00c391f380538eb146b161f180f811d0","link_m3u8":"https://vip.opstream11.com/20230629/45384_6b4e8324/index.m3u8"}]}],"time":"70 Phút","description":"Những năm đầu thời kỳ Dân Quốc, một khối thiên thạch rơi từ trên trời xuống, đáp trúng vùng núi Tần Lĩnh, tình cờ khai phá được một mộ cổ bí ẩn. Thiên hạ truyền tai trong mộ cất giữ những kho báu có giá trị. Ấy cũng là lúc Quân Phiệt tranh quyền, vì muốn thâu tóm khó báu sung quân phí, Dương Tư lệnh ngay lập tức sai người phong tỏa hiện trường. Thời kỳ này, có bao kẻ hèn bán nước cầu vinh, cũng không thiếu bậc anh tài hy sinh cứu quốc. Đệ tử Mã Cửu Xuyên của môn Thôi Hiển Linh chính là một trong số anh tài thuở ấy. Dương Tư lệnh, Tần Thiên, dẫn theo đám tay sai xông vào nhà của Thôi Hiển Linh, ép buộc Mã Cửu Xuyên dẫn đường quật mộ. Khi Mã Cửu Xuyên và đồng đội đến gần hố sâu trên Tần Lĩnh, một đội ngũ khác cũng đến đấy cùng một lúc- đó là quân Nhật do Eguchi Taku dẫn đầu. Vì bảo tàng trong mộ, ai nấy cũng ẩn giấu ý đồ trong lòng. Sau khi trải qua những hiện tượng kỳ quái và nguy hiểm chết người trong mộ, cuối cùng mọi người đã thấy được kho báu mà họ ao ước, sự xấu xa của các Quân Phiệt và Quân Nhật đã được tiết lộ vào lúc này...","tmdb":{"type":"movie","id":"1143484","season":null,"vote_average":0,"vote_count":0},"modified":"2025-03-26T11:29:17.000Z","cast":["He Gang","Yucheng Cao","Zhang Bonan","Từ Thiếu Cường","Lou Yunfei","Liu Sasa","Kai Shen"],"director":["Tao Yuan"],"cast_meta":[{"name":"He Gang","name_vi":null,"name_original":"He Gang","tmdb_id":1644866,"profile":"https://image.tmdb.org/t/p/w500/t2yibANWNeSHRD38Q8Jx46zYQyz.jpg","tmdb_url":"https://www.themoviedb.org/person/1644866"},{"name":"Yucheng Cao","name_vi":null,"name_original":"Yucheng Cao","tmdb_id":3206057,"profile":"https://image.tmdb.org/t/p/w500/mLt11BFaDvVyJpZ6O5y2CQcLrQa.jpg","tmdb_url":"https://www.themoviedb.org/person/3206057"},{"name":"Zhang Bonan","name_vi":null,"name_original":"Zhang Bonan","tmdb_id":2503979,"profile":"https://image.tmdb.org/t/p/w500/1unvYJrsD8gWdapSfqztbIXfdqR.jpg","tmdb_url":"https://www.themoviedb.org/person/2503979"},{"name":"Từ Thiếu Cường","name_vi":"Từ Thiếu Cường","name_original":"Norman Tsui Siu-Keung","tmdb_id":70674,"profile":"https://image.tmdb.org/t/p/w500/s3uEzXI19Xq5D3pJojgnvVz6vov.jpg","tmdb_url":"https://www.themoviedb.org/person/70674"},{"name":"Lou Yunfei","name_vi":null,"name_original":"Lou Yunfei","tmdb_id":1797696,"profile":"https://image.tmdb.org/t/p/w500/faL98n0YtIQKGj4qqGrLfuXiXxy.jpg","tmdb_url":"https://www.themoviedb.org/person/1797696"},{"name":"Liu Sasa","name_vi":null,"name_original":"Liu Sasa","tmdb_id":4006999,"profile":"https://image.tmdb.org/t/p/w500/jRkxA6X5aE6sjgCvBgxItmL7zXn.jpg","tmdb_url":"https://www.themoviedb.org/person/4006999"},{"name":"Kai Shen","name_vi":null,"name_original":"Kai Shen","tmdb_id":1484354,"profile":"https://image.tmdb.org/t/p/w500/37hpaUtuzREsVbpRnTSiD81O1pg.jpg","tmdb_url":"https://www.themoviedb