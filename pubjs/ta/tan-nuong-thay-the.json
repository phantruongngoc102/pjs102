570df1d681f97b1f","link_m3u8":"https://vip.opstream11.com/20241024/55651_0d0c7e3f/index.m3u8"},{"name":"25","slug":"25","filename":"Tân Nương Thay Thế - Ep25","link_embed":"https://vip.opstream11.com/share/93beb9cf543cc3fff9d32c618ccb78ad","link_m3u8":"https://vip.opstream11.com/20241025/55701_93beb9cf/index.m3u8"},{"name":"26","slug":"26","filename":"Tân Nương Thay Thế - Ep26","link_embed":"https://vip.opstream11.com/share/b7bde35396e68757ded1e8aafd91c83f","link_m3u8":"https://vip.opstream11.com/20241025/55702_b7bde353/index.m3u8"},{"name":"27","slug":"27","filename":"Tân Nương Thay Thế - Ep27","link_embed":"https://vip.opstream11.com/share/a604c8306e4c6e99e2aec550eaa1d510","link_m3u8":"https://vip.opstream11.com/20241026/55740_a604c830/index.m3u8"},{"name":"28","slug":"28","filename":"Tân Nương Thay Thế - Ep28","link_embed":"https://vip.opstream11.com/share/897fd9c0f53fa1d2d4cedaf50ce5b4b8","link_m3u8":"https://vip.opstream11.com/20241026/55741_897fd9c0/index.m3u8"}]}],"time":"14 phút/tập","description":"<p>Nữ sát thủ trẻ mất trí nhớ tên Nguyệt Dao, năm mười sáu tuổi cuối cùng cũng đón nhận nhiệm vụ ám sát đầu tiên của mình. Nguyệt Dao nhận lệnh từ sư phụ để ám sát Tướng quân Hạc Vân Hành nổi tiếng tàn ác của Nha Môn Mười Bốn. Nguyệt Dao thâm nhập vào phủ tướng quân nhưng thất bại, lại còn bị Hạc Vân Hành thiết kế trở thành tân nương vừa được hắn cưới vào cửa! Để hoàn thành nhiệm vụ ám sát, Nguyệt Dao đành phải đóng giả làm tân nương mới cưới của Hạc Vân Hành. Không lâu sau, trong phủ tướng quân liên tục xảy ra những vụ án mạng liên hoàn, và Nguyệt Dao trở thành nghi phạm chính. Trong sự kích động của những vụ án đẫm máu, Nguyệt Dao dần dần bắt đầu khôi phục trí nhớ đã mất của mình, nhưng lúc này cô vẫn chưa biết rằng mình đã bị cuốn vào một âm mưu kinh thiên động địa.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"252220","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-17T15:32:55.000Z","cast":["Li Junchen","Lâm Tư Ý","Zhang Yike","Zhu Minxin"],"dire