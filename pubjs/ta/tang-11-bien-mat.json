2ce95d/index.m3u8"},{"name":"24","slug":"24","filename":"THE LOST 11TH FLOOR 2023 EP24","link_embed":"https://vip.opstream11.com/share/61d62d0476b05d467684cfd3e2a1fe4a","link_m3u8":"https://vip.opstream11.com/20230718/45896_6c96c2cd/index.m3u8"}]}],"time":"43 phút/tập","description":"Một tập báo cáo của Tập đoàn Cự Luân nổi tiếng ở thành phố Thương Hải đã che đậy sự thật về vụ tai nạn hầm mỏ, khiến phó cục trưởng Khúc Giang Hà (do Phan Việt Minh thủ vai) trở thành tâm điểm trong cuộc chiến trừ gian diệt ác này. Cuốn vào cuộc điều tra, anh mới hay hóa ra cuộc chiến trắng đen vốn chẳng phân rõ hai màu đen trắng. Vì biết bao lợi ích mà đối thủ, bạn bè và thậm chí cả cấp trên của anh đều yêu cầu anh che đậy chân tướng thật sự, mà nữ cục trưởng mới được bổ nhiệm Nghiêm Cáp (do Trần Sác thủ vai) lại không ngờ thực tế lại tàn khốc và hoành tráng đến vậy. Che đậy là tội ác còn nghiêm trọng hơn cả phạm tội.","tmdb":{"type":"tv","id":"230128","season":1,"vote_average":6.5,"vote_count":6},"modified":"2024-11-15T11:23:12.000Z","cast":["Pan Yueming","Trần Sổ","Guo Jinglin","Vạn Bằng","Yu Jiwei","Sun Yan","Trần Hạo Lam","Wang Zheng","Liu Shuailiang","Uông Tịch Triều","Zhang Yiwen"],"director":["Jiang Zhuo Yuan"],"cast_meta":[{"name":"Pan Yueming","name_vi":null,"name_original":"Pan Yueming","tmdb_id":138734,"profile":"https://image.tmdb.org/t/p/w500/xxFTAdA2Nsiz5YRCwGer6MVXOzT.jpg","tmdb_url":"https://www.themoviedb.org/person/138734"},{"name":"Trần Sổ","name_vi":"Trần Sổ","name_original":"Chen Shu","tmdb_id":1076049,"profile":"https://image.tmdb.org/t/p/w500/slC0yQfoSN0nMZDKhYu2lGl4vSi.jpg","tmdb_url":"https://www.themoviedb.org/person/1076049"},{"name":"Guo Jinglin","name_vi":null,"name_original":"Guo Jinglin","tmdb_id":1079118,"profile":"https://image.tmdb.org/t/p/w500/uCgfEQDI33P9KaWs6eLCLeoeFZX.jpg","tmdb_url":"https://www.themoviedb.org/person/1079118"},{"name":"Vạn Bằng","name_vi":"Vạn Bằng","name_original":"Wan Peng","tmdb_id":2187124,"profile":"https://image.tmdb.org/t/p