0260205/24223_7c4e2c89/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream90.com/share/709f9b6bebbf6b83d059f97a0fd5faa0","link_m3u8":"https://vip.opstream90.com/20260205/24224_709f9b6b/index.m3u8"}]}],"description":"<p>Bộ phim là câu chuyện phim được khai thác dựa trên những tài liệu lịch sử có thật trong lịch sử Trung Hoa về nhân vật Tào Tháo được tái hiện chân thực và một góc nhìn khách quan, toàn diện hơn về nhân vật lịch sử có nhiều chiến tích này. Bộ phim “Tào Tháo”như một biện chứng hùng hồn về tính lịch sử của nhân vật được cho là nhất đại gian hùng trong thời Tam Quốc. Theo lịch sử Tào Tháo là người thủ đoạn, vô tình, máu lạnh. Nhưng ở phim này đạo diễn đã biến Tào Tháo thành người có tình, có nghĩa. Được nhắc đến nhiều nhất là chuyện tình giữa Tào Tháo và Thái Văn Cơ</p>","tmdb_id":103800,"cast":["Sun Hongtao","Zhang Yujie","Triệu Lập Tân","Cổ Cự Cơ","Hàn Tuyết","Yue Hong","Emn Chen","Zang Jinsheng","Ma Danni","Jie Gong","Lei Kesheng","Yin Junzheng","Shi Liming","Kun Yan","Li Lingyu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"103800","season":1,"vote_average":8,"vote_count":2},"cast_meta":[{"name":"Sun Hongtao","name_vi":null,"name_original":"Sun Hongtao","tmdb_id":3559416,"profile":"https://image.tmdb.org/t/p/w500/eYXxvIbo46FsaTkcuwObrp8t3fj.jpg","tmdb_url":"https://www.themoviedb.org/person/3559416"},{"name":"Zhang Yujie","name_vi":null,"name_original":"Zhang Yujie","tmdb_id":3559448,"profile":"https://image.tmdb.org/t/p/w500/aBtOzswDsGBaP9TknyAdogbI1Ze.jpg","tmdb_url":"https://www.themoviedb.org/person/3559448"},{"name":"Triệu Lập Tân","name_vi":"Triệu Lập Tân","name_original":"Zhao Lixin","tmdb_id":1513411,"profile":"https://image.tmdb.org/t/p/w500/dPN7skvFdzna1pxPLCQpdwpH9zd.jpg","tmdb_url":"https://www.themoviedb.org/person/1513411"},{"name":"Cổ Cự Cơ","name_vi":"Cổ Cự Cơ","name_original":"Leo Ku","tmdb_id":1236321,"profile":"https://image.tmdb.org/t/p/w500/50hNaLKosRAqimtb9XUcrLv7kz.jpg","tmdb_url":"https://www.themov