20260111/32298_29e48b72/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/b4755be9028acf67416ab6d2abf34d46","link_m3u8":"https://vip.opstream10.com/20260111/32299_b4755be9/index.m3u8"}]}],"description":"<p>Một trận đấu đích thực sẽ diễn ra trên võ đài, nơi quy tụ những võ sĩ hàng đầu quốc gia!</p><p>Đây là một trò chơi sinh tồn quyền anh siêu đỉnh, được phát triển bởi Don Lee, một ngôi sao hành động đẳng cấp thế giới và là chủ sở hữu một phòng tập quyền anh với 30 năm kinh nghiệm. Những người tham gia đến từ nhiều hoàn cảnh khác nhau, bao gồm cả những người từng đoạt huy chương và thậm chí là nhà vô địch, cùng nhau đối đầu nảy lửa và nỗ lực vươn lên đỉnh cao. Ai sẽ vượt qua giới hạn của bản thân, chứng minh tiềm năng và trở thành nhà vô địch? Một chương trình hành động hấp dẫn với những set đấu ấn tượng, những trận đấu ngoạn mục và những nhiệm vụ quy mô đáng kinh ngạc.</p><p>Thế giới quyền anh đích thực, một trò chơi sinh tồn quyền anh siêu đỉnh mà chưa ai từng trải nghiệm.</p>","tmdb_id":306252,"cast":["Ma Dong seok","Dex","Kim Jong-kook"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"306252","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Ma Dong seok","name_vi":"Ma Dong seok","name_original":"Don Lee","tmdb_id":1024395,"profile":"https://image.tmdb.org/t/p/w500/ckxoXz3l4mCcHEIRaqUc7oGoIFg.jpg","tmdb_url":"https://www.themoviedb.org/person/1024395"},{"name":"Dex","name_vi":null,"name_original":"Dex","tmdb_id":3887213,"profile":"https://image.tmdb.org/t/p/w500/WH81boD2vDEW6RvahjDHVH7vJh.jpg","tmdb_url":"https://www.themoviedb.org/person/3887213"},{"name":"Kim Jong-kook","name_vi":null,"name_original":"Kim Jong-kook","tmdb_id":1241035,"profile":"https://image.tmdb.org/t/p/w500/56y9LaL65dbeaWZJt9dB7ifAUhR.jpg","tmdb_url":"https://www.themoviedb.org/person/1241035"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/tay-dam-boc.json"}