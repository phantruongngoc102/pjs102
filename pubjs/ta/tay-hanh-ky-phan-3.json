3u8":"https://vip.opstream14.com/20231019/40468_e243eae3/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/e0df2a6236771992a0d39345c4b73f71","link_m3u8":"https://vip.opstream14.com/20231019/40469_1efb5f79/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/af866a23e5202f7bc6f2f3c5eed85d0d","link_m3u8":"https://vip.opstream14.com/20231019/40470_72bfcd4a/index.m3u8"}]}],"description":"<p>Tây Hành Kỷ (Phần 3) là câu chuyện về thời đại thần linh viễn cổ, nơi tồn tại Thiên tộc, Long Tộc, Dạ xoa, A-tu-la, Ma hầu la, yêu quái và nhân loại. Vào 16 năm trước, khi Đường Tam Tạng cùng 3 người đệ tử của mình thỉnh được “ Kỳ kinh” ở Tây Thiên trở về trung thổ. Vẫn tưởng giao lại kỳ kinh cho Đế Thích Thiên, là hoàn thành nhiệm vụ phổ độ chúng sinh. Nhưng Đường Tam Tạng đâu biết, thực ra Kỳ kinh mang trong mình một sức mạnh vô hạn, mà bất kể một thế lực nào trong thiên hạ đều muốn đạt được.</p>","tmdb_id":83031,"cast":["Cedric Hardwicke","Stanley Holloway","Derek Bond","Mary Merrall","Sally Ann Howes","Aubrey Woods","Jill Balcon","Bernard Miles","Alfred Drayton","Vera Pearce","James Hayter","Emrys Jones","Cecil Ramage","Timothy Bateson","George Relph"],"director":["Alberto Cavalcanti"],"keywords":["boarding school","victorian england","smike","wackford squeers"],"tmdb":{"type":"tv","id":"83031","season":3,"vote_average":7.6,"vote_count":7},"cast_meta":[{"name":"Cedric Hardwicke","name_vi":null,"name_original":"Cedric Hardwicke","tmdb_id":99461,"profile":"https://image.tmdb.org/t/p/w500/ypNZBNKlCibI0KsI3GQ1G0xJsQB.jpg","tmdb_url":"https://www.themoviedb.org/person/99461"},{"name":"Stanley Holloway","name_vi":null,"name_original":"Stanley Holloway","tmdb_id":12727,"profile":"https://image.tmdb.org/t/p/w500/3FLfK05mtqhF0mtuWVVWQCYwbA9.jpg","tmdb_url":"https://www.themoviedb.org/person/12727"},{"name":"Derek Bond","name_vi":null,"name_original":"Derek Bond","tmdb_id":39053,"profile":"https://image.tmdb.org/t/p/w500/dN