758533feded97683d573154714a195b","link_m3u8":"https://vip.opstream11.com/20230731/46211_3ab43760/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/371e5908cd5d0f190e4479cfdd5e1d9c","link_m3u8":"https://vip.opstream11.com/20230731/46212_c3851c5b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/fc3a68ae910a64c3c1a7d8ea0c525b9d","link_m3u8":"https://vip.opstream11.com/20230731/46213_c1a0a5cd/index.m3u8"}]}],"description":"<p>Lý Tây Phong vì báo thù cho cha mà nhập cung, vô tình được chọn trở thành công chúa, đến Đột Quyết hòa thân để thăm dò quân tình. Lý Tây Phong vốn muốn lợi dụng thế lực của Cát Liệt để báo thù cho cha, nhưng lại biết được sở dĩ Cát Liệt cầu thân là vì đại ca hắn đang làm con tin ở Đại Đường, cưới nàng là vì muốn giữ chân hoàng đế Đại Đường mà thôi. Đằng sau mọi thủ đoạn lấy lòng của Cát Liệt chính là để lợi dụng thân phận công chúa của nàng để thăm dò tình báo, nhưng lại biết được rằng thân phận công chúa của Lý Tây Phong là giả. Hai người mang lòng thù hận, từ giấu giếm nhau đến lúc yêu nhau, cuối cùng cũng tìm được hạnh phúc mà mình muốn có.</p>","tmdb_id":226890,"cast":["Vương Lộ Tình","Chen Yilong","范迪禹","Nomindalal"],"director":["Wu Yang"],"keywords":[],"tmdb":{"type":"tv","id":"226890","season":1,"vote_average":8,"vote_count":2},"cast_meta":[{"name":"Vương Lộ Tình","name_vi":"Vương Lộ Tình","name_original":"Wang Luqing","tmdb_id":2231067,"profile":"https://image.tmdb.org/t/p/w500/2RnpcMA3uUAo2eiLH5ZZIpvGzHB.jpg","tmdb_url":"https://www.themoviedb.org/person/2231067"},{"name":"Chen Yilong","name_vi":null,"name_original":"Chen Yilong","tmdb_id":2071178,"profile":"https://image.tmdb.org/t/p/w500/npsMxP6s0OOiNiDwxUFpBH6dVbC.jpg","tmdb_url":"https://www.themoviedb.org/person/2071178"},{"name":"范迪禹","name_vi":null,"name_original":"范迪禹","tmdb_id":4072828,"profile":"https://image.tmdb.org/t/p/w500/wcSuNyc83psHuwMUxzETvvE6Z0n.jpg","tmdb_url":"https://www.themoviedb.org/person/40728