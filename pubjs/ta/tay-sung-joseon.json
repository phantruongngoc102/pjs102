ttps://vip.opstream11.com/20220325/5070_ee63c0dd/index.m3u8"},{"name":"40","slug":"40","filename":"Tay súng Joseon - Gunman in Joseon - Tập 40","link_embed":"https://vip.opstream11.com/share/785736838d7b51f2cabb00e6b28a8969","link_m3u8":"https://vip.opstream11.com/20220325/5071_eb2b3940/index.m3u8"},{"name":"41","slug":"41","filename":"Tay súng Joseon - Gunman in Joseon - Tập 41","link_embed":"https://vip.opstream11.com/share/a6e8ad49045f0bef72fb92d7c4a97fed","link_m3u8":"https://vip.opstream11.com/20220325/5072_192a4ea2/index.m3u8"},{"name":"42","slug":"42","filename":"Tay súng Joseon - Gunman in Joseon - Tập 42","link_embed":"https://vip.opstream11.com/share/4ac778418206cc85ac960d5b9134bf74","link_m3u8":"https://vip.opstream11.com/20220325/5073_0b422dd6/index.m3u8"},{"name":"43","slug":"43","filename":"Tay súng Joseon - Gunman in Joseon - Tập 43","link_embed":"https://vip.opstream11.com/share/e1cd50f4a9880333cdad4a24ee9d550c","link_m3u8":"https://vip.opstream11.com/20220325/5074_538f9705/index.m3u8"},{"name":"44","slug":"44","filename":"Tay súng Joseon - Gunman in Joseon - Tập 44","link_embed":"https://vip.opstream11.com/share/23685a2431acad7789c1e3d43ea1522c","link_m3u8":"https://vip.opstream11.com/20220325/5075_3c282154/index.m3u8"}]}],"time":"30 phút/tập","description":"<p>Phim Tay Súng Joseon lấy bối cảnh vào thế kỉ 19, là thời kì có nhiều biến động sâu sắc, bộ phim khắc họa được lòng dũng cảm cũng như nỗi đau của người thanh niên trẻ tuổi Park Yoon Kang, là con trai của đệ nhất kiếm Joseon, vì báo thù cho cha và em gái của mình, đã từ bỏ đao kiếm, trở thành tay súng cừ khôi. Nhân vật Park Yoon Kang của Lee Jun Ki là kiếm khách cuối cùng của thời đại Joseon. Đây là tuyến nhân vật anh hùng của dân tộc, là tay súng được sinh ra giữa loạn lạc chuyển giao thời đại. Nam Sang Mi trong vai Jeong Su In, là người con gái được nuôi dưỡng như bông hoa trong nhà kính, sau đó, nhờ định mệnh, cô đã thay đổi hoàn toàn, trở thành người con gái mạnh mẽ.</p>","tmdb":{"type":"tv","id":"61184","season":1,"vote_average":4.9,"vote_count":14},"modified":"2023-07-12T09:30:55.000Z","cast":["Lee Joon-gi","Nam Sang-mi","Han Joo-wan","Oh Min-suk","Jeon Hye-bin","Yu Oh-seong","Kim Ye-ryeong","Ahn Suk-hwan","Ryohei Otani","Lee Dong-hwi","Kim Hyeon-soo","Sun Woo-chul","Song Ji-ho"],"director":["Kim Jung Min","Cha Young Hoon","Lee Jae Sang"],"cast_meta":[{"name":"Lee Joon-gi","name_vi":null,"name_original":"Lee Joon-gi","tmdb_id":122408,"profile":"https://image.tmdb.org/t/p/w500/tHPJUgGiQRWt1Bh7ymqmmJ2zKF6.jpg","tmdb_url":"https://www.themoviedb.org/person/122408"},{"name":"Nam Sang-mi","name_vi":null,"name_original":"Nam Sang-mi","tmdb_id":87890,"profile":"https://image.tmdb.org/t/p/w500/yath31Jq5ajboNbMS200xFPirn1.jpg","tmdb_url":"https://www.themoviedb.org/person/87890"},{"name":"Han Joo-wan","name_vi":null,"name_original":"Han Joo-wan","tmdb_id":1275152,"profile":"https://image.tmdb.org/t/p/w500/mM571wiVBnGvTvnLzETEX5uSu1.jpg","tmdb_url":"https://www.themoviedb.org/person/1275152"},{"name":"Oh Min-suk","name_vi":null,"name_original":"Oh Min-suk","tmdb_id":980289,"profile":"https://image.tmdb.org/t/p/w500/14gxqx1Wq6lx9c2u5czh9buLdGl.jpg","tmdb_url":"https://www.themoviedb.org/person/980289"},{"name":"Jeon Hye-bin","name_vi":null,"name_original":"Jeon Hye-bin","tmdb_id":1115730,"profile":"https://image.tmdb.org/t/p/w500/Ar9Ol7gk1YQdQqdNaYEgzcIEstY.jpg","tmdb_url":"https://www.themoviedb.org/person/1115730"},{"name":"Yu Oh-seong","name_vi":null,"name_original":"Yu Oh-seong","tmdb_id":80654,"profile":"https://image.tmdb.org/t/p/w500/iNqbeyp8Qoi0Sw2rlKgvwu5rSV2.jpg","tmdb_url":"https://www.themoviedb.org/person/80654"},{"name":"Kim Ye-ryeong","name_vi":null,"name_original":"Kim Ye-ryeong","tmdb_id":1043191,"profile":"https://image.tmdb.org/t/p/w500/SELcbYEye7UnRoN1KpzUzpSO9E.jpg","tmdb_url":"https://www.themoviedb.org/person/1043191"},{"name":"Ahn Suk-hwan","name_vi":null,"name_original":"Ahn Suk-hwan","tmdb_id":1239677,"profile":"https://image.tmdb.org