325/5071_eb2b3940/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream11.com/share/a6e8ad49045f0bef72fb92d7c4a97fed","link_m3u8":"https://vip.opstream11.com/20220325/5072_192a4ea2/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream11.com/share/4ac778418206cc85ac960d5b9134bf74","link_m3u8":"https://vip.opstream11.com/20220325/5073_0b422dd6/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream11.com/share/e1cd50f4a9880333cdad4a24ee9d550c","link_m3u8":"https://vip.opstream11.com/20220325/5074_538f9705/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream11.com/share/23685a2431acad7789c1e3d43ea1522c","link_m3u8":"https://vip.opstream11.com/20220325/5075_3c282154/index.m3u8"}]}],"description":"<p>Phim Tay Súng Joseon lấy bối cảnh vào thế kỉ 19, là thời kì có nhiều biến động sâu sắc, bộ phim khắc họa được lòng dũng cảm cũng như nỗi đau của người thanh niên trẻ tuổi Park Yoon Kang, là con trai của đệ nhất kiếm Joseon, vì báo thù cho cha và em gái của mình, đã từ bỏ đao kiếm, trở thành tay súng cừ khôi. Nhân vật Park Yoon Kang của Lee Jun Ki là kiếm khách cuối cùng của thời đại Joseon. Đây là tuyến nhân vật anh hùng của dân tộc, là tay súng được sinh ra giữa loạn lạc chuyển giao thời đại. Nam Sang Mi trong vai Jeong Su In, là người con gái được nuôi dưỡng như bông hoa trong nhà kính, sau đó, nhờ định mệnh, cô đã thay đổi hoàn toàn, trở thành người con gái mạnh mẽ.</p>","tmdb_id":61184,"cast":[],"director":[],"keywords":[],"tmdb":{"id":61184},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/tay-sung-joseon.json"}