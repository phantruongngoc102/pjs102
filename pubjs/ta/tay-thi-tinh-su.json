/11870_70865d41/index.m3u8"},{"name":"33","slug":"33","filename":"Tây Thi Tình Sử - Hero - Tập 33","link_embed":"https://vip.opstream11.com/share/ebc2aa04e75e3caabda543a1317160c0","link_m3u8":"https://vip.opstream11.com/20220409/11871_d1855853/index.m3u8"},{"name":"34","slug":"34","filename":"Tây Thi Tình Sử - Hero - Tập 34","link_embed":"https://vip.opstream11.com/share/f1558e79c0736bcc9770373fdf03dccb","link_m3u8":"https://vip.opstream11.com/20220409/11872_7fd52251/index.m3u8"},{"name":"35","slug":"35","filename":"Tây Thi Tình Sử - Hero - Tập 35","link_embed":"https://vip.opstream11.com/share/8fbf752a03d27d94c949ca816b453196","link_m3u8":"https://vip.opstream11.com/20220409/11873_3f8e0824/index.m3u8"},{"name":"36","slug":"36","filename":"Tây Thi Tình Sử - Hero - Tập 36","link_embed":"https://vip.opstream11.com/share/786ab8c4d7ee758f80d57e65582e609d","link_m3u8":"https://vip.opstream11.com/20220409/11874_f41c49d6/index.m3u8"},{"name":"37","slug":"37","filename":"Tây Thi Tình Sử - Hero - Tập 37","link_embed":"https://vip.opstream11.com/share/a63105ddeebde57807d9c794ca3b39d6","link_m3u8":"https://vip.opstream11.com/20220409/11875_81126cbb/index.m3u8"},{"name":"38","slug":"38","filename":"Tây Thi Tình Sử - Hero - Tập 38","link_embed":"https://vip.opstream11.com/share/a8e5a72192378802318bf51063153729","link_m3u8":"https://vip.opstream11.com/20220409/11876_985ed409/index.m3u8"},{"name":"39","slug":"39","filename":"Tây Thi Tình Sử - Hero - Tập 39","link_embed":"https://vip.opstream11.com/share/0cc24cb7c26586310cc95c8cb1a81cbc","link_m3u8":"https://vip.opstream11.com/20220409/11877_e79104bc/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Tây Thi Tình Sử - Hero mở đầu bằng tình tiết gia đình Tây Thi gặp nạn vì cha nàng cự tuyệt không làm theo mưu kế “tự sát để đánh lạc hướng quân Ngô” của Câu Tiễn. Trên đường cùng Trịnh Đán chạy trốn, Tây thi đã gặp Phạm Lãi và đem lòng yêu mến chàng. Khi Ngô Vương Phù Sai đánh đến nước Việt, Phạm Lãi được Câu Tiễn phong làm tướng quốc. Để cứu đất nước, Phạm Lãi đã hiến kế lấy Tây Thi dâng cho Phù Sai hòng mê hoặc và làm lung lay tinh thần kẻ địch. Cũng từ đó, liên tiếp những sóng gió đẩy đưa khiến cuộc đời nàng Tây Thi hoàn toàn bước sang một trang khác.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-07-10T10:03:33.000Z","cast":["Trịnh Gia Dĩnh","Chu Hiếu Thiên","Dĩnh Nhi","Tạ Thiên Hoa","Vương Phù Sai"],"director":["Lại Kiến Quốc"],"cast_meta":[{"name":"Trịnh Gia Dĩnh","name_vi":null,"name_original":"Trịnh Gia Dĩnh"},{"name":"Chu Hiếu Thiên","name_vi":null,"name_original":"Chu Hiếu Thiên"},{"name":"Dĩnh Nhi","name_vi":null,"name_original":"Dĩnh Nhi"},{"name":"Tạ Thiên Hoa","name_vi":null,"name_original":"Tạ Thiên Hoa"},{"name":"Vương Phù Sai","name_vi":null,"name_original":"Vương Phù Sai"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ta/tay-thi-tinh-su.json","keywords":[],"tmdb_checked":false}