ndex.m3u8"},{"name":"36","slug":"","filename":"Te Cong 36","link_embed":"https://vip.opstream17.com/share/b77375f945f272a2084c0119c871c13c","link_m3u8":"https://vip.opstream17.com/20240429/6198_a3243f24/index.m3u8"},{"name":"37","slug":"","filename":"Te Cong 37","link_embed":"https://vip.opstream17.com/share/64ff7983a47d331b13a81156e2f4d29d","link_m3u8":"https://vip.opstream17.com/20240429/6197_a916fb8a/index.m3u8"},{"name":"38","slug":"","filename":"Te Cong 38","link_embed":"https://vip.opstream17.com/share/f169b1a771215329737c91f70b5bf05c","link_m3u8":"https://vip.opstream17.com/20240429/6196_eebbd5c3/index.m3u8"},{"name":"39","slug":"","filename":"Te Cong 39","link_embed":"https://vip.opstream17.com/share/03c874ab55baa3c1f835d108415fac44","link_m3u8":"https://vip.opstream17.com/20240429/6195_de6401aa/index.m3u8"},{"name":"40","slug":"","filename":"Te Cong 40","link_embed":"https://vip.opstream17.com/share/af5baf594e9197b43c9f26f17b205e5b","link_m3u8":"https://vip.opstream17.com/20240429/6194_35ec03f6/index.m3u8"},{"name":"41","slug":"","filename":"Te Cong 41","link_embed":"https://vip.opstream17.com/share/24bfde45b5790f04b1d096565157f6a4","link_m3u8":"https://vip.opstream17.com/20240429/6193_21fde705/index.m3u8"},{"name":"42","slug":"","filename":"Te Cong 42","link_embed":"https://vip.opstream17.com/share/f91ceb5afe88b7ab6023892165de4033","link_m3u8":"https://vip.opstream17.com/20240429/6192_8310bbd0/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Câu chuyện về ngài La Hán tên gọi Tế Công tính tình cởi mở,phóng khoáng.Ngài không tuân theo luật đi tu mà thích ăn thịt chó,uống rượu.Tế Công là người hay giải quyết những điều bất bình trong thiên hạ. Phim xoay quanh những chuyện bi hài của cuộc đời Tế Công với nhiều tình tiết vui nhộn sẽ mang lại nhiều tiếng cười cho khán giả. Đây là bộ phim hoàn toàn mới từ cốt truyện đến kỹ thuật, phối hợp tế bào hài hước và tài diễn xuất điêu luyện của Mạch Gia làm sống lại Hòa Thượng Tế Công một Hòa Thượng bê bối, không giữ quy giới, du hý nhân gian, phò nguy tế thế, Tế Công pháp lực cao thâm, chuyên lo chuyện phàm gian, diệt trừ ác bá tham quan, phù nguy giải khốn cho bá tánh, vì muốn hiểu rõ những phiền phức tình cảm trong dân gian, Tế Công có tình cảm và sống chung với Ngô Thiện Liên, bộ phim sử dụng những màn tiếu lâm để dạy đời một cách nhẹ nhàng nhưng có ý nghĩa thâm sâu...</i></p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2024-04-29T20:42:11.000Z","cast":["Mạch Gia","Ngô Thiện Liên","Lương Vĩnh Trung","Tào Tuấn"],"director":["Lương Quốc Quán"],"cast_meta":[{"name":"Mạch Gia","name_vi":null,"name_original":"Mạch Gia"},{"name":"Ngô Thiện Liên","name_vi":null,"name_original":"Ngô Thiện Liên"},{"name":"Lương Vĩnh Trung","name_vi":null,"name_original":"Lương Vĩnh Trung"},{"name":"Tào Tuấn","name_vi":null,"name_original":"Tào Tuấn"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/te/te-cong-truyen-ky-2003.json","keywords":[],"tmdb_checked":false}