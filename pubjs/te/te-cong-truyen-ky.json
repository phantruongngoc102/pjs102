ái tình, quyết tâm tu hành, lấy pháp danh Đạo Tế để thay trời hành đạo, hoàn thành sứ mệnh mà Phật Tổ đã giao phó.</p>","tmdb":{"type":"tv","id":"126146","season":1,"vote_average":0,"vote_count":0},"modified":"2022-07-06T04:08:20.000Z","cast":["Tiêu Chính Nam","Roxanne Tong","Sammy Sum Chun-Hin","Jessica Kan Shuk-Yi","Max Cheung Tat-Lun","Văn Tuyết Nhi","Giang Hân Yến","To Yin-Gor","Rebecca Chan"],"director":["Thi Tuấn Kiệt"],"cast_meta":[{"name":"Tiêu Chính Nam","name_vi":"Tiêu Chính Nam","name_original":"Edwin Siu","tmdb_id":1059226,"profile":"https://image.tmdb.org/t/p/w500/bPEjnmBPWTZcrWQklkqcT1bUQwb.jpg","tmdb_url":"https://www.themoviedb.org/person/1059226"},{"name":"Roxanne Tong","name_vi":null,"name_original":"Roxanne Tong","tmdb_id":1967121,"profile":"https://image.tmdb.org/t/p/w500/zLbZGXfvhKbJpReSEECiedarfeg.jpg","tmdb_url":"https://www.themoviedb.org/person/1967121"},{"name":"Sammy Sum Chun-Hin","name_vi":null,"name_original":"Sammy Sum Chun-Hin","tmdb_id":1143687,"profile":"https://image.tmdb.org/t/p/w500/14JvAGteXhwqciX0uNAwdGaC20K.jpg","tmdb_url":"https://www.themoviedb.org/person/1143687"},{"name":"Jessica Kan Shuk-Yi","name_vi":null,"name_original":"Jessica Kan Shuk-Yi","tmdb_id":2165679,"profile":"https://image.tmdb.org/t/p/w500/hhpFepjAl8YDSojSZbOuCiOh0c1.jpg","tmdb_url":"https://www.themoviedb.org/person/2165679"},{"name":"Max Cheung Tat-Lun","name_vi":null,"name_original":"Max Cheung Tat-Lun","tmdb_id":2064580,"profile":"https://image.tmdb.org/t/p/w500/1ZSkCer0mTgl37IRlbqi0euypIU.jpg","tmdb_url":"https://www.themoviedb.org/person/2064580"},{"name":"Văn Tuyết Nhi","name_vi":"Văn Tuyết Nhi","name_original":"Candy Man","tmdb_id":240164,"profile":"https://image.tmdb.org/t/p/w500/uEiYm0iTAOnWNJHFNwhnBJ11c0K.jpg","tmdb_url":"https://www.themoviedb.org/person/240164"},{"name":"Giang Hân Yến","name_vi":"Giang Hân Yến","name_original":"Alvina Kong Yan-Yin","tmdb_id":240927,"profile":"https://image.tmdb.org/t/p/w500/96pcgW1IxSCXyHwmghrdow6SVbn.jpg","tmdb_