865b834ce8c3cfc0ad3adee5e64","link_m3u8":"https://vip.opstream16.com/20231119/37724_bf68f401/index.m3u8"},{"name":"07","slug":"","filename":"Te Suu Vo Diem 07","link_embed":"https://vip.opstream16.com/share/0c7f4235270e061c4a70e6135a50f019","link_m3u8":"https://vip.opstream16.com/20231119/37723_b9e3837f/index.m3u8"},{"name":"08","slug":"","filename":"Te Suu Vo Diem 08","link_embed":"https://vip.opstream16.com/share/d9106553cc5dcab924a87b57eb707fdd","link_m3u8":"https://vip.opstream16.com/20231120/37755_0ba3d13f/index.m3u8"},{"name":"09","slug":"","filename":"Te Suu Vo Diem 09","link_embed":"https://vip.opstream16.com/share/3a3b7accf5943bdf3781f2afa5ccd1eb","link_m3u8":"https://vip.opstream16.com/20231119/37721_66a9efb6/index.m3u8"},{"name":"10","slug":"","filename":"Te Suu Vo Diem 10","link_embed":"https://vip.opstream16.com/share/6a26800f2276dd0c5a7b6cf491647f96","link_m3u8":"https://vip.opstream16.com/20231119/37720_b27b6cfd/index.m3u8"},{"name":"11","slug":"","filename":"Te Suu Vo Diem 11","link_embed":"https://vip.opstream16.com/share/abd69bbc2c51e3be894a2b70d08ee4fc","link_m3u8":"https://vip.opstream16.com/20231119/37719_5c9ba019/index.m3u8"},{"name":"12-End","slug":"","filename":"Te Suu Vo Diem 12end","link_embed":"https://vip.opstream16.com/share/06a86f0e78a16e1a8628128cf1fd3a9f","link_m3u8":"https://vip.opstream16.com/20231119/37718_0a8a3bfc/index.m3u8"}]}],"time":"40 phút/tập","description":"<p><i>Tề Sửu Vô Diệm lấy bối cảnh thời Xuân Thu Chiến Quốc, các nước chư hầu phân tranh. Trong số bảy nước mạnh, Tề quốc được coi như là quốc gia mạnh nhất. Tề Uy Vương băng hà, truyền lại ngôi cho Tề Tuyên Vương (Cao Hải Thành). Tề Tuyên Vương trầm mê tửu sắc, không quan tâm đến chính sự quốc gia. Ngọc Hoàng Đại Đế có bảy người con gái, trong đó Lục công chúa xinh đẹp lương thiện, thương xót lê dân bách tính, quyết tâm hạ phàm để cứu vớt bách tích khỏi khổ nạn lầm than. Nhưng nàng không thể hạ phàm với thân phận tiên nữ, đành phải đội lên mình vỏ bọc ngoại hình của Dạ Xoa mới có thể hạ phàm giúp đỡ dân chúng. Nàng đầu thai ở Chung Li thôn - một vùng rừng núi rộng lớn, nên lấy tên là Chung Li Vô Diệm. Vì ngoại hình xấu xí, da xanh ngắt, tóc xấu, từ nhỏ ít có người lại gần nàng. Nàng lại yêu thích học săn bắt tập võ, học chữ. Nàng trở thành một người tài giỏi, trên thông thiên văn dưới tường địa lý. Sau này, nàng trở thành hoàng hậu của Tề Tuyên Vương, giúp vua Tề chú tâm hơn đến việc trị quốc. Thời Tề Tuyên Vương tại vị, không có nước nào đến xâm lăng.</i></p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-11-20T09:28:37.000Z","cast":["Hác Văn Đình","Cao Hải Thành","Vũ Hồng Ngôn","Lập Phi","Trịnh Long"],"director":["Lý Học Chính","Từ Hiến Phong"],"cast_meta":[{"name":"Hác Văn Đình","name_vi":null,"name_original":"Hác Văn Đình"},{"name":"Cao Hải Thành","name_vi":null,"name_original":"Cao Hải Thành"},{"name":"Vũ Hồng Ngôn","name_vi":null,"name_original":"Vũ Hồng Ngôn"},{"name":"Lập Phi","name_vi":null,"name_original":"Lập Phi"},{"name":"Trịnh Long","name_vi":null,"name_original":"Trịnh Long"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/te/te-suu-vo-diem.json","keywords":[],"tmdb_checked":false}