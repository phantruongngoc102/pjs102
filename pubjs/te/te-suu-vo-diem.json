f019","link_m3u8":"https://vip.opstream16.com/20231119/37723_b9e3837f/index.m3u8"},{"name":"08","slug":"08","link_embed":"https://vip.opstream16.com/share/d9106553cc5dcab924a87b57eb707fdd","link_m3u8":"https://vip.opstream16.com/20231120/37755_0ba3d13f/index.m3u8"},{"name":"09","slug":"09","link_embed":"https://vip.opstream16.com/share/3a3b7accf5943bdf3781f2afa5ccd1eb","link_m3u8":"https://vip.opstream16.com/20231119/37721_66a9efb6/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream16.com/share/6a26800f2276dd0c5a7b6cf491647f96","link_m3u8":"https://vip.opstream16.com/20231119/37720_b27b6cfd/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream16.com/share/abd69bbc2c51e3be894a2b70d08ee4fc","link_m3u8":"https://vip.opstream16.com/20231119/37719_5c9ba019/index.m3u8"},{"name":"12-End","slug":"12-end","link_embed":"https://vip.opstream16.com/share/06a86f0e78a16e1a8628128cf1fd3a9f","link_m3u8":"https://vip.opstream16.com/20231119/37718_0a8a3bfc/index.m3u8"}]}],"description":"<p><i>Tề Sửu Vô Diệm lấy bối cảnh thời Xuân Thu Chiến Quốc, các nước chư hầu phân tranh. Trong số bảy nước mạnh, Tề quốc được coi như là quốc gia mạnh nhất. Tề Uy Vương băng hà, truyền lại ngôi cho Tề Tuyên Vương (Cao Hải Thành). Tề Tuyên Vương trầm mê tửu sắc, không quan tâm đến chính sự quốc gia. Ngọc Hoàng Đại Đế có bảy người con gái, trong đó Lục công chúa xinh đẹp lương thiện, thương xót lê dân bách tính, quyết tâm hạ phàm để cứu vớt bách tích khỏi khổ nạn lầm than. Nhưng nàng không thể hạ phàm với thân phận tiên nữ, đành phải đội lên mình vỏ bọc ngoại hình của Dạ Xoa mới có thể hạ phàm giúp đỡ dân chúng. Nàng đầu thai ở Chung Li thôn - một vùng rừng núi rộng lớn, nên lấy tên là Chung Li Vô Diệm. Vì ngoại hình xấu xí, da xanh ngắt, tóc xấu, từ nhỏ ít có người lại gần nàng. Nàng lại yêu thích học săn bắt tập võ, học chữ. Nàng trở thành một người tài giỏi, trên thông thiên văn dưới tường địa lý. Sau này, nàng trở thành hoàng hậu của Tề Tuyên Vương, giúp vua Tề chú tâm hơn đến việc trị quốc. Thời Tề Tuyên Vương tại vị, không có nước nào đến xâm lăng.</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/te/te-suu-vo-diem.json","tmdb_checked":false}