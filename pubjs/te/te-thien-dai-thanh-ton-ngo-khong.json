ex.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream12.com/share/b89bd6465f1baed1810a82e1d5138f52","link_m3u8":"https://vip.opstream12.com/20251214/30851_b89bd646/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/97bf6036e7669246dad4e84d1abec531","link_m3u8":"https://vip.opstream12.com/20251214/30852_97bf6036/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/27ac0ca86e06d1822d546ed038ea33ae","link_m3u8":"https://vip.opstream12.com/20251214/30853_27ac0ca8/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/f3535a949e0637d4894131d516649a5f","link_m3u8":"https://vip.opstream12.com/20251214/30854_f3535a94/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream12.com/share/c2090502cd75f701449abad130cce798","link_m3u8":"https://vip.opstream12.com/20251214/30855_c2090502/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream12.com/share/41f59478b82ac344e8f8e229d8e080f3","link_m3u8":"https://vip.opstream12.com/20251214/30856_41f59478/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream12.com/share/159f02cdca45838bdfe5ecdeadb520be","link_m3u8":"https://vip.opstream12.com/20251214/30822_159f02cd/index.m3u8"},{"name":"Tập 36","slug":"36"}]}],"description":"<p>175 triệu năm về trước, có ba cục vãn thạch bay ra ngoài không gian. Ba cục đá này rơi rớt ở ba vị trí khác nhau, và biến thành 3 người khác nhau. Cứ mỗi 200 triệu năm, thái dương sẽ nổ tung và tạo thành bão tố trong vũ trụ. Thiên Khí của thiên đình sẽ bị giảm đi và Supreme Demon, đại diên cho một sức mạnh tà khí sẽ xuất hiện. Chỉ có một cách để tiêu diệt Supreme Demon đó là tìm cho ra một người sanh vào giờ chỉ định, nguời đó sẽ được bảo vệ bởi 1 trong 3 cục vãn thạch để đến lấy \"Tam Tạng Kinh\". Cục vãn thạch này sẽ đi tìm kiếm hai cục vãn thạch khác trong thời gian đi lấy Tây Kinh. Ba cục vãn thạch sẽ hợp thành một dưới sức mạnh của Tây Kinh, để tiêu diệt Supreme Demon khi nó xuất hiện. Còn ngược lại, thế giới sẽ bị đảo lộn và tà khí sẽ bao trùm vũ trụ.</p>","tmdb_id":21058,"cast":["Trương Vệ Kiện","Eric Kot Man-Fai","Lý Xán Sâm","Edmond Leung Hon-Man","Lâm Chí Dĩnh","Thái Trác Nghiên","Chung Hân Đồng","Dương Cung Như","Tạ Đình Phong","Hoàng Nhất Phi","Stephanie Siao","Từ Hi Viên","Yuki Hsu","Viên Vịnh Nghi","La Gia Anh"],"director":["Fung Pak Yuen","Wai-Ming Wong"],"keywords":[],"tmdb":{"type":"tv","id":"21058","season":1,"vote_average":6.5,"vote_count":4},"cast_meta":[{"name":"Trương Vệ Kiện","name_vi":"Trương Vệ Kiện","name_original":"Dicky Cheung Wai-Kin","tmdb_id":83489,"profile":"https://image.tmdb.org/t/p/w500/b2a2h0Xz4pDk7B0WDFADvzc5S1g.jpg","tmdb_url":"https://www.themoviedb.org/person/83489"},{"name":"Eric Kot Man-Fai","name_vi":null,"name_original":"Eric Kot Man-Fai","tmdb_id":68561,"profile":"https://image.tmdb.org/t/p/w500/1lnpAb3knAXGXauaXX2NiGqpNQz.jpg","tmdb_url":"https://www.themoviedb.org/person/68561"},{"name":"Lý Xán Sâm","name_vi":"Lý Xán Sâm","name_original":"Sam Lee","tmdb_id":74193,"profile":"https://image.tmdb.org/t/p/w500/8bPqONKhCJkYKGPL0wKhdjR1Shv.jpg","tmdb_url":"https://www.themoviedb.org/person/74193"},{"name":"Edmond Leung Hon-Man","name_vi":null,"name_original":"Edmond Leung Hon-Man","tmdb_id":110846,"profile":"https://image.tmdb.org/t/p/w500/kjbq0Xs1qlazEJ700t1VLEH2G0O.jpg","tmdb_url":"https://www.themoviedb.org/person/110846"},{"name":"Lâm Chí Dĩnh","name_vi":"Lâm Chí Dĩnh","name_original":"Jimmy Lin Chih-Ying","tmdb_id":123801,"profile":"https://image.tmdb.org/t/p/w500/aS0aqrBHa4THPOQY1LidsRZytci.jpg","tmdb_url":"https://www.themoviedb.org/person/123801"},{"name":"Thái Trác Nghiên","name_vi":"Thái Trác Nghiên","name_original":"Charlene Choi Chuek-Yin","tmdb_id":64434,"profile":"https://image.tmdb.org/t/p/w500/9f4cT2AgaDsvEwMQRirs0w01mF1.jpg","tmdb_url":"https://www.themoviedb.org/person/64434"},{"name":"Chung Hân Đồng","name_vi":"Chung Hân Đồng","name_original":"Gillian C