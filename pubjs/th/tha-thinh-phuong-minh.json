ip.opstream10.com/share/f46a7537f2a4d9cb860b5969ed5da1db","link_m3u8":"https://vip.opstream10.com/20220606/19141_05f29b88/index.m3u8"},{"name":"29","slug":"29","filename":"tha-thinh-phuong-minh-thuyet-minh-dance-of-the-phoenix-tap-29","link_embed":"https://vip.opstream10.com/share/cd7d952b109ea30fa0b8b59c7b7be36d","link_m3u8":"https://vip.opstream10.com/20220606/19143_da94629c/index.m3u8"},{"name":"30","slug":"30","filename":"tha-thinh-phuong-minh-thuyet-minh-dance-of-the-phoenix-tap-30","link_embed":"https://vip.opstream10.com/share/458858fb060a54dc9edccb7a14ccbe68","link_m3u8":"https://vip.opstream10.com/20220606/19146_5fc7200e/index.m3u8"}]}],"time":"","description":"<p>Thả Thính Phượng Minh xoay quanh thiên tài thiếu nữ Phượng Vũ bị kẻ thù Tả Thanh Loan lên kế hoạch ám sát khiến nàng mất đi dòng máu chân chính của phượng hoàng và trở thành phế nhân. Cùng lúc đó, cô sinh viên đại học chuyên ngành đông y Mạnh Viện vì một sự cố mà xuyên không vào giới tu tiên, tỉnh lại dưới thân phận Phượng Vũ. Từ đây, Mạnh Viện đã dùng sự thông minh và kiến thức đông y ở thời hiện đại của mình để bảo vệ người nhà ở một thế giới khác. Nàng gặp gỡ và viết nên câu chuyện tình yêu đầy ngọt ngào với Thánh tử Quân Lâm Uyên của gia tộc đứng đầu Quân Vũ.​</p>","tmdb":{"type":"tv","id":"107231","season":1,"vote_average":5.5,"vote_count":6},"modified":"2022-06-08T15:45:42.000Z","cast":["Dương Siêu Việt","Từ Khai Sính","Fu Jing","Vương Hạo Hiên","Quách Thừa","Dong Yan","Yao Shuhao"],"director":["Chan Ka-Lam"],"cast_meta":[{"name":"Dương Siêu Việt","name_vi":"Dương Siêu Việt","name_original":"Yang Chaoyue","tmdb_id":2396870,"profile":"https://image.tmdb.org/t/p/w500/fIqlPh8S13ttFRTnHC2XZnmGc4C.jpg","tmdb_url":"https://www.themoviedb.org/person/2396870"},{"name":"Từ Khai Sính","name_vi":"Từ Khai Sính","name_original":"Xu Kaicheng","tmdb_id":1512741,"profile":"https://image.tmdb.org/t/p/w500/vl4dUEJlVOJ4Duq7Q4r23JQDGyH.jpg","tmdb_url":"https://www.themoviedb.org/person/1512741"},{"name":"Fu Jin