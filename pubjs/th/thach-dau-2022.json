940b7bc12af1ceb9b3d3754634ae3e","link_m3u8":"https://vip.opstream13.com/20251021/13491_61940b7b/index.m3u8"},{"name":"24","slug":"24","filename":"Thách Đấu - Tập 24---2022","link_embed":"https://vip.opstream13.com/share/799974951f19a0c730acda2389cc852b","link_m3u8":"https://vip.opstream13.com/20251021/13492_79997495/index.m3u8"}]}],"time":"47 phút/tập","description":"<p>Tại tỉnh Quảng Đông phát triển kinh tế ở miền Đông, huyện Lạc Nguyên là huyện lỵ có tình trạng an ninh công cộng thấp nhất, và làn sóng càn quét diệt trừ tà ác đã nhấn chìm nơi này. Trên đường điều tra một vụ án nổ súng, cảnh sát hình sự trẻ tuổi Ngô Kiến đã gặp phải sự cản trở của thế lực ngầm, và chứng cứ anh ta giao nộp cho cảnh sát đã biến mất. Anh ta không thể xóa bỏ nghi ngờ, chỉ có Văn Lộ Dương kiên quyết tin tưởng Ngô Kiến và mời anh ta hợp tác với Đội Đặc nhiệm. Văn Lộ Dương, người không chơi bài theo lệ thường, và anh chàng chính trực Ngô Kiến, người có lúc dày lúc mỏng, đã tạo thành một cặp đôi phá án với phong cách hoàn toàn khác biệt.</p>","tmdb":{"type":"tv","id":"201531","season":1,"vote_average":10,"vote_count":1},"modified":"2025-10-23T11:28:44.000Z","cast":["Âu Hào","Vương Cảnh Xuân","Lü Xiaolin","Đinh Dũng Đại","Zhao Yang","Xing Hanqing","Li Hongchen","Sun Rui"],"director":["Zhou Linhao"],"cast_meta":[{"name":"Âu Hào","name_vi":"Âu Hào","name_original":"Ou Hao","tmdb_id":1355667,"profile":"https://image.tmdb.org/t/p/w500/nHokLSjlWJB3Gwt3zBXUuBPvR77.jpg","tmdb_url":"https://www.themoviedb.org/person/1355667"},{"name":"Vương Cảnh Xuân","name_vi":"Vương Cảnh Xuân","name_original":"Wang Jingchun","tmdb_id":1288449,"profile":"https://image.tmdb.org/t/p/w500/hc5Qcb6NXWmW8PXEqEJOv9WHYF6.jpg","tmdb_url":"https://www.themoviedb.org/person/1288449"},{"name":"Lü Xiaolin","name_vi":null,"name_original":"Lü Xiaolin","tmdb_id":1909342,"profile":"https://image.tmdb.org/t/p/w500/mY06Aa7UuBTbjTZ8Gab7DFD9UH0.jpg","tmdb_url":"https://www.themoviedb.org/person/1909342"},{"name":"Đinh Dũng Đại","name_v