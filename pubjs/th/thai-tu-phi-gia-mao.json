p.opstream11.com/20220407/10864_3a21b596/index.m3u8"},{"name":"23","slug":"23","filename":"Thái Tử Phi Giả Mạo - Fake Princess - Tập 23","link_embed":"https://vip.opstream11.com/share/4d171e8c3b2ef70c7afb02614b99e632","link_m3u8":"https://vip.opstream11.com/20220407/10865_b1e2fda4/index.m3u8"},{"name":"24","slug":"24","filename":"Thái Tử Phi Giả Mạo - Fake Princess - Tập 24","link_embed":"https://vip.opstream11.com/share/23f35020df135821bc9a1c51e3900047","link_m3u8":"https://vip.opstream11.com/20220407/10866_80fac48c/index.m3u8"},{"name":"25","slug":"25","filename":"Thái Tử Phi Giả Mạo - Fake Princess - Tập 25","link_embed":"https://vip.opstream11.com/share/685d3703a0b1410dc3bf2280eb5a15ec","link_m3u8":"https://vip.opstream11.com/20220407/10867_84d5d20a/index.m3u8"},{"name":"26","slug":"26","filename":"Thái Tử Phi Giả Mạo - Fake Princess - Tập 26","link_embed":"https://vip.opstream11.com/share/c432976945dc8b1ac46792dfa97ea068","link_m3u8":"https://vip.opstream11.com/20220407/10868_7d5f0844/index.m3u8"},{"name":"27","slug":"27","filename":"Thái Tử Phi Giả Mạo - Fake Princess - Tập 27","link_embed":"https://vip.opstream11.com/share/b14fba037d119d307e3b6ceb2a9fbb31","link_m3u8":"https://vip.opstream11.com/20220407/10869_dac67d0e/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>Thái Tử Phi Giả Mạo - Fake Princess kể về nhât vật Thường Lạc, con gái của Lưu gia. Từ nhỏ, cô đã được cha mẹ chiều chuộng nên tính cách bướng bỉnh, thích ngao du thiên hạ. Trong một lần bỏ nhà lên núi làm sơn tặc đại vương, Thường Lạc đụng độ với hoàng tử điện hạ Lý Triệt. Để có được một rương vàng, nàng quyết định cưới thái tử, nhưng tất cả quá trình thành hôn đều được làm giả. Tuy nhiên, Lý Triệt không thể ngờ rằng cậu đụng phải một cô nàng cá tính ngang bướng hơn cả mình. Hai người tuy mỗi người đều mang một mặt nạ, nhưng họ đã cùng chia sẻ buồn vui, hoạn nạn, và cuối cùng là vượt qua mọi chông gai, cùng nắm tay nhau bước lên đỉnh danh vọng cao nhất.</p>","tmdb":{"type":"tv","id":"103904","season":1,"vote_average":5,"vote_count":3},"modified":"2023-04-17T20:01:19.000Z","cast":["Lý Khải Hinh","Triệu Dịch Khâm","Kim Trạch","Tôn Tuyết Ninh","Chen Siyu","Wang Yitian"],"director":["Tần Tần"],"cast_meta":[{"name":"Lý Khải Hinh","name_vi":"Lý Khải Hinh","name_original":"Eleanor Lee","tmdb_id":2126495,"profile":"https://image.tmdb.org/t/p/w500/xeYJamjizAVbUtSR2daLISDmlBV.jpg","tmdb_url":"https://www.themoviedb.org/person/2126495"},{"name":"Triệu Dịch Khâm","name_vi":"Triệu Dịch Khâm","name_original":"Zhao Yiqin","tmdb_id":1879667,"profile":"https://image.tmdb.org/t/p/w500/5QiIAqWAAzuhbDQ9MwGTpMtUlYj.jpg","tmdb_url":"https://www.themoviedb.org/person/1879667"},{"name":"Kim Trạch","name_vi":"Kim Trạch","name_original":"Jin Ze","tmdb_id":2595206,"profile":"https://image.tmdb.org/t/p/w500/MOjid8gln59Qpkn4f3COwPS7AS.jpg","tmdb_url":"https://www.themoviedb.org/person/2595206"},{"name":"Tôn Tuyết Ninh","name_vi":"Tôn Tuyết Ninh","name_original":"Sun Xuening","tmdb_id":1905964,"profile":"https://image.tmdb.org/t/p/w500/ljAAA4TIWc6v1clXp7Hh9jYOPVh.jpg","tmdb_url":"https://www.themoviedb.org/person/1905964"},{"name":"Chen Siyu","name_vi":null,"name_original":"Chen Siyu","tmdb_id":1745761,"profile":"https://image.tmdb.org/t/p/w500/xtOsaSh4O3HHXCjttcp9tujTdnP.jpg","tmdb_url":"https://www.themoviedb.org/person/1745761"},{"name":"Wang Yitian","name_vi":null,"name_original":"Wang Yitian","tmdb_id":3149871,"profile":"https://image.tmdb.org/t/p/w500/ybHS39ZbhG6TXcNF4BBytdrp4gW.jpg","tmdb_url":"https://www.themoviedb.org/person/3149871"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thai-tu-phi-gia-mao.json"}