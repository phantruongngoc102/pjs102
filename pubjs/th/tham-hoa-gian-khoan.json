{"id":"62370d083d016a3b6717e8a2","title":"Tham Hoa Giàn Khoan","origin_name":"Deepwater Horizon","slug":"tham-hoa-gian-khoan","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/th/tham-hoa-gian-khoan.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/th/tham-hoa-gian-khoan.webp","year":2016,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a22ace0fc277084dfd531","name":"Kinh Dị","slug":"kinh-di"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620a2347e0fc277084dfd876","name":"Hồng Kông","slug":"hong-kong"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Tham Hoa Giàn Khoan","link_embed":"https://vip.opstream12.com/share/fa612be4940bae15b019b36f9282c5ab","link_m3u8":"https://vip.opstream12.com/20220318/4286_cb7ce94e/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Vào tháng Tư năm 2010, không có hoạt động thăm dò dầu ở Vịnh Mexico để so sánh với các giàn khoan dầu Deepwater Horizon với kích thước của nó hoặc chiều sâu tuyệt khoan của nó . Tuy nhiên, các dự án cho các công ty dầu khí BP đang bao vây với những khó khăn kỹ thuật cho các điểm mà người giám sát nói chung hoạt động, Jimmy Harrell , và kỹ sư trưởng điện của mình, Mike Williams , đang lo ngại rắc rối nguy hiểm tiềm tàng là sản xuất bia . Thật không may , tham quan giám đốc điều hành BP, thất vọng bởi sự chậm trễ dài của dự án , trình tự cắt kiểm tra trang web và kiểm tra hệ thống nghiêng để bù đắp cho thời gian đã mất ngay cả khi Harrell , Williams và nhóm của ông bất lực phản đối vì lợi ích của an toàn thích hợp. Vào ngày 20, những lo ngại của người lao được thực hiện theo cách tồi tệ nhất có thể khi nhiều sai sót về cấu trúc và hệ thống của giàn khoan gây ra một tầng thảm khốc của những thất bại đó sẽ tạo ra một blowout khổng lồ nổ đe dọa tất cả, ngay cả khi nó cũng bắt đầu các môi trường tồi tệ nhất thảm họa trong lịch sử Hoa Kỳ .</p>","tmdb":{"type":"movie","id":"296524","season":null,"vote_average":6.891,"vote_count":4798},"modified":"2024-10-23T11:12:16.000Z","cast":["Mark Wahlberg","Kurt Russell","John Malkovich","Gina Rodriguez","Dylan O'Brien","Kate Hudson","J.D. Evermore","Ethan Suplee","Dave Maldonado","Henry Frost","Jeremy Sande","Brad Leland","Douglas M. Griffin","Joe Chrest","James DuMont"],"director":["Peter Berg"],"cast_meta":[{"name":"Mark Wahlberg","name_vi":null,"name_original":"Mark Wahlberg","tmdb_id":13240,"profile":"https://image.tmdb.org/t/p/w500/1Oc3XSLyb8hxmjmlgFENu582Kqw.jpg","tmdb_url":"https://www.themoviedb.org/person/13240"},{"name":"Kurt Russell","name_vi":null,"name_original":"Kurt Russell","tmdb_id":6856,"profile":"https://image.tmdb.org/t/p/w500/6g1d98oH4miG4k0ZiZWmF3Dt0bO.jpg","tmdb_url":"https://www.themoviedb.org/person/6856"},{"name":"John Malkovich","name_vi":null,"name_original":"John Malkovich","tmdb_id":6949,"profile":"https://image.tmdb.org/t/p/w500/7GoOdGNc4ra1L0F5nJTkmIB37iu.jpg","tmdb_url":"https://www.themoviedb.org/person/6949"},{"name":"Gina Rodriguez","name_vi":null,"name_original":"Gina Rodriguez","tmdb_id":180486,"profile":"https://image.tmdb.org/t/p/w500/2Mw6L8gpAhnXAgmJZkz85YxVmOt.jpg","tmdb_url":"https://www.themoviedb.org/person/180486"},{"name":"Dylan O'Brien","name_vi":null,"name_original":"Dylan O'Brien","tmdb_id":527393,"profile":"https://image.tmdb.org/t/p/w500/xN3GdvIlqsR838gDoblhPH0numP.jpg","tmdb_url":"https://www.themoviedb.org/person/527393"},{"name":"Kate Hudson","name_vi":null,"name_original":"Kate Hudson","tmdb_id":11661,"profile":"https://image.tmdb.org/t/p/w500/s79lH1QzEg2fkXULKBxRmU9aNr8.jpg","tmdb_url":"https://www.themoviedb.org/person/11