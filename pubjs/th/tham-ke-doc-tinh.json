vip.opstream12.com/20220627/22572_082c6f6b/index.m3u8"},{"name":"24A","slug":"24a","link_embed":"https://vip.opstream12.com/share/23275f3844585a6a9bbb627837278e13","link_m3u8":"https://vip.opstream12.com/20220627/22573_4da38120/index.m3u8"},{"name":"24B","slug":"24b","link_embed":"https://vip.opstream12.com/share/4eb9407d63d543de5afcd082d88280f4","link_m3u8":"https://vip.opstream12.com/20220627/22574_19f77cd2/index.m3u8"}]}],"description":"<p>Phing là một cô gái bình thường và thừa cân. Cô ấy sống nội tâm nhưng cô ấy có một trái tim nhân hậu bởi vì người ông của cô ấy đã nuôi dạy cô ấy luôn khuyến khích cô ấy giúp đỡ người khác. Mặt khác, Han, học trò của ông nội, luôn nghĩ về bản thân. Phing thiếu các kỹ năng xã hội nên Fei có cơ hội đến gần và kết hôn với cô ấy vì lợi ích nhưng đây lại là sự khởi đầu cho thảm họa của cuộc đời cô. Cô ấy đang phải đối mặt với một bà mẹ chồng kinh khủng và người chồng của cô ấy đang lừa dối cô ấy với công nhân của cô ấy. Cuối cùng, cô biết sự thật nhưng những người này cố gắng đầu độc và chôn sống cô và ông nội cô. May mắn thay, Korn, người mà ông cô đã giúp đỡ từ lâu, có thể cứu cô và ông của cô. Sau khi sống sót, Phing đã biến thành May, một phụ nữ quyến rũ với trái tim đầy giận dữ.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/tham-ke-doc-tinh.json","tmdb_checked":false}