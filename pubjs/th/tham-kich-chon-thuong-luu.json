om/share/10a9288f519d683f87f6443f7b6810e6","link_m3u8":"https://vip.opstream11.com/20220411/13266_665a7bcb/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream11.com/share/4049f46696d549c65f5832e15664afdd","link_m3u8":"https://vip.opstream11.com/20220411/13267_b8de6991/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream11.com/share/951cb7fcf08241d659513d4e84acdfaa","link_m3u8":"https://vip.opstream11.com/20220411/13268_dac16781/index.m3u8"}]}],"description":"<p>Thảm Kịch Chốn Thượng Lưu - The Road: Tragedy of One là bộ phim mới nhất về xã hội thượng lưu với sự tham gia của Ji Jin Hee, Yoon Se Ah và Kim Hye Eun. Bộ phim tập trung vào cuộc sống bí ẩn, tham vọng và sự xấu hổ của những cư dân sống trong dinh thự biệt lập \"Royal the Hill\". Trong số cư dân có Baek Soo Hyun (Ji Jin Hee), nhà báo nổi tiếng, được kính trọng nhưng bản chất tàn nhẫn, lạnh lùng và khó đoán. Soo Hyun kết hôn với Seo Eun Soo (Yoon Se Ah), con gái của giám đốc điều hành công ty quyền lực. Ngoài ra là Cha Seo Young (Kim Hye Eun), phát thanh viên truyền hình xinh đẹp, có nền tảng giáo dục tốt nhưng không bao giờ hài lòng với cuộc sống của mình.</p>","tmdb_id":127016,"cast":["Ji Jin-hee","Yoon Se-a","Kim Hye-eun","Cheon Ho-jin","Ahn Nae-sang","Kim Sung-su","Kang Sung-min","Ju Ye-eun","Kim Min-joon","Kim Roi-ha","Baek Ji-won","Ha-min"],"director":["Kim Nowon"],"keywords":[],"cast_meta":[{"name":"Ji Jin-hee","name_vi":null,"name_original":"Ji Jin-hee","tmdb_id":145989,"profile":"https://image.tmdb.org/t/p/w500/7O6u0vn1SafFgcyJwP4rJwBfvaR.jpg","tmdb_url":"https://www.themoviedb.org/person/145989"},{"name":"Yoon Se-a","name_vi":null,"name_original":"Yoon Se-a","tmdb_id":232408,"profile":"https://image.tmdb.org/t/p/w500/wdytv8MZeNjulCR4nMmpreuDS6w.jpg","tmdb_url":"https://www.themoviedb.org/person/232408"},{"name":"Kim Hye-eun","name_vi":null,"name_original":"Kim Hye-eun","tmdb_id":1299278,"profile":"https://image.tmdb.org/t/p/w500/qoOOqPCwoNoZpZuelhOG1M4klgK.jpg