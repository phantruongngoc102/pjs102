ilename":"The.Mentalist.S01E22.1080p.BluRay.x265-RARBG","link_embed":"https://vip.opstream15.com/share/2ab5569b4274a31c7f2b7c67cd9ba9e2","link_m3u8":"https://vip.opstream15.com/20230115/31741_880237f1/index.m3u8"},{"name":"23","slug":"23","filename":"The.Mentalist.S01E23.1080p.BluRay.x265-RARBG","link_embed":"https://vip.opstream15.com/share/c545987fb970f7b1f05c9f2a2f3340dd","link_m3u8":"https://vip.opstream15.com/20230115/31742_4f24e03e/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Chuyện phim xoay quanh cuộc hành trình tìm kiếm hung thủ đã sát hại vợ và con gái mình của Patrick Jane. Trước khi thảm kịch xảy đến với gia đình mình, Jane có một sự nghiệp thành công. Nhờ khả năng thôi miên, nắm bắt tâm lý và nhất là khả năng quan sát kỳ tài, anh đã trở nên nổi tiếng bằng việc giả làm một nhà tâm linh. Để khẳng định tài năng của mình, Jane đã xuất hiện trên truyền hình và tuyên bố mình đã giúp cảnh sát phác họa tiểu sử của tên giết người hàng loạt Red John. Tức giận vì bị xem thường, Red John đã giết vợ và con gái Jane để trả thù. Ngay sau thảm kịch, Jane bỏ nghề, trở thành là một cố vấn viên độc lập của phòng điều tra tội phạm bang California (CBI) với hy vọng tìm ra kẻ thủ ác.</p>","tmdb":{"type":"tv","id":"5920","season":1,"vote_average":8.358,"vote_count":4060},"modified":"2023-01-16T04:58:03.000Z","cast":["Simon Baker","Robin Tunney","Tim Kang","Rockmond Dunbar","Joe Adler","Josie Loren"],"director":["Adam Kane"],"cast_meta":[{"name":"Simon Baker","name_vi":null,"name_original":"Simon Baker","tmdb_id":1284159,"profile":"https://image.tmdb.org/t/p/w500/8RPbdwSOJ3DEQDQaj05zBFaUu5f.jpg","tmdb_url":"https://www.themoviedb.org/person/1284159"},{"name":"Robin Tunney","name_vi":null,"name_original":"Robin Tunney","tmdb_id":17346,"profile":"https://image.tmdb.org/t/p/w500/vOmWyYNoVEaPPvoto4IW8dSXn7I.jpg","tmdb_url":"https://www.themoviedb.org/person/17346"},{"name":"Tim Kang","name_vi":null,"name_original":"Tim Kang","tmdb_id":52947,"profile":"https://image.tmdb.