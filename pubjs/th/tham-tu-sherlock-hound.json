u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream12.com/share/12aa94495d96d67d5b9db20cdc307c5d","link_m3u8":"https://vip.opstream12.com/20251013/28572_12aa9449/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/c719661049fdb28eb938384500b8ad60","link_m3u8":"https://vip.opstream12.com/20251013/28573_c7196610/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/efd96ed062314a7607130621ad106180","link_m3u8":"https://vip.opstream12.com/20251013/28574_efd96ed0/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream12.com/share/82da28cb17ab0b7adcdef72dacbc68ba","link_m3u8":"https://vip.opstream12.com/20251013/28575_82da28cb/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream12.com/share/729d1221683eaf66616b5a8b301522d1","link_m3u8":"https://vip.opstream12.com/20251013/28576_729d1221/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream12.com/share/2def82558a0b5b01ac62b2bc46cfdb76","link_m3u8":"https://vip.opstream12.com/20251013/28577_2def8255/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream12.com/share/040cea6d24ed05b83f0db871f6794b61","link_m3u8":"https://vip.opstream12.com/20251013/28578_040cea6d/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream12.com/share/0e495e80390ae6477a619c5067c8b16f","link_m3u8":"https://vip.opstream12.com/20251013/28579_0e495e80/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream12.com/share/b24e8379f02a337976cc22e17ade2786","link_m3u8":"https://vip.opstream12.com/20251013/28580_b24e8379/index.m3u8"}]}],"description":"<p>Một thám tử nổi tiếng trong tiểu thuyết? Không ai khác: Sherlock Holmes. Từ sự nổi tiếng đó, bộ tiểu thuyết về nhân vật này đã được dựng thành phim và cả hoạt hình dành cho thiếu nhi. Bằng những sự biến đổi ngộ nghĩnh, kết hợp với sự hài hước, hãng Studio Ghibli đã thành công trong việc chuyển thể tác phẩm trinh thám này thành phim thiếu nhi. Tên của nó cũng không hề xa lạ gì với những otaku nói chung và những fan của Studio Ghibli nói riêng: Sherlock Hound (Hound: chó săn). Nhân vật với sự kết hợp độc đáo, dễ dàng chiếm được cảm tình và thu hút được trẻ em, câu chuyện hấo dẫn, lôi cuốn và có tính giáo dục, những bài hát trong phim gây được cảm xúc nơi khán giả, bấy nhiêu là đủ cho một bộ phim hoạt hình dài tập của Studio Ghibli. Sherlock Hound tuy cũ nhưng vẫn luôn là một chọn lựa tốt trong những phim hoạt hình dành cho lứa tuổi thiếu nhi.</p>","tmdb_id":21296,"cast":["Taichiro Hirokawa","Chikao Ohtsuka","Yoko Asagami","Kosei Tomita","Shozo Iizuka","Hiroshi Masuoka","Mitsuo Senda","Hitomi Oikawa","Ichiro Nagai","Kumiko Takizawa","Mayumi Tanaka","Miki Takahashi","Run Sasaki","Ryo Horikawa","Show Hayami"],"director":["Kyosuke Mikuriya"],"keywords":[],"tmdb":{"type":"tv","id":"21296","season":1,"vote_average":7.1,"vote_count":57},"cast_meta":[{"name":"Taichiro Hirokawa","name_vi":null,"name_original":"Taichiro Hirokawa","tmdb_id":96729,"profile":"https://image.tmdb.org/t/p/w500/7marDUhAAcUDAGZz52CiHE3OYHd.jpg","tmdb_url":"https://www.themoviedb.org/person/96729"},{"name":"Chikao Ohtsuka","name_vi":null,"name_original":"Chikao Ohtsuka","tmdb_id":85285,"profile":"https://image.tmdb.org/t/p/w500/j3UBKXO0c1lJaEx0SUbxlvSZCsI.jpg","tmdb_url":"https://www.themoviedb.org/person/85285"},{"name":"Yoko Asagami","name_vi":null,"name_original":"Yoko Asagami","tmdb_id":121630,"profile":"https://image.tmdb.org/t/p/w500/w1DJFu6UUJSHuPZuGE2eZuFtZR9.jpg","tmdb_url":"https://www.themoviedb.org/person/121630"},{"name":"Kosei Tomita","name_vi":null,"name_original":"Kosei Tomita","tmdb_id":551966,"profile":"https://image.tmdb.org/t/p/w500/nSGbAVJaUsrvcGujlByBjNH6dje.jpg","tmdb_url":"https://www.themoviedb.org/person/551966"},{"name":"Shozo Iizuka","name_vi":null,"name_original":"Shozo Iizuka","tmdb_id":223309,"profile":"https://image.tmdb.org/t/p/w500/msqe5A1q5YUUND0RhzB9dw1AEAO.jpg","tmdb_url":"https://www.th