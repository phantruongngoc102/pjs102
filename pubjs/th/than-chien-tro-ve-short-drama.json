opstream-short.com/20251125/50469_aaf68231/index.m3u8"},{"name":"60","slug":"60","link_embed":"https://vip.opstream-short.com/share/5bad1ee29d26170d91491dab90d8fd3c","link_m3u8":"https://vip.opstream-short.com/20251125/50470_5bad1ee2/index.m3u8"},{"name":"61","slug":"61","link_embed":"https://vip.opstream-short.com/share/3ee4085ce6f44d7591dbacfd9b0613ac","link_m3u8":"https://vip.opstream-short.com/20251125/50471_3ee4085c/index.m3u8"},{"name":"62","slug":"62","link_embed":"https://vip.opstream-short.com/share/6b92eb77d8570eda9ec81399569a5183","link_m3u8":"https://vip.opstream-short.com/20251125/50472_6b92eb77/index.m3u8"}]}],"description":"<p>Thần Chiến Diệp Vân vô tình đến một thành phố hiện đại sau một cuộc du hành thời gian bí ẩn. Trong môi trường xa lạ này, Diệp Vân nhanh chóng thích nghi và thể hiện khả năng phi thường với ý chí được rèn luyện trên chiến trường và kỹ năng chiến đấu xuất sắc. Anh không chỉ chống lại tội phạm và bảo vệ người vô tội ở những góc tối của thành phố, mà còn vướng vào một cuộc đấu tranh liên quan đến nhiều thế lực kinh doanh và quyền lực. Với sức hút độc đáo và sức mạnh mạnh mẽ, Diệp Vân giành được sự ủng hộ của nhiều bạn bè và đồng minh. Qua nhiều thử thách, Diệp Vân dần tiết lộ bí mật đằng sau chuyến du hành thời gian và tìm ra cách trở về thế giới của mình. Cuối cùng, Diệp Vân để lại huyền thoại của mình ở thành phố hiện đại và thành công trở về thế giới của mình để tiếp tục con đường Thần Chiến.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/than-chien-tro-ve-short-drama.json","tmdb_checked":false}