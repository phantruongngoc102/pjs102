com/share/b7da6669894867f04b8727876a69ffc0","link_m3u8":"https://vip.opstream12.com/20220407/8264_eeaa59a3/index.m3u8"},{"name":"42","slug":"42","filename":"than-khuyen-tieu-that-3-tap-42","link_embed":"https://vip.opstream12.com/share/fe2b421b8b5f0e7c355ace66a9fe0206","link_m3u8":"https://vip.opstream12.com/20220407/8265_5086e870/index.m3u8"},{"name":"43","slug":"43","filename":"than-khuyen-tieu-that-3-tap-43","link_embed":"https://vip.opstream12.com/share/0a93091da5efb0d9d5649e7f6b2ad9d7","link_m3u8":"https://vip.opstream12.com/20220407/8266_957312b6/index.m3u8"}]}],"time":"43M36S","description":"<p>Sau khi tham gia đội chó tìm kiếm và cứu hộ, Tiểu Thất và các đồng đội trong đội luôn dũng cảm, đoàn kết một lòng, phối hợp với HLV của mình. Chú chó quân cảnh xuất ngũ Bộ Thương vì cứu Tiểu Thất mà hi sinh, Tiểu Thất trở thành thủ lĩnh mới của đội, nhưng khứu giác bị tổn hại nghiêm trọng trong một lần làm nhiệm vụ. Khi hồi phục khứu giác, Tiểu Thất với con trai cùng nhau xuất trận, hoàn thành nhiệm vụ cứu hộ một cách hoàn hảo. Sau trận động đất, đội tìm kiếm cứu hộ dưới sự lãnh đạo của Tiểu Thất đã anh dũng giải cứu và cứu sống nhiều người.</p>","tmdb":{"type":"tv","id":"104825","season":3,"vote_average":5,"vote_count":1},"modified":"2023-06-01T19:09:55.000Z","cast":["Trần Tư Thành","Wang Chi-yang","Xu Ke","Cecilia Boey"],"director":["Yuan Xiao Man"],"cast_meta":[{"name":"Trần Tư Thành","name_vi":"Trần Tư Thành","name_original":"Chen Sicheng","tmdb_id":1065761,"profile":"https://image.tmdb.org/t/p/w500/4b67lnSvIlNMYHTowSJMHmTM54H.jpg","tmdb_url":"https://www.themoviedb.org/person/1065761"},{"name":"Wang Chi-yang","name_vi":null,"name_original":"Wang Chi-yang","tmdb_id":1211186,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1211186"},{"name":"Xu Ke","name_vi":null,"name_original":"Xu Ke","tmdb_id":1703470,"profile":"https://image.tmdb.org/t/p/w500/xKYUBH4JPykOsJpYjbNiBocdhYv.jpg","tmdb_url":"https://www.themoviedb.org/person/1703470"},{"name":"Cecilia Boe