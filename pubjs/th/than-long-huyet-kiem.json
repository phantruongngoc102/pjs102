ename":"[ATV1990][-23-]TrungHoaAnhHung[CCTV-MKV]","link_embed":"https://vip.opstream16.com/share/151707d721895d9379a3762726859df7","link_m3u8":"https://vip.opstream16.com/20231128/38301_951a6526/index.m3u8"},{"name":"24","slug":"","filename":"[ATV1990][-24-]TrungHoaAnhHung[CCTV-MKV]","link_embed":"https://vip.opstream16.com/share/beaf594a6ef2fcec5f012455dda9c81f","link_m3u8":"https://vip.opstream16.com/20231128/38299_1ff9e1d0/index.m3u8"},{"name":"25-End","slug":"","filename":"[ATV1990][-25-]TrungHoaAnhHung[CCTV-MKV]","link_embed":"https://vip.opstream16.com/share/c1b952b6948f085d619846108cec1b8b","link_m3u8":"https://vip.opstream16.com/20231128/38298_87531c09/index.m3u8"}]}],"time":"20phút/Tập","description":"<p>Hoa Anh Hùng vì nhớ quê hương, nên anh quyết định đưa vợ con từ mỹ về Trung quốc , nhưng vì có thù với tướng sadam phục kích đẻ giết anh. quá đau khỏ vì vợ con bị chết, may sống xót người con trai, anh quyết định trở lại mỹ trả thù , 15 năm sau con trai anh cũng lớn lên và trở lại mỹ tìm cha, anh gây chuốc án với hội hội Hắc Long. sau đó hoa anh hung nhận lời quyết đấu với vô địch , và không ngừng tập võ, quá sức và ngất xỉu, qua hôm sau bị bạc đầu , Hai người đánh nhau ở tượng Nữ Thần Tự Do, cuối cùng Hoa Anh Hùng bị đánh rơi xuống biến. Vô Địch tưởng Hoa Anh Hùng đã chết, không còn đối thủ nên cảm thấy cô đơn mà tự sát.</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-11-29T09:24:00.000Z","cast":["Hà Gia Kính","La Tụng Hoa","Diệp Ngọc Khanh","Quan Vịnh Hà","Dương Trạch Lâm"],"director":[],"cast_meta":[{"name":"Hà Gia Kính","name_vi":null,"name_original":"Hà Gia Kính"},{"name":"La Tụng Hoa","name_vi":null,"name_original":"La Tụng Hoa"},{"name":"Diệp Ngọc Khanh","name_vi":null,"name_original":"Diệp Ngọc Khanh"},{"name":"Quan Vịnh Hà","name_vi":null,"name_original":"Quan Vịnh Hà"},{"name":"Dương Trạch Lâm","name_vi":null,"name_original":"Dương Trạch Lâm"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc