ự là chồng của Trương thị. Đường Phiếm và Tùy Châu sau đó cũng đồng tâm hiệp lực phá được nhiều vụ án, phá tan âm mưu tạo phản của Thượng Minh, được người người khen ngợi.</p>","tmdb_id":101413,"cast":["Quan Hồng","Đường Phiếm"],"director":["Khổng Du"],"keywords":[],"time":"45 phút/tập","tmdb":{"type":"tv","id":"101413","season":1,"vote_average":8.286,"vote_count":7},"cast_meta":[{"name":"Quan Hồng","name_vi":null,"name_original":"Quan Hồng"},{"name":"Đường Phiếm","name_vi":null,"name_original":"Đường Phiếm"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/than-tham-dai-tai.json"}