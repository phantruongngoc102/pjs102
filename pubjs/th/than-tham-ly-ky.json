uan hệ họ hàng với tên trộm mèo và quyết định theo dõi họ sát sao.</p>","tmdb_id":93350,"cast":["La Gia Lương","Lâm Gia Đống","Elaine Ng Yee-Lei","Trương Khả Di","Suet Nei","Uyển Quỳnh Đan","Lâm Hiểu Phong","Gregory Charles Rivers","Đằng Lệ Danh","Châu Thông","Leung Wing-Lam"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"93350","season":1,"vote_average":8.5,"vote_count":2},"cast_meta":[{"name":"La Gia Lương","name_vi":"La Gia Lương","name_original":"Gallen Lo Ka-Leung","tmdb_id":1223043,"profile":"https://image.tmdb.org/t/p/w500/6ZCTOMeRktYL7iTEz7lg7N3XXPc.jpg","tmdb_url":"https://www.themoviedb.org/person/1223043"},{"name":"Lâm Gia Đống","name_vi":"Lâm Gia Đống","name_original":"Gordon Lam Ka-Tung","tmdb_id":83820,"profile":"https://image.tmdb.org/t/p/w500/61gQoVwgpd4qzovOaZjzJpdm47K.jpg","tmdb_url":"https://www.themoviedb.org/person/83820"},{"name":"Elaine Ng Yee-Lei","name_vi":null,"name_original":"Elaine Ng Yee-Lei","tmdb_id":1401915,"profile":"https://image.tmdb.org/t/p/w500/vpzJf3PA6eADQvK8WLls53XQJHs.jpg","tmdb_url":"https://www.themoviedb.org/person/1401915"},{"name":"Trương Khả Di","name_vi":"Trương Khả Di","name_original":"Maggie Cheung Ho-Yee","tmdb_id":125882,"profile":"https://image.tmdb.org/t/p/w500/2c4ILgnK12OMAGnLA9DhjwA93ko.jpg","tmdb_url":"https://www.themoviedb.org/person/125882"},{"name":"Suet Nei","name_vi":null,"name_original":"Suet Nei","tmdb_id":63586,"profile":"https://image.tmdb.org/t/p/w500/htXfjXCVlrA83Dm3rqFzL1Zene5.jpg","tmdb_url":"https://www.themoviedb.org/person/63586"},{"name":"Uyển Quỳnh Đan","name_vi":"Uyển Quỳnh Đan","name_original":"Kingdom Yuen King-Tan","tmdb_id":94076,"profile":"https://image.tmdb.org/t/p/w500/nXVQeVWR0sMpW2eZ4blSqZt9ces.jpg","tmdb_url":"https://www.themoviedb.org/person/94076"},{"name":"Lâm Hiểu Phong","name_vi":"Lâm Hiểu Phong","name_original":"Jerry Lamb Hiu-Fung","tmdb_id":553201,"profile":"https://image.tmdb.org/t/p/w500/fjovzalpmKcn5TKoABfvNCGReay.jpg","tmdb_url":"https://www.themoviedb.org/per