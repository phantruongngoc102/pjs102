_embed":"https://vip.opstream17.com/share/81ef0f4401b9bec98b849df4f0febfd3","link_m3u8":"https://vip.opstream17.com/20251220/25485_81ef0f44/index.m3u8"},{"name":"132","slug":"132","filename":"Thần Y Cổ Đại Nơi Đô Thị - Tập 132---2024","link_embed":"https://vip.opstream17.com/share/e61f7911ee778def6a5aade05bbe9ca1","link_m3u8":"https://vip.opstream17.com/20251220/25486_e61f7911/index.m3u8"}]}],"time":"9 phút/tập","description":"<p>Diệp Bất Phàm là một sinh viên năm 3, để kiếm đủ tiền nằm viện cho mẹ mà đi ăn vạ, giả vờ tai nạn để bắt người khác bồi thường. Nào ngờ lại gặp phải một cô tài xế không làm theo những gì người ta hay làm. Sau khi bị đâm, Diệp bất Phàm vô tình xuyên không vào một ảo cảnh, và có được truyền thừa của một môn phái về y học thời cổ đại. Từ đó, anh ta thông thạo y thuật, tu luyện công pháp, và được rất nhiều cô gái xinh đẹp chú ý đến.</p>","tmdb":{"type":"tv","id":"273263","season":1,"vote_average":8.5,"vote_count":4},"modified":"2025-12-21T10:51:52.000Z","cast":["冷调","萧篙","陈新玥"],"director":[],"cast_meta":[{"name":"冷调","name_vi":null,"name_original":"冷调","tmdb_id":5434746,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5434746"},{"name":"萧篙","name_vi":null,"name_original":"萧篙","tmdb_id":5978141,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5978141"},{"name":"陈新玥","name_vi":null,"name_original":"陈新玥","tmdb_id":4629478,"profile":"https://image.tmdb.org/t/p/w500/4PxUPoT8AneFZREvOAP4WyTknwQ.jpg","tmdb_url":"https://www.themoviedb.org/person/4629478"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/than-y-co-dai-noi-do-thi.json"}