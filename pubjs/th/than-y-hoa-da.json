1b528b302","link_m3u8":"https://vip.opstream13.com/20251108/17472_6e3a0a9a/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/a87c3e8f9b58723ac1c4f6ab69c0d0c9","link_m3u8":"https://vip.opstream13.com/20251108/17473_a87c3e8f/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/0af07e9885819ecb85897611e758433b","link_m3u8":"https://vip.opstream13.com/20251108/17474_0af07e98/index.m3u8"}]}],"description":"<p>Hoa Đà (Lâm Văn Long) từ nhỏ đã thông minh tuyệt đỉnh, mê y thuật. Gặp được danh y Trương Trọng Cảnh, chàng liền tôn thờ làm thầy. Có lần, Quan Vân Trường (Âm Dương Minh) dẫn một người cùng quê đi chữa bệnh. Đồ phát hiện bệnh của người này khác thường, không phải bệnh thương hàn thông thường, bèn kết hợp \"Bệnh sốt rét luận\" với \"Âm dưỡng lý\" và thành công chế ra thuốc chữa bệnh dịch hạch. Đáng tiếc là dân chúng mê tín dị đoan với quỷ thần, thành công của kẻ thủ ác đã gây hại không nhỏ cho Đồ, khiến nàng bị sát hại. Trương Diệu Tâm (Ngô Vĩnh Vệ), con gái lớn của Trọng Cảnh, đem lòng yêu Đồ và quyết tâm cùng chồng bỏ trốn.</p>","tmdb_id":94972,"cast":["Lâm Văn Long","Huỳnh Nhật Hoa","Ngũ Vịnh Vy","Leung Wing-Lam","Doãn Dương Minh","Wong Wai","Helen Poon Bing-Seung","Giang Hân Yến","Jenny Yam Kong-Sau","Tam Yat-Ching","Cheung Ying-Tsoi","La Lan","Margaret Chung","Vi Gia Hùng","Sunny Tai Yiu-Ming"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"94972","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lâm Văn Long","name_vi":"Lâm Văn Long","name_original":"Frankie Lam","tmdb_id":550946,"profile":"https://image.tmdb.org/t/p/w500/xlVW82bcSIfRX75ADAZZq5YXpCW.jpg","tmdb_url":"https://www.themoviedb.org/person/550946"},{"name":"Huỳnh Nhật Hoa","name_vi":"Huỳnh Nhật Hoa","name_original":"Felix Wong Yat-Wah","tmdb_id":71655,"profile":"https://image.tmdb.org/t/p/w500/9HooA3aF764XKYU8GUxO4P7v5gZ.jpg","tmdb_url":"https://www.themoviedb.org/person/71655"},{"name":"Ngũ Vịnh Vy","name_vi":"N