.com/share/ae9950b87ffc3b372739ad468bb2a676","link_m3u8":"https://vip.opstream17.com/20251220/26142_ae9950b8/index.m3u8"},{"name":"51","slug":"51","link_embed":"https://vip.opstream17.com/share/2555b8e9861b4b0e141181b725fb1b3b","link_m3u8":"https://vip.opstream17.com/20251220/26143_2555b8e9/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream17.com/share/6edf4b8ea5fb8603fcf25f2438205094","link_m3u8":"https://vip.opstream17.com/20251220/26144_6edf4b8e/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream17.com/share/b4c740208036d64c467b9cb682edb0c5","link_m3u8":"https://vip.opstream17.com/20251220/26145_b4c74020/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream17.com/share/b9648e4dc6a5ad47bea0c9023e810dfd","link_m3u8":"https://vip.opstream17.com/20251220/26146_b9648e4d/index.m3u8"}]}],"description":"<p>Kể về Thương Vân Giới, tiên ma lưỡng đạo không ngừng đấu tranh. Từ Trường Thanh xuất thân Thanh Liên kiếm cốc một lòng muốn làm Kiếm tiên, nhưng ngày vui ngắn ngủi, Ma tướng thứ chín của Thương Nguyệt Cung xâm phạm Thanh Liên kiếm cốc, ông nội hy sinh, Từ Trường Thanh được Thanh Liên Kiếm Đế công nhận, quyết chiến với Ma tướng thứ chín như bại trận. Sau đó, Côn Luân kiếm tiên Thu Vô Nhai chạy tới, đánh lui ma môn, đem Từ Trường Thanh và Mục Tử Huân đến Côn Luân. Người trên Côn Luân muốn chiếm đoạt Thanh Liên Đế Kiếm, nhưng may mắn đã bị Thu Vô Nhai ngăn cản. Từ Trường Thanh thức tỉnh “Bia Hỗn Độn Tụ Linh” của mình, được Thu Vô Nhai nhận làm đồ đệ. Trong cuộc thi kiếm, Từ Trường Thanh đánh bại Hạ Thanh Hầu giành được ngôi quán quân, có được tư cách vào cấm địa Côn Luân. Để tìm kiếm Bất Lão Thần Tuyền về hồi sinh ông nội, Từ Trường Thanh bước lên con đường hung hiểm của cấm địa Côn Luân.</p>","tmdb_id":225733,"cast":[],"director":["Qing Xuan","Bai Cha"],"keywords":[],"tmdb":{"type":"tv","id":"225733","season":1,"vote_average":8.7,"vote_count":3},"cast_meta":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thanh-lien-kiem-tien-truyen.json"}