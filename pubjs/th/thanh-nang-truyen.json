dân quốc. Cơ duyên giúp Tinh Trần trở thành một chiến sĩ, chiến đấu bảo vệ tổ quốc.</p>","tmdb_id":90711,"cast":[],"director":[],"keywords":[],"tmdb":{"id":90711},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thanh-nang-truyen.json"}