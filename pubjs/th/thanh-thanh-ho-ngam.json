ps://vip.opstream90.com/20260115/22475_d91c1cf7/index.m3u8"},{"name":"21","slug":"21","filename":"Thanh Thanh Hồ Ngâm - Tập 21---2026","link_embed":"https://vip.opstream90.com/share/3e89bba71de1106a7d13e0c630e994ff","link_m3u8":"https://vip.opstream90.com/20260116/22562_3e89bba7/index.m3u8"},{"name":"22","slug":"22","filename":"Thanh Thanh Hồ Ngâm - Tập 22---2026","link_embed":"https://vip.opstream90.com/share/8548f76db3195b7b3bbe1791092dd99e","link_m3u8":"https://vip.opstream90.com/20260116/22563_8548f76d/index.m3u8"},{"name":"23","slug":"23","filename":"Thanh Thanh Hồ Ngâm - Tập 23---2026","link_embed":"https://vip.opstream90.com/share/50f3c73883917b44d9109375d6e9c37c","link_m3u8":"https://vip.opstream90.com/20260116/22570_50f3c738/index.m3u8"},{"name":"24","slug":"24","filename":"Thanh Thanh Hồ Ngâm - Tập 24---2026","link_embed":"https://vip.opstream90.com/share/d3d9022eea71cf2692909471bc947301","link_m3u8":"https://vip.opstream90.com/20260116/22571_d3d9022e/index.m3u8"}]}],"time":"15 phút/tập","description":"<p>Mấy nghìn năm trước, thần bếp thao thiết của tộc tiên là Dao Linh Nhi độ kiếp thất bại ở vùng đất cực hàn. Lôi hỏa độ kiếp vô tình giải phong ấn cho hồ yêu Thanh Khâu, hắn lấy lại được tự do sau nhiều năm bị giam cầm, đồng thời cứu được Dao Linh Nhi đang thoi thóp hơi tàn. Để tránh sự truy đuổi của tộc tiên, Dao Linh Nhi đưa hồ yêu Thanh Khâu về nhà dưỡng thương, nhiều năm sau hai người âm thầm nảy sinh tình cảm. Đại sư huynh của Dao Linh Nhi là thượng tiên Mặc Nam phát hiện ra mối tình này, mới bày kế khiến hai người hiểu lầm và trở mặt nhau, hồ yêu ôm hận mà chết, Dao Linh Nhi muốn hóa giải hận thù nên cũng xuống trần gian lịch kiếp. Dưới phàm trần, hồ yêu hóa thân thành Hạ Tiêu Dao, chịu cảnh tan cửa nát nhà từ khi còn nhỏ nên một lòng muốn báo thù, Dao Linh Nhi giúp đỡ hắn điều tra ra sự thật. Trong những năm tháng bên nhau, hai người cùng trải qua vô số trắc trở, lần lượt phá giải những vụ việc kì quái liên quan đến lửa hồ, dần tháo gỡ khúc mắc năm xưa để rồi yêu nhau lại lần nữa.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"298700","season":1,"vote_average":1,"vote_count":1},"modified":"2026-01-16T18:02:18.000Z","cast":["Han Xiaoyao","Sun Yanen","Qian Qianyi","Xu Lisha"],"director":[],"cast_meta":[{"name":"Han Xiaoyao","name_vi":null,"name_original":"Han Xiaoyao","tmdb_id":4858694,"profile":"https://image.tmdb.org/t/p/w500/fWf7nnrhBqas7kz3FM2B2dljMPR.jpg","tmdb_url":"https://www.themoviedb.org/person/4858694"},{"name":"Sun Yanen","name_vi":null,"name_original":"Sun Yanen","tmdb_id":4284340,"profile":"https://image.tmdb.org/t/p/w500/l0xwbYiDnB03jnPf9BMT23S3EsW.jpg","tmdb_url":"https://www.themoviedb.org/person/4284340"},{"name":"Qian Qianyi","name_vi":null,"name_original":"Qian Qianyi","tmdb_id":4409247,"profile":"https://image.tmdb.org/t/p/w500/zekWxcd5eGwiUx1u7uTMLhFfS7W.jpg","tmdb_url":"https://www.themoviedb.org/person/4409247"},{"name":"Xu Lisha","name_vi":null,"name_original":"Xu Lisha","tmdb_id":4475919,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4475919"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/thanh-thanh-ho-ngam.json"}