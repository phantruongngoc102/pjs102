g năm tháng bên nhau, hai người cùng trải qua vô số trắc trở, lần lượt phá giải những vụ việc kì quái liên quan đến lửa hồ, dần tháo gỡ khúc mắc năm xưa để rồi yêu nhau lại lần nữa.</p><p>&nbsp;</p>","tmdb_id":298700,"cast":["Han Xiaoyao","Sun Yanen","Qian Qianyi","Xu Lisha"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"298700","season":1,"vote_average":1,"vote_count":1},"cast_meta":[{"name":"Han Xiaoyao","name_vi":null,"name_original":"Han Xiaoyao","tmdb_id":4858694,"profile":"https://image.tmdb.org/t/p/w500/fWf7nnrhBqas7kz3FM2B2dljMPR.jpg","tmdb_url":"https://www.themoviedb.org/person/4858694"},{"name":"Sun Yanen","name_vi":null,"name_original":"Sun Yanen","tmdb_id":4284340,"profile":"https://image.tmdb.org/t/p/w500/l0xwbYiDnB03jnPf9BMT23S3EsW.jpg","tmdb_url":"https://www.themoviedb.org/person/4284340"},{"name":"Qian Qianyi","name_vi":null,"name_original":"Qian Qianyi","tmdb_id":4409247,"profile":"https://image.tmdb.org/t/p/w500/zekWxcd5eGwiUx1u7uTMLhFfS7W.jpg","tmdb_url":"https://www.themoviedb.org/person/4409247"},{"name":"Xu Lisha","name_vi":null,"name_original":"Xu Lisha","tmdb_id":4475919,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4475919"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thanh-thanh-ho-ngam.json"}