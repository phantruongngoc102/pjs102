stream12.com/share/8cbd005a556ccd4211ce43f309bc0eac","link_m3u8":"https://vip.opstream12.com/20220302/2374_c549f93a/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/123b7f02433572a0a560e620311a469c","link_m3u8":"https://vip.opstream12.com/20220302/2375_f069e96d/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream12.com/share/6ee69d3769e832ec77c9584e0b7ba112","link_m3u8":"https://vip.opstream12.com/20220302/2376_d7bb9c53/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream12.com/share/269d837afada308dd4aeab28ca2d57e4","link_m3u8":"https://vip.opstream12.com/20220302/2377_6dc89ffc/index.m3u8"}]}],"description":"<p>Thanh Tra Lao Động Đặc Biệt - Special Labor Inspector Mr. Jo kể về Jo Jin-gap là một người có chăm chỉ và trung thực với ý thức mạnh mẽ về công lý. Anh ấy đã từng là một vận động viên judo đầy triển vọng nhưng đã bị buộc thôi việc sau khi cố gắng phản đối một kết quả không công bằng. Sau đó, anh đã cố gắng trở thành giáo viên thể dục, nhưng nó không kéo dài vì anh không thể kiềm chế sự nóng nảy của mình trước mặt con trai của chủ tịch. Cuối cùng, ông đã học và vượt qua kỳ thi công chức cấp chín và trở thành một công chức cho một vị trí chính phủ được bảo đảm. Tuy nhiên, mọi thứ thay đổi khi anh được phân công làm thanh tra lao động cho Bộ Lao động.</p>","tmdb_id":87980,"cast":[],"director":[],"keywords":[],"tmdb":{"id":87980},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thanh-tra-lao-dong-dac-biet.json"}