ám tử Lee Sung-A (Kyung Soo-Jin) và Son Kyung-Chan (Lee Hak-Joo).</p>","tmdb":{"type":"tv","id":"157161","season":1,"vote_average":6.182,"vote_count":44},"modified":"2022-11-19T12:00:20.000Z","cast":["Lee Sung-min","Gyeong Su-jin","Lee Hak-ju","Jung Jin-young","Kim Shin-rock","Kim Hong-pa","Ju Jin-mo","Jung Hae-kyun","Choi Byung-mo","Kim Min-jae","Kim Jae-beom","Hyun Bong-sik","Ko Kyu-pil","Jeong In-gi","Kim Ji-an"],"director":["Han Dong-Hwa"],"cast_meta":[{"name":"Lee Sung-min","name_vi":null,"name_original":"Lee Sung-min","tmdb_id":141548,"profile":"https://image.tmdb.org/t/p/w500/xpkERL8rumQoS9QQcuHkSm8Y3YO.jpg","tmdb_url":"https://www.themoviedb.org/person/141548"},{"name":"Gyeong Su-jin","name_vi":null,"name_original":"Gyeong Su-jin","tmdb_id":1206963,"profile":"https://image.tmdb.org/t/p/w500/5gdThWkpzuNkNyQ6Cw29oOefvXO.jpg","tmdb_url":"https://www.themoviedb.org/person/1206963"},{"name":"Lee Hak-ju","name_vi":null,"name_original":"Lee Hak-ju","tmdb_id":1615316,"profile":"https://image.tmdb.org/t/p/w500/9PuGmzY1nm8uYYiOanEKJHEcdbZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1615316"},{"name":"Jung Jin-young","name_vi":null,"name_original":"Jung Jin-young","tmdb_id":96484,"profile":"https://image.tmdb.org/t/p/w500/ipBYiyEfFrffCoTpoSiEChHDwz4.jpg","tmdb_url":"https://www.themoviedb.org/person/96484"},{"name":"Kim Shin-rock","name_vi":null,"name_original":"Kim Shin-rock","tmdb_id":3038410,"profile":"https://image.tmdb.org/t/p/w500/x4zo2mSbehnQY80PbuldAZ7ruGm.jpg","tmdb_url":"https://www.themoviedb.org/person/3038410"},{"name":"Kim Hong-pa","name_vi":null,"name_original":"Kim Hong-pa","tmdb_id":1287909,"profile":"https://image.tmdb.org/t/p/w500/b953MkFBGBu6A14otCyMuxTYGgb.jpg","tmdb_url":"https://www.themoviedb.org/person/1287909"},{"name":"Ju Jin-mo","name_vi":null,"name_original":"Ju Jin-mo","tmdb_id":945428,"profile":"https://image.tmdb.org/t/p/w500/1qTItiktKLOBRX00xIqx8GO0TXk.jpg","tmdb_url":"https://www.themoviedb.org/person/945428"},{"name":"Jung Hae-