 ý đồ, mưu tính việc khó, mỗi bước đều nguy hiểm. Nhưng khi ân oán sáng tỏ lại là tình sâu không hối hận, khi nhận nhầm đúng sai trở thành tử cục khó hóa giải, liệu người có tình có thể tiếp tục tiền duyên, thực hiện lời hứa năm xưa?","tmdb":{"type":"tv","id":"241013","season":1,"vote_average":0,"vote_count":0},"modified":"2023-12-21T13:12:08.000Z","cast":["Lý Cửu Lâm","Tiểu Vũ","Cecilia","Wang Lu","Quách Đài Minh"],"director":[],"cast_meta":[{"name":"Lý Cửu Lâm","name_vi":"Lý Cửu Lâm","name_original":"Li Jiulin","tmdb_id":2752786,"profile":"https://image.tmdb.org/t/p/w500/29NG6ZFlXsvfvsF7eIOW6OTKRou.jpg","tmdb_url":"https://www.themoviedb.org/person/2752786"},{"name":"Tiểu Vũ","name_vi":"Tiểu Vũ","name_original":"Xiao Yu","tmdb_id":3195874,"profile":"https://image.tmdb.org/t/p/w500/y5p72XoOmZaIDcyD244kltrEIqE.jpg","tmdb_url":"https://www.themoviedb.org/person/3195874"},{"name":"Cecilia","name_vi":null,"name_original":"Cecilia","tmdb_id":3062870,"profile":"https://image.tmdb.org/t/p/w500/nW77yICD2jm6jBJdytrAXEXDdCZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3062870"},{"name":"Wang Lu","name_vi":null,"name_original":"Wang Lu","tmdb_id":3481253,"profile":"https://image.tmdb.org/t/p/w500/iMHMhXzCEqShi2ar9s3fUxt6ZS4.jpg","tmdb_url":"https://www.themoviedb.org/person/3481253"},{"name":"Quách Đài Minh","name_vi":"Quách Đài Minh","name_original":"Terry Guo","tmdb_id":2682571,"profile":"https://image.tmdb.org/t/p/w500/mDxBgsOCs5nzAFbzm8mW5bAOH45.jpg","tmdb_url":"https://www.themoviedb.org/person/2682571"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/thanh-tuoc-thanh-hoang.json"}