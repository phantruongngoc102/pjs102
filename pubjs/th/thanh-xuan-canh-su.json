m10.com/20220601/18357_0133eb23/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream10.com/share/5aafd54467e6622e9f3a3c986efde8f2","link_m3u8":"https://vip.opstream10.com/20220601/18360_981973bc/index.m3u8"}]}],"description":"<p>Nói về Thanh niên Đường Nhất Tu lập chí quyết tâm trở thành một cảnh sát chính nghĩa. Trong quá trình chấp hành nhiệm vụ tại bệnh viện, anh vô tình gặp gỡ Cổ Tĩnh. Cổ Tĩnh vốn là con nhà cảnh sát, nhưng đang bị hôn mê nhưng vô tình Nhất Tu đã khiến cho Cổ Tĩnh được tỉnh dậy, hoạt động được bình thường nhưng kí ức lại bị mất đi. Cổ Tĩnh với trí nhớ và năng lực phân tích hơn người, thông qua nhiều khảo thí và huấn luyện cũng trở thành cảnh sát. Đường Nhất Tu và Cổ Tĩnh trở thành một đôi phá án cực ăn ý. Trải qua nhiều quá trình, Đường Nhất Tu cũng giúp đỡ Cổ Tĩnh tìm kiếm lại kí ức đã bị mất.</p>","tmdb_id":81098,"cast":["Jiao Junyan","Ngụy Đại Huân","Yang Tingdong","Vương Tử Hiên","Ngụy Thiên Hạo","Li Peiming","Trần Mục Dương","Shi Dao"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"81098","season":1,"vote_average":8.2,"vote_count":4},"cast_meta":[{"name":"Jiao Junyan","name_vi":null,"name_original":"Jiao Junyan","tmdb_id":1353694,"profile":"https://image.tmdb.org/t/p/w500/bYgmlpj2hEg1CHIFTTYoAzacCfZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1353694"},{"name":"Ngụy Đại Huân","name_vi":"Ngụy Đại Huân","name_original":"Wei Daxun","tmdb_id":1712691,"profile":"https://image.tmdb.org/t/p/w500/8zDh8Tp6xbVSpxr307alnGqUiJP.jpg","tmdb_url":"https://www.themoviedb.org/person/1712691"},{"name":"Yang Tingdong","name_vi":null,"name_original":"Yang Tingdong","tmdb_id":2369884,"profile":"https://image.tmdb.org/t/p/w500/mGCupnehSJESXDzLcxgYsqyrNkI.jpg","tmdb_url":"https://www.themoviedb.org/person/2369884"},{"name":"Vương Tử Hiên","name_vi":"Vương Tử Hiên","name_original":"Wang Zixuan","tmdb_id":4444646,"profile":"https://image.tmdb.org/t/p/w500/6yQGSuQh8hK3seJ2En63GE99CBh.jpg","tmdb_url":"https://www.themoviedb.org/perso