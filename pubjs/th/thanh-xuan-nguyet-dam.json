2","link_m3u8":"https://vip.opstream14.com/20230322/33940_8129db32/index.m3u8"},{"name":"15","slug":"15","filename":"Our Blooming Youth_S01E15_Episode 15","link_embed":"https://vip.opstream14.com/share/ebb72d4bfba370aecb29bc7519c9dac2","link_m3u8":"https://vip.opstream14.com/20230327/34195_7f807b13/index.m3u8"},{"name":"16","slug":"16","filename":"Our Blooming Youth_S01E16_Episode 16","link_embed":"https://vip.opstream14.com/share/28a32c20769baa8373833005b125864b","link_m3u8":"https://vip.opstream14.com/20230329/34235_39edbe44/index.m3u8"},{"name":"17","slug":"17","filename":"Our Blooming Youth_S01E17_Episode 17","link_embed":"https://vip.opstream14.com/share/6ec6bb3422418bd6a33bbfe1df28450f","link_m3u8":"https://vip.opstream14.com/20230404/34607_3b17e7db/index.m3u8"},{"name":"18","slug":"18","filename":"Our Blooming Youth_S01E18_Episode 18","link_embed":"https://vip.opstream14.com/share/dcbf540f6a9056d33884b1f54a610c1b","link_m3u8":"https://vip.opstream14.com/20230404/34647_432acc3a/index.m3u8"},{"name":"19","slug":"19","filename":"Our Blooming Youth_S01E19_Episode 19","link_embed":"https://vip.opstream14.com/share/ee0e73fb83714a265451153b803ff57f","link_m3u8":"https://vip.opstream14.com/20230410/35124_300d649a/index.m3u8"},{"name":"20","slug":"20","filename":"Our Blooming Youth_S01E20_Episode 20","link_embed":"https://vip.opstream14.com/share/8abf3bb568d1c7ba57cd3fff7a22880c","link_m3u8":"https://vip.opstream14.com/20230411/35184_635333ae/index.m3u8"}]}],"time":"60 phút/tập","description":"<p>Bộ phim lấy bối cảnh giả tưởng ở thời kỳ&nbsp;Nhà Triều Tiên, kể về câu chuyện tình yêu định mệnh giữa vị Thế tử để hạ Lee Hwan (Park Hyung-sik) và cô gái Min Jae Yi (Jeon So-nee).</p><p>&nbsp;</p><p>Lee Hwan là một vị Đông Cung Thế tử kiêu ngạo và tính khí thất thường đang phải chịu đựng một lời nguyền bí ẩn. Anh là một người cô đơn, luôn che giấu vết sẹo sâu trong tâm trí. Trong khi đó, Min Jae Yi là một cô gái cực kỳ thông minh và xuất thân từ một gia đình quý tộc được kính trọng. Một ngày, cả gia đình cô đột nhiên bị sát hại và cô bị coi là kẻ giết người. Vừa phải trốn chạy, cô cũng vẫn quyết tâm tìm ra sự thật bị che giấu.[</p>","tmdb":{"type":"tv","id":"154889","season":1,"vote_average":6.196,"vote_count":28},"modified":"2023-10-06T00:14:02.000Z","cast":["Park Hyung-sik","Jeon So-nee","Pyo Ye-jin","Yun Jong-seok","Lee Tae-seon","Heo Won-seo","Cho Seong-ha","Jung Woong-in","Son Byung-ho","Lee Jong-hyuk","Hong Soo-hyun","Park Hyo-joon","Kim Ki-doo","Lee Min-ji","Jeong In-kyeom"],"director":["Lee Jong-jae"],"cast_meta":[{"name":"Park Hyung-sik","name_vi":null,"name_original":"Park Hyung-sik","tmdb_id":1330918,"profile":"https://image.tmdb.org/t/p/w500/8FHH9kQLRdByDOjdMn1oRUCEWZA.jpg","tmdb_url":"https://www.themoviedb.org/person/1330918"},{"name":"Jeon So-nee","name_vi":null,"name_original":"Jeon So-nee","tmdb_id":2104287,"profile":"https://image.tmdb.org/t/p/w500/dIYceHYZ9lHePBnAsZo2zMEHHAq.jpg","tmdb_url":"https://www.themoviedb.org/person/2104287"},{"name":"Pyo Ye-jin","name_vi":null,"name_original":"Pyo Ye-jin","tmdb_id":1818072,"profile":"https://image.tmdb.org/t/p/w500/kgJP15cNNslxFT0kaI8MCra5lr8.jpg","tmdb_url":"https://www.themoviedb.org/person/1818072"},{"name":"Yun Jong-seok","name_vi":null,"name_original":"Yun Jong-seok","tmdb_id":2206571,"profile":"https://image.tmdb.org/t/p/w500/3xCbxWx5dqtUQYANEZxOpGOsuYJ.jpg","tmdb_url":"https://www.themoviedb.org/person/2206571"},{"name":"Lee Tae-seon","name_vi":null,"name_original":"Lee Tae-seon","tmdb_id":1607799,"profile":"https://image.tmdb.org/t/p/w500/4u7rNEJ2PTZKz0XHO6eLoYbC6qP.jpg","tmdb_url":"https://www.themoviedb.org/person/1607799"},{"name":"Heo Won-seo","name_vi":null,"name_original":"Heo Won-seo","tmdb_id":3865959,"profile":"https://image.tmdb.org/t/p/w500/2sja1cS4NkmjgUKwUMBnIxLWAkU.jpg","tmdb_url":"https://www.themoviedb.org/person/3865959"},{"name":"Cho Seong-ha","name_vi":null,"name_original":"Cho Seong-ha","tmdb_id":551171,"profile":"https://image.tmdb.org/t/p/w500/