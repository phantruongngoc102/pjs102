m90.com/share/9a3bd37a71b632e7726f149bbd771052","link_m3u8":"https://vip.opstream90.com/20260305/26525_9a3bd37a/index.m3u8"}]}],"description":"<p>Sáu sinh viên đại học với tính cách hoàn toàn trái ngược đã đến thực tập tại cộng đồng dưỡng lão. Qua sự tiếp xúc gần gũi và những điều tai nghe mắt thấy tại đây, họ đã xóa bỏ được những định kiến ban đầu và thấu hiểu chân thực về cuộc sống của người cao tuổi. Họ ngỡ ngàng nhận ra rằng, các cụ vẫn căng tràn sức sống thanh xuân với những tư tưởng mới mẻ, vốn sống phong phú dày dặn, và cả những nét tinh nghịch, hóm hỉnh như trẻ nhỏ. Kỳ thực tập ngắn ngủi trong một học kỳ đã thay đổi hoàn toàn cách nhìn của nhóm sinh viên, biến họ trở thành những \"người bạn vong niên\" thân thiết của các ông bà trong cộng đồng dưỡng lão.</p><p>&nbsp;</p>","tmdb_id":273275,"cast":["Li Chengru","Hứa Đệ","Cai Ming","Phạm Minh","Liang Tian","Zhang Hongming"],"director":["英达"],"keywords":[],"tmdb":{"type":"tv","id":"273275","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Li Chengru","name_vi":null,"name_original":"Li Chengru","tmdb_id":1280711,"profile":"https://image.tmdb.org/t/p/w500/j8fcElX7TtnoZrGULrXkyNgJcqT.jpg","tmdb_url":"https://www.themoviedb.org/person/1280711"},{"name":"Hứa Đệ","name_vi":"Hứa Đệ","name_original":"Xu Di","tmdb_id":2472971,"profile":"https://image.tmdb.org/t/p/w500/2Oo9R5lAIB98QfehaqgtEyEz7FZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2472971"},{"name":"Cai Ming","name_vi":null,"name_original":"Cai Ming","tmdb_id":2282263,"profile":"https://image.tmdb.org/t/p/w500/pNW967o0BR1vxLjFdQWKq9J6AZ3.jpg","tmdb_url":"https://www.themoviedb.org/person/2282263"},{"name":"Phạm Minh","name_vi":"Phạm Minh","name_original":"Fan Ming","tmdb_id":1100750,"profile":"https://image.tmdb.org/t/p/w500/lgs16RJ2YPhvx5Vmp1H7sLhXm1M.jpg","tmdb_url":"https://www.themoviedb.org/person/1100750"},{"name":"Liang Tian","name_vi":null,"name_original":"Liang Tian","tmdb_id":1172006,"profile":"https://image.tmdb.org/t/p/w500/6voR