1b5ddcaf017290","link_m3u8":"https://vip.opstream11.com/20241020/55328_a7944fb6/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/51b458b4e6ac5bfdcce31855ad2c0fec","link_m3u8":"https://vip.opstream11.com/20241020/55329_51b458b4/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/291806ebb9de8fe92dc92a02a2b46b5a","link_m3u8":"https://vip.opstream11.com/20241020/55330_291806eb/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream11.com/share/362bb9e85bfd59d170c7367d97e2b515","link_m3u8":"https://vip.opstream11.com/20241020/55331_362bb9e8/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream11.com/share/00a0072866e151e12d9518d19424963a","link_m3u8":"https://vip.opstream11.com/20241020/55332_00a00728/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream11.com/share/94cb2fd7973caa84e16dcf4067183797","link_m3u8":"https://vip.opstream11.com/20241020/55333_94cb2fd7/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream11.com/share/1c73b5ac340119713cc76226aa147eaf","link_m3u8":"https://vip.opstream11.com/20241020/55334_1c73b5ac/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream11.com/share/49a741920d73edccf235bf67736b9247","link_m3u8":"https://vip.opstream11.com/20241020/55335_49a74192/index.m3u8"}]}],"description":"<p><i>Câu chuyện xảy ra vào thời nhà Minh, triều đình hủ bại, gian thần nắm quyền nên cuộc sống người dân vô cùng khốn khổ. Vào lúc này, trên giang hồ xuất hiện Thập Tam Nương – một nữ hiệp gan dạ và xinh đẹp lại mang trong người dòng máu thám tử của cha. Thập Tam Nương chuyên khám phá các vụ nghi án và trừng trị kẻ gian ác, cùng với cô còn có những người bạn chung lý tưởng là Vương Đại Hữu – tên trộm nổi tiếng khắp kinh thành nhưng rất nhiệt tình, khinh công cái thế; Tống Quân Du – con gái của một danh y, sắc đẹp tuyệt trần, y thuật cao siêu và Địch Vô Tà là bộ khoái số một của Viện Đô sát, võ công cao cường. Tất cả họ cùng kết hợp với nhau khám phá thành công nhiều vụ án bí hiểm.</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thap-tam-nuong.json","tmdb_checked":false}