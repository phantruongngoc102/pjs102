://vip.opstream13.com/20251011/11958_1f3a9b29/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream13.com/share/b02980b0db1585859d77d1f033e23f42","link_m3u8":"https://vip.opstream13.com/20251011/11959_b02980b0/index.m3u8"}]}],"description":"<p>Lục Tiêu là đội trưởng của cảnh sát Hải Cương, là người khôn ngoan và điềm tĩnh. Anh được coi là người tinh nhuệ của lực lượng cảnh sát dù tuổi đời còn trẻ vì đã giải quyết được nhiều vụ án hóc búa. Tuy nhiên, anh bị bối rối bởi một trường hợp kỳ lạ về một xác chết trôi nổi, và kẻ giết người \"Bóng ma nước\". Trong quá trình điều tra, tên sát nhân đã nhiều lần tẩu thoát nhờ tài quan sát phi thường của mình. Cùng với người bạn cùng phòng mới Fang Yi Tong, cả hai hợp tác để truy bắt kẻ giết người. Tuy nhiên, anh cũng mất đi người vợ yêu quý của mình, Jiang Yi Ran trong quá trình này và gần như phải từ bỏ. Được sự động viên của đồng đội, Lục Tiêu tự mình ra tay và cuối cùng đã bắt được hung thủ, trả lại công bằng cho các nạn nhân.</p>","tmdb_id":204647,"cast":["Tần Tuấn Kiệt","Đặng Gia Giai","Lưu Hoan","Lý Mộng","Sun Hao","Chen Ran","Hong Jiantao","Jin Xianzheng","Wang Tianyu","Gu Tongzhi","Chen Qianhua"],"director":["解航"],"keywords":[],"tmdb":{"type":"tv","id":"204647","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Tần Tuấn Kiệt","name_vi":"Tần Tuấn Kiệt","name_original":"Qin Junjie","tmdb_id":17385,"profile":"https://image.tmdb.org/t/p/w500/iYdwWhvd4QuipsNkeB3XzFa27jo.jpg","tmdb_url":"https://www.themoviedb.org/person/17385"},{"name":"Đặng Gia Giai","name_vi":"Đặng Gia Giai","name_original":"Deng Jiajia","tmdb_id":1059217,"profile":"https://image.tmdb.org/t/p/w500/zwTb6M8FI0eOaLEITulpSKUWmtE.jpg","tmdb_url":"https://www.themoviedb.org/person/1059217"},{"name":"Lưu Hoan","name_vi":"Lưu Hoan","name_original":"Liu Huan","tmdb_id":3227810,"profile":"https://image.tmdb.org/t/p/w500/tUL4Znn78vSZdUEC3BgD0cfQgnP.jpg","tmdb_url":"https://www.themoviedb.org/person/3227810"},{"name":"Lý Mộng","name_vi