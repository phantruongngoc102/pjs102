3u8":"https://vip.opstream16.com/20230923/35141_001295da/index.m3u8"},{"name":"13","slug":"13","filename":"Thất Kiếm Ma Thuật Thống Trị Thế Giới Tập 13 - Khu rừng Nhộn nhịp - Bstation Tập 13","link_embed":"https://vip.opstream16.com/share/4c1ed2facc7f349e4810f522a6ea9990","link_m3u8":"https://vip.opstream16.com/20230930/35327_429ef50a/index.m3u8"},{"name":"14","slug":"14","filename":"Thất Kiếm Ma Thuật Thống Trị Thế Giới Tập 14 - Salvadori - Bstation Tập 14","link_embed":"https://vip.opstream16.com/share/cb88c602ad91ca0dc97d93f87ed88286","link_m3u8":"https://vip.opstream16.com/20231007/35373_80b64fbe/index.m3u8"},{"name":"15","slug":"15","filename":"Thất Kiếm Ma Thuật Thống Trị Thế Giới Tập 15 - Bài hát cuối cùng - Bstation Tập 15","link_embed":"https://vip.opstream16.com/share/822d2e6c61952fcef5021c9ebcd6fa96","link_m3u8":"https://vip.opstream16.com/20231014/35686_8b0e4d5f/index.m3u8"}]}],"time":"24 phút/tập","description":"Mùa xuân - Trường Phù thủy và Phép thuật Kimberley danh tiếng cũng có học sinh mới nhập học năm nay.\nHọ mặc áo choàng đen, đeo gậy trắng và đeo kiếm bên hông, mang trong mình niềm kiêu hãnh và sứ mệnh.\nĐiều chào đón những pháp sư tập sự này là một con đường đầy hoa anh đào và cuộc diễu hành của các sinh vật huyền bí.\nTuy nhiên, họ chỉ có thể tràn đầy kỳ vọng ở thời gian đầu.\nCó nhiều mối đe dọa khác nhau ẩn giấu trong Kimberley, một mê cung dưới lòng đất có thể nuốt chửng học sinh, những người cao niên giống như quái vật, và các cuộc đấu tranh phe phái về quyền con người của những kẻ hạ đẳng──\nOliver cố gắng sống sót trong một môi trường kỳ lạ như vậy cùng với những người bạn đồng hành của mình,\nTrong thời gian này, cậu đã gặp Nanao, một nữ samurai với thanh kiếm Nhật trên thắt lưng.","tmdb":{"type":"tv","id":"153337","season":1,"vote_average":6.6,"vote_count":36},"modified":"2024-10-18T10:48:10.000Z","cast":["Atsushi Tamaru","Yuka Nukui","Hitomi Ohwada","Misuzu Yamada","Riho Sugiyama","Shinsuke Sugawara"],"director":[],"cast_meta":[{"name