 bạn,\\n\\n</p>","tmdb_id":107633,"cast":["Tống Thiến","Trương Giai Ninh","Lý Thuần","Celina Jade","Trịnh Khải","Dương Hựu Ninh","David Wang","Vương Lịch Hâm","Shi An","Trương Hạo Duy"],"director":["Guangli Wang"],"keywords":[],"tmdb":{"type":"tv","id":"107633","season":1,"vote_average":9,"vote_count":1},"cast_meta":[{"name":"Tống Thiến","name_vi":"Tống Thiến","name_original":"Victoria Song","tmdb_id":1255268,"profile":"https://image.tmdb.org/t/p/w500/xOrFdPmJXdmuSSMAF12AwSDpHw3.jpg","tmdb_url":"https://www.themoviedb.org/person/1255268"},{"name":"Trương Giai Ninh","name_vi":"Trương Giai Ninh","name_original":"Karlina Zhang","tmdb_id":1829558,"profile":"https://image.tmdb.org/t/p/w500/hEOl3OdG16uag7xMznk3X9FRCH0.jpg","tmdb_url":"https://www.themoviedb.org/person/1829558"},{"name":"Lý Thuần","name_vi":"Lý Thuần","name_original":"Li Chun","tmdb_id":1683309,"profile":"https://image.tmdb.org/t/p/w500/26Z1lcLUTtcqqwzKYPUqYKmD1h9.jpg","tmdb_url":"https://www.themoviedb.org/person/1683309"},{"name":"Celina Jade","name_vi":null,"name_original":"Celina Jade","tmdb_id":1224028,"profile":"https://image.tmdb.org/t/p/w500/jehhIDOYWRvfC8SXxhXRXUxP193.jpg","tmdb_url":"https://www.themoviedb.org/person/1224028"},{"name":"Trịnh Khải","name_vi":"Trịnh Khải","name_original":"Ryan Zheng","tmdb_id":1279598,"profile":"https://image.tmdb.org/t/p/w500/wHUCaZAe8KkpXs6sXmPUr9B6C82.jpg","tmdb_url":"https://www.themoviedb.org/person/1279598"},{"name":"Dương Hựu Ninh","name_vi":"Dương Hựu Ninh","name_original":"Tony Yang","tmdb_id":96958,"profile":"https://image.tmdb.org/t/p/w500/d0C8Dp9itcFV4Q8bLRISguGJmPR.jpg","tmdb_url":"https://www.themoviedb.org/person/96958"},{"name":"David Wang","name_vi":null,"name_original":"David Wang","tmdb_id":1623136,"profile":"https://image.tmdb.org/t/p/w500/uDOia8x3GyqhRnQs7Akgqytui7Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1623136"},{"name":"Vương Lịch Hâm","name_vi":"Vương Lịch Hâm","name_original":"Wang Yuexin","tmdb_id":1621704,"profile":"https://i