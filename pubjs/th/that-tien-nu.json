3u8":"https://vip.opstream15.com/20230913/43484_c448d32e/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/f24225f22f15bced3886d8fa30b6cca3","link_m3u8":"https://vip.opstream15.com/20230913/43485_8512a1a3/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/7570a1928de2b6137980bde646329ba6","link_m3u8":"https://vip.opstream15.com/20230913/43486_d03e835e/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/ec571ab7b4d7949853f9bf65e19442d5","link_m3u8":"https://vip.opstream15.com/20230913/43487_402c161f/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/40a0aa5c2c4ad38b70e4caf62ac90fe1","link_m3u8":"https://vip.opstream15.com/20230913/43488_6825abb6/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream15.com/share/81ab41f724391ef12094724fc6d8234f","link_m3u8":"https://vip.opstream15.com/20230913/43489_009038d8/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream15.com/share/864d8d390024caafa47fed54b8ecd9b5","link_m3u8":"https://vip.opstream15.com/20230913/43490_03526956/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream15.com/share/8e3ecc6d79b651cabc3b9403543358dd","link_m3u8":"https://vip.opstream15.com/20230913/43491_394ef630/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream15.com/share/f070d86251aaa3f977261bc44bce5341","link_m3u8":"https://vip.opstream15.com/20230913/43492_a9bea204/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream15.com/share/2ef610424f612b411a3e43f0917fb3a6","link_m3u8":"https://vip.opstream15.com/20230913/43493_9cc48c49/index.m3u8"}]}],"description":"Thất công chúa đã gặp và yêu một người phàm trần là Đổng Vĩnh. Sau khi về trời, vì quá nhớ thương Đổng Vĩnh nhân hậu thật thà, nàng lại một lần nữa hạ phàm. Các nàng tiên còn lại vì thương em nên đã bao che cho cô. Không ngờ, hội bàn đào lại được tổ chức đúng vào ngày Thất công chúa đi chưa được bao lâu. Vũ khúc Cát Tường của bảy vị công chúa thiếu mất một nhân vật quan trọng. Chỗ trống đó đã được thay thế bởi Thuận Phong Nhĩ. Nhưng Sao Chổi - một hạ tiên chuyên lo việc quét rác trên thiên đình, đi đến đâu cũng bị xua đuổi - vì không được tham dự hội bàn đào nên rất tức giận và đã cố ý làm lộ việc Thất công chúa trốn xuống trần, khiến cô bị tước bỏ tiên cốt, đày xuống trần gian. Sau đó, y gặp được đại ma đầu Âm Thực Vương (sư đệ của Vương Mẫu nương nương), khi đó đang bị giam trong cấm địa của thiên đình. Vì ham muốn được làm thượng tiên nên Sao Chổi đã nghe lời dụ dỗ của hắn, tìm cách đưa các vị công chúa còn lại xuống trần gian và hợp sức cùng với Giả đại nhân (một tên quan tham gian ác từng tìm cách hại chết Đổng Vĩnh) bày ra những âm mưu thâm độc để hãm hại họ. Tuy nhiên, sau khi giành được quyền trượng của Vương Mẫu nương nương và có được pháp lực vô biên, Âm Thực Vương trở mặt với Sao Chổi. Sao Chổi tỉnh ngộ nên đã quay lại giúp bảy nàng tiên và còn cho họ biết điểm yếu của Âm Thực Vương. Nhờ đó, các nàng tiên đã đánh bại Âm Thực Vương, đồng thời tìm được ý trung nhân cho mình. Vương mẫu nương nương cuối cùng sửa đổi luật trời và tất cả các phò mã đều được thành tiên.","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/that-tien-nu.json"}