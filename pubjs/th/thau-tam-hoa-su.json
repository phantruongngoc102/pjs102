hau-tam-hoa-su--eps-tap-24","link_embed":"https://vip.opstream11.com/share/860f5834f8e7f8e2834fc2957042760e","link_m3u8":"https://vip.opstream11.com/20220506/23542_3ff4d06a/index.m3u8"},{"name":"25","slug":"25","filename":"thau-tam-hoa-su--eps-tap-25","link_embed":"https://vip.opstream11.com/share/bc633e62b0095c6ed17684297ee49db4","link_m3u8":"https://vip.opstream11.com/20220506/23543_d5c46e53/index.m3u8"},{"name":"26","slug":"26","filename":"thau-tam-hoa-su--eps-tap-26","link_embed":"https://vip.opstream11.com/share/5aa86b4de7af02b2dda5de2fe8c60f47","link_m3u8":"https://vip.opstream11.com/20220506/23544_2258ea0d/index.m3u8"},{"name":"27","slug":"27","filename":"thau-tam-hoa-su--eps-tap-27","link_embed":"https://vip.opstream11.com/share/a9ddacdd8891788c87fb2a7f31fa1ca0","link_m3u8":"https://vip.opstream11.com/20220506/23545_55cebb63/index.m3u8"},{"name":"28","slug":"28","filename":"thau-tam-hoa-su--eps-tap-28","link_embed":"https://vip.opstream11.com/share/c1aa157f9e8516370e3345f226ef62fc","link_m3u8":"https://vip.opstream11.com/20220506/23546_429ccd5c/index.m3u8"},{"name":"29","slug":"29","filename":"thau-tam-hoa-su--eps-tap-29","link_embed":"https://vip.opstream11.com/share/7dfbfb4a386b98740005488c55f5ccbe","link_m3u8":"https://vip.opstream11.com/20220506/23547_4c804006/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Thâu Tâm Họa Sư kể về câu chuyện tình lãng mạn giữa Hùng Hi Nhược, một họa sĩ tài năng sở hữu một trí nhớ tuyệt vời và Lý Hoằng Bân, thiếu chủ gia tộc họ Lý danh giá, nhưng vô cùng lạnh lùng. Do hàng loạt hiểu lầm, hai người buộc phải nói dối rằng họ yêu nhau, để cứu mạng Hùng Hi Nhược còn Lý Hoằng Bâ thì thoát khỏi cuộc hôn nhân sắp đặt. Nhưng theo thời gian, hai người bắt đầu nảy sinh tình cảm thật sự, từ đây mở ra câu chuyện tình yêu vô cùng lãng mạn, ngọt ngào nhưng cũng gian khó, khi những hiểm nguy rình rập gia đình họ Lý xuất hiện.</p>","tmdb":{"type":"tv","id":"110124","season":1,"vote_average":10,"vote_count":1},"modified":"2022-07-03T01:33:37.000Z","cast":["Xia Ningjun","Xi Zi","Lan Bo","Kang Keren","Tian Shuchen","Huang Xingyuan","He Lingyao","Yu Baishui","Xie Yiqiaoyang","Song Ziqin","Luo Qingyu","Dai Hejiaqi","Gu Jiangshan","Qiao Shiyu"],"director":["Kha Chính Minh"],"cast_meta":[{"name":"Xia Ningjun","name_vi":null,"name_original":"Xia Ningjun","tmdb_id":2392823,"profile":"https://image.tmdb.org/t/p/w500/cjKnfU4yKGqejQiER651lmvi5Ki.jpg","tmdb_url":"https://www.themoviedb.org/person/2392823"},{"name":"Xi Zi","name_vi":null,"name_original":"Xi Zi","tmdb_id":2781619,"profile":"https://image.tmdb.org/t/p/w500/ubT6maw5rWmwD5x5vanjWS8gr70.jpg","tmdb_url":"https://www.themoviedb.org/person/2781619"},{"name":"Lan Bo","name_vi":null,"name_original":"Lan Bo","tmdb_id":2781620,"profile":"https://image.tmdb.org/t/p/w500/27gilsbLGqYYog6Q3prmYcT3V6M.jpg","tmdb_url":"https://www.themoviedb.org/person/2781620"},{"name":"Kang Keren","name_vi":null,"name_original":"Kang Keren","tmdb_id":2716734,"profile":"https://image.tmdb.org/t/p/w500/fkC6UcyIIJE0Pf1V8Ejl0EqzYNy.jpg","tmdb_url":"https://www.themoviedb.org/person/2716734"},{"name":"Tian Shuchen","name_vi":null,"name_original":"Tian Shuchen","tmdb_id":2781624,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2781624"},{"name":"Huang Xingyuan","name_vi":null,"name_original":"Huang Xingyuan","tmdb_id":3961099,"profile":"https://image.tmdb.org/t/p/w500/wsJb1vNAQmEAJZqzYg7ukrchqOZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3961099"},{"name":"He Lingyao","name_vi":null,"name_original":"He Lingyao","tmdb_id":3737008,"profile":"https://image.tmdb.org/t/p/w500/p8WeLHtuRHnAvHaepz81rdntuvy.jpg","tmdb_url":"https://www.themoviedb.org/person/3737008"},{"name":"Yu Baishui","name_vi":null,"name_original":"Yu Baishui","tmdb_id":3814777,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3814777"},{"name":"Xie Yiqiaoyang","