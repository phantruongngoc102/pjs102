.com/20220605/19056_dae6a1da/index.m3u8"},{"name":"24","slug":"24","filename":"thay-lang-trung-manh-thuyet-minh-thong-ek-the-herbal-master-tap-24","link_embed":"https://vip.opstream10.com/share/7cbaaa9b7b79120a7e12db5b2e51137f","link_m3u8":"https://vip.opstream10.com/20220605/19057_fedb11e0/index.m3u8"},{"name":"25","slug":"25","filename":"thay-lang-trung-manh-thuyet-minh-thong-ek-the-herbal-master-tap-25","link_embed":"https://vip.opstream10.com/share/4d9b45c6f8d4b9d814b0ca849a6c6dda","link_m3u8":"https://vip.opstream10.com/20220605/19058_3c9d926c/index.m3u8"},{"name":"26","slug":"26","filename":"thay-lang-trung-manh-thuyet-minh-thong-ek-the-herbal-master-tap-26","link_embed":"https://vip.opstream10.com/share/8f2ba96517924ee3d08ec132c4bad818","link_m3u8":"https://vip.opstream10.com/20220605/19060_19f23d48/index.m3u8"},{"name":"27","slug":"27","filename":"thay-lang-trung-manh-thuyet-minh-thong-ek-the-herbal-master-tap-27","link_embed":"https://vip.opstream10.com/share/ee3e2bda9df62dc0c091db891154cf34","link_m3u8":"https://vip.opstream10.com/20220605/19059_b98963d1/index.m3u8"},{"name":"28","slug":"28","filename":"thay-lang-trung-manh-thuyet-minh-thong-ek-the-herbal-master-tap-28","link_embed":"https://vip.opstream10.com/share/07662abf6d1635f05215d0614a1b6329","link_m3u8":"https://vip.opstream10.com/20220605/19061_676ebb9d/index.m3u8"}]}],"time":"57phút/tập","description":"<p>Nội dung phim Thầy Lang Trúng Mánh kể về những câu chuyện hài hước giữa anh chàng lang băm ThongEk (Mario Maurer) và cô tiểu thư đanh đá Chaba (Kimmy Kimberly). Xuất thân bình thường, ThongEk đam mê y thuật và luôn muốn trở thành một thầy thuốc giỏi để cứu giúp mọi người. Mặc sự ngăn cản từ phía gia đình, ThongEk luôn tiến về phía trước, dần hoàn thiện kỹ năng, kiến thức y học. Duyên phân sắp đặt anh đụng độ với tiểu thư Chaba, họ cứ hễ gặp nhau là lại đấu khẩu và người thiệt luôn là ThongEk. Câu chuyện giữa cặp đôi này sẽ đi về đâu, liệu có một cái kết viên mãn cho cả hai?</p>","tmdb":{"type":"