ô ấy cố gắng thuyết phục anh ấy thay đổi ý định của mình.</p>","tmdb":{"type":"movie","id":"10200","season":null,"vote_average":5.654,"vote_count":3648},"modified":"2024-10-08T10:09:48.000Z","cast":["Keanu Reeves","Jennifer Connelly","Jaden Smith","Jon Hamm","Kathy Bates","John Cleese","Kyle Chandler","Robert Knepper","Brandon T. Jackson","James Hong","Jake McLaughlin","John Rothman","Sunita Prasad","Juan Riedinger","Sam Gilroy"],"director":["Scott Derrickson"],"cast_meta":[{"name":"Keanu Reeves","name_vi":null,"name_original":"Keanu Reeves","tmdb_id":6384,"profile":"https://image.tmdb.org/t/p/w500/8RZLOyYGsoRe9p44q3xin9QkMHv.jpg","tmdb_url":"https://www.themoviedb.org/person/6384"},{"name":"Jennifer Connelly","name_vi":null,"name_original":"Jennifer Connelly","tmdb_id":6161,"profile":"https://image.tmdb.org/t/p/w500/wdmcJagSRJ65AuJ4IUCzuHAdvgy.jpg","tmdb_url":"https://www.themoviedb.org/person/6161"},{"name":"Jaden Smith","name_vi":null,"name_original":"Jaden Smith","tmdb_id":120724,"profile":"https://image.tmdb.org/t/p/w500/aXCn1kRjs4sZS55xSrdmjbht7SM.jpg","tmdb_url":"https://www.themoviedb.org/person/120724"},{"name":"Jon Hamm","name_vi":null,"name_original":"Jon Hamm","tmdb_id":65717,"profile":"https://image.tmdb.org/t/p/w500/mrXE5fZbEDPc7BEE5G21J6qrwzi.jpg","tmdb_url":"https://www.themoviedb.org/person/65717"},{"name":"Kathy Bates","name_vi":null,"name_original":"Kathy Bates","tmdb_id":8534,"profile":"https://image.tmdb.org/t/p/w500/y1QUbku8Ro3XCIs3J9nph3U57U6.jpg","tmdb_url":"https://www.themoviedb.org/person/8534"},{"name":"John Cleese","name_vi":null,"name_original":"John Cleese","tmdb_id":8930,"profile":"https://image.tmdb.org/t/p/w500/nQpBf77cStmR35V0XOinm2zZMWG.jpg","tmdb_url":"https://www.themoviedb.org/person/8930"},{"name":"Kyle Chandler","name_vi":null,"name_original":"Kyle Chandler","tmdb_id":3497,"profile":"https://image.tmdb.org/t/p/w500/66n7XNj1dyYkzCBWR3Lq8Vz4PJ1.jpg","tmdb_url":"https://www.themoviedb.org/person/3497"},{"name":"Robert Knepper","