t giữa hai cõi. Ma Kwai phải lựa chọn giữa giữ bí mật năng lực, bảo vệ người thân và thực hiện sứ mệnh trừ ma của mình.</p>","tmdb_id":231910,"cast":["Kenneth Ma Kwok-Ming","Hubert Wu","Mandy Wong","Ram Chiang Chi-Kwong","Susan Tse Suet-Sum","Lưu Bội Nguyệt","Đàm Khải Kỳ","Gloria Tang","Lâm Khải Ân","Kayee Tam"],"director":["Dave Fong Chun"],"keywords":[],"tmdb":{"type":"tv","id":"231910","season":1,"vote_average":7.5,"vote_count":2},"cast_meta":[{"name":"Kenneth Ma Kwok-Ming","name_vi":null,"name_original":"Kenneth Ma Kwok-Ming","tmdb_id":1232198,"profile":"https://image.tmdb.org/t/p/w500/6DejZHB8htcmosNwuOGJeDUgfJr.jpg","tmdb_url":"https://www.themoviedb.org/person/1232198"},{"name":"Hubert Wu","name_vi":null,"name_original":"Hubert Wu","tmdb_id":2071065,"profile":"https://image.tmdb.org/t/p/w500/wUwG6yplwRoIrQChpbUB0LEehfQ.jpg","tmdb_url":"https://www.themoviedb.org/person/2071065"},{"name":"Mandy Wong","name_vi":null,"name_original":"Mandy Wong","tmdb_id":1255464,"profile":"https://image.tmdb.org/t/p/w500/hK69LsDU6G1EHtiwPEpf7BYV0e.jpg","tmdb_url":"https://www.themoviedb.org/person/1255464"},{"name":"Ram Chiang Chi-Kwong","name_vi":null,"name_original":"Ram Chiang Chi-Kwong","tmdb_id":1083956,"profile":"https://image.tmdb.org/t/p/w500/7ikYgSecvhDXc8tQgqFucBitfG0.jpg","tmdb_url":"https://www.themoviedb.org/person/1083956"},{"name":"Susan Tse Suet-Sum","name_vi":null,"name_original":"Susan Tse Suet-Sum","tmdb_id":1274608,"profile":"https://image.tmdb.org/t/p/w500/4K66G20ntTiQX3hPD9tHIaTHLE2.jpg","tmdb_url":"https://www.themoviedb.org/person/1274608"},{"name":"Lưu Bội Nguyệt","name_vi":"Lưu Bội Nguyệt","name_original":"Moon Lau","tmdb_id":2363302,"profile":"https://image.tmdb.org/t/p/w500/7gTQNEtJqNfsb7703Jr8Bgn5Ebb.jpg","tmdb_url":"https://www.themoviedb.org/person/2363302"},{"name":"Đàm Khải Kỳ","name_vi":"Đàm Khải Kỳ","name_original":"Zoie Tam","tmdb_id":1315729,"profile":"https://image.tmdb.org/t/p/w500/rHoeN66q8PBV2TLZdWbmyXQE1Wt.jpg","tmdb_url":"https://www.t