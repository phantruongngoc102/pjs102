b9d1b6673cfd8602f9f9765265bc78","link_m3u8":"https://vip.opstream15.com/20220611/20167_c140ee5c/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Đây là thế giới bầu trời, nơi có nhiều hòn đảo trôi nổi trên trời. Một cậu bé tên là Gran và một chú thằn lằn có cánh tên là Vyrn sống ở Zinkenstill, một hòn đảo với nhiều bí ẩn. Ngày nọ, họ tình cờ gặp một cô gái tên là Lyria. Cô ấy đã trốn thoát khỏi Đế quốc Erste, một chính quyền quân sự thôn tính cai trị thế giới bằng cách dùng sức mạnh quân sự mạnh mẽ. Để thoát khỏi Đế quốc, Gran và Lyria bắt đầu lên đường tới bầu trời mênh mông, theo như lá thư mà cha Gran để lại, ông ấy nói:\"Ta sẽ đợi con ở Estalucia, Đảo của các vì sao.\"</p>","tmdb":{"type":"tv","id":"69820","season":1,"vote_average":6.4,"vote_count":37},"modified":"2022-06-11T17:01:40.000Z","cast":["Yuki Ono","Miyuki Sawashiro","Nao Toyama","Rie Tanaka","Emiri Kato","Keiji Fujiwara","Hisako Kanemoto","Yukari Tamura","Hiroaki Hirata"],"director":["Yuuki Itou"],"cast_meta":[{"name":"Yuki Ono","name_vi":null,"name_original":"Yuki Ono","tmdb_id":1206317,"profile":"https://image.tmdb.org/t/p/w500/oEx13CbNLsHzURdYafkFJYXDjfm.jpg","tmdb_url":"https://www.themoviedb.org/person/1206317"},{"name":"Miyuki Sawashiro","name_vi":null,"name_original":"Miyuki Sawashiro","tmdb_id":186341,"profile":"https://image.tmdb.org/t/p/w500/11mGqwpmu8CoEy1YJgabj2g7MIv.jpg","tmdb_url":"https://www.themoviedb.org/person/186341"},{"name":"Nao Toyama","name_vi":null,"name_original":"Nao Toyama","tmdb_id":1168909,"profile":"https://image.tmdb.org/t/p/w500/6WJDd1z946yFfZBgpC7dWi0FyQw.jpg","tmdb_url":"https://www.themoviedb.org/person/1168909"},{"name":"Rie Tanaka","name_vi":null,"name_original":"Rie Tanaka","tmdb_id":89883,"profile":"https://image.tmdb.org/t/p/w500/wBWsjzwpFovyHDv027zU0oZyWHd.jpg","tmdb_url":"https://www.themoviedb.org/person/89883"},{"name":"Emiri Kato","name_vi":null,"name_original":"Emiri Kato","tmdb_id":1157126,"profile":"https://image.tmdb.org/t/p/w500/m0zqjeg65sEe5TTy