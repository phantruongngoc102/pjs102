ung cư phải sát cánh cùng nhau chống lại đám quái vật để giành lấy sự sống mong manh của mình.</p>","tmdb":{"type":"tv","id":"96648","season":1,"vote_average":8.236,"vote_count":1533},"modified":"2022-05-13T07:38:59.000Z","cast":["Hong So Ri","Jang Young Woo","Kim Hyeong Min"],"director":["Lee Eung-Bok"],"cast_meta":[{"name":"Hong So Ri","name_vi":null,"name_original":"Hong So Ri"},{"name":"Jang Young Woo","name_vi":null,"name_original":"Jang Young Woo"},{"name":"Kim Hyeong Min","name_vi":null,"name_original":"Kim Hyeong Min"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/the-gioi-ma-quai.json"}