are/f675d8aec99e98b4e62c6aae5fb12fb6","link_m3u8":"https://vip.opstream15.com/20220509/12534_167e83b5/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/359499f804ea7988921bf86c9377fb95","link_m3u8":"https://vip.opstream15.com/20220509/12536_9bf0f887/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream15.com/share/b2bb9671f6bda2005155a9078b6fcd07","link_m3u8":"https://vip.opstream15.com/20220509/12539_841029c4/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream15.com/share/2aa99900aa004f52980b7c2cad7ed31a","link_m3u8":"https://vip.opstream15.com/20220509/12541_9550c11a/index.m3u8"}]}],"description":"<p>Phim kể về cuộc hành trình cô độc của nam sinh tên Cha Hyun Soo (do Song Kang đảm nhận). Cha Hyun Soo vốn có tiền sử tự tử, sống ích kỷ và cậu tỏ ra chán ghét cuộc sống ngoài xã hội. Trước đó cậu là một nam sinh trung học bị tổn thương nặng nề sau khi chịu cảnh làm nạn nhân của bạo lực học đường. Cậu rời nhà và đi thuê một căn phòng khác. Biến cố bắt đầu khi cậu liên tục mất tất cả người thân vào một ngày và phải tự mình bươn chải với đời. Tuy nhiên mọi chuyện không đơn giản như cậu ta nghĩ, anh phát hiện ra những sinh vật đáng sợ đang tồn tại và ám ảnh mình. Cha Hyun Soo cùng với Pyeon Sang Wook (Lee Jin Wook thủ vai), bao gồm với những người sống cùng một chung cư phải sát cánh cùng nhau chống lại đám quái vật để giành lấy sự sống mong manh của mình.</p>","tmdb_id":96648,"cast":["Song Kang","Lee Jin-uk","Lee Si-young","Jung Jin-young","Lee Do-hyun","Go Min-si","Yu Oh-seong","Oh Jung-se","Kim Moo-yul","Kim Si-a","Go Youn-jung","Chae Won-been","Kim Ji-an","Yang Hye-ji","Heo Nam-jun"],"director":["Lee Eung-Bok"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"96648","season":1,"vote_average":8.236,"vote_count":1533},"cast_meta":[{"name":"Song Kang","name_vi":null,"name_original":"Song Kang","tmdb_id":1878952,"profile":"https://image.tmdb.org/t/p/w500/83fLAMMb1LGT8YZ4dgRI0fti3az.jpg","tmdb_url":"ht