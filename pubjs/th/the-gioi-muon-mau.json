vip.opstream13.com/20250909/7031_b91f5a1e/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/6af97d7deea1a1d2c76c5c512e66700b","link_m3u8":"https://vip.opstream13.com/20250909/7032_6af97d7d/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/47060dfad0287968d7a4a022691b7f53","link_m3u8":"https://vip.opstream13.com/20250909/7033_47060dfa/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream13.com/share/1f50d0737a738a9ba3206543d1102cbc","link_m3u8":"https://vip.opstream13.com/20250909/7034_1f50d073/index.m3u8"}]}],"description":"Lâm Lạc Nhi (Tuyên Huyên), một người hiền lành, xinh đẹp và tốt bụng, tuy nhiên khiết điểm về thị giác khiến cô tự ti về bản thân. Có một cuộc sống bình yên cùng gia đình trên một đảo nhỏ, Lạc Nhi luôn lạc quan, yêu đời và chấp nhận cuộc sống đơn giản đó. Và cho đến khi Trương Gia Phát xuất hiện, anh đã làm thay đổi tư tưởng, suy nghĩ của Lạc Nhi, giúp cô từ từ bước ra thế giới bên ngoài với nhiều niềm vui, lỗi buồn và cả những thử thách. Hai người rất hợp nhau và luôn dành tình cảm đặc biêt cho nhau nhưng cuối cùng Gia Phát cũng phải rời khỏi đảo. Một thời gian sau, Lạc Nhi quyết định đi tìm Gia Phát, liệu họ có được hưởng hạnh phúc trọn vẹn.","tmdb_id":104587,"cast":[],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"104587","season":1,"vote_average":0,"vote_count":0},"cast_meta":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/the-gioi-muon-mau.json"}