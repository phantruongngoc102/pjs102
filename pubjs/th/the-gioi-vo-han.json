_embed":"https://vip.opstream11.com/share/e60f9011ef48d8d02f27f16d2a8175c1","link_m3u8":"https://vip.opstream11.com/20230313/43062_bf4f6010/index.m3u8"},{"name":"16","slug":"16","filename":"Thế Giới Vô Hạn Tập 16Tập 16","link_embed":"https://vip.opstream11.com/share/c2642e781e07a51e779c62ee00bab576","link_m3u8":"https://vip.opstream11.com/20230319/43107_dbe85e82/index.m3u8"}]}],"time":"19 phút/tập","description":"<p>Một công nhân nhận được lời mời bí ẩn, \"Bạn có muốn biết ý nghĩa của cuộc sống không? Bạn có muốn thực sự sống không?\" Dịch chuyển vào không gian nơi không thể đoán trước của Chúa. Lời mời và thách thức từ con người tương lai đến thế giới hiện tại. Con người trong vũ trụ rộng lớn. Nhiều thách thức phải đối mặt trong thời đại tiên phong sẽ được mô phỏng thành \"bản sao\" để những người được chọn tấn công, vượt qua nhiều cạm bẫy, gặp gỡ đồng đội sinh tử, trở thành trưởng nhóm, vì sự tiến hóa và sự sống còn của loài người, và tương lai vô tận!</p>","tmdb":{"type":"tv","id":"213400","season":1,"vote_average":5.7,"vote_count":3},"modified":"2025-04-14T12:08:58.000Z","cast":["Lin Su","Zongzhe Xu","Lin Jing"],"director":[],"cast_meta":[{"name":"Lin Su","name_vi":null,"name_original":"Lin Su","tmdb_id":3838951,"profile":"https://image.tmdb.org/t/p/w500/ps3K3fMkaBCraHKcYhXID0nI1at.jpg","tmdb_url":"https://www.themoviedb.org/person/3838951"},{"name":"Zongzhe Xu","name_vi":null,"name_original":"Zongzhe Xu","tmdb_id":2472770,"profile":"https://image.tmdb.org/t/p/w500/e0xzKiQ6bi9Snh6p6o87Zm3i4x8.jpg","tmdb_url":"https://www.themoviedb.org/person/2472770"},{"name":"Lin Jing","name_vi":null,"name_original":"Lin Jing","tmdb_id":4063299,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4063299"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/the-gioi-vo-han.json"}