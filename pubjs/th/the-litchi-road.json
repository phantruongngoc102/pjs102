70_c802ceaa/index.m3u8"},{"name":"35","slug":"35","filename":"The Litchi Road - Tập 35---2025","link_embed":"https://vip.opstream90.com/share/45017f6511f91be700fda3d118034994","link_m3u8":"https://vip.opstream90.com/20250624/7795_45017f65/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Phim kể về nhân vật chính Lý Thiện Đức bị đồng liêu lừa gạt, từ một giám sự đã biến thành \"sứ giả vải thiều\". Ông buộc phải nhận một nhiệm vụ \"tử thần\": vận chuyển vải tươi từ Lĩnh Nam đến Trường An để mừng sinh nhật quý phi. Vấn đề là vải thiều \"một ngày thay đổi màu, hai ngày đổi mùi hương, ba ngày thay đổi vị\", trong khi Lĩnh Nam cách Trường An hơn năm ngàn dặm, đường sá xa xôi. Làm thế nào để hoàn thành nhiệm vụ trong điều kiện thời gian khắc nghiệt và thiếu thốn như vậy?</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"203367","season":1,"vote_average":7.3,"vote_count":21},"modified":"2025-06-24T18:30:49.000Z","cast":["Lei Jiayin","Yue Yunpeng","Nashi","Vivienne Tien","Lü Liang","Gong Lei","Phùng Gia Di","Lu Fangsheng","Zhao Wei","Cai Lu","Yan Biguo","Zhou Meijun","Hàn Đồng Sinh"],"director":["Cao Dun"],"cast_meta":[{"name":"Lei Jiayin","name_vi":null,"name_original":"Lei Jiayin","tmdb_id":1724403,"profile":"https://image.tmdb.org/t/p/w500/wjDzXeAycQj01k40oXigRgJCPRr.jpg","tmdb_url":"https://www.themoviedb.org/person/1724403"},{"name":"Yue Yunpeng","name_vi":null,"name_original":"Yue Yunpeng","tmdb_id":1048642,"profile":"https://image.tmdb.org/t/p/w500/eROIOhIu51llWLlITz8GGNZ9MEa.jpg","tmdb_url":"https://www.themoviedb.org/person/1048642"},{"name":"Nashi","name_vi":null,"name_original":"Nashi","tmdb_id":4176055,"profile":"https://image.tmdb.org/t/p/w500/i2oD8NEMmCSXDVtJq0bxOF0cJ4V.jpg","tmdb_url":"https://www.themoviedb.org/person/4176055"},{"name":"Vivienne Tien","name_vi":null,"name_original":"Vivienne Tien","tmdb_id":2762135,"profile":"https://image.tmdb.org/t/p/w500/iIMSjySpkMhgxIm1rzMJb089GUG.jpg","tmdb_url":"https://www.themoviedb.org/person/2762135"},{"name":"Lü Li