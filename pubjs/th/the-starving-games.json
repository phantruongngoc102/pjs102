{"id":"623713d23d016a3b6717ee78","title":"The Starving Games","origin_name":"The Starving Games","slug":"the-starving-games","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/th/the-starving-games.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/th/the-starving-games.webp","year":2013,"type":"single","genre":[{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"},{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"},{"id":"620a229be0fc277084dfd4dd","name":"Khoa Học","slug":"khoa-hoc"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"The Starving Games","link_embed":"https://vip.opstream12.com/share/d3e0f226df6865b28fb677548370f467","link_m3u8":"https://vip.opstream12.com/20220319/4365_a7d041c3/index.m3u8"}]}],"time":"Đang cập nhật","description":"<p>Đặt trong góc đáng buồn nhất của một tương lai hậu tận thế, nữ anh hùng Kantmiss Evershot (Maiara Walsh) tình nguyện viên để đưa vị trí của em gái mình thao túng của cô ấy trong bảy mươi lăm trò chơi đói khát hàng năm. Khi làm như vậy, cô phải để lại phía sau Dale-a-bạn bè của mình (Brant Daugherty) và hợp tác với con trai của Bakey Baker Peter Malarkey (Cody Allen Christian) trong một cuộc chiến cho cuộc sống của cô. Nhưng xin chờ chút nữa! Cô ấy cũng có thể giành được một ham già, một phiếu giảm giá cho một phụ dài bằng chân với giá sáu inch, và một người dưa chua ăn một phần! Trong các trò chơi đói khát, Friedberg và Seltzer's Sixth's Cinematic Cinematic of Office Hit, The Preific Parody Duo có các điểm tham quan được đào tạo về bom tấn phiêu lưu The Hunger Games! Đó là tất cả những lời cười và một nửa lượng calo khi chúng kéo hàng chục mũi tên bị rắn, gai tại các bộ phim khoa học, hành động và tưởng tượng từ những nhân vật và những người nổi tiếng vĩ đại và mạnh mẽ đến Pop như Harry Potter và Taylor Swift.</p>","tmdb":{"type":"movie","id":"225703","season":null,"vote_average":4.242,"vote_count":677},"modified":"2024-11-16T07:19:04.000Z","cast":["Maiara Walsh","Cody Christian","Brant Daugherty","Diedrich Bader","Ross Wyngaarden","Lauren Bowles","Dean J. West","Michael Hartson","Theodus Crane","Chris Marroy","Eryn L. Davis","Kennedy Hermansen","Juhahn Jones","Taylor Murphy","Nick Gomez"],"director":["Jason Friedberg","Aaron Seltzer"],"cast_meta":[{"name":"Maiara Walsh","name_vi":null,"name_original":"Maiara Walsh","tmdb_id":144288,"profile":"https://image.tmdb.org/t/p/w500/cXdNMZ83WAXvRGglqPkyf815Ooi.jpg","tmdb_url":"https://www.themoviedb.org/person/144288"},{"name":"Cody Christian","name_vi":null,"name_original":"Cody Christian","tmdb_id":219664,"profile":"https://image.tmdb.org/t/p/w500/l3DBlk7nLxIOYLKQ40kVHHvEgWB.jpg","tmdb_url":"https://www.themoviedb.org/person/219664"},{"name":"Brant Daugherty","name_vi":null,"name_original":"Brant Daugherty","tmdb_id":1211093,"profile":"https://image.tmdb.org/t/p/w500/5QwCgAqM1fimgebdv7gLDTEmcis.jpg","tmdb_url":"https://www.themoviedb.org/person/1211093"},{"name":"Diedrich Bader","name_vi":null,"name_original":"Diedrich Bader","tmdb_id":5727,"profile":"https://image.tmdb.org/t/p/w500/z7CctykPTuXDfAs7pkAA7vW4b3T.jpg","tmdb_url":"https://www.themoviedb.org/person/5727"},{"name":"Ross Wyngaarden","name_vi":null,"name_original":"Ross Wyngaarden","tmdb_id":1267286,"profile":"https://image.tmdb.org/t/p/w500/aN0c2ekeDK9zSsgdLLJhnzl09pv.jpg","tmdb_url":"https://www.themoviedb.org/person/1267286"},{"name":"Lauren Bowles","name_vi":null,"name_original":"Lauren Bowles","tmdb_id":168326,"profile":"https://image.tmdb.org/t/p/w500/44IKklmPoS73RBd0L07kZb2jKcY.jpg","tmdb_url":"https://www.themoviedb.org/person/168326"},{"name":"Dean J. West","name_vi":null,"