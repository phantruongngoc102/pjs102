stream11.com/share/eaac44eefff218557692720f8a56af4e","link_m3u8":"https://vip.opstream11.com/20230125/41969_51c5af8a/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/777d507edf29d82605c3f695407c681f","link_m3u8":"https://vip.opstream11.com/20230202/42187_40b77d4a/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/f73a5af9af3faf241cfdde1141f3a658","link_m3u8":"https://vip.opstream11.com/20230208/42479_28e604da/index.m3u8"}]}],"description":"<p>Điềm báo của cơn bão sắp làm rung chuyển cả Lục Địa Gió, một buổi hôn lễ đầy rẫy tin tức nội bộ thu hút chú ý của nhân sĩ bốn phương, biến Thành Tiên La thành nơi bảy tông môn lớn minh tranh ám đấu. Lan Tư Lạc đầy tham vọng, Hoa Thứ Lang kiếm thuật trác tuyệt, Hồng Ngũ Lang bí ẩn và đa trí và Thiên Địa Hữu Tuyết đục nước béo cò, lợi dụng dòng chảy ngầm này, hoặc cố tình hoặc vô ý, vì nhân duyên mà tập hợp ở Tiên La, cùng nhau dâng lên một làn gió quái dị nhắm tới Địa Lục Gió.</p>","tmdb_id":124761,"cast":["Ma Haifeng","Qiao Su","江月","张树彬 Shubin Zhang"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"124761","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Ma Haifeng","name_vi":null,"name_original":"Ma Haifeng","tmdb_id":3035396,"profile":"https://image.tmdb.org/t/p/w500/ik7uxOXJ2XRMJKM1KHw2TqUODXB.jpg","tmdb_url":"https://www.themoviedb.org/person/3035396"},{"name":"Qiao Su","name_vi":null,"name_original":"Qiao Su","tmdb_id":3850987,"profile":"https://image.tmdb.org/t/p/w500/joz3baiQTwIMy9nqbeG59CkiT2L.jpg","tmdb_url":"https://www.themoviedb.org/person/3850987"},{"name":"江月","name_vi":null,"name_original":"江月","tmdb_id":5090699,"profile":"https://image.tmdb.org/t/p/w500/pNgEmfdVW3Pcy5yK1mj6kVn9pMG.jpg","tmdb_url":"https://www.themoviedb.org/person/5090699"},{"name":"张树彬 Shubin Zhang","name_vi":null,"name_original":"张树彬 Shubin Zhang","tmdb_id":4387546,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4387546"}],"tmdb_checked":