m/20230104/40798_0342e98d/index.m3u8"}]}],"description":"<p>The Tom and Jerry Comedy Show là một chương trình truyền hình hoạt hình do Filmation sản xuất cho MGM Television vào năm 1980, trên CBS vào các buổi sáng thứ Bảy. Chương trình kéo dài một mùa và các tập riêng lẻ cuối cùng đã được thêm vào các gói Tom và Jerry tổng hợp, đồng thời cũng thỉnh thoảng xuất hiện trên Cartoon Network và Boomerang. Hầu hết các giọng nói được thực hiện bởi Frank Welker và Lou Scheimer.</p>","tmdb_id":14705,"cast":["Lou Scheimer"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"14705","season":1,"vote_average":7.357,"vote_count":63},"cast_meta":[{"name":"Lou Scheimer","name_vi":null,"name_original":"Lou Scheimer","tmdb_id":176055,"profile":"https://image.tmdb.org/t/p/w500/4tIrsOTcDVzE7LNyAIDr1fA5Q8z.jpg","tmdb_url":"https://www.themoviedb.org/person/176055"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/the-tom-and-jerry-comedy-show.json"}