ream-short.com/20251121/41862_0ade1197/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream-short.com/share/ad23d17e84b11e505c01aae76b1d08a4","link_m3u8":"https://vip.opstream-short.com/20251121/41863_ad23d17e/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream-short.com/share/a3980fc1d4915887bc4b815080e58a00","link_m3u8":"https://vip.opstream-short.com/20251121/41864_a3980fc1/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream-short.com/share/45ea7a74693f661f47516842014b1f76","link_m3u8":"https://vip.opstream-short.com/20251121/41865_45ea7a74/index.m3u8"}]}],"description":"<p>Tống Thanh Thanh, nữ sinh đại học lớn lên trong nghịch cảnh, bước vào cổng trường đại học với đầy ước mơ và hy vọng. Như mọi sinh viên khác, cô kết bạn sâu sắc và tìm thấy tình yêu trong trẻo trên campus. Đối mặt với sự chia ly tốt nghiệp và khoảng cách giữa lý tưởng và hiện thực, Tống Thanh Thanh và Hoàng Tiểu Minh - cặp đôi yêu nhau từ lần đầu gặp gỡ, phải lựa chọn con đường khác nhau cho tương lai. Trong chuyến du lịch tốt nghiệp, Thanh Thanh và bạn bè vô tình dính líu vào một vụ giao dịch tội phạm, biến chuyến đi thành cuộc phiêu lưu sinh tử.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/theo-duoi-uoc-mo-cung-em-short-drama.json","tmdb_checked":false}