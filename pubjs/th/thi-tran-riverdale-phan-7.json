ndex.m3u8"}]}],"time":"45 phút/tập","description":"<p>Tiếp nối phần 6 đã kết thúc, phần 7 tìm thấy Jughead Jones bị mắc kẹt trong những năm 1950. Anh ta không biết làm thế nào anh ta đến đó, cũng như làm thế nào để quay trở lại hiện tại. Bạn bè của anh ấy không giúp được gì, vì họ đang sống cuộc sống có vẻ chân thực, tương tự như các đối tác Archie Comics cổ điển của họ, không biết rằng họ đã từng ở bất cứ đâu ngoài những năm 1950. Liệu Jughead và đồng bọn có thể trở về hiện tại? Hay các nhân vật của chúng ta sẽ bị mắc kẹt trong những năm 1950 mãi mãi? Và, nếu vậy ... đó có phải là một điều xấu?</p>","tmdb":{"type":"tv","id":"69050","season":7,"vote_average":8.416,"vote_count":13653},"modified":"2023-08-25T15:57:16.000Z","cast":["KJ Apa","Lili Reinhart","Camila Mendes","Cole Sprouse","Madelaine Petsch","Casey Cott","Drew Ray Tanner","Vanessa Morgan","Mädchen Amick"],"director":[],"cast_meta":[{"name":"KJ Apa","name_vi":null,"name_original":"KJ Apa","tmdb_id":1680339,"profile":"https://image.tmdb.org/t/p/w500/e2mowKCKKkexzsKy0bTGk5S5Soa.jpg","tmdb_url":"https://www.themoviedb.org/person/1680339"},{"name":"Lili Reinhart","name_vi":null,"name_original":"Lili Reinhart","tmdb_id":1136940,"profile":"https://image.tmdb.org/t/p/w500/wt4SuihSkEA0bOc0JTtsgCD7pHZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1136940"},{"name":"Camila Mendes","name_vi":null,"name_original":"Camila Mendes","tmdb_id":1721740,"profile":"https://image.tmdb.org/t/p/w500/pZAWRHdJtJlDcWuQHlgIwX12s02.jpg","tmdb_url":"https://www.themoviedb.org/person/1721740"},{"name":"Cole Sprouse","name_vi":null,"name_original":"Cole Sprouse","tmdb_id":56730,"profile":"https://image.tmdb.org/t/p/w500/mQAXL0rUGwX316d1FBBQmloZzHu.jpg","tmdb_url":"https://www.themoviedb.org/person/56730"},{"name":"Madelaine Petsch","name_vi":null,"name_original":"Madelaine Petsch","tmdb_id":1592855,"profile":"https://image.tmdb.org/t/p/w500/mfZo30YgMx7vhAUajM8OG6I6VM8.jpg","tmdb_url":"https://www.themoviedb.org/person/1592855"},{"n