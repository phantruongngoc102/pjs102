15.com/share/1aa7690e43a5471b7344591df7afb611","link_m3u8":"https://vip.opstream15.com/20220521/15950_60a4fb93/index.m3u8"},{"name":"6","slug":"6","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-6","link_embed":"https://vip.opstream15.com/share/8441c6ab9e88ee3764bd79b6d72269a1","link_m3u8":"https://vip.opstream15.com/20220521/15951_159c7f91/index.m3u8"},{"name":"7","slug":"7","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-7","link_embed":"https://vip.opstream15.com/share/6c76b077da2c70369698bfef9bfb5be7","link_m3u8":"https://vip.opstream15.com/20220521/15952_bf352649/index.m3u8"},{"name":"8","slug":"8","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-8","link_embed":"https://vip.opstream15.com/share/84d2a013f34a449185e0a8b510929235","link_m3u8":"https://vip.opstream15.com/20220521/15953_c1d2ce65/index.m3u8"},{"name":"9","slug":"9","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-9","link_embed":"https://vip.opstream15.com/share/26dd3e3520fb7e479ba6e8f53f150d10","link_m3u8":"https://vip.opstream15.com/20220521/15954_47498f1d/index.m3u8"},{"name":"10","slug":"10","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-10","link_embed":"https://vip.opstream15.com/share/d999ac77ec9c98bd436d1016a6a8276a","link_m3u8":"https://vip.opstream15.com/20220521/15955_96496bc3/index.m3u8"},{"name":"11","slug":"11","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-11","link_embed":"https://vip.opstream15.com/share/281bc81fb21d55e267f37af58d79801a","link_m3u8":"https://vip.opstream15.com/20220521/15956_fa1b96c2/index.m3u8"},{"name":"12","slug":"12","filename":"thien-anh-hung-ca-sengoku-night-blood-tap-12","link_embed":"https://vip.opstream15.com/share/4d3a2c830a6d81fe70e1a0691218121a","link_m3u8":"https://vip.opstream15.com/20220521/15957_47ec7122/index.m3u8"}]}],"time":"","description":"<p>Một hôm, Yuzuki bị bao phủ bởi tia sáng bí ẩn phát ra từ điện thoại của cô và thấy mình ở một nơi lạ. Phong cảnh trước mắt cô giống như thời Sengoku (Chiến quốc) Nhật bản. Nhưng đây là thế giới khác được gọi là \"Shinga\", nơi mà các sinh vật không phải con người như ma cà rồng và người sói cư trú. Toyotomi Hideyoshi, người lãnh đạo quân Toyotomi, mang Yuzuki đi theo sau khi giải cứu cô trên chiến trường và vô tình phát hiện máu của cô có thể đánh thức sức mạnh tiềm ẩn của Tộc Gegga. Sau khi biết được sức mạnh của máu Yuzuki, các lãnh chúa khác như Oda, Uesugi, Takeda, Sanada và Date bắt đầu theo đuổi Yuzuki, mỗi người đều có mục đích riêng.</p>","tmdb":{"type":"tv","id":"74184","season":1,"vote_average":7.4,"vote_count":5},"modified":"2022-05-24T11:05:01.000Z","cast":["Katsuyuki Konishi","Yuuichirou Umehara","Natsuki Hanae"],"director":["Katsuya Kikuchi"],"cast_meta":[{"name":"Katsuyuki Konishi","name_vi":null,"name_original":"Katsuyuki Konishi"},{"name":"Yuuichirou Umehara","name_vi":null,"name_original":"Yuuichirou Umehara"},{"name":"Natsuki Hanae","name_vi":null,"name_original":"Natsuki Hanae"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thien-anh-hung-ca-2017.json"}