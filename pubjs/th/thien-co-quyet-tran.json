n đi người mà nàng yêu nhất. Bây giờ, Cửu Châu tịch mịch, tam giới tuyệt vọng, Càn Khôn chỉ còn lại bóng dáng cô độc của nàng. Lần này, đổi lại là nàng đợi người ấy trở lại.\"</p>","tmdb":{"type":"tv","id":"102777","season":1,"vote_average":7.5,"vote_count":26},"modified":"2022-05-31T11:31:14.000Z","cast":["Châu Đông Vũ","Hứa Khải","Lưu Học Nghĩa","Lý Trạch Phong","La Thu Vận","Trương Nhã Khâm","Lai Nghệ","Zhong Qi","Đại Tư","Phó Tân Bác","Zhang Jiani","Trương Vân Long"],"director":["Doãn Đào","Lý Tài"],"cast_meta":[{"name":"Châu Đông Vũ","name_vi":"Châu Đông Vũ","name_original":"Zhou Dongyu","tmdb_id":145092,"profile":"https://image.tmdb.org/t/p/w500/vD2vVvIIx8ygzkhUQZJLkvYT1jr.jpg","tmdb_url":"https://www.themoviedb.org/person/145092"},{"name":"Hứa Khải","name_vi":"Hứa Khải","name_original":"Xu Kai","tmdb_id":2091759,"profile":"https://image.tmdb.org/t/p/w500/wEfatQWa3v9tNtmgr5LOOmFSSJj.jpg","tmdb_url":"https://www.themoviedb.org/person/2091759"},{"name":"Lưu Học Nghĩa","name_vi":"Lưu Học Nghĩa","name_original":"Liu Xueyi","tmdb_id":2084467,"profile":"https://image.tmdb.org/t/p/w500/zJG3K9Ey4EJp9p2wu88UchkgRG0.jpg","tmdb_url":"https://www.themoviedb.org/person/2084467"},{"name":"Lý Trạch Phong","name_vi":"Lý Trạch Phong","name_original":"Li Zefeng","tmdb_id":1910069,"profile":"https://image.tmdb.org/t/p/w500/fqPhLubbymkJ8ILJSuVkTAgyaP8.jpg","tmdb_url":"https://www.themoviedb.org/person/1910069"},{"name":"La Thu Vận","name_vi":"La Thu Vận","name_original":"Luo Qiuyun","tmdb_id":2863227,"profile":"https://image.tmdb.org/t/p/w500/6L7DtHNaj7JiwFGFb7xRswFumm6.jpg","tmdb_url":"https://www.themoviedb.org/person/2863227"},{"name":"Trương Nhã Khâm","name_vi":"Trương Nhã Khâm","name_original":"Zhang Yaqin","tmdb_id":1971604,"profile":"https://image.tmdb.org/t/p/w500/mBsq8Vch45vbJ78m6Hlf9ryoTnr.jpg","tmdb_url":"https://www.themoviedb.org/person/1971604"},{"name":"Lai Nghệ","name_vi":"Lai Nghệ","name_original":"Lai Yi","tmdb_id":1971420,"profile":"https://image.tmdb.org/t/p/w