x.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream15.com/share/44895ba66f4c02432a9ea77523364819","link_m3u8":"https://vip.opstream15.com/20250125/48335_44895ba6/index.m3u8"}]}],"description":"<p>Thời cổ đại, Hoàng đế Nhân tộc Chiêu Minh vì muôn dân mà xả thân, hy sinh bản thân để chống lại thần giới. Sau khi Chiêu Minh ngã xuống, người yêu của ông, Hỗn Độn Châu đã liều mạng cứu vớt một phần hồn phách của ông, lập ra vòng luân hồi vạn thế. Vạn thế sau, Chiêu Minh đầu thai thành Minh chủ Tiên minh, Tạ Tuyết Thần, còn Hỗn Độn Châu trở thành Thánh nữ Ám vực, Mộ Huyền Linh. Hai người cuối cùng tái ngộ ở nhân gian, nhưng đã quên hết quá khứ, trở thành đối thủ không đội trời chung. Mộ Huyền Linh trong Ám vực cứu sống Tạ Tuyết Thần đang trọng thương, lấy ân cứu mạng để ép buộc hắn cùng đồng hành. Dọc đường, hai người từ kẻ thù đầy toan tính đến đồng đội sát cánh, dần tháo bỏ phòng bị và nảy sinh tình cảm. Tuy nhiên, trong âm mưu tranh đoạt thần khí “Hỗn Độn Châu,” hai người rơi vào thử thách sinh tử. Mộ Huyền Linh vì cứu thế gian mà hy sinh, Tạ Tuyết Thần nghịch thiên cải mệnh, quay lại quá khứ cứu nàng. Kiếp nạn vạn thế kết thúc, cuối cùng hồn của Tạ Tuyết Thần trở về Chiêu Minh, nhưng bản thể Chiêu Minh đã trở thành Thần Sa Đọa. Mộ Huyền Linh dùng tình yêu để đánh thức Thần Sa Đọa, hóa giải đại họa, mang lại thái bình cho thiên hạ.</p><p>&nbsp;</p>","tmdb_id":243512,"cast":["Trương Bân Bân","Tôn Trân Ny","Uông Đạc","Trương Nhã Khâm","Wu Yuheng","Trần Vũ Hiền"],"director":["Sam Ho Shu-Pui"],"keywords":[],"tmdb":{"type":"tv","id":"243512","season":1,"vote_average":7.9,"vote_count":12},"cast_meta":[{"name":"Trương Bân Bân","name_vi":"Trương Bân Bân","name_original":"Vin Zhang","tmdb_id":1701963,"profile":"https://image.tmdb.org/t/p/w500/8LvvrOhj4zxPuYgpPJ9HWyJzf4a.jpg","tmdb_url":"https://www.themoviedb.org/person/1701963"},{"name":"Tôn Trân Ny","name_vi":"Tôn Trân Ny","name_original":"Sun Zhenni","tmdb_id":3287640,"profile":"https://image.tmdb.org/t/p/w500