 đó, sự thật đằng sau việc anh xuyên không cũng dần dần được hé lộ.</p><p>&nbsp;</p>","tmdb_id":296355,"cast":["Lu Yunfeng","Ma Xinyu","Bu Ziying","Guo Xiang"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"296355","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lu Yunfeng","name_vi":null,"name_original":"Lu Yunfeng","tmdb_id":2500602,"profile":"https://image.tmdb.org/t/p/w500/1JdMTEJUuk8nxENyFs2TcqLJx0C.jpg","tmdb_url":"https://www.themoviedb.org/person/2500602"},{"name":"Ma Xinyu","name_vi":null,"name_original":"Ma Xinyu","tmdb_id":2282092,"profile":"https://image.tmdb.org/t/p/w500/mdjTKbQh9MnYQKrgaIIYVoEoJC6.jpg","tmdb_url":"https://www.themoviedb.org/person/2282092"},{"name":"Bu Ziying","name_vi":null,"name_original":"Bu Ziying","tmdb_id":3938015,"profile":"https://image.tmdb.org/t/p/w500/87cXGG2oq92rxbKU4mR0meQP9Uo.jpg","tmdb_url":"https://www.themoviedb.org/person/3938015"},{"name":"Guo Xiang","name_vi":null,"name_original":"Guo Xiang","tmdb_id":5575046,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5575046"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/thien-hi-phong-van.json"}