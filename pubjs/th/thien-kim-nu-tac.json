nk_m3u8":"https://vip.opstream17.com/20240616/11999_f48eefad/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream17.com/share/516cc95d0baf5a0b04f55d8ae4212944","link_m3u8":"https://vip.opstream17.com/20240616/11998_66d849d9/index.m3u8"}]}],"description":"\"Thiên kim nữ tặc\" lấy bối cảnh ở thành phố Thượng Hải những năm 30. Câu chuyện xoay quanh hai người con gái Tưởng Tâm (Đường Yên), cô con gái bị mất tích từ lâu của một gia đình giàu có và Đỗ Tiểu Hàn (Dương Dung), một tên trộm vừa mới vượt ngục.\n\nSau một tai nạn trên biển, Tưởng Tâm đã bị mất đi ký ức của mình. Đỗ Tiểu Hàn đã tận dụng cơ hội này để giả mạo làm Tưởng Tâm và có cuộc sống vinh hoa phú quý.","tmdb_id":63191,"cast":["Đường Yên","Lưu Khải Uy","Dương Dung","Dương Hựu Ninh","Trương Manh","Tai Chih-yuan","臧洪娜","Vương Ngạn Lâm","Zhang Xin","Lu Senbao","Vương Đức Thuận"],"director":["Chou Hsiao Peng"],"keywords":[],"tmdb":{"type":"tv","id":"63191","season":1,"vote_average":7.5,"vote_count":2},"cast_meta":[{"name":"Đường Yên","name_vi":"Đường Yên","name_original":"Tang Yan","tmdb_id":99691,"profile":"https://image.tmdb.org/t/p/w500/eW3F16Namf5EoCmeWaTdkd3ncoH.jpg","tmdb_url":"https://www.themoviedb.org/person/99691"},{"name":"Lưu Khải Uy","name_vi":"Lưu Khải Uy","name_original":"Hawick Lau Hau-Wai","tmdb_id":1223046,"profile":"https://image.tmdb.org/t/p/w500/zU4ZgnWcsjPx7eTO2wLUf5z5H3c.jpg","tmdb_url":"https://www.themoviedb.org/person/1223046"},{"name":"Dương Dung","name_vi":"Dương Dung","name_original":"Yang Rong","tmdb_id":1258369,"profile":"https://image.tmdb.org/t/p/w500/skYJrfi5ii3dHxA2a5Gra7ZCAMT.jpg","tmdb_url":"https://www.themoviedb.org/person/1258369"},{"name":"Dương Hựu Ninh","name_vi":"Dương Hựu Ninh","name_original":"Tony Yang","tmdb_id":96958,"profile":"https://image.tmdb.org/t/p/w500/d0C8Dp9itcFV4Q8bLRISguGJmPR.jpg","tmdb_url":"https://www.themoviedb.org/person/96958"},{"name":"Trương Manh","name_vi":"Trương Manh","name_original":"Zhang Meng","tmdb_id":1612556,"profile"