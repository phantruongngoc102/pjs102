","spirit","storm"],"tmdb":{"type":"movie","id":"9048","season":null,"vote_average":6.5,"vote_count":102},"cast_meta":[{"name":"Lương Triều Vỹ","name_vi":"Lương Triều Vỹ","name_original":"Tony Leung Chiu-wai","tmdb_id":1337,"profile":"https://image.tmdb.org/t/p/w500/nQbSQAws5BdakPEB5MtiqWVeaMV.jpg","tmdb_url":"https://www.themoviedb.org/person/1337"},{"name":"Trương Học Hữu","name_vi":"Trương Học Hữu","name_original":"Jacky Cheung Hok-Yau","tmdb_id":25245,"profile":"https://image.tmdb.org/t/p/w500/eoh2sI1IBYmQSuIapr32EUbl3Nw.jpg","tmdb_url":"https://www.themoviedb.org/person/25245"},{"name":"Vương Tổ Hiền","name_vi":"Vương Tổ Hiền","name_original":"Joey Wong","tmdb_id":68557,"profile":"https://image.tmdb.org/t/p/w500/czi7jy9VnrEmrJTE9oVUJRgDsY.jpg","tmdb_url":"https://www.themoviedb.org/person/68557"},{"name":"Lợi Trí","name_vi":"Lợi Trí","name_original":"Nina Li Chi","tmdb_id":26785,"profile":"https://image.tmdb.org/t/p/w500/7c4aCvQ7L6XHjLlO5wLmSEqZSv3.jpg","tmdb_url":"https://www.themoviedb.org/person/26785"},{"name":"Lưu Triệu Minh","name_vi":"Lưu Triệu Minh","name_original":"Lau Siu-Ming","tmdb_id":56804,"profile":"https://image.tmdb.org/t/p/w500/qYtz9B0AwTSIJmObwCeZPYIGmcO.jpg","tmdb_url":"https://www.themoviedb.org/person/56804"},{"name":"Lưu Tuân","name_vi":"Lưu Tuân","name_original":"Lau Shun","tmdb_id":65974,"profile":"https://image.tmdb.org/t/p/w500/sNnEnje7gqpOQZR3NWIodvh0ti5.jpg","tmdb_url":"https://www.themoviedb.org/person/65974"},{"name":"Tiffany Lau Yuk-Ting","name_vi":null,"name_original":"Tiffany Lau Yuk-Ting","tmdb_id":1358812,"profile":"https://image.tmdb.org/t/p/w500/zi7jiT5rpqnhwJRjx8TMnyV0zA7.jpg","tmdb_url":"https://www.themoviedb.org/person/1358812"},{"name":"Huỳnh Quang Lượng","name_vi":"Huỳnh Quang Lượng","name_original":"Tommy Wong","tmdb_id":1135394,"profile":"https://image.tmdb.org/t/p/w500/4vcp6AtQpaW5LrAwkDudVy6ibUt.jpg","tmdb_url":"https://www.themoviedb.org/person/1135394"},{"name":"Sam Ho Choi-Chow","name_vi":null,"name_original":"