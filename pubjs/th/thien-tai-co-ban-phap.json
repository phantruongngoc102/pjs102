546e793d51f41ab68","link_m3u8":"https://vip.opstream16.com/20221224/28111_7978e756/index.m3u8"},{"name":"33","slug":"33","filename":"thien-tai-co-ban-phap-tap-33","link_embed":"https://vip.opstream16.com/share/a311dd84030f32ea6e0550b09f5869eb","link_m3u8":"https://vip.opstream16.com/20221224/28112_9c8617dc/index.m3u8"},{"name":"34","slug":"34","filename":"thien-tai-co-ban-phap-tap-34","link_embed":"https://vip.opstream16.com/share/854b68b3c6c3e69b52672108c5a99010","link_m3u8":"https://vip.opstream16.com/20221224/28113_b80aaf25/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Thiên Tài Cơ Bản Pháp (Phương Pháp Cơ Bản Để Trở Thành Thiên Tài) kể về câu chuyện của thiên tài toán học Lâm Triệu Sinh, con gái của ông Lâm Triều Tịch, và một thiếu niên có chỉ số IQ cao - Bùi Chi là những người tìm thấy chính mình trong lý luận toán học và tương tác không-thời gian kép. Một công thức toán học bí ẩn đã bất ngờ đưa Lâm Triều Tịch 13 tuổi đến một thế giới song song. Trong chuyến phiêu lưu kỳ lạ này, Lâm Triều Tịch bằng kinh nghiệm thi Olympic Toán học tích lũy trong nhiều năm, chợt nhận ra rằng những lần hụt hẫng, mất niềm tin, và cả căn bệnh nan y của cha, khi cô tìm được sự ưu ái này từ số phận, mọi thứ đều có khả năng bù đắp lại - cho dù đó là khởi đầu vô cùng tồi tệ, cuộc sống cũng có thể có sức sống vô hạn.</p>","tmdb":{"type":"tv","id":"206489","season":1,"vote_average":6.9,"vote_count":13},"modified":"2025-04-26T12:54:58.000Z","cast":["Lei Jiayin","Trương Tử Phong","Trương Tân Thành"],"director":["Shen Yan"],"cast_meta":[{"name":"Lei Jiayin","name_vi":null,"name_original":"Lei Jiayin","tmdb_id":1724403,"profile":"https://image.tmdb.org/t/p/w500/wjDzXeAycQj01k40oXigRgJCPRr.jpg","tmdb_url":"https://www.themoviedb.org/person/1724403"},{"name":"Trương Tử Phong","name_vi":"Trương Tử Phong","name_original":"Zhang Zifeng","tmdb_id":1173805,"profile":"https://image.tmdb.org/t/p/w500/3S8yEnTVqH8T3bTVf9FmtXxWcu2.jpg","tmdb_url":"https://www.themoviedb.org/person/1173805"},{"n