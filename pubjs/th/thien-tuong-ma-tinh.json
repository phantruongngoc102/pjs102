share/2b8dec786a8cdf5889309995733b54d4","link_m3u8":"https://vip.opstream17.com/20240509/7176_8941e8ed/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/37aa5dfc44dddd0d19d4311e2c7a0240","link_m3u8":"https://vip.opstream17.com/20240509/7175_0862d3e8/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/0b229b5ea84cc5f79dcaf2984efb7e45","link_m3u8":"https://vip.opstream17.com/20240509/7174_0c9f0e36/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream17.com/share/162d18156abe38a3b32851b72b1d44f5","link_m3u8":"https://vip.opstream17.com/20240509/7173_8116227b/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream17.com/share/1d0832c4969f6a4cc8e8a8fffe083efb","link_m3u8":"https://vip.opstream17.com/20240509/7172_b2aeb6f6/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream17.com/share/a35f4223bb8f6c8638dc91d94e9b16f5","link_m3u8":"https://vip.opstream17.com/20240509/7171_37ae4d07/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream17.com/share/9eb53b5052d534ea2619ca03b5649af7","link_m3u8":"https://vip.opstream17.com/20240509/7170_2ff70349/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream17.com/share/b44182379bf9fae976e6ae5996e13cd8","link_m3u8":"https://vip.opstream17.com/20240509/7169_0b86e443/index.m3u8"}]}],"description":"<p><i>Tổ tiên của các tầng trời và thế giới quỷ Ao Xing đã chiến đấu hàng ngàn năm cho sự hóa thân của các vì sao, và cuối cùng kết thúc bằng sự thất bại của Ao Xing và bị mắc kẹt trong khóa thiên đường. Biao Xing Yuanshen ra khỏi cơ thể, và khi ngọn lửa cuồng nộ đi vào ma quỷ, Đấng Tối cao đã ném vào cơ thể anh ta và điều khiển anh ta, và anh ta đã luyện tập \"Cửu sao Liên hoa\" cả ngày, để phá vỡ cạm bẫy của bầu trời, và Đấng tối cao có thể sống thêm 20 năm nữa. Đấng tối cao có được sức mạnh của Yuanshen, loại bỏ đối thủ Taoyuan King và trở thành thế hệ bá chủ, và con trai của Taoyuan King là Wei Tianbao, với sự giúp đỡ của Tianjie Yuan vào trong lỗ, tìm thấy thanh kiếm thần, và tôn thờ Ding Yi và Bu Guanyi là Dunjia ở cửa bên trái. Điều hiếm hoi hơn nữa là anh đã yêu Yi Hanyan, con gái của Đấng tối cao, và họ có tình cảm với nhau. Yan dù là người hiếu thảo nhưng cha anh bị linh hồn quỷ dữ khống chế nên không ngần ngại giúp Bảo ngay chính giết người thân của mình. Ngoài ra, Bảo kiếm được sức mạnh tâm tình và san hô đỏ để trở thành chủ nhân của biệt thự lánh nạn, sau đó anh được thăng làm chủ nhân của thánh điện vì đã bình định được nội loạn ở cổng thánh kiếm. Đối với thuộc hạ của Taoyuan King, Tianchu, và việc thành lập một Taoyuan nhỏ trên bầu trời, cũng tăng sức mạnh của Bao chống lại Tianzun; Bao’s Refuge Villa, Shengjianmen, và sức mạnh của Xiaotaoyuan, tất cả những khó khăn và dã thú đều đánh bại được Fire Supreme. Tuy nhiên, lúc này sao tà đã thành một vệt chín sao, và sau khi nguyên thần trở lại lỗ phun, trận chiến thực sự mới bắt đầu ...</i></p>","tmdb_id":101382,"cast":["Veronica Yip Yuk-Hing","Yuen Cheung-Yan"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"101382","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Veronica Yip Yuk-Hing","name_vi":null,"name_original":"Veronica Yip Yuk-Hing","tmdb_id":1377675,"profile":"https://image.tmdb.org/t/p/w500/zzLN0nVBTFlO4gokEtLVXQEzc76.jpg","tmdb_url":"https://www.themoviedb.org/person/1377675"},{"name":"Yuen Cheung-Yan","name_vi":null,"name_original":"Yuen Cheung-Yan","tmdb_id":65975,"profile":"https://image.tmdb.org/t/p/w500/sI8Dr2Icy31xRiODXPThiK6XkYv.jpg","tmdb_url":"https://www.themoviedb.org/person/65975"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/thien-tuong-ma-tinh.json"}