{"id":"62ae08827a956fb5db178fac","title":"Thiết Thính Phong Vân","origin_name":"Overheard","slug":"thiet-thinh-phong-van","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/th/thiet-thinh-phong-van.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/th/thiet-thinh-phong-van.webp","year":2009,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"},{"id":"620a2293e0fc277084dfd489","name":"Phiêu Lưu","slug":"phieu-luu"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a2347e0fc277084dfd876","name":"Hồng Kông","slug":"hong-kong"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"thiet-thinh-phong-van-overheard","link_embed":"https://vip.opstream14.com/share/8e3e59214cfae2e1afa470119559e683","link_m3u8":"https://vip.opstream14.com/20220617/14799_dbe9bb8b/index.m3u8"}]}],"time":"","description":"<p>Dương (Cổ Thiên Lạc), Tường (Ngô Ngạn Tổ) và Tuấn (Lưu Thanh Vân) là 3 người chơi thân với nhau trong đội tình báo của Cục liêm chính Hong Kong. Nhiệm vụ của họ là lắp đặt các thiết bị quay trộm và nghe lén tại các công ty là đối tượng về tội phạm kinh tế , để tìm ra chứng cứ phạm tội. Lần hành động này, đối tượng tình nghi là Tập đoàn Phong Hoa. Trong một lần nghe lén, Dương và Tường đã biết được thông tin mật về giá cổ phiếu của Phong Hoa, mà thông tin này có thể sẽ kiếm được rất nhiều tiền nếu như mua cổ phiếu Phong Hoa với số lượng lớn. Dương đang bị bệnh nặng chỉ còn sống được 1 năm, anh muốn nhân dịp này kiếm một số tiền để lại cho vợ con. Dương cầu xin Tường xóa đoạn ghi chép đó đi. Hai người bắt đầu bỏ số tiền lớn mua vào cổ phiếu Phong Hoa, Tuấn cũng đành phải bao che cho bạn, ém nhẹm với cấp trên...</p>","tmdb":{"type":"movie","id":"24889","season":null,"vote_average":6.906,"vote_count":112},"modified":"2022-06-18T17:16:50.000Z","cast":["Lưu Thanh Vân","Cổ Thiên Lạc","Ngô Ngạn Tổ","Trương Tịnh Sơ","Phương Trung Tín","Michael Wong","Dominic Lam Ka-Wah","Lý Tử Hùng","Sharon Luk Sze-Wan","Trần Vỹ Đình","Âu Cẩm Đường","Queenie Chu Wai-Man","Phương Bình","Lạc Ứng Quân","Geoffrey Wong Chi-Hung"],"director":["Felix Chong","Alan Mak"],"cast_meta":[{"name":"Lưu Thanh Vân","name_vi":"Lưu Thanh Vân","name_original":"Sean Lau Ching-wan","tmdb_id":940339,"profile":"https://image.tmdb.org/t/p/w500/ecxJyPA6EPDG2AXomVJORaN4qLZ.jpg","tmdb_url":"https://www.themoviedb.org/person/940339"},{"name":"Cổ Thiên Lạc","name_vi":"Cổ Thiên Lạc","name_original":"Louis Koo","tmdb_id":78875,"profile":"https://image.tmdb.org/t/p/w500/yQuDBTzm7xWlJICNvl20OmcJP80.jpg","tmdb_url":"https://www.themoviedb.org/person/78875"},{"name":"Ngô Ngạn Tổ","name_vi":"Ngô Ngạn Tổ","name_original":"Daniel Wu","tmdb_id":64436,"profile":"https://image.tmdb.org/t/p/w500/w6fCmYDlTNYfgdXBZjZH107c9zJ.jpg","tmdb_url":"https://www.themoviedb.org/person/64436"},{"name":"Trương Tịnh Sơ","name_vi":"Trương Tịnh Sơ","name_original":"Zhang Jingchu","tmdb_id":41894,"profile":"https://image.tmdb.org/t/p/w500/nQdau9zu3e91AZZv471hKBnjIHo.jpg","tmdb_url":"https://www.themoviedb.org/person/41894"},{"name":"Phương Trung Tín","name_vi":"Phương Trung Tín","name_original":"Alex Fong Chung-Sun","tmdb_id":21914,"profile":"https://image.tmdb.org/t/p/w500/qQKB910E3e2YLOQs4WdaouJiFJE.jpg","tmdb_url":"https://www.themoviedb.org/person/21914"},{"name":"Michael Wong","name_vi":null,"name_original":"Michael Wong","tmdb_id":64896,"profile":"https://image.tmdb.org/t/p/w500/k3iH4zPZ8faWEF5uJeiq7fTtg7p.jpg","tmdb_url":"https://www.themoviedb.org/person/64896"},{"name":"Dominic Lam Ka-Wah","name_vi":null,"name_original":"Dominic Lam Ka-Wah","tmdb_id":1175810,"profil