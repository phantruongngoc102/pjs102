.opstream15.com/20230725/40837_a6b4ac8b/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream15.com/share/7b27ab2fbcbe3b67935da0694742ed0e","link_m3u8":"https://vip.opstream15.com/20230725/40839_457be5cf/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/83db1518c5bd4e9bf12fdf97de0d29fc","link_m3u8":"https://vip.opstream15.com/20230725/40840_5552c7ed/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream15.com/share/c99d191b82af960a7bfab48a035d2f8b","link_m3u8":"https://vip.opstream15.com/20230725/40841_c277b4f7/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream15.com/share/d303e6665ea75181d5bdf2221aa8a0fa","link_m3u8":"https://vip.opstream15.com/20230725/40842_8a503f42/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream15.com/share/3514f1f7f9a8c61c063aa8cd834c5561","link_m3u8":"https://vip.opstream15.com/20230725/40844_098abc2f/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream15.com/share/5578e16e3443da7f7af10c70874a7fe2","link_m3u8":"https://vip.opstream15.com/20230725/40843_cdd90d13/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream15.com/share/0c24bb115003e07539daeb5370faf136","link_m3u8":"https://vip.opstream15.com/20230725/40845_996674ad/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream15.com/share/a38a9af287823928c8b66b29dde21c29","link_m3u8":"https://vip.opstream15.com/20230725/40846_72906928/index.m3u8"}]}],"description":"<p>Thiếu Gia Xã Hội Đen Yêu Tôi (KinnPorsche The Series) xoay quanh câu chuyện của hai chị em Jennaree và Lalisa, họ muốn trở thành cảnh sát để trả thù cho cha. Họ vào văn phòng của Công tố viên Non, người đã xử lí vụ án Sakda, tên mafia giết cha họ. Cả hai đều hài lòng với vụ án này. Nhưng cuối cùng, Jennaree đã giết chết Sakda do nhầm lẫn. Thuộc hạ của Sakda sau đó đã trả thù bằng cách giết mẹ của họ. Điều này khiến Lalisa rất giận Jennaree, tạo nên rạn nứt không thể hàn gắn giữa hai chị em. Công tố viên Non cố gắng giúp Jennaree, nhưng thay vào đó lại tạo ra mối tình tay ba cho ba người họ. Lalisa trở nên ghen tị với Jennaree khi cô phát hiện ra những gì Công tố viên Non đã làm cho Jennaree. Công tố viên Non đợi Jennaree quay lại bên mình, nhưng Jennaree lại luôn tránh xa anh, khiến mặt tốt xấu của hai chị em đối lập nhau. Xung đột khó tránh khỏi này có khả năng giúp cả hai yêu thương nhau lần nữa.</p>","tmdb_id":117067,"cast":["Phakphum Romsaithong","Nattawin Wattanagitiphat","Wichapas Sumettikul","Jakapan Puttha","Jeff Satur","Tinnasit Isarapongporn","Nannakun Pakapatpornpob","Thanayut Thakoonauttaya","Nititorn Akkarachotsopon","Chalach Tantijibul","Nutthasid Panyangarm","Nakhun Screaigh","Yosatorn Konglikit","Pongsakorn Ponsantigul","Touchchavit Kulkrachang"],"director":["Kongkiat Komesiri"],"keywords":[],"tmdb":{"type":"tv","id":"117067","season":1,"vote_average":8.7,"vote_count":152},"cast_meta":[{"name":"Phakphum Romsaithong","name_vi":null,"name_original":"Phakphum Romsaithong","tmdb_id":3030319,"profile":"https://image.tmdb.org/t/p/w500/yNdJB94CnVXfGPACgtwBrVXezmh.jpg","tmdb_url":"https://www.themoviedb.org/person/3030319"},{"name":"Nattawin Wattanagitiphat","name_vi":null,"name_original":"Nattawin Wattanagitiphat","tmdb_id":3030320,"profile":"https://image.tmdb.org/t/p/w500/jE8fUezSByytab72ywC1ZelLl1e.jpg","tmdb_url":"https://www.themoviedb.org/person/3030320"},{"name":"Wichapas Sumettikul","name_vi":null,"name_original":"Wichapas Sumettikul","tmdb_id":3030333,"profile":"https://image.tmdb.org/t/p/w500/th0UDLlxKdkaS7FdPiLw61SQLlP.jpg","tmdb_url":"https://www.themoviedb.org/person/3030333"},{"name":"Jakapan Puttha","name_vi":null,"name_original":"Jakapan Puttha","tmdb_id":2190307,"profile":"https://image.tmdb.org/t/p/w500/tRCg6QkRr2V5C2Fm1ZjubMeMZvh.jpg","tmdb_url":"https://www.themoviedb.org/person/2190307"},{"name":"Jeff Satur","name_vi":"Jeff Satur","name_original":"Jeff Satur","tmdb_id":2450028,"profile":"https:/