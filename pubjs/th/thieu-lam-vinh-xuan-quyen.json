embed":"https://vip.opstream17.com/share/e092aed5316b555a770029849e06a7de","link_m3u8":"https://vip.opstream17.com/20240523/8512_68f6805b/index.m3u8"},{"name":"15","slug":"15","filename":"Thieu Lam Vinh Xuan Quyen 1988 15","link_embed":"https://vip.opstream17.com/share/3b777b775721dfa8d36de2a320a03e53","link_m3u8":"https://vip.opstream17.com/20240523/8511_97089636/index.m3u8"},{"name":"16","slug":"16","filename":"Thieu Lam Vinh Xuan Quyen 1988 16","link_embed":"https://vip.opstream17.com/share/fcbfab2f4cda26061ed9e3ee96a4fd61","link_m3u8":"https://vip.opstream17.com/20240523/8510_35faa00f/index.m3u8"},{"name":"17","slug":"17","filename":"Thieu Lam Vinh Xuan Quyen 1988 17","link_embed":"https://vip.opstream17.com/share/e80ba3de4e2f156e3bdf5b3596b36ca4","link_m3u8":"https://vip.opstream17.com/20240523/8509_311adc34/index.m3u8"},{"name":"18","slug":"18","filename":"Thieu Lam Vinh Xuan Quyen 1988 18","link_embed":"https://vip.opstream17.com/share/3091d86c09a002e144f4ec506eada3d7","link_m3u8":"https://vip.opstream17.com/20240523/8508_c18a6e63/index.m3u8"},{"name":"19","slug":"19","filename":"Thieu Lam Vinh Xuan Quyen 1988 19","link_embed":"https://vip.opstream17.com/share/172fd0d638b3282151bd8f3d652cb640","link_m3u8":"https://vip.opstream17.com/20240523/8507_5770244f/index.m3u8"},{"name":"20","slug":"20","filename":"Thieu Lam Vinh Xuan Quyen 1988 20 end","link_embed":"https://vip.opstream17.com/share/254a5ecb7ac40cc6c8ff9402f37eb585","link_m3u8":"https://vip.opstream17.com/20240523/8506_ff45ad87/index.m3u8"}]}],"time":"43 phút/tập","description":"<p>Quyết Chiến Thiếu Lâm Tự (Thiếu Lâm &amp; Vịnh Xuân) Gian thần Hòa Thân tay nắm trọng quyền che mắt hoàng thượng làm mưa làm gió, hãm hại trung thần. Vì muốn đoạt được bí cắp võ công của Thiếu Lâm, Hòa thân còn liên tục khống chế trụ trì thiếu lâm. Nghiêm Vịnh Xuân cùng gia đình là đoàn hát đến biểu diễn ở Quảng Đông. Dù là nữ nhi nhưng Vịnh Xuân rất thích biểu diễn &amp; học võ, tuy bị cha ngăn cấm nhưng Vịnh Xuân vẫn lén học. Hòa thân giết cả nhà của trung thần, Lương Thế Hiển là con trai duy nhất của nhà họ Lương chạy thoát được. Đến Quảng Đông được Vịnh Xuân giúp đỡ nhận vào đoàn hát. Con trai của Hòa thân là Kiến Đức truy sát Thế Hiển đến Quảng Đông, vừa gặp Vịnh Xuân đã si mê, Kiến Đức che giấu thân phận tìm mọi cách tiếp cận Vịnh Xuân nhưng trái lại Vịnh Xuân &amp; Thế Hiển lại có tình cảm tốt. Thế Hiển đem cảnh ngộ của mình viết lên vở diễn bi thương để đoàn hát diễn. Không ngờ trong đêm biểu diễn Hòa thân cũng đến xem. Hòa thân tức giận giết chết cả đoàn hát. Vịnh Xuân &amp; Thế Hiển chạy thoát, Vịnh Xuân sau khi biết được thân thế thực sự của Thế Hiển, cùng anh đồng lòng tầm sư học võ để trả thù nhà. Vịnh Xuân &amp; Thế Hiển bái Tam Đức cao tăng Thiếu Lâm làm sư phụ, Kiến Đức cũng đến bái sư mục đích là truy tìm bí cắp mà sư phụ nắm giữ. Kiến Đức mặt khác vẫn đeo đuổi Vịnh Xuân, càng đố kị Thế Hiển. Thục Phương là em gái của sư thúc lại một lòng một dạ với Kiến Đức, bị Kiến Đức lợi dụng mà không biết. Kiến Đức đánh cắp bí cắp bị bại lộ thân phận, sử dụng cao thủ tây vực giết chết sư phụ. Vịnh Xuân &amp; Thế Hiển cùng các sư thúc một lần nữa chạy thoát. Đến tố cáo tội ác của Hòa thân với Thập Ngũ A Ka. Nhưng Thập Ngũ A Ka sức yếu không thể chống chọi với Hòa Thân, còn bị Hòa thân khép tội tàn sát huynh đệ. Vịnh Xuân ngày đêm rèn luyện võ học + với bản tính thông minh đã sáng tạo ra những thế võ lạ đánh bại được các sư thúc, được đặt tên là Vịnh Xuân Quyền. Dùng Vịnh Xuân Quyền đánh bại Kiến Đức, giúp Thập Ngũ A Ka đăng cơ làm vua, trừng trị Hòa Thân ... Từ đó Vịnh Xuân dạy võ cho các bá tánh với đạo lý Thiếu Lâm &amp; Vịnh Xuân là một.</p>","tmdb":{"type":"tv","id":"108090","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-09T11:51:21.000Z","cast":["Mễ Tuyết","Thạch Tu","Đới Chí Vỹ","Lưu Giang","Wong Wan-Choi","Ma Chung-Tak","Thiệu Mỹ Kỳ","Wong Man-Yee","Cao Hùng"],"director":["Tiêu Sinh"],"cast_meta":[{"name":"Mễ Tuyết","name_vi":"Mễ Tuyết","name_original":"Miche