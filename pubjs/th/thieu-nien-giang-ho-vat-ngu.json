ndex.m3u8"},{"name":"23","slug":"23","filename":"thieu-nien-giang-ho-vat-ngu-tap-23","link_embed":"https://vip.opstream14.com/share/5cd7edbe7a1a668fdc63c138002cc43a","link_m3u8":"https://vip.opstream14.com/20220406/6055_7044838a/index.m3u8"},{"name":"24","slug":"24","filename":"thieu-nien-giang-ho-vat-ngu-tap-24","link_embed":"https://vip.opstream14.com/share/ee1abc6b5f7c6acb34ad076b05d40815","link_m3u8":"https://vip.opstream14.com/20220406/6056_291f0afa/index.m3u8"}]}],"time":"39M7S","description":"<p>“Thiếu niên giang hồ vật ngữ” kể về một câu chuyện ấm ấp trong giang hồ, nơi đó tà không thể thắng chính, thanh xuân tươi đẹp, có nghĩa có tình. Trong truyện có giáo chủ ma giáo, có đệ nhất kiếm khách trên giang hồ, có đại phu giang hồ mà thân thế là cả một câu đố không lời giải, có tiểu nha đầu trung thành tận tụy, lại còn có cả hoa khôi nổi tiếng với sắc đẹp áp chế một phương, bao nhiêu nhân vật tưởng chừng như không hề có chút liên quan lần lượt xuất hiện, khuấy động giang hồ đang yên tĩnh như hồ nước mùa xuân.</p>","tmdb":{"type":"tv","id":"91015","season":1,"vote_average":6.5,"vote_count":6},"modified":"2023-06-02T18:25:44.000Z","cast":["Zhou Yanchen","Lạc Minh Cật","Su Xiaotong","Song Jiyang","Tạ Hưng Dương","Wang Jiayin","Hero Tai","Fan Yize","Liu Yuting","Liu Jianyu","Zhang Xinyu"],"director":["Li Yan Qian"],"cast_meta":[{"name":"Zhou Yanchen","name_vi":null,"name_original":"Zhou Yanchen","tmdb_id":2082540,"profile":"https://image.tmdb.org/t/p/w500/tO6R8vx3jJsaOhCRPE7PvGUWsU9.jpg","tmdb_url":"https://www.themoviedb.org/person/2082540"},{"name":"Lạc Minh Cật","name_vi":"Lạc Minh Cật","name_original":"Luo Mingjie","tmdb_id":2359338,"profile":"https://image.tmdb.org/t/p/w500/cg8cgZXDBeRdW50yFpRr5zhCUpJ.jpg","tmdb_url":"https://www.themoviedb.org/person/2359338"},{"name":"Su Xiaotong","name_vi":null,"name_original":"Su Xiaotong","tmdb_id":2359339,"profile":"https://image.tmdb.org/t/p/w500/eHeqGwOUhISgX4d293SmPVAswDC.jpg","tmdb_url":"https://www.themoviedb.org/pers