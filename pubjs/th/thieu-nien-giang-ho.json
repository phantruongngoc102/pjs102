b79bc85a14","link_m3u8":"https://vip.opstream14.com/20230530/37045_62f8c8f0/index.m3u8"},{"name":"23","slug":"23","filename":"Thiếu Niên Giang Hồ Tập 23","link_embed":"https://vip.opstream14.com/share/3e9aa06e4dd6770317a014fb19c762b8","link_m3u8":"https://vip.opstream14.com/20230530/37046_d6af8f0b/index.m3u8"},{"name":"24","slug":"24","filename":"Thiếu Niên Giang Hồ Tập 24","link_embed":"https://vip.opstream14.com/share/dedd5db8f760f36dd41fba0d5e94308b","link_m3u8":"https://vip.opstream14.com/20230530/37047_facf2b80/index.m3u8"}]}],"time":"35 phút/tập","description":"Nữ chính Tiểu Như là một tên võ công tầm thường, lập dị, nghèo khó, dễ thương và nhát gan, bề ngoài thì lừa lọc và tham tiền, trong lòng thì sẵn sàng giúp đỡ người khác. cô ngốc bị bắt nạt cô Murong Zhuwan. Xiaoru, người không biết gì về tình yêu, buộc phải tham gia vào các cuộc tranh chấp sau khi gặp người đàn ông mình thích, Murong Chong, và cũng gặp Fu Hong, người nghĩ rằng mình đã bị phản bội và căm ghét vì tình yêu. Murong Chong, Zhu Wan và Fu Hong phải vật lộn để sống sót trước nhiều âm mưu khác nhau trên đấu trường, và xung đột giữa họ ngày càng trở nên gay gắt hơn. Trong khi tận hưởng vinh quang và quyền lợi, ba người họ cũng gánh vác áp lực và trách nhiệm, họ lớn lên trong nghịch cảnh xa lạ, trở nên dũng cảm và mạnh mẽ vì tình yêu, và làm việc chăm chỉ vì tình yêu. .","tmdb":{"type":"tv","id":"227213","season":1,"vote_average":2,"vote_count":1},"modified":"2025-03-30T15:04:37.000Z","cast":["Ngao Thụy Bằng","Aaron Deng","Zong Yuanyuan","Si Zheng","Wu Yixun","Zhong Qi","Hu Caihong","Wang Junzhe","Xuan Yihao","Pu Yutong","Wang Boqing","Hu Jiahao","Guo Xingqi","Ma Shujun","Vương Nhất Chu"],"director":["Wing-Lun Mak"],"cast_meta":[{"name":"Ngao Thụy Bằng","name_vi":"Ngao Thụy Bằng","name_original":"Ao Ruipeng","tmdb_id":2798208,"profile":"https://image.tmdb.org/t/p/w500/ixekaZD5T0rkc518UZtadioBX9z.jpg","tmdb_url":"https://www.themoviedb.org/person/2798208"},{"name":"Aaron Deng","name_vi":null,"name_