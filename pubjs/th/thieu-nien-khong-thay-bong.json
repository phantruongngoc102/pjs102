lug":"7","link_embed":"https://vip.opstream13.com/share/792b765aa995daf26cf6f17f519c949d","link_m3u8":"https://vip.opstream13.com/20251013/12238_792b765a/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream13.com/share/61b07251e835d37322b7460d2b88c05b","link_m3u8":"https://vip.opstream13.com/20251013/12239_61b07251/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream13.com/share/b750f74544cb00c138079607276995e9","link_m3u8":"https://vip.opstream13.com/20251013/12240_b750f745/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream13.com/share/1b0251ccb8bd5f9ccf444e4bda7713e3","link_m3u8":"https://vip.opstream13.com/20251013/12241_1b0251cc/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream13.com/share/47a878d199b3fcb8447a9a1b3a78ee73","link_m3u8":"https://vip.opstream13.com/20251013/12242_47a878d1/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream13.com/share/27609bf6990a3f2f5bddb7908b421ea7","link_m3u8":"https://vip.opstream13.com/20251013/12243_27609bf6/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream13.com/share/336e4fcc43c1194d7bb9c8fc6188e9b3","link_m3u8":"https://vip.opstream13.com/20251013/12244_336e4fcc/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream13.com/share/af0da643a413a1551f47198cfccae577","link_m3u8":"https://vip.opstream13.com/20251013/12245_af0da643/index.m3u8"},{"name":"15","slug":"15","link_embed":"https://vip.opstream13.com/share/19406b9f645610fda9a0f6f27bdac710","link_m3u8":"https://vip.opstream13.com/20251013/12246_19406b9f/index.m3u8"},{"name":"16","slug":"16","link_embed":"https://vip.opstream13.com/share/5e56343dada029d40a90b44e1ca3d495","link_m3u8":"https://vip.opstream13.com/20251013/12247_5e56343d/index.m3u8"}]}],"description":"<p>Vào những năm 1990, trong một đêm sấm chớp, một thị trấn nhỏ tên là Triệu Dương đã chứng kiến ​​cuộc truy đuổi bí ẩn và số phận bất định của một thiếu niên. Hai cậu bé khác mất tích cùng cậu cũng biến mất không dấu vết. Ba năm sau, một trong hai cậu bé tái xuất hiện với tư cách là một \"tên móc túi nhỏ\", giả vờ mất trí nhớ và trở về với gia đình. Đằng sau sự nhận diện thành công, liệu đó là một cuộc đoàn tụ hay tiếp nối một sai lầm? Đáng ngạc nhiên, gia đình tưởng chừng như đã đoàn tụ này vẫn ẩn chứa những bí mật và mối đe dọa. Một viên cảnh sát già tiến hành một cuộc điều tra bí mật, và sau một cuộc rượt đuổi như mèo vờn chuột, những manh mối về tung tích của hai cậu bé mất tích khác bắt đầu lộ diện. Sự thật đằng sau hàng loạt vụ mất tích, buôn người, ngộ sát và các vụ án giết người dần dần được hé lộ. Khi bí ẩn dần được hé lộ, viên cảnh sát già và \"cậu bé mất tích\" đã cùng nhau chuộc lỗi, kết nối câu chuyện hồi hộp này thành một câu chuyện về mối quan hệ gia đình.</p>","tmdb_id":249188,"cast":["Trương Tụng Văn","Rong Zishan","Cheng Taishen","Trần Vũ Tư","Li Jian","Guo Keyu","Zeng Youzhen","Triệu Hoa Vi","Zhang Shanmeng","Li Yixiang","Cao Lei","Jiang Han","Tong Lei","Wang Peilu","Zhang Bin"],"director":["Zhou Quan"],"keywords":[],"tmdb":{"type":"tv","id":"249188","season":1,"vote_average":6.8,"vote_count":6},"cast_meta":[{"name":"Trương Tụng Văn","name_vi":"Trương Tụng Văn","name_original":"Zhang Songwen","tmdb_id":1086250,"profile":"https://image.tmdb.org/t/p/w500/rz1mKSiuV5LuY0l0Y6HRGJGBeED.jpg","tmdb_url":"https://www.themoviedb.org/person/1086250"},{"name":"Rong Zishan","name_vi":null,"name_original":"Rong Zishan","tmdb_id":2682523,"profile":"https://image.tmdb.org/t/p/w500/qNEzWQ3TMHx7ggSxPCKNTS8yJnD.jpg","tmdb_url":"https://www.themoviedb.org/person/2682523"},{"name":"Cheng Taishen","name_vi":null,"name_original":"Cheng Taishen","tmdb_id":72483,"profile":"https://image.tmdb.org/t/p/w500/7lH9HMtPtGH0BbR7THOjVZWnlLn.jpg","tmdb_url":"https://www.themoviedb.org/person/72483"},{"name":"Trần Vũ Tư","name_vi":"Trần Vũ Tư","name_original":"Chen Yusi","tmdb_id":2263549,"profile":"https://image.tmdb.org/t/p/w500/aw4m3hxi6O06Z4xGv2s