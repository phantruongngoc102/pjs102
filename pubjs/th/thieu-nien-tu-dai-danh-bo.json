23042_f4c7c456/index.m3u8"}]}],"time":"45 phút","description":"<p>Thiếu Niên Tứ Đại Danh Bổ - The Four là dự án phim truyền hình lấy bối cảnh cổ trang, câu chuyện xoay quanh bộ tứ danh bổ chốn kinh thành, bao gồm: Lãnh Huyết, Vô Tình, Truy Mệnh, Thiết Thủ. Để bảo vệ bình an của giang sơn, bốn người nhiều lần phá được những huyết án khủng khiếp, thậm chí không quản hiểm nguy chiến đấu với thế lực tà ác của An Thế Cảnh.</p>","tmdb":{"type":"tv","id":"83905","season":1,"vote_average":7,"vote_count":3},"modified":"2023-06-25T19:26:41.000Z","cast":["Mao Tử Tuấn","Dương Dương","Trần Vỹ Đình","Trương Hàn","Trương Quân Ninh","Hàn Đống","Ứng Hạo Minh","Emma Wu","Nhạc Dược Lợi","Liu Xin"],"director":["Lương Thắng Quyền","Hoàng Tuấn Văn"],"cast_meta":[{"name":"Mao Tử Tuấn","name_vi":"Mao Tử Tuấn","name_original":"Mao Zijun","tmdb_id":1176004,"profile":"https://image.tmdb.org/t/p/w500/cqugMweL96ERGdE98D2z3Cza5JY.jpg","tmdb_url":"https://www.themoviedb.org/person/1176004"},{"name":"Dương Dương","name_vi":"Dương Dương","name_original":"Yang Yang","tmdb_id":1635792,"profile":"https://image.tmdb.org/t/p/w500/lEBuoN1XItYMLpgsMmtORrEx1BY.jpg","tmdb_url":"https://www.themoviedb.org/person/1635792"},{"name":"Trần Vỹ Đình","name_vi":"Trần Vỹ Đình","name_original":"William Chan","tmdb_id":127268,"profile":"https://image.tmdb.org/t/p/w500/mHunqWHguLuD0CEW8vLIrERdegN.jpg","tmdb_url":"https://www.themoviedb.org/person/127268"},{"name":"Trương Hàn","name_vi":"Trương Hàn","name_original":"Hans Zhang","tmdb_id":1539662,"profile":"https://image.tmdb.org/t/p/w500/d7jfyPwUBEPpp3siCclNEPy5IgX.jpg","tmdb_url":"https://www.themoviedb.org/person/1539662"},{"name":"Trương Quân Ninh","name_vi":"Trương Quân Ninh","name_original":"Janine Chang Chun-Ning","tmdb_id":564891,"profile":"https://image.tmdb.org/t/p/w500/xNov6ffJ8dZCPUxO6g1nWnmdXM2.jpg","tmdb_url":"https://www.themoviedb.org/person/564891"},{"name":"Hàn Đống","name_vi":"Hàn Đống","name_original":"Han Dong","tmdb_id":1518226,"profile":"https://im