c Môn, cũng nhau tìm thấy được chân ái của đời mình.","tmdb_id":233781,"cast":["Từ Lộ","Ngô Hi Trạch","Vương Dĩ Luân","Zhang Chuhan","Li Zhuozhao"],"director":["Tong Zhou","Dai Meng Ying"],"keywords":[],"tmdb":{"type":"tv","id":"233781","season":1,"vote_average":7.5,"vote_count":2},"cast_meta":[{"name":"Từ Lộ","name_vi":"Từ Lộ","name_original":"Xu Lu","tmdb_id":1236326,"profile":"https://image.tmdb.org/t/p/w500/hgaIcXhEhS68u5ACYLKO9FIv06k.jpg","tmdb_url":"https://www.themoviedb.org/person/1236326"},{"name":"Ngô Hi Trạch","name_vi":"Ngô Hi Trạch","name_original":"Caesar Wu","tmdb_id":2050469,"profile":"https://image.tmdb.org/t/p/w500/zIoLqJWTDFF96WuxQjpkOaXXUuu.jpg","tmdb_url":"https://www.themoviedb.org/person/2050469"},{"name":"Vương Dĩ Luân","name_vi":"Vương Dĩ Luân","name_original":"Riley Wang","tmdb_id":1868412,"profile":"https://image.tmdb.org/t/p/w500/lzzvRyyltnsExIrsWhm6DCPMz62.jpg","tmdb_url":"https://www.themoviedb.org/person/1868412"},{"name":"Zhang Chuhan","name_vi":null,"name_original":"Zhang Chuhan","tmdb_id":3503856,"profile":"https://image.tmdb.org/t/p/w500/726OGXSWm31nWPnsL011Jl80Mks.jpg","tmdb_url":"https://www.themoviedb.org/person/3503856"},{"name":"Li Zhuozhao","name_vi":null,"name_original":"Li Zhuozhao","tmdb_id":2304107,"profile":"https://image.tmdb.org/t/p/w500/jOBzktvMtRJliLjTPWXFPXhmIKy.jpg","tmdb_url":"https://www.themoviedb.org/person/2304107"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/thieu-nu-luu-lac-giang-ho.json"}