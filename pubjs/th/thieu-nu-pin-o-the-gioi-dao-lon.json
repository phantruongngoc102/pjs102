Doll, cùng những thiếu nữ sạc năng lượng cho nó. Người ta gọi những cô gái đó với cái tên: những Thiếu nữ pin.</p>","tmdb_id":122286,"cast":["Seiichiro Yamashita","Fairouz Ai","Aina Suzuki","Shiori Izawa","Takamitsu Fukuchi","Takuma Terashima","Rina Hidaka","Yukiyo Fujii","Shino Shimoji","Tomokazu Sugita","Aki Toyosaki","Kenichirou Matsuda","Takahiro Mizushima","Shota Hayama","Hayato Kaneko"],"director":[],"keywords":[],"time":"","tmdb":{"type":"tv","id":"122286","season":1,"vote_average":4.3,"vote_count":6},"cast_meta":[{"name":"Seiichiro Yamashita","name_vi":null,"name_original":"Seiichiro Yamashita","tmdb_id":1732278,"profile":"https://image.tmdb.org/t/p/w500/zym6WY3rxL4FdbHoLzG2CnqnR7.jpg","tmdb_url":"https://www.themoviedb.org/person/1732278"},{"name":"Fairouz Ai","name_vi":null,"name_original":"Fairouz Ai","tmdb_id":2359492,"profile":"https://image.tmdb.org/t/p/w500/coFu6WOVBZvqd1fw89vbHkiC0zB.jpg","tmdb_url":"https://www.themoviedb.org/person/2359492"},{"name":"Aina Suzuki","name_vi":null,"name_original":"Aina Suzuki","tmdb_id":1661870,"profile":"https://image.tmdb.org/t/p/w500/bRLwfft4yckDTpLenlbTrt3FRRN.jpg","tmdb_url":"https://www.themoviedb.org/person/1661870"},{"name":"Shiori Izawa","name_vi":null,"name_original":"Shiori Izawa","tmdb_id":1647448,"profile":"https://image.tmdb.org/t/p/w500/f9V38OeDvRGevWuKc4dN6LB62TH.jpg","tmdb_url":"https://www.themoviedb.org/person/1647448"},{"name":"Takamitsu Fukuchi","name_vi":null,"name_original":"Takamitsu Fukuchi","tmdb_id":3229365,"profile":"https://image.tmdb.org/t/p/w500/eWGxU85mwQ4z6Us5kCq2wOIUrYz.jpg","tmdb_url":"https://www.themoviedb.org/person/3229365"},{"name":"Takuma Terashima","name_vi":null,"name_original":"Takuma Terashima","tmdb_id":222350,"profile":"https://image.tmdb.org/t/p/w500/n5uCihb318AzQCT9gieMlI2ueYL.jpg","tmdb_url":"https://www.themoviedb.org/person/222350"},{"name":"Rina Hidaka","name_vi":null,"name_original":"Rina Hidaka","tmdb_id":1116334,"profile":"https://image.tmdb.org/t/p/w500/7JupZGvq