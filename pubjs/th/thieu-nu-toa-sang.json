18_8a180ee8/index.m3u8"}]}],"time":"42M29S","description":"<p>Thiếu nữ tinh quái, láu lỉnh, dám yêu dám hận Trần Kinh là học sinh nhạc cụ dân tộc của trường trung học âm nhạc. Nhân duyên của Trần Kinh không mấy tốt, chỉ có anh chàng bạn thân Du Tra luôn bằng lòng đi theo chăm sóc cho cô, nhưng cô lại đem lòng thích anh chàng đẹp trai học dương cầm, nhân vật nổi tiếng trong trường nên bị mọi người chế giễu và xa lánh, còn gây ra cuộc chiến giữ khoa âm nhạc dân tộc và âm nhạc phương Tây.</p>","tmdb":{"type":"tv","id":"96921","season":1,"vote_average":7.7,"vote_count":3},"modified":"2023-06-13T22:35:51.000Z","cast":["Chu Dực Nhiên","Hách Phú Thân","Vương An Vũ","Li Yichen","Chu He","Zhai Yishu","Wu Shuang","Sun Tianyu","Zhang Ge"],"director":["Wang Ran"],"cast_meta":[{"name":"Chu Dực Nhiên","name_vi":"Chu Dực Nhiên","name_original":"Zhou Yiran","tmdb_id":2280423,"profile":"https://image.tmdb.org/t/p/w500/3T1oJq6ODZahHvtqDxfzzIDpdSo.jpg","tmdb_url":"https://www.themoviedb.org/person/2280423"},{"name":"Hách Phú Thân","name_vi":"Hách Phú Thân","name_original":"Hao Fushen","tmdb_id":2492185,"profile":"https://image.tmdb.org/t/p/w500/rwp5YkRILyEJtVz6vwvxnM7Iuwp.jpg","tmdb_url":"https://www.themoviedb.org/person/2492185"},{"name":"Vương An Vũ","name_vi":"Vương An Vũ","name_original":"Wang Anyu","tmdb_id":2482605,"profile":"https://image.tmdb.org/t/p/w500/7ai55C0CoOdzOlkAOpfatW5xuh.jpg","tmdb_url":"https://www.themoviedb.org/person/2482605"},{"name":"Li Yichen","name_vi":null,"name_original":"Li Yichen","tmdb_id":2551139,"profile":"https://image.tmdb.org/t/p/w500/dlTzmB9q80kTQ06V1Sm5dvTIeEu.jpg","tmdb_url":"https://www.themoviedb.org/person/2551139"},{"name":"Chu He","name_vi":null,"name_original":"Chu He","tmdb_id":2551143,"profile":"https://image.tmdb.org/t/p/w500/zO6rq3NOI0S72HLWgNYirkit5He.jpg","tmdb_url":"https://www.themoviedb.org/person/2551143"},{"name":"Zhai Yishu","name_vi":null,"name_original":"Zhai Yishu","tmdb_id":2548035,"profile":"https://image.tmdb.org/t/p/w50