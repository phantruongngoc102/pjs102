.com/share/6c730b10822a93522acc2c6918150f60","link_m3u8":"https://vip.opstream15.com/20220609/19597_ee5fd62b/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/a0b286be4319741767e21c8c2216fa77","link_m3u8":"https://vip.opstream15.com/20220609/19601_c48c8e51/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/cde52d3f5013d4f75b0e6f46dddafcae","link_m3u8":"https://vip.opstream15.com/20220609/19604_a11cefab/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/efaaba7b6a9f5030033337074884b7e0","link_m3u8":"https://vip.opstream15.com/20220609/19607_11620ee3/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/23caa86a7dadfef1317f9af86bd135e1","link_m3u8":"https://vip.opstream15.com/20220609/19610_faa43691/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream15.com/share/b210215075f68e712aa3d04c9269aea8","link_m3u8":"https://vip.opstream15.com/20220609/19613_1eafb346/index.m3u8"},{"name":"35","slug":"35","link_embed":"https://vip.opstream15.com/share/6f1110b10375fc596c6cea03fd3e1d24","link_m3u8":"https://vip.opstream15.com/20220609/19617_0f8b4b8c/index.m3u8"},{"name":"36","slug":"36","link_embed":"https://vip.opstream15.com/share/c747496ce40dc4e41d7028334dab7739","link_m3u8":"https://vip.opstream15.com/20220609/19620_2aafb26e/index.m3u8"}]}],"description":"<p>Thiếu Nữ Toàn Phong chuyển thể từ tiểu thuyết của nhà văn Minh Hiểu Khê. Trong tác phẩm lần này, Dương Dương thủ vai đại sư huynh Nhược Bạch của một võ đường Taekwondo. Tuy bề ngoài có phần lạnh lùng, nhưng anh lại là người luôn giúp đỡ, động viên các sư đệ sư muội của mình. Trong khi đó, nữ chính của bộ phim - Bách Thảo lại là một cô gái quật cường và cực kì đam mê với môn võ Taekwondo. Bách Thảo tuy bình thường dễ bị bắt nạt nhưng có những nguyên tắc của bản thân không thể thay đổi, một khi cô đã quyết định, không gì có thể ngăn cản cô thực hiện ước mơ của mình.</p>",