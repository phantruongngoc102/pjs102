f9","link_m3u8":"https://vip.opstream16.com/20221224/28053_6c82baae/index.m3u8"},{"name":"35","slug":"35","filename":"thinh-quan-tap-35","link_embed":"https://vip.opstream16.com/share/761067fbba1d6ef159173bfb8109abc2","link_m3u8":"https://vip.opstream16.com/20221224/28054_4d5aee59/index.m3u8"},{"name":"36","slug":"36","filename":"thinh-quan-tap-36","link_embed":"https://vip.opstream16.com/share/c9a4268367a43297ba960eb5bd78155c","link_m3u8":"https://vip.opstream16.com/20221224/28055_859795c2/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Thỉnh Quân (Thousand Years For You) xoay quanh mối lương duyên 2 kiếp giữa nữ trại chủ Vu Đăng Đăng (Lý Thấm thủ vai) nghĩa hiệp, trọng nghĩa. Kiếp trước nàng là thần nữ với năng lực tuyệt đỉnh, nhất kiến chung tình cùng Lục Viêm (Nhậm Gia Luân thủ vai) một “sát thần ngàn năm” lạnh lùng, kiêu ngạo, vì yêu mà ngủ say ngàn năm. Từ đây câu chuyện tình yêu dở khóc, dở cười giữa 2 nhân vật diễn ra ,khi nàng ”một nữ trại chủ” dám cướp hôn ”một chiến thần ngàn năm”, trớ trêu thay khi kiếp trước họ là người yêu trong số mệnh, tạo ra một cuộc tình oan gia đầy thú vị.</p>","tmdb":{"type":"tv","id":"138276","season":1,"vote_average":10,"vote_count":2},"modified":"2025-04-26T12:54:30.000Z","cast":["Nhậm Gia Luân","Lý Thấm","Chen Xijun","Wu Mingjing","Xương Long","Song Wenzuo","Tiểu Thẩm Dương","Trương Vĩnh Cương","Lai Nghệ","Tào Hi Nguyệt","Huang Qi Lin'er","Yang Jinjie","王丹"],"director":["Trịnh Vĩ Văn"],"cast_meta":[{"name":"Nhậm Gia Luân","name_vi":"Nhậm Gia Luân","name_original":"Ren Jialun","tmdb_id":2084465,"profile":"https://image.tmdb.org/t/p/w500/5sBfnbHbTmNriFPGGD12mPpTNNO.jpg","tmdb_url":"https://www.themoviedb.org/person/2084465"},{"name":"Lý Thấm","name_vi":"Lý Thấm","name_original":"Li Qin","tmdb_id":568304,"profile":"https://image.tmdb.org/t/p/w500/thak4pt7jCPbl2xx5HnFhkEE0Tu.jpg","tmdb_url":"https://www.themoviedb.org/person/568304"},{"name":"Chen Xijun","name_vi":null,"name_original":"Chen Xijun","tmdb_id":2285161,"profil