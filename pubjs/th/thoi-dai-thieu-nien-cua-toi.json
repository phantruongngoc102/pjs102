7/6918_45e4db93/index.m3u8"},{"name":"15","slug":"15","filename":"Thời Đại Thiếu Niên Của Tôi  - Ep15","link_embed":"https://vip.opstream17.com/share/219d0a315520ccbbb971bba8f5d455fe","link_m3u8":"https://vip.opstream17.com/20240509/7147_6e25f800/index.m3u8"},{"name":"16","slug":"16","filename":"Thời Đại Thiếu Niên Của Tôi  - Ep16","link_embed":"https://vip.opstream17.com/share/f6b6d2a114a9644419dc8d2315f22401","link_m3u8":"https://vip.opstream17.com/20240509/7145_bcd96358/index.m3u8"},{"name":"17","slug":"17","filename":"Thời Đại Thiếu Niên Của Tôi  - Ep17","link_embed":"https://vip.opstream17.com/share/c20bb2d9a50d5ac1f713f8b34d9aac5a","link_m3u8":"https://vip.opstream17.com/20240509/7150_34117000/index.m3u8"},{"name":"18","slug":"18","filename":"Thời Đại Thiếu Niên Của Tôi  - Ep18","link_embed":"https://vip.opstream17.com/share/fc394e9935fbd62c8aedc372464e1965","link_m3u8":"https://vip.opstream17.com/20240509/7151_91428d07/index.m3u8"},{"name":"19","slug":"19","filename":"Thời Đại Thiếu Niên Của Tôi   - Ep19","link_embed":"https://vip.opstream17.com/share/cc360b61d7eb072c77a4beddebb3c95b","link_m3u8":"https://vip.opstream17.com/20240510/7298_5db9401c/index.m3u8"},{"name":"20","slug":"20","filename":"Thời Đại Thiếu Niên Của Tôi   - Ep20","link_embed":"https://vip.opstream17.com/share/29e11dc359bad383e1243f730bdbe032","link_m3u8":"https://vip.opstream17.com/20240510/7299_48c9cd4e/index.m3u8"},{"name":"21","slug":"21","filename":"Thời Đại Thiếu Niên Của Tôi  21","link_embed":"https://vip.opstream17.com/share/46e0eae7d5217c79c3ef6b4c212b8c6f","link_m3u8":"https://vip.opstream17.com/20240511/7340_16adfb88/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>Tọa lạc tại \"phố vũ trụ\" của một thị trấn nhỏ ven biển, \"Vua trẻ em\" Vương Hoàn Vũ, \"Nữ thần vũ đạo\" Vệ Tinh, \"Cửa hàng thế hệ thứ hai\" Hàn Soái, \"Thiếu nữ ma ngựa\" Quách Đình và \"Nhà văn học\" Sử Văn Khả từ nhỏ là thanh mai trúc mã, cùng nhau lớn lên. Đối mặt với năm cuối cấp tốt nghiệp phổ thông, bất luận học sinh kém như Vương Hoàn Vũ, Hàn Soái và Quách Đình, hay học bá như Vệ Tinh và Sử Văn Khả đều phải đối mặt với vấn đề khó tương lai đi đâu về đâu. Phiền não của sự trưởng thành đi cùng với sự mờ mịt của thanh xuân, cũng lặng lẽ gõ cửa trái tim bọn trẻ. Thanh xuân là một trận nhốn nháo hoảng loạn, nhưng chỉ cần có những người bạn quan tâm ở bên, bạn chẳng có gì phải sợ hãi. Một năm nay, nhóm thanh thiếu niên với những tính cách khác nhau và có sức hấp dẫn lẫn nhau, với khí chất riêng, đã trải qua những niềm vui, nỗi buồn do tình cảm gia đình, tình bạn và tình yêu hồ đồ mang lại. Giữa lúc do dự và bối rối, họ cẩn thận làm rõ hướng đi của mình, bảo vệ sơ tâm của mình và tiếp tục chạy về phía kia trong lòng mình.</p>","tmdb":{"type":"tv","id":"251945","season":1,"vote_average":7.5,"vote_count":2},"modified":"2025-01-10T10:34:13.000Z","cast":["Lv Xiaoyu","Fang Xiaodong","Trình Hoằng Hâm","Li Mengying","Cao Saiya","Yang Yikai","Zhang Xiao'ang","Zhang Zhilu","Yang Xiaolan","Sun Guitian","Zhan Yashu","Thuần Vu San San","Zhao Yansong","Tian Miao","Zhao Gang"],"director":[],"cast_meta":[{"name":"Lv Xiaoyu","name_vi":null,"name_original":"Lv Xiaoyu","tmdb_id":2343728,"profile":"https://image.tmdb.org/t/p/w500/bLBJkHqqRAPPrjbjzhNzrj4nkhq.jpg","tmdb_url":"https://www.themoviedb.org/person/2343728"},{"name":"Fang Xiaodong","name_vi":null,"name_original":"Fang Xiaodong","tmdb_id":3505987,"profile":"https://image.tmdb.org/t/p/w500/ex0zF12LkqFu4mbYUOkSr6ABxlF.jpg","tmdb_url":"https://www.themoviedb.org/person/3505987"},{"name":"Trình Hoằng Hâm","name_vi":"Trình Hoằng Hâm","name_original":"Cheng Hongxin","tmdb_id":3817383,"profile":"https://image.tmdb.org/t/p/w500/fmo0MN1aQZYsw4lIsq6mpPf8OGI.jpg","tmdb_url":"https://www.themoviedb.org/person/3817383"},{"name":"Li Mengying","name_vi":null,"name_original":"Li Mengying","tmdb_id":2239253,"profile":"https://image.tmdb.org/t/p/w500/47naLG34HsbTTbssEQ5geHUvUc2.jpg","tmdb_url":"https://www.themoviedb.org/person/2239253"},{"name":"C