com/20220318/1049_b4a21599/index.m3u8"},{"name":"23","slug":"23","filename":"thoi-gian-va-em-biet-lai-vo-dang-tap-23","link_embed":"https://vip.opstream10.com/share/5055cbf43fac3f7e2336b27310f0b9ef","link_m3u8":"https://vip.opstream10.com/20220318/1050_4eebb221/index.m3u8"},{"name":"24","slug":"24","filename":"thoi-gian-va-em-biet-lai-vo-dang-tap-24","link_embed":"https://vip.opstream10.com/share/456ac9b0d15a8b7f1e71073221059886","link_m3u8":"https://vip.opstream10.com/20220318/1051_312d7b6d/index.m3u8"}]}],"time":"29M34S","description":"<p>Anh chàng đẹp trai vẻ ngoài lạnh lùng nhưng yêu thương bạn gái Khương Điên bất ngờ chui vào trong sách, gặp tình yêu sét đánh với cô gái mạnh mẽ Trình Phùng nhưng lại bị từ chối. Khương Điên không ngừng theo đuổi và gỡ được nút thắt trong lòng Trình Phùng, hai người bắt đầu sống chung. Sau khi Khương Điên và Trình Phùng sống cùng nhau, những trở ngại đến từ thế giới bên ngoài cũng lần lượt kéo đến. Hai người không thể đi tiếp vì nhiều lý do, cuối cùng phải chia tay do nhiều thứ áp lực. Nhưng hai người đã hẹn phải trở thành một bản thân mạnh mẽ hơn...</p>","tmdb":{"type":"tv","id":"129816","season":1,"vote_average":8,"vote_count":3},"modified":"2022-05-31T04:03:25.000Z","cast":["Từ Nghệ Dương","Trần Hựu Duy","Sái Tường Vũ","Phó Vỹ Luân","Zheng Yujia","Tian Yifan","Khương Trinh Vũ"],"director":["Tan You Ye"],"cast_meta":[{"name":"Từ Nghệ Dương","name_vi":"Từ Nghệ Dương","name_original":"Xu Yiyang","tmdb_id":3172419,"profile":"https://image.tmdb.org/t/p/w500/yRgNafX3IvoewWl3GeVTX2kITjb.jpg","tmdb_url":"https://www.themoviedb.org/person/3172419"},{"name":"Trần Hựu Duy","name_vi":"Trần Hựu Duy","name_original":"Chen Youwei","tmdb_id":2159086,"profile":"https://image.tmdb.org/t/p/w500/53abr9RyVQ4fOWw7NKoU3lyQj20.jpg","tmdb_url":"https://www.themoviedb.org/person/2159086"},{"name":"Sái Tường Vũ","name_vi":"Sái Tường Vũ","name_original":"Cai Xiangyu","tmdb_id":2961684,"profile":"https://image.tmdb.org/t/p/w500/9P9916rJ9SkiYBqrAckRsuO48FA