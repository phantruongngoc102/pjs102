u8"},{"name":"23","slug":"23","filename":"Once and Forever The Sun Rises EP23","link_embed":"https://vip.opstream16.com/share/d07a97171065ecb1cd41f298c0453aab","link_m3u8":"https://vip.opstream16.com/20230314/33002_c15435e7/index.m3u8"},{"name":"24","slug":"24","filename":"Once and Forever The Sun Rises EP24","link_embed":"https://vip.opstream16.com/share/da396723b0381ecdb354cfccc2bf1799","link_m3u8":"https://vip.opstream16.com/20230314/33003_4adea49e/index.m3u8"},{"name":"25","slug":"25","filename":"Once and Forever The Sun Rises EP25","link_embed":"https://vip.opstream16.com/share/2f9dabd3b7df074505f362da6a52c389","link_m3u8":"https://vip.opstream16.com/20230315/33038_aa867c0e/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i><strong>Thời Niên Thiếu Của Tăng Thiếu Niên</strong></i> là&nbsp;một câu chuyện ấm áp về tình thân, tình bạn và sự trưởng thành của bốn gia đình ba thế hệ trong một tứ hợp viện ở Bắc Kinh vào những năm từ 1997 đến 2001. Hai thiếu niên thiếu nữ trung học Tạ Kiều, Tần Xuyên cùng bạn bè và người thân của mình đã trải qua những việc lớn nhỏ trong thời đại này, đối diện với những câu chuyện vừa muộn phiền vừa hạnh phúc trong quá trình trưởng thành. Tình cảm thân thiết và ấm áp giữa hàng xóm láng giềng đã trở thành những hành trang quý giá trong cuộc đời họ. Các bạn trẻ mang theo món quà mà thời gian ban tặng, từng bước trưởng thành, hướng đến một thời đại mới.</p>","tmdb":{"type":"tv","id":"221274","season":1,"vote_average":7.8,"vote_count":5},"modified":"2023-03-15T19:19:15.000Z","cast":["Zhang Zimu","Zhang Kaitai","Quách Tử Phàm","Hạc Thu","Hải Nhất Thiên","Triệu Tử Kỳ","Phạm Thi Nhiên","Wang Qing"],"director":["Lưu Sướng","Vương Lôi"],"cast_meta":[{"name":"Zhang Zimu","name_vi":null,"name_original":"Zhang Zimu","tmdb_id":3709707,"profile":"https://image.tmdb.org/t/p/w500/ckTZ7YR0ebf27f8Ak3nQQwpk7F0.jpg","tmdb_url":"https://www.themoviedb.org/person/3709707"},{"name":"Zhang Kaitai","name_vi":null,"name_original":"Zhang Kaitai","tmdb_id":