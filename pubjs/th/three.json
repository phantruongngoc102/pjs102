{"id":"649a42b3953e2ecd7e07bd36","title":"Three","origin_name":"Three","slug":"three","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/th/three.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/th/three.webp","year":2016,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a2347e0fc277084dfd876","name":"Hồng Kông","slug":"hong-kong"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"is_ai":false,"server_name":"Vietsub #1","server_data":[{"name":"Full","slug":"full","filename":"Three - Tam Nhân Hành - 2016","link_embed":"https://vip.opstream14.com/share/a658d23016fb87f4536849e04851921d","link_m3u8":"https://vip.opstream14.com/20230626/38261_779f2473/index.m3u8"}]}],"time":"88 Phút","description":"Tam Nhân Hành là một bộ phim của đạo diễn Đỗ Kỳ Phong, mang đậm phong cách “lạnh lùng, tàn nhẫn, đen tối” vẫn thường thấy trong các bộ phim xã hội đen Hong Kong của ông. Tác phẩm chủ yếu kể lại câu chuyện của ba nhân vật chính: tên tội phạm nguy hiểm Đại Nghĩa (Chung Hán Lương), cảnh sát Trần Vĩ Lạc (Cổ Thiên Lạc) và nữ bác sĩ Đồng Sảnh (Triệu Vy). Trong một lần bị cảnh sát truy bắt, Đại Nghĩa bị thương ở đầu và uy hiếp các cảnh sát phải đưa mình tới bệnh viện. Tuy nhiên hắn lại từ chối chữa trị, kéo dài thời gian để đồng bọn đến giải thoát cho mình. Cùng lúc đó là cuộc giằng co giữa nữ bác sĩ Đồng Sảnh và cảnh sát Vĩ Lạc, với lương tâm của một người bác sĩ, cô quyết ra tay giúp đỡ Đại Nghĩa mặc cho Vĩ Lạc ngăn cản.","tmdb":{"type":"movie","id":"413133","season":null,"vote_average":0,"vote_count":0},"modified":"2023