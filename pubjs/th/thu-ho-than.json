ó trong phim, Tam ca Miêu Kiều Vỹ thường xuyên phải thực hiện các cảnh hành động và đấu súng căng thắng.</p>","tmdb_id":84817,"cast":["Miêu Kiều Vỹ","Huỳnh Tông Trạch","Annie Liu Xin-You","Kate Tsui Tsz-Shan","Hứa Thiệu Hùng","Từ Đông Đông","Ngô Đại Dung","Khương Hạo Văn","Địch Thiên Lâm","Hải Lục","Oscar Leung Lit-Wai","Jin Au-Yeung","Lâm Đức Tín","Từ Chính Khê","Wang Xiwei"],"director":["鍾澍佳"],"keywords":[],"tmdb":{"type":"tv","id":"84817","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Miêu Kiều Vỹ","name_vi":"Miêu Kiều Vỹ","name_original":"Michael Miu Kiu-Wai","tmdb_id":236075,"profile":"https://image.tmdb.org/t/p/w500/gJt4HBE493fHSBjHezSuA75VQ4A.jpg","tmdb_url":"https://www.themoviedb.org/person/236075"},{"name":"Huỳnh Tông Trạch","name_vi":"Huỳnh Tông Trạch","name_original":"Bosco Wong Chung-Chak","tmdb_id":144586,"profile":"https://image.tmdb.org/t/p/w500/o6RGUQXQRobk2PhoTc6zqpOC9yr.jpg","tmdb_url":"https://www.themoviedb.org/person/144586"},{"name":"Annie Liu Xin-You","name_vi":null,"name_original":"Annie Liu Xin-You","tmdb_id":104752,"profile":"https://image.tmdb.org/t/p/w500/ogzlGNWSVUVs6DJPWF6YFwkHE08.jpg","tmdb_url":"https://www.themoviedb.org/person/104752"},{"name":"Kate Tsui Tsz-Shan","name_vi":null,"name_original":"Kate Tsui Tsz-Shan","tmdb_id":131256,"profile":"https://image.tmdb.org/t/p/w500/d1YkPN0x4o46Jz7ws5WowWgOoW8.jpg","tmdb_url":"https://www.themoviedb.org/person/131256"},{"name":"Hứa Thiệu Hùng","name_vi":"Hứa Thiệu Hùng","name_original":"Benz Hui Siu-Hung","tmdb_id":63582,"profile":"https://image.tmdb.org/t/p/w500/bgC8VLG8bBdbQTuiHQtjFlEXo6E.jpg","tmdb_url":"https://www.themoviedb.org/person/63582"},{"name":"Từ Đông Đông","name_vi":"Từ Đông Đông","name_original":"Xu Dongdong","tmdb_id":1822751,"profile":"https://image.tmdb.org/t/p/w500/nV1wWx7nzt8kOdvoNNWDdCZEUsl.jpg","tmdb_url":"https://www.themoviedb.org/person/1822751"},{"name":"Ngô Đại Dung","name_vi":"Ngô Đại Dung","name_original":"Hugo Ng Doi-Yung","tmdb_id":1187932,