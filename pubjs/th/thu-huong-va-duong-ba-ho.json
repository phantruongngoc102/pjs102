om/share/59b109c700b500daa9ef3a6769bc8c6f","link_m3u8":"https://vip.opstream17.com/20240717/15195_d680bd2f/index.m3u8"},{"name":"15","slug":"15","filename":"Thu Huong  Duong Ba Ho 2010_720p-15","link_embed":"https://vip.opstream17.com/share/973cf0f1e5cb6a86bcc5a188d698a7bc","link_m3u8":"https://vip.opstream17.com/20240717/15196_0f087bd2/index.m3u8"},{"name":"16","slug":"16","filename":"Thu Huong  Duong Ba Ho 2010_720p-16","link_embed":"https://vip.opstream17.com/share/cdeb62ca10f63c94f575fa8f7f7a2b1f","link_m3u8":"https://vip.opstream17.com/20240717/15197_8904504b/index.m3u8"},{"name":"17","slug":"17","filename":"Thu Huong  Duong Ba Ho 2010_720p-17","link_embed":"https://vip.opstream17.com/share/d8e1d5073bde1c96433e0463f000bb35","link_m3u8":"https://vip.opstream17.com/20240717/15198_047b8ac7/index.m3u8"},{"name":"18","slug":"18","filename":"Thu Huong  Duong Ba Ho 2010_720p-18","link_embed":"https://vip.opstream17.com/share/21928eda50b8057eb6708e3c4d52faed","link_m3u8":"https://vip.opstream17.com/20240717/15199_506a8738/index.m3u8"},{"name":"19","slug":"19","filename":"Thu Huong  Duong Ba Ho 2010_720p-19","link_embed":"https://vip.opstream17.com/share/b1370fcd515bccf46591ed09a543d21b","link_m3u8":"https://vip.opstream17.com/20240717/15200_658bb23c/index.m3u8"},{"name":"20","slug":"20","filename":"Thu Huong  Duong Ba Ho 2010_720p-20.end","link_embed":"https://vip.opstream17.com/share/7c7b23ffe10825da18545758c0917543","link_m3u8":"https://vip.opstream17.com/20240717/15201_75a79ae0/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Bức tranh \"Cửu Mỹ Đồ\" của Đường Bá Hổ (do Trần Hào đóng) còn thiếu một mỹ nhân đặc biệt. Vì thế, tài tử Bá Hổ du sơn ngoạn thủy tìm kiếm mỹ nhân. Tình cờ anh gặp được Thu Hương (do Hồ Hạnh Nhi đóng) – nha hoàn của Hoa phủ. Bá Hổ không chỉ say mê phong thái thu hút mà còn ngưỡng mộ võ công lợi hại của cô. Bá Hổ quyết định vào Hoa phủ làm gia đinh. Anh muốn chinh phục Thu Hương bằng trái tim chân thành chứ không phải dựa vào danh tiếng của bản thân nên đã đổi tên thành Hoa An. Nào ngờ vì nhiều hiểu lầm, Bá Hổ chẳng những không thể lấy lòng người đẹp, ngược lại càng khiến Thu Hương thêm căm ghét. Duy chỉ có lão gia Hoa Hồng Sơn (do Hạ Vũ đóng) là nhìn Bá Hổ bằng cặp mắt khác. Từ lâu, ông đã biết anh không phải người tầm thường. Đường Bá Hổ vô tình vướng vào âm mưu lật đổ hoàng đế của Ninh Vương (do Tăng Vĩ Quyền đóng) và tình yêu đơn phương của quận chúa Chu Đình Ngọc (do Trần Pháp Lai đóng).</i></p>","tmdb":{"type":"tv","id":"32224","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-04T11:25:23.000Z","cast":["Elaine Yiu","Chris Lai","Trần Hào","Johnson Lee Sze-Chit","Hồ Hạnh Nhi","Trần Pháp Lai","La Quân Tả","Ha Yue","Lê Diệu Tường","Lý Quốc Lân","Savio Tsang","Lý Thành Xương","Âu Thụy Vỹ","Diêu Doanh Doanh","Hàn Mã Lợi"],"director":["Lưu Gia Hào"],"cast_meta":[{"name":"Elaine Yiu","name_vi":null,"name_original":"Elaine Yiu","tmdb_id":1234807,"profile":"https://image.tmdb.org/t/p/w500/CV05R5HbE4MnpeWeE5HAFaV2bG.jpg","tmdb_url":"https://www.themoviedb.org/person/1234807"},{"name":"Chris Lai","name_vi":null,"name_original":"Chris Lai","tmdb_id":112986,"profile":"https://image.tmdb.org/t/p/w500/en9t651XkkOpdfIZRQdtqmZD6YG.jpg","tmdb_url":"https://www.themoviedb.org/person/112986"},{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Johnson Lee Sze-Chit","name_vi":null,"name_original":"Johnson Lee Sze-Chit","tmdb_id":232771,"profile":"https://image.tmdb.org/t/p/w500/dIOWv7s4lgyBe4DxNx9gs7E6Kpz.jpg","tmdb_url":"https://www.themoviedb.org/person/232771"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/938251"},{"name":"Trần Pháp Lai","name_vi":"