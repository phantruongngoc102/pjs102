_embed":"https://vip.opstream90.com/share/4cf7fbdf88b8e8dc6f99b975754493e4","link_m3u8":"https://vip.opstream90.com/20260205/24148_4cf7fbdf/index.m3u8"}]}],"description":"<p>Năm năm trước, Ngô Nùng Vũ theo anh trai Ngô Tư Nguyên đến hiện trường một vụ án mạng, từ đó số phận cô giao thoa với nghi phạm Tạ Tân Tự. Dường như cơ thể cô tự nhiên tỏa ra sức hấp dẫn đặc biệt đối với anh, khiến anh vừa trông thấy cô đã nảy sinh khao khát mãnh liệt muốn chiếm hữu cô. Năm năm sau, để có được Ngô Nùng Vũ, Tạ Tân Tự ngụy trang thành một giáo sư y khoa lạnh lùng, âm mưu tiếp cận cô, cẩn thận giăng bẫy khiến cô yêu mình, hai người cùng dấn thân vào một cuộc phiêu lưu mạo hiểm. Trong những tháng ngày tiếp xúc với cô gái rạng rỡ như mặt trời, gã điên trời sinh thiếu sự đồng cảm dần dần học được cách nhận biết cảm xúc như người bình thường!</p><p>&nbsp;</p>","tmdb_id":311025,"cast":["Thôi Vũ Hâm","Phương Cẩn","Wang Yijun","Cao Duy Mạn","Wu Fei"],"director":["Chen Jiajie"],"keywords":[],"tmdb":{"type":"tv","id":"311025","season":1,"vote_average":10,"vote_count":2},"cast_meta":[{"name":"Thôi Vũ Hâm","name_vi":"Thôi Vũ Hâm","name_original":"Cui Yuxin","tmdb_id":2730675,"profile":"https://image.tmdb.org/t/p/w500/hy88IB9C0TFZH16m2aoplKEfFwx.jpg","tmdb_url":"https://www.themoviedb.org/person/2730675"},{"name":"Phương Cẩn","name_vi":"Phương Cẩn","name_original":"Fang Jin","tmdb_id":3541107,"profile":"https://image.tmdb.org/t/p/w500/zyFWHwiQkUoxD4gwhsJqXUIdaP8.jpg","tmdb_url":"https://www.themoviedb.org/person/3541107"},{"name":"Wang Yijun","name_vi":null,"name_original":"Wang Yijun","tmdb_id":2823870,"profile":"https://image.tmdb.org/t/p/w500/jhVZlxiS1n8GlfQMXiMLMSNvFQr.jpg","tmdb_url":"https://www.themoviedb.org/person/2823870"},{"name":"Cao Duy Mạn","name_vi":"Cao Duy Mạn","name_original":"Gao Weiman","tmdb_id":2580771,"profile":"https://image.tmdb.org/t/p/w500/4n8XToC5mCFiEryIfy2qr2gEfEj.jpg","tmdb_url":"https://www.themoviedb.org/person/2580771"},{"name":"Wu Fei","name_vi":null,"name_or