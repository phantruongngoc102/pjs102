ed":"https://vip.opstream15.com/share/7c8ba697dbc0c69dbdbf8a1a544e788f","link_m3u8":"https://vip.opstream15.com/20220518/15217_d97ff183/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream15.com/share/6f3ebe425120e7ee621966824bafee23","link_m3u8":"https://vip.opstream15.com/20220518/15218_010bb240/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/09b35ad905cc1f7bcdcee849bc4451a4","link_m3u8":"https://vip.opstream15.com/20220518/15219_efdd532f/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream15.com/share/ccea163536ff22f5706464b2d5cff933","link_m3u8":"https://vip.opstream15.com/20220518/15220_7ce8bf93/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream15.com/share/57b33ae6c0bf00c454900bea31d88893","link_m3u8":"https://vip.opstream15.com/20220518/15221_c331e545/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream15.com/share/7d4a769562e3528950e2d1aebdfb0550","link_m3u8":"https://vip.opstream15.com/20220518/15222_2ba3d0fc/index.m3u8"}]}],"description":"<p>Phim Thư Kiếm Tình Hiệp phim võ thuật nói về thời Bắc Tống, một số triều thần không phục triều đình có âm mưu phản tống khôi phục lại nhà đường. Và cũng tình cờ ngẫu nhiên đúng lúc đó có 2 người lạ mặt đột nhập hoàng cung đánh cắp bảo kiếm nhưng khi lấy được nó lại là một thanh kiếm giả không phải Thái A Bảo Kiếm. Lợi dụng điều đó thá tử lưu vong củ đời đường đã lập mưu kế để khôi phục triều Đường, ông có một người con trai là Liễu Tam Biến một người văn võ song toàn được ông cho ẩn thân ở chốn giang hồ từ rất lâu để chờ thời cơ. Âm mưu khôi phục lại triều đường có được thành công hay không?. Phim Thư Kiếm Tình Hiệp có nhiều màng trình diễn võ thuật thật đẹp mắt.</p>","tmdb_id":107711,"cast":["Lâm Chí Dĩnh","He Meitian","Hu Ke"],"director":["Trần Bách Nhật"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"107711","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Lâm Chí Dĩnh","name_vi