index.m3u8"}]}],"time":"48","description":"<p>Bộ phim võ thuật nói về thời Bắc Tống, một số triều thần không phục triều đình có âm mưu phản Tống khôi phục lại nhà Đường. Và cũng tình cờ ngẫu nhiên đúng lúc đó có 2 người lạ mặt đột nhập hoàng cung đánh cắp bảo kiếm nhưng khi lấy được nó lại là một thanh kiếm giả không phải Thái A Bảo Kiếm. Lợi dụng điều đó thái tử lưu vong cũ đời Đường đã lập mưu kế để khôi phục triều Đường, ông có một người con trai là Liễu Tam Biến văn võ song toàn được ông cho ẩn thân ở chốn giang hồ từ rất lâu để chờ thời cơ. Liệu âm mưu khôi phục lại triều Đường có thành công hay không?</p>","tmdb":{"type":"tv","id":"107711","season":1,"vote_average":0,"vote_count":0},"modified":"2023-07-05T20:14:27.000Z","cast":["Lâm Chí Dĩnh","He Meitian","Hu Ke"],"director":["Trần Bách Nhật"],"cast_meta":[{"name":"Lâm Chí Dĩnh","name_vi":"Lâm Chí Dĩnh","name_original":"Jimmy Lin Chih-Ying","tmdb_id":123801,"profile":"https://image.tmdb.org/t/p/w500/aS0aqrBHa4THPOQY1LidsRZytci.jpg","tmdb_url":"https://www.themoviedb.org/person/123801"},{"name":"He Meitian","name_vi":null,"name_original":"He Meitian","tmdb_id":116422,"profile":"https://image.tmdb.org/t/p/w500/qQVjKRuJLhg1n6PemWVflsPpvdu.jpg","tmdb_url":"https://www.themoviedb.org/person/116422"},{"name":"Hu Ke","name_vi":null,"name_original":"Hu Ke","tmdb_id":544790,"profile":"https://image.tmdb.org/t/p/w500/3LMCJlrifOO1Me47sjeQ3xAu22o.jpg","tmdb_url":"https://www.themoviedb.org/person/544790"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thu-kiem-tinh-hiep.json"}