g Kim Sung Yeol cũng chính là một ma cà rồng…</p>","tmdb":{"type":"tv","id":"63106","season":1,"vote_average":6.5,"vote_count":38},"modified":"2023-07-06T18:31:48.000Z","cast":["Lee Joon-gi","Lee Yu-bi","MAX Changmin","Lee Soo-hyuk","Kim So-eun","Jang Hee-jin","Lee Soon-jae","Choi Tae-hwan","Park So-young","Kim Myung-gon","Park Si-woo","Moo Jin-sung","Seo Ji Yeon"],"director":["Lee Sung Joon"],"cast_meta":[{"name":"Lee Joon-gi","name_vi":null,"name_original":"Lee Joon-gi","tmdb_id":122408,"profile":"https://image.tmdb.org/t/p/w500/tHPJUgGiQRWt1Bh7ymqmmJ2zKF6.jpg","tmdb_url":"https://www.themoviedb.org/person/122408"},{"name":"Lee Yu-bi","name_vi":null,"name_original":"Lee Yu-bi","tmdb_id":1346876,"profile":"https://image.tmdb.org/t/p/w500/dWJhrhEf9IfT62Qo7bT4j3ab1IE.jpg","tmdb_url":"https://www.themoviedb.org/person/1346876"},{"name":"MAX Changmin","name_vi":null,"name_original":"MAX Changmin","tmdb_id":1255918,"profile":"https://image.tmdb.org/t/p/w500/4zQDFt8JAikGGdgyifJkO3jLL23.jpg","tmdb_url":"https://www.themoviedb.org/person/1255918"},{"name":"Lee Soo-hyuk","name_vi":null,"name_original":"Lee Soo-hyuk","tmdb_id":1257624,"profile":"https://image.tmdb.org/t/p/w500/drqY2KOm6kcESbVPSNnOj4oa27b.jpg","tmdb_url":"https://www.themoviedb.org/person/1257624"},{"name":"Kim So-eun","name_vi":null,"name_original":"Kim So-eun","tmdb_id":117508,"profile":"https://image.tmdb.org/t/p/w500/kXl9W2FGBnHMq2UeCtaYeG1Do4O.jpg","tmdb_url":"https://www.themoviedb.org/person/117508"},{"name":"Jang Hee-jin","name_vi":null,"name_original":"Jang Hee-jin","tmdb_id":936836,"profile":"https://image.tmdb.org/t/p/w500/kHoM8wW7IDpTfyfB0ohXCBgzobi.jpg","tmdb_url":"https://www.themoviedb.org/person/936836"},{"name":"Lee Soon-jae","name_vi":null,"name_original":"Lee Soon-jae","tmdb_id":566367,"profile":"https://image.tmdb.org/t/p/w500/zYjhQJ27PUY2hxiIr50AIJ7TWa8.jpg","tmdb_url":"https://www.themoviedb.org/person/566367"},{"name":"Choi Tae-hwan","name_vi":null,"name_original":"Choi Tae-hwan","tmdb_