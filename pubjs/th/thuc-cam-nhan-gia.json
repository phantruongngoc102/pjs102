6f8cde8ddce74e2","link_m3u8":"https://vip.opstream15.com/20241221/45746_88dc6aff/index.m3u8"}]}],"description":"“Thục Cẩm Nhân Gia” là câu chuyện về lòng dũng cảm, đấu tranh và không sợ gian khổ. Nó xoay quanh huyền thoại về Quý Anh Anh với tính cách mạnh mẽ, từ một cô gái trẻ ở phường nhuộm Hoán Hoa trở thành một nữ thợ thủ công. Vào thời nhà Đường, vẻ đẹp của gấm Thục đã được người đời biết đến, giới quyền quý đổ xô theo nó, trong quân đội thậm chí có thể “dùng gấm để đổi lấy lương bổng”, tấc gấm tấc vàng. Nó trở thành mục tiêu tranh giành lợi ích của tất cả các thế lực. Dưới sự thịnh vượng của ngành gấm ở Ích Châu là sóng ngầm dữ dội. Tơ đỏ gấm Thục của nhà họ Quý ở Ích Châu vô cùng hiếm có, và nổi danh là “Gấm đỏ xuất hiện, ngàn đỏ lu mờ”. Tuy nhiên, nhà họ Quý không may dính líu đến vụ án gấm giả, gia chủ chết trong ô nhục, cả gia đình rơi vào cảnh điêu tàn chỉ sau một đêm. Tiểu thư nhà họ Quý, Quý Anh Anh, từ nhỏ đã thông minh, say mê nhuộm lụa, tài năng dần dần bộc lộ, nàng quyết chí chấn hưng gia nghiệp, minh oan cho cha.","tmdb_id":258463,"cast":["Đàm Tùng Vận","Trịnh Nghiệp Thành","Kinh Siêu","Trương Hạo Duy","Trần Tiểu Vân","Wang Yinuo","Triệu Hoa Vi","Huang Wei Zhong","Cindy Chen"],"director":["Liu Haibo","Song Yang","Ben Fang"],"keywords":[],"tmdb":{"type":"tv","id":"258463","season":1,"vote_average":7.8,"vote_count":5},"cast_meta":[{"name":"Đàm Tùng Vận","name_vi":"Đàm Tùng Vận","name_original":"Tan Songyun","tmdb_id":1614218,"profile":"https://image.tmdb.org/t/p/w500/yYMnfaIix23U51z21EJhznq3DHN.jpg","tmdb_url":"https://www.themoviedb.org/person/1614218"},{"name":"Trịnh Nghiệp Thành","name_vi":"Trịnh Nghiệp Thành","name_original":"Zheng Yecheng","tmdb_id":1683307,"profile":"https://image.tmdb.org/t/p/w500/cYgbZiaaGa25peTsf10mvX7KoZb.jpg","tmdb_url":"https://www.themoviedb.org/person/1683307"},{"name":"Kinh Siêu","name_vi":"Kinh Siêu","name_original":"Jing Chao","tmdb_id":1528926,"profile":"https://image.tmdb.org/t/p/w500/6dsz8k3gcXPWRYBpszQyldmT8b.jpg"