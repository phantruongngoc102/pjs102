u8"},{"name":"55","slug":"55","filename":"thuc-son-chien-ky-kiem-hiep-truyen-ky-tap-55","link_embed":"https://vip.opstream14.com/share/1aa7690e43a5471b7344591df7afb611","link_m3u8":"https://vip.opstream14.com/20220626/15950_89af21cb/index.m3u8"},{"name":"56","slug":"56","filename":"thuc-son-chien-ky-kiem-hiep-truyen-ky-tap-56","link_embed":"https://vip.opstream14.com/share/8441c6ab9e88ee3764bd79b6d72269a1","link_m3u8":"https://vip.opstream14.com/20220626/15951_64293dbf/index.m3u8"}]}],"time":"43M43S","description":"<p>Phái Thục Sơn - môn phái chính đạo nổi danh giang hồ đã dẫn dắt toàn bộ võ lâm trong một thời gian dài. Với mong muốn bảo vệ thiên hạ, chống lại ý đồ chiếm đoạt Xích Hồn Thạch của Lục Bào tôn giả, chưởng môn Gia Cát Ngự Ngã của phái Thục Sơn đã đưa Xích Hồn Thạch vào cơ thể của Đinh Ẩn. Từ đó, Đinh Ẩn đã trở thành đệ tử của Thục Sơn và bắt đầu tu luyện kiếm pháp tại đây, với mong muốn thay người dân trăm họ trả thù Lục Bào tôn giả. Tình cờ, Đinh Ẩn phát hiện ra cô con gái Ngọc Vô Tâm của Lục Bào giống hệt người vợ yêu đã mất của mình. Hai người nhanh chóng cùng nhau rơi vào lưới tình. Đinh Ẩn đã cùng hợp tác với sư huynh đồng môn là Đan Thần Tử và những người khác để vượt qua âm mưu gian khổ, không muốn lại rơi vào một âm mưu nguy hiểm hơn nữa.</p>","tmdb":{"type":"tv","id":"65665","season":1,"vote_average":7.4,"vote_count":7},"modified":"2023-06-23T19:30:17.000Z","cast":["Yu Ting'er","Trần Triết Viễn","Ngô Kỳ Long","Liu Yitong","Nie Zihao","Liu Sitong","Wei Chunguang","Bian Yuan","Qin Shan","Biên Trình","Yu Yao","Đại Lộ Oa","Guo Wei","Li Jiawen","Guan Mei Ting"],"director":["Ricky Wong"],"cast_meta":[{"name":"Yu Ting'er","name_vi":null,"name_original":"Yu Ting'er","tmdb_id":2887207,"profile":"https://image.tmdb.org/t/p/w500/wkyaRLDdsDl8mmmVwEd0DhEHOsg.jpg","tmdb_url":"https://www.themoviedb.org/person/2887207"},{"name":"Trần Triết Viễn","name_vi":"Trần Triết Viễn","name_original":"Chen Zheyuan","tmdb_id":2439184,"profile":"https://image.tmdb.org/t/p/w