20327/6133_d7a83533/index.m3u8"},{"name":"25","slug":"25","filename":"thuc-tap-sinh-khach-san-tap-24","link_embed":"https://vip.opstream12.com/share/1ca5c750a30312d1919ae6a4d636dcc4","link_m3u8":"https://vip.opstream12.com/20220327/6134_e2008c3b/index.m3u8"}]}],"time":"44M6S","description":"<p>Cô nàng Nhạc Nhiên sinh viên ngành quản trị khách sạn vừa đến thực tập tại khách sạn nghỉ dưỡng suối nước nóng hàng đầu cả nước. Đen đủi cho cô, mới ngày đầu tiên đi làm đã chụp lên đầu tổng giám đốc Tạ Phàn Vũ, thái tử gia đang vi hành tội danh biến thái. Hai người không đánh không quen biết, bắt đầu chuỗi ngày ân oán bất tận. Tai vạ dồn dập, suối nước nóng bỗng dưng khô cạn, khách sạn sắp bị đem ra thế chấp, khiến Tạ Phàn Vũ và những thực tập sinh ở đây phải bắt đầu cuộc chiến bảo vệ khách sạn của mình!</p>","tmdb":{"type":"tv","id":"111591","season":1,"vote_average":8,"vote_count":1},"modified":"2023-04-16T14:49:07.000Z","cast":["Bo Guanzhi","Mã Mộng Duy","Triệu Chí Vỹ","Zhu Si Yi","Sun Jiaqi","Heliao Lüyun","Li Hua","Wang Neng","Zhao Wenming","Zhu Minxin","Yu Yingying","Zhang Shulun","Oliver Yan","Wang Yu Hang","Wang Zi Yan"],"director":["Tan Jie"],"cast_meta":[{"name":"Bo Guanzhi","name_vi":null,"name_original":"Bo Guanzhi","tmdb_id":2816817,"profile":"https://image.tmdb.org/t/p/w500/sS3Kzkb1z6fZvP58pOuu0wxFoFw.jpg","tmdb_url":"https://www.themoviedb.org/person/2816817"},{"name":"Mã Mộng Duy","name_vi":"Mã Mộng Duy","name_original":"Ma Mengwei","tmdb_id":2492962,"profile":"https://image.tmdb.org/t/p/w500/2MTS1mtpkOcLkyBGLop6HThQ0uQ.jpg","tmdb_url":"https://www.themoviedb.org/person/2492962"},{"name":"Triệu Chí Vỹ","name_vi":"Triệu Chí Vỹ","name_original":"Zhao Zhiwei","tmdb_id":2300678,"profile":"https://image.tmdb.org/t/p/w500/alsxeaNeEtTLdw8psXaQsgfn4cg.jpg","tmdb_url":"https://www.themoviedb.org/person/2300678"},{"name":"Zhu Si Yi","name_vi":null,"name_original":"Zhu Si Yi","tmdb_id":3958159,"profile":"https://image.tmdb.org/t/p/w500/fh3qWhmB0jY4ZSBBgeKKeRoRWrp.jpg","t