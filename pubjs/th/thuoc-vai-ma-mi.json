/share/de24e1cb8921280596f82fe71298847e","link_m3u8":"https://vip.opstream14.com/20221011/23995_d9e4c7f2/index.m3u8"},{"name":"37","slug":"37","link_embed":"https://vip.opstream14.com/share/17d6adbfbdb7e94b4012bce72ad86379","link_m3u8":"https://vip.opstream14.com/20221011/23996_511f9a2e/index.m3u8"},{"name":"38","slug":"38","link_embed":"https://vip.opstream14.com/share/1e963a1d2b57f85203e9fc58a78e7018","link_m3u8":"https://vip.opstream14.com/20221011/23997_dac01f89/index.m3u8"},{"name":"39","slug":"39","link_embed":"https://vip.opstream14.com/share/97a6101840de04f86a2540e62a7b3e13","link_m3u8":"https://vip.opstream14.com/20221011/23998_5179279e/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream14.com/share/efc7667564c801b723843a81b5b10ab5","link_m3u8":"https://vip.opstream14.com/20221011/23999_a4d0a183/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream14.com/share/b9adc4df9a0d423c165f63f40eb3a0df","link_m3u8":"https://vip.opstream14.com/20221011/24000_f66c754f/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream14.com/share/0091db9e2726ab840251ea69bc0faea3","link_m3u8":"https://vip.opstream14.com/20221011/24001_54987d71/index.m3u8"}]}],"description":"<p>Gia đình Alada sở hữu tấm vải Luntaya màu hồng tuyệt đẹp do bà nội cô dệt cho Công chúa Minphayu. Tuy nhiên, sau đó, bà cô lại bị mù một cách bí ẩn. Đam mê với ngành dệt, Alada tham gia nghiên cứu việc bảo quản vải cổ tại Viện dệt may Saodor ở Anh. Sau khi tốt nghiệp, cô trở về Thái Lan và gặp gỡ những người bạn mới. Thật tình cờ khi cả nhóm đều có mối liên hệ với tấm vải Luntaya và họ đã cùng nhau giải mã bí ẩn xung quanh nó.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thuoc-vai-ma-mi.json"}