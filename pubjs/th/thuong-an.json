n Ổn) và Vưu Kỳ (Lâm Phong Tùng) cũng xuất hiện những tình cảm khó nói.</p>","tmdb_id":65890,"cast":["Timmy Xu","Hoàng Cảnh Du","Lin Fengsong","Chen Wen"],"director":["Wei Ding"],"keywords":[],"tmdb":{"type":"tv","id":"65890","season":1,"vote_average":7.4,"vote_count":55},"cast_meta":[{"name":"Timmy Xu","name_vi":null,"name_original":"Timmy Xu","tmdb_id":1591362,"profile":"https://image.tmdb.org/t/p/w500/mntBCVt07NMqVafuBKOc9kCFl9U.jpg","tmdb_url":"https://www.themoviedb.org/person/1591362"},{"name":"Hoàng Cảnh Du","name_vi":"Hoàng Cảnh Du","name_original":"Johnny Huang","tmdb_id":1816461,"profile":"https://image.tmdb.org/t/p/w500/mc7HlXJU0Sr5WkodEHS3csaxi6E.jpg","tmdb_url":"https://www.themoviedb.org/person/1816461"},{"name":"Lin Fengsong","name_vi":null,"name_original":"Lin Fengsong","tmdb_id":1591363,"profile":"https://image.tmdb.org/t/p/w500/fHuXu83YRE2L1hmcavFpIxYm6Im.jpg","tmdb_url":"https://www.themoviedb.org/person/1591363"},{"name":"Chen Wen","name_vi":null,"name_original":"Chen Wen","tmdb_id":1591364,"profile":"https://image.tmdb.org/t/p/w500/rQWBLkU6kYIxUft9G9bR6rxDQVZ.jpg","tmdb_url":"https://www.themoviedb.org/person/1591364"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thuong-an.json"}