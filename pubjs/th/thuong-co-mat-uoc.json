ttps://vip.opstream15.com/share/e430f779f7ff81de0e5b4c4f5e316672","link_m3u8":"https://vip.opstream15.com/20220511/13321_eafc8707/index.m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream15.com/share/3640536b683d5276cbe1174768aed8df","link_m3u8":"https://vip.opstream15.com/20220511/13323_f5821d56/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream15.com/share/220bd44f67edd4f311c6c06436cf9a65","link_m3u8":"https://vip.opstream15.com/20220511/13325_1e3b2355/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream15.com/share/82f82644bda7a260970fbd52a4c96528","link_m3u8":"https://vip.opstream15.com/20220511/13327_99846d43/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream15.com/share/d27bf4d538d65711468835f9daef576e","link_m3u8":"https://vip.opstream15.com/20220511/13329_3f0c124c/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream15.com/share/f055c54d16a8cc75a8cc996511cc9a9c","link_m3u8":"https://vip.opstream15.com/20220511/13331_36d9c956/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream15.com/share/03bd9b02ba7c3138715a5c3fd05ff6d7","link_m3u8":"https://vip.opstream15.com/20220511/13333_d49beefa/index.m3u8"}]}],"description":"<p>Phim Thượng Cổ Mật Ước – The Promise Keepers kể về Ngụy Tấn Nam bắc triều , Tiên Ti Mộ dung thị lập nên yên quốc. Lang tộc luôn trợ giúp hoàng tộc Mộ Dung. Vua Yên còn trẻ, và các trận chiến chính trị giữa các thành viên hoàng gia rất khốc liệt. 1 sự biến cố trong hoàng gia khiến Con trai cả Murong Yan bị chặt đầu, con trai thứ hai Murong Chen bị gửi đi lưu vong. Con gái Murong Yi đã được gửi trở lại Vùng Đất của bộ tộc Sói, bị người yên bỏ qua một bên. Dưới sự giúp đỡ của các linh hồn xấu xa, Murong Yan, người đã giả chết, muốn trở lại và chiến thắng các vị thần cổ đại. Murong Chen đã nghiên cứu sức mạnh của những con quỷ chiến thắng để trả thù, và anh gặp Murong Yi, người đã biến thành quỷ dữ. Ba anh chị em đã bị ép buộc bởi sự ghét bỏ và trả thù của các quốc gia, dẫn đến việc làm sáng tỏ một âm mưu ngàn năm để được làm sáng tỏ.</p>","tmdb_id":99317,"cast":["Cao Nhân","Ngô Lỗi","Quách Tuấn Thần"],"director":["Hỗ Diệu Chi"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"99317","season":1,"vote_average":7.8,"vote_count":4},"cast_meta":[{"name":"Cao Nhân","name_vi":null,"name_original":"Cao Nhân"},{"name":"Ngô Lỗi","name_vi":null,"name_original":"Ngô Lỗi"},{"name":"Quách Tuấn Thần","name_vi":null,"name_original":"Quách Tuấn Thần"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thuong-co-mat-uoc.json"}