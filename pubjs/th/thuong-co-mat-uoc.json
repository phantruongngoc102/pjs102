a, dẫn đến việc làm sáng tỏ một âm mưu ngàn năm để được làm sáng tỏ.</p>","tmdb_id":99317,"cast":["Ngô Lỗi","Tống Tổ Nhi","Vương Tuấn Khải","Quách Tuấn Thần","Zhang Lingxin","Trịnh Khải","Gao Yiren","Xuan Yan","Liu Zhiwei","Trương Vũ Kỳ","Liu Ruiqiao","Li Junxian","孔令伟"],"director":["Hu Yaozhi"],"keywords":[],"cast_meta":[{"name":"Ngô Lỗi","name_vi":"Ngô Lỗi","name_original":"Leo Wu","tmdb_id":1438264,"profile":"https://image.tmdb.org/t/p/w500/43fYrqW26tisHBblj9lazersTdr.jpg","tmdb_url":"https://www.themoviedb.org/person/1438264"},{"name":"Tống Tổ Nhi","name_vi":"Tống Tổ Nhi","name_original":"Song Zuer","tmdb_id":2104489,"profile":"https://image.tmdb.org/t/p/w500/aB1MfYz5LDZmfULDnqGjRgsg25Z.jpg","tmdb_url":"https://www.themoviedb.org/person/2104489"},{"name":"Vương Tuấn Khải","name_vi":"Vương Tuấn Khải","name_original":"Karry Wang","tmdb_id":1785744,"profile":"https://image.tmdb.org/t/p/w500/gl1ibG6gEDy0XKAkSDbzEieDZq0.jpg","tmdb_url":"https://www.themoviedb.org/person/1785744"},{"name":"Quách Tuấn Thần","name_vi":"Quách Tuấn Thần","name_original":"Guo Junchen","tmdb_id":1599859,"profile":"https://image.tmdb.org/t/p/w500/m6Ub6fRrw03atP60nCj4o55ojrO.jpg","tmdb_url":"https://www.themoviedb.org/person/1599859"},{"name":"Zhang Lingxin","name_vi":null,"name_original":"Zhang Lingxin","tmdb_id":2314448,"profile":"https://image.tmdb.org/t/p/w500/c7W6C2GLcvsAFqcjIEg1SPm51hm.jpg","tmdb_url":"https://www.themoviedb.org/person/2314448"},{"name":"Trịnh Khải","name_vi":"Trịnh Khải","name_original":"Zheng Kai","tmdb_id":2348849,"profile":"https://image.tmdb.org/t/p/w500/ux9D2eyOdd7QauGDOVSklZ22OJE.jpg","tmdb_url":"https://www.themoviedb.org/person/2348849"},{"name":"Gao Yiren","name_vi":null,"name_original":"Gao Yiren","tmdb_id":2541521,"profile":"https://image.tmdb.org/t/p/w500/UWFhtfJ0EGPehGDlKKWVJMg6e3.jpg","tmdb_url":"https://www.themoviedb.org/person/2541521"},{"name":"Xuan Yan","name_vi":null,"name_original":"Xuan Yan","tmdb_id":2541538,"profile":"https://image.tmdb.org/t/p/