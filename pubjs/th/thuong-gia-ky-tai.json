m/share/422e42d058a41c75062760d7d640debf","link_m3u8":"https://vip.opstream10.com/20220506/12215_67b2a087/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream10.com/share/b18336c06954cf0a92113517ca2bdd29","link_m3u8":"https://vip.opstream10.com/20220506/12218_4bcf5ab3/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream10.com/share/2c5201a7391fedbc40c3cc6aa057a029","link_m3u8":"https://vip.opstream10.com/20220506/12217_ef26e13b/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream10.com/share/96752f0608aff8b3436a1b5a5099c0ce","link_m3u8":"https://vip.opstream10.com/20220506/12220_76dd77be/index.m3u8"},{"name":"33","slug":"33","link_embed":"https://vip.opstream10.com/share/004881ebe3826cf16cfd124968f2a5bb","link_m3u8":"https://vip.opstream10.com/20220506/12223_9a0b48d6/index.m3u8"},{"name":"34","slug":"34","link_embed":"https://vip.opstream10.com/share/eafd9b2037cb218fafd3aa05535c123e","link_m3u8":"https://vip.opstream10.com/20220506/12224_57ab0ca2/index.m3u8"}]}],"description":"<p>Bộ phim Thương Gia Kỳ Tài 2014 lấy bối cảnh vào một cuộc suy thoái của triều đại Trung Quốc năm 1776. Giao thương qua đất nước này càng ngày càng nhộn nhịp thì đi đôi với đó là những thương gia giàu có nhờ buôn bán ngày càng nhiều. Trong đó có một vị thương gia được mệnh danh là kỳ tài. Lúc đó vua Càn Long đương ngồi trên ngôi, triều đình loạn lạc, ngân khố cạn kiệt và vua Càn Long cho triệu tập các hiền tài về giao thương</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thuong-gia-ky-tai.json","tmdb_checked":false}