.opstream11.com/share/7dc18693b9385d133160f80154c8976d","link_m3u8":"https://vip.opstream11.com/20220416/15962_6f79d3d7/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream11.com/share/2e74a7ac5ae99bce3c891f74bcbfd0ee","link_m3u8":"https://vip.opstream11.com/20220416/15964_0077ecab/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream11.com/share/87da3a68e40336b5aaed42e34be59e3b","link_m3u8":"https://vip.opstream11.com/20220416/15965_e3e69595/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream11.com/share/527c815c48b61dcafe755b5d425115ec","link_m3u8":"https://vip.opstream11.com/20220416/15966_98c92c28/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream11.com/share/fdc2397ee9d0dbbcfdc0ba1c0fe3442b","link_m3u8":"https://vip.opstream11.com/20220416/15968_f46d9094/index.m3u8"}]}],"description":"<p>Câu chuyện về 3 anh em họ Lu cùng lớn lên tại Thượng Hải những năm 1990, chứng kiến nền kinh tế hỗn loạn nơi đây dần thay đổi trở thành trung tâm tài chính thương mại lớn của Trung Quốc. Lu JiangTao từ tay trắng trở lên giàu có, nhưng anh dần thay đổi và đánh mất bản thân, trở lên thực dụng và thờ ơ với gia đình. Anh coi người thân và gia đình như những công cụ cho mục đích làm giàu. Người anh cả Lu Hai Bo luôn coi trọng gia đình, tình cảm. Anh có thể thất bại và từ bỏ nhiều thứ, nhưng điều đó lại giúp anh thành công về sau. Cùng với gia đình, Hai Bo giúp đỡ JiangTao nhận thức được sai lầm và tìm lại hạnh phúc.Trong thế giới kinh doanh khốc liệt, gia đình họ Lu một lần nữa cùng nhau vượt qua khó khăn, vươn đến thành công.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thuong-hai-vinh-hoa-lac-loi.json","tmdb_checked":false}