51334a0e3f64650913cc80a50d4d78","link_m3u8":"https://vip.opstream16.com/20230310/32849_898375cb/index.m3u8"},{"name":"24","slug":"24","filename":"Thuong Lan Quyet HH E24","link_embed":"https://vip.opstream16.com/share/875dbe9e8d6e7a08b546eee88a3bddd3","link_m3u8":"https://vip.opstream16.com/20230310/32850_34ef208a/index.m3u8"}]}],"time":"14 phút/tập","description":"<p>Đông Phương Thanh Thương người bị đàn áp hàng ngàn năm đã quay trở lại Tam giới, sau khi hồi sinh, đã gây ra một cuộc chiến giữa tiên giới và ma giới, nhưng vì linh lực chưa hồi phục nên đã bị trọng thương. Để trốn thoát, Ma tôn và tiểu tiên Tiểu Lan Hoa đã hoán đổi linh hồn, nhưng Tiểu Lan Hoa, vì không muốn điều khiển ma lực nên đã vô tình làm chết tiên thân của mình, hai người rơi vào tình thế khó xử khi dùng chung thân thể. Trong cơn tuyệt vọng, cả hai lao vào hành trình tìm kiếm một cơ thể mới. Trên đường đi, cả hai trải qua đủ thứ chuyện, Tiểu Tiên Hoa đã thầm yêu Đông Phương Thanh Thương nhưng không hề biết rằng lúc này Đông Phương Thanh Thương chỉ coi cô ấy như một công cụ để hồi sinh. Hơn nữa một âm mưu vô cùng lớn đang âm thầm diễn ra trong sự yên bình...</p>","tmdb":{"type":"tv","id":"206534","season":1,"vote_average":7.3,"vote_count":7},"modified":"2025-04-15T10:20:20.000Z","cast":["Ajie","Nie Xiying","Yang Tianxiang"],"director":[],"cast_meta":[{"name":"Ajie","name_vi":null,"name_original":"Ajie","tmdb_id":1674221,"profile":"https://image.tmdb.org/t/p/w500/AaXR7HBOkyrLlM93cycAt6i9NDE.jpg","tmdb_url":"https://www.themoviedb.org/person/1674221"},{"name":"Nie Xiying","name_vi":null,"name_original":"Nie Xiying","tmdb_id":3424042,"profile":"https://image.tmdb.org/t/p/w500/hzdBwUblHmYsDITxSgaW5M9faZX.jpg","tmdb_url":"https://www.themoviedb.org/person/3424042"},{"name":"Yang Tianxiang","name_vi":null,"name_original":"Yang Tianxiang","tmdb_id":2185754,"profile":"https://image.tmdb.org/t/p/w500/jEwKu9VEtl0ecc6oA264U3iJV08.jpg","tmdb_url":"https://www.themoviedb.org/person/2185754"}],"keywords":[],"