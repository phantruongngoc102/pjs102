ou Dong","Baomu Zhongyang","Wang Xiaoqian"],"director":["张毅立"],"keywords":[],"tmdb":{"type":"tv","id":"229192","season":1,"vote_average":9.4,"vote_count":15},"cast_meta":[{"name":"Sanshi","name_vi":null,"name_original":"Sanshi","tmdb_id":4316658,"profile":"https://image.tmdb.org/t/p/w500/ajQVjnlrTOw6M8qSrwjBXlcCFkg.jpg","tmdb_url":"https://www.themoviedb.org/person/4316658"},{"name":"Đoàn Nghi Hiên","name_vi":"Đoàn Nghi Hiên","name_original":"Duan Yixuan","tmdb_id":2206686,"profile":"https://image.tmdb.org/t/p/w500/t0SFESlym4mWsrhNM3V1qY7ZQXo.jpg","tmdb_url":"https://www.themoviedb.org/person/2206686"},{"name":"Liangwei Hu","name_vi":null,"name_original":"Liangwei Hu","tmdb_id":2541894,"profile":"https://image.tmdb.org/t/p/w500/akWLy9NWNy9RwPpli7FsjdzrVUy.jpg","tmdb_url":"https://www.themoviedb.org/person/2541894"},{"name":"Ma Zhengyang","name_vi":null,"name_original":"Ma Zhengyang","tmdb_id":2532862,"profile":"https://image.tmdb.org/t/p/w500/d7ySPv0g1cq8QrWbdfqG4YvTxM1.jpg","tmdb_url":"https://www.themoviedb.org/person/2532862"},{"name":"Ma Haifeng","name_vi":null,"name_original":"Ma Haifeng","tmdb_id":3035396,"profile":"https://image.tmdb.org/t/p/w500/ik7uxOXJ2XRMJKM1KHw2TqUODXB.jpg","tmdb_url":"https://www.themoviedb.org/person/3035396"},{"name":"Xia Michen","name_vi":null,"name_original":"Xia Michen","tmdb_id":4248911,"profile":"https://image.tmdb.org/t/p/w500/pluH4RyBlc8sGqwdTDWxtoyqKlk.jpg","tmdb_url":"https://www.themoviedb.org/person/4248911"},{"name":"Liu Qianhan","name_vi":null,"name_original":"Liu Qianhan","tmdb_id":4382368,"profile":"https://image.tmdb.org/t/p/w500/vlbc1Mo87d1ZIKc3mwXr1QgUahH.jpg","tmdb_url":"https://www.themoviedb.org/person/4382368"},{"name":"Zhengjian Hu","name_vi":null,"name_original":"Zhengjian Hu","tmdb_id":4382366,"profile":"https://image.tmdb.org/t/p/w500/y9A09AMmUbZp4TWvI6fgMYH8dZ8.jpg","tmdb_url":"https://www.themoviedb.org/person/4382366"},{"name":"Zhen Zhao","name_vi":null,"name_original":"Zhen Zhao","tmdb_id":4382367,"profil