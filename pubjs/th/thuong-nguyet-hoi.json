ream14.com/share/489dde05f53b59ffd2ec29bf410a0ebb","link_m3u8":"https://vip.opstream14.com/20221212/28358_9258c01a/index.m3u8"},{"name":"25","slug":"25","filename":"thuong-nguyet-hoi-tap-25","link_embed":"https://vip.opstream14.com/share/36677a1d815d4528bebf89833d168f56","link_m3u8":"https://vip.opstream14.com/20221213/28377_c6f0fd07/index.m3u8"},{"name":"26","slug":"26","filename":"thuong-nguyet-hoi-tap-26","link_embed":"https://vip.opstream14.com/share/daf94f1c25809886095022d124aaf1fa","link_m3u8":"https://vip.opstream14.com/20221213/28378_27b98ede/index.m3u8"}]}],"time":"36 phút/tập","description":"<p>Thương Nguyệt Hội (Mỹ Nhân Nghịch Lân) là bộ phim kể về câu chuyện của Lạc gia, bị bọn xã hội đen cướp vì sở hữu phượng chi bí ẩn. Gia tộc này đã bị tiêu diệt và chỉ còn lại Lạc Khê Vân một cô gái bị nhiễm chất độc bào thai. Tám năm sau Lạc Khê Vân đã trở thành nhà khảo sát dân sự nổi tiếng nhất ở thành phố Thương Nguyệt. Cô dựa vào bán bản đồ và vẽ bản đồ khảo sát để kiếm sống. Cô bị nhiễm độc nặng và chỉ còn sống được ba tháng. Trước khi chết, cô muốn trả thù cho anh trai mình bằng cách giết Giang Triều Hi. Lúc này, phố Kiến Gia vốn là nơi duy nhất mang lại hơi ấm cho cô sắp bị phá hủy do quy hoạch phát triển thành phố. Để bảo vệ ngôi nhà của tổ tiên và dân làng, Lạc Khê Vân đã dồn hết tài năng của mình để đưa ra một bản đồ quy hoạch mới, sau đó cô tiếp cận Giang Triều Hi, trở thành khách hàng của hắn. Tình cờ, cô phát hiện ra rằng anh trai bất tỉnh của mình đang được giấu trong phủ. Cô cũng khám phá ra một bí mật đáng ngạc nhiên của Triều Hi. Trong quá trình cải trang và giao lưu với nhau họ nảy sinh tình cảm với nhau. Tuy nhiên, Khê Vân lại gặp nguy hiểm khi danh tính thực sự của cô ấy được bi tiết lộ</p>","tmdb":{"type":"tv","id":"215463","season":1,"vote_average":6,"vote_count":2},"modified":"2025-05-03T10:29:35.000Z","cast":["Kim Trạch","Guan Xin","Chen Zhengyang","Zhao Pinlin","Xu Baiyun","Wang Gang","Song Yunhao","Tông Phong Nham"],"director":["Yang Xiao Bo