k_m3u8":"https://vip.opstream90.com/20251015/15117_13da2193/index.m3u8"}]}],"time":"? phút/tập","description":"<p>Năm mười bảy tuổi, Giang Xuân Vũ trở thành mục tiêu bắt nạt tàn bạo do Cố Niệm cầm đầu, một cuộc tra tấn kết thúc bằng cái chết đau lòng của mẹ cô, người thân duy nhất còn lại của cô. Nhiều năm sau, được tôi luyện bởi đau khổ, cô trở về, hóa thân thành một thiên thần báo thù. Trong câu chuyện báo thù đầy kịch tính này, không ai có thể thoát khỏi hậu quả từ sự trả thù của cô.</p>","tmdb":{"type":"tv","id":"302636","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-08T13:10:34.000Z","cast":["Mu Le'en","Yu Yang","Kuang Xiaotong","Wang Ruizi","Xu Yingluo"],"director":[],"cast_meta":[{"name":"Mu Le'en","name_vi":null,"name_original":"Mu Le'en","tmdb_id":2359899,"profile":"https://image.tmdb.org/t/p/w500/fRfFU0VR6OBYgIQGypCGi7BoJ0N.jpg","tmdb_url":"https://www.themoviedb.org/person/2359899"},{"name":"Yu Yang","name_vi":null,"name_original":"Yu Yang","tmdb_id":4848582,"profile":"https://image.tmdb.org/t/p/w500/80SqmTaLlZmnXVUDO9vuAqFCnfW.jpg","tmdb_url":"https://www.themoviedb.org/person/4848582"},{"name":"Kuang Xiaotong","name_vi":null,"name_original":"Kuang Xiaotong","tmdb_id":3243718,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3243718"},{"name":"Wang Ruizi","name_vi":null,"name_original":"Wang Ruizi","tmdb_id":5096189,"profile":"https://image.tmdb.org/t/p/w500/soNCx3YHn1Whnxpl23SB4A1lmT6.jpg","tmdb_url":"https://www.themoviedb.org/person/5096189"},{"name":"Xu Yingluo","name_vi":null,"name_original":"Xu Yingluo","tmdb_id":3302216,"profile":"https://image.tmdb.org/t/p/w500/z47ZvMygzj47CJM3UHcZwrEUBI.jpg","tmdb_url":"https://www.themoviedb.org/person/3302216"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/th/thuong-xuan-son.json"}