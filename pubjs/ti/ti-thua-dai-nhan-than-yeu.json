:"15","filename":"TI THỪA ĐẠI NHÂN THÂN YÊU - Ep15","link_embed":"https://vip.opstream17.com/share/f12f2b34a0c3174269c19e21c07dee68","link_m3u8":"https://vip.opstream17.com/20240315/2642_6631a7ed/index.m3u8"},{"name":"16","slug":"16","filename":"TI THỪA ĐẠI NHÂN THÂN YÊU - Ep16","link_embed":"https://vip.opstream17.com/share/38181d991caac98be8fb2ecb8bd0f166","link_m3u8":"https://vip.opstream17.com/20240315/2643_d2535caf/index.m3u8"},{"name":"17","slug":"17","filename":"TI THỪA ĐẠI NHÂN THÂN YÊU - Ep17","link_embed":"https://vip.opstream17.com/share/f35a2bc72dfdc2aae569a0c7370bd7f5","link_m3u8":"https://vip.opstream17.com/20240315/2644_04571558/index.m3u8"},{"name":"18","slug":"18","filename":"TI THỪA ĐẠI NHÂN THÂN YÊU - Ep18","link_embed":"https://vip.opstream17.com/share/a7789ef88d599b8df86bbee632b2994d","link_m3u8":"https://vip.opstream17.com/20240315/2645_4e0ca01a/index.m3u8"},{"name":"19","slug":"19","filename":"TI THỪA ĐẠI NHÂN THÂN YÊU - Ep19","link_embed":"https://vip.opstream17.com/share/f2e43fa3400d826df4195a9ac70dca62","link_m3u8":"https://vip.opstream17.com/20240315/2646_0fcac535/index.m3u8"},{"name":"20","slug":"20","filename":"TI THỪA ĐẠI NHÂN THÂN YÊU - Ep20","link_embed":"https://vip.opstream17.com/share/0b7e926154c1274e8b602ff0d7c133d7","link_m3u8":"https://vip.opstream17.com/20240315/2647_35bcba07/index.m3u8"}]}],"time":"10 phút/tập","description":"<p>Mai Thập Thất là một cận vệ cấp dưới của Cục bảo vệ ẩn. Cô còn trẻ và phù phiếm, mục tiêu cuộc đời của cô là được quan chức tôn trọng, được thăng chức làm cận vệ đặc biệt, giành được một triệu đô la bạc và tìm được một người con rể đáp ứng tiêu chuẩn của cô. Tuy nhiên, do trình độ chuyên môn khá thấp nên cô chưa bao giờ tìm được cơ hội lập công, cũng chưa bao giờ gặp được người chồng đáp ứng yêu cầu và ngưỡng mộ cô. Người vợ lẽ yêu thích của Hoàng đế Ngư là Thần phi đột ngột qua đời, gây chấn động cả chính phủ và dư luận. Ông ra lệnh cho Ẩn Vệ vụ điều tra vụ án một cách bí mật. Bởi vì liên quan đến cung điện nên nam ám vệ gặp rất nhiều bất tiện. Mai Thập Thất đã dũng cảm tiến cử mình, ban hành lệnh quân sự sau khi làm việc chăm chỉ và cuối cùng đã nhận nhiệm vụ. Các sư huynh đều lắc đầu thở dài, lo lắng cô sẽ bị Lãnh Mặc Ngôn, thanh tra tàn nhẫn , lột da và xé xác thành từng mảnh.</p>","tmdb":{"type":"tv","id":"247660","season":1,"vote_average":0,"vote_count":0},"modified":"2025-03-14T11:19:19.000Z","cast":["Ma Haodong","Wang Xinting","Lưu Nhuận Minh","Su Zhenhua","Bi Shaoyan","Jiaru Wang","Ding Zien","Zhao Delong","Jiang Xinqi","Bo Chengjun"],"director":[],"cast_meta":[{"name":"Ma Haodong","name_vi":null,"name_original":"Ma Haodong","tmdb_id":2712874,"profile":"https://image.tmdb.org/t/p/w500/kRhYoyS8UowqdKp6lO33jBaQ5ON.jpg","tmdb_url":"https://www.themoviedb.org/person/2712874"},{"name":"Wang Xinting","name_vi":null,"name_original":"Wang Xinting","tmdb_id":2377111,"profile":"https://image.tmdb.org/t/p/w500/dbs1xDpCwDWEs37vjCf2rmLr9pO.jpg","tmdb_url":"https://www.themoviedb.org/person/2377111"},{"name":"Lưu Nhuận Minh","name_vi":"Lưu Nhuận Minh","name_original":"Liu Runming","tmdb_id":4813639,"profile":"https://image.tmdb.org/t/p/w500/dKA8QgzT2ZcjRN2kIGCrgEFZc3h.jpg","tmdb_url":"https://www.themoviedb.org/person/4813639"},{"name":"Su Zhenhua","name_vi":null,"name_original":"Su Zhenhua","tmdb_id":3379617,"profile":"https://image.tmdb.org/t/p/w500/7IjJDjAfwFpSHLNIs15QMY3fs0X.jpg","tmdb_url":"https://www.themoviedb.org/person/3379617"},{"name":"Bi Shaoyan","name_vi":null,"name_original":"Bi Shaoyan","tmdb_id":5139858,"profile":"https://image.tmdb.org/t/p/w500/vjV9DXLGqwpuSgTN1KE9kF6nWIm.jpg","tmdb_url":"https://www.themoviedb.org/person/5139858"},{"name":"Jiaru Wang","name_vi":null,"name_original":"Jiaru Wang","tmdb_id":2848688,"profile":"https://image.tmdb.org/t/p/w500/3zt8F4WKT1LYJ26z9DN4UCQo6kD.jpg","tmdb_url":"https://www.themoviedb.org/person/2848688"},{"name":"Ding Zien","name_vi":null,"name_original":"Ding Zien","tmdb_id":4868392,"profile":"https://image.tmd