{"id":"673dc7f096e9a5c7a67635f7","title":"Tiếc Nuối Của Hướng Bắc","origin_name":"Xiangbei Regret","slug":"tiec-nuoi-cua-huong-bac","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ti/tiec-nuoi-cua-huong-bac.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ti/tiec-nuoi-cua-huong-bac.webp","year":2024,"type":"series","genre":[{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Trailer","quality":"HD","is_4k":false,"is_exclusive":false,"status":"trailer","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"","slug":"","filename":"","link_embed":"","link_m3u8":""}]}],"time":"16 phút/tập","description":"Nhiếp ảnh gia tự do Mạc Hướng Bắc mang thai ngoài ý muốn khi sự nghiệp của bạn trai Mộ Dĩ Nam đang trên đà phát triển. Mạc Hướng Bắc hy vọng bạn trai có thể ở bên mình nhiều hơn, trong khi Mộ Dĩ Nam lại muốn tăng tốc công việc để tạo dựng tương lai tốt hơn cho bạn gái và đứa con sắp chào đời. Dần dần, cả hai bắt đầu có những xung đột nhỏ. Từ nhỏ vốn thiếu thốn tình yêu thương, Mạc Hướng Bắc trở nên nhạy cảm và đa nghi, cuối cùng bất ngờ sảy thai. Cô rời bỏ cuộc sống cùng Mộ Dĩ Nam trong đêm, đi đến Đại Lý và mở một quán trọ nhỏ tên là \"Nhà trọ Tiếc Nuối,\" bắt đầu hành trình cứu rỗi bản thân.","tmdb":{"type":"tv","id":"261833","season":1,"vote_average":8,"vote_count":2},"modified":"2024-12-14T10:21:27.000Z","cast":["Hạc Thu","Pang Hanchen","Lan Bo","Liu Xinlei"],"director":["曹国莉"],"cast_meta":[{"name":"Hạc Thu","name_vi":"Hạc Thu","name_original":"He Qiu","tmdb_id":4773380,"profile":"https://image.tmdb.org/t/p/w500/rRzBOsMr1TS5eJMUs4L4Omdp9T7.jpg","tmdb_url":"https://www.themoviedb.org/person/4773380"},{"name":"Pang Hanchen","name_vi":null,"name_original":"Pang Hanchen","tmdb_id":194496