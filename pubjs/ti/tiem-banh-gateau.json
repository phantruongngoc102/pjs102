ilename":"Tiệm Bánh Gateau (The Gateau Affairs) 14 2005","link_embed":"https://vip.opstream16.com/share/38079fb5e58a4ca17329d3eb9b309749","link_m3u8":"https://vip.opstream16.com/20250802/43824_38079fb5/index.m3u8"},{"name":"15","slug":"15","filename":"Tiệm Bánh Gateau (The Gateau Affairs) 15 2005","link_embed":"https://vip.opstream16.com/share/1a31856c66090c6d9dce2e1395d690ce","link_m3u8":"https://vip.opstream16.com/20250802/43825_1a31856c/index.m3u8"},{"name":"16","slug":"16","filename":"Tiệm Bánh Gateau (The Gateau Affairs) 16 2005","link_embed":"https://vip.opstream16.com/share/3969214cf75af11c1a013e4386787c54","link_m3u8":"https://vip.opstream16.com/20250802/43826_3969214c/index.m3u8"},{"name":"17","slug":"17","filename":"Tiệm Bánh Gateau (The Gateau Affairs) 17 2005","link_embed":"https://vip.opstream16.com/share/a2db3a7829a3d16e3735781ced544816","link_m3u8":"https://vip.opstream16.com/20250802/43827_a2db3a78/index.m3u8"},{"name":"18","slug":"18","filename":"Tiệm Bánh Gateau (The Gateau Affairs) 18 2005","link_embed":"https://vip.opstream16.com/share/e6483ae9e85b801c582ca117ecd16eb6","link_m3u8":"https://vip.opstream16.com/20250802/43828_e6483ae9/index.m3u8"},{"name":"19","slug":"19","filename":"Tiệm Bánh Gateau (The Gateau Affairs) 19 2005","link_embed":"https://vip.opstream16.com/share/fedc1c02505c1330544af28c1abe2528","link_m3u8":"https://vip.opstream16.com/20250802/43829_fedc1c02/index.m3u8"},{"name":"20","slug":"20","filename":"Tiệm Bánh Gateau (The Gateau Affairs) 20 2005","link_embed":"https://vip.opstream16.com/share/95e00030b8bd03e7c44548a60263ee6d","link_m3u8":"https://vip.opstream16.com/20250802/43830_95e00030/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Ko Gan là một thợ làm bánh tài năng. Vì quá đam mê làm bánh mà anh bỏ bê gia đình, khiến vợ và con trai rời xa anh. Trong lúc vội vã ra sân bay gặp vợ con, Ko Gan gặp tai nạn xe hơi và bị cảnh sát bắt giữ khi anh nói dối về việc chiếc bánh là bom của con trai để có thể đến sân bay đúng giờ. Hai năm sau, Ko Gan được thả ra khỏi tù và một lần nữa quay lại kinh doanh bánh ngọt, trở thành bếp trưởng tại Gateaux, một tiệm bánh do Sabayung làm chủ. Ko Gan lạnh lùng và nghiêm khắc với nhân viên, đồng thời phải đối mặt với đủ loại khó khăn trong việc tạo ra những chiếc bánh mới và các cuộc thi từ các thợ làm bánh trên khắp thế giới; chưa kể đến việc gặp gỡ một cô gái nóng tính, Tong Sheung, người có niềm đam mê làm bánh. Từ cô, anh học được nhiều điều mới mẻ cũng như khi ở bên cô, Ko Gun trở nên dịu dàng hơn. Nhưng có một điều gì đó to lớn cản trở mối quan hệ của họ khiến mối quan hệ của họ lung lay... và điều đó có liên quan đến Kuk Kei.</p>","tmdb":{"type":"tv","id":"5377","season":1,"vote_average":6,"vote_count":1},"modified":"2025-08-02T17:00:57.000Z","cast":["Joe Ma Tak-Chung","Hồ Hạnh Nhi","Jack Wu","Bobo Chan Man-Yuen","Văn Tụng Nhàn","Lưu Gia Huy","Teresa Lee Fung","Lư Hải Bằng","Gregory Charles Rivers","Wong Ching","La Quân Tả"],"director":[],"cast_meta":[{"name":"Joe Ma Tak-Chung","name_vi":null,"name_original":"Joe Ma Tak-Chung","tmdb_id":227805,"profile":"https://image.tmdb.org/t/p/w500/oK0d0kFPwSNKtlcBNbDqt6ExVYa.jpg","tmdb_url":"https://www.themoviedb.org/person/227805"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/938251"},{"name":"Jack Wu","name_vi":null,"name_original":"Jack Wu","tmdb_id":1222315,"profile":"https://image.tmdb.org/t/p/w500/8q1QdqHHQxzVFGuProbEgkP1qnh.jpg","tmdb_url":"https://www.themoviedb.org/person/1222315"},{"name":"Bobo Chan Man-Yuen","name_vi":null,"name_original":"Bobo Chan Man-Yuen","tmdb_id":231746,"profile":"https://image.tmdb.org/t/p/w500/1btAOqLglhftmxAPTulhMKotioj.jpg","tmdb_url":"https://www.themoviedb.org/person/231746"},{"name":"Văn Tụng Nhàn","name_vi":"Văn Tụng Nhàn","name_original":"Annie Man Chung-Han","tmdb_id":125103,"profile":"http