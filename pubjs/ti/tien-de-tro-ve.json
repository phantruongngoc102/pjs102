3u8"},{"name":"2","slug":"2","link_embed":"https://vip.opstream90.com/share/8485694bae96aebc7c4fe6119599d0e0","link_m3u8":"https://vip.opstream90.com/20251029/16429_8485694b/index.m3u8"},{"name":"3","slug":"3","link_embed":"https://vip.opstream90.com/share/7fe61f156a674de0eb34eee36d98f68e","link_m3u8":"https://vip.opstream90.com/20251029/16430_7fe61f15/index.m3u8"}]}],"description":"<p>Thực lực vi tôn, nhưng khi không còn thực lực nào nữa thì tự nhiên mọi bi kịch cứ vậy mà ập đến, đó cũng là điều dĩ nhiên xảy đến khi mà con người ta không còn sức mạnh để khẳng định lời nói và sức mạnh nữa. Đó cũng là đôi nét sơ qua về câu chuyện Tiên Đế Trở Về, với anh chàng Vân Thanh Nham đầy thú vị. Xuất phát là một người dân hết sức bình thường, chẳng qua là mang trong mình một chút thiên phú mà đã vô tình bị cuốn đến thế giới khác gọi là Tiên Giới. Tại đó, Vân Thanh Nham trở thành một trong 10 vị Tiên Đế lừng danh, sống một cuộc sống an nhàn đến phát chán, thêm với những điều phiền muộn của nơi đây và nỗi nhớ nhà không nguôi, sau 3000 năm dài đằng đẵng thì anh đã quyết định quay trở lại nhân gian, tìm lại gia đình và người thân của mình. Nhưng trên đường xuyên không trở về, vô vàn gian khó cứ luôn xảy đến, rồi lại bị đuổi đánh dữ dội, những tu vi và thần khí của Vân Thanh Nham bỗng chốc trở về con số 0.</p>","tmdb_id":303881,"cast":["Yang Chaoran","Li Chanfei","静宸","黄进泽","Gao Sihang","Zhu Hongxi","Bingtian Wang"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"303881","season":1,"vote_average":9,"vote_count":2},"cast_meta":[{"name":"Yang Chaoran","name_vi":null,"name_original":"Yang Chaoran","tmdb_id":3900472,"profile":"https://image.tmdb.org/t/p/w500/glEpdVtAhmL6VRAEHxpjHSlCbHZ.jpg","tmdb_url":"https://www.themoviedb.org/person/3900472"},{"name":"Li Chanfei","name_vi":null,"name_original":"Li Chanfei","tmdb_id":3718828,"profile":"https://image.tmdb.org/t/p/w500/9lPXNOqWemS1gilUTsRQcyG8wnX.jpg","tmdb_url":"https://www.themoviedb.org/person/3718828"},{"name":"静宸","name_vi":