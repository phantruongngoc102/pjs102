":"33","filename":"Tiên Kiếm Kỳ Hiệp - Tập 33","link_embed":"https://vip.opstream11.com/share/3846f5ae211da371800d278073470dd0","link_m3u8":"https://vip.opstream11.com/20220731/35413_a6413ef0/index.m3u8"},{"name":"34","slug":"34","filename":"Tiên Kiếm Kỳ Hiệp - Tập 34","link_embed":"https://vip.opstream11.com/share/5a432ca05467666d90425b7b869c5003","link_m3u8":"https://vip.opstream11.com/20220731/35414_ad20e0cc/index.m3u8"},{"name":"35","slug":"35","filename":"Tiên Kiếm Kỳ Hiệp - Tập 35","link_embed":"https://vip.opstream11.com/share/eec278b875a784c7646e2a27648819d5","link_m3u8":"https://vip.opstream11.com/20220731/35415_3564159d/index.m3u8"},{"name":"36","slug":"36","filename":"Tiên Kiếm Kỳ Hiệp - Tập 36","link_embed":"https://vip.opstream11.com/share/447f51ef2d069e87d21382789ccab1e6","link_m3u8":"https://vip.opstream11.com/20220731/35416_c456bcae/index.m3u8"},{"name":"37","slug":"37","filename":"Tiên Kiếm Kỳ Hiệp - Tập 37","link_embed":"https://vip.opstream11.com/share/ae618c0a3cb67308d7299886a7add4b6","link_m3u8":"https://vip.opstream11.com/20220731/35417_fcb2f6f1/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>18 năm trước, người trông coi Thần Thụ là tiên nữ Tịch Dao dịu dàng, nhu mì, vốn là tri kỷ của Phi Bồng, vì muốn tiếp tục chăm sóc Phi Bồng ở trần thế nên đã gửi gắm ước nguyện vào Thánh Quả tạo thành một đứa bé gái xuất hiện chốn nhân gian. Đứa bé này được Đường chủ của Đường Môn nhận làm cháu gái và đặt tên là Tuyết Kiến, trở thành Đường gia đại tiểu thư nghịch ngợm, nhí nhảnh. Phi Bồng sau nhiều kiếp luân hồi đã đầu thai thành con của ông chủ tiệm đồ của Vĩnh An Đường, lúc này vừa được 1 tuổi, tên là Cảnh Thiên. Phim bắt đầu khi Cảnh Thiên đã trở thành một chàng trai 19 tuổi làm thuê ở cửa hiệu đồ cổ Vĩnh An, thành Dương Châu. Anh bị cuốn vào cuộc tranh chấp trong nội bộ Đường gia, rồi cuộc chiến giữa Đường Môn với Tích Lịch Đường. Không chỉ vậy, vì là chuyển thế của thần tướng Phi Bồng, anh được 5 vị trưởng lão phái Thục Sơn giao cho một nhiệm vụ mang chiếc hộp chứa kết tinh Tà Niệm của năm người lên Thần Giới, bỏ vào Thiên Trì để gột sạch tội lỗi. Trên đường làm nhiệm vụ, anh được sự giúp đỡ của Hậu Nhân Nữ Oa - Tử Huyên. Tất cả cùng trải qua nhiều cuộc phiêu lưu: tìm kiếm Ngũ Linh Châu, đối phó với Tà Kiếm Tiên.</p>","tmdb":{"type":"tv","id":"33823","season":1,"vote_average":7.9,"vote_count":42},"modified":"2022-08-01T05:29:43.000Z","cast":["Hu Ge","Dương Mịch","Hoắc Kiến Hoa","Lưu Thi Thi","Đường Yên","Lam Tze-Chung","Quách Hiểu Đình","Lưu Gia Huy","Jerry Huang","Yuan Hong","Dong Ziwu","Nhạc Dược Lợi","He Yanni","韩晓","Liu Xiaojie"],"director":["Lý Quốc Lập"],"cast_meta":[{"name":"Hu Ge","name_vi":null,"name_original":"Hu Ge","tmdb_id":1106514,"profile":"https://image.tmdb.org/t/p/w500/yMDKxcljmEFhxSGk3oeW3sl2YKu.jpg","tmdb_url":"https://www.themoviedb.org/person/1106514"},{"name":"Dương Mịch","name_vi":"Dương Mịch","name_original":"Yang Mi","tmdb_id":572043,"profile":"https://image.tmdb.org/t/p/w500/lPQ9RgOj5hY5AYRJ8G1CedjdCGz.jpg","tmdb_url":"https://www.themoviedb.org/person/572043"},{"name":"Hoắc Kiến Hoa","name_vi":"Hoắc Kiến Hoa","name_original":"Wallace Huo","tmdb_id":1192904,"profile":"https://image.tmdb.org/t/p/w500/kiuLPAKlIT98fgjuwnYF9u6Wus7.jpg","tmdb_url":"https://www.themoviedb.org/person/1192904"},{"name":"Lưu Thi Thi","name_vi":"Lưu Thi Thi","name_original":"Liu Shishi","tmdb_id":1185786,"profile":"https://image.tmdb.org/t/p/w500/yPyMTroHKKpK2g24o7920erAa3L.jpg","tmdb_url":"https://www.themoviedb.org/person/1185786"},{"name":"Đường Yên","name_vi":"Đường Yên","name_original":"Tang Yan","tmdb_id":99691,"profile":"https://image.tmdb.org/t/p/w500/eW3F16Namf5EoCmeWaTdkd3ncoH.jpg","tmdb_url":"https://www.themoviedb.org/person/99691"},{"name":"Lam Tze-Chung","name_vi":null,"name_original":"Lam Tze-Chung","tmdb_id":545277,"profile":"https://image.tmdb.org/t/p/w500/4lA8TnRYSZBysNvZLMdNe1UoIK9.jpg","tmdb_url":"https://www.themoviedb.org/person/545277"},{"name":"Quách Hiểu Đình","name_vi":"Quách Hiể