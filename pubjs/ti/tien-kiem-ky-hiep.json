3u8":"https://vip.opstream14.com/20221004/23114_86d0efad/index.m3u8"},{"name":"31","slug":"31","filename":"Tiên Kiếm Kỳ Hiệp - Chinese Paladin - Tập 31","link_embed":"https://vip.opstream14.com/share/693ba0757b77ceb996e90c00431d9ebc","link_m3u8":"https://vip.opstream14.com/20221004/23116_964d33cd/index.m3u8"},{"name":"32","slug":"32","filename":"Tiên Kiếm Kỳ Hiệp - Chinese Paladin - Tập 32","link_embed":"https://vip.opstream14.com/share/8a29a411e91931b2c009daf000f9ed7d","link_m3u8":"https://vip.opstream14.com/20221004/23115_bbc45e01/index.m3u8"},{"name":"33","slug":"33","filename":"Tiên Kiếm Kỳ Hiệp - Chinese Paladin - Tập 33","link_embed":"https://vip.opstream14.com/share/c56491fecc8c073d6c811b69a3ab6539","link_m3u8":"https://vip.opstream14.com/20221004/23117_4878bd47/index.m3u8"},{"name":"34","slug":"34","filename":"Tiên Kiếm Kỳ Hiệp - Chinese Paladin - Tập 34","link_embed":"https://vip.opstream14.com/share/7d7733c8d01b7352aab3990d99d89d8e","link_m3u8":"https://vip.opstream14.com/20221004/23118_01f6cb7c/index.m3u8"}]}],"time":"46phút/tập","description":"<p>18 năm trước, người trông coi Thần Thụ là tiên nữ Tịch Dao dịu dàng, nhu mì, vốn là tri kỷ của Phi Bồng, vì muốn tiếp tục chăm sóc Phi Bồng ở trần thế nên đã gửi gắm ước nguyện vào Thánh Quả tạo thành một đứa bé gái xuất hiện chốn nhân gian. Đứa bé này được Đường chủ của Đường Môn nhận làm cháu gái và đặt tên là Tuyết Kiến, trở thành Đường gia đại tiểu thư nghịch ngợm, nhí nhảnh. Phi Bồng sau nhiều kiếp luân hồi đã đầu thai thành con của ông chủ tiệm đồ của Vĩnh An Đường, lúc này vừa được 1 tuổi, tên là Cảnh Thiên. Phim bắt đầu khi Cảnh Thiên đã trở thành một chàng trai 19 tuổi làm thuê ở cửa hiệu đồ cổ Vĩnh An, thành Dương Châu. Anh bị cuốn vào cuộc tranh chấp trong nội bộ Đường gia, rồi cuộc chiến giữa Đường Môn với Tích Lịch Đường. Không chỉ vậy, vì là chuyển thế của thần tướng Phi Bồng, anh được 5 vị trưởng lão phái Thục Sơn giao cho một nhiệm vụ mang chiếc hộp chứa kết tinh Tà Niệm của năm người lên Thần Giới, bỏ vào Thiên Trì để gột sạch tội lỗi. Trên đường làm nhiệm vụ, anh được sự giúp đỡ của Hậu Nhân Nữ Oa - Tử Huyên. Tất cả cùng trải qua nhiều cuộc phiêu lưu: tìm kiếm Ngũ Linh Châu, đối phó với Tà Kiếm Tiên.</p>","tmdb":{"type":"tv","id":"8757","season":1,"vote_average":8,"vote_count":48},"modified":"2022-10-04T10:57:45.000Z","cast":["Hu Ge","Lưu Diệc Phi","An Dĩ Hiên","Bành Vu Yến","Esther Liu","Limin Deng","Tưởng Hân","Từ Cẩm Giang","Bryan Wong","Tạ Quân Hào","Yang Kun","Wang Lei"],"director":["Lý Quốc Lập"],"cast_meta":[{"name":"Hu Ge","name_vi":null,"name_original":"Hu Ge","tmdb_id":1106514,"profile":"https://image.tmdb.org/t/p/w500/yMDKxcljmEFhxSGk3oeW3sl2YKu.jpg","tmdb_url":"https://www.themoviedb.org/person/1106514"},{"name":"Lưu Diệc Phi","name_vi":"Lưu Diệc Phi","name_original":"Liu Yifei","tmdb_id":122503,"profile":"https://image.tmdb.org/t/p/w500/lucEre1rrypvclDkO4nFDKY1O9A.jpg","tmdb_url":"https://www.themoviedb.org/person/122503"},{"name":"An Dĩ Hiên","name_vi":"An Dĩ Hiên","name_original":"Ady An","tmdb_id":1241442,"profile":"https://image.tmdb.org/t/p/w500/xmPVIj1Vtzltq0KNNWx0LvMlvdo.jpg","tmdb_url":"https://www.themoviedb.org/person/1241442"},{"name":"Bành Vu Yến","name_vi":"Bành Vu Yến","name_original":"Eddie Peng Yu-Yan","tmdb_id":126778,"profile":"https://image.tmdb.org/t/p/w500/gIiEFUVbGRwrLKUURxU67ShJ00o.jpg","tmdb_url":"https://www.themoviedb.org/person/126778"},{"name":"Esther Liu","name_vi":null,"name_original":"Esther Liu","tmdb_id":1241444,"profile":"https://image.tmdb.org/t/p/w500/dZWLoOK2XNpwU5U8oA3JEmdjLQS.jpg","tmdb_url":"https://www.themoviedb.org/person/1241444"},{"name":"Limin Deng","name_vi":null,"name_original":"Limin Deng","tmdb_id":1436153,"profile":"https://image.tmdb.org/t/p/w500/BP2VOf7z6siJ3047ZyMSnWG5Oq.jpg","tmdb_url":"https://www.themoviedb.org/person/1436153"},{"name":"Tưởng Hân","name_vi":"Tưởng Hân","name_original":"Jiang Xin","tmdb_id":1241445,"profile":"https://image.tmdb.org/t/p/w500/jwUQ7B22K0rlRtAMegnkMR2O2t5.jp