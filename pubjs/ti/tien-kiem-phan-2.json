opstream11.com/share/95989e5332126090c9b8e355c523fa77","link_m3u8":"https://vip.opstream11.com/20241103/56390_95989e53/index.m3u8"},{"name":"74","slug":"74","link_embed":"https://vip.opstream11.com/share/495cf49584a3537d41f8bc54350b97ba","link_m3u8":"https://vip.opstream11.com/20241103/56381_495cf495/index.m3u8"},{"name":"75","slug":"75","link_embed":"https://vip.opstream11.com/share/141290bf85e8828275ca2c4fe4c48bb9","link_m3u8":"https://vip.opstream11.com/20241103/56403_141290bf/index.m3u8"}]}],"description":"<p>Nhân Gian Hữu Ái - A Happy Life 2 kể về chuyện tình của Lưu Tứ Hỉ và Cửu Muội. Tuyết Nghiên Đường là một cửa hàng phấn son nổi tiếng, nhưng thực ra gia đình Lưu thị có truyền thống bắt yêu, trong đó hồ tộc là kẻ thù không đội trời chung. Bố mẹ Lưu Tứ Hỉ vì mong con trai luyện thành THẦN công để nối dõi sự nghiệp gia tộc mà từ nhỏ đã bắt anh uống NGƯNG THẦN HOÀN (thuốc trở thành thần), và luôn ngăn cản anh có tình cảm với bất kỳ người con gái nào. Tứ Hỉ có một em gái và một thanh mai trúc mã (Vương Kim Châu). Kim Châu si tình Tứ Hỉ,Tứ Hỉ lại thích Cửu Muội, nhưng Cửu muội lại rất ghét những công tử nhà giàu chỉ biết khua môi múa mép. Vì cơ duyên mà Tứ Hỉ lấy Cửu muội (đám cưới giả)...suốt thời gian đầu một mình Cửu muội đối đầu với mẹ chồng, em chồng và tình địch Kim Châu. Tứ Hỉ vì uống Ngưng Thần Hoàn quá nhiều mà bị độc phát, nguy hiểm đến tính mạng, khi ấy Cửu Muội mới nhận ra tình cảm thật trong lòng mình. Từ đó tình cảm của cả hai đối với nhau cũng có những chuyển biến, và sau khi trải qua trùng trùng phong ba, bão táp, cả hai được sống bên nhau hạnh phúc.</p>","tmdb_id":214190,"cast":["Trần Hạo Dân","Monica Mu","Trần Tử Hàm"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"214190","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trần Hạo Dân","name_vi":"Trần Hạo Dân","name_original":"Benny Chan Ho-Man","tmdb_id":1314817,"profile":"https://image.tmdb.org/t/p/w500/cGNOprzxJntHcg6db0HZOdyCZX8.jpg","tmdb_url":"https://www.themoviedb.org/person/1314817"},{"name":"Monica Mu","name_vi":null,"name_original":"Monica Mu","tmdb_id":2412208,"profile":"https://image.tmdb.org/t/p/w500/3a5SiYK37J9fQ9YzIv0Mgd8jls6.jpg","tmdb_url":"https://www.themoviedb.org/person/2412208"},{"name":"Trần Tử Hàm","name_vi":"Trần Tử Hàm","name_original":"Chen Zihan","tmdb_id":593166,"profile":"https://image.tmdb.org/t/p/w500/xItbxt0SQa6FlA4w0rrlDRH0ghY.jpg","tmdb_url":"https://www.themoviedb.org/person/593166"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tien-kiem-phan-2.json"}