nghiệm, Vân Phàm thành công bái nhập làm đệ tử Thục Sơn, chăm chỉ luyện tập, tiến bộ thần tốc. Tuy nhiên do vẫn mặc cảm vì xuất thân của mình, Vân Phàm không dám đáp trả tình cảm của Vũ Nhu.</p>","tmdb":{"type":"tv","id":"74763","season":1,"vote_average":8,"vote_count":1},"modified":"2022-09-28T12:21:42.000Z","cast":["Geng Le","Hàn Đông Quân","Kim Thần","Cổ Lực Na Trát","Joe Cheng","Limin Deng","Jerry Wu","Li Yuan","Lưu Nhã Sắt"],"director":["Lý Quốc Lập","Trịnh Vỹ Văn"],"cast_meta":[{"name":"Geng Le","name_vi":null,"name_original":"Geng Le","tmdb_id":1170661,"profile":"https://image.tmdb.org/t/p/w500/tyqtorVkTRu1ZFQsnEccwMZEf4Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1170661"},{"name":"Hàn Đông Quân","name_vi":"Hàn Đông Quân","name_original":"Elvis Han","tmdb_id":1541647,"profile":"https://image.tmdb.org/t/p/w500/r3b5X3gHqHStLnBcs51L7QqraKp.jpg","tmdb_url":"https://www.themoviedb.org/person/1541647"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Cổ Lực Na Trát","name_vi":"Cổ Lực Na Trát","name_original":"Gulnezer Bextiyar","tmdb_id":1291460,"profile":"https://image.tmdb.org/t/p/w500/9HZkWl3glcA56J1rWlMU1TKh71q.jpg","tmdb_url":"https://www.themoviedb.org/person/1291460"},{"name":"Joe Cheng","name_vi":null,"name_original":"Joe Cheng","tmdb_id":1245708,"profile":"https://image.tmdb.org/t/p/w500/u8jmKnYs3TNoF4uRzQpXxlW4uTL.jpg","tmdb_url":"https://www.themoviedb.org/person/1245708"},{"name":"Limin Deng","name_vi":null,"name_original":"Limin Deng","tmdb_id":1436153,"profile":"https://image.tmdb.org/t/p/w500/BP2VOf7z6siJ3047ZyMSnWG5Oq.jpg","tmdb_url":"https://www.themoviedb.org/person/1436153"},{"name":"Jerry Wu","name_vi":null,"name_original":"Jerry Wu","tmdb_id":1044684,"profile":"https://image.tmdb.org/t/p/w500/w0DUDusyAhfvcvGkLtA9Ls9KuLD.jpg","tmdb_url":"https://www.themoviedb.or