31444_2d7ef352/index.m3u8"},{"name":"12","slug":"12","filename":"TVB Tiền Là Tất Cả 15⧸20 ｜ tiếng Việt ｜ Âu Dương Chấn Hoa, Trần Diệu Anh, Quách Tấn An ｜ TVB 1996","link_embed":"https://vip.opstream14.com/share/82d584b97651cd1b10ae553c61803c61","link_m3u8":"https://vip.opstream14.com/20230214/31445_1385eda2/index.m3u8"},{"name":"13","slug":"13","filename":"TVB Tiền Là Tất Cả 16⧸20 ｜ tiếng Việt ｜ Âu Dương Chấn Hoa, Trần Diệu Anh, Quách Tấn An ｜ TVB 1996","link_embed":"https://vip.opstream14.com/share/70fc8a17ae8984aaa705b62f3e9ef2df","link_m3u8":"https://vip.opstream14.com/20230214/31446_36d8df0f/index.m3u8"},{"name":"14","slug":"14","filename":"TVB Tiền Là Tất Cả 20⧸20 ｜ tiếng Việt ｜ Âu Dương Chấn Hoa, Trần Diệu Anh, Quách Tấn An ｜ TVB 1996","link_embed":"https://vip.opstream14.com/share/be1fe5a4cbad9fd763db5aaedf0ec611","link_m3u8":"https://vip.opstream14.com/20230214/31447_c91ea188/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Trong khi Thần Tài luôn cho rằng dưới trần gian tiền của là vạn năng, còn Ông Thọ lại cho rằng tình cảm là điều thiết yếu nên đã tranh cãi dẫn đến quyết định cá cược với nhau. Thần Tài chọn người trần Dương Dậu Tựu và buộc anh ta thay đổi cách sống cũng như thuần phục sức mạnh của đồng tiền. Thần Tài hóa thân thành người trần, lấy tên là Dương Tế Tài. Lắm tiền của, Tài ra sức dụ Dương Dậu Tựu nhưng vô dụng bởi anh này là người ngay thẳng, an phận nên không hề bị chao đảo hay choáng ngợp trước sức mạnh của đồng tiền.</p>","tmdb":{"type":"tv","id":"98283","season":1,"vote_average":6,"vote_count":1},"modified":"2023-02-14T16:39:56.000Z","cast":["Âu Dương Chấn Hoa","Quách Tấn An","Trần Diệu Anh","Natalie Wong Kei-Ying","Đằng Lệ Danh","Hilary Tsui Ho-Ying","Leung Wing-Lam","Cho Chai","Emotion Cheung Kam-Ching","Pak Yan","Tang Yuk-Wing","Danny Summer","Ling Hon","Chan Dik-Hak","Lee Kuei-Ying"],"director":["Tiêu Hiển Huy"],"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb