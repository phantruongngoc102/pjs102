220303/2530_1f576149/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/217c0e01c1828e7279051f1b6675745d","link_m3u8":"https://vip.opstream12.com/20220303/2531_65c0a13c/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/9824f9c1543628a85bb51d2dd6fcf8a3","link_m3u8":"https://vip.opstream12.com/20220303/2532_f1b408a6/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream12.com/share/4de754248c196c85ee4fbdcee89179bd","link_m3u8":"https://vip.opstream12.com/20220303/2533_0f286c2e/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream12.com/share/7827d1ec626c891d4b61a15c9dff296e","link_m3u8":"https://vip.opstream12.com/20220303/2534_8234dbdd/index.m3u8"}]}],"description":"<p>Tiên Nữ Cử Tạ - Weightlifting Fairy lấy cảm hứng từ câu chuyện có thật của nữ vận động viên cử tạ giành huy chương vàng Olympics Jang Mi Ran. Bộ phim xoay quanh Kim Bok Joo (Lee Sung Kyung), một cô gái trẻ luôn đấu tranh cho lẽ phải và chống lại sự bất công. Ẩn sau vẻ ngoài lực lưỡng của một vận động viên cử tạ là một Kim Bok Joo với trái tim mỏng manh dễ vỡ. Jung Joon Hyung (Nam Joo Hyuk), một thiên tài bơi lội, bạn cùng lớp đại học với Kim Bok Joo - Là một chàng trai có tính cách mạnh mẽ và đầy hoài bão, song Jung Joon Hyung lại bị một tai nạn trong quá khứ kìm hãm năng lực. Mối quan hệ giữa anh và Kim Bok Joo tương đối phức tạp và thường xuyên xảy ra xung đột, nhưng có lẽ vì thế mà hút nhau.</p>","tmdb_id":68349,"cast":[],"director":[],"keywords":[],"tmdb":{"id":68349},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ti/tien-nu-cu-ta.json"}