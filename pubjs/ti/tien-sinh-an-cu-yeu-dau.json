f6e7ca78e8f7","link_m3u8":"https://vip.opstream11.com/20230913/47141_141ba276/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/702c7c3c2936d1b5a651c1cd184b2e7f","link_m3u8":"https://vip.opstream11.com/20230914/47200_926c7b5b/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/4434510da6f777ce53a98936d874b600","link_m3u8":"https://vip.opstream11.com/20230914/47199_61df240d/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/77b72cfe26c89df8636dfd51ec85ed95","link_m3u8":"https://vip.opstream11.com/20230918/47464_c325c1d3/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/4bf9decb991cfa0ff9d26f47f2e807b9","link_m3u8":"https://vip.opstream11.com/20230919/47485_d3a8a0af/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream11.com/share/97c94ae691105989d42fdbb5d4f17e3e","link_m3u8":"https://vip.opstream11.com/20230919/47484_b5478bcc/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream11.com/share/b2e6e837143d63daca07f522905f79a9","link_m3u8":"https://vip.opstream11.com/20230920/47501_b8e13ede/index.m3u8"}]}],"description":"<p>Tiên Sinh Ẩn Cư Yêu Dấu (Dear Mr Hermitage) là một bộ phim đầy cảm xúc về mất mát, tình yêu và sự trưởng thành. Bộ phim tập trung vào nhân vật chính Tô Thời Vũ, một blogger ẩm thực không tên tuổi bị cộng sự phản bội và mất hết công trình mà cô đã dày công xây dựng trong nhiều tháng. Tuy nhiên, cô không thể ngồi trong đau đớn và buồn bã mà phải chấp nhận một nhiệm vụ ngớ ngẩn từ Lâm Hiếu Kiện, chủ tịch của Tập đoàn Cà Phê Hảo Vị.</p><p>Trước yêu cầu của ông, Tô Thời Vũ cần thuyết phục con trai của ông là Lâm Vị từ bỏ việc tu hành trên núi để quay trở lại và tiếp quản tập đoàn. Tô Thời Vũ tin rằng cô có thể sử dụng khả năng giao tiếp của mình để hoàn thành nhiệm vụ này, nhưng thực tế không hề dễ dàng như vậy. Cô liên tục bị xúc phạm và hắt hủi và không biết phải làm sao để khuyên Lâm Vị, đồng thời cảm thấy bất lực trước bức tường vô hình này.</p><p>Qua cuộc hành trình này, Tô Thời Vũ gradually học được cách sống một cách độc lập thực sự. Đồng thời, cô ngẫu nhiên tiếp cận với cuộc sống của Lâm Vị và từ đó, hai con người từ hai thế giới khác nhau đã bỏ qua tất cả để đến với nhau.</p><p>Tuy nhiên, một biến cố đã làm hiện ra vết thương lòng cũ của Lâm Vị và anh buộc phải đối mặt với câu hỏi đau đớn về lương tâm: liệu kẻ đã lạc lối như anh có tư cách được hạnh phúc hay không?</p>","tmdb_id":233764,"cast":["Tang Min","Trần Tĩnh Khả","Jerron Wu","Peggy Ji","Wang Cong"],"director":["Chen Shi Yi"],"keywords":[],"tmdb":{"type":"tv","id":"233764","season":1,"vote_average":8.2,"vote_count":4},"cast_meta":[{"name":"Tang Min","name_vi":null,"name_original":"Tang Min","tmdb_id":2461692,"profile":"https://image.tmdb.org/t/p/w500/p3z0UoSZ4uQRAq9KDRNe0vphuID.jpg","tmdb_url":"https://www.themoviedb.org/person/2461692"},{"name":"Trần Tĩnh Khả","name_vi":"Trần Tĩnh Khả","name_original":"Chen Jingke","tmdb_id":2682101,"profile":"https://image.tmdb.org/t/p/w500/yqGeMSEZVJlxAvh9k6JFo6jhrUT.jpg","tmdb_url":"https://www.themoviedb.org/person/2682101"},{"name":"Jerron Wu","name_vi":null,"name_original":"Jerron Wu","tmdb_id":3362027,"profile":"https://image.tmdb.org/t/p/w500/A006tf0uJWMSD7mjdqUdDqCD3L6.jpg","tmdb_url":"https://www.themoviedb.org/person/3362027"},{"name":"Peggy Ji","name_vi":null,"name_original":"Peggy Ji","tmdb_id":4050663,"profile":"https://image.tmdb.org/t/p/w500/fbTC1wzaEF44h1NNyr8rpNXow6r.jpg","tmdb_url":"https://www.themoviedb.org/person/4050663"},{"name":"Wang Cong","name_vi":null,"name_original":"Wang Cong","tmdb_id":2735121,"profile":"https://image.tmdb.org/t/p/w500/g6ccKgO63zHOJqfkvvR7QuOPJCG.jpg","tmdb_url":"https://www.themoviedb.org/person/2735121"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tien-sinh-an-cu-yeu-dau.json"}