m/20220512/13647_cdb5d8d7/index.m3u8"}]}],"time":"","description":"<p>Thiên tài bơi lội Bạch Vịnh Trạch lớn lên trong một gia đình bình thường, cùng với Tống Trà Trà là tiểu thư có gia cảnh sa sút trở thành 1 đôi oan gia. Lam Thiên là bạn thân của Bạch Vịnh Trạch bởi vì một bí mật mà phải chia tay vị hôn thê của mình là Tống Trà Trà. Chính vì thế, trong sự nghiệp, tình yêu, đối mặt với tình cảm, Bạch Vịnh Trạch và Lam Thiên từ bạn bè thân thiết trở thành đối thủ cạnh tranh</p>","tmdb":{"type":"tv","id":"82951","season":1,"vote_average":7.5,"vote_count":2},"modified":"2022-05-12T16:12:57.000Z","cast":["Cúc Tịnh Y","Hoàng Hinh Dao"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Cúc Tịnh Y","name_vi":null,"name_original":"Cúc Tịnh Y"},{"name":"Hoàng Hinh Dao","name_vi":null,"name_original":"Hoàng Hinh Dao"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ti/tien-sinh-boi-loi.json"}