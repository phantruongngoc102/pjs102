352_119804f3/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream14.com/share/6a12f449790ed7be96d77aa4c7d9c1c1","link_m3u8":"https://vip.opstream14.com/20230205/30353_586affea/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/5231f53ee04409d2d652039077794382","link_m3u8":"https://vip.opstream14.com/20230205/30354_478fb9e0/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/e35ca2aa785ca87355449938e1450f9b","link_m3u8":"https://vip.opstream14.com/20230205/30355_c18adb9e/index.m3u8"}]}],"description":"<p>Một người đàn ông tên là Giang Hải Tuyền - anh ta làm việc trong một trung tâm chuyên môi giới hôn nhân. Diệu Linh - một người con gái thất bại trong tình yêu và rồi Hải Tuyền gặp Diệu Linh, anh ta cố gắng xoa dịu nỗi đau cho Diệu Linh, rồi hai người yêu nhau và&nbsp;đi đến hôn nhân sau nửa năm gắn bó. Nhưng sau đó hạnh phúc chưa bao lâu thì Hải Tuyền biết được vợ mình qua lại với người tình cũ năm xưa đã phụ bạc cô. Hải Tuyền đòi ly hôn, nhưng Diệu Linh vẫn khăng khăng không chịu đi nơi khác vì thế Hải Tuyền đã đưa một người phụ nữ khác vào nhà sống chung để chiến đấu đến cùng với vợ mình. Cả ba người ở cùng chung một mái nhà, tình cảm của Hải Tuyền giờ đã dành cho cả hai người, anh không biết phải giải quyết thế nào, tiến không được mà lùi cũng không xong...</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ti/tien-thoai-luong-nan-tvb.json"}