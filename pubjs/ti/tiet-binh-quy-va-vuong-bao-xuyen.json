5752_330d805f/index.m3u8"},{"name":"51","slug":"51","link_embed":"https://vip.opstream17.com/share/507cefd45103934642e8584a58e5e10e","link_m3u8":"https://vip.opstream17.com/20240726/15753_23c4c424/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream17.com/share/5b6197f0d9457592cc439fce42933ebb","link_m3u8":"https://vip.opstream17.com/20240726/15754_8f48f97e/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream17.com/share/aec3e4a8bf7a9a78686f7973d4c848b1","link_m3u8":"https://vip.opstream17.com/20240726/15755_08e96c5c/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream17.com/share/f9dc4851e9b5048656736369d10d6b97","link_m3u8":"https://vip.opstream17.com/20240726/15756_6ec887e9/index.m3u8"},{"name":"55","slug":"55","link_embed":"https://vip.opstream17.com/share/054826216783428249a279ba5b984315","link_m3u8":"https://vip.opstream17.com/20240726/15757_5ee0c7c3/index.m3u8"}]}],"description":"Nhà đường niên đại Túc Tông, cung đình tranh đấu thái tử lưu lạc bên ngoài nên đổi tên là Tiết Bình Quý. Bình Quý sau khi lớn lên đến Trường An thì gặp được thiên kim của Tướng gia là Vương Bảo Xuyến. Vương tướng quốc được Hoàng thượng ra lệnh chiêu hôn cho Bảo Xuyến, Bảo Xuyến vì chung tình với Bình Quý tuyệt tình nghĩa với phụ thân bằng tam kích chưởng, sau đó cùng Bình Quý kết thành vợ chồng.\n\nHai quân giao chiến, công chúa nước địch gặp và được Bình Quý tha mạng nên đem lòng cảm kích. Công chúa đại chiến được gã cho Bình Quý, Bình Quý kế thừa vương vị sau thiết lập hòa bình giữa hai nước, mở ra thông thương giao dịch đẩy mạnh cuộc sống người dân. Bảo Xyến biết được sự việc này hỉu lầm Bình Quý hai người phát sinh mâu thuẫn. Sau này, Bình Quý giải thích rõ ràng mọi chuyện, hai người lại thông hiểu cho nhau cho nên một nhà đoàn viên.","tmdb_id":105097,"cast":["Trương Lượng","Trần Hạo Dân","Tuyên Huyên","Tiến Vinh"],"director":["Đồng Lực"],"keywords":[],"tmdb":{"type":"tv","id":"105097","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trương Lượng","name_vi":null,"name_original":"Trương Lượng"},{"name":"Trần Hạo Dân","name_vi":null,"name_original":"Trần Hạo Dân"},{"name":"Tuyên Huyên","name_vi":null,"name_original":"Tuyên Huyên"},{"name":"Tiến Vinh","name_vi":null,"name_original":"Tiến Vinh"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tiet-binh-quy-va-vuong-bao-xuyen.json"}