iều tra rõ mồn một rồi, vì để che giấu thân phận anh cuối cùng chọn… mặc áo quần con gái. Cuộc sống vườn trường hung hiểm lại hài hước sắp bắt đầu.</p>","tmdb_id":139166,"cast":[],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"139166","season":1,"vote_average":7,"vote_count":1},"cast_meta":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tieu-ma-dau-lo-tay-roi.json"}