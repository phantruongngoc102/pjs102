p.opstream11.com/share/e2151f0daad7ba067138b6ad9fb96661","link_m3u8":"https://vip.opstream11.com/20241101/56198_e2151f0d/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/ae72e011c9314e653ee4bef551c8be3a","link_m3u8":"https://vip.opstream11.com/20241102/56277_ae72e011/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/ba48e3bddfd8b7160acdedcad3055780","link_m3u8":"https://vip.opstream11.com/20241102/56278_ba48e3bd/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/f06067263051b3f5a73ddeebadf6faab","link_m3u8":"https://vip.opstream11.com/20241103/56411_f0606726/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/f1c204756f75e95bd82b957bb9a2727e","link_m3u8":"https://vip.opstream11.com/20241103/56412_f1c20475/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream11.com/share/95c7a47f19fed03b040aec2326360cf7","link_m3u8":"https://vip.opstream11.com/20241104/56576_95c7a47f/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream11.com/share/231a171b205742febf998a329042ba9c","link_m3u8":"https://vip.opstream11.com/20241104/56577_231a171b/index.m3u8"}]}],"description":"Trong lúc tham gia hoạt động ngoại khóa của câu lạc bộ khảo cổ, thành viên Tô Khả vô tình chạm vào lệnh bài tướng quân và bị xuyên không đến nước Ngô, đúng vào lúc đại tướng quân Đới Vũ đang điều tra một vụ án mạng liên hoàn. Vì có ngoại hình giống hệt nạn nhân nên Tô Khả bị Đới Vũ dùng lệnh bài tướng quân ép cưới về phủ. Thế nhưng đô thành sóng ngầm cuộn trào, Tô Khả liên tục bị ám sát, vì vậy cô quyết định cùng Đới Vũ điều tra hung thủ. Trong quá trình điều tra, Tô Khả quen được Lục Thần, thiếu trang chủ của sơn trang Lục Ly, còn được yết kiến Hoàng đế đương triều, lại phát hiện ra Hoàng đế chính là Tôn Đạc, thành viên câu lạc bộ cùng xuyên không tới. Thì ra các bạn học của Tô Khả đều xuyên không đến nước Ngô, hơn nữa vì thời điểm xuyên không khác nhau, nên tuổi tác và trải nghiệm của mỗi người cũng khác nhau, tâm tính cũng thay đổi. Dưới sự giúp đỡ của Tôn Đạc, Tô Khả và Đới Vũ thuận lợi điều tra ra hung thủ, trừng trị hắn theo pháp luật.","tmdb_id":272039,"cast":["Cheng Yufeng","Qiao Jingwen","Lu Ming","Liu Xinnian"],"director":["Zhang Haixiao"],"keywords":[],"tmdb":{"type":"tv","id":"272039","season":1,"vote_average":8.25,"vote_count":2},"cast_meta":[{"name":"Cheng Yufeng","name_vi":null,"name_original":"Cheng Yufeng","tmdb_id":4179551,"profile":"https://image.tmdb.org/t/p/w500/uZybp9EvZOc4lUfpo5Q6ua6QpA2.jpg","tmdb_url":"https://www.themoviedb.org/person/4179551"},{"name":"Qiao Jingwen","name_vi":null,"name_original":"Qiao Jingwen","tmdb_id":3456395,"profile":"https://image.tmdb.org/t/p/w500/gg2cqPOQy3JjASF9DDkopNHM5Le.jpg","tmdb_url":"https://www.themoviedb.org/person/3456395"},{"name":"Lu Ming","name_vi":null,"name_original":"Lu Ming","tmdb_id":4953875,"profile":"https://image.tmdb.org/t/p/w500/mn0hrI8lPnIduSafOb8ci6q2aC5.jpg","tmdb_url":"https://www.themoviedb.org/person/4953875"},{"name":"Liu Xinnian","name_vi":null,"name_original":"Liu Xinnian","tmdb_id":4859794,"profile":"https://image.tmdb.org/t/p/w500/4dFYbspflfEKErlY0NJLoTOSX1G.jpg","tmdb_url":"https://www.themoviedb.org/person/4859794"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tieu-nu-khong-nghe-lenh-tuong-quan.json"}