opstream12.com/20220619/20815_c8b9ddaa/index.m3u8"}]}],"description":"<p>Bộ phim kể về cô nàng tiểu thư vương phủ Thẩm Cẩm từ bé đã được nuông chiều bảo bọc trong phủ, nhưng lại bị hoàng thượng ban hôn đến tận biên ải xa xôi. Phu quân của nàng là đại tướng quân Sở Tu Minh, người khiến nàng phải lòng vị tướng quân này từ cái nhìn đầu tiên. Tuy nhiên, cuộc sống mới nơi biên ải không đơn giản, hơn nữa hoàng thượng lại bắt đầu nảy sinh lòng nghi ngờ với Sở gia. Chuyện tình yêu của Thẩm Cẩm và Sở Tu Minh cũng vì thế mà trải qua muôn vàn gian khó.</p>","tmdb_id":111322,"cast":["Tang Min","Ngô Hi Trạch","Cao Junxiang","Liu Yinjun","Xu Yiwen","Yu Cong","Xu Hao","Lu Jia","Zhang Zihan"],"director":["Qiang Wu"],"keywords":[],"tmdb":{"type":"tv","id":"111322","season":1,"vote_average":8.1,"vote_count":7},"cast_meta":[{"name":"Tang Min","name_vi":null,"name_original":"Tang Min","tmdb_id":2461692,"profile":"https://image.tmdb.org/t/p/w500/p3z0UoSZ4uQRAq9KDRNe0vphuID.jpg","tmdb_url":"https://www.themoviedb.org/person/2461692"},{"name":"Ngô Hi Trạch","name_vi":"Ngô Hi Trạch","name_original":"Caesar Wu","tmdb_id":2050469,"profile":"https://image.tmdb.org/t/p/w500/zIoLqJWTDFF96WuxQjpkOaXXUuu.jpg","tmdb_url":"https://www.themoviedb.org/person/2050469"},{"name":"Cao Junxiang","name_vi":null,"name_original":"Cao Junxiang","tmdb_id":2649250,"profile":"https://image.tmdb.org/t/p/w500/hAUu6GgPZBiKZ8LzuKPbNd4gbH6.jpg","tmdb_url":"https://www.themoviedb.org/person/2649250"},{"name":"Liu Yinjun","name_vi":null,"name_original":"Liu Yinjun","tmdb_id":2681547,"profile":"https://image.tmdb.org/t/p/w500/icztV9oWQzlX7KwjchJwuaxaARN.jpg","tmdb_url":"https://www.themoviedb.org/person/2681547"},{"name":"Xu Yiwen","name_vi":null,"name_original":"Xu Yiwen","tmdb_id":2810071,"profile":"https://image.tmdb.org/t/p/w500/joZA6jAaSSQBPdfHoZ2GhkWZI86.jpg","tmdb_url":"https://www.themoviedb.org/person/2810071"},{"name":"Yu Cong","name_vi":null,"name_original":"Yu Cong","tmdb_id":3794444,"profile":"https://image