m/20230204/32519_e1ad7549/index.m3u8"},{"name":"15","slug":"15","filename":"Tiêu Thập Nhất Lang tập 15","link_embed":"https://vip.opstream15.com/share/c2f8e1260683ddd569afefcb6558a1a6","link_m3u8":"https://vip.opstream15.com/20230204/32520_763488a6/index.m3u8"},{"name":"16","slug":"16","filename":"Tieu Thap Nhat Lang Tap 16","link_embed":"https://vip.opstream15.com/share/23ec211d0365be0665abf1354689014d","link_m3u8":"https://vip.opstream15.com/20230204/32543_f0a5fe90/index.m3u8"},{"name":"17","slug":"17","filename":"Tiêu Thập Nhất Lang tập 17","link_embed":"https://vip.opstream15.com/share/e8660ee8b41231074f2d9f16adb2ea71","link_m3u8":"https://vip.opstream15.com/20230204/32521_f8f8aac9/index.m3u8"},{"name":"18","slug":"18","filename":"Tiêu Thập Nhất Lang tập 18","link_embed":"https://vip.opstream15.com/share/238f12faae477497ff945ea4c695073b","link_m3u8":"https://vip.opstream15.com/20230204/32522_df6c7ad9/index.m3u8"},{"name":"19","slug":"19","filename":"Tiêu Thập Nhất Lang tập 19","link_embed":"https://vip.opstream15.com/share/d9f53a87e571214d24718690a39f67e9","link_m3u8":"https://vip.opstream15.com/20230204/32523_5beeab8c/index.m3u8"},{"name":"20","slug":"20","filename":"Tiêu Thập Nhất Lang tập 20","link_embed":"https://vip.opstream15.com/share/d15ff2db80a89807d24869fd9ffb1700","link_m3u8":"https://vip.opstream15.com/20230204/32524_ec9b07f9/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Sở Lưu Hương trước khi lâm chung đem bí mất bảo tàng gửi gắp cho bộ tộc Tiêu thị, nói rằng 16 năm sau Hậu nhân của mình sẽ đến để thu hồi. Trong bộ tộc Tiêu thị có người tiết lộ bí bận cho nên dẫn đển thảm cảnh diệt môn. Cha ruột của Tiêu Thập Nhất Lang vì không muốn bi kích tái diễn nên đã nhẫn tâm giết chết đệ để của Nhất Lang để y trở thành người duy nhất nắm giữ bí mật của bảo tàng. Khi Nhất Lang đến kinh thành vô tình bị liên đới vào ba vụ án diệt môn lớn nhất nơi đây, trở thành can phạm số 1 của triều đình. Trên Giang Hồ, chỉ có Bộ Khoái Phong Tứ Nương là tin tưởng Nhất Lang, Song ngạy vì thân phận nên Phong đành cùng với Nhất Lang diễn một đoạn kịch nhất binh nhất giặc truy đuổi khắp giang hồ để tìm ra sự thật. Trên giang hồ, nghe đồn Cát Lộc Đao nắm giữ bí mật của kho tàng nên đổ xô đi tranh đoạt, nào ngờ phía sau lời đồn này là một tập đoàn Thiên Tôn thần bí do Tiêu Dao Hầu thống lĩnh đặt ra nhằm tranh đoạt bảo tàng…</p>","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2023-02-04T16:02:41.000Z","cast":["Huỳnh Nhật Hoa","Thiệu Mỹ Kỳ","Hướng Hải Lam","La Mẫn Trang","Ngô Đại Dung","Tâng Vỹ Quyền","Quách Diệu Minh","Lạc Ứng Quân","Đàm Tiểu Hoàn","Lý Quốc Lân","Quách Chính Hồng"],"director":["Huỳnh Vỹ Thanh"],"cast_meta":[{"name":"Huỳnh Nhật Hoa","name_vi":null,"name_original":"Huỳnh Nhật Hoa"},{"name":"Thiệu Mỹ Kỳ","name_vi":null,"name_original":"Thiệu Mỹ Kỳ"},{"name":"Hướng Hải Lam","name_vi":null,"name_original":"Hướng Hải Lam"},{"name":"La Mẫn Trang","name_vi":null,"name_original":"La Mẫn Trang"},{"name":"Ngô Đại Dung","name_vi":null,"name_original":"Ngô Đại Dung"},{"name":"Tâng Vỹ Quyền","name_vi":null,"name_original":"Tâng Vỹ Quyền"},{"name":"Quách Diệu Minh","name_vi":null,"name_original":"Quách Diệu Minh"},{"name":"Lạc Ứng Quân","name_vi":null,"name_original":"Lạc Ứng Quân"},{"name":"Đàm Tiểu Hoàn","name_vi":null,"name_original":"Đàm Tiểu Hoàn"},{"name":"Lý Quốc Lân","name_vi":null,"name_original":"Lý Quốc Lân"},{"name":"Quách Chính Hồng","name_vi":null,"name_original":"Quách Chính Hồng"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tieu-thap-nhat-lang.json","keywords":[],"tmdb_checked":false}