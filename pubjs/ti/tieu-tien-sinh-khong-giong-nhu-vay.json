f68d79da98d5ad7e2fa873c8c8c0383","link_m3u8":"https://vip.opstream15.com/20230831/41983_cc06b60e/index.m3u8"},{"name":"24","slug":"24","filename":"A Different Mr Xiao 2023 EP24","link_embed":"https://vip.opstream15.com/share/a05def2ffe22028e9db25b4e6e99543d","link_m3u8":"https://vip.opstream15.com/20230831/41984_5f583896/index.m3u8"}]}],"time":"35 phút/tập","description":"Sinh viên năm tư học viện y học cổ truyền Tống Ức Quất, từ lâu rồi cô đã dựa dẫm vào sự giúp đỡ của trợ giảng Tiêu Tĩnh để đủ điểm qua môn. Cả hai quen biết nhau đã lâu và luôn duy trì một mối quan hệ đôi bên cùng có lợi. Tuy nhiên, sau khi có một ngôi sao băng ban ngày xẹt qua thì Tiêu Tĩnh lại liên tục thay đổi, khiến cô nàng biếng học nhác làm Tống Ức Quất biếng ngơ ngác chẳng hiểu gì, trong long dấy lên cảnh báo. Sự thật thì Tiêu Tĩnh của bây giờ là người đến từ tương lai. Vì muốn có được dược liệu quý hiếm mà anh phải vượt thời không để tiếp cận ông của Tống Ức Quất, chờ đợi cơ hội ra tay lấy đi. Tuy nhiên, lại xuyên không lệch tận 3 tháng, ông của Tống ỨC Quất đã giao cô cho anh chăm sóc, mọi chuyện đều rối tung rối mù lên.Để đạt được mục tiêu, Tiêu Tĩnh đành ép bản thân xã giao, nhưng anh ta dần bị nữ sinh Tống Ức Quất làm tan chảy, tìm được liều thuốc cho tâm hồn. Nhưng sự chia ly vẫn đang chực chờ ở tương lai…","tmdb":{"type":"tv","id":"233087","season":1,"vote_average":7.7,"vote_count":3},"modified":"2025-03-21T11:47:10.000Z","cast":["Triệu Dịch Khâm","Duan Xingyu","Zhao Qiyue","Lưu Húc Uy","Xu Xiao","Jiangyuan Yarong","Xiong Wenwen","Yang Jinjie"],"director":["Elsie Zhao"],"cast_meta":[{"name":"Triệu Dịch Khâm","name_vi":"Triệu Dịch Khâm","name_original":"Zhao Yiqin","tmdb_id":1879667,"profile":"https://image.tmdb.org/t/p/w500/5QiIAqWAAzuhbDQ9MwGTpMtUlYj.jpg","tmdb_url":"https://www.themoviedb.org/person/1879667"},{"name":"Duan Xingyu","name_vi":null,"name_original":"Duan Xingyu","tmdb_id":3220656,"profile":"https://image.tmdb.org/t/p/w500/goQkP08KIh0M8XU2WZdV1mOaz9n.jpg","tmdb_url":"htt