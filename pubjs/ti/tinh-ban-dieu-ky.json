2.com/20220304/2690_c442da5d/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/110eec23201d80e40d0c4a48954e2ff5","link_m3u8":"https://vip.opstream12.com/20220304/2691_5a5e0554/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/d790c9e6c0b5e02c87b375e782ac01bc","link_m3u8":"https://vip.opstream12.com/20220304/2692_dd532bbd/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream12.com/share/3bd4017318837e92a66298c7855f4427","link_m3u8":"https://vip.opstream12.com/20220304/2693_d379ed74/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream12.com/share/cf9b2d0406020c56599f9a93708832b5","link_m3u8":"https://vip.opstream12.com/20220304/2694_30be9483/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream12.com/share/dbbf603ff0e99629dda5d75b6f75f966","link_m3u8":"https://vip.opstream12.com/20220304/2695_faf66fb2/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream12.com/share/dc2b690516158a874dd8aabe1365c6a0","link_m3u8":"https://vip.opstream12.com/20220304/2696_1c5dec19/index.m3u8"}]}],"description":"<p>Tình Bạn Diệu Kỳ - The Best Friend bắt đầu với cuộc sống đại học của sáu sinh viên chuyên ngành Nhật Bản, với Lin và Shao là nhân vật chính. Lin là một thanh niên nhạy cảm nhưng cực kỳ bướng bỉnh, không chịu nhờ người khác giúp đỡ trong bất kỳ khó khăn nào; trong khi Shao là người tháo vát, cởi mở và bổ sung một cách hoàn hảo tính cách của Lin. Họ nhanh chóng thành bạn bè và tham gia vào một loạt sự kiện và cuộc phiêu lưu. Họ hỗ trợ nhau vượt qua những khó khăn. Tuy nhiên, tính cách trái ngược của họ cũng tạo ra những cuộc tranh cãi và mâu thuẫn không ngừng. Cuối cùng thì Lin và Shao rời xa nhau. 10 năm sau, hai người gặp lại nhau. Họ bỏ qua những bất đồng trong quá khứ phù phiếm thời đại học, và câu chuyện tình bạn tiếp tục từ đó.</p>","tmdb_id":133247,"cast":["Xu Xin Chi","Chen Mu","杨皓羽","Wang Yueyi","Wang Yijun"],"director":["Paco Yi"],"keywords":[],"tmdb":{"type":"tv","id":"133247","season":1,"vote_average":10,"vote_count":1},"cast_meta":[{"name":"Xu Xin Chi","name_vi":null,"name_original":"Xu Xin Chi","tmdb_id":3242348,"profile":"https://image.tmdb.org/t/p/w500/nCrxWDyb1gXpLtz1GTcwXBpMqDm.jpg","tmdb_url":"https://www.themoviedb.org/person/3242348"},{"name":"Chen Mu","name_vi":null,"name_original":"Chen Mu","tmdb_id":3242350,"profile":"https://image.tmdb.org/t/p/w500/vHRP5zzIQQJAjtaJjcfAGprpwCH.jpg","tmdb_url":"https://www.themoviedb.org/person/3242350"},{"name":"杨皓羽","name_vi":null,"name_original":"杨皓羽","tmdb_id":3242351,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/3242351"},{"name":"Wang Yueyi","name_vi":null,"name_original":"Wang Yueyi","tmdb_id":3161424,"profile":"https://image.tmdb.org/t/p/w500/srstANWgPIsMrmdxWvLStDRiTmW.jpg","tmdb_url":"https://www.themoviedb.org/person/3161424"},{"name":"Wang Yijun","name_vi":null,"name_original":"Wang Yijun","tmdb_id":2823870,"profile":"https://image.tmdb.org/t/p/w500/jhVZlxiS1n8GlfQMXiMLMSNvFQr.jpg","tmdb_url":"https://www.themoviedb.org/person/2823870"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tinh-ban-dieu-ky.json"}