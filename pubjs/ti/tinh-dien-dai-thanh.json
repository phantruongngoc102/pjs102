{"id":"63bed2aab562641c5f2b5e7c","title":"Tình Điên Đại Thánh","origin_name":"A Chinese Tall Story","slug":"tinh-dien-dai-thanh","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/ti/tinh-dien-dai-thanh.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/ti/tinh-dien-dai-thanh.webp","year":2005,"type":"single","genre":[{"id":"620a2282e0fc277084dfd435","name":"Viễn Tưởng","slug":"vien-tuong"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a2347e0fc277084dfd876","name":"Hồng Kông","slug":"hong-kong"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"A Chinese Tall Story - 2005","link_embed":"https://vip.opstream14.com/share/e4c60bf7a076969fc058178b44f2f054","link_m3u8":"https://vip.opstream14.com/20230111/29250_760ad8c8/index.m3u8"}]}],"time":"103 Phút","description":"<p>Nhà sư trẻ Taka và ba đệ tử của mình bị bắt bởi một cây ma quỷ. Taka trốn thoát nhờ cây gậy thần của Vua khỉ và quyết định giải thoát cho những người bạn đồng hành của mình. Trên đường đi, anh gặp một đồng minh kỳ lạ tên là Meiyan, một cô gái nửa người nửa quái vật. Khi Taka và người bạn mới của mình bắt đầu một cuộc phiêu lưu kỳ thú, họ sẽ phải đối mặt với nhiều khó khăn và trận chiến và rất có thể sẽ quyết định số phận của nhân loại và toàn vũ trụ...</p>","tmdb":{"type":"movie","id":"45912","season":null,"vote_average":5.1,"vote_count":33},"modified":"2023-01-11T22:15:54.000Z","cast":["Tạ Đình Phong","Thái Trác Nghiên","Phạm Băng Băng","Chen Bolin","Quan Trí Bân","Steven Cheung Chi-Hang","Isabella Leong Lok-Sze","Nguyên Hoa","Huệ Anh Hồng","Lưu Gia Huy","Đàm Diệu Văn","Hoàng Nhất Phi","Lee Kin-Yan","Lê Diệu Tường","Dai Jiaoqian"],"director":["Jeffrey Lau"],"cast_meta":