f7151d5a/index.m3u8"},{"name":"6","slug":"6","filename":"Tinh linh Huyễn tưởng ký Tập 6 - Đêm hội","link_embed":"https://vip.opstream15.com/share/1b9f38268c50805669fd8caf8f3cc84a","link_m3u8":"https://vip.opstream15.com/20220413/3574_b634ea4c/index.m3u8"},{"name":"7","slug":"7","filename":"Tinh linh Huyễn tưởng ký Tập 7 - Vùng đất hẹn ước","link_embed":"https://vip.opstream15.com/share/c9f06bc7b46d0247a91c8fc665c13d0e","link_m3u8":"https://vip.opstream15.com/20220413/3575_cfef60ce/index.m3u8"},{"name":"8","slug":"8","filename":"Tinh linh Huyễn tưởng ký Tập 8 - Phả hệ hoàng gia","link_embed":"https://vip.opstream15.com/share/3f647cadf56541fb9513cb63ec370187","link_m3u8":"https://vip.opstream15.com/20220413/3576_652fdaa4/index.m3u8"},{"name":"9","slug":"9","filename":"Tinh linh Huyễn tưởng ký Tập 9 - Quyết ý của mỗi người","link_embed":"https://vip.opstream15.com/share/3e77a14629775492504515dc4b23deda","link_m3u8":"https://vip.opstream15.com/20220413/3577_e06161d7/index.m3u8"},{"name":"10","slug":"10","filename":"Tinh linh Huyễn tưởng ký Tập 10 - Tinh linh thức tỉnh","link_embed":"https://vip.opstream15.com/share/252a3dbaeb32e7690242ad3b556e626b","link_m3u8":"https://vip.opstream15.com/20220413/3578_179ba468/index.m3u8"},{"name":"11","slug":"11","filename":"Tinh linh Huyễn tưởng ký Tập 11 - Nàng dâu bạch ngân","link_embed":"https://vip.opstream15.com/share/0d441de75945e5acbc865406fc9a2559","link_m3u8":"https://vip.opstream15.com/20220413/3579_7f4e5a9a/index.m3u8"},{"name":"12","slug":"12","filename":"Tinh linh Huyễn tưởng ký Tập 12 - Cuộc gặp gỡ định mệnh","link_embed":"https://vip.opstream15.com/share/630b7d8dd49a0bab667498f287d68c16","link_m3u8":"https://vip.opstream15.com/20220413/3580_77971b03/index.m3u8"}]}],"time":"24 phút/tập","description":"<p>Tiền kiếp và hiện tại hòa lẫn vào nhau, chàng trai với hai kí ức của hai kiếp người đứng lên chống lại định mệnh. Thuở thơ ấu, Rio đã sớm trở thành trẻ mồ côi do mẹ bị giết, cậu phải kiến cường sống sót trong khu ổ chuột. Một ngày nọ, chàng trai Amakawa Haruto đã chết trong một tai nạn trong lúc mơ về cuộc tái ngộ với cô bạn thuở nhỏ đã mất tích, thức tỉnh bên trong thân xác Rio cùng với nguồn ma lực khổng lồ. Lúc ấy Haruto nhận ra mình đã chuyển sinh tại dị giới của kiếm và ma thuật. Sau một lần vô tình góp phần giải quyết vụ án bắt cóc công chúa, Haruto được Quốc vương đặc cách cho nhập học tại Học viện Hoàng gia Beltram. Đây là câu chuyện về cậu nhóc Rio và cũng là chàng trai Amakawa Haruto leo lên từ dưới đáy xã hội, qua nhiều cuộc gặp gỡ và chia li, cậu tích lũy sức mạnh để đánh tan vận mệnh tàn khốc.</p>","tmdb":{"type":"tv","id":"113808","season":1,"vote_average":8.3,"vote_count":240},"modified":"2022-05-22T03:49:29.000Z","cast":["Yoshitsugu Matsuoka","Ayaka Suwa","Akane Fujita","Yuuki Kuwahara"],"director":[],"cast_meta":[{"name":"Yoshitsugu Matsuoka","name_vi":null,"name_original":"Yoshitsugu Matsuoka","tmdb_id":233590,"profile":"https://image.tmdb.org/t/p/w500/ugDwdWEXnmv43jcbnfAi4XwiQ8C.jpg","tmdb_url":"https://www.themoviedb.org/person/233590"},{"name":"Ayaka Suwa","name_vi":null,"name_original":"Ayaka Suwa","tmdb_id":1325957,"profile":"https://image.tmdb.org/t/p/w500/pLd8VPfRp50Q744sT492FCn2k6f.jpg","tmdb_url":"https://www.themoviedb.org/person/1325957"},{"name":"Akane Fujita","name_vi":null,"name_original":"Akane Fujita","tmdb_id":1668897,"profile":"https://image.tmdb.org/t/p/w500/oMhN3uXgezyVk86gjwi8q1TYV2R.jpg","tmdb_url":"https://www.themoviedb.org/person/1668897"},{"name":"Yuuki Kuwahara","name_vi":null,"name_original":"Yuuki Kuwahara","tmdb_id":1763402,"profile":"https://image.tmdb.org/t/p/w500/n9kLcB2YNl9S2kK6b2rId7cpjdh.jpg","tmdb_url":"https://www.themoviedb.org/person/1763402"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ti/tinh-linh-huyen-tuong-ky.json"}