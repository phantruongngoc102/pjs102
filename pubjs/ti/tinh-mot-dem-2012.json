name":"25B","slug":"25b","filename":"tinh-mot-dem-i-do-i-do-tap-25B","link_embed":"https://vip.opstream11.com/share/bc4647bddd46ee572310781a51030572","link_m3u8":"https://vip.opstream11.com/20220516/25099_9581a1cb/index.m3u8"}]}],"time":"45 phút","description":"<p>Là 1 nhà thiết kế giày nổi tiếng, Hwang Ji-an có tất cả những thứ mà một phụ nữ tuổi 30 ao ước: độc thân, giàu có và thành đạt. Bỗng dưng, cô phạm phải 1 sai lầm chết người khi qua đêm cùng với Park Tea Gang, một nhân viên mới trong công ty của cô, và mang bầu. Đối thủ lớn nhất của cô, Yeom Na Ri, dựa vào đó để tìm cách chiếm lấy vị trí của cô trong công ty. Bên cạnh đó, Ji Ah cũng tình cờ gặp lại người yêu cũ của mình giờ đã trở thành một bác sĩ sản phụ khoa.</p>","tmdb":{"type":"tv","id":"45073","season":1,"vote_average":6.6,"vote_count":5},"modified":"2022-05-16T14:17:10.000Z","cast":["Oh Min-suk","Kim Seon-a","Park Gun-hyung","Lee Jang-woo","Im Soo-hyang","Park Young-kyu","Yun Ju-sang","Jo Hee-bong","Kim Soo-hyeon","Kim Hye-eun","Baek Seoung-hee","Han Ji-Wan"],"director":["Kang Dae Sun"],"cast_meta":[{"name":"Oh Min-suk","name_vi":null,"name_original":"Oh Min-suk","tmdb_id":980289,"profile":"https://image.tmdb.org/t/p/w500/14gxqx1Wq6lx9c2u5czh9buLdGl.jpg","tmdb_url":"https://www.themoviedb.org/person/980289"},{"name":"Kim Seon-a","name_vi":null,"name_original":"Kim Seon-a","tmdb_id":83221,"profile":"https://image.tmdb.org/t/p/w500/xzS16c1pZwjrhrbj5SGENtRaQkk.jpg","tmdb_url":"https://www.themoviedb.org/person/83221"},{"name":"Park Gun-hyung","name_vi":null,"name_original":"Park Gun-hyung","tmdb_id":1254417,"profile":"https://image.tmdb.org/t/p/w500/jZrGXYMc8Y439yqY88X3jMjfg7n.jpg","tmdb_url":"https://www.themoviedb.org/person/1254417"},{"name":"Lee Jang-woo","name_vi":null,"name_original":"Lee Jang-woo","tmdb_id":1348986,"profile":"https://image.tmdb.org/t/p/w500/o7eXMPTBj1wCNnRofaIxF5OgnDh.jpg","tmdb_url":"https://www.themoviedb.org/person/1348986"},{"name":"Im Soo-