ương thoát khỏi thân xác rồi vượt thời gian và không gian, trở về thời nhà Tống, nhập vào người Bao Chửng – Khai Phong phủ. Anh kinh ngạc khi nhìn thấy Hàn Sương Sương có khuôn mặt giống y Tịch Tuyết. Bao Chửng điều tra ra Sương vốn là công chúa, bị kẻ gian Cao Kế An (do Huỳnh Trí Hiền đóng) hãm hại. Nhưng rồi Bao Chửng bị ép trảm Sương Sương, và linh hồn anh lạc vào thời kỳ những năm thập niên 1950.","tmdb":{"type":"tv","id":"97028","season":1,"vote_average":0,"vote_count":0},"modified":"2025-09-21T21:12:23.000Z","cast":["Âu Dương Chấn Hoa","Quan Vịnh Hà","Ben Wong Chi-Yin","Ram Chiang Chi-Kwong","Viên Vỹ Hào","Christine Kuo Yun-Hui","JJ Jia","Vivien Yeo","Mandy Wong","Ngao Gia Niên","Rebecca Zhu Chenli","Derek Kwok Jing-Hung"],"director":[],"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Quan Vịnh Hà","name_vi":"Quan Vịnh Hà","name_original":"Esther Kwan Wing-Ho","tmdb_id":979045,"profile":"https://image.tmdb.org/t/p/w500/mMJpoUGwEyPloyuzTWijQuJav3p.jpg","tmdb_url":"https://www.themoviedb.org/person/979045"},{"name":"Ben Wong Chi-Yin","name_vi":null,"name_original":"Ben Wong Chi-Yin","tmdb_id":1192984,"profile":"https://image.tmdb.org/t/p/w500/yhL5DLBZv4BQIWIZQROvoNGyZuw.jpg","tmdb_url":"https://www.themoviedb.org/person/1192984"},{"name":"Ram Chiang Chi-Kwong","name_vi":null,"name_original":"Ram Chiang Chi-Kwong","tmdb_id":1083956,"profile":"https://image.tmdb.org/t/p/w500/7ikYgSecvhDXc8tQgqFucBitfG0.jpg","tmdb_url":"https://www.themoviedb.org/person/1083956"},{"name":"Viên Vỹ Hào","name_vi":"Viên Vỹ Hào","name_original":"Benjamin Yuen Wai-Ho","tmdb_id":1615007,"profile":"https://image.tmdb.org/t/p/w500/l2I4dLefQPTFZ0N2gkXm8KEgX1h.jpg","tmdb_url":"https://www.themoviedb.org/person/1615007"},{"name":"Christine Kuo Yun-Hui","name_vi":null,"name_or