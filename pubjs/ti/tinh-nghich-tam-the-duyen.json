0406/34943_d25a1b3e/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>kể về Viên Kim Xương là một giám đốc của phòng tình báo, một hôm vì một lời hứa của mình mà anh đã lỡ tay sát hại cô bạn gái Dương Tịch Tuyết. Thế nhưng, trong lúc anh suy sụp nhất thì bỗng nhiên linh hồn của anh thoát khỏi thể xác và quay trở về quá khứ vào thời nhà Tống, và thâm nhập vào thân xác của Bao Chửng. Anh còn vô cùng bất ngờ khi phát hiện cô nàng Hàn Sương Sương có khuôn mặt giống hệt Tịnh Tuyết. Sau đó anh còn bị ép buộc trảm Sương Sương và linh hồn của anh lại rơi vào năm 1950.</p>","tmdb":{"type":"tv","id":"97028","season":1,"vote_average":0,"vote_count":0},"modified":"2023-04-17T17:19:10.000Z","cast":["Âu Dương Chấn Hoa","Quan Vịnh Hà","Ben Wong","Ram Chiang Chi-Kwong","Viên Vỹ Hào","Christine Kuo Yun-Hui","JJ Jia","Vivien Yeo","Mandy Wong","Ngao Gia Niên","Rebecca Zhu Chenli","Derek Kwok Jing-Hung"],"director":["Trang Vỹ Kiện"],"cast_meta":[{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Quan Vịnh Hà","name_vi":"Quan Vịnh Hà","name_original":"Esther Kwan Wing-Ho","tmdb_id":979045,"profile":"https://image.tmdb.org/t/p/w500/mMJpoUGwEyPloyuzTWijQuJav3p.jpg","tmdb_url":"https://www.themoviedb.org/person/979045"},{"name":"Ben Wong","name_vi":null,"name_original":"Ben Wong","tmdb_id":1192984,"profile":"https://image.tmdb.org/t/p/w500/yhL5DLBZv4BQIWIZQROvoNGyZuw.jpg","tmdb_url":"https://www.themoviedb.org/person/1192984"},{"name":"Ram Chiang Chi-Kwong","name_vi":null,"name_original":"Ram Chiang Chi-Kwong","tmdb_id":1083956,"profile":"https://image.tmdb.org/t/p/w500/7ikYgSecvhDXc8tQgqFucBitfG0.jpg","tmdb_url":"https://www.themoviedb.org/person/1083956"},{"name":"Viên Vỹ Hào","name_vi":"Viên Vỹ Hào","name_original":"Benjamin Yuen Wai-Ho","tmdb_id":1615007,"profile":"https://image