ình của họ bị xáo trộn khi Tae Koo xuất hiện, gây ra mối đe dọa cho vẻ bề ngoài được trau chuốt cẩn thận của họ.</p>","tmdb":{"type":"tv","id":"214529","season":1,"vote_average":7.4,"vote_count":13},"modified":"2023-10-06T13:32:44.000Z","cast":["Jang Hyuk","Jang Na-ra","Chae Jung-an","Kim Nam-hee","Lee Soon-jae","Kim Kang-min","Yun Sang-jeong","Gabee","Lee Chae-young","Son Sook","Lee Ju-won","Jeong Min-jun","Shin Su-a","Kim Hye-na","Choi Young-jun"],"director":["Jang Jung Do"],"cast_meta":[{"name":"Jang Hyuk","name_vi":null,"name_original":"Jang Hyuk","tmdb_id":63438,"profile":"https://image.tmdb.org/t/p/w500/wOGbzgmlogfpPUvXTWVSROVTUYf.jpg","tmdb_url":"https://www.themoviedb.org/person/63438"},{"name":"Jang Na-ra","name_vi":null,"name_original":"Jang Na-ra","tmdb_id":1234280,"profile":"https://image.tmdb.org/t/p/w500/uIIShNFO8torFMbPqbjs6VXVqD8.jpg","tmdb_url":"https://www.themoviedb.org/person/1234280"},{"name":"Chae Jung-an","name_vi":null,"name_original":"Chae Jung-an","tmdb_id":124394,"profile":"https://image.tmdb.org/t/p/w500/242dNGEsHLaMIEpwWtsbX5lgEa9.jpg","tmdb_url":"https://www.themoviedb.org/person/124394"},{"name":"Kim Nam-hee","name_vi":null,"name_original":"Kim Nam-hee","tmdb_id":1747532,"profile":"https://image.tmdb.org/t/p/w500/isgY8huXgnoW7AD97vKYlhJwAyI.jpg","tmdb_url":"https://www.themoviedb.org/person/1747532"},{"name":"Lee Soon-jae","name_vi":null,"name_original":"Lee Soon-jae","tmdb_id":566367,"profile":"https://image.tmdb.org/t/p/w500/zYjhQJ27PUY2hxiIr50AIJ7TWa8.jpg","tmdb_url":"https://www.themoviedb.org/person/566367"},{"name":"Kim Kang-min","name_vi":null,"name_original":"Kim Kang-min","tmdb_id":2762557,"profile":"https://image.tmdb.org/t/p/w500/lShZsNK3SimVpnJctkDI0ZxFFqu.jpg","tmdb_url":"https://www.themoviedb.org/person/2762557"},{"name":"Yun Sang-jeong","name_vi":null,"name_original":"Yun Sang-jeong","tmdb_id":3481219,"profile":"https://image.tmdb.org/t/p/w500/pOwEfgsFJhYQ8PtxtQW0aaeW0nR.jpg","tmdb_url":"https://www.themoviedb.org/perso