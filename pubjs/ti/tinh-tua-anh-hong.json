om/share/af71676c7ff18aa1e3753650104db82d","link_m3u8":"https://vip.opstream17.com/20240822/17525_59ffce51/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/64b0a7e11a467063ff3fa8d3bdf661e1","link_m3u8":"https://vip.opstream17.com/20240822/17526_e1ce7fb8/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/a18128daad05bf1de8ab6530a5f3b287","link_m3u8":"https://vip.opstream17.com/20240822/17527_4898ec62/index.m3u8"}]}],"description":"<p><i>Bộ phim truyền hình đầy cảm hứng về tuổi trẻ đầy nắng và năng lượng, miêu tả quá trình đấu tranh của một họa sĩ hoạt hình trẻ tuổi một cách thoải mái và chân thực. Đặng Kiến Bang (Chiêm Bỉnh Hy) từ nhỏ đã mê vẽ phim hoạt hình và không có ý định học, nhưng anh trai Jianguo lại tốt nghiệp y khoa nên Bang thường bị gia đình cho là mù quáng. Sau khi bỏ học cấp hai ở bang thứ hai, anh ấy làm công việc áp phích văn phòng và gặp sếp của mình là Mai Zhengyun (do Yang Zelin thủ vai), người nhanh chóng trở thành một người bạn tốt. Ngoài ra, Bang thậm chí còn theo đuổi đồng nghiệp nữ của mình là Yin Cuier (do Trương Mạn Ngọc đóng), nhưng Cuiyuan và Zhaowen (do Lu Liangwei đóng) rất thân với nhau và họ rất thân với Bang. Bang đã có ý kiến với công ty và bị đuổi việc với lý do, Mak cũng tức giận từ chức, Bang và Mak cùng bạn của mình là Luo Jiaqin (do Liu Qingyun thủ vai) cùng xuất bản truyện tranh, bán rất chạy. Khi cả ba đang vui mừng khôn xiết thì bất ngờ, cha đẻ của Jiaqin đã bán bản quyền cho ông lớn manga Guo Jianxi, cả ba không khỏi thất vọng. May mắn thay, về tình yêu, Bang cuối cùng đã giành được trái tim của Tweet bằng sự chăm chỉ và chân thành không ngừng. Sau khi chán nản với việc xuất bản truyện tranh, Jia Qin và Bang buộc phải làm việc trong công ty truyện tranh quy mô lớn của Guo, tuy nhiên Bang liên tục bị sếp bắt nạt và chế giễu, không có cơ hội phát triển và chán nản. và Bang cũng dựa vào đó. Nhưng khó khăn cũng có rắc rối, vì Jiaqin thấy thành tích của Bang vượt xa mình nên anh ấy vô cùng không muốn nhìn thấy thành tích của Bang, lại bị người khác xúi giục, cuối cùng đổi sang công ty xuất bản khác khiến Bang rất thất vọng. Ngoài ra, Quách cũng bị lừa gạt nên Bang mất đi quyền lực, sự nghiệp lại xuống dốc không phanh.</i></p>","tmdb_id":107895,"cast":["Trương Mạn Ngọc","Lưu Thanh Vân","Tần Bái","Yammie Lam Kit-Ying","Lữ Lương Vỹ","Chim Bing-Hei","Yeung Chak-Lam","Susanna Au-Yeung Pui-San","Seung Yee","Wong Man-Yee","Lưu Triệu Minh","Lưu Giang","Cheung Ying-Tsoi","Chan Lap-Ban","Cheng Mang-Ha"],"director":["Chiêu Chấn Cường"],"keywords":[],"tmdb":{"type":"tv","id":"107895","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trương Mạn Ngọc","name_vi":"Trương Mạn Ngọc","name_original":"Maggie Cheung","tmdb_id":1338,"profile":"https://image.tmdb.org/t/p/w500/hre6xmoDbh67YN7wR5nhUazPTlb.jpg","tmdb_url":"https://www.themoviedb.org/person/1338"},{"name":"Lưu Thanh Vân","name_vi":"Lưu Thanh Vân","name_original":"Sean Lau Ching-wan","tmdb_id":940339,"profile":"https://image.tmdb.org/t/p/w500/ecxJyPA6EPDG2AXomVJORaN4qLZ.jpg","tmdb_url":"https://www.themoviedb.org/person/940339"},{"name":"Tần Bái","name_vi":"Tần Bái","name_original":"Paul Chun Pui","tmdb_id":87733,"profile":"https://image.tmdb.org/t/p/w500/lsxGuBaBPmKu1yj9qcHzvLq5SGH.jpg","tmdb_url":"https://www.themoviedb.org/person/87733"},{"name":"Yammie Lam Kit-Ying","name_vi":null,"name_original":"Yammie Lam Kit-Ying","tmdb_id":87945,"profile":"https://image.tmdb.org/t/p/w500/o2B9BUelQVAvaRipDwJRJLU7dHk.jpg","tmdb_url":"https://www.themoviedb.org/person/87945"},{"name":"Lữ Lương Vỹ","name_vi":"Lữ Lương Vỹ","name_original":"Ray Lui","tmdb_id":78877,"profile":"https://image.tmdb.org/t/p/w500/vAWHhBCWZwBKLsujgEKusfMLmCO.jpg","tmdb_url":"https://www.themoviedb.org/person/78877"},{"name":"Chim Bing-Hei","name_vi":null,"name_original":"Chim Bing-Hei","tmdb_id":1277925,"profile":"https://image.tmdb.org/t/p/w500/cZGWEXnFNnqIiVyYge1l5ZNJqIP.jpg","tmdb_url":"https://www.th