lug":"40","link_embed":"https://vip.opstream16.com/share/db782d22265fd45c6af25f3bb5fc6a1a","link_m3u8":"https://vip.opstream16.com/20220930/23180_0ae8b96a/index.m3u8"}]}],"description":"<p>Tình Xa Vạn Kiếp - Tang Dynasty Tour một câu chuyện đầy ắp tiếng cười và nước mắt xoay quanh một nhà khảo cổ học du hành xuyên thời gian đến triều đại nhà Đường và bị cuốn vào những cuộc tranh giành chính trị trong hoàng cung. Sau khi bị bão cát trong một chuyến thám hiểm khảo cổ, Yun Ye bị sốc khi biết rằng mình đã kết thúc ở nhà Đường. Anh ta tận dụng kiến thức của mình từ thời hiện đại để tạo ra một cuộc sống đàng hoàng cho bản thân và từ từ leo lên các cấp bậc như một quan chức triều đình. Anh kết thân với Thái tử và cũng gặp lại tình cũ, từ đó mắc kẹt giữa những mưu tính tranh đoạt vương quyền.</p>","tmdb_id":83833,"cast":["Vương Thiên Thần","Trương Giai Ninh","Trương Tấn","Viên Vịnh Nghi","Yu Ziyang","Wang Wenjie","Wang Yongquan","Yang Cao"],"director":["Long Tiểu Sơn"],"keywords":[],"tmdb":{"type":"tv","id":"83833","season":1,"vote_average":7.2,"vote_count":6},"cast_meta":[{"name":"Vương Thiên Thần","name_vi":"Vương Thiên Thần","name_original":"Wang Tianchen","tmdb_id":1815239,"profile":"https://image.tmdb.org/t/p/w500/hWfKsHErCBPR3Z8gRkRvLuj9r0o.jpg","tmdb_url":"https://www.themoviedb.org/person/1815239"},{"name":"Trương Giai Ninh","name_vi":"Trương Giai Ninh","name_original":"Karlina Zhang","tmdb_id":1829558,"profile":"https://image.tmdb.org/t/p/w500/hEOl3OdG16uag7xMznk3X9FRCH0.jpg","tmdb_url":"https://www.themoviedb.org/person/1829558"},{"name":"Trương Tấn","name_vi":"Trương Tấn","name_original":"Ken Chang Tzu-Yao","tmdb_id":78872,"profile":"https://image.tmdb.org/t/p/w500/f0nx1VMAqy2X3DfgDc069efAqYk.jpg","tmdb_url":"https://www.themoviedb.org/person/78872"},{"name":"Viên Vịnh Nghi","name_vi":"Viên Vịnh Nghi","name_original":"Anita Yuen Wing-Yee","tmdb_id":64895,"profile":"https://image.tmdb.org/t/p/w500/AuCZvEuF5QFzManEGuJLGXg4DZ.jpg","tmdb_url":"https://www.themoviedb.