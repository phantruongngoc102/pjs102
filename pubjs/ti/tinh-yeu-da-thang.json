 ba phần này ghi lại những nguy cơ của việc truyền đạo trên internet và một đức tin bị thúc đẩy bởi thuyết âm mưu.</p>","tmdb":{"type":"tv","id":"238179","season":1,"vote_average":6.87,"vote_count":27},"modified":"2025-03-22T11:17:37.000Z","cast":["Amy Carlson","Mary Lowers","Ashley Peluso","Lauryn Suarez","Linda Haythorne","Tara Flores","Ryan Kramer","Gabriel Gomez","Avigail Lowes","John Robertson","Jason Castillo"],"director":[],"cast_meta":[{"name":"Amy Carlson","name_vi":null,"name_original":"Amy Carlson","tmdb_id":4398796,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398796"},{"name":"Mary Lowers","name_vi":null,"name_original":"Mary Lowers","tmdb_id":4398834,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398834"},{"name":"Ashley Peluso","name_vi":null,"name_original":"Ashley Peluso","tmdb_id":4398863,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398863"},{"name":"Lauryn Suarez","name_vi":null,"name_original":"Lauryn Suarez","tmdb_id":4398843,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398843"},{"name":"Linda Haythorne","name_vi":null,"name_original":"Linda Haythorne","tmdb_id":4398861,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398861"},{"name":"Tara Flores","name_vi":null,"name_original":"Tara Flores","tmdb_id":4398850,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398850"},{"name":"Ryan Kramer","name_vi":null,"name_original":"Ryan Kramer","tmdb_id":4398833,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398833"},{"name":"Gabriel Gomez","name_vi":null,"name_original":"Gabriel Gomez","tmdb_id":4398832,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398832"},{"name":"Avigail Lowes","name_vi":null,"name_original":"Avigail Lowes","tmdb_id":4398828,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4398828"},{"name":"John Robertson","name_vi":null,"name_original":"John Robertson","tmdb_id":4398837,"profile":null,"tmdb_url":"https: