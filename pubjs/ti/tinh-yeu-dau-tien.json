3c270200daf0475c1f217910f982","link_m3u8":"https://vip.opstream14.com/20220620/14972_e3e69f48/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream14.com/share/5ca1b0a18c411c3ebfc35c9dad7da921","link_m3u8":"https://vip.opstream14.com/20220620/14973_cf0d4053/index.m3u8"}]}],"description":"<p>Kể về Hoa Tây Hề một tác giả truyện tranh manga, trong lúc đi tìm đề tài sáng tác đã vô tình gặp gỡ và quen biết với Hoắc Tử Ngang chỉ vì chấn thương mà đã bỏ lỡ giấc mộng của mình. Hai người ghét nhau ngay từ giây phút gặp gỡ đầu tiên, mãi cho đến khi hai người cùng theo đuổi giấc mộng của mình họ mới bắt đầu bén lửa tình. Đồng thời, Hoa Tây Hề còn làm sứ giả hòa bình giúp Hoắc Tử Ngang xóa bỏ hiểu lầm trong quá khứ với người anh em tốt của mình là Tôn Tu Kiệt, họ chẳng may đã rơi vào tình yêu tay ba. Trong vấn đề nan giải giữa tình yêu và tình bạn cuối cùng cả ba người đều đã đưa ra sự lựa chọn của riêng mình cuối cùng họ đã có được tình yêu và giấc mộng đẹp nhất đời mình.</p>","tmdb_id":94844,"cast":["Chen Ziyou","Zheng Hehuizi","Leo Yang","Sun Jia Lu","Lý Cửu Lâm","Bai Fan","Rong Zixi","Huo Xingyu","Tianjiao Fu","Zhang Shen","Yang Chuanbei","Zhang Yiyang","Bian Yiming","Feng Qing"],"director":["Đang cập nhật"],"keywords":[],"tmdb":{"type":"tv","id":"94844","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Chen Ziyou","name_vi":null,"name_original":"Chen Ziyou","tmdb_id":2693803,"profile":"https://image.tmdb.org/t/p/w500/r0Bzu5s5CeQk1ioOEYR2JcfbAfI.jpg","tmdb_url":"https://www.themoviedb.org/person/2693803"},{"name":"Zheng Hehuizi","name_vi":null,"name_original":"Zheng Hehuizi","tmdb_id":1850227,"profile":"https://image.tmdb.org/t/p/w500/q9dHA42JLYCaC7JEe2KyRRcL2wJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1850227"},{"name":"Leo Yang","name_vi":null,"name_original":"Leo Yang","tmdb_id":2480231,"profile":"https://image.tmdb.org/t/p/w500/dOjn9t7lUVlXdMsY6JUsNXSyccp.jpg","tmdb_url":"https://www.themoviedb.org/person/2480231"},{"name":"S