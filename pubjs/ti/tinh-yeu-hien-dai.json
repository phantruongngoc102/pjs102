ip.opstream16.com/20221021/24500_a7547b54/index.m3u8"}]}],"description":"<p>Sê-ri Amazon Original “Tình yêu hiện đại”, dựa trên một chuyên mục xuất hiện trên Thời báo New York, đã được phát hành từ năm 2019. Giờ đây, “Tình yêu hiện đại” khởi động lại với giao diện mới ở Tokyo với tên gọi “Tình yêu hiện đại Tokyo”. Tuyển tập bảy tập có sự tham gia của các diễn viên chính và mô tả nhiều dạng “tình yêu” khác nhau, chẳng hạn như tình yêu gần như bị lãng quên, tình yêu giữa con trai và mẹ, và tình yêu vượt qua biên giới.</p>","tmdb_id":208596,"cast":["Mizukawa Asami","Ikematsu Sosuke","Nagasaku Hiromi","Yusuke Santamaria","Naomi Scott","Maeda Atsuko"],"director":["Kurosawa Kiyoshi"],"keywords":[],"tmdb":{"type":"tv","id":"208596","season":1,"vote_average":6.8,"vote_count":18},"cast_meta":[{"name":"Mizukawa Asami","name_vi":null,"name_original":"Mizukawa Asami"},{"name":"Ikematsu Sosuke","name_vi":null,"name_original":"Ikematsu Sosuke"},{"name":"Nagasaku Hiromi","name_vi":null,"name_original":"Nagasaku Hiromi"},{"name":"Yusuke Santamaria","name_vi":null,"name_original":"Yusuke Santamaria"},{"name":"Naomi Scott","name_vi":null,"name_original":"Naomi Scott"},{"name":"Maeda Atsuko","name_vi":null,"name_original":"Maeda Atsuko"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tinh-yeu-hien-dai.json"}