14.com/share/5e07b82cfd5b5b726a8b5685ce1a3766","link_m3u8":"https://vip.opstream14.com/20220828/20781_0f48cf44/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream14.com/share/f8531013695084f6fd79ed6d8e24b2d6","link_m3u8":"https://vip.opstream14.com/20220905/21051_a0023170/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream14.com/share/043c00e6c7ff021e8cc4d394d3264cb5","link_m3u8":"https://vip.opstream14.com/20220911/21321_0ae2988e/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream14.com/share/df05dec7f743ab807bfd4a47135aa61f","link_m3u8":"https://vip.opstream14.com/20220918/21624_949dbd2b/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream14.com/share/f4b3da8be9b354457f288b15bd37410a","link_m3u8":"https://vip.opstream14.com/20221002/22806_59663a1d/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream14.com/share/e1bad13934791680a1d90abb4abb26e2","link_m3u8":"https://vip.opstream14.com/20221002/22807_272ec682/index.m3u8"}]}],"description":"<p>Talay là một sinh viên tài năng mới ra trường. Anh ấy nhận được xác nhận cho công việc mới của mình với tư cách là một thợ pha màu và rất vui. Thật không may, trong một chuyến đi biển với bạn bè của mình, Talay bị chết đuối. Anh ta thức dậy trong một vũ trụ thay thế, bên trong cơ thể của một người khác. Anh phát hiện ra rằng người đó tên là Tess. Tess là một đứa con nhà giàu hư hỏng rắc rối. Trong bệnh viện, Talay gặp một y tá khác từ vũ trụ của anh ấy, người cũng đã chuyển đến đó. Cô ấy giải thích sự tồn tại của hai vũ trụ song song và nhấn mạnh sự cần thiết phải tìm ra “Portkey”. Cô ấy cũng nhắc lại rằng có thể có mối liên hệ sâu sắc nào đó giữa Talay và chiếc chìa khóa. Khi Talay tiếp cận với những người bạn của Tess, anh bắt gặp một người bạn thời tiểu học, Tun. Khi gặp Tun, Talay nhận thấy một số điều kỳ lạ và nhận ra rằng linh hồn của Tun ban đầu cũng đã biến đổi. Talay thú nhận với anh chàng mới rằng anh ta cũng đến từ vũ trụ khác. Khi cả hai làm việc cùng nhau để tìm các khóa cổng, mối quan hệ của họ càng bền chặt. Nhưng điều gì sẽ xảy ra khi họ trở lại vũ trụ của chính mình? Liệu họ có gặp lại nhau và nhận ra nhau?</p>","tmdb_id":205115,"cast":["Tawinan Anukoolprasert","Jitaraphol Potiwihok","Korapat Kirdpan","Pawat Chittsawangdee","Trai Nimtawat","Aou Thanaboon Kiatniran","Lalana Kongthoranin","Maneerat Kam-Uan","Tipnaree Weerawatnodom","Phanuroj Chalermkijporntavee","Boom Tharatorn Jantharaworakarn","Daweerit Chullasapya"],"director":["X Nuttapong Mongkolsawas"],"keywords":[],"tmdb":{"type":"tv","id":"205115","season":1,"vote_average":7.4,"vote_count":25},"cast_meta":[{"name":"Tawinan Anukoolprasert","name_vi":null,"name_original":"Tawinan Anukoolprasert","tmdb_id":3636167,"profile":"https://image.tmdb.org/t/p/w500/cTfSBEiH4cJDrYFn1KKIbC7JE1R.jpg","tmdb_url":"https://www.themoviedb.org/person/3636167"},{"name":"Jitaraphol Potiwihok","name_vi":null,"name_original":"Jitaraphol Potiwihok","tmdb_id":3039963,"profile":"https://image.tmdb.org/t/p/w500/9k97SlfwsnOjm4UH4SHWcGH9cBg.jpg","tmdb_url":"https://www.themoviedb.org/person/3039963"},{"name":"Korapat Kirdpan","name_vi":null,"name_original":"Korapat Kirdpan","tmdb_id":1872288,"profile":"https://image.tmdb.org/t/p/w500/adjXW5d1AvIW5thb5XjhDNtgBUn.jpg","tmdb_url":"https://www.themoviedb.org/person/1872288"},{"name":"Pawat Chittsawangdee","name_vi":null,"name_original":"Pawat Chittsawangdee","tmdb_id":1752096,"profile":"https://image.tmdb.org/t/p/w500/ggKqjNJTKAFmy5z6PpfVVpxw2S0.jpg","tmdb_url":"https://www.themoviedb.org/person/1752096"},{"name":"Trai Nimtawat","name_vi":null,"name_original":"Trai Nimtawat","tmdb_id":2668721,"profile":"https://image.tmdb.org/t/p/w500/hJgOYgT2MgCt0d0OSybh8JnAdwu.jpg","tmdb_url":"https://www.themoviedb.org/person/2668721"},{"name":"Aou Thanaboon Kiatniran","name_vi":"Aou Thanaboon Kiatniran","name_original":"Thanaboon Kiatniran","tmdb_id":3039960,"profile":"https://image.tmdb.org/t/p/w500/nz0oOHNmZDqJPy