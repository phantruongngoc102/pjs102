8f86fee5a83e22","link_m3u8":"https://vip.opstream11.com/20231225/50167_02e9832d/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/ba91c53141a643c6e46492fc64d8eebb","link_m3u8":"https://vip.opstream11.com/20231225/50168_55e81130/index.m3u8"}]}],"description":"Lâm Tâm Đồng, con gái duy nhất của doanh nhân giàu có Lâm Quốc Phú đem lòng yêu chàng trai nghèo Trì Sam bất chấp sự phản đối của cha mình. Tuy nhiên vào ngày đính hôn, Lâm Tâm Đồng đã bị cưỡng hôn bởi một gã đàn ông không rõ lai lịch và cực kỳ hung hãn. Sau đó khi cô còn chưa hết hoảng loạn, lúng túng thì biết tin cha mình là Lâm Quốc Phú đột ngột chết thảm. Tần Mặc Nghiêu bị buộc tội là kẻ giết người, để minh oan cho mình, anh chủ động tìm đến Lâm Tâm Đồng, nhưng chưa kịp giải thích đã bị cuốn vào âm mưu của gia đình họ Lâm. Từ đó Tần Mặc Nghiêu và Lâm Tâm Đồng bắt đầu một mối quan hệ độc đáo và kịch tính. Lâm Tâm Đồng cũng dần phát hiện ra vị hôn phu Trì Sam có quan hệ bất chính với Hạ Vũ Vi, đồng thời nảy sinh hiểu lầm với Tần Mặc Nghiêu. Phút chốc, tình yêu và thù hận ập đến với Lâm Tâm Đồng, cô quyết định phải tính sổ từng chuyện. Nhưng đến khi ra tay với Tần Mặc Nghiêu, cô mới biết được anh chính là người đã âm thầm bảo vệ cô.","tmdb_id":233753,"cast":["Trần Phương Đồng","Đại Cao Chính","Hou Dong","Ma Xinyu","Hu Xifan","Liu Xiaolei","Li Chengyang","Chen Yuan","Yun Wei Yi","Sun Ruiyang"],"director":["Lin Qing"],"keywords":[],"tmdb":{"type":"tv","id":"233753","season":1,"vote_average":8.1,"vote_count":26},"cast_meta":[{"name":"Trần Phương Đồng","name_vi":"Trần Phương Đồng","name_original":"Chen Fangtong","tmdb_id":3488128,"profile":"https://image.tmdb.org/t/p/w500/F3vKtnvDdUtPZ36KP2SLt34WVF.jpg","tmdb_url":"https://www.themoviedb.org/person/3488128"},{"name":"Đại Cao Chính","name_vi":"Đại Cao Chính","name_original":"Dai Gaozheng","tmdb_id":3693678,"profile":"https://image.tmdb.org/t/p/w500/yku8OmgfaJDVkEKH8laynjU54um.jpg","tmdb_url":"https://www.themoviedb.org/person/36936