ước đó là do hiểu lầm. Họ nỗ lực để lại gần nhau, khơi dậy lại tình yêu đã nguội lạnh và cuối cùng tìm được hạnh phúc bên nhau.","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ti/tinh-yeu-nguoi-lanh-short-drama.json"}