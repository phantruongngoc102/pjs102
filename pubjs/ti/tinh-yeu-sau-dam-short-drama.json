are/feccf7d1ccb03f33026fbdf6c7b7d110","link_m3u8":"https://vip.opstream-short.com/20251116/30582_feccf7d1/index.m3u8"},{"name":"91","slug":"91","filename":"Tình Yêu Sâu Đậm - Tập 91---2025","link_embed":"https://vip.opstream-short.com/share/9ad2f925a32643f541b183503f33a8c6","link_m3u8":"https://vip.opstream-short.com/20251116/30583_9ad2f925/index.m3u8"},{"name":"92","slug":"92","filename":"Tình Yêu Sâu Đậm - Tập 92---2025","link_embed":"https://vip.opstream-short.com/share/d82815d548d98ff14d95120eef2e6a3c","link_m3u8":"https://vip.opstream-short.com/20251116/30584_d82815d5/index.m3u8"},{"name":"93","slug":"93","filename":"Tình Yêu Sâu Đậm - Tập 93---2025","link_embed":"https://vip.opstream-short.com/share/6f1ee9cf8ecb6f8f9e26b778f92a9cdd","link_m3u8":"https://vip.opstream-short.com/20251116/30585_6f1ee9cf/index.m3u8"},{"name":"94","slug":"94","filename":"Tình Yêu Sâu Đậm - Tập 94---2025","link_embed":"https://vip.opstream-short.com/share/5ca177e9af12f0d5d9c4c72668c81b63","link_m3u8":"https://vip.opstream-short.com/20251116/30586_5ca177e9/index.m3u8"},{"name":"95","slug":"95","filename":"Tình Yêu Sâu Đậm - Tập 95---2025","link_embed":"https://vip.opstream-short.com/share/98d0c2a2816ff30684a55980833a7316","link_m3u8":"https://vip.opstream-short.com/20251116/30587_98d0c2a2/index.m3u8"},{"name":"96","slug":"96","filename":"Tình Yêu Sâu Đậm - Tập 96---2025","link_embed":"https://vip.opstream-short.com/share/65b6edfd9f135a6a1dbe075fb82c411f","link_m3u8":"https://vip.opstream-short.com/20251116/30588_65b6edfd/index.m3u8"}]}],"time":"2 phút/tập","description":"<p>\"Tình Yêu Sâu Đậm\" là một bộ phim tình cảm hiện đại kể về Xu Yanqing, người có được cơ hội thứ hai trong cuộc sống sau khi được tái sinh. Trong kiếp trước, cô đã chịu đựng rất nhiều khổ đau từ việc bị bắt nạt và sỉ nhục bởi chị gái Shen Rulan và một nhóm thiếu niên hư hỏng, cuối cùng chết trong tuyệt vọng. Tuy nhiên, số phận đã cho cô một cơ hội khác khi cô bí ẩn trở về năm 2008, chỉ vài ngày trước khi cha cô qua đời. Với ký ức về kiếp trước, Xu Yanqing tái sinh quyết tâm không lặp lại số phận bi thảm của mình. Cô quyết định bảo vệ bản thân và gia đình, nhận ra rằng mình đã từng sống dưới những âm mưu của Shen Rulan, bao gồm cả vụ tai nạn xe hơi của cha cô cũng do Shen Rulan lên kế hoạch. Với kiến thức về tương lai, Xu Yanqing bắt đầu hành trình báo thù và tìm kiếm tình yêu đích thực. Trong quá trình này, cô gặp nam chính Qin Donge, và họ phát triển một mối liên kết cảm xúc sâu sắc. Câu chuyện cho thấy làm thế nào một người phụ nữ có thể đứng dậy sau sự phản bội và đau khổ, dũng cảm đối mặt với cuộc sống.</p>","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-20T09:59:03.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tinh-yeu-sau-dam-short-drama.json","keywords":[],"tmdb_checked":false}