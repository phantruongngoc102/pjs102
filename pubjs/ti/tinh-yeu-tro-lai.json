_m3u8":"https://vip.opstream10.com/20220420/9392_eba69c58/index.m3u8"},{"name":"15","slug":"15","filename":"tinh-yeu-tro-lai-love-is-back-tap-15","link_embed":"https://vip.opstream10.com/share/1415fe9fea0fa1e45dddcff5682239a0","link_m3u8":"https://vip.opstream10.com/20220420/9393_2a6c3b6f/index.m3u8"},{"name":"16","slug":"16","filename":"tinh-yeu-tro-lai-love-is-back-tap-16","link_embed":"https://vip.opstream10.com/share/9f4b4f2f258308200b389ca0523f92f8","link_m3u8":"https://vip.opstream10.com/20220420/9394_bf32d092/index.m3u8"},{"name":"17","slug":"17","filename":"tinh-yeu-tro-lai-love-is-back-tap-17","link_embed":"https://vip.opstream10.com/share/d7fd83eaf0a5593a190e8e9c8d7ece84","link_m3u8":"https://vip.opstream10.com/20220420/9395_9a51f69a/index.m3u8"},{"name":"18","slug":"18","filename":"tinh-yeu-tro-lai-love-is-back-tap-18","link_embed":"https://vip.opstream10.com/share/cfaae21cc5ea9eef9bba69c7d4e8710a","link_m3u8":"https://vip.opstream10.com/20220420/9396_a6b95a8a/index.m3u8"},{"name":"19","slug":"19","filename":"tinh-yeu-tro-lai-love-is-back-tap-19","link_embed":"https://vip.opstream10.com/share/c4ede56bbd98819ae6112b20ac6bf145","link_m3u8":"https://vip.opstream10.com/20220420/9397_59644bc8/index.m3u8"},{"name":"20","slug":"20","filename":"tinh-yeu-tro-lai-love-is-back-tap-20","link_embed":"https://vip.opstream10.com/share/62000dee5a05a6a71de3a6127a68778a","link_m3u8":"https://vip.opstream10.com/20220420/9398_c0a370f5/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Trong phim Tình Yêu Trở Lại, thời đại nam nữ trẻ tuổi, đứng trước cánh cửa hôn nhân bàng hoàng do dự không ít. Minh Lượng và Cao Kiến là đối thủ một mất một còn, nhưng hai người đều chống lại hôn nhân, hi vọng chỉ nói đến tình yêu không có trách nhiệm, ai người sống chung với nhau, trở thành một đôi bí mật. Trong thời gian chung sống cả hai dần nảy sinh tình cảm, nhưng rồi lại sợ quan hệ càng lúc càng đến gần, khiến hai bên xung đột không ngừng. Tiểu thư Bao Niệm Niệm bị bác sĩ thú y Phương Tư Tề thu hút, chủ động theo đuổi lại không cẩn thận mang thai, bị cha mẹ hai bên bức hôn. Lúc nhận kết quả Niệm Niệm vô ý sinh non thì đã không còn lý do để kết hôn, quan hệ với Tư Tề càng lúc càng mỏng manh, nhưng Tư Tề lại nghĩ ra một cách \"quan hệ hôn nhân mới\" để giữ lại Niệm Niệm.</p>","tmdb":{"type":"tv","id":"106110","season":1,"vote_average":6.5,"vote_count":2},"modified":"2024-10-13T14:46:39.000Z","cast":["He Yutong","Nan Zhao","Qi Wei","Chen He","Mao Hiểu Đồng","Wang Chuanjun","Jiang Yan","He Minghan","Yang Qing"],"director":["Đang cập nhật"],"cast_meta":[{"name":"He Yutong","name_vi":null,"name_original":"He Yutong","tmdb_id":2855360,"profile":"https://image.tmdb.org/t/p/w500/hc846IXMqtsxxT188hS7Ef6dUBg.jpg","tmdb_url":"https://www.themoviedb.org/person/2855360"},{"name":"Nan Zhao","name_vi":null,"name_original":"Nan Zhao","tmdb_id":2855778,"profile":"https://image.tmdb.org/t/p/w500/di6XGL13jvqf59OOd27AaoN2w4t.jpg","tmdb_url":"https://www.themoviedb.org/person/2855778"},{"name":"Qi Wei","name_vi":null,"name_original":"Qi Wei","tmdb_id":1276002,"profile":"https://image.tmdb.org/t/p/w500/hNczmTxWQsdlbHrAkPlyixLPmH3.jpg","tmdb_url":"https://www.themoviedb.org/person/1276002"},{"name":"Chen He","name_vi":null,"name_original":"Chen He","tmdb_id":1397016,"profile":"https://image.tmdb.org/t/p/w500/78V2SYzwekBQOK55F4CmFWTwk34.jpg","tmdb_url":"https://www.themoviedb.org/person/1397016"},{"name":"Mao Hiểu Đồng","name_vi":"Mao Hiểu Đồng","name_original":"Mao Xiaotong","tmdb_id":1697058,"profile":"https://image.tmdb.org/t/p/w500/zOrbXf5SInGL06eYi56Z0jxI99G.jpg","tmdb_url":"https://www.themoviedb.org/person/1697058"},{"name":"Wang Chuanjun","name_vi":null,"name_original":"Wang Chuanjun","tmdb_id":1329842,"profile":"https://image.tmdb.org/t/p/w500/ilFW1ONI5UILya7nC1SuqZtkGRG.jpg","tmdb_url":"https://www.themoviedb.org/person/1329842"},{"name":"Jiang Yan","name_vi":null,"name_original":"Jiang Yan","tmdb_id":1993059,"profile":"https://image.tmdb.org/t/p/w500/o5TZh9UN