77df06712730b20748a335","link_m3u8":"https://vip.opstream15.com/20230510/39023_d4c57057/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream15.com/share/f47010edcf219c9b53403b26c519c027","link_m3u8":"https://vip.opstream15.com/20230510/39022_959188b5/index.m3u8"}]}],"description":"<p>Tô Bắc là nhà thiết kế thời trang của công ty Tang Lan, vì công ty của bố đang đứng bên bờ vực phá sản nên cô phải gả cho một ông chủ lớn chưa từng quen biết, lại không ngờ ông chủ lớn này lại là CEO Lộ Nam của tập đoàn Hoán Trăn. Vì muốn mau chóng được tiếp quản công ty, dưới sự bày mưu tính kế của bà nội Lộ Nam tìm được Tô Bắc, cô gái từng đính hôn với mình lúc nhỏ, cũng cùng Tô Bắc ký hợp đồng vợ chồng, không can thiệp vào cuộc sống của nhau. Ngày qua ngày chung sống hai người đã nảy sinh tình cảm sâu đậm, nhưng sóng gió ồ ạt kéo đến khi em gái cùng cha khác mẹ của Tô Bắc là Tô Mạn Ny lại có ý đồ bất chính với Lộ Nam, đồng thời cô em gái Lộ Phỉ Nhi trông như ngoan ngoan của Lộ Nam dường như cũng có tình cảm khác thường với anh trai mình. Người trợ lý thân cận vẫn luôn trung thành lại có dụng ý khác, người bà từng thích Tô Bắc cũng vì chuyện cô không muốn từ chức để mang thai mà dần xa cách.</p>","tmdb_id":206602,"cast":["Trần Thù Quân","Trần Phẩm Diên","Tôn Hiểu Luân","Lưu Hân Lôi","Thái Tường Vũ","Kỳ Lăng"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"206602","season":1,"vote_average":4,"vote_count":1},"cast_meta":[{"name":"Trần Thù Quân","name_vi":null,"name_original":"Trần Thù Quân"},{"name":"Trần Phẩm Diên","name_vi":null,"name_original":"Trần Phẩm Diên"},{"name":"Tôn Hiểu Luân","name_vi":null,"name_original":"Tôn Hiểu Luân"},{"name":"Lưu Hân Lôi","name_vi":null,"name_original":"Lưu Hân Lôi"},{"name":"Thái Tường Vũ","name_vi":null,"name_original":"Thái Tường Vũ"},{"name":"Kỳ Lăng","name_vi":null,"name_original":"Kỳ Lăng"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tinh-yeu-va-am-muu-2.json"}