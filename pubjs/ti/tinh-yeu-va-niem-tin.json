ừa kế mà cha mẹ Zuleika để lại, chính là mảnh đất của trại trẻ mồ côi. Lúc này, cô rơi vào tình cảnh khó khăn trong hôn nhân...</p>","tmdb":{"type":"tv","id":"257555","season":1,"vote_average":0,"vote_count":0},"modified":"2025-10-16T09:44:08.000Z","cast":["Elisya Sandha","Azrel Ismail","Johan As'ari","Scha Elinnea"],"director":[],"cast_meta":[{"name":"Elisya Sandha","name_vi":null,"name_original":"Elisya Sandha","tmdb_id":2321922,"profile":"https://image.tmdb.org/t/p/w500/mmrMhinWi6JUbqPdSdBMiABlDvM.jpg","tmdb_url":"https://www.themoviedb.org/person/2321922"},{"name":"Azrel Ismail","name_vi":null,"name_original":"Azrel Ismail","tmdb_id":1283207,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1283207"},{"name":"Johan As'ari","name_vi":null,"name_original":"Johan As'ari","tmdb_id":1271796,"profile":"https://image.tmdb.org/t/p/w500/zzejtxETCK29vqUPvoNiN4LV3wy.jpg","tmdb_url":"https://www.themoviedb.org/person/1271796"},{"name":"Scha Elinnea","name_vi":null,"name_original":"Scha Elinnea","tmdb_id":2019604,"profile":"https://image.tmdb.org/t/p/w500/glpGX0STDkzbYF3xHu14oY6g3kC.jpg","tmdb_url":"https://www.themoviedb.org/person/2019604"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ti/tinh-yeu-va-niem-tin.json"}