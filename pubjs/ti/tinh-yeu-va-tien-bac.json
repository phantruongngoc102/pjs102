53","filename":"Kara Para Ask 53","link_embed":"https://vip.opstream13.com/share/748ba69d3e8d1af87f84fee909eef339","link_m3u8":"https://vip.opstream13.com/20231109/1535_25181b12/index.m3u8"},{"name":"54","slug":"54","filename":"Kara Para Ask 54","link_embed":"https://vip.opstream13.com/share/aff0a6a4521232970b2c1cf539ad0a19","link_m3u8":"https://vip.opstream13.com/20231110/1546_ca885bb6/index.m3u8"}]}],"time":"130 phút/tập","description":"<p>Ömer là cảnh sát. Sau cái chết của vợ sắp cưới, anh phải chịu đựng rất nhiều đau đớn. Thi thể của Sibel, vợ chưa cưới của Ömer, được tìm thấy trên đỉnh một vách đá, trong một chiếc ô tô cạnh một doanh nhân khá già, giàu có. Sau cú sốc về cái chết đột ngột của cô và những cáo buộc về tình yêu lừa dối mình, Ömer nhận ra rằng còn nhiều điều đằng sau vụ giết người đáng ngờ của cô.</p>","tmdb":{"type":"tv","id":"60929","season":1,"vote_average":8.2,"vote_count":45},"modified":"2023-11-10T15:00:06.000Z","cast":["Engin Akyürek","Tuba Büyüküstün","Erkan Can","Saygın Soysal","Burak Tamdoğan","Bestemsu Özdemir","Elif İnci","Ali Yörenç","Ahmet Tansu Taşanlar","İlkin Tüfekçi","Güler Ökten","Hazal Türesan","Işıl Yücesoy","Öykü Karayel","Kürşat Kurnaz"],"director":[],"cast_meta":[{"name":"Engin Akyürek","name_vi":null,"name_original":"Engin Akyürek","tmdb_id":1004806,"profile":"https://image.tmdb.org/t/p/w500/oynWT3byuD2t6DUaCkS9dr84cqQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1004806"},{"name":"Tuba Büyüküstün","name_vi":null,"name_original":"Tuba Büyüküstün","tmdb_id":142855,"profile":"https://image.tmdb.org/t/p/w500/7EgdthwcD5uCSOg0YWivuQ5kyK6.jpg","tmdb_url":"https://www.themoviedb.org/person/142855"},{"name":"Erkan Can","name_vi":null,"name_original":"Erkan Can","tmdb_id":90282,"profile":"https://image.tmdb.org/t/p/w500/oioTwnpigGCUR3LBGeqYQxp5DMt.jpg","tmdb_url":"https://www.themoviedb.org/person/90282"},{"name":"Saygın Soysal","name_vi":null,"name_original":"Saygın Soysal","tmdb_id":1251169,"profile":"https://image.tmdb.org/t