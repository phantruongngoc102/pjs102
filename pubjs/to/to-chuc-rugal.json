2","link_m3u8":"https://vip.opstream16.com/20220403/6001_d84d4107/index.m3u8"}]}],"time":"60 phút / tập","description":"<p><strong>Tổ Chức Rugal</strong> xoay quanh Kang Ki Bum (Choi Jin Hyuk), vốn là một cảnh sát giỏi nhưng trong khi đang điều tra về tổ chức Argos thì bị người của Argos tìm đến tiêu diệt. Cả vợ và con anh đều bị sát hại, còn anh thì bị làm cho mù mắt. Khi tỉnh lại, Ki Bum bị buộc tội giết chính vợ con mình. Trong tình thế tuyệt vọng, NIS tìm đến Ki Bum và kết nạp anh vào đội Rugal - một nhóm người đặc biệt lãnh nhiệm vụ đánh sập tổ chức tội phạm Argos.</p>","tmdb":{"type":"tv","id":"97766","season":1,"vote_average":6.9,"vote_count":54},"modified":"2023-04-16T15:05:58.000Z","cast":["Choi Jin-hyuk","Park Sung-woong","Cho Dong-hyuk","Jung Hye-in","Kim Min-sang","Park Sun-ho","Park Jeong-hak","Ji Dae-han","Kim In-woo","Jang In-sub","Kim Da-hyun","Han Ji-Wan","Jang Seo-kyung","Yoo Ji-yeon"],"director":["Kang Cheol Woo"],"cast_meta":[{"name":"Choi Jin-hyuk","name_vi":null,"name_original":"Choi Jin-hyuk","tmdb_id":1330916,"profile":"https://image.tmdb.org/t/p/w500/lb8NIxnrczxN24i82wsZ5zOxsi.jpg","tmdb_url":"https://www.themoviedb.org/person/1330916"},{"name":"Park Sung-woong","name_vi":null,"name_original":"Park Sung-woong","tmdb_id":139493,"profile":"https://image.tmdb.org/t/p/w500/nyCMZSOV1P4GtRo9svoDwHl19WO.jpg","tmdb_url":"https://www.themoviedb.org/person/139493"},{"name":"Cho Dong-hyuk","name_vi":null,"name_original":"Cho Dong-hyuk","tmdb_id":1255801,"profile":"https://image.tmdb.org/t/p/w500/kS6Wu70u5wrzLvCaWgSJI8cfWPM.jpg","tmdb_url":"https://www.themoviedb.org/person/1255801"},{"name":"Jung Hye-in","name_vi":null,"name_original":"Jung Hye-in","tmdb_id":1530162,"profile":"https://image.tmdb.org/t/p/w500/3cjehNLCmGzESl5FYZo9ogU0Kdj.jpg","tmdb_url":"https://www.themoviedb.org/person/1530162"},{"name":"Kim Min-sang","name_vi":null,"name_original":"Kim Min-sang","tmdb_id":1294797,"profile":"https://image.tmdb.org/t/p/w500/rBEVIyOVfYxtaHZWSwKvi8mhs1r.j