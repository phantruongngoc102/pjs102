ẳng có gì. Anh cần 1 cộng sự thông minh và nhạy bén. Và một ngày, anh gặp Mike Ross. Mike Ross: một anh chàng luôn ấp ủ ước mơ trở thành 1 luật sư tài giỏi.</p>","tmdb":{"type":"tv","id":"37680","season":1,"vote_average":8.222,"vote_count":5513},"modified":"2023-06-26T17:02:07.000Z","cast":["Gabriel Macht","Rick Hoffman","Sarah Rafferty","Amanda Schull","Dulé Hill","Katherine Heigl"],"director":["Tim Matheson","Kevin Bray","Jennifer Getzinger","Terry Mcdonough","John Scott","Felix Alcala","Kate Woods","Mike Smith","Norberto Barba","Dennie Gordon"],"cast_meta":[{"name":"Gabriel Macht","name_vi":null,"name_original":"Gabriel Macht","tmdb_id":16856,"profile":"https://image.tmdb.org/t/p/w500/lacMH4Ju1x9AsKXm7mDkklSsPyV.jpg","tmdb_url":"https://www.themoviedb.org/person/16856"},{"name":"Rick Hoffman","name_vi":null,"name_original":"Rick Hoffman","tmdb_id":1216133,"profile":"https://image.tmdb.org/t/p/w500/c9CKBkLtGtW1T8GRNUid0tQHaJY.jpg","tmdb_url":"https://www.themoviedb.org/person/1216133"},{"name":"Sarah Rafferty","name_vi":null,"name_original":"Sarah Rafferty","tmdb_id":154856,"profile":"https://image.tmdb.org/t/p/w500/Am3yPjKVbGWWn2Q1SB5wPz3yzgV.jpg","tmdb_url":"https://www.themoviedb.org/person/154856"},{"name":"Amanda Schull","name_vi":null,"name_original":"Amanda Schull","tmdb_id":65871,"profile":"https://image.tmdb.org/t/p/w500/1u0zGqSDaWOQVYmnpUCmEZ50oJP.jpg","tmdb_url":"https://www.themoviedb.org/person/65871"},{"name":"Dulé Hill","name_vi":null,"name_original":"Dulé Hill","tmdb_id":122756,"profile":"https://image.tmdb.org/t/p/w500/fPJ8lIx6WwBgO2AhnHQSeiZiAUy.jpg","tmdb_url":"https://www.themoviedb.org/person/122756"},{"name":"Katherine Heigl","name_vi":null,"name_original":"Katherine Heigl","tmdb_id":25541,"profile":"https://image.tmdb.org/t/p/w500/hjtNdbdy1qn25y5SGl71y8nR0Kg.jpg","tmdb_url":"https://www.themoviedb.org/person/25541"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/to/to-tung-phan-1.json