áp luật.</p><p>&nbsp;</p>","tmdb_id":261675,"cast":["Cung Tuấn","Nhậm Mẫn","Huang Lu","Han Yunyun","Phạm Trương","Zhang Cheng","Wang Gongliang","Zhou Yangyang","Jie Bing","Cady Yang"],"director":["Xie Dongshen"],"keywords":[],"tmdb":{"type":"tv","id":"261675","season":1,"vote_average":6.5,"vote_count":6},"cast_meta":[{"name":"Cung Tuấn","name_vi":"Cung Tuấn","name_original":"Gong Jun","tmdb_id":1820070,"profile":"https://image.tmdb.org/t/p/w500/rtjBdEF61NySmDDnoDgAtuclAJJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1820070"},{"name":"Nhậm Mẫn","name_vi":"Nhậm Mẫn","name_original":"Ren Min","tmdb_id":2174695,"profile":"https://image.tmdb.org/t/p/w500/3PKeDlZVW3b3R0dBjfqvxtHOXRn.jpg","tmdb_url":"https://www.themoviedb.org/person/2174695"},{"name":"Huang Lu","name_vi":null,"name_original":"Huang Lu","tmdb_id":131246,"profile":"https://image.tmdb.org/t/p/w500/rFWjgjRJbNzKwIIc8glQbsAFTGi.jpg","tmdb_url":"https://www.themoviedb.org/person/131246"},{"name":"Han Yunyun","name_vi":null,"name_original":"Han Yunyun","tmdb_id":3080664,"profile":"https://image.tmdb.org/t/p/w500/1hlkQ9QpF9gbpGK6uZ7UYkNprz8.jpg","tmdb_url":"https://www.themoviedb.org/person/3080664"},{"name":"Phạm Trương","name_vi":"Phạm Trương","name_original":"Zhang Fan","tmdb_id":2027655,"profile":"https://image.tmdb.org/t/p/w500/rsESxwWDrHpakybSNO7AtHaI35y.jpg","tmdb_url":"https://www.themoviedb.org/person/2027655"},{"name":"Zhang Cheng","name_vi":null,"name_original":"Zhang Cheng","tmdb_id":1335024,"profile":"https://image.tmdb.org/t/p/w500/cbPesoTv20CrA1VzqLlIVrP254O.jpg","tmdb_url":"https://www.themoviedb.org/person/1335024"},{"name":"Wang Gongliang","name_vi":null,"name_original":"Wang Gongliang","tmdb_id":2320652,"profile":"https://image.tmdb.org/t/p/w500/bcxiu4QYF2PBLdpJtnSVeyosyyZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2320652"},{"name":"Zhou Yangyang","name_vi":null,"name_original":"Zhou Yangyang","tmdb_id":4922346,"profile":"https://image.tmdb.org/t/p/w500/aWIe06EWAdK26TRh7y1Eu30ZFq