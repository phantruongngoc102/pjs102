ttps://vip.opstream17.com/share/6b4a9e228208a5008088d8ad6e1b3dd7","link_m3u8":"https://vip.opstream17.com/20240727/15787_da154210/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/1d0155b49e8121154701476d893aa0a7","link_m3u8":"https://vip.opstream17.com/20240727/15788_d95b1812/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/8a27c2ddc3d3fe74aa037f4b7d262e34","link_m3u8":"https://vip.opstream17.com/20240727/15789_83ba1d4c/index.m3u8"}]}],"description":"LUẬT LIK-AH từng chiến đấu vì danh tiếng cá nhân và đạt được lợi ích trong lĩnh vực luật. Sau khi thành lập Trung tâm Tư vấn Pháp lý với người anh họ GEORGE MIKE JR. (Lâm Chí Sin) và người bạn tốt của mình TING KA-FU ở Sham Shui Po, LIK-AH thay đổi ý định và nhận ra rằng luật pháp không phải là đặc quyền của người giàu. Bằng cách giúp đỡ cơ sở đấu tranh chống lại sự bất công bằng những chiến thuật độc đáo, LIK-AH trở thành Anh hùng của nhân dân Sham Shui Po. Cũng làm luật sư, WONG SZ-FU (Hồ Hạnh Nhi) từng ngưỡng mộ LIK-AH vì màn trình diễn bất khả chiến bại của anh ấy trong lĩnh vực này nhưng cô ấy bắt đầu coi thường anh ấy vì anh ấy đã bị biến thành luật sư khu ổ chuột. Tuy nhiên, sau một vài phiên tòa với anh ta, cả hai bắt đầu cảm kích và yêu nhau.","tmdb_id":39595,"cast":["Trịnh Gia Dĩnh","Hồ Hạnh Nhi","Lâm Tử Thiện","Lý Xán Sâm","Tào Vĩnh Liêm","JJ Jia"],"director":["Lương Gia Thụ"],"keywords":[],"tmdb":{"type":"tv","id":"39595","season":1,"vote_average":8.4,"vote_count":5},"cast_meta":[{"name":"Trịnh Gia Dĩnh","name_vi":"Trịnh Gia Dĩnh","name_original":"Kevin Cheng Ka-Wing","tmdb_id":1140044,"profile":"https://image.tmdb.org/t/p/w500/rzT8YmWjBRbrfXii9is8uZAbiBQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1140044"},{"name":"Hồ Hạnh Nhi","name_vi":"Hồ Hạnh Nhi","name_original":"Myolie Wu Hang-Yee","tmdb_id":938251,"profile":"https://image.tmdb.org/t/p/w500/dKfRqzeGLu8eYtg9Sf4KyD7VVPH.jpg","tmdb_url":"https://www.themoviedb.org/person/9382