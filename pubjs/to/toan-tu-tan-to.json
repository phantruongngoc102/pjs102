ink_embed":"https://vip.opstream15.com/share/814780edbfedcd6356e9be7786960e64","link_m3u8":"https://vip.opstream15.com/20230502/38636_92e8c4a4/index.m3u8"},{"name":"16","slug":"16","filename":"toan-tu-tan-to-tap-16","link_embed":"https://vip.opstream15.com/share/3fa14c8a59cc0c01c983bb7cbdce16d5","link_m3u8":"https://vip.opstream15.com/20230502/38635_84e2933f/index.m3u8"},{"name":"17","slug":"17","filename":"toan-tu-tan-to-tap-17","link_embed":"https://vip.opstream15.com/share/59039a3b52d947c16b7eb0060d7b57ea","link_m3u8":"https://vip.opstream15.com/20230502/38637_535fbd5c/index.m3u8"},{"name":"18","slug":"18","filename":"toan-tu-tan-to-tap-18","link_embed":"https://vip.opstream15.com/share/a74e65df39b527b7cf3a888cfda196f5","link_m3u8":"https://vip.opstream15.com/20230502/38638_f25aa874/index.m3u8"},{"name":"19","slug":"19","filename":"toan-tu-tan-to-tap-19","link_embed":"https://vip.opstream15.com/share/9fbea88c76d0e1fca62216774396348a","link_m3u8":"https://vip.opstream15.com/20230502/38639_f877ad31/index.m3u8"},{"name":"20","slug":"20","filename":"toan-tu-tan-to-tap-20","link_embed":"https://vip.opstream15.com/share/707ea698e94199fea00950703d3d844b","link_m3u8":"https://vip.opstream15.com/20230502/38640_cdce7d66/index.m3u8"},{"name":"21","slug":"21","filename":"toan-tu-tan-to-tap-21","link_embed":"https://vip.opstream15.com/share/5cd580b09d20ca28f5aeaeb0d505bc6d","link_m3u8":"https://vip.opstream15.com/20230502/38641_781ed502/index.m3u8"},{"name":"22","slug":"22","filename":"toan-tu-tan-to-tap-22","link_embed":"https://vip.opstream15.com/share/b948e956cdb4dc29954c5a3d5e5d5309","link_m3u8":"https://vip.opstream15.com/20230502/38645_4d985157/index.m3u8"},{"name":"23","slug":"23","filename":"toan-tu-tan-to-tap-23","link_embed":"https://vip.opstream15.com/share/4d3d68218084db39aa3c734ead6aaa31","link_m3u8":"https://vip.opstream15.com/20230502/38643_4742701b/index.m3u8"},{"name":"24","slug":"24","filename":"toan-tu-tan-to-tap-24","link_embed":"https://vip.opstream15.com/share/f1551a3b0b447d1a7436c8a1fcb117bb","link_m3u8":"https://vip.opstream15.com/20230502/38648_acc8adb3/index.m3u8"}]}],"time":"11M33S","description":"Đây là câu chuyện về một nhà tư bản giàu trí tưởng tượng, người đã tài trợ toàn bộ cho một đội sản xuất để thực hiện ước mơ trở thành nam chính trong các bộ phim truyền hình cổ trang. Việc viết lại kịch bản một cách điên cuồng của anh ấy dẫn đến một cốt truyện rời rạc. Nhà biên kịch thấp hèn và tội nghiệp bất lực để chống lại, cố gắng lấp đầy những khoảng trống và sự mâu thuẫn trong tuyệt vọng mặc dù họ sắp rụng hết tóc. Kết quả là một sự khác biệt hoàn toàn so với phong cách ban đầu, với việc phát triển nhân vật liên tục không hiệu quả. Từ cung đình đến trinh thám, từ trinh thám đến kỳ ảo, từ kỳ ảo đến võ hiệp, từ võ hiệp đến cuộc sống cung đình, từ cuộc sống cung đình đến xuyên không... xuyên phá bức tường không gian. Tất cả các thể loại phim truyền hình lịch sử tập hợp lại với nhau, chuyển hướng thành một chủ đề đa dạng. Với những nỗ lực của họ, thể loại giả tưởng sẽ lần đầu tiên được xuất hiện, linh hồn nam chính mặt lạnh kỳ thật là một mảnh băng cổ tồn tại mấy ngàn năm; hậu cung phi thường hài hòa, tình nghĩa chị em sâu nặng; quá trình phá án của các cận vệ hoàng gia đầy hồi hộp nhưng kẻ sát nhân không bao giờ được tìm thấy trong suốt bộ phim; một thư sinh trên đường đến kỳ thi hoàng gia bất ngờ đăng quang quán quân của thế giới võ lâm thông qua một khoản đầu tư của một cô gái giàu có; cáo nam vừa thiện vừa ác, và nữ thợ săn yêu quái thường xuyên thay đổi tính cách, không thể cưỡng lại cám dỗ và trở thành kẻ thù vì tình yêu. Ngay cả con chó của bạn nhân vật chính, được mang đến phim trường trong một chuyến thăm, cũng được biến thành một linh hồn để thêm vào câu chuyện, với một tình tiết phụ lãng mạn được thêm vào... Tuy nhiên, đằng sau tất cả sự phi lý, bạn sẽ phát hiện ra rằng anh ấy là một diễn viên đang theo đuổi ước mơ của mình và cứu chuộc với niềm đam mê không thể kiềm chế.","tmdb":{"type":"tv","id":"225468","season":1,"vote_average":6,"vote_count":1},"modified":"2023-05-03T01:22:06.000Z","cast":["Chen Tengyue","Tào Hi Nguyệt","Wang Jiali","Solange Maggie","Jin Luying","Ma Fei","Tôn Nghệ Nhiên","Xiang Xin","Zhang Wanfang","Li Fengwei","Zhuo Yi Na Mu"],"director":["Ba Chen Xu"],"cast_meta":[{"name":"Chen Tengyue","name_vi":null,"name_original":"Chen Tengyue","tmdb_id":2860989,"profile":"https://image.tmdb.org/t/p/w500/bkR4o4VabsHSNTHXsz6Df8fjr39.jpg","tmdb_url":"https://www.themoviedb.org/person/2860989"},{"name":"Tào Hi Nguyệt","name_vi":"Tào Hi Nguyệt","name_original":"Cao Xiyue","tmdb_id":1516524,"profile":"https://image.tmdb.org/t/p/w500/1r1iNWndh8wfOT3lPKGm3NC1sDI.jpg","tmdb_url":"https://www.themoviedb.org/person/1516524"},{"name":"Wang Jiali","name_vi":null,"name_original":"Wang Jiali","tmdb_id":2689643,"profile":"https://image.tmdb.org/t/p/w500/xsa8JNrmuIabauktlJncAySni2q.jpg","tmdb_url":"https://www.themoviedb.org/person/2689643"},{"name":"Solange Maggie","name_vi":null,"name_original":"Solange Maggie","tmdb_id":3005954,"profile":"https://image.tmdb.org/t/p/w500/snQ7Xty40OZz9owusUo2ulJshQK.jpg","tmdb_url":"https://www.themoviedb.org/person/3005954"},{"name":"Jin Luying","name_vi":null,"name_original":"Jin Luying","tmdb_id":2691755,"profile":"https://image.tmdb.org/t/p/w500/fgVMMH2t03xafRYrKVDW2cX1OQh.jpg","tmdb_url":"https://www.themoviedb.org/person/2691755"},{"name":"Ma Fei","name_vi":null,"name_original":"Ma Fei","tmdb_id":4391182,"profile":"https://image.tmdb.org/t/p/w500/yxVnS4jToA4e6byYvN99w2J06Ll.jpg","tmdb_url":"https://www.themoviedb.org/person/4391182"},{"name":"Tôn Nghệ Nhiên","name_vi":"Tôn Nghệ Nhiên","name_original":"Sun Yiran","tmdb_id":4908598,"profile":"https://image.tmdb.org/t/p/w500/dSosVsN6Kvjn8gE3Fz9XuarrxGt.jpg","tmdb_url":"https://www.themoviedb.org/person/4908598"},{"name":"Xiang Xin","name_vi":null,"name_original":"Xiang Xin","tmdb_id":3885682,"profile":"https://image.tmdb.org/t/p/w500/uTlqf8bXQvYOfL98M5hprIDTO5c.jpg","tmdb_url":"http