com/20220305/983_f5c79b76/index.m3u8"},{"name":"6","slug":"6","link_embed":"https://vip.opstream11.com/share/287e03db1d99e0ec2edb90d079e142f3","link_m3u8":"https://vip.opstream11.com/20220305/981_02eee6ce/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream11.com/share/fec8d47d412bcbeece3d9128ae855a7a","link_m3u8":"https://vip.opstream11.com/20220305/982_24031d20/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream11.com/share/d93ed5b6db83be78efb0d05ae420158e","link_m3u8":"https://vip.opstream11.com/20220305/984_41aeb9e6/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream11.com/share/54a367d629152b720749e187b3eaa11b","link_m3u8":"https://vip.opstream11.com/20220305/985_48067d2e/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream11.com/share/df6d2338b2b8fce1ec2f6dda0a630eb0","link_m3u8":"https://vip.opstream11.com/20220305/987_772a46d0/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream11.com/share/9908279ebbf1f9b250ba689db6a0222b","link_m3u8":"https://vip.opstream11.com/20220305/988_37992eb5/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream11.com/share/fe7ee8fc1959cc7214fa21c4840dff0a","link_m3u8":"https://vip.opstream11.com/20220305/986_da5d7345/index.m3u8"}]}],"description":"<p>Was Kidnapped by a Young Lady's School to be a Sample of the Common People | Ore ga Ojou-sama Gakkou ni Shomin Sample Toshite Rachirareta Ken. Trong câu chuyện, Kagurazaka Kimito, một nam sing phổ thông tầm thường bị một học viện kín dành cho nữ sinh thuộc con nhà danh giá bắt cóc, để trở thành mẫu vật điển hình cho thường dân. Ngôi trường này toàn những nữ sinh được bao bọc che chở, chưa từng gặp nam sinh cùng trang lứa bao giờ, nên các học viên ra trường rất khó hòa nhập với cuộc sống. Kimito được đem đến trường như là một cách giới thiệu cho các nữ sinh về thế giới bên ngoài.&nbsp;</p><p>Ichijinsha xuất bản tập đầu tiên của bộ tiểu thuyết vào tháng 3 năm 2013, và bộ đến nay đã có 8 tập được phát hành. Phiên bản đặc biệt của tập thứ 7 có di kèm một đĩa drama CD. Gekka Urū đã thiết kế nhân vật cho bộ tiểu thuyết, và Risumai đã thực hiện một bản chuyển thể manga trong tạp chí Monthly Comic Rex của Ichijinsha. Tập thứ 5 của bộ manga sẽ phát hành vào ngày 18 tháng 7 tới tại Nhật Bản.&nbsp;</p><p>Ichijinsha vừa công bố một bản chuyển thể anime cho bộ tiểu thuyết Ore ga Ojō-Sama Gakkō ni 'Shomin Sample' Toshite Usarareta Ken (Story in Which I Was Kidnapped by a Young Lady's School to be a Sample of the Common People) của Takafumi Nanatsuki.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/to/toi-da-bi-bat-vao-truong-cua-cac-tieu-thu-lam-thuong-dan-tieu-bieu-nhu-the-nao.json","tmdb_checked":false}