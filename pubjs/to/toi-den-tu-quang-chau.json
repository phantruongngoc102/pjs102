//vip.opstream12.com/share/8ebef38fe0b242f7c7a87e7f5b2de305","link_m3u8":"https://vip.opstream12.com/20251220/31230_8ebef38f/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream12.com/share/f80f574e584495515259692b741b890e","link_m3u8":"https://vip.opstream12.com/20251220/31231_f80f574e/index.m3u8"}]}],"description":"<p>Phim kể về hành trình của một người đàn ông đến từ Quảng Châu sang Hồng Kông để lập nghiệp, tìm kiếm cơ hội và đối mặt với sự khác biệt văn hóa, lối sống cùng những định kiến xã hội.<br>Qua những thăng trầm trong công việc, tình cảm và các mối quan hệ gia đình, bộ phim khắc họa sâu sắc hình ảnh con người Trung Hoa trong thời kỳ giao thoa kinh tế, khi giá trị truyền thống và hiện đại liên tục va chạm.<br>“Tôi Đến Từ Quảng Châu” là câu chuyện xúc động về nghị lực, lòng nhân ái và khát vọng vươn lên giữa thành phố phồn hoa nhưng đầy thử thách.</p>","tmdb_id":109092,"cast":["Nathan Chan Ting-Wai","Văn Tụng Nhàn","Âu Cẩm Đường","Linda Wong Hing-Ping","Lưu Tích Hiền","Viên Văn Kiệt","Đỗ Vấn Trạch"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"109092","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Nathan Chan Ting-Wai","name_vi":null,"name_original":"Nathan Chan Ting-Wai","tmdb_id":2593751,"profile":"https://image.tmdb.org/t/p/w500/qJFMV4djjEXDN5pXgPwWEWEgayv.jpg","tmdb_url":"https://www.themoviedb.org/person/2593751"},{"name":"Văn Tụng Nhàn","name_vi":"Văn Tụng Nhàn","name_original":"Annie Man Chung-Han","tmdb_id":125103,"profile":"https://image.tmdb.org/t/p/w500/jwUk0tNZUjCUSBpY7Br5An495nt.jpg","tmdb_url":"https://www.themoviedb.org/person/125103"},{"name":"Âu Cẩm Đường","name_vi":"Âu Cẩm Đường","name_original":"Stephen Au Kam-Tong","tmdb_id":987587,"profile":"https://image.tmdb.org/t/p/w500/jSONQ4UlIaC0nD9EDXfJvU8Njs0.jpg","tmdb_url":"https://www.themoviedb.org/person/987587"},{"name":"Linda Wong Hing-Ping","name_vi":null,"name_original":"Linda Wong Hing-Ping","tmdb_id":1401222,"profile":"https://image.tmdb