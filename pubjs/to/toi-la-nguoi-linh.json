{"id":"642f9e63839826002421d4fb","title":"Tôi Là Người Lính","origin_name":"I Am Soldier","slug":"toi-la-nguoi-linh","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/to/toi-la-nguoi-linh.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/to/toi-la-nguoi-linh.webp","year":2014,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2253e0fc277084dfd339","name":"Chiến Tranh","slug":"chien-tranh"},{"id":"620f84d291fa4af90ab6b3f4","name":"Bí ẩn","slug":"bi-an"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"I Am Soldier - Tôi Là Chiến Binh - 2014","link_embed":"https://vip.opstream14.com/share/b043afb8c56c57b7a4015bbc613de3d4","link_m3u8":"https://vip.opstream14.com/20230407/34954_176d6c7f/index.m3u8"}]}],"time":"84 Phút","description":"Mickey Tomlinson, một đầu bếp quân đội, cố gắng thực hiện cuộc tuyển chọn quân sự nguy hiểm nhất mà con người từng biết: Cuộc tuyển chọn của Lực lượng Hàng không Đặc biệt (S.A.S.). S.A.S. Là Trung đoàn Lực lượng Đặc biệt nổi tiếng nhất của Vương quốc Anh, được giao nhiệm vụ đe dọa tính mạng ở một số nơi nguy hiểm nhất hành tinh. Mickey có nhiều kinh nghiệm quân sự hơn là chỉ đơn giản là trở thành một đầu bếp, điều mà các ứng cử viên khác không cho phép... Mickey bị phá vỡ bởi quá trình lựa chọn này - tâm trí, cơ thể và linh hồn của anh ấy kêu gào sự thương xót khi anh ấy phải chịu đựng những cuộc hành quân thần tốc đầy tra tấn. những ngọn núi dốc nhất, chạy thục mạng trong quá trình 'Trốn thoát và Trốn tránh' và sau đó đối mặt với cuộc thẩm vấn độc ác nhất có thể, trong giai đoạn chết người được gọi là: 'Câu hỏi Chiến thuật'. Ngay cả sau tất cả, vẫn chỉ có một cách duy nhất để bạn có thể thực sự chứng tỏ bản thân: trong chiến đấu... Nhiều người cố gắng gia nhập S.A.S. Chỉ có giới thượng lưu làm cho nó.","tmdb":{"type":"movie","id":"259453","season":null,"vote_average":5.012,"vote_count":82},"modified":"2023-04-07T11:39:05.000Z","cast":["Noel Clarke","Philip Desmeules","Duncan Casey","Lee Charles","Jordan Long","Allistair McNab","Josh Myers","Ian Pirie","Tom Hughes","Miranda Raison","Alex Reid","George Russo","Joe Egan"],"director":["Ronnie Thompson"],"cast_meta":[{"name":"Noel Clarke","name_vi":null,"name_original":"Noel Clarke","tmdb_id":76242,"profile":"https://image.tmdb.org/t/p/w500/B4VwUzthFfF4g2cr8xdyz7n3Vp.jpg","tmdb_url":"https://www.themoviedb.org/person/76242"},{"name":"Philip Desmeules","name_vi":null,"name_original":"Philip Desmeules","tmdb_id":1077056,"profile":"https://image.tmdb.org/t/p/w500/sCMqRwGxSdvjlEZHBZEObLHs6TL.jpg","tmdb_url":"https://www.themoviedb.org/person/1077056"},{"name":"Duncan Casey","name_vi":null,"name_original":"Duncan Casey","tmdb_id":1301637,"profile":"https://image.tmdb.org/t/p/w500/sSt1Ws5ZaISgTKGbcrSdSkHm30K.jpg","tmdb_url":"https://www.themoviedb.org/person/1301637"},{"name":"Lee Charles","name_vi":null,"name_original":"Lee Charles","tmdb_id":1301638,"profile":"https://image.tmdb.org/t/p/w500/hPcEeF8mG9PiOJmnduVjq9yH9jD.jpg","tmdb_url":"https://www.themoviedb.org/person/1301638"},{"name":"Jordan Long","name_vi":null,"name_original":"Jordan Long","tmdb_id":199529,"profile":"https://image.tmdb.org/t/p/w500/ew39mDa4vhhylYnRg5nC8USOwTf.jpg","tmdb_url":"https://www.themoviedb.org/person/199529"},{"name":"Allistair McNab","name_vi":null,"name_original":"Allistair McNab","tmdb_id":1265256,"profile":"https://image.tmdb.org/t/p/w500/qJpndTc9zvztS7K1UYPuVc63Ied.jpg","tmdb_url":"https://www.themoviedb.org/person/1265256"},{"name":"Josh Myers","name_vi":null,"name_original":"Josh Myers","tmdb_id":1109987,"profile":"https://image.tmdb.org/t/p/w500/5BD8lkmI