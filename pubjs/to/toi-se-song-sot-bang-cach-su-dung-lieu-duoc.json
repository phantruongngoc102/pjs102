2/37263_7ef7f6f6/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream11.com/share/23d2018fbeae92114a4f4ff189549215","link_m3u8":"https://vip.opstream11.com/20231119/49324_dc300dfe/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream16.com/share/5ec89c93544667a23507e34238fc74a7","link_m3u8":"https://vip.opstream16.com/20231127/38159_83a6544c/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream16.com/share/cb4fb8ff74d13fd168c9d16414c08b8c","link_m3u8":"https://vip.opstream16.com/20231203/38514_fa2bd6a2/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream16.com/share/8d3d1357e96a141b8e89b161dc774a47","link_m3u8":"https://vip.opstream16.com/20231210/38916_9ade775c/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream16.com/share/61a018642a904c166b8949cac36e1177","link_m3u8":"https://vip.opstream16.com/20231217/39309_ab7368dc/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream16.com/share/149994a079ddd43eab8cb827dfae9d1f","link_m3u8":"https://vip.opstream16.com/20231224/39799_74eab219/index.m3u8"}]}],"description":"<p>Kể về Kaoru Nagase, một cô gái bình thường sống trên Trái Đất. Một ngày nọ, những người giám sát chăm sóc Trái Đất phạm một sai lầm đáng kể, khiến cô bị mất cơ thể của mình. Nhưng thay vì kết thúc tại đó, Kaoru được tái sinh vào một thế giới hoàn toàn khác, nơi văn hóa và công nghệ khác biệt hoàn toàn.Không phục lòng với việc trở thành một phần của thế giới mới này, Kaoru đặt ra một yêu cầu đầy thách thức: cô muốn có khả năng tạo ra độc dược bất cứ lúc nào với bất kỳ tác dụng nào mà cô muốn.&nbsp;</p><p>Nhưng yêu cầu của cô không dừng lại ở đó. Kaoru còn đòi một Hộp vật phẩm ma thuật, khả năng hiểu và nói mọi ngôn ngữ, và thậm chí một cơ thể trẻ trung hơn khi cô còn là một cô gái mười lăm tuổi.Với sức mạnh mới tìm thấy, Kaoru phải tạo nên một cuộc sống mới và ổn định cho chính mình trong một thế giới xa lạ. Cô sử dụng kiến thức về liều dược và ma thuật để chống lại những thách thức của thế giới mới này và tìm kiếm mục tiêu sống sót và thịnh vượng.</p>","tmdb_id":221148,"cast":["Rin Kusumi","Tomoyo Takayanagi","Moeka Koizumi","Haruki Iwata","Natsuki Kitagawa"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"221148","season":1,"vote_average":7.3,"vote_count":24},"cast_meta":[{"name":"Rin Kusumi","name_vi":null,"name_original":"Rin Kusumi","tmdb_id":3068827,"profile":"https://image.tmdb.org/t/p/w500/iHmZQsCaVgTkwz8zeYheSb1aYCQ.jpg","tmdb_url":"https://www.themoviedb.org/person/3068827"},{"name":"Tomoyo Takayanagi","name_vi":null,"name_original":"Tomoyo Takayanagi","tmdb_id":2394855,"profile":"https://image.tmdb.org/t/p/w500/hc7zoKWJMwUBLCZEKXro6TotqZS.jpg","tmdb_url":"https://www.themoviedb.org/person/2394855"},{"name":"Moeka Koizumi","name_vi":null,"name_original":"Moeka Koizumi","tmdb_id":2241364,"profile":"https://image.tmdb.org/t/p/w500/crKuaBWCvM4aMESbvQ6JNZ69Vyf.jpg","tmdb_url":"https://www.themoviedb.org/person/2241364"},{"name":"Haruki Iwata","name_vi":null,"name_original":"Haruki Iwata","tmdb_id":2241362,"profile":"https://image.tmdb.org/t/p/w500/8RLhDmrskY3p2xlMgVkL6Kh8jUg.jpg","tmdb_url":"https://www.themoviedb.org/person/2241362"},{"name":"Natsuki Kitagawa","name_vi":null,"name_original":"Natsuki Kitagawa","tmdb_id":3490235,"profile":"https://image.tmdb.org/t/p/w500/atvRZduBUewOK5HDK3LkCqObcai.jpg","tmdb_url":"https://www.themoviedb.org/person/3490235"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/to/toi-se-song-sot-bang-cach-su-dung-lieu-duoc.json"}