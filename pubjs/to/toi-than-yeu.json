pstream11.com/share/314e9197a43a6d40cef6f1629e2c3721","link_m3u8":"https://vip.opstream11.com/20220419/17137_d62cd5bd/index.m3u8"}]}],"time":"46 phút/tập","description":"<p>\"Tôi Thân Yêu - To Dear Myself\" là dự án truyền hình đánh dấu sự trở lại của \"ngọc nữ\" màn ảnh Lưu Thi Thi sau hơn ba năm vắng bóng kể từ sau thành công của bộ phim Túy Linh Lung. Đây cũng là lần hợp tác đầu tiên của Lưu Thi Thi và Chu Nhất Long - nam thần \"bạo hồng\" nhờ vai diễn thầy giáo Thẩm Ngụy trong \"Trấn Hồn\". Bộ phim kể câu chuyện về người trẻ tuổi trong thành thị - những người trải qua đấu tranh để thay đổi và trưởng thành dưới sự bao vây của sự nghiệp, gia đình, tình yêu... và cuối cùng họ đã tìm thấy cách sống phù hợp nhất với bản thân mình.</p>","tmdb":{"type":"tv","id":"109288","season":1,"vote_average":6,"vote_count":1},"modified":"2024-11-23T11:17:58.000Z","cast":["Lưu Thi Thi","Chu Nhất Long","Hám Thanh Tử","Bành Quán Anh","Chen Miqi","Lý Trạch Phong","Zhang Yao","Trạch Tử Lộ","Yao Lu","Che Xiao","Lin Peng","Gao Ziqi","Zhu Yaying"],"director":["Đinh Hắc"],"cast_meta":[{"name":"Lưu Thi Thi","name_vi":"Lưu Thi Thi","name_original":"Liu Shishi","tmdb_id":1185786,"profile":"https://image.tmdb.org/t/p/w500/yPyMTroHKKpK2g24o7920erAa3L.jpg","tmdb_url":"https://www.themoviedb.org/person/1185786"},{"name":"Chu Nhất Long","name_vi":"Chu Nhất Long","name_original":"Zhu Yilong","tmdb_id":1743471,"profile":"https://image.tmdb.org/t/p/w500/tdm21vg4E7ubhd429UT1UpPpFGo.jpg","tmdb_url":"https://www.themoviedb.org/person/1743471"},{"name":"Hám Thanh Tử","name_vi":"Hám Thanh Tử","name_original":"Kan Qingzi","tmdb_id":1675906,"profile":"https://image.tmdb.org/t/p/w500/q0XuEIcm9eB4tHaKFOvn0ymFo2l.jpg","tmdb_url":"https://www.themoviedb.org/person/1675906"},{"name":"Bành Quán Anh","name_vi":"Bành Quán Anh","name_original":"Peng Guanying","tmdb_id":1690592,"profile":"https://image.tmdb.org/t/p/w500/xPWJwXDVHy1biQxVMBYkzSFQm8q.jpg","tmdb_url":"https://www.themoviedb.org/person/1690592"},{"name":"