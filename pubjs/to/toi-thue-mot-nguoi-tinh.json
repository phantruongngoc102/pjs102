m11.com/share/2d6304a207cd9469f776e651e81ed7f8","link_m3u8":"https://vip.opstream11.com/20220408/11573_7ec8c5ae/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/486d016ed2f8a1de28c4b664be01f35f","link_m3u8":"https://vip.opstream11.com/20220408/11574_3d4afd54/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream11.com/share/12007262fce809193497e0dd36b00f8d","link_m3u8":"https://vip.opstream11.com/20220408/11575_aeafacba/index.m3u8"}]}],"description":"<p>Tám năm yêu nhau, mặc cho những lời cầu hôn chân thành từ Hạo Minh nhưng Kỷ Tình vẫn né tránh và hoài nghi về tình yêu của anh. Bởi vì cha của cô lúc còn trẻ đã có vợ lẽ bên ngoài, khiến mẹ của cô tức giận chạy ra ngoài và xảy ra tai nại mà qua đời. Lại thêm sau khi trưởng thành, các bạn bè xung quanh sau khi kết hôn cũng bị chồng bội bạc, càng khiến cô theo chủ nghĩa không hôn nhân. Vì vô cùng yêu thương Kỷ Tình nên Hạo Minh đề nghị cả hai trải qua cuộc sống “hôn nhân thử”. Qua một tháng, Kỷ Tình dần bị Hạo Minh cảm hóa. Trước khi chấp nhận đeo nhẫn cưới, nghe theo kiến nghị của các chị em, Kỷ Tình quyết định thử mức độ chân thành của Hạo Minh bằng cách thuê một phụ nữ theo đuổi anh, nhưng không ngờ rằng người phụ nữ Triệu San San đó tiếp cận Hạo Minh là có mục đích khác. San San rất sùng bái những gì mà Kỷ Tình đang có, nên muốn cướp đi cuộc sống hoàn mỹ của cô...</p>","tmdb_id":46591,"cast":[],"director":[],"keywords":[],"tmdb":{"id":46591},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/to/toi-thue-mot-nguoi-tinh.json"}