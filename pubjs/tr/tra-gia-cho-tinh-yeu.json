06/22369_8cee1be3/index.m3u8"},{"name":"31","slug":"31","filename":"tra-gia-cho-tinh-yeu-or-love-revenge-tap-31","link_embed":"https://vip.opstream16.com/share/3ac1fc4ea518c8f25ef3366bf240395a","link_m3u8":"https://vip.opstream16.com/20220906/22371_1139076e/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim Trả Giá Cho Tình Yêu (Love Revenge) nói về Arisa, một y tá xinh đẹp. Cô đã từng nghĩ cuộc đời cô may mắn như nàng Lọ Lem khi kết hôn với người đàn ông ấm áp như Aek Phum. Thế nhưng, vào ngày kỷ niệm 10 năm bên nhau, Aek Phum đã bỏ Arisa để chạy theo Kesirin giàu có và quyền lực. Sau đó, Arisa quen chàng trai trẻ Pongkul và dần tìm lại được niềm vui sau nhiều đau khổ, cho đến khi cô phát hiện mình mang thai.</p>","tmdb":{"type":"tv","id":"96064","season":1,"vote_average":0,"vote_count":0},"modified":"2022-09-28T03:59:26.000Z","cast":["Woranuch Bhirombhakdi","Kawee Tanjararak","Joss Way-ar Sangngern","Napapa Tantrakul","Chawallakorn Wanthanapisitkul","Yanee Jongwisut","Krunnapol Teansuwan","Ratchanok Saeng-Chuto","Mouzie Benjawan Kulterdtool","Atitaya Tribudarak"],"director":["Kritsada Techanilobon"],"cast_meta":[{"name":"Woranuch Bhirombhakdi","name_vi":null,"name_original":"Woranuch Bhirombhakdi","tmdb_id":573580,"profile":"https://image.tmdb.org/t/p/w500/y2Rt6coQdn7l0YKlkM2Qv2ArOx6.jpg","tmdb_url":"https://www.themoviedb.org/person/573580"},{"name":"Kawee Tanjararak","name_vi":null,"name_original":"Kawee Tanjararak","tmdb_id":929521,"profile":"https://image.tmdb.org/t/p/w500/y7DNYhrzE5BPeLZAcYZnxA5psGX.jpg","tmdb_url":"https://www.themoviedb.org/person/929521"},{"name":"Joss Way-ar Sangngern","name_vi":"Joss Way-ar Sangngern","name_original":"Way-ar Sangngern","tmdb_id":2302265,"profile":"https://image.tmdb.org/t/p/w500/dBD2WVjQgJQZUkCVrydXyvdMagM.jpg","tmdb_url":"https://www.themoviedb.org/person/2302265"},{"name":"Napapa Tantrakul","name_vi":null,"name_original":"Napapa Tantrakul","tmdb_id":1341375,"profile":"https://image.tmdb.org/t/p/w500/5yr8N6y