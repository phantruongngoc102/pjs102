d":"https://vip.opstream16.com/share/b527dc22b8335235e992c700352fd78d","link_m3u8":"https://vip.opstream16.com/20220906/22392_705fc816/index.m3u8"},{"name":"14","slug":"14","filename":"trai-tim-dai-duong-xanh-or-the-blue-ocean-diamond-tap-14","link_embed":"https://vip.opstream16.com/share/11f64a21a22a548559e4edfbdd8e0397","link_m3u8":"https://vip.opstream16.com/20220906/22394_1d405798/index.m3u8"},{"name":"15","slug":"15","filename":"trai-tim-dai-duong-xanh-or-the-blue-ocean-diamond-tap-15","link_embed":"https://vip.opstream16.com/share/b36386583d6f2df72b8fc8dca09e34a4","link_m3u8":"https://vip.opstream16.com/20220906/22396_79b48e97/index.m3u8"},{"name":"16","slug":"16","filename":"trai-tim-dai-duong-xanh-or-the-blue-ocean-diamond-tap-16","link_embed":"https://vip.opstream16.com/share/dd67ae2383fa440995218a0915e2cd71","link_m3u8":"https://vip.opstream16.com/20220906/22398_d6334013/index.m3u8"},{"name":"17","slug":"17","filename":"trai-tim-dai-duong-xanh-or-the-blue-ocean-diamond-tap-17","link_embed":"https://vip.opstream16.com/share/d9663e409ced6f5a8be7614c4a90a701","link_m3u8":"https://vip.opstream16.com/20220906/22400_2e7f1bb8/index.m3u8"},{"name":"18","slug":"18","filename":"trai-tim-dai-duong-xanh-or-the-blue-ocean-diamond-tap-18","link_embed":"https://vip.opstream16.com/share/d9290c1d84c18de491112fab16fc0172","link_m3u8":"https://vip.opstream16.com/20220906/22401_b8ba76c4/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Trái Tim Đại Dương Xanh (The Blue Ocean Diamond) vietsub xoay quanh chủ một công ty vệ sĩ, một cựu cảnh sát điển trai và rất giỏi võ tên Prompoom. Anh luôn được giao những nhiệm vụ khó. Lúc này, có nhiều tin đồn về một viên kim cương quý giá bị đánh cắp và có rất nhiều kẻ muốn lấy nó. Với trị giá cực lớn, cảnh sát bắt đầu vào cuộc và 10 kẻ tình nghi được cho vào tầm ngắm. Sau đó, Prompoom được chọn để thực hiện nhiệm vụ truy tìm kẻ trộm, người đứng sau điều khiển mọi chuyện là ai. Đồng hành cùng anh là Lisa thông minh xinh đẹp, đồng thời là con gái của chủ nhân viên kim cương. Liệu hai người có thể tìm ra sự thật, bắt gọn tên tội phạm?</p>","tmdb":{"type":"tv","id":"115105","season":1,"vote_average":0,"vote_count":0},"modified":"2022-09-28T04:04:01.000Z","cast":["Esther Supreeleela","Yuke Songpaisan","Ornjira Lamwilai","Keerati Mahapreukpong","Anupart Luangsodsai","Narupornkamol Chaisang","Akarat Nimitchai","Savitree Samipak","Korn Sirisorn","Dilok Thongwattana","Anuchit Sapanpong"],"director":["Methee Charoenpong"],"cast_meta":[{"name":"Esther Supreeleela","name_vi":null,"name_original":"Esther Supreeleela","tmdb_id":1259493,"profile":"https://image.tmdb.org/t/p/w500/qL1NLM4tPynGmvH1ARa3kKB4sQS.jpg","tmdb_url":"https://www.themoviedb.org/person/1259493"},{"name":"Yuke Songpaisan","name_vi":null,"name_original":"Yuke Songpaisan","tmdb_id":1259426,"profile":"https://image.tmdb.org/t/p/w500/uylW0Rv8SLM97vtBHy95eBiOEz.jpg","tmdb_url":"https://www.themoviedb.org/person/1259426"},{"name":"Ornjira Lamwilai","name_vi":null,"name_original":"Ornjira Lamwilai","tmdb_id":1156558,"profile":"https://image.tmdb.org/t/p/w500/aAJ0Y5EOaRkEy3DHyYRWhY0YYxO.jpg","tmdb_url":"https://www.themoviedb.org/person/1156558"},{"name":"Keerati Mahapreukpong","name_vi":null,"name_original":"Keerati Mahapreukpong","tmdb_id":929517,"profile":"https://image.tmdb.org/t/p/w500/f7421wia36Eznbov3DHN63ol9h7.jpg","tmdb_url":"https://www.themoviedb.org/person/929517"},{"name":"Anupart Luangsodsai","name_vi":null,"name_original":"Anupart Luangsodsai","tmdb_id":1593727,"profile":"https://image.tmdb.org/t/p/w500/1oW7KgUOFfQ1EVxxpesmvDn6QHG.jpg","tmdb_url":"https://www.themoviedb.org/person/1593727"},{"name":"Narupornkamol Chaisang","name_vi":null,"name_original":"Narupornkamol Chaisang","tmdb_id":1960604,"profile":"https://image.tmdb.org/t/p/w500/aw7u7wnAG7xWpA1XV1kxQG48BNg.jpg","tmdb_url":"https://www.themoviedb.org/person/1960604"},{"name":"Akarat Nimitchai","name_vi":"Akarat Nimitchai","name_original":"Akarat Nimitchai","tmdb_id":3406040,"p