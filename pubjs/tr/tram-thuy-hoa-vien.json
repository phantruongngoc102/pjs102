bd46d76/index.m3u8"},{"name":"31","slug":"31","filename":"tram-thuy-hoa-vien-dream-garden-tap-31","link_embed":"https://vip.opstream12.com/share/154860e7d6c1a90ff1fd9f6c8b209054","link_m3u8":"https://vip.opstream12.com/20220624/21687_9f74a585/index.m3u8"},{"name":"32","slug":"32","filename":"tram-thuy-hoa-vien-dream-garden-tap-32","link_embed":"https://vip.opstream12.com/share/e4628797d1c5b2d9e119f892f43f3d6d","link_m3u8":"https://vip.opstream12.com/20220624/21689_5ec8b6c6/index.m3u8"}]}],"time":"38 phút/tập","description":"<p>Trầm Thụy Hoa Viên - Dream Garden là câu chuyện tình lãng mạn của Lâm Thâm (Cung Tuấn) - một chuyên gia tâm lý và Tiêu Tiêu (Kiều Hân) - chuyên gia tình cảm. Vì tính chất công việc, cả hai thường xuyên chạm mặt nhau, nhưng lại ở hai thái cực hoàn toàn đối lập nên thường xuyên xảy ra xung đột, tranh cãi. Tuy nhiên, sau thời gian dài gắn bó để cùng tìm hiểu, lý giải những bí ẩn của \"bệnh nhân\", cả hai dần nảy sinh tình cảm với nhau lúc nào không hay.</p>","tmdb":{"type":"tv","id":"290744","season":1,"vote_average":0,"vote_count":0},"modified":"2022-06-24T02:42:53.000Z","cast":[],"director":[],"cast_meta":[],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/tr/tram-thuy-hoa-vien.json"}