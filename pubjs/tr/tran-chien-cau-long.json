m/20220703/17059_23d9a9fb/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream14.com/share/9f8f593af6b09a7d68c36ed5a2a56b3e","link_m3u8":"https://vip.opstream14.com/20220703/17060_bd1826f9/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream14.com/share/d358d2a68839eda9e25bbe539acf175d","link_m3u8":"https://vip.opstream14.com/20220703/17061_ca520ab1/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream14.com/share/7856b5ed39600c48efbf2e40576e1345","link_m3u8":"https://vip.opstream14.com/20220703/17062_3c1b1bbc/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream14.com/share/86ebc213e0f98319c2b45c900031c7c7","link_m3u8":"https://vip.opstream14.com/20220703/17063_19cc8629/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream14.com/share/5d7ada35204d7dd09cf8990cd0a2df2e","link_m3u8":"https://vip.opstream14.com/20220703/17064_1040ebc0/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream14.com/share/2631f2f74cfaf1f994552c0316f5e220","link_m3u8":"https://vip.opstream14.com/20220703/17065_adcc2c59/index.m3u8"}]}],"description":"<p>Sau khi thảm bại 21-0 ở Giải Cầu Lông Trung Học Toàn Quốc, tình yêu của Aragaki Nagisa dành cho cầu lông bắt đầu vụn vỡ. Không thể chấp nhận thất bại nhục nhã đó, cô bắt đầu khiến các thành viên câu lạc bộ của mình kinh hoàng vì sự hà khắc khi luyện tập. Những bài tập nặng nề của cô khiến nhiều thành viên phải bật khóc trong khi nhiều người khác rời bỏ câu lạc bộ. Với việc mất đi nhiều thành viên và các học sinh mới không dám gia nhập gia nhập vì sợ hãi, tương lai của câu lạc bộ cầu lông không hề sáng sủa. Mọi chuyện cứ thế đén khi Tachibana Kentarou trở thành huấn luyện viên của câu lạc bộ cầu lông. Anh ấy không chỉ có trình độ của một tay vợt từng được chọn tham gia Thế Vận Hội và anh ấy còn mang đến cho câu lạc bộ “vũ khí bí mật” của mình: Hanesaki Ayano, cô bé đã đánh bại Nagisa sáu tháng trước đó. Tuy nhiên, Ayano không có là đối thủ mà Nagisa từng biết khi cô bé, với cảm xúc mâu thuẫn của mình, không muốn tiếp tục chơi cầu lông nữa. Với việc tương lai của mình trong môn cầu lông bị đe dọa, Nagisa cần tìm cách đối mặt với mặc cảm kém cỏi của mình cũng như xoa dịu trái tim bị tổn thương của kình địch để mang về vinh quang cho câu lạc bộ cầu lông Cao Trung Kitakomachi.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/tran-chien-cau-long.json","tmdb_checked":false}