//vip.opstream17.com/share/30580a4caf21ef930b7774a2eff4aa26","link_m3u8":"https://vip.opstream17.com/20240801/16073_548bbdbf/index.m3u8"},{"name":"25","slug":"25","filename":"Trang Su Dai Nao 25.end","link_embed":"https://vip.opstream17.com/share/1d18c59d33149e93443c87bf4d1ab535","link_m3u8":"https://vip.opstream17.com/20240801/16074_421dffcb/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Hương Tứ Duy (Quách Tấn An) mở học đường đề bồi dưỡng các anh tài, trong đó có môn sinh Châu Cúc (Huỳnh Thuý Như) với Tứ Duy vừa là thầy trò vừa là bạn hữu, Châu Cúc tư chất thông minh nhưng đọc sách luôn hiểu một nữa, từ đó thường xuyên dùng sai các thành ngữ. Tứ Duy là một người chính nghĩa, nhận thấy chuyện đời hoang đường và có sự dạy dỗ sâu sắc nên khó ai có thể thay đổi tâm tính của anh, nhưng một dịp tình cờ gặp một người tên Trần Chân Chân (Điền Nhuỵ Ni) lai lịch bất minh nhưng lanh lẹ cơ trí, giỏi tài biện minh, sau đó hai người trở thành hai người trạng sư biện hộ. Phan Kính Toàn (Trương Quốc Cường) nổi tiếng ác bá và con trai hắn-Phan Nhĩ Danh (Lâm Hiểu Phong) luôn coi Tứ Duy và Chân Chân là kẻ thù. Sự thay đổi của Tứ Duy khiến cho người bạn thân của anh là Hạ Hầu Võ (Mạch Trường Thanh) đau lòng thất vọng, bởi vì năm xưa phụ thân của Hầu Võ bị trạng sư Trần Mộng Cát (Lý Thành Xương) vu oan nên chết đi nên anh luôn có thành kiến với những ai là trạng sư, tuy Hầu Võ hiểu dụng ý của Tứ Duy nhưng lại nghi ngờ thân phận bất minh của Chân Chân nên anh ta quyết tâm điều tra. Từ đó vạch ra vụ án an chôn giấu 20 năm trước tái diễn, một tên sát thủ trạng sư máu lạnh xuất hiện, từ đó tin đồn khắp nơi, khiến cho mọi người lo lắng từng ngày...</i></p>","tmdb":{"type":"tv","id":"109654","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-03T15:36:10.000Z","cast":["Quách Tấn An","Kristal Tin Yui-Nei","Trương Quốc Cường","Kwan Ching","Huỳnh Thuý Như","Trương Dĩnh Khang","Mạch Trường Thanh","Lâm Hiểu Phong","Lý Thành Xương","Fred Cheng Chun-Hung","Timothy Cheng Chi-Sing","Rachel Kan","Grace Wong","Khang Hoa","Suet Nei"],"director":["Lý Diễm Phương"],"cast_meta":[{"name":"Quách Tấn An","name_vi":"Quách Tấn An","name_original":"Roger Kwok Chun-On","tmdb_id":230576,"profile":"https://image.tmdb.org/t/p/w500/lmvdYkdC7i8RWF1pK0A4uMOv34k.jpg","tmdb_url":"https://www.themoviedb.org/person/230576"},{"name":"Kristal Tin Yui-Nei","name_vi":null,"name_original":"Kristal Tin Yui-Nei","tmdb_id":123650,"profile":"https://image.tmdb.org/t/p/w500/mjXRFqm1TS6faWfKeOoAGGrgHyU.jpg","tmdb_url":"https://www.themoviedb.org/person/123650"},{"name":"Trương Quốc Cường","name_vi":"Trương Quốc Cường","name_original":"Cheung Kwok-Keung","tmdb_id":1266162,"profile":"https://image.tmdb.org/t/p/w500/jsauufq9uAPZPoaJQhzgkSlTOZQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1266162"},{"name":"Kwan Ching","name_vi":null,"name_original":"Kwan Ching","tmdb_id":3444638,"profile":"https://image.tmdb.org/t/p/w500/9ItgkyBLMuR1GZZ3WUJMT85HgnS.jpg","tmdb_url":"https://www.themoviedb.org/person/3444638"},{"name":"Huỳnh Thuý Như","name_vi":"Huỳnh Thuý Như","name_original":"Priscilla Wong","tmdb_id":227741,"profile":"https://image.tmdb.org/t/p/w500/yjZHT5RSQunnEc1yLkyyPKLR3Lm.jpg","tmdb_url":"https://www.themoviedb.org/person/227741"},{"name":"Trương Dĩnh Khang","name_vi":"Trương Dĩnh Khang","name_original":"Jonathan Cheung Wing-Hong","tmdb_id":1775002,"profile":"https://image.tmdb.org/t/p/w500/vfKaCwPlmnupA8Y7yxDThpk681h.jpg","tmdb_url":"https://www.themoviedb.org/person/1775002"},{"name":"Mạch Trường Thanh","name_vi":"Mạch Trường Thanh","name_original":"Evergreen Mak Cheung-Ching","tmdb_id":985094,"profile":"https://image.tmdb.org/t/p/w500/u1lUv0JR4v0gNXjUWtfPJ43I8SA.jpg","tmdb_url":"https://www.themoviedb.org/person/985094"},{"name":"Lâm Hiểu Phong","name_vi":"Lâm Hiểu Phong","name_original":"Jerry Lamb Hiu-Fung","tmdb_id":553201,"profile":"https://image.tmdb.org/t/p/w500/fjovzalpmKcn5TKoABfvNCGReay.jpg","tmdb_url":"https://www.themoviedb.org/person/553201"},{"n