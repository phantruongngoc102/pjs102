ink_embed":"https://vip.opstream11.com/share/d4aa3819fa81ce7edefa6cd564645656","link_m3u8":"https://vip.opstream11.com/20231022/48562_bb472d7a/index.m3u8"}]}],"time":"15 phút/tập","description":"<p>Bộ phim đầy kịch tính kể về cuộc hành trình của Tiết Đồng, một tiểu thư giàu có nhưng gia đình cô đã gặp biến cố đầy bí ẩn từ khi cô còn nhỏ. Sau 18 năm, Tiết Đồng quyết định trở về cố hương dưới bí danh \"Lâm Bảo Nhi\" với mục tiêu rõ ràng: trả thù kẻ đã hủy hoại gia đình cô. Tuy nhiên, kế hoạch của cô bị đe dọa khi cô bị buộc phải tham gia buổi đính hôn và trở thành hôn thê của Chu Quan Văn, con trai của kẻ thù. Cuộc đối đầu giữa Tiết Đồng và Chu Quan Văn trở nên phức tạp hơn khi tình cảm xen vào. Liệu Tiết Đồng có thể tiêu diệt kẻ thù của mình và đồng thời bảo vệ tình yêu đang nảy nở?</p>","tmdb":{"type":"tv","id":"236602","season":1,"vote_average":8.5,"vote_count":2},"modified":"2023-10-22T21:39:39.000Z","cast":["Chen Shujun","Leo Yang","Wu Jingxin","Wang Cheng"],"director":[],"cast_meta":[{"name":"Chen Shujun","name_vi":null,"name_original":"Chen Shujun","tmdb_id":2738545,"profile":"https://image.tmdb.org/t/p/w500/hd0TdZZsT6iZv5MY26ZpwdiUxqb.jpg","tmdb_url":"https://www.themoviedb.org/person/2738545"},{"name":"Leo Yang","name_vi":null,"name_original":"Leo Yang","tmdb_id":2480231,"profile":"https://image.tmdb.org/t/p/w500/dOjn9t7lUVlXdMsY6JUsNXSyccp.jpg","tmdb_url":"https://www.themoviedb.org/person/2480231"},{"name":"Wu Jingxin","name_vi":null,"name_original":"Wu Jingxin","tmdb_id":3381727,"profile":"https://image.tmdb.org/t/p/w500/353Xny9P12jQGmtGEerUnwSBU3c.jpg","tmdb_url":"https://www.themoviedb.org/person/3381727"},{"name":"Wang Cheng","name_vi":null,"name_original":"Wang Cheng","tmdb_id":237820,"profile":"https://image.tmdb.org/t/p/w500/m4IxicoRrcxNooIgyecKkh3ZGOx.jpg","tmdb_url":"https://www.themoviedb.org/person/237820"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/trang-vien-me-tinh.json"}