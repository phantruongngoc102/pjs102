pstream13.com/share/e00944d55e6432ccf20f9fda2492b6fd","link_m3u8":"https://vip.opstream13.com/20250920/9062_e00944d5/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream13.com/share/4d7e0d72898ae7ea3593eb5ebf20c744","link_m3u8":"https://vip.opstream13.com/20250920/9061_4d7e0d72/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream13.com/share/cb4b69eb9bd10da82c15dca2f86a1385","link_m3u8":"https://vip.opstream13.com/20250920/9060_cb4b69eb/index.m3u8"}]}],"description":"Vào thời Võ chu, tể tướng Địch Nhân Kiệt là một vị quan nổi tiếng cương chính liêm minh. Ông được nữ vương Võ Tắc Thiên hết lòng tin cẩn và được người đời tôn kính phong là “thanh thiên”.Cháu trưởng của Võ Hậu, Võ Thừa Tựlà một kẻ vô cùng hiểm độc và ích kỷ, luôn chực chờ cơ hội để hãm hại Địch đại nhân hòng chiếm đoạt ngôi thái tử. Để thực hiện âm mưu của mình, y vu khống Địch Nhân Kiệt cấu kết với phu quân của tiểu muội ông – Địch Thanh Loan – là Tống Đình Ngọc mưu đồ tạo phản nhằm soán ngôi Võ hậu. Điêu đứng trước thủ đoạn hèn hạ của kẻ thù cộng với việc Võ hậu bị Thừa Tự xúi giục, cả nhà lớn nhỏ của Địch gia bị tống giam vào ngục chờ ngày xét xử. May mắn thay, Địch Nhân Kiệt thoát được ngục tù trong lúc triều đình nhiễu nhương. Tuy nhiên, Võ Thừa Tự dọa sẽ giết nhị phu nhân của ông là Tào Nguyệt để uy hiếp ông. Bị đẩy vào thế tiến thoái lưỡng nan, một người quang minh chính đại liêm khiết như Địch Nhân Kiệt sẽ xử trí ra sao trước thế lực hắc ám lẩn khuất trong bóng tối?","tmdb_id":7691,"cast":["Quách Thiện Ni","Cao Quân Hiền","Đường Ninh","Trịnh Tắc Sĩ","Claire Yiu","Trần Cẩm Hồng","Tào Vĩnh Liêm","Kwan Ching","La Quân Tả","Lê Diệu Tường","Liêu Bích Nhi","Rebecca Chan","Lee Heung-Kam","Queenie Chu Wai-Man","Lee Tin-Cheung"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"7691","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Quách Thiện Ni","name_vi":"Quách Thiện Ni","name_original":"Sonija Kwok Sin-Nae","tmdb_id":1223071,"profile":"http