om/20260402/33213_2ffe5ae2/index.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream10.com/share/36d950d2edf29ad0067ab7ef5a06daa4","link_m3u8":"https://vip.opstream10.com/20260409/33263_36d950d2/index.m3u8"}]}],"description":"<p>Sau thành công của mùa đầu tiên, Morgan Gillory (Kaitlin Olson) - bà mẹ đơn thân thông minh xuất chúng với chỉ số IQ 160 – tiếp tục trở lại trong mùa 2 của High Potential.&nbsp;</p><p>Ở mùa 1, Morgan từ một nhân viên dọn dẹp bình thường đã khiến Sở cảnh sát Los Angeles phải kinh ngạc bởi khả năng quan sát và suy luận thiên tài. Nhưng bên cạnh những vụ án hóc búa, cô cũng phải đối diện với những rắc rối riêng tư: nuôi dạy ba đứa con nhỏ và mối quan hệ phức tạp giữa mình và Karadec bước sang một giai đoạn mới, khi cả hai vừa phải hợp tác phá án, vừa phải giải quyết cảm xúc cá nhân. Mùa 2 mở ra nhiều thử thách mới. Một kẻ thù nguy hiểm, \"Game Maker\", tiếp tục thách thức trí tuệ của Morgan với những trò chơi chết chóc, đặt gia đình cô vào vòng nguy hiểm.&nbsp;</p>","tmdb_id":226637,"cast":["Kaitlin Olson","Daniel Sunjata","Judy Reyes","Javicia Leslie","Deniz Akdeniz","Amirah J","Matthew Lamb"],"director":[],"keywords":[],"time":"44 phút/tập","tmdb":{"type":"tv","id":"226637","season":2,"vote_average":7.984,"vote_count":471},"cast_meta":[{"name":"Kaitlin Olson","name_vi":null,"name_original":"Kaitlin Olson","tmdb_id":95102,"profile":"https://image.tmdb.org/t/p/w500/z84SKRCVl9zPhP9AINVS8Bx8dRO.jpg","tmdb_url":"https://www.themoviedb.org/person/95102"},{"name":"Daniel Sunjata","name_vi":null,"name_original":"Daniel Sunjata","tmdb_id":10582,"profile":"https://image.tmdb.org/t/p/w500/w3Wa0d7j2auA2R8FQvjrgfB3ozo.jpg","tmdb_url":"https://www.themoviedb.org/person/10582"},{"name":"Judy Reyes","name_vi":null,"name_original":"Judy Reyes","tmdb_id":159657,"profile":"https://image.tmdb.org/t/p/w500/DQ8kIRHru9Zzy6CftVryHmIOJs.jpg","tmdb_url":"https://www.themoviedb.org/person/159657"},{"name":"Javicia Leslie","name_vi":null,"name_original":"