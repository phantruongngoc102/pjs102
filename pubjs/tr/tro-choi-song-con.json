hĩ, một thiếu niên với quá khứ bí ẩn. Họ cùng nhau đối mặt với sự ác độc của Hàn Bân, kẻ thống trị tàn ác, và tổ chức của anh ta. Sau những cuộc chiến khốc liệt, khi họ tự tin rằng chiến thắng đã đến gần, họ phát hiện ra mình bị rơi vào bẫy của Hàn Bân, lâm vào tình cảnh tuyệt vọng. Điều đáng sợ hơn là, với thất bại này, sự tin tưởng duy nhất giữa ba người cũng tan vỡ hoàn toàn. Trong thời khắc nguy cấp, sự xuất hiện của một cao thủ siêu phàm, Châu Nhất Đao, thay đổi cả cục diện lực lượng tại làng mới và mang đến cho Kiều Kinh Đình và những người khác một tia hy vọng trốn thoát.","tmdb_id":241527,"cast":["Zhao Yi","Ye Zhiqiu","Meme Yan","Yang Zai","Cai Na","Sun Lulu","Lai Qiuyu","Ba He","Wei Yifan","Qing Liu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"241527","season":1,"vote_average":8,"vote_count":3},"cast_meta":[{"name":"Zhao Yi","name_vi":null,"name_original":"Zhao Yi","tmdb_id":2199291,"profile":"https://image.tmdb.org/t/p/w500/c35JU0PEZscEHCpOUabFp3EHcpo.jpg","tmdb_url":"https://www.themoviedb.org/person/2199291"},{"name":"Ye Zhiqiu","name_vi":null,"name_original":"Ye Zhiqiu","tmdb_id":2156491,"profile":"https://image.tmdb.org/t/p/w500/eqdPGpXF9cb98Ft80xRdA83G2An.jpg","tmdb_url":"https://www.themoviedb.org/person/2156491"},{"name":"Meme Yan","name_vi":null,"name_original":"Meme Yan","tmdb_id":2156554,"profile":"https://image.tmdb.org/t/p/w500/8Gf8Ji8CKJ3lhnKlnYM2ZpDOIXy.jpg","tmdb_url":"https://www.themoviedb.org/person/2156554"},{"name":"Yang Zai","name_vi":null,"name_original":"Yang Zai","tmdb_id":4024179,"profile":"https://image.tmdb.org/t/p/w500/ccZSPpaZMK6R6p8Ajqd7JS3ssxn.jpg","tmdb_url":"https://www.themoviedb.org/person/4024179"},{"name":"Cai Na","name_vi":null,"name_original":"Cai Na","tmdb_id":3281156,"profile":"https://image.tmdb.org/t/p/w500/eqnsMWn22zKjjDJc6rncek4y1v7.jpg","tmdb_url":"https://www.themoviedb.org/person/3281156"},{"name":"Sun Lulu","name_vi":null,"name_original":"Sun Lulu","tmdb_id":3434824,"profile":"https://image.tmdb.o