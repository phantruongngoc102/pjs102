om/share/21f1dfbf0e1ba7279aed485a3fa63af6","link_m3u8":"https://vip.opstream15.com/20250404/51544_21f1dfbf/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream15.com/share/b3d24d90af6f625d0dbf0337837c9aa8","link_m3u8":"https://vip.opstream15.com/20250404/51545_b3d24d90/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream15.com/share/74ed869696c0995195fc8faded4ebcfd","link_m3u8":"https://vip.opstream15.com/20250404/51546_74ed8696/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream15.com/share/94ef973ad76b162c56698035819f28a8","link_m3u8":"https://vip.opstream15.com/20250404/51547_94ef973a/index.m3u8"},{"name":"55","slug":"55","link_embed":"https://vip.opstream15.com/share/a1f40c42a98d42936db30295c6245991","link_m3u8":"https://vip.opstream15.com/20250404/51548_a1f40c42/index.m3u8"},{"name":"56","slug":"56","link_embed":"https://vip.opstream15.com/share/cfc9acc5717fa8f921a7c6e704383496","link_m3u8":"https://vip.opstream15.com/20250404/51549_cfc9acc5/index.m3u8"}]}],"description":"Thiên kim của tập đoàn Viễn Phi, Hứa Nặc, từ nhỏ lớn lên trong sự nuông chiều của bố mẹ. Sau khi du học nước ngoài trở về, cô kinh hoàng phát hiện gia đình hạnh phúc ngày nào đã tan nát. Mẹ cô bị đuổi ra khỏi nhà tay trắng, còn người anh không cùng huyết thống được gia đình cô nuôi dưỡng từ nhỏ Thẩm Gia Hòa lại sắp thay cô thừa kế sản nghiệp. Mà vị hôn thê của bố cô chính là Bạch Hạ, bạn gái tin đồn trước đây của Thẩm Gia Hòa, đồng thời cũng là kẻ thù không đội trời chung ngày xưa của cô.Hứa Nặc nhìn thấu âm mưu của Thẩm Gia Hòa. Để giành lại Viễn Phi và vạch trần bộ mặt thật của hắn, cô tính toán kỹ lưỡng, từng bước thực hiện kế hoạch. Cô cố ý dụ dỗ Thẩm Gia Hòa lao vào một canh bạc mang tên \"trò chơi tình ái\", mở ra hành trình vừa yêu vừa hận giữa hai người.","tmdb_id":256542,"cast":["Phàn Trị Hân","Hà Thụy Hiền","Vương Sách","Wang Zuyi","Huang Qiao","Chen Yisha","Mei Lingzhen","Min Xinghan"],"director":["Xi Dao"],"keywords":[],"