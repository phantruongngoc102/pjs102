://vip.opstream11.com/share/efb76cff97aaf057654ef2f38cd77d73","link_m3u8":"https://vip.opstream11.com/20220311/1628_fe7c0286/index.m3u8"},{"name":"6","slug":"6","filename":"game-of-thrones-season-4-tap-6","link_embed":"https://vip.opstream11.com/share/5c50b4df4b176845cd235b6a510c6903","link_m3u8":"https://vip.opstream11.com/20220311/1629_2e8257bb/index.m3u8"},{"name":"7","slug":"7","filename":"game-of-thrones-season-4-tap-7","link_embed":"https://vip.opstream11.com/share/46031b3d04dc90994ca317a7c55c4289","link_m3u8":"https://vip.opstream11.com/20220311/1630_2566ddfc/index.m3u8"},{"name":"8","slug":"8","filename":"game-of-thrones-season-4-tap-8","link_embed":"https://vip.opstream11.com/share/6ba3af5d7b2790e73f0de32e5c8c1798","link_m3u8":"https://vip.opstream11.com/20220311/1631_ff388be5/index.m3u8"},{"name":"9","slug":"9","filename":"game-of-thrones-season-4-tap-9","link_embed":"https://vip.opstream11.com/share/0771fc6f0f4b1d7d1bb73bbbe14e0e31","link_m3u8":"https://vip.opstream11.com/20220311/1632_e60b069e/index.m3u8"},{"name":"10","slug":"10","filename":"game-of-thrones-season-4-tap-10","link_embed":"https://vip.opstream11.com/share/21fe5b8ba755eeaece7a450849876228","link_m3u8":"https://vip.opstream11.com/20220311/1633_3a015185/index.m3u8"}]}],"time":"55 phút/tập","description":"<p>Phần 4 của series phim truyền hình nổi tiếng Game Of Thrones sẽ dựa theo nửa cuối của tiểu thuyết A Storm of Swords (Quyển thứ 3 của tiểu thuyết A Song of Ice and Fire). Cuộc tranh đấu không mệt mỏi của 7 gia tộc chiến đấu để làm chủ vùng đất thần thoại Westeros được tiếp tục trong phần 4. Một mưu đồ chính trị mới lại trỗi dậy và các phe phái còn sống sót không chỉ đấu tranh với kẻ thù bên ngoài mà còn với giặc trong. Gia tộc Lannister giành chiến thắng sau khi đã đánh bại các mối đe dọa, mặc dù vùng đất thần thoại Westeros đã nằm trong tay sự kiểm soát của gia tộc Lannister, nhưng vẫn còn hai phe phái phản đối họ: Greyjoys và Baratheons! Lần này thì các thế lực siêu nhiên đang nổi dậy như đội quân White Walkers đang dần tràn về vương quốc từ phương bắc, phù thủy Đỏ với các phép thuật hắc ám của mình đang dần trở nên mạnh hơn, 3 con rồng của công chúa Daenerys Targaryen cũng đã lớn và sẽ trở thành một thế lực lớn trong cuộc tranh đấu này.</p>","tmdb":{"type":"tv","id":"1399","season":4,"vote_average":8.459,"vote_count":26188},"modified":"2023-07-02T17:20:54.000Z","cast":["Peter Dinklage","Kit Harington","Nikolaj Coster-Waldau","Lena Headey","Emilia Clarke","Liam Cunningham","Maisie Williams","Isaac Hempstead Wright","Sophie Turner","John Bradley","Rory McCann","Joe Dempsie","Gwendoline Christie","Jacob Anderson"],"director":["Daniel Minahan","Alex Graves"],"cast_meta":[{"name":"Peter Dinklage","name_vi":null,"name_original":"Peter Dinklage","tmdb_id":22970,"profile":"https://image.tmdb.org/t/p/w500/9CAd7wr8QZyIN0E7nm8v1B6WkGn.jpg","tmdb_url":"https://www.themoviedb.org/person/22970"},{"name":"Kit Harington","name_vi":null,"name_original":"Kit Harington","tmdb_id":239019,"profile":"https://image.tmdb.org/t/p/w500/iGXlJbExWwZmo9sUDsYuzf4Sv4y.jpg","tmdb_url":"https://www.themoviedb.org/person/239019"},{"name":"Nikolaj Coster-Waldau","name_vi":null,"name_original":"Nikolaj Coster-Waldau","tmdb_id":12795,"profile":"https://image.tmdb.org/t/p/w500/rpFOERbHkj7GWxkinUNiQ76sSGk.jpg","tmdb_url":"https://www.themoviedb.org/person/12795"},{"name":"Lena Headey","name_vi":null,"name_original":"Lena Headey","tmdb_id":17286,"profile":"https://image.tmdb.org/t/p/w500/cDyZLf8ddz0EgoUjpv4jjzy7qxA.jpg","tmdb_url":"https://www.themoviedb.org/person/17286"},{"name":"Emilia Clarke","name_vi":null,"name_original":"Emilia Clarke","tmdb_id":1223786,"profile":"https://image.tmdb.org/t/p/w500/wb8VfDPGpyqcFltnRcJR1Wj3h4Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1223786"},{"name":"Liam Cunningham","name_vi":null,"name_original":"Liam Cunningham","tmdb_id":15498,"profile":"https://image.tmdb.org/t/p/w500/ljmFT9zYqh4k2bmEcNU6rxoE7fW.jpg","tmdb_url":"https://www.themovied