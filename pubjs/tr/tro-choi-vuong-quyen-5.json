gia tộc này, và với sự tồn tại của các dòng tộc lớn khác như Greyjoy, Tully, Arryn, và Tyrell đã dẫn đến cuộc chiến toàn diện. Trong khoảng thời gian này thì ở phía cực Bắc, Bóng Trắng – loài quỷ vốn chìm trong giấc ngủ rất dài, nay đã thức giấc…</p>","tmdb":{"type":"tv","id":"1399","season":5,"vote_average":8.459,"vote_count":26188},"modified":"2023-07-02T17:21:30.000Z","cast":["Peter Dinklage","Kit Harington","Nikolaj Coster-Waldau","Lena Headey","Emilia Clarke","Liam Cunningham","Maisie Williams","Isaac Hempstead Wright","Sophie Turner","John Bradley","Rory McCann","Joe Dempsie","Gwendoline Christie","Jacob Anderson"],"director":[],"cast_meta":[{"name":"Peter Dinklage","name_vi":null,"name_original":"Peter Dinklage","tmdb_id":22970,"profile":"https://image.tmdb.org/t/p/w500/9CAd7wr8QZyIN0E7nm8v1B6WkGn.jpg","tmdb_url":"https://www.themoviedb.org/person/22970"},{"name":"Kit Harington","name_vi":null,"name_original":"Kit Harington","tmdb_id":239019,"profile":"https://image.tmdb.org/t/p/w500/iGXlJbExWwZmo9sUDsYuzf4Sv4y.jpg","tmdb_url":"https://www.themoviedb.org/person/239019"},{"name":"Nikolaj Coster-Waldau","name_vi":null,"name_original":"Nikolaj Coster-Waldau","tmdb_id":12795,"profile":"https://image.tmdb.org/t/p/w500/rpFOERbHkj7GWxkinUNiQ76sSGk.jpg","tmdb_url":"https://www.themoviedb.org/person/12795"},{"name":"Lena Headey","name_vi":null,"name_original":"Lena Headey","tmdb_id":17286,"profile":"https://image.tmdb.org/t/p/w500/cDyZLf8ddz0EgoUjpv4jjzy7qxA.jpg","tmdb_url":"https://www.themoviedb.org/person/17286"},{"name":"Emilia Clarke","name_vi":null,"name_original":"Emilia Clarke","tmdb_id":1223786,"profile":"https://image.tmdb.org/t/p/w500/wb8VfDPGpyqcFltnRcJR1Wj3h4Z.jpg","tmdb_url":"https://www.themoviedb.org/person/1223786"},{"name":"Liam Cunningham","name_vi":null,"name_original":"Liam Cunningham","tmdb_id":15498,"profile":"https://image.tmdb.org/t/p/w500/ljmFT9zYqh4k2bmEcNU6rxoE7fW.jpg","tmdb_url":"https://www.themoviedb.org/person/15498"},{"name":"Maisie Wi