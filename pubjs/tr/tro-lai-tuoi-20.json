g một cuộc đời mới và theo đuổi giấc mơ ca hát bấy lâu nay chôn kín.</p>","tmdb_id":80811,"cast":[],"director":[],"keywords":[],"tmdb":{"id":80811},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/tro-lai-tuoi-20.json"}