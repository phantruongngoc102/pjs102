/20251212/31805_a4cfa388/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream10.com/share/d89920adb1af2d681ea0df8a9f863a82","link_m3u8":"https://vip.opstream10.com/20251212/31806_d89920ad/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream10.com/share/4eec603b40c78b0390abbd2bec778563","link_m3u8":"https://vip.opstream10.com/20251212/31807_4eec603b/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream10.com/share/01065cc12a9d7a950be0386ba0e43157","link_m3u8":"https://vip.opstream10.com/20260110/32273_01065cc1/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream10.com/share/d38446cc4f5c0bef25d2270f9db29985","link_m3u8":"https://vip.opstream10.com/20260110/32274_d38446cc/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream10.com/share/4c9f17e01c03106d9117905e58eb0951","link_m3u8":"https://vip.opstream10.com/20260110/32275_4c9f17e0/index.m3u8"}]}],"description":"<p>Lee Seo Jin và Kim Kwang Kyu – những người đã quen với cuộc sống của một diễn viên – nay đảm nhận vai trò mới: làm <strong>trợ lý</strong>. Từ ca sĩ đến các diễn viên đồng nghiệp, họ chăm sóc “gà nhà” bằng cách lo liệu mọi việc lớn nhỏ, chứng minh khả năng hỗ trợ chuyên nghiệp.</p><p>Họ còn hé lộ những khoảnh khắc đời thường, tự nhiên và không màu mè của các ngôi sao phía sau ánh đèn sân khấu thông qua những cuộc trò chuyện chân thật. Lee Seo Jin, nổi tiếng với nền tảng học vấn tốt và kinh nghiệm trong lĩnh vực tài chính, trở thành “bộ não” của đội, luôn thấu hiểu phía sau vẻ ngoài lạnh lùng. Trong khi đó, Kim Kwang Kyu trông có vẻ thoải mái nhưng lại sở hữu nhiều trải nghiệm sống, từ tài xế taxi đến phục vụ bàn.</p><p>Là cặp đôi “Tom và Jerry” nổi tiếng, cả hai nhiều lúc rơi vào tình huống dở khóc dở cười khi học cách thích nghi với những trách nhiệm mới. Liệu họ có xây dựng được sự nghiệp <strong>trợ lý</strong> thành công? Hãy cùng theo dõi.</p>","tmdb_id":302173,"cast":["Lee Seo-jin","Kim Kwang-kyu"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"302173","season":1,"vote_average":9,"vote_count":1},"cast_meta":[{"name":"Lee Seo-jin","name_vi":null,"name_original":"Lee Seo-jin","tmdb_id":77282,"profile":"https://image.tmdb.org/t/p/w500/s5KginY3G9ZmqsgiOKmx9mto6Vx.jpg","tmdb_url":"https://www.themoviedb.org/person/77282"},{"name":"Kim Kwang-kyu","name_vi":null,"name_original":"Kim Kwang-kyu","tmdb_id":224673,"profile":"https://image.tmdb.org/t/p/w500/5X3oJA1NaesYHeX3LfuC7t3j7VV.jpg","tmdb_url":"https://www.themoviedb.org/person/224673"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/tro-ly-kho-tinh.json"}