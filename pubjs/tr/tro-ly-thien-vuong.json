stream12.com/share/00ca4dc5c4d94396ae3966f3b0ab1f1b","link_m3u8":"https://vip.opstream12.com/20220619/20863_dd89f5a1/index.m3u8"}]}],"time":"45 phút / tập","description":"<p><strong>Trợ Lý Thiên Vương</strong> kể về một sinh viên hàng đầu của Khoa lịch sử tình cờ gặp gỡ và quen biết siêu sao Do Hi. Do trình độ văn chương kém, Do Hi khiến đạo diễn tức giận, hơn nữa còn bị tố cáo năng lực của bản thân. Không còn cách nào, công ty quản lý bèn phải tìm người gia sư với hy vọng có thể giúp Do Hi nâng cao trình độ và giúp anh giành được vai nam chính trong phim. Từ hai con người có tính cách và thói quen trái ngược, họ dần quen với sự xuất hiện của đối phương.</p>","tmdb":{"type":"tv","id":"157638","season":1,"vote_average":6.9,"vote_count":9},"modified":"2022-06-19T14:07:51.000Z","cast":["Sun Zeyuan","Lư Dương Dương","Xu Heni","Kong Xiao Ming","Chen Pengwanli","Han Dan","Vương Lộ Tình","Tạ Hưng Dương","Yao Jun Zhe","Zhang Tong","Tiêu Vũ Lương","Huai Yuan","Shang Guantong","Yucheng Cao","Li Jiajia"],"director":["Li Wen Hao"],"cast_meta":[{"name":"Sun Zeyuan","name_vi":null,"name_original":"Sun Zeyuan","tmdb_id":1997251,"profile":"https://image.tmdb.org/t/p/w500/7R7ez7MnjMkVprfIRBw7G3NG452.jpg","tmdb_url":"https://www.themoviedb.org/person/1997251"},{"name":"Lư Dương Dương","name_vi":"Lư Dương Dương","name_original":"Lu Yangyang","tmdb_id":2295780,"profile":"https://image.tmdb.org/t/p/w500/hwcIF6awLZPiQI2UU9YCo4Ubuli.jpg","tmdb_url":"https://www.themoviedb.org/person/2295780"},{"name":"Xu Heni","name_vi":null,"name_original":"Xu Heni","tmdb_id":1833172,"profile":"https://image.tmdb.org/t/p/w500/rAwpKR5aBLrHD5v8mDd6MGdnFeC.jpg","tmdb_url":"https://www.themoviedb.org/person/1833172"},{"name":"Kong Xiao Ming","name_vi":null,"name_original":"Kong Xiao Ming","tmdb_id":3427456,"profile":"https://image.tmdb.org/t/p/w500/hCmJ5bo7ZUgE5MxZ7FaOy9RCbpA.jpg","tmdb_url":"https://www.themoviedb.org/person/3427456"},{"name":"Chen Pengwanli","name_vi":null,"name_original":"Chen Pengwanli",