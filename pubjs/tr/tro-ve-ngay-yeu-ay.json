12.com/20220627/22618_d68f00d4/index.m3u8"},{"name":"21B","slug":"21b","filename":"tro-ve-ngay-yeu-ay-dejavu-rak-yon-welah-tap-21B","link_embed":"https://vip.opstream12.com/share/f10a347a96638e91f5e715eb44299b88","link_m3u8":"https://vip.opstream12.com/20220627/22614_18001b29/index.m3u8"},{"name":"22A","slug":"22a","filename":"tro-ve-ngay-yeu-ay-dejavu-rak-yon-welah-tap-22A","link_embed":"https://vip.opstream12.com/share/09f4d591f9ff9e5e0bb6766b0188d017","link_m3u8":"https://vip.opstream12.com/20220627/22617_992d6d21/index.m3u8"},{"name":"22B","slug":"22b","filename":"tro-ve-ngay-yeu-ay-dejavu-rak-yon-welah-tap-22B","link_embed":"https://vip.opstream12.com/share/38dadc9fae7b5a4415d01986ee4907fe","link_m3u8":"https://vip.opstream12.com/20220627/22615_501d7c1f/index.m3u8"}]}],"time":"46phút/tập","description":"<p>Bản quyền phim thuộc 5Dmax. Trở Về Ngày Yêu Ấy được phát song song đài Thái Lan vào 23h thứ Tư, thứ Năm hàng tuần từ ngày 19/1/2020. Đây là bộ phim tình cảm của Thái Lan với sự tham gia của Pong Nawat, Esther Supreeleela... Nội dung phim xoay quanh Jane - một nữ diễn viên ba lê. Tình yêu đến sau khi Jane cứu Wyn - người thừa kế trẻ của Tập đoàn PetchNatee - khỏi một trận hỏa hoạn. Sau ba năm yêu, Wyn đưa Jane ra ngoài thành phố để cầu hôn. Cô đã đồng ý nhưng không may khi trở lại, chiếc xe của họ đã bị hỏng và vụ tai nạn đã cướp đi mạng sống của Wyn. Jane rất đau lòng và trở lại nơi xưa để hồi tưởng về những ngày tháng tốt đẹp của họ. Một cơn bão kỳ lạ sau đó đến và nhấn chìm thuyền của Jane, giúp cô gặp được thần biển, người cho cô cơ hội quay ngược thời gian. Du hành trở về quá khứ, Jane thấy mình ở thời điểm trước khi xảy ra hỏa hoạn. Lần này cô quyết định cứu Wyn nhưng sau đó tránh xa cuộc đời anh! Hãy theo dõi và xem liệu Wyn có chọn cùng một con đường không và liệu định mệnh có mang lại cuộc sống và tình yêu của họ trở lại với nhau.</p>","tmdb":{"type":"tv","id":"99854","season":1,"vote_average":10,"vote_count":1},"modified":"2023-04-10T13:31:25.000Z","