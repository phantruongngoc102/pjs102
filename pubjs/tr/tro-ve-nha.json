 dân làng với điều kiện Tất Quốc Kiến và Nam Nguyệt Lễ phải kết hôn với nhau. Sau khi di chúc được công bố, cả hai bị dân làng bao vây, vì vậy Tất Quốc Kiến và Nam Nguyệt Lễ đành phải quyết định kết hôn với nhau để thực hiện di chúc.</p>","tmdb":{"type":"tv","id":"90426","season":1,"vote_average":0,"vote_count":0},"modified":"2022-12-25T20:08:22.000Z","cast":["Xie Kun-da","Lin Si-yu","Wu Nien-hsuan","Angela Lee","Liu Hsiao-yi","Akio Chen","Yang Kuei-mei"],"director":["Quách Xuân Huy"],"cast_meta":[{"name":"Xie Kun-da","name_vi":null,"name_original":"Xie Kun-da","tmdb_id":1258481,"profile":"https://image.tmdb.org/t/p/w500/x9qd7RaiD2JLK8a7UaquiYrWwDY.jpg","tmdb_url":"https://www.themoviedb.org/person/1258481"},{"name":"Lin Si-yu","name_vi":null,"name_original":"Lin Si-yu","tmdb_id":2341280,"profile":"https://image.tmdb.org/t/p/w500/p2wp78gk9PoIg32DL24KxGyue2V.jpg","tmdb_url":"https://www.themoviedb.org/person/2341280"},{"name":"Wu Nien-hsuan","name_vi":null,"name_original":"Wu Nien-hsuan","tmdb_id":2341301,"profile":"https://image.tmdb.org/t/p/w500/v8BsRtGI3Z0FWubtuK7B4a9IgOw.jpg","tmdb_url":"https://www.themoviedb.org/person/2341301"},{"name":"Angela Lee","name_vi":null,"name_original":"Angela Lee","tmdb_id":2341304,"profile":"https://image.tmdb.org/t/p/w500/4g11TiNq8KVJl7ErpoALxKJJU5S.jpg","tmdb_url":"https://www.themoviedb.org/person/2341304"},{"name":"Liu Hsiao-yi","name_vi":null,"name_original":"Liu Hsiao-yi","tmdb_id":2341314,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2341314"},{"name":"Akio Chen","name_vi":null,"name_original":"Akio Chen","tmdb_id":1258444,"profile":"https://image.tmdb.org/t/p/w500/pVRNH2f1o03zg0zOjoGBq23gXyh.jpg","tmdb_url":"https://www.themoviedb.org/person/1258444"},{"name":"Yang Kuei-mei","name_vi":null,"name_original":"Yang Kuei-mei","tmdb_id":65354,"profile":"https://image.tmdb.org/t/p/w500/bQuu5naLHk5ergPgQZXpGXJm3aO.jpg","tmdb_url":"https://www.themoviedb.org/person/65354"}],"keywords":[],"tmdb_checked":true,"pubjs_url