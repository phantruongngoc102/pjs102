hặn nó lại. Tài xế đã cứu con gái cô. Cả hai được đưa đến bệnh viện, nơi cơ thể của Yến Gia vẫn trong tình trạng hôn mê sâu.</p>","tmdb":{"type":"tv","id":"","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-30T10:31:48.000Z","cast":[],"director":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/troi-cho-toi-49-ngay-short-drama.json","keywords":[],"tmdb_checked":false}