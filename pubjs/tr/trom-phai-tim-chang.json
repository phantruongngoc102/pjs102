p.opstream14.com/20230101/28940_fdd1c69c/index.m3u8"}]}],"time":"25 phút/tập","description":"<p>Đệ nhất nữ tặc của An Hồn các đang có ý định rửa tay gác kiếm, quy ẩn chốn đồng quê. Nàng được giao nhiệm vụ đánh cắp bản đồ phòng thủ biên giới phía Nam của chiến thần nước Đông Duệ, Định Nam Tướng quân. Trong quá trình trà trộn vào làm tùy tùng thân cận bên cạnh Tướng quân, nàng đã đem lòng yêu nam nhân trung quân ái quốc này, đồng thời thấu hiểu đại nghĩa quốc gia, từ đó sát cánh cùng Tướng quân chống lại giặc thù, viết nên câu chuyện kề vai chiến đấu tuyệt đẹp.</p>","tmdb":{"type":"tv","id":"217252","season":1,"vote_average":5,"vote_count":1},"modified":"2025-04-23T13:20:22.000Z","cast":["Zhang Jialin","Hei Ze","Đại Siêu","Ariel Ann"],"director":["Nhậm San San"],"cast_meta":[{"name":"Zhang Jialin","name_vi":null,"name_original":"Zhang Jialin","tmdb_id":2787699,"profile":"https://image.tmdb.org/t/p/w500/5eMjV4wvzammoJlC1zrV4EDohoh.jpg","tmdb_url":"https://www.themoviedb.org/person/2787699"},{"name":"Hei Ze","name_vi":null,"name_original":"Hei Ze","tmdb_id":3217775,"profile":"https://image.tmdb.org/t/p/w500/6jVx1RUGbJP93QTAOPCpSFa7HU4.jpg","tmdb_url":"https://www.themoviedb.org/person/3217775"},{"name":"Đại Siêu","name_vi":"Đại Siêu","name_original":"Dai Chao","tmdb_id":2133083,"profile":"https://image.tmdb.org/t/p/w500/uZPt9b9Ktd4sEVKdJBUW8tDsy7p.jpg","tmdb_url":"https://www.themoviedb.org/person/2133083"},{"name":"Ariel Ann","name_vi":null,"name_original":"Ariel Ann","tmdb_id":2148814,"profile":"https://image.tmdb.org/t/p/w500/6vuoeReG4SXf5NLMJmo3sv34iWk.jpg","tmdb_url":"https://www.themoviedb.org/person/2148814"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/trom-phai-tim-chang.json"}