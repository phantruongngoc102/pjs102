/31193_d7524e44/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream12.com/share/b6622e4ef1a8d811316fe50fd2975faf","link_m3u8":"https://vip.opstream12.com/20251219/31194_b6622e4e/index.m3u8"},{"name":"15","slug":"15","link_embed":"https://vip.opstream12.com/share/16a153a27394122922a55fb102f602e3","link_m3u8":"https://vip.opstream12.com/20251219/31195_16a153a2/index.m3u8"},{"name":"16","slug":"16","link_embed":"https://vip.opstream12.com/share/6a6a73c9c5eecb746b0ab4c888939818","link_m3u8":"https://vip.opstream12.com/20251219/31196_6a6a73c9/index.m3u8"}]}],"description":"<p>Vào đầu thế kỷ, do nhu cầu dự trữ nước của các dự án thủy lợi, một thị trấn nhỏ ven sông sắp bị nhấn chìm. Người dân đang tất bật xây dựng thành phố mới và di cư. Mùa hè năm 2002, thành phố Đông Giang hứng chịu một trận mưa lớn. Một vụ án mạng kỳ lạ lọt vào tầm ngắm của cảnh sát. Một người tình đã chết và một người chồng mất tích rồi sống lại vừa là \"kẻ giết người\" vừa là \"người chết\". Cuối cùng, dưới sự điều tra không ngừng nghỉ của cảnh sát, một quá khứ phủ bụi nhiều năm đã được hé lộ. Sự phức tạp của bản chất con người đã che mắt biết bao người, nhưng sự thật sẽ không bao giờ bị che khuất. Mọi thứ bạn nhìn thấy đều là ánh nắng mặt trời.</p>","tmdb_id":280063,"cast":["La Tấn","Vương Tử Văn","Dư Nam","Trần Kim"],"director":["毛鲲宇"],"keywords":[],"tmdb":{"type":"tv","id":"280063","season":1,"vote_average":7.5,"vote_count":2},"cast_meta":[{"name":"La Tấn","name_vi":"La Tấn","name_original":"Luo Jin","tmdb_id":1115666,"profile":"https://image.tmdb.org/t/p/w500/qP8nQt2PpHh19odhuhUXqGqdEO9.jpg","tmdb_url":"https://www.themoviedb.org/person/1115666"},{"name":"Vương Tử Văn","name_vi":"Vương Tử Văn","name_original":"Wang Ziwen","tmdb_id":1006594,"profile":"https://image.tmdb.org/t/p/w500/qcbGx4uKq3HAbAZRsZkrOztVgGe.jpg","tmdb_url":"https://www.themoviedb.org/person/1006594"},{"name":"Dư Nam","name_vi":"Dư Nam","name_original":"Yu Nan","tmdb_id":27084,"profile":"https://image.tmdb.or