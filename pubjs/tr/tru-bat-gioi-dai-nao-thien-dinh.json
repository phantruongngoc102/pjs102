m3u8"},{"name":"40","slug":"40","link_embed":"https://vip.opstream11.com/share/f7f62619bfc41df6707311b79ab5e3e6","link_m3u8":"https://vip.opstream11.com/20220528/27173_ad8e8017/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream11.com/share/c19fa3728a347ac2a373dbb5c44ba1c2","link_m3u8":"https://vip.opstream11.com/20220528/27174_0f464131/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream11.com/share/e1cb9ebefa419a866a655b1a74d4b0df","link_m3u8":"https://vip.opstream11.com/20220528/27175_bb71c6f6/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream11.com/share/312e53ccba0b2ddfefd4a1f05b55bcdd","link_m3u8":"https://vip.opstream11.com/20220528/27176_35867cc9/index.m3u8"}]}],"description":"<p>Trư Bát Giới Đại Náo Thiên Đình kể về những thăng trầm của chàng Trư Bát Giới. Vì cơ duyên hội ngộ, Bát Giới quen được cẩu yêu Hạo Thiên Khuyển. Một ngày nọ, hai người đã đánh bại Lôi Công lạm sát người vô tội, từ đó kết oán với Lôi Công. Bát Giới nhiều lần phạm thiên điều, không những đã yêu nữ vương Nữ Nhi Quốc, còn trúng phải tình độc chí mạng. Thiết Tảo chung tình với Bát Giới dùng tuyệt chiêu của mình để cứu chàng sắp chết vì vỡ tim, nhưng Bát Giới vẫn chấp mê bất ngộ, vẫn si tình với nữ vương Nữ Nhi Quốc. Trong lúc không hay biết, Bát Giới bị cuốn vào tranh đấu đế hậu của thiên đình, bị tước thẻ bài thần tiên, đày xuống hạ giới làm Thổ Địa.</p>","tmdb_id":null,"cast":["Hân Tuyết","Hồ Đông","Trần Long","Từ Cẩm Giang","Huỳnh Hải Băng"],"director":["Lý Khải"],"keywords":[],"time":"45 phút/tập","tmdb":{"type":null,"id":"","season":null,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Hân Tuyết","name_vi":null,"name_original":"Hân Tuyết"},{"name":"Hồ Đông","name_vi":null,"name_original":"Hồ Đông"},{"name":"Trần Long","name_vi":null,"name_original":"Trần Long"},{"name":"Từ Cẩm Giang","name_vi":null,"name_original":"Từ Cẩm Giang"},{"name":"Huỳnh Hải Băng","name_vi":null,"name_original":"Huỳnh Hải Băng"}],"pubjs_url"