{"id":"67c6676f75e275d00a3a3468","title":"Trừ Độc","origin_name":"The Enigma of Arrival","slug":"tru-doc","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/tr/tru-doc.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/tr/tru-doc.webp","year":2024,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"is_ai":false,"server_name":"Vietsub #1","server_data":[{"name":"Full","slug":"full","filename":"The Enigma Of Arrival 2024","link_embed":"https://vip.opstream16.com/share/748aae853cec038ddf04d18e51be9438","link_m3u8":"https://vip.opstream16.com/20250303/41153_748aae85/index.m3u8"}]}],"time":"85 Phút","description":"<p>Cảnh sát phòng chống ma túy Dịch Vĩnh Chính được phái đi điều tra một vụ án ma túy và gặp lại người bạn cũ. Năm xưa, để cứu con trai mình, Đinh Chỉ Đồng đã gia nhập vào một tổ chức buôn ma túy, bị kẻ thù truy sát và chồng cũng qua đời vì cô. Sau khi suy nghĩ lại, Đinh Chỉ Đồng quyết định giao nộp bằng chứng cho Dịch Vĩnh Chính. Đáng tiếc, hành động của cô đã bị phát hiện từ trước. Cuối cùng, cô hợp tác với Dịch Vĩnh Chính, cùng nhau triệt phá tổ chức buôn ma túy và chấp nhận chịu sự trừng phạt của pháp luật.</p>","tmdb":{"type":"movie","id":"1381569","season":null,"vote_average":8,"vote_count":1},"modified":"2025-03-15T13:57:52.000Z","cast":["Jiang Yisheng","Shi Zhaoqi","Zhao Longhao","Wei Lu","Bai Hongbiao","Baode Wang"],"director":["姜艺声","胥明文"],"cast_meta":[{"name":"Jiang Yisheng","name_vi":null,"name_original":"Jiang Yisheng","tmdb_id":2512387,"profile":"https://image.tmdb.org/t/p/w500/lYibuw0RuRsD6JvXLlSe16