ợc sự tin tưởng của Long Chí Cường, âm thầm phối hợp với cảnh sát giăng thiên la địa võng thì hóa ra đây là cái bẫy.","tmdb":{"type":"movie","id":"602661","season":null,"vote_average":5.97,"vote_count":33},"modified":"2023-05-16T14:57:24.000Z","cast":["Lương Gia Huy","Cổ Thiên Lạc","Lâm Gia Đống","Khâu Ý Nùng","Nhậm Đạt Hoa","Ye Xiangming","Phat Chan","Vi Gia Hùng","Du Jiang","Candice Yu On-On","Connie Man","Lukian Wang","Jason Wong","Michael Wong","Fiona Zhen"],"director":["Wong Jing","Jason Kwan"],"cast_meta":[{"name":"Lương Gia Huy","name_vi":"Lương Gia Huy","name_original":"Tony Leung Ka-fai","tmdb_id":56861,"profile":"https://image.tmdb.org/t/p/w500/il4L0QSp5STfZCB1wsvb6rSCDar.jpg","tmdb_url":"https://www.themoviedb.org/person/56861"},{"name":"Cổ Thiên Lạc","name_vi":"Cổ Thiên Lạc","name_original":"Louis Koo","tmdb_id":78875,"profile":"https://image.tmdb.org/t/p/w500/yQuDBTzm7xWlJICNvl20OmcJP80.jpg","tmdb_url":"https://www.themoviedb.org/person/78875"},{"name":"Lâm Gia Đống","name_vi":"Lâm Gia Đống","name_original":"Gordon Lam Ka-Tung","tmdb_id":83820,"profile":"https://image.tmdb.org/t/p/w500/61gQoVwgpd4qzovOaZjzJpdm47K.jpg","tmdb_url":"https://www.themoviedb.org/person/83820"},{"name":"Khâu Ý Nùng","name_vi":"Khâu Ý Nùng","name_original":"Sabrina Qiu","tmdb_id":1399228,"profile":"https://image.tmdb.org/t/p/w500/cXuhzwtSqPpWPCUW3tJW9J6oHGP.jpg","tmdb_url":"https://www.themoviedb.org/person/1399228"},{"name":"Nhậm Đạt Hoa","name_vi":"Nhậm Đạt Hoa","name_original":"Simon Yam","tmdb_id":20519,"profile":"https://image.tmdb.org/t/p/w500/eilxjMhfobctnzZ0kBcFmnqtFyd.jpg","tmdb_url":"https://www.themoviedb.org/person/20519"},{"name":"Ye Xiangming","name_vi":null,"name_original":"Ye Xiangming","tmdb_id":2022209,"profile":"https://image.tmdb.org/t/p/w500/qtCHmgDwomqAkzm1y72uN350PlP.jpg","tmdb_url":"https://www.themoviedb.org/person/2022209"},{"name":"Phat Chan","name_vi":null,"name_original":"Phat Chan","tmdb_id":1183231,"profile":"https://image.tmdb.org/t/p/w500/kb0Qnc