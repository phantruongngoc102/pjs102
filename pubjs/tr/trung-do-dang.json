":"25","slug":"25","filename":"Insect Totem EP25","link_embed":"https://vip.opstream16.com/share/3e95b38ce315f12892dee0121e6fad4a","link_m3u8":"https://vip.opstream16.com/20230127/30103_31cd4dbf/index.m3u8"},{"name":"26","slug":"26","filename":"Insect Totem EP26","link_embed":"https://vip.opstream16.com/share/7ca595cd7955654b36629c1470763487","link_m3u8":"https://vip.opstream16.com/20230127/30104_71c9edb5/index.m3u8"},{"name":"27","slug":"27","filename":"Insect Totem EP27","link_embed":"https://vip.opstream16.com/share/453129ee88ee891d1b7581e77eafac40","link_m3u8":"https://vip.opstream16.com/20230128/30191_def9ab5c/index.m3u8"},{"name":"28","slug":"28","filename":"Insect Totem EP28","link_embed":"https://vip.opstream16.com/share/a154ffbcec538a4161a406abf62f5b76","link_m3u8":"https://vip.opstream16.com/20230128/30192_cd6454be/index.m3u8"},{"name":"29","slug":"29","filename":"Insect Totem EP29","link_embed":"https://vip.opstream16.com/share/b8321cc2ef02a2823b92d06f2ea3e298","link_m3u8":"https://vip.opstream16.com/20230129/30247_095ab5ea/index.m3u8"},{"name":"30","slug":"30","filename":"Insect Totem EP30","link_embed":"https://vip.opstream16.com/share/35405f014bb0dbc14cea7766ccd0256e","link_m3u8":"https://vip.opstream16.com/20230129/30248_14660c96/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Ở thời Dân Quốc, danh y Phan Tuấn của Trùng Thảo Đường và hậu duệ của năm đại gia tộc Trùng tộc gặp gỡ nhau, biết được manh mối của tổ tiên liên quan đến kho báu Trùng tộc, từ đó dấn thân vào hành trình tìm kiếm báu vật gia tộc để lại. Họ bầu bạn với nhau, cùng tìm kiếm báu vật của năm tộc để có thể khởi động kho báu. Suốt thời gian này, họ ngao du qua các nơi, tìm tòi bí mật về tổ tiên, chống lại dịch bệnh và sự bất công trên đường đi. Khi càng lúc càng đến gần kho báu thì lại bị thế lực của kẻ trộm kho báu tấn công, nhờ đó đã vạch trần chân tướng vụ tranh đoạt kho báu 20 năm về trước. Từ khát vọng làm giàu ban đầu, họ cũng dần dần gánh vác sứ mệnh bảo vệ kho báu quốc gia, nhiều lần giằng co với kẻ trộm kho báu, cuối cùng đập tan lòng tham của đối phương, khiến kho báu Trùng tộc trong truyền thuyết lại một lần nữa được nhìn thấy ánh sáng. Trong quá trình đó, họ học được cách hợp tác tập thể, xây dựng tình bạn sâu sắc và phát triển thành tình yêu trong sáng, từ thiếu niên ngây ngô trở thành anh hùng có tinh thần trách nhiệm.</p>","tmdb":{"type":"tv","id":"217778","season":1,"vote_average":8,"vote_count":2},"modified":"2025-07-18T16:39:31.000Z","cast":["Zhang Ming'en","Hồ Băng Khanh","Aliyah","Lu Yunfeng","Zhang Jiading","Ding Xiangnan","Liu Weiwei","Xie Yuan","Chu Vịnh Đằng","Sha Baoliang","Zhou Xiaoou","Wang Xiao"],"director":[],"cast_meta":[{"name":"Zhang Ming'en","name_vi":null,"name_original":"Zhang Ming'en","tmdb_id":1875562,"profile":"https://image.tmdb.org/t/p/w500/jh9UTeOzs38OO7KqVjp8KvaVfSG.jpg","tmdb_url":"https://www.themoviedb.org/person/1875562"},{"name":"Hồ Băng Khanh","name_vi":"Hồ Băng Khanh","name_original":"Hu Bingqing","tmdb_id":1549582,"profile":"https://image.tmdb.org/t/p/w500/32BVbSXdAnKAJ6QXKHW36fBLVEF.jpg","tmdb_url":"https://www.themoviedb.org/person/1549582"},{"name":"Aliyah","name_vi":null,"name_original":"Aliyah","tmdb_id":2634117,"profile":"https://image.tmdb.org/t/p/w500/xTjnbfDQNE4gg2NXqUOJBBbTlPS.jpg","tmdb_url":"https://www.themoviedb.org/person/2634117"},{"name":"Lu Yunfeng","name_vi":null,"name_original":"Lu Yunfeng","tmdb_id":2500602,"profile":"https://image.tmdb.org/t/p/w500/1JdMTEJUuk8nxENyFs2TcqLJx0C.jpg","tmdb_url":"https://www.themoviedb.org/person/2500602"},{"name":"Zhang Jiading","name_vi":null,"name_original":"Zhang Jiading","tmdb_id":2713786,"profile":"https://image.tmdb.org/t/p/w500/rcrQAEfsJfs1OJX2NgdqAJy9t2q.jpg","tmdb_url":"https://www.themoviedb.org/person/2713786"},{"name":"Ding Xiangnan","name_vi":null,"name_original":"Ding Xiangnan","tmdb_id":2036541,"profile":"https://image.tmdb.org/t/p/w500/yDuRTwznimbamLlje6wvd6wqZ03.jpg","tmdb_url":"https://www.themoviedb.org/person/2036541"},