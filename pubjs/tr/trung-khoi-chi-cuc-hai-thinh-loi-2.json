891ed23f5677a174ea","link_m3u8":"https://vip.opstream14.com/20220328/3970_d49bbbd8/index.m3u8"}]}],"time":"45M28S","description":"<p>Nội dung phim xoay quanh việc sau khi Ngô Tà vào làm tại kho 11 biết được chú ba phát hiện tiếng sấm ở kho Tử Đương, đã tiến hành điều tra lần nữa. Anh cùng Vương Bàn Tử, Trương Khởi Linh, Bạch Hạo Thiên lên đường đi tìm tung tích của chú ba, cuối cùng đến được với Thành Sấm. Trong khi họ tìm cách giải đáp bí ẩn trong chuyện “nghe sấm”, một âm mưu bí ẩn đã lâu cũng đang từng bước tiếp cận Ngô Tà và mọi người.</p>","tmdb":{"type":"tv","id":"105962","season":2,"vote_average":7.9,"vote_count":10},"modified":"2025-06-18T09:51:48.000Z","cast":["Chu Nhất Long","Mao Hiểu Đồng","Hồ Quân","Trần Sở Hà","Huang Junjie","Chen Minghao","Hoàng Mộng Oánh"],"director":["ANZI PAN"],"cast_meta":[{"name":"Chu Nhất Long","name_vi":"Chu Nhất Long","name_original":"Zhu Yilong","tmdb_id":1743471,"profile":"https://image.tmdb.org/t/p/w500/tdm21vg4E7ubhd429UT1UpPpFGo.jpg","tmdb_url":"https://www.themoviedb.org/person/1743471"},{"name":"Mao Hiểu Đồng","name_vi":"Mao Hiểu Đồng","name_original":"Mao Xiaotong","tmdb_id":1697058,"profile":"https://image.tmdb.org/t/p/w500/zOrbXf5SInGL06eYi56Z0jxI99G.jpg","tmdb_url":"https://www.themoviedb.org/person/1697058"},{"name":"Hồ Quân","name_vi":"Hồ Quân","name_original":"Hu Jun","tmdb_id":96862,"profile":"https://image.tmdb.org/t/p/w500/3RXwZKvACtHdnrmOvQbJWJa718W.jpg","tmdb_url":"https://www.themoviedb.org/person/96862"},{"name":"Trần Sở Hà","name_vi":"Trần Sở Hà","name_original":"Baron Chen","tmdb_id":118725,"profile":"https://image.tmdb.org/t/p/w500/cIC1Erx4W8A7b7WwcrtqpQ0Ue3l.jpg","tmdb_url":"https://www.themoviedb.org/person/118725"},{"name":"Huang Junjie","name_vi":null,"name_original":"Huang Junjie","tmdb_id":1926550,"profile":"https://image.tmdb.org/t/p/w500/fBiEiyYdDzrhyXqL8n9BNryn12y.jpg","tmdb_url":"https://www.themoviedb.org/person/1926550"},{"name":"Chen Minghao","name_vi":null,"name_original":"Chen Minghao","tm