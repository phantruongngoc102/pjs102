ết giao với Vi Nhược Chiêu và Lý Tú Nhất. Mối quan hệ của ba người bị cuốn trong các vụ án giết người, những cảm xúc đan xen giữa tình yêu và tình bạn.</p>","tmdb_id":86277,"cast":[],"director":[],"keywords":[],"tmdb":{"id":86277},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/truong-an-tam-quai-tham.json"}