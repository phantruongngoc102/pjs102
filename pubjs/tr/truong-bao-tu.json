.com/share/485b551f4f68d315b9a0856bd3c92195","link_m3u8":"https://vip.opstream16.com/20230417/33992_925a7bca/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream16.com/share/1690bccd010b308cd33989d3819ed96a","link_m3u8":"https://vip.opstream16.com/20230417/33993_76ab63e4/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream16.com/share/16755a59feefe5a2e038fa89eb54278d","link_m3u8":"https://vip.opstream16.com/20230417/33994_ec5b5d4c/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream16.com/share/8e017d9b51e7b9284cd0da58fae39b33","link_m3u8":"https://vip.opstream16.com/20230417/33995_bc84a5a1/index.m3u8"}]}],"description":"<p>Kể về anh chàng Trương Bảo Tử là một tên cướp vô cùng khét tiếng cào thời nhà Thanh. Mặc dù Bảo Tử giết vô số người nhưng không bao giờ làm hại dân vô tội. Không những thế anh chỉ cướp của người giàu và quân tham ô trong triều đình để có thể nuôi dưỡng những người anh em của mình. Tuy Nhiên, sau đó lại xảy ra biến cố khiến cho Bao Tử trở thành kẻ thù của những người dân, và không những thế trong chuyến hành trình trên biển anh gặp phải cơn lốc xoáy và vô tình gặp gỡ cô gái Huỳnh Đệ Muội từ thời hiện đại quay trở về quá khứ.<br>&nbsp;</p>","tmdb_id":82531,"cast":[],"director":[],"keywords":[],"tmdb":{"id":82531},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/truong-bao-tu.json"}