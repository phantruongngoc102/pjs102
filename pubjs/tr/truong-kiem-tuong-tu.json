p.opstream11.com/20240830/52216_0bfb1562/index.m3u8"},{"name":"33","slug":"33","filename":"Truong Kiem Tuong Tu 2005-33","link_embed":"https://vip.opstream11.com/share/cccb7f7cfe7acc3641e17927f820c159","link_m3u8":"https://vip.opstream11.com/20240830/52217_cccb7f7c/index.m3u8"},{"name":"34","slug":"34","filename":"Truong Kiem Tuong Tu 2005-34","link_embed":"https://vip.opstream11.com/share/5d7eecd2ceeaf37717c50a6372d42e41","link_m3u8":"https://vip.opstream11.com/20240830/52218_5d7eecd2/index.m3u8"},{"name":"35","slug":"35","filename":"Truong Kiem Tuong Tu 2005-35.end","link_embed":"https://vip.opstream11.com/share/e5b2b969f92ce208b531c252d9ccacc5","link_m3u8":"https://vip.opstream11.com/20240830/52219_e5b2b969/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Được chuyển thể từ tiểu thuyết võ hiệp cùng tên của nhà văn Tiêu Dật Thời Minh, triều Chính Đức, Trung nguyên gặp đại hạn, dân chúng lưu lạc, bọn hoạn quan chuyên quyền, thừa cơ muốn huyết tẩy giang hồ. Thế lực ác nhân trong giang hổ cũng thừa cơ làm loạn nhân gian, đề xướng \" diệt thiện , kích ác \", công nhiên khiêu chiến thiên hạ. Chính trong thời khắc nguy cấp này, xuất hiện một chàng thiếu niên bí ẩn, chàng mang trên mình gánh nặng của mối huyết hải thâm thù của \" Yến Gia bảo \", chàng chính là Yến Truy Vân.Từ đó, chàng đã đi khắp nơi hành hiệp, diệt ác, gây nên những sự việc làm bọn giang hồ ác nhân kinh tâm táng đởm. 2 phái chính tà bắt đầu triển khai 1 trường tranh đấu kinh tâm động phách...</i></p>","tmdb":{"type":"tv","id":"","season":null,"vote_average":0,"vote_count":0},"modified":"2024-08-31T16:13:30.000Z","cast":["Trần Khôn","Lý Băng Băng","Lý Thanh","Huỳng Giác","Hàn Hiểu","Vương Á Nam","Thiên Tâm"],"director":["Lý Tuệ Dân"],"cast_meta":[{"name":"Trần Khôn","name_vi":null,"name_original":"Trần Khôn"},{"name":"Lý Băng Băng","name_vi":null,"name_original":"Lý Băng Băng"},{"name":"Lý Thanh","name_vi":null,"name_original":"Lý Thanh"},{"name":"Huỳng Giác","name_vi":null,"name_original":"Huỳn