u Thần đi theo bước chân của những người trường sinh bất tử, từ từ vén lên bức màn bí ẩn về một thế giới thần thoại cổ xưa bị cát bụi phong</p>","tmdb":{"type":"tv","id":"273600","season":1,"vote_average":9,"vote_count":4},"modified":"2025-04-15T12:37:04.000Z","cast":["Liang Dawei","Yajing Tang","Huang Ying","Kaiyin Sun","Danni Pan","Zhuoting Li","伍凯立","Yu Kailong","Xiyue Chen","Xiang Xu"],"director":[],"cast_meta":[{"name":"Liang Dawei","name_vi":null,"name_original":"Liang Dawei","tmdb_id":2196310,"profile":"https://image.tmdb.org/t/p/w500/yNXWQKc8K5JJlmsSs1pMhjjAhzj.jpg","tmdb_url":"https://www.themoviedb.org/person/2196310"},{"name":"Yajing Tang","name_vi":null,"name_original":"Yajing Tang","tmdb_id":2196311,"profile":"https://image.tmdb.org/t/p/w500/1woRUHdnQLzpIeHsDQsgBfs4WRU.jpg","tmdb_url":"https://www.themoviedb.org/person/2196311"},{"name":"Huang Ying","name_vi":null,"name_original":"Huang Ying","tmdb_id":1496419,"profile":"https://image.tmdb.org/t/p/w500/cchQTm4OdkjJ8g3GKcBdCfDmoJI.jpg","tmdb_url":"https://www.themoviedb.org/person/1496419"},{"name":"Kaiyin Sun","name_vi":null,"name_original":"Kaiyin Sun","tmdb_id":4174198,"profile":"https://image.tmdb.org/t/p/w500/4C5SuU7o8vzKLdllClA9bscLNCS.jpg","tmdb_url":"https://www.themoviedb.org/person/4174198"},{"name":"Danni Pan","name_vi":null,"name_original":"Danni Pan","tmdb_id":3791120,"profile":"https://image.tmdb.org/t/p/w500/8wlKS7XCbZiubKd79OfQ3KUOypr.jpg","tmdb_url":"https://www.themoviedb.org/person/3791120"},{"name":"Zhuoting Li","name_vi":null,"name_original":"Zhuoting Li","tmdb_id":3791109,"profile":"https://image.tmdb.org/t/p/w500/hl0revCT0QvImC5G2Cna09sZS3a.jpg","tmdb_url":"https://www.themoviedb.org/person/3791109"},{"name":"伍凯立","name_vi":null,"name_original":"伍凯立","tmdb_id":5292077,"profile":"https://image.tmdb.org/t/p/w500/bTgE12pNu1dIXThE7WPUdW3NCkz.jpg","tmdb_url":"https://www.themoviedb.org/person/5292077"},{"name":"Yu Kailong","name_vi":null,"name_original":"Yu Kailong","tmdb_id":4784617,"p