10524,"cast":["Dương Tử","Trương Vãn Ý","Đặng Vi","Đàn Kiện Thứ","Đại Lộ Oa","Vương Hoằng Nghị","Hoàng Xán Xán"],"director":["Zoe Qin","Yang Huan"],"keywords":[],"tmdb":{"type":"tv","id":"210524","season":2,"vote_average":7.5,"vote_count":18},"cast_meta":[{"name":"Dương Tử","name_vi":"Dương Tử","name_original":"Yang Zi","tmdb_id":1696482,"profile":"https://image.tmdb.org/t/p/w500/20Nc1xnRFC5XGsb896ZxVNUOzFU.jpg","tmdb_url":"https://www.themoviedb.org/person/1696482"},{"name":"Trương Vãn Ý","name_vi":"Trương Vãn Ý","name_original":"Zhang Wanyi","tmdb_id":3028958,"profile":"https://image.tmdb.org/t/p/w500/wG7GZ5XRUgwTMiAQS1gvgJEABKl.jpg","tmdb_url":"https://www.themoviedb.org/person/3028958"},{"name":"Đặng Vi","name_vi":"Đặng Vi","name_original":"Deng Wei","tmdb_id":3082099,"profile":"https://image.tmdb.org/t/p/w500/AtcwQb1B20rvGCw3JRCbOQyVpcN.jpg","tmdb_url":"https://www.themoviedb.org/person/3082099"},{"name":"Đàn Kiện Thứ","name_vi":"Đàn Kiện Thứ","name_original":"Tan Jianci","tmdb_id":2122379,"profile":"https://image.tmdb.org/t/p/w500/3TxJqYIDQM3BOicpjAjSMr88bja.jpg","tmdb_url":"https://www.themoviedb.org/person/2122379"},{"name":"Đại Lộ Oa","name_vi":"Đại Lộ Oa","name_original":"Dai Luwa","tmdb_id":2190499,"profile":"https://image.tmdb.org/t/p/w500/4yJZSb5RAUprTdS2dW5TdiVAWp4.jpg","tmdb_url":"https://www.themoviedb.org/person/2190499"},{"name":"Vương Hoằng Nghị","name_vi":"Vương Hoằng Nghị","name_original":"Wang Hongyi","tmdb_id":3715156,"profile":"https://image.tmdb.org/t/p/w500/6rUH7NxarCBHRDbSmtPisgJq7pn.jpg","tmdb_url":"https://www.themoviedb.org/person/3715156"},{"name":"Hoàng Xán Xán","name_vi":"Hoàng Xán Xán","name_original":"Huang Cancan","tmdb_id":2273809,"profile":"https://image.tmdb.org/t/p/w500/pF4G9RDwp49zTMl92xBF7ndzGoI.jpg","tmdb_url":"https://www.themoviedb.org/person/2273809"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/tr/truong-tuong-tu-phan-2.json"}