e8","link_m3u8":"https://vip.opstream90.com/20260126/23122_30d0da31/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream90.com/share/860b432652504fa60f8da945398e20de","link_m3u8":"https://vip.opstream90.com/20260126/23123_860b4326/index.m3u8"}]}],"description":"<p>Trò bói toán tà thuật của một người nổi tiếng trên mạng chuyên lừa đảo đã dẫn đến một vụ bắt cóc kỳ quái. Trong vòng 24 giờ, âm mưu chồng chất âm mưu, che giấu những bí mật không thể nói ra. Mối quan hệ giữa ba nhóm nhân vật vật đan xen phức tạp. Trong khoảng thời gian 24 giờ, từng lớp, từng lớp âm mưu vốn ẩn dưới mặt nước tưởng như bình lặng dần được lật mở. Hotgirl mạng xinh đẹp, bọn bắt cóc chợ đen, ông chủ hiệu cầm đồ lần lượt xuất hiện; trên hành trình chạy đua với thời gian, hoặc cứu người, mỗi kẻ đều phô diễn thủ đoạn của mình, dần dần lộ ra những bộ mặt xấu xí.</p>","tmdb_id":310145,"cast":["Khương Triều","Shi Yuanting","Zhan Jiaming","Qiang Guoming","Song Xiaorui","Ma Xudong"],"director":["姬俞"],"keywords":[],"tmdb":{"type":"tv","id":"310145","season":1,"vote_average":8,"vote_count":2},"cast_meta":[{"name":"Khương Triều","name_vi":"Khương Triều","name_original":"Jiang Chao","tmdb_id":235521,"profile":"https://image.tmdb.org/t/p/w500/q7Y4kNRkIK1GrfCZSuP7GqRKw85.jpg","tmdb_url":"https://www.themoviedb.org/person/235521"},{"name":"Shi Yuanting","name_vi":null,"name_original":"Shi Yuanting","tmdb_id":2498004,"profile":"https://image.tmdb.org/t/p/w500/89U8671IS0eDxbyVmKAMiu1vD5.jpg","tmdb_url":"https://www.themoviedb.org/person/2498004"},{"name":"Zhan Jiaming","name_vi":null,"name_original":"Zhan Jiaming","tmdb_id":5835778,"profile":"https://image.tmdb.org/t/p/w500/pp5gfNqgaxXeimVOeXGGkBNMfY0.jpg","tmdb_url":"https://www.themoviedb.org/person/5835778"},{"name":"Qiang Guoming","name_vi":null,"name_original":"Qiang Guoming","tmdb_id":5921859,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5921859"},{"name":"Song Xiaorui","name_vi":null,"name_original":"Song Xiaorui","tmdb_