8"}]}],"time":"Đang cập nhật","description":"<p>Shima Tamahiko là con trai út của gia đình Shima quyền lực và giàu có từ nhỏ. Sau khi mất mẹ và bị tàn tật cánh tay trong một vụ tai nạn, Tamahiko rơi vào tuyệt vọng và bị chính cha mình bỏ mặc vì tật nguyền. Bị cho sống biệt lập ở vùng nông thôn. Cho đến một ngày, một cô gái trẻ tên là Tachibana Yuzuki xuất hiện trước cửa nhà anh, tuyên bố rằng cha của Tamahiko đã gửi cô đến làm cô dâu của mình.</p>","tmdb":{"type":"tv","id":"114937","season":1,"vote_average":7.359,"vote_count":39},"modified":"2025-06-10T10:06:21.000Z","cast":["Yusuke Kobayashi","Saya Aizawa","Yume Miyamoto","Chika Anzai","Ayasa Ito","Shunichi Toki"],"director":[],"cast_meta":[{"name":"Yusuke Kobayashi","name_vi":null,"name_original":"Yusuke Kobayashi","tmdb_id":1350418,"profile":"https://image.tmdb.org/t/p/w500/y4ukKDSobZJNuB4H3k89hkrKCDC.jpg","tmdb_url":"https://www.themoviedb.org/person/1350418"},{"name":"Saya Aizawa","name_vi":null,"name_original":"Saya Aizawa","tmdb_id":2467933,"profile":"https://image.tmdb.org/t/p/w500/3QoVKl1w7uBMf5ivJ4MccYkt4zR.jpg","tmdb_url":"https://www.themoviedb.org/person/2467933"},{"name":"Yume Miyamoto","name_vi":null,"name_original":"Yume Miyamoto","tmdb_id":1772522,"profile":"https://image.tmdb.org/t/p/w500/8PzHX7owawEZKq7Eg9WwcmWYx9s.jpg","tmdb_url":"https://www.themoviedb.org/person/1772522"},{"name":"Chika Anzai","name_vi":null,"name_original":"Chika Anzai","tmdb_id":1324927,"profile":"https://image.tmdb.org/t/p/w500/lk3Az9O67qrXR69rctwDDHWqi9d.jpg","tmdb_url":"https://www.themoviedb.org/person/1324927"},{"name":"Ayasa Ito","name_vi":null,"name_original":"Ayasa Ito","tmdb_id":2241366,"profile":"https://image.tmdb.org/t/p/w500/2PrCCbr8wI9lZHtUtyy2SJszua1.jpg","tmdb_url":"https://www.themoviedb.org/person/2241366"},{"name":"Shunichi Toki","name_vi":null,"name_original":"Shunichi Toki","tmdb_id":1922635,"profile":"https://image.tmdb.org/t/p/w500/3hauO9r1NEzgXxk8d2ed1p5dnxM.jpg","tmdb_url":"https://www.themoviedb.org/