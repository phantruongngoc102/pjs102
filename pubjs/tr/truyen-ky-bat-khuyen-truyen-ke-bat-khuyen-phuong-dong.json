ex.m3u8"},{"name":"18","slug":"18","link_embed":"https://vip.opstream14.com/share/3f5d4760ffc7f8a1da5fc490022a9f58","link_m3u8":"https://vip.opstream14.com/20220809/19824_aed7cca4/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/4361c8e1e16420a12979e7acaeae4add","link_m3u8":"https://vip.opstream14.com/20220816/20223_371a1ba8/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/32824c14387bff0a269b11c976c1d0d0","link_m3u8":"https://vip.opstream14.com/20220816/20224_9b958f43/index.m3u8"}]}],"description":"<p>Năm năm trước, hầu hết dân làng Ootsuka đã phải chết vì một cơn bệnh dịch. Nhưng thật thần bí, có 3 người đã sống sót: 1 nữ 2 nam. Họ hiện đang sống tại một nhà thờ tách biệt với thế giới bên ngoài nhằm thoát khỏi sự truy sát của kẻ thù. Đặc biệt thay, Shino, một trong 3 người sống sót đã có được quyền năng của Murasame - thanh kiếm linh hồn. Thế nhưng, cuộc sống yên bình của họ đã kết thúc khi mà Tòa Thánh đã rắp tâm muốn chiếm đoạt Murasame...</p>","tmdb_id":48623,"cast":["Tetsuya Kakihara","Nobuhiko Okamoto","Hino Satoshi","Ayahi Takagaki","Tomoaki Maeno","Takuma Terashima","Hiroshi Kamiya","Daisuke Namikawa","Satomi Akesaka","Junichi Miyake","Shin-ichiro Miki"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"48623","season":1,"vote_average":7.4,"vote_count":19},"cast_meta":[{"name":"Tetsuya Kakihara","name_vi":null,"name_original":"Tetsuya Kakihara","tmdb_id":90134,"profile":"https://image.tmdb.org/t/p/w500/80DeAD6DYh030wsyUygFqDpNkSj.jpg","tmdb_url":"https://www.themoviedb.org/person/90134"},{"name":"Nobuhiko Okamoto","name_vi":null,"name_original":"Nobuhiko Okamoto","tmdb_id":1245094,"profile":"https://image.tmdb.org/t/p/w500/7s1K2yQVF5iIWILaOfG7QrMZkXA.jpg","tmdb_url":"https://www.themoviedb.org/person/1245094"},{"name":"Hino Satoshi","name_vi":"Hino Satoshi","name_original":"Satoshi Hino","tmdb_id":224413,"profile":"https://image.tmdb.org/t/p/w500/8ZJIiwIVF2zDyyFr7oXewj0eEuu.jpg","tm