ao Câu Ly. Sau bao nhiêu khó khăn, cuối cùng Jumong trở thành vua. Vua Jumong đã đưa Cao Câu LY trở thành một cường quốc kể từ sau khi lập nước.","tmdb_id":4734,"cast":["Song Il-gook","Jin Hee-kyung","Song Ji-hyo","Han Hye-jin","Bae Soo-bin","Ahn Yong-jun","Park Tam-hee","Song Ok-suk","Kim Yong-hee","Oh Yeon-soo","Kim Won-Suk","Huh Joon-ho","Oh Ji-young","Kyeon Mi-ri","Yoon Seo-hyun"],"director":["Kim Keun-Hong","Lee Joo-hwan"],"keywords":[],"tmdb":{"type":"tv","id":"4734","season":1,"vote_average":7.304,"vote_count":51},"cast_meta":[{"name":"Song Il-gook","name_vi":null,"name_original":"Song Il-gook","tmdb_id":86887,"profile":"https://image.tmdb.org/t/p/w500/l1SK4GmG636GUzxgK5RoLjwicBZ.jpg","tmdb_url":"https://www.themoviedb.org/person/86887"},{"name":"Jin Hee-kyung","name_vi":null,"name_original":"Jin Hee-kyung","tmdb_id":62336,"profile":"https://image.tmdb.org/t/p/w500/5H0Zkr5tL0ApYaRw6HEF4RaJpVw.jpg","tmdb_url":"https://www.themoviedb.org/person/62336"},{"name":"Song Ji-hyo","name_vi":null,"name_original":"Song Ji-hyo","tmdb_id":85174,"profile":"https://image.tmdb.org/t/p/w500/f3QRDGEqHkeLBQZfWe3GbmHeuuX.jpg","tmdb_url":"https://www.themoviedb.org/person/85174"},{"name":"Han Hye-jin","name_vi":null,"name_original":"Han Hye-jin","tmdb_id":1489755,"profile":"https://image.tmdb.org/t/p/w500/8w6XEFKgq030lons0cChvRQrLF4.jpg","tmdb_url":"https://www.themoviedb.org/person/1489755"},{"name":"Bae Soo-bin","name_vi":null,"name_original":"Bae Soo-bin","tmdb_id":1248899,"profile":"https://image.tmdb.org/t/p/w500/bc1nnZZ1PFMOwVoNodl1Vdo3RA6.jpg","tmdb_url":"https://www.themoviedb.org/person/1248899"},{"name":"Ahn Yong-jun","name_vi":null,"name_original":"Ahn Yong-jun","tmdb_id":1306444,"profile":"https://image.tmdb.org/t/p/w500/pRz99NwKF6gMTWqe0CE3uK8rAVr.jpg","tmdb_url":"https://www.themoviedb.org/person/1306444"},{"name":"Park Tam-hee","name_vi":null,"name_original":"Park Tam-hee","tmdb_id":553690,"profile":"https://image.tmdb.org/t/p/w500/wR6vrGUZJBpfHqRfVSxO4gsa8Ti.jpg",