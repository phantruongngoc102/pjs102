04bc/index.m3u8"},{"name":"15","slug":"","filename":"Truyen Thuyet Nguoi Va Rong 15","link_embed":"https://vip.opstream17.com/share/e9a8f256f4904b06246375df06a8864b","link_m3u8":"https://vip.opstream17.com/20240511/7358_6679fdc5/index.m3u8"},{"name":"16","slug":"","filename":"Truyen Thuyet Nguoi Va Rong 16","link_embed":"https://vip.opstream17.com/share/f065d878ccfb4cc4f4265a4ff8bafa9a","link_m3u8":"https://vip.opstream17.com/20240511/7357_1af8f76e/index.m3u8"},{"name":"17","slug":"","filename":"Truyen Thuyet Nguoi Va Rong 17","link_embed":"https://vip.opstream17.com/share/0ea6f098a59fcf2462afc50d130ff034","link_m3u8":"https://vip.opstream17.com/20240511/7356_5ba721f6/index.m3u8"},{"name":"18","slug":"","filename":"Truyen Thuyet Nguoi Va Rong 18","link_embed":"https://vip.opstream17.com/share/536eecee295b92db6b32194e269541f8","link_m3u8":"https://vip.opstream17.com/20240511/7355_6d48a0f0/index.m3u8"},{"name":"19","slug":"","filename":"Truyen Thuyet Nguoi Va Rong 19","link_embed":"https://vip.opstream17.com/share/547b85f3fafdf30856386753dc21c4e1","link_m3u8":"https://vip.opstream17.com/20240511/7354_22492ddc/index.m3u8"},{"name":"20","slug":"","filename":"Truyen Thuyet Nguoi Va Rong 20end","link_embed":"https://vip.opstream17.com/share/5fd2c06f558321eff612bbbe455f6fbd","link_m3u8":"https://vip.opstream17.com/20240511/7353_d71d6195/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Diệp quốc sư và tướng quân Châu Ngạo Thiên luôn bất đồng quan điểm về việc Người và Rồng có thể chung sống hòa bình với nhau. Để giữ hòa khí trong triều đình nên Diệp quốc sư đã cáo quan ở ẩn. Diệp Hy (là con của Diệp quốc sư) đã trở thành một chàng trai khôi ngô, tuấn tú là đại phu chữa bệnh cho dân làng. Trong 1 lần cứu mạng cho bé trai, Diệp Hy đã gặp Tiểu Ngư xinh đẹp, tốt bụng và hai người đã nảy sinh tình cảm sâu đậm. Sau này, Diệp Hy đã phát hiện Tiểu Ngư là Long nữ (con của Long Vương) nhưng anh vẫn quyết định tiếp tục yêu Tiểu Ngư. Họ đã cùng nhau vượt qua rất nhiều sóng gió để có thể được cưới nhau. Nhưng vào ngày thành hôn, \"ông Trời\" đã giáng tai họa để trừng phạt vì Người và Rồng không được phép lấy nhau.Việc họ tổ chức lễ thành hôn đã làm rất nhiều người chết trong đó có cả mẹ của Tiểu Ngư. Sau sự việc này thì cả gia đình của Tiểu Ngư đã mất tích…</i></p>","tmdb":{"type":"tv","id":"86286","season":1,"vote_average":8,"vote_count":1},"modified":"2024-12-27T11:37:33.000Z","cast":["Trần Hạo Dân","Viên Khiết Doanh","Tiền Gia Lạc","La Quán Lan","Lưu Gia Huy","Nguyên Hoa","Nicola Cheung Sun-Yuet","Rain Lau Yuk-Chui","Tạ Thiên Hoa","Safina Lam"],"director":["La Vĩnh Hiền"],"cast_meta":[{"name":"Trần Hạo Dân","name_vi":"Trần Hạo Dân","name_original":"Benny Chan Ho-Man","tmdb_id":1314817,"profile":"https://image.tmdb.org/t/p/w500/cGNOprzxJntHcg6db0HZOdyCZX8.jpg","tmdb_url":"https://www.themoviedb.org/person/1314817"},{"name":"Viên Khiết Doanh","name_vi":"Viên Khiết Doanh","name_original":"Fennie Yuen Kit-Ying","tmdb_id":579216,"profile":"https://image.tmdb.org/t/p/w500/lrCW4BLzej3C3boJRlNQSfD19Ul.jpg","tmdb_url":"https://www.themoviedb.org/person/579216"},{"name":"Tiền Gia Lạc","name_vi":"Tiền Gia Lạc","name_original":"Chin Ka-Lok","tmdb_id":148884,"profile":"https://image.tmdb.org/t/p/w500/1C8uMztrOOBYlhOj2VKHsfDzQv9.jpg","tmdb_url":"https://www.themoviedb.org/person/148884"},{"name":"La Quán Lan","name_vi":"La Quán Lan","name_original":"May Law Koon-Lan","tmdb_id":1334856,"profile":"https://image.tmdb.org/t/p/w500/ed9wfTluBR4ZgMj8HpvHeqHiGU0.jpg","tmdb_url":"https://www.themoviedb.org/person/1334856"},{"name":"Lưu Gia Huy","name_vi":"Lưu Gia Huy","name_original":"Gordon Liu Chia-Hui","tmdb_id":240171,"profile":"https://image.tmdb.org/t/p/w500/nGpgPSRGXJ808e1ay54nym3qUdp.jpg","tmdb_url":"https://www.themoviedb.org/person/240171"},{"name":"Nguyên Hoa","name_vi":"Nguyên Hoa","name_original":"Yuen Wah","tmdb_id":57609,"profile":"https://image.tmdb.org/t/p/w500/50iChkgIJI7ZmPUjCpYKfEsXBnf.jpg","tmdb_url":"https://www.themoviedb.org/person/57