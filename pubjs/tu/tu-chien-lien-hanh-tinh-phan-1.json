i sống sót sau trận chiến phải trốn chạy và đi tìm thuộc địa thứ mười ba, hành tinh có tên Trái Đất...</p>","tmdb_id":1972,"cast":["Edward James Olmos","Mary McDonnell","Jamie Bamber","Katee Sackhoff","James Callis","Tricia Helfer","Tahmoh Penikett","Grace Park","Michael Hogan","Aaron Douglas"],"director":["Michael Rymer","Marita Grabiak","Rod Hardy"],"keywords":[],"tmdb":{"type":"tv","id":"1972","season":1,"vote_average":8.212,"vote_count":1707},"cast_meta":[{"name":"Edward James Olmos","name_vi":null,"name_original":"Edward James Olmos","tmdb_id":587,"profile":"https://image.tmdb.org/t/p/w500/mXnilUrQBIMLHSQkPjQk99mX70x.jpg","tmdb_url":"https://www.themoviedb.org/person/587"},{"name":"Mary McDonnell","name_vi":null,"name_original":"Mary McDonnell","tmdb_id":1581,"profile":"https://image.tmdb.org/t/p/w500/qqdaaFLEPXbB8thVJJkYJ4WoAuj.jpg","tmdb_url":"https://www.themoviedb.org/person/1581"},{"name":"Jamie Bamber","name_vi":null,"name_original":"Jamie Bamber","tmdb_id":50668,"profile":"https://image.tmdb.org/t/p/w500/qQCn0z3o0udPM6OseBhvyNpCkkK.jpg","tmdb_url":"https://www.themoviedb.org/person/50668"},{"name":"Katee Sackhoff","name_vi":null,"name_original":"Katee Sackhoff","tmdb_id":51798,"profile":"https://image.tmdb.org/t/p/w500/kzcwfDDrgXnVgyTfcpG0obOn7Qk.jpg","tmdb_url":"https://www.themoviedb.org/person/51798"},{"name":"James Callis","name_vi":null,"name_original":"James Callis","tmdb_id":9145,"profile":"https://image.tmdb.org/t/p/w500/dLmmQU5hA0J6Jxi20aS8kdN6k3o.jpg","tmdb_url":"https://www.themoviedb.org/person/9145"},{"name":"Tricia Helfer","name_vi":null,"name_original":"Tricia Helfer","tmdb_id":74423,"profile":"https://image.tmdb.org/t/p/w500/cXwa8yT2Qv7EmCI8yjs5ldvMHmw.jpg","tmdb_url":"https://www.themoviedb.org/person/74423"},{"name":"Tahmoh Penikett","name_vi":null,"name_original":"Tahmoh Penikett","tmdb_id":77223,"profile":"https://image.tmdb.org/t/p/w500/716vNPQ4UaPga3n8RX777c9Excg.jpg","tmdb_url":"https://www.themoviedb.org/person/77223"},{"name":"Gr