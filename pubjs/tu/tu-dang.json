 thoát khỏi Tư Đằng, nhưng trên con đường báo thù rối như tơ vò, hắn dần dần phát hiện vận mệnh của mình đã sớm được an bài từ hơn 70 năm trước....</p>","tmdb":{"type":"tv","id":"120199","season":1,"vote_average":7.5,"vote_count":21},"modified":"2023-05-22T18:44:08.000Z","cast":["Cảnh Điềm","Trương Bân Bân","Lý Mộc Thần","Zhang Yichi","June Wu","Jin Zehao","Zhang Dinghan","Najima","Benson Wang","Wang Han","Thiệu Phong"],"director":["Lý Mộc Qua"],"cast_meta":[{"name":"Cảnh Điềm","name_vi":"Cảnh Điềm","name_original":"Jing Tian","tmdb_id":1151657,"profile":"https://image.tmdb.org/t/p/w500/nNlM15XOEJU8A1dKuGEnN7NgxEy.jpg","tmdb_url":"https://www.themoviedb.org/person/1151657"},{"name":"Trương Bân Bân","name_vi":"Trương Bân Bân","name_original":"Vin Zhang","tmdb_id":1701963,"profile":"https://image.tmdb.org/t/p/w500/8LvvrOhj4zxPuYgpPJ9HWyJzf4a.jpg","tmdb_url":"https://www.themoviedb.org/person/1701963"},{"name":"Lý Mộc Thần","name_vi":"Lý Mộc Thần","name_original":"Daisy Li","tmdb_id":1747503,"profile":"https://image.tmdb.org/t/p/w500/5rsbbbPLKtkGGX0v8MT1oivpGhS.jpg","tmdb_url":"https://www.themoviedb.org/person/1747503"},{"name":"Zhang Yichi","name_vi":null,"name_original":"Zhang Yichi","tmdb_id":1724348,"profile":"https://image.tmdb.org/t/p/w500/8y56Efd4AytO0kcpVqrrbrm2aAI.jpg","tmdb_url":"https://www.themoviedb.org/person/1724348"},{"name":"June Wu","name_vi":null,"name_original":"June Wu","tmdb_id":1842337,"profile":"https://image.tmdb.org/t/p/w500/wNLFI18YOnOKjOsiVDi7mSwVTWK.jpg","tmdb_url":"https://www.themoviedb.org/person/1842337"},{"name":"Jin Zehao","name_vi":null,"name_original":"Jin Zehao","tmdb_id":2417157,"profile":"https://image.tmdb.org/t/p/w500/na86BexdYh4u3DhZ7IWVTi8mr3m.jpg","tmdb_url":"https://www.themoviedb.org/person/2417157"},{"name":"Zhang Dinghan","name_vi":null,"name_original":"Zhang Dinghan","tmdb_id":2781376,"profile":"https://image.tmdb.org/t/p/w500/oBIIPMlByBzugTfXY0Py5zuvIlV.jpg","tmdb_url":"https://www.themoviedb.org/person/2781376"},{"na