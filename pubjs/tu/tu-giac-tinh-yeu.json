https://vip.opstream13.com/share/430a27748f3853d3745bda9d32419fef","link_m3u8":"https://vip.opstream13.com/20250915/7815_430a2774/index.m3u8"},{"name":"20","slug":"20","filename":"Tứ Giác Tình Yêu tập 20#20 # tiếng Việt # Xa Thi Mạn, Trần Hào, Huỳnh Đức Bân # 2012","link_embed":"https://vip.opstream13.com/share/a2a722df674185b45ae4752a1e7d5444","link_m3u8":"https://vip.opstream13.com/20250915/7816_a2a722df/index.m3u8"}]}],"time":"45 phút/tập","description":"Tứ giác tình yêu là bộ phim tình cảm đầy phức tạp của các diễn viên trong phim, mà cụ thể ở đây là 4 cặp bạn cùng lứa chơi chung với nhau. Đầu tiên là mối tình của diễn viên minh tinh Đồng Ái Dao đang nổi tiếng làm mưa làm gió khắp châu Á với chàng fan trung thành của mình Dư Trấn Đông sau lần gặp mặt đầu tiên đã làm cô cảm nắng anh chàng này.\n\nNhưng tình yêu của họ được biết trước là sẽ không bền chặt khi giữa họ một con đường đang trên đỉnh cao danh vọng và có mối quan hệ phức tạp trong Cbiz và một chàng trai có hong kong suy nghĩ hết sức bình thường. Hay là họ sẽ gặp bởi sự cản trở của một nhân vật thứ 3.\n\nNgoài ra, trong phim còn 3 cặp tình nhân khác nữa, mỗi cặp có một đặc điểm hoàn toàn khác nhau, đó là Chung Bỉnh Lương và Châu Ân Trừng, trong chuyện tình này thì người phụ nữ là người chiếm thế thượng phong và quyết định tất cả trong khi nam giới chỉ đóng vai phụ.","tmdb":{"type":"tv","id":"42026","season":1,"vote_average":0,"vote_count":0},"modified":"2025-09-15T19:57:07.000Z","cast":["Trần Hào","Xa Thi Mạn","Florence Kwok Siu-Wan","Huỳnh Đức Bân","Giang Hân Yến","Jin Gang","Rachel Kan","Vi Gia Hùng","Tracy Ip","Trương Quốc Cường","Lưu Đan","Hàn Mã Lợi","Queenie Chu Wai-Man","Becky Lee","Marine Lee Yee-Man"],"director":[],"cast_meta":[{"name":"Trần Hào","name_vi":"Trần Hào","name_original":"Moses Chan Ho","tmdb_id":551869,"profile":"https://image.tmdb.org/t/p/w500/gvZcLkr1GMPajHROKd7rqzYWQbj.jpg","tmdb_url":"https://www.themoviedb.org/person/551869"},{"name":"Xa Thi Mạn","name_vi":"Xa Thi Mạn","name_or