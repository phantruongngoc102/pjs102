.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tu/tu-nghe-nghiep-tam-thuong-tro-thanh-nguoi-manh-nhat-the-gioi-phan-1.json","tmdb_checked":false}