 tưởng lớn lao, dũng cảm tiến lên vì gia đình, quốc gia và công lý, dù họ chỉ sống trong một thế giới nhỏ bé. Trong thời kỳ An Bình của Đại Ung, chàng trai trẻ Nguyên Mạc người thành Trường Nhạc (Đàm Kiện Thứ đóng) mang theo con dấu Tứ Phương Quán để cấp giấy phép vào thành cho dị tộc, không ngờ sao lại gặp phải A Thuật từ nước Yên Nhạc đến tị nạn.","tmdb_id":243076,"cast":["Đàn Kiện Thứ","Chu Dực Nhiên","Đỗ Thuần","Hám Thanh Tử","Wei Zixin","Zhang Shulun","Wang Chengsi","Shao Weitong","Chu Lịch Kiệt","Wang Zifei","Vu Dương"],"director":["Qichen Zhao"],"keywords":[],"tmdb":{"type":"tv","id":"243076","season":1,"vote_average":6.7,"vote_count":3},"cast_meta":[{"name":"Đàn Kiện Thứ","name_vi":"Đàn Kiện Thứ","name_original":"Tan Jianci","tmdb_id":2122379,"profile":"https://image.tmdb.org/t/p/w500/3TxJqYIDQM3BOicpjAjSMr88bja.jpg","tmdb_url":"https://www.themoviedb.org/person/2122379"},{"name":"Chu Dực Nhiên","name_vi":"Chu Dực Nhiên","name_original":"Zhou Yiran","tmdb_id":2280423,"profile":"https://image.tmdb.org/t/p/w500/3T1oJq6ODZahHvtqDxfzzIDpdSo.jpg","tmdb_url":"https://www.themoviedb.org/person/2280423"},{"name":"Đỗ Thuần","name_vi":"Đỗ Thuần","name_original":"Du Chun","tmdb_id":1110539,"profile":"https://image.tmdb.org/t/p/w500/eQ0JFpXtW3Zs0AQwgEV2icjdJNo.jpg","tmdb_url":"https://www.themoviedb.org/person/1110539"},{"name":"Hám Thanh Tử","name_vi":"Hám Thanh Tử","name_original":"Kan Qingzi","tmdb_id":1675906,"profile":"https://image.tmdb.org/t/p/w500/q0XuEIcm9eB4tHaKFOvn0ymFo2l.jpg","tmdb_url":"https://www.themoviedb.org/person/1675906"},{"name":"Wei Zixin","name_vi":"Wei Zixin","name_original":"Wei Zixin","tmdb_id":3094484,"profile":"https://image.tmdb.org/t/p/w500/bNqFs9jJWJZ4xmZNOpxe4KN5trh.jpg","tmdb_url":"https://www.themoviedb.org/person/3094484"},{"name":"Zhang Shulun","name_vi":null,"name_original":"Zhang Shulun","tmdb_id":3148368,"profile":"https://image.tmdb.org/t/p/w500/jh1fVRyIDz4yAczrQYlJ2YoCE9X.jpg","tmdb_url":"https://www.themoviedb.org/person/314836