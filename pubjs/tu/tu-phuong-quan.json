6_fc9e81e0/index.m3u8"},{"name":"34","slug":"34","filename":"Go.East.S01E34.2024.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB","link_embed":"https://vip.opstream11.com/share/d076269530e867631737acb5c735b4dd","link_m3u8":"https://vip.opstream11.com/20240908/52550_d0762695/index.m3u8"},{"name":"35","slug":"35","filename":"Go.East.S01E35.2024.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB","link_embed":"https://vip.opstream11.com/share/e0ae59981983bd3bd98e070098e84bbe","link_m3u8":"https://vip.opstream11.com/20240908/52551_e0ae5998/index.m3u8"},{"name":"36","slug":"36","filename":"Go.East.S01E36.2024.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB","link_embed":"https://vip.opstream11.com/share/bd5bcf28c0cfbe46018375d5e04a0a3a","link_m3u8":"https://vip.opstream11.com/20240908/52552_bd5bcf28/index.m3u8"},{"name":"37","slug":"37","filename":"Go.East.S01E37.End.2024.2160p.IQ.WEB-DL.H265.DDP5.1-CHDWEB","link_embed":"https://vip.opstream11.com/share/6551eee9b14143cac7eb1baf35ed4739","link_m3u8":"https://vip.opstream11.com/20240908/52553_6551eee9/index.m3u8"}]}],"time":"45 phút/tập","description":"\"Tứ Phương Quán\" là bộ phim hài cổ trang do Triệu Khải Thần (đạo diễn \"Ở Rể\") đạo diễn, có sự tham gia của Đàm Kiện Thứ (diễn viên \"Lạp Tội Đồ Giám\"), Châu Y Nhiên (diễn viên \"Đuổi bắt thanh xuân\") và Đỗ Thuần (diễn viên \"Bát Bách\"), Hám Thanh Tử (diễn viên \"Chuyến Bay Sinh Tử\"). Bộ phim kể về câu chuyện của Nguyên Mạc, A Thuật, Vương Khôn Ngô, và Úy Trì Hoa, bốn chí sĩ với lý tưởng lớn lao, dũng cảm tiến lên vì gia đình, quốc gia và công lý, dù họ chỉ sống trong một thế giới nhỏ bé. Trong thời kỳ An Bình của Đại Ung, chàng trai trẻ Nguyên Mạc người thành Trường Nhạc (Đàm Kiện Thứ đóng) mang theo con dấu Tứ Phương Quán để cấp giấy phép vào thành cho dị tộc, không ngờ sao lại gặp phải A Thuật từ nước Yên Nhạc đến tị nạn.","tmdb":{"type":"tv","id":"243076","season":1,"vote_average":6.7,"vote_count":3},"modified":"2024-09-08T23:39:49.000Z","cast":["Đàn Kiện Thứ","Chu Dực Nhiên","Đỗ Thuần","Hám Thanh Tử","Wei Zixin","Zhang Shulun","Wang Chengsi","Shao Weitong","Chu Lịch Kiệt","Wang Zifei","Vu Dương"],"director":["Qichen Zhao"],"cast_meta":[{"name":"Đàn Kiện Thứ","name_vi":"Đàn Kiện Thứ","name_original":"Tan Jianci","tmdb_id":2122379,"profile":"https://image.tmdb.org/t/p/w500/3TxJqYIDQM3BOicpjAjSMr88bja.jpg","tmdb_url":"https://www.themoviedb.org/person/2122379"},{"name":"Chu Dực Nhiên","name_vi":"Chu Dực Nhiên","name_original":"Zhou Yiran","tmdb_id":2280423,"profile":"https://image.tmdb.org/t/p/w500/3T1oJq6ODZahHvtqDxfzzIDpdSo.jpg","tmdb_url":"https://www.themoviedb.org/person/2280423"},{"name":"Đỗ Thuần","name_vi":"Đỗ Thuần","name_original":"Du Chun","tmdb_id":1110539,"profile":"https://image.tmdb.org/t/p/w500/eQ0JFpXtW3Zs0AQwgEV2icjdJNo.jpg","tmdb_url":"https://www.themoviedb.org/person/1110539"},{"name":"Hám Thanh Tử","name_vi":"Hám Thanh Tử","name_original":"Kan Qingzi","tmdb_id":1675906,"profile":"https://image.tmdb.org/t/p/w500/q0XuEIcm9eB4tHaKFOvn0ymFo2l.jpg","tmdb_url":"https://www.themoviedb.org/person/1675906"},{"name":"Wei Zixin","name_vi":"Wei Zixin","name_original":"Wei Zixin","tmdb_id":3094484,"profile":"https://image.tmdb.org/t/p/w500/bNqFs9jJWJZ4xmZNOpxe4KN5trh.jpg","tmdb_url":"https://www.themoviedb.org/person/3094484"},{"name":"Zhang Shulun","name_vi":null,"name_original":"Zhang Shulun","tmdb_id":3148368,"profile":"https://image.tmdb.org/t/p/w500/jh1fVRyIDz4yAczrQYlJ2YoCE9X.jpg","tmdb_url":"https://www.themoviedb.org/person/3148368"},{"name":"Wang Chengsi","name_vi":null,"name_original":"Wang Chengsi","tmdb_id":2029011,"profile":"https://image.tmdb.org/t/p/w500/nIZhWUvPfE7pTnKdlud8iFJdhqQ.jpg","tmdb_url":"https://www.themoviedb.org/person/2029011"},{"name":"Shao Weitong","name_vi":null,"name_original":"Shao Weitong","tmdb_id":2264044,"profile":"https://image.tmdb.org/t/p/w500/jZHT9IXQEg9Drn9aeP0Wfvzi4x5.jpg","tmdb_url":"https://www.themoviedb.org/person/2264044"},{"name":"Chu Lịch Kiệt","name_vi":"Chu Lịch Kiệt","name_original":"Zhou Lijie","tmdb_id":