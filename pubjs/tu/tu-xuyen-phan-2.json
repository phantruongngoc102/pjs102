 giữ biên giới của Tử Xuyên, trở về Đế Đô với chiến tích lớn, mang lại sự ổn định cho đất nước. Tuy nhiên, nguy cơ mới nổi lên khi quan lại lớn trong triều đình, Dương Minh Hoa, nổi loạn và gây ra cuộc nổi dậy.","tmdb_id":247590,"cast":["Dương Húc Văn","Lưu Vũ Ninh","Zhang Ming'en","Lý Mặc Chi","Joyin Cai","Ma Shaohua","Huang Haoyue","Li Guo","Chen Siche","Wu Helun","Chen Jiawen"],"director":["Wei Lizhou","Zhang Meng"],"keywords":[],"tmdb":{"type":"tv","id":"247590","season":2,"vote_average":5,"vote_count":2},"cast_meta":[{"name":"Dương Húc Văn","name_vi":"Dương Húc Văn","name_original":"Yang Xuwen","tmdb_id":1557178,"profile":"https://image.tmdb.org/t/p/w500/doI0BtQ39mRn9WzmmXylnukCuks.jpg","tmdb_url":"https://www.themoviedb.org/person/1557178"},{"name":"Lưu Vũ Ninh","name_vi":"Lưu Vũ Ninh","name_original":"Liu Yuning","tmdb_id":2365187,"profile":"https://image.tmdb.org/t/p/w500/6JvMALlglmZB5gutlheu4J5KjAI.jpg","tmdb_url":"https://www.themoviedb.org/person/2365187"},{"name":"Zhang Ming'en","name_vi":null,"name_original":"Zhang Ming'en","tmdb_id":1875562,"profile":"https://image.tmdb.org/t/p/w500/jh9UTeOzs38OO7KqVjp8KvaVfSG.jpg","tmdb_url":"https://www.themoviedb.org/person/1875562"},{"name":"Lý Mặc Chi","name_vi":"Lý Mặc Chi","name_original":"Li Mozhi","tmdb_id":2307498,"profile":"https://image.tmdb.org/t/p/w500/854rfaDtFW3Dcjb02ERbQibNrM4.jpg","tmdb_url":"https://www.themoviedb.org/person/2307498"},{"name":"Joyin Cai","name_vi":null,"name_original":"Joyin Cai","tmdb_id":2443801,"profile":"https://image.tmdb.org/t/p/w500/cZWXUZJWEIgJ56Cry4l5CmpcDUU.jpg","tmdb_url":"https://www.themoviedb.org/person/2443801"},{"name":"Ma Shaohua","name_vi":null,"name_original":"Ma Shaohua","tmdb_id":134793,"profile":"https://image.tmdb.org/t/p/w500/AhpgfN01hk12WJJkcOPA7crlouy.jpg","tmdb_url":"https://www.themoviedb.org/person/134793"},{"name":"Huang Haoyue","name_vi":null,"name_original":"Huang Haoyue","tmdb_id":2732001,"profile":"https://image.tmdb.org/t/p/w500/ygUj6XOtpUuqMTZqXKZa