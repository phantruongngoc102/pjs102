 án này. V</p><p>&nbsp;</p>","tmdb_id":1198409,"cast":["Gong Xiaojun","Zeng Chen","Wu Chunyi","Yuen Cheung-Yan","Chu Xiaolong","Yang Shu"],"director":["Guan Dongjie"],"keywords":[],"tmdb":{"type":"movie","id":"1198409","season":null,"vote_average":3,"vote_count":1},"cast_meta":[{"name":"Gong Xiaojun","name_vi":null,"name_original":"Gong Xiaojun","tmdb_id":2765302,"profile":"https://image.tmdb.org/t/p/w500/AfUg4dTZmrwarzHdpl6hBTcozQ4.jpg","tmdb_url":"https://www.themoviedb.org/person/2765302"},{"name":"Zeng Chen","name_vi":null,"name_original":"Zeng Chen","tmdb_id":2461945,"profile":"https://image.tmdb.org/t/p/w500/xjt9kDlGM2xCwg45n5xGFdg1KIR.jpg","tmdb_url":"https://www.themoviedb.org/person/2461945"},{"name":"Wu Chunyi","name_vi":null,"name_original":"Wu Chunyi","tmdb_id":2982510,"profile":"https://image.tmdb.org/t/p/w500/xYfsZoZcwDHGvSmN6xN7zQ1tOik.jpg","tmdb_url":"https://www.themoviedb.org/person/2982510"},{"name":"Yuen Cheung-Yan","name_vi":null,"name_original":"Yuen Cheung-Yan","tmdb_id":65975,"profile":"https://image.tmdb.org/t/p/w500/sI8Dr2Icy31xRiODXPThiK6XkYv.jpg","tmdb_url":"https://www.themoviedb.org/person/65975"},{"name":"Chu Xiaolong","name_vi":null,"name_original":"Chu Xiaolong","tmdb_id":2138984,"profile":"https://image.tmdb.org/t/p/w500/uJwtdSIWkHXg2kVIlRRBB98Z7Ua.jpg","tmdb_url":"https://www.themoviedb.org/person/2138984"},{"name":"Yang Shu","name_vi":null,"name_original":"Yang Shu","tmdb_id":3303809,"profile":"https://image.tmdb.org/t/p/w500/sD1U86w9M00SsO6xSePMQv1lens.jpg","tmdb_url":"https://www.themoviedb.org/person/3303809"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/tu/tu-yeu-quan-ki-an.json"}