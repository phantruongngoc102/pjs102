u và tinh thần đoàn kết của toàn thể giáo viên học sinh. Thế nhưng, Cao Văn Minh thức tỉnh, khủng hoảng sự nghiệp của Trần Tất Đạt cũng theo đó tăng lên.","tmdb_id":231071,"cast":["Châu Khải","Lý Minh Đức","Nghiêm Ngật Khoan","Hạc Thu","Trương Thần Tiêu","Chen Jieyi","Liao Huijia","Xue Jianing","Deng Zhihao"],"director":["Song Yang"],"keywords":[],"tmdb":{"type":"tv","id":"231071","season":17,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Châu Khải","name_vi":"Châu Khải","name_original":"Zhou Qi","tmdb_id":2407983,"profile":"https://image.tmdb.org/t/p/w500/p8mUtx6C5o6jVYQ86eSOMvN3ZTz.jpg","tmdb_url":"https://www.themoviedb.org/person/2407983"},{"name":"Lý Minh Đức","name_vi":"Lý Minh Đức","name_original":"Li Mingde","tmdb_id":2727869,"profile":"https://image.tmdb.org/t/p/w500/chyIdYAmXBBHjC2f9GyNVhtNVkV.jpg","tmdb_url":"https://www.themoviedb.org/person/2727869"},{"name":"Nghiêm Ngật Khoan","name_vi":"Nghiêm Ngật Khoan","name_original":"Kevin Yan","tmdb_id":1407599,"profile":"https://image.tmdb.org/t/p/w500/oCUiTeAnwmjc0tof4SFziOExIK7.jpg","tmdb_url":"https://www.themoviedb.org/person/1407599"},{"name":"Hạc Thu","name_vi":"Hạc Thu","name_original":"He Nan","tmdb_id":2325917,"profile":"https://image.tmdb.org/t/p/w500/5mkgprDlDC3TwnPwa8neUBx75C2.jpg","tmdb_url":"https://www.themoviedb.org/person/2325917"},{"name":"Trương Thần Tiêu","name_vi":"Trương Thần Tiêu","name_original":"Zhang Chenxiao","tmdb_id":3655514,"profile":"https://image.tmdb.org/t/p/w500/4Rp4KNjCLW0rBmWVakZtFVAfOFk.jpg","tmdb_url":"https://www.themoviedb.org/person/3655514"},{"name":"Chen Jieyi","name_vi":null,"name_original":"Chen Jieyi","tmdb_id":3508415,"profile":"https://image.tmdb.org/t/p/w500/2vbc3dR1WSuFeJmI9E9oU5PqemL.jpg","tmdb_url":"https://www.themoviedb.org/person/3508415"},{"name":"Liao Huijia","name_vi":null,"name_original":"Liao Huijia","tmdb_id":2456853,"profile":"https://image.tmdb.org/t/p/w500/6HHVzwBdUu6Iut8IKDYgIh9ts1c.jpg","tmdb_url":"https://www.themoviedb.org/person/245685