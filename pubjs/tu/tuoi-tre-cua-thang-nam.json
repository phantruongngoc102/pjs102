1","link_m3u8":"https://vip.opstream12.com/20220303/2603_cae61ce9/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream12.com/share/6403675579f6114559c90de0014cd3d6","link_m3u8":"https://vip.opstream12.com/20220303/2602_575fc403/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream12.com/share/880610aa9f9de9ea7c545169c716f477","link_m3u8":"https://vip.opstream12.com/20220303/2604_b5bf4a0b/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream12.com/share/a431d70133ef6cf688bc4f6093922b48","link_m3u8":"https://vip.opstream12.com/20220303/2606_e6e1efd3/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream12.com/share/d3fad7d3634dbfb61018813546edbccb","link_m3u8":"https://vip.opstream12.com/20220303/2605_17e22813/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream12.com/share/d756d3d2b9dac72449a6a6926534558a","link_m3u8":"https://vip.opstream12.com/20220303/2608_d53b28b1/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream12.com/share/53c6de78244e9f528eb3e1cda69699bb","link_m3u8":"https://vip.opstream12.com/20220303/2607_17ea6b1c/index.m3u8"}]}],"description":"<p>Tuổi Trẻ Của Tháng Năm - Youth of May kể về cuộc sống của hai nhân vật trẻ tuổi đã bị cuốn vào cuộc nổi dậy Gwangju xảy ra vào tháng 5, năm 1980. Hwang Hee Tae là một kẻ gây rối, người luôn ghét những gì được sắp đặt trước. Cuộc đời của anh đã được mô tả bằng cum từ :\"Cuộc chiến chống lại định kiến\". Nhờ phá vỡ định kiến đối với những con được nuôi dưỡng bởi những người mẹ đơn thân, anh đã được tuyển tại đại học Seul. Tuy nhiên, do những sự kiện bất ngờ xảy ra, anh đã phải trải qua những năm tháng khắc nhiệt nhất trong cuộc đời. Kim Myung Hee là một nữ y tá, luôn làm việc chăm chỉ và hết lòng cho các bệnh nhân của mình.</p>","tmdb_id":119466,"cast":[],"director":[],"keywords":[],"tmdb":{"id":119466},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tu/tuoi-tre-cua-thang-nam.json"}