am15.com/20220612/20409_3a01b777/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream15.com/share/299bb6d67f1bf42897291cc8f4aa3a95","link_m3u8":"https://vip.opstream15.com/20220612/20410_36d571c1/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream15.com/share/c55da58933dadf65138cee2fe9a4169e","link_m3u8":"https://vip.opstream15.com/20220612/20411_ffbd5cec/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream15.com/share/fd7b27cb8f482d541add663d421a0b5d","link_m3u8":"https://vip.opstream15.com/20220612/20412_bdc215e9/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream15.com/share/92b47f497a9c49c386b46a840307c3e1","link_m3u8":"https://vip.opstream15.com/20220612/20413_ef9d87e9/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream15.com/share/b4fddb161c723fe41814b43123ff0f9c","link_m3u8":"https://vip.opstream15.com/20220612/20414_9921f490/index.m3u8"}]}],"description":"<p>Một bộ phim kể về tuổi thanh xuân của những cô gái trẻ đầy lạc quan, hài hước, trẻ trung, câu chuyện xoay quanh năm cô gái cùng trọ sống trong một ngôi nhà, Mỗi người có 1 cá tính riêng của mình, về phong cách hẹn hò, gu đàn ông, và học các ngành khác nhau. Bộ phim mô tả cách các cô gái đối phó với một loạt các vấn đề mà phụ nữ hiện đại phải đối mặt, cho dù đó là hẹn hò hay quan hệ tình dục hay các mối quan hệ giữa các cá nhân. Yoon Jin Myung (Han Ye Ri) rất bận rộn lo chuyện tài chính và học tập cho chính mình. Cô bị thiếu ngủ.Jung Ye Eun (Han Seung Yeon) lại là người hết lòng vì bạn trai của cô, cô rất rõ ràng về những gì cô ấy thích hay không thích. Song Ji Won (Park Eun Bin) có một tính cách trẻ trung và rất thích uống rượu.Kang Yi Na (Ryu Hwa Young) lại khá nổi tiếng bởi sự xuất hiện xinh đẹp của mình. Yoo Eun Jae (Park Hye Soo) có tính cách nhút nhát, nhưng cô ấy lại có duyên ngầm độc đáo thu hút với nam giới.</p>","tmdb_id":67014,"cast":[],"director":[],"keywords":[],"tmdb":{"id":67014},"cast_meta":[