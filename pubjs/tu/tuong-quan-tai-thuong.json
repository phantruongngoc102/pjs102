https://vip.opstream11.com/20220401/8230_de6ca019/index.m3u8"},{"name":"56","slug":"56","filename":"Tướng Quân Tại Thượng - Oh My General - Tập 56","link_embed":"https://vip.opstream11.com/share/ef8b5fcc338e003145ac9c134754db71","link_m3u8":"https://vip.opstream11.com/20220401/8234_77f204a2/index.m3u8"},{"name":"57","slug":"57","filename":"Tướng Quân Tại Thượng - Oh My General - Tập 57","link_embed":"https://vip.opstream11.com/share/b6af2c9703f203a2794be03d443af2e3","link_m3u8":"https://vip.opstream11.com/20220401/8233_c9cfe64e/index.m3u8"},{"name":"58","slug":"58","filename":"Tướng Quân Tại Thượng - Oh My General - Tập 58","link_embed":"https://vip.opstream11.com/share/e61eaa38aed621dd776d0e67cfeee366","link_m3u8":"https://vip.opstream11.com/20220401/8232_e5e69770/index.m3u8"},{"name":"59","slug":"59","filename":"Tướng Quân Tại Thượng - Oh My General - Tập 59","link_embed":"https://vip.opstream11.com/share/2004e0f2b74655ee92d3a6af6bdb6626","link_m3u8":"https://vip.opstream11.com/20220401/8231_1b5da5da/index.m3u8"},{"name":"60","slug":"60","filename":"Tướng Quân Tại Thượng - Oh My General - Tập 60","link_embed":"https://vip.opstream11.com/share/9f9a2e9ab3dc74b58ef7c5b974807751","link_m3u8":"https://vip.opstream11.com/20220401/8235_7f8e1b85/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Tướng Quân Tại Thượng' là dự án phim truyền hình Trung Quốc cổ trang - giả sử với sự góp mặt của nhiều gương mặt triển vọng như nữ diễn viên Mã Tư Thuần thủ vai Diệp Chiêu – một nữ tướng quân tài ba, oai dũng - và Thịnh Nhất Luân đảm nhận vai nam chính Triệu Ngọc Cẩn. Phim xoay quanh chuyện tình yêu và hôn nhân giữa nữ tướng quân Diệp Chiêu lạnh lùng, võ nghệ siêu phàm và vương gia Triệu Ngọc Cẩn tuy có dung mạo hơn người nhưng lại bất tài, vô dụng, không xứng với Diệp Chiêu... Mã Tư Thuần là một trong những gương mặt nữ diễn viên triển vọng của làng giải trí Hoa Ngữ, người hâm mộ hy vọng \"Tướng Quân Tại Thượng\" tiếp tục sẽ là một thành công của nữ diễn viên trẻ tuổi. Nam diễn viên Thịnh Nhất Luân mỹ nam cổ trang cũng được kỳ vọng sẽ tỏa sáng trong phim truyền hình \"Tướng Quân Tại Thượng\".</p>","tmdb":{"type":"tv","id":"75953","season":1,"vote_average":7.6,"vote_count":13},"modified":"2023-06-14T19:56:25.000Z","cast":["Mã Tư Thuần","Thịnh Nhất Luân","Vương Sở Nhiên","Sookie Pan","Wang Xuan","Zhang Junming","Liu Weihua","Zhang Yao","Zhang Wen","Xiao Han","Chu Vịnh Đằng","Xiang Hao","Xu Yukun","Vu Ba","Zhao Yutong"],"director":["Lữ Hạo Cát Cát"],"cast_meta":[{"name":"Mã Tư Thuần","name_vi":"Mã Tư Thuần","name_original":"Ma Sichun","tmdb_id":1476994,"profile":"https://image.tmdb.org/t/p/w500/lBaMftRfwBOoKeEg76ooqfffZTw.jpg","tmdb_url":"https://www.themoviedb.org/person/1476994"},{"name":"Thịnh Nhất Luân","name_vi":"Thịnh Nhất Luân","name_original":"Peter Sheng","tmdb_id":1599856,"profile":"https://image.tmdb.org/t/p/w500/ugxYOHpMFto0po1XL0cuE8rh4re.jpg","tmdb_url":"https://www.themoviedb.org/person/1599856"},{"name":"Vương Sở Nhiên","name_vi":"Vương Sở Nhiên","name_original":"Wang Churan","tmdb_id":2271369,"profile":"https://image.tmdb.org/t/p/w500/jHSQ3ZOfFhszPuz1kG0zkpHwe8N.jpg","tmdb_url":"https://www.themoviedb.org/person/2271369"},{"name":"Sookie Pan","name_vi":null,"name_original":"Sookie Pan","tmdb_id":1810613,"profile":"https://image.tmdb.org/t/p/w500/iRmYLgFnRswDH5xRiRfl5BBYgay.jpg","tmdb_url":"https://www.themoviedb.org/person/1810613"},{"name":"Wang Xuan","name_vi":null,"name_original":"Wang Xuan","tmdb_id":2790173,"profile":"https://image.tmdb.org/t/p/w500/oDrYeLtTSVO3lITGKY7rxg4pIKN.jpg","tmdb_url":"https://www.themoviedb.org/person/2790173"},{"name":"Zhang Junming","name_vi":null,"name_original":"Zhang Junming","tmdb_id":3539591,"profile":"https://image.tmdb.org/t/p/w500/3ehi6IG08KAhx09UAN7FVyghkdx.jpg","tmdb_url":"https://www.themoviedb.org/person/3539591"},{"name":"Liu Weihua","name_vi":null,"name_original":"Liu Weihua","tmdb_id":1174456,"profile":"https://image.tmdb.org/t/p/w500/ikuzKpCTg6KMwWQXwMYFENW8i2J.jpg","tmdb_ur