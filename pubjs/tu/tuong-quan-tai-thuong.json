:"https://vip.opstream11.com/20220401/8226_6480897d/index.m3u8"},{"name":"52","slug":"52","link_embed":"https://vip.opstream11.com/share/c35bc9eaa4a930e006ab98bf3ef90408","link_m3u8":"https://vip.opstream11.com/20220401/8227_060e5cc9/index.m3u8"},{"name":"53","slug":"53","link_embed":"https://vip.opstream11.com/share/03573b32b2746e6e8ca98b9123f2249b","link_m3u8":"https://vip.opstream11.com/20220401/8228_e449bbb7/index.m3u8"},{"name":"54","slug":"54","link_embed":"https://vip.opstream11.com/share/0396df57e78b6d04b6854dd682e27b3c","link_m3u8":"https://vip.opstream11.com/20220401/8229_757270ee/index.m3u8"},{"name":"55","slug":"55","link_embed":"https://vip.opstream11.com/share/bd4a6d0563e0604510989eb8f9ff71f5","link_m3u8":"https://vip.opstream11.com/20220401/8230_de6ca019/index.m3u8"},{"name":"56","slug":"56","link_embed":"https://vip.opstream11.com/share/ef8b5fcc338e003145ac9c134754db71","link_m3u8":"https://vip.opstream11.com/20220401/8234_77f204a2/index.m3u8"},{"name":"57","slug":"57","link_embed":"https://vip.opstream11.com/share/b6af2c9703f203a2794be03d443af2e3","link_m3u8":"https://vip.opstream11.com/20220401/8233_c9cfe64e/index.m3u8"},{"name":"58","slug":"58","link_embed":"https://vip.opstream11.com/share/e61eaa38aed621dd776d0e67cfeee366","link_m3u8":"https://vip.opstream11.com/20220401/8232_e5e69770/index.m3u8"},{"name":"59","slug":"59","link_embed":"https://vip.opstream11.com/share/2004e0f2b74655ee92d3a6af6bdb6626","link_m3u8":"https://vip.opstream11.com/20220401/8231_1b5da5da/index.m3u8"},{"name":"60","slug":"60","link_embed":"https://vip.opstream11.com/share/9f9a2e9ab3dc74b58ef7c5b974807751","link_m3u8":"https://vip.opstream11.com/20220401/8235_7f8e1b85/index.m3u8"}]}],"description":"<p>Tướng Quân Tại Thượng' là dự án phim truyền hình Trung Quốc cổ trang - giả sử với sự góp mặt của nhiều gương mặt triển vọng như nữ diễn viên Mã Tư Thuần thủ vai Diệp Chiêu – một nữ tướng quân tài ba, oai dũng - và Thịnh Nhất Luân đảm nhận vai nam chính Triệu Ngọc Cẩn. Phim xoay quanh chuyện tình yêu và hôn nhân giữa nữ tướng quân Diệp Chiêu lạnh lùng, võ nghệ siêu phàm và vương gia Triệu Ngọc Cẩn tuy có dung mạo hơn người nhưng lại bất tài, vô dụng, không xứng với Diệp Chiêu... Mã Tư Thuần là một trong những gương mặt nữ diễn viên triển vọng của làng giải trí Hoa Ngữ, người hâm mộ hy vọng \"Tướng Quân Tại Thượng\" tiếp tục sẽ là một thành công của nữ diễn viên trẻ tuổi. Nam diễn viên Thịnh Nhất Luân mỹ nam cổ trang cũng được kỳ vọng sẽ tỏa sáng trong phim truyền hình \"Tướng Quân Tại Thượng\".</p>","tmdb_id":75953,"cast":[],"director":[],"keywords":[],"tmdb":{"id":75953},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tu/tuong-quan-tai-thuong.json"}