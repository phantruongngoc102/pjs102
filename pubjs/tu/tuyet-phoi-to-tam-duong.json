ed":"https://vip.opstream16.com/share/72abaa8894cb6f7d827ac8e157b722f0","link_m3u8":"https://vip.opstream16.com/20230307/32748_46e58417/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/98af8de5c746356a4b872fa0857e540c","link_m3u8":"https://vip.opstream16.com/20230309/32795_cee1bdae/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/b8d2e8e69225480f7b5565085552ed21","link_m3u8":"https://vip.opstream16.com/20230309/32803_4efb14e0/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream16.com/share/a4bbee2cb160b062774d395dac7280a2","link_m3u8":"https://vip.opstream16.com/20230309/32829_f67eb6bd/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream16.com/share/d4a7914bff40acc6f2d3d5850cacae28","link_m3u8":"https://vip.opstream16.com/20230309/32830_c199a270/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream16.com/share/326a8605975106f1672c912bd16b4e7b","link_m3u8":"https://vip.opstream16.com/20230310/32881_169de307/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream16.com/share/90918c5b8c17f80e32d5b155a7bf6197","link_m3u8":"https://vip.opstream16.com/20230310/32882_0ddfd664/index.m3u8"}]}],"description":"<p>Tuyệt Phối Tô Tâm Đường sắp lên sóng tại iQIYI. Phim được chuyển thể từ bộ truyện tranh \\\"Tôi Bị Tổng Tài Anti Rồi\\\" và kể về câu chuyện của ngôi sao nhạc pop đình đám Đường Tô bị hiểu nhầm và bị đưa vào tình trạng tạm ngưng hoạt động nghệ thuật, sau đó tăng cân đến 50 kg và trở thành người giúp việc trực tiếp của Hoàng Phủ Quyết - chủ tịch của một tập đoàn giải trí. Thật không ngờ, Hoàng Phủ Quyết, người bị mù mặt lại chính là fan hâm mộ số một của Tang Tố.\\n\\nVì vậy, hai người đã bắt đầu một câu chuyện tình yêu vô cùng hài hước và nghịch ngợm khi Hoàng Phủ Quyết muốn \\\"anti\\\" cô nàng ngôi sao tăng cân và \\\"trục xuất\\\" cô khỏi công ty. Những tình huống dở khóc dở cười đã xảy ra khi Đường Tô cố gắng lấy lại tên tuổi của mình trong khi đối đầu với Hoàng Phủ Quyết.</p>","tmdb_id":221379,"cast":["Wang Yijin","Đặng Khải","Lin Yanrou","Zhao Yibo","Trần Hâm Hải","Zeng Youzhen","Li Haozhen","Adia Chan"],"director":["Trương Thu Hằng"],"keywords":[],"tmdb":{"type":"tv","id":"221379","season":1,"vote_average":6,"vote_count":1},"cast_meta":[{"name":"Wang Yijin","name_vi":null,"name_original":"Wang Yijin","tmdb_id":2883996,"profile":"https://image.tmdb.org/t/p/w500/6fg5rPPFTBStBI2qCBGbi0ea4RD.jpg","tmdb_url":"https://www.themoviedb.org/person/2883996"},{"name":"Đặng Khải","name_vi":"Đặng Khải","name_original":"Deng Kai","tmdb_id":3152643,"profile":"https://image.tmdb.org/t/p/w500/cefuRdyIZaVf0jaO5a0agqZWvMC.jpg","tmdb_url":"https://www.themoviedb.org/person/3152643"},{"name":"Lin Yanrou","name_vi":null,"name_original":"Lin Yanrou","tmdb_id":2295864,"profile":"https://image.tmdb.org/t/p/w500/wDy24dJ18N89kYfiDFLOf3OKccW.jpg","tmdb_url":"https://www.themoviedb.org/person/2295864"},{"name":"Zhao Yibo","name_vi":null,"name_original":"Zhao Yibo","tmdb_id":3923727,"profile":"https://image.tmdb.org/t/p/w500/rjDl24mEqTXxFUOdM8slJQpWfkc.jpg","tmdb_url":"https://www.themoviedb.org/person/3923727"},{"name":"Trần Hâm Hải","name_vi":"Trần Hâm Hải","name_original":"Chen Xinhai","tmdb_id":3989428,"profile":"https://image.tmdb.org/t/p/w500/1Io0Q04kmGzgTHjYrDFHrsRTpAv.jpg","tmdb_url":"https://www.themoviedb.org/person/3989428"},{"name":"Zeng Youzhen","name_vi":null,"name_original":"Zeng Youzhen","tmdb_id":3303296,"profile":"https://image.tmdb.org/t/p/w500/m0Cw1LDKXmAMLgsvi5bUxxlDZgh.jpg","tmdb_url":"https://www.themoviedb.org/person/3303296"},{"name":"Li Haozhen","name_vi":null,"name_original":"Li Haozhen","tmdb_id":2405945,"profile":"https://image.tmdb.org/t/p/w500/8ugVs8WdMQ8K6MQOi5fmUZgNBqy.jpg","tmdb_url":"https://www.themoviedb.org/person/2405945"},{"name":"Adia Chan","name_vi":"Adia Chan","name_original":"Nadia Chan Chung-Ling","tmdb_id":2265139,"profile":"https://image.tmdb.org/t/p/w500/enhES