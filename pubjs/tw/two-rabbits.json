{"id":"64184417be1ee82036a185b9","title":"Two Rabbits","origin_name":"Two Rabbits","slug":"two-rabbits","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/tw/two-rabbits.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/tw/two-rabbits.webp","year":2012,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620a2249e0fc277084dfd2e5","name":"Hình Sự","slug":"hinh-su"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"62166eef70b58bba6858b624","name":"Bồ Đào Nha","slug":"bo-dao-nha"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Two Rabbits - Tiền Đen - 2012","link_embed":"https://vip.opstream14.com/share/e70316503be47caffc6d6e6484e04f5e","link_m3u8":"https://vip.opstream14.com/20230320/33857_b4ab9cbd/index.m3u8"}]}],"time":"108 Phút","description":"Edgar là một thanh niên thuộc tầng lớp trung lưu, gần 30 tuổi. Anh ấy sống trong một cuộc sống đầy khủng hoảng và ở một vị trí phổ biến đối với đại đa số người Brazil. Một mặt, quyền lực, được đại diện bởi một nhà nước tham nhũng, lạm dụng và vắng mặt trong các khoản thuế trước nghĩa vụ của họ. Mặt khác, bạo lực có tổ chức ngày càng gia tăng đã trở thành một điều thường xuyên trong cuộc sống của người dân ở các thành phố lớn. Edgar phản ứng với tất cả những điều này với tư cách là một người cảnh giác hiện đại. Với sự trợ giúp của các thành phần như công nghệ, thông tin phản tác dụng và thao túng, Edgar vạch ra một kế hoạch tuyệt vời, sử dụng lòng tham của đối thủ làm lý do cho sự hủy diệt của nó. Khi cốt truyện mở ra, chúng ta biết nhiều hơn về quá khứ đen tối của mỗi nhân vật khi Edgar ghép các mảnh lại với nhau trong một câu đố hấp dẫn tạo nên cốt truyện của bộ phim.","tmdb":{"type":"movie","id":"102784","season":null,"vote_average":6.826,"vote_count":149},"modified":"2023-03-20T18:31:39.000Z","cast":["Fernando Alves Pinto","Alessandra Negrini","Caco Ciocler","Marat Descartes","Neco Vila Lobos","Thaíde","Robson Nunes","Thogun Teixeira","Roberto Marchese","Aldine Müller","Charles Paraventi","Norival Rizzo","Yoram Blaschkauer","Samantha Dalsoglio","Eliseu Paranhos"],"director":["Afonso Poyart"],"cast_meta":[{"name":"Fernando Alves Pinto","name_vi":null,"name_original":"Fernando Alves Pinto","tmdb_id":142322,"profile":"https://image.tmdb.org/t/p/w500/69kBXDyiATKUoYMXpMpyz68BGjk.jpg","tmdb_url":"https://www.themoviedb.org/person/142322"},{"name":"Alessandra Negrini","name_vi":null,"name_original":"Alessandra Negrini","tmdb_id":145609,"profile":"https://image.tmdb.org/t/p/w500/zFanfnX3uw7EIJmkzxgHUhHNiiS.jpg","tmdb_url":"https://www.themoviedb.org/person/145609"},{"name":"Caco Ciocler","name_vi":null,"name_original":"Caco Ciocler","tmdb_id":142319,"profile":"https://image.tmdb.org/t/p/w500/h27WDnvLtdVdRQxgIrQR38e7BdN.jpg","tmdb_url":"https://www.themoviedb.org/person/142319"},{"name":"Marat Descartes","name_vi":null,"name_original":"Marat Descartes","tmdb_id":933011,"profile":"https://image.tmdb.org/t/p/w500/vsjsehuV8ragp3MxdGz0KJNfArC.jpg","tmdb_url":"https://www.themoviedb.org/person/933011"},{"name":"Neco Vila Lobos","name_vi":null,"name_original":"Neco Vila Lobos","tmdb_id":1032020,"profile":"https://image.tmdb.org/t/p/w500/ebdXx3VT4KP8Pr6TILWO2wxJ7fk.jpg","tmdb_url":"https://www.themoviedb.org/person/1032020"},{"name":"Thaíde","name_vi":null,"name_original":"Thaíde","tmdb_id":1032019,"profile":"https://image.tmdb.org/t/p/w500/5SRkoTHvQsZUIFM9VeFEdRNanO2.jpg","tmdb_url":"https://www.themoviedb.org/person/1032019"},{"name":"Robson Nunes","name_vi":null,"name_original":"Robson Nunes","tmdb_id":54999,"profile":"https://image.tmdb.org/t/p/w500/ux4IXL4J4WDIGN5xURb4nhIS2Mm.jpg","tmdb_url":"https://www.themovied