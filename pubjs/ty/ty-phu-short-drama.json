 phá vỡ từng âm mưu, từng bước tiến về phía trước trong cuộc phiêu lưu ly kỳ và kỳ diệu này.","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ty/ty-phu-short-drama.json","tmdb_checked":false}