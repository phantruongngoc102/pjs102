6.com/share/fc77eeae6b54251137390500c50c9172","link_m3u8":"https://vip.opstream16.com/20250821/46745_fc77eeae/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream16.com/share/f3ff512452bab41fce871de6cfbb2911","link_m3u8":"https://vip.opstream16.com/20250821/46746_f3ff5124/index.m3u8"}]}],"description":"<p>Lấy bối cảnh Hồng Kông những năm 1960, \"Chị Em Ngọc Trai\" xoay quanh cuộc chiến giành quyền thừa kế công ty của một thương gia trang sức. Vị tỷ phú hấp hối giao cho con gái cả Chu Pik-Wan tiếp quản công ty với sự giúp đỡ của con gái thứ hai Chu Pik-Ha, người vừa trở về nhà sau cái chết của chồng, và cô con gái út Chu Pik-Lam vẫn đang đi học. Mâu thuẫn giữa hai chị em nảy sinh khi Pik-Wan nghi ngờ chồng mình, Ho Cheung-Hing, vẫn còn ấp ủ những ham muốn bất chính với Ha. Khi một người phụ nữ bất ngờ xuất hiện và tự xưng là tình nhân của cha họ, liệu hai chị em nhà Chu có thể gạt bỏ bất đồng và đoàn kết chống lại kẻ thù chung?</p>","tmdb_id":32463,"cast":["Thương Thiên Nga","Tuyên Huyên","Đằng Lệ Danh","Lâm Bảo Di","Đào Đại Vũ","Macy Chan","Lưu Giang","Trần Sơn Thông"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"32463","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Thương Thiên Nga","name_vi":"Thương Thiên Nga","name_original":"Kiki Sheung","tmdb_id":1588963,"profile":"https://image.tmdb.org/t/p/w500/pr43xrvugDA6fjlsjfeyqKUEUjg.jpg","tmdb_url":"https://www.themoviedb.org/person/1588963"},{"name":"Tuyên Huyên","name_vi":"Tuyên Huyên","name_original":"Jessica Hsuan","tmdb_id":230777,"profile":"https://image.tmdb.org/t/p/w500/3hp9D2B1Y7L7imPUHCpHiNgxSY.jpg","tmdb_url":"https://www.themoviedb.org/person/230777"},{"name":"Đằng Lệ Danh","name_vi":"Đằng Lệ Danh","name_original":"Joyce Tang Lai-Ming","tmdb_id":1223072,"profile":"https://image.tmdb.org/t/p/w500/rCGjxrs3HeRoOhzqbAwCucV12qo.jpg","tmdb_url":"https://www.themoviedb.org/person/1223072"},{"name":"Lâm Bảo Di","name_vi":"Lâm Bảo Di","name_original":"Bowie Lam Bo-Yee",