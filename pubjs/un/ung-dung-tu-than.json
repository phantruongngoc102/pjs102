ện để phá vỡ lời nguyền.</p>","tmdb_id":599975,"cast":["Elizabeth Lail","Jordan Calloway","Talitha Eliana Bateman","Peter Facinelli","Dillon Lane","Matt Letscher","Tom Segura","Lana McKissack","Anne Winters","Tichina Arnold","P.J. Byrne","Valente Rodriguez","Louisa Abernathy","Charlie McDermott","Jonny Berryman"],"director":["Justin Dec"],"keywords":["nurse","countdown","supernatural","religion","phone terror","devil","duringcreditsstinger","mysterious","mobile app","sinister"],"tmdb":{"type":"movie","id":"599975","season":null,"vote_average":6.21,"vote_count":2256},"cast_meta":[{"name":"Elizabeth Lail","name_vi":null,"name_original":"Elizabeth Lail","tmdb_id":1368507,"profile":"https://image.tmdb.org/t/p/w500/lDYjEyqojUs2sF3CgdsOZ9vr2KL.jpg","tmdb_url":"https://www.themoviedb.org/person/1368507"},{"name":"Jordan Calloway","name_vi":null,"name_original":"Jordan Calloway","tmdb_id":1216004,"profile":"https://image.tmdb.org/t/p/w500/tRqqOTzfAAftvtWgNIdjyo5WDfm.jpg","tmdb_url":"https://www.themoviedb.org/person/1216004"},{"name":"Talitha Eliana Bateman","name_vi":null,"name_original":"Talitha Eliana Bateman","tmdb_id":1379123,"profile":"https://image.tmdb.org/t/p/w500/nJ8usNkXlYwg6jUhtCWgcDwu3jw.jpg","tmdb_url":"https://www.themoviedb.org/person/1379123"},{"name":"Peter Facinelli","name_vi":null,"name_original":"Peter Facinelli","tmdb_id":56857,"profile":"https://image.tmdb.org/t/p/w500/mmha3A5INmromiCsN8FBSLScVpZ.jpg","tmdb_url":"https://www.themoviedb.org/person/56857"},{"name":"Dillon Lane","name_vi":null,"name_original":"Dillon Lane","tmdb_id":546850,"profile":"https://image.tmdb.org/t/p/w500/2L6aFiOt9HBd4SuioX9Jv31e5nu.jpg","tmdb_url":"https://www.themoviedb.org/person/546850"},{"name":"Matt Letscher","name_vi":null,"name_original":"Matt Letscher","tmdb_id":28414,"profile":"https://image.tmdb.org/t/p/w500/4tFddqIAqUnPAl64sM335GhYPdM.jpg","tmdb_url":"https://www.themoviedb.org/person/28414"},{"name":"Tom Segura","name_vi":null,"name_original":"Tom Segura","tmdb_id"