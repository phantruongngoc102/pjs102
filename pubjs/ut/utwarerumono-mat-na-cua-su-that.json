:"<p>Sau sự kiện tại phần trước \"Mặt Nạ Lừa Dối\", Đế quốc Yamato hiện tại được cai trị dưới hình thức thiết quân luật được dựng nên bởi những kẻ cầm quyền tàn nhẫn với tham vọng tất cả phải khuất phục trước mình. Haku dưới thân phận Oshutoru đã đứng lên lãnh đạo một đội quân khởi nghĩa giúp Công chúa Anju giành lại ngai vàng. Thế giới bỗng chốc rơi vào tình trạng khói lửa khi các quốc gia và tướng lĩnh phải lựa chọn phe để chiến đấu. Những bí mật to lớn dần được tiết lộ. Liệu hòa bình sẽ được khôi phục hay đây sẽ là khởi đầu của kết thúc?</p>","tmdb_id":46412,"cast":["Kentaro Tone","Risa Taneda","Chinatsu Akasaki","Inori Minase","Miyuki Sawashiro","Rie Kugimiya","Sayaka Ohara"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"46412","season":1,"vote_average":7.1,"vote_count":26},"cast_meta":[{"name":"Kentaro Tone","name_vi":null,"name_original":"Kentaro Tone","tmdb_id":1845268,"profile":"https://image.tmdb.org/t/p/w500/9IZ9SpSV0P4bJBN8ALll7IYMLG2.jpg","tmdb_url":"https://www.themoviedb.org/person/1845268"},{"name":"Risa Taneda","name_vi":null,"name_original":"Risa Taneda","tmdb_id":1324469,"profile":"https://image.tmdb.org/t/p/w500/cuUqpOqZyzfJLzRa6syhOLUCvNW.jpg","tmdb_url":"https://www.themoviedb.org/person/1324469"},{"name":"Chinatsu Akasaki","name_vi":null,"name_original":"Chinatsu Akasaki","tmdb_id":1296666,"profile":"https://image.tmdb.org/t/p/w500/nYYs30FgGrgr3uOiQ4ASmRpFca2.jpg","tmdb_url":"https://www.themoviedb.org/person/1296666"},{"name":"Inori Minase","name_vi":null,"name_original":"Inori Minase","tmdb_id":1325949,"profile":"https://image.tmdb.org/t/p/w500/cqOrQDUbbQLKpujzcK47YqjFdNp.jpg","tmdb_url":"https://www.themoviedb.org/person/1325949"},{"name":"Miyuki Sawashiro","name_vi":null,"name_original":"Miyuki Sawashiro","tmdb_id":186341,"profile":"https://image.tmdb.org/t/p/w500/11mGqwpmu8CoEy1YJgabj2g7MIv.jpg","tmdb_url":"https://www.themoviedb.org/person/186341"},{"name":"Rie Kugimiya","name_vi":null,"name_original":"Rie Kugimiya","tmdb_id":8392