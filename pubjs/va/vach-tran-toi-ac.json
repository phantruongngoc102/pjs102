cba9b134a3a77dd7d","link_m3u8":"https://vip.opstream10.com/20220530/18010_091f4af5/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream10.com/share/45ebd93b65d907b7f84545b9aed9af8f","link_m3u8":"https://vip.opstream10.com/20220530/18011_90938afb/index.m3u8"}]}],"description":"<p>Trưởng nhóm mảng Chính trị – nhà báo nữ xinh đẹp, nhanh nhẹn Cao Minh và Trưởng nhóm mảng Xã hội – nhà báo nam đẹp trai nhưng ăn chơi Hầu Phương Bình là nòng cốt của đội điều tra, dẫn dắt cả đội truy tìm sự thật. Bởi vì quan điểm khác nhau nên Cao Minh và Hầu Phương Bình thường xuyên xung đột với nhau nhưng đồng thời cũng rất thưởng thức điểm tốt của nhau. Cả đội điều tra đã hết mình tìm kiếm sự thật trong những vụ án bị che đậy ở một bệnh viện, một vụ scandal tình tay ba, một vụ tham nhũng, một cuộc biểu tình, một vụ buôn ma túy, một vụ bắt cóc, … Họ bị ngăn cản, bị buộc tội, nhiều lần gặp nguy hiểm, thậm chí suýt mất mạng nhưng vì là nhà báo, điều duy nhất họ muốn theo đuổi là sự thật.</p>","tmdb_id":96726,"cast":["Cheryl Yang","Jack Yao","Rexen Cheng","Tang Fei","Sam Yang","Chris Lee","Alex Ko","Danny Liang","Lee Chih-chin","Yu An-shun"],"director":["Li Chuang-yang"],"keywords":[],"cast_meta":[{"name":"Cheryl Yang","name_vi":null,"name_original":"Cheryl Yang","tmdb_id":1247111,"profile":"https://image.tmdb.org/t/p/w500/mqk1S0i5eMJ3tGuNAFT6RtKgSQb.jpg","tmdb_url":"https://www.themoviedb.org/person/1247111"},{"name":"Jack Yao","name_vi":null,"name_original":"Jack Yao","tmdb_id":126719,"profile":"https://image.tmdb.org/t/p/w500/yKAy8DfSRau9SdF9JSvqSwKzldY.jpg","tmdb_url":"https://www.themoviedb.org/person/126719"},{"name":"Rexen Cheng","name_vi":null,"name_original":"Rexen Cheng","tmdb_id":1630179,"profile":"https://image.tmdb.org/t/p/w500/g4LRyvuiNpDcS7E7I8pH6de062e.jpg","tmdb_url":"https://www.themoviedb.org/person/1630179"},{"name":"Tang Fei","name_vi":null,"name_original":"Tang Fei","tmdb_id":2899828,"profile":"https://image.tmdb.org/t/p/w500/yzA5KoBiLFsi04WXDWn3QwWOc