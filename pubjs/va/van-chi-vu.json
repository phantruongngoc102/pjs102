8":"https://vip.opstream11.com/20230915/47278_bf192d2d/index.m3u8"},{"name":"24","slug":"24","filename":"My Journey to You 2023 EP24","link_embed":"https://vip.opstream11.com/share/030d224ae955e3dd63825944830c8fe4","link_m3u8":"https://vip.opstream11.com/20230915/47279_c36646bd/index.m3u8"}]}],"time":"57 phút/tập","description":"<p>Vân Chi Vũ là một bộ phim cổ trang huyền thoại do Quách Kính Minh đạo diễn, với sự tham gia của các diễn viên Ngu Thư Hân, Trương Lăng Hách, Trần Đô Linh, Tăng Khả Ny.</p><p>Bộ phim kể về câu chuyện của thích khách mong muốn tự do Vũ Vị Sam (Ngu Thư Hân thủ vai) phải thâm nhập hoàng cung hoàn thành nhiệm vụ. Trong chốn cung cấm đầy hiểm nguy, cô gặp tình yêu, tình bạn, tìm kiếm bản thân, kiên định hướng đi, và trưởng thành cùng với Tử Vũ - chàng điện hạ ương bướng (Trương Lăng Hách thủ vai).</p>","tmdb":{"type":"tv","id":"226186","season":1,"vote_average":7.3,"vote_count":21},"modified":"2024-12-01T14:12:27.000Z","cast":["Ngu Thư Hân","Trương Lăng Hách","Thừa Lũy","Lư Dục Hiểu","Kim Tĩnh","Tôn Thần Thuân","Điền Gia Thụy"],"director":["Director"],"cast_meta":[{"name":"Ngu Thư Hân","name_vi":"Ngu Thư Hân","name_original":"Yu Shuxin","tmdb_id":2140103,"profile":"https://image.tmdb.org/t/p/w500/xQ2Bur9AEy0IX3qHMvLbr7tmTyD.jpg","tmdb_url":"https://www.themoviedb.org/person/2140103"},{"name":"Trương Lăng Hách","name_vi":"Trương Lăng Hách","name_original":"Zhang Linghe","tmdb_id":3091887,"profile":"https://image.tmdb.org/t/p/w500/qJtnyHBnv7t7sNCei2By1CJ9hwL.jpg","tmdb_url":"https://www.themoviedb.org/person/3091887"},{"name":"Thừa Lũy","name_vi":"Thừa Lũy","name_original":"Ryan Cheng","tmdb_id":3093089,"profile":"https://image.tmdb.org/t/p/w500/mN45mgpV6TkttOt7zOIGv2u3H0S.jpg","tmdb_url":"https://www.themoviedb.org/person/3093089"},{"name":"Lư Dục Hiểu","name_vi":"Lư Dục Hiểu","name_original":"Lu Yuxiao","tmdb_id":3503861,"profile":"https://image.tmdb.org/t/p/w500/42fcXOMXCts1iEfJJpOBFPVwMLW.jpg","tmdb_url":"https://www.themoviedb.org/person/350