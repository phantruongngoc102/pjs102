m17.com/20251213/24698_e5cebc6f/index.m3u8"},{"name":"29","slug":"29","link_embed":"https://vip.opstream17.com/share/c44953f2f780be79d8f60e568c9bd1e4","link_m3u8":"https://vip.opstream17.com/20251213/24699_c44953f2/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream17.com/share/a7a0da96b4c16537050114ceed8368c9","link_m3u8":"https://vip.opstream17.com/20251213/24700_a7a0da96/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream17.com/share/2e405b15462930fe38bd7ab3ca37869b","link_m3u8":"https://vip.opstream17.com/20251213/24701_2e405b15/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream17.com/share/26f6abfa0d7725fef678e371897d5df0","link_m3u8":"https://vip.opstream17.com/20251213/24702_26f6abfa/index.m3u8"}]}],"description":"<p>Nhân vật chính Lâm Phong vốn là một kỹ sư AI thiên tài, dốc bao tâm huyết và công sức để nâng cao chức năng của người máy siêu cấp mà anh đang nghiên cứu. Anh đào được một con mắt của tổ loài rồng (Tổ Long Chi Mâu), báu vật từ thời thượng cổ ở dưới một vực sâu. Khi anh đang lắp con mắt đó vào trong người máy, thần lực trong mắt rồng bỗng được kích hoạt mở ra một vòng xoáy thời không đưa Lâm Phong đến Đại lục Cổ Thần - nơi vẫn đang thịnh hành võ đạo. Từ đó Lâm Phong chuyển kiếp sống lại. Sau khi sống lại, Lâm Phong bị phong ấn ký ức của kiếp trước, trở thành một người bình thường thức tỉnh võ hồn hệ trị liệu. Anh bị ghét, còn bị vị hôn thê huỷ hôn. Tộc nhân của vị hôn thê đó tàn nhẫn đánh lén muốn giết Lâm Phong để diệt cỏ tận gốc. Lúc nguy hiểm, Lâm Phong đã thức tỉnh ký ức về Tổ Long Chi Mâu và bất ngờ phát hiện ra thần lực của nó và siêu người máy anh nghiên cứu đã dung hợp. Dưới sự giúp đỡ của người máy, anh dần dần khống chế được thần lực của con mắt và bước vào con đường võ giả.</p>","tmdb_id":275400,"cast":["曲正"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"275400","season":1,"vote_average":7,"vote_count":2},"cast_meta":[{"name":"曲正","name_vi":null,"name_original":"曲正"