3ba/index.m3u8"},{"name":"15","slug":"15","filename":"van-menh-ky-dieu-tap-15","link_embed":"https://vip.opstream12.com/share/cb59b747f88a35e0d452377f60f7c25f","link_m3u8":"https://vip.opstream12.com/20220322/4714_c8f2f7a6/index.m3u8"},{"name":"16","slug":"16","filename":"van-menh-ky-dieu-tap-16","link_embed":"https://vip.opstream12.com/share/5b0fa0e4c041548bb6289e15d865a696","link_m3u8":"https://vip.opstream12.com/20220322/4715_ff48fd46/index.m3u8"}]}],"time":"30M47S","description":"<p>Lý Phúc Châu, một người thiếu nữ học tra cổ linh tinh quái, ngẫu nhiên lạc vào nước Vân Lai nghèo khổ trong thế giới truyện tranh, được người dân nơi đó nhầm tưởng là thiên nữ từ trời giáng trần mà hưởng lễ ngang với thiên tử Vân Dịch. Nàng muốn dùng học thức nông cạn của mình giúp nước Vân Lai trở nên giàu mạnh, nhưng lại vô cớ bị cuốn vào trần đấu giữa quốc sư mang dã tâm sôi sục và thiên tử bù nhìn Vân Dịch. Nàng đơn thuần, hiền lành, trở thành bánh quy có nhân, rơi vào tình thế khó xử. Do vậy, nàng còn hiểu được chỗ xấu của sự thiếu hiểu biết và tầm quan trọng của học tập.</p>","tmdb":{"type":"tv","id":"124775","season":1,"vote_average":10,"vote_count":2},"modified":"2025-10-24T09:21:37.000Z","cast":["Cao Junxiang","Zhang Yuenan","Zhang Qing","Hồ Diệc Dao","Wang Yulin","Ming Yue","Zhu Lang","Parker Mao","Li Yaxi"],"director":["Zeng Huang Wu"],"cast_meta":[{"name":"Cao Junxiang","name_vi":null,"name_original":"Cao Junxiang","tmdb_id":2649250,"profile":"https://image.tmdb.org/t/p/w500/hAUu6GgPZBiKZ8LzuKPbNd4gbH6.jpg","tmdb_url":"https://www.themoviedb.org/person/2649250"},{"name":"Zhang Yuenan","name_vi":null,"name_original":"Zhang Yuenan","tmdb_id":2698071,"profile":"https://image.tmdb.org/t/p/w500/6ZK8MFqiQGNzjPQR8LSAL4uh9ev.jpg","tmdb_url":"https://www.themoviedb.org/person/2698071"},{"name":"Zhang Qing","name_vi":null,"name_original":"Zhang Qing","tmdb_id":5235651,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/5235651"},{"name":"Hồ Diệc Dao","name_vi":"Hồ Diệc Dao