share/ce6846556e8c145e84416120fd93e50c","link_m3u8":"https://vip.opstream12.com/20220609/17851_79077e65/index.m3u8"},{"name":"48A","slug":"48a","filename":"van-tich-truyen-legend-of-yunxi-tap-48A","link_embed":"https://vip.opstream12.com/share/59eea54dcd4065473150ed398d7ebeb8","link_m3u8":"https://vip.opstream12.com/20220609/17852_35e541f9/index.m3u8"},{"name":"48B","slug":"48b","filename":"van-tich-truyen-legend-of-yunxi-tap-48B","link_embed":"https://vip.opstream12.com/share/ebdbcb5360801434b7014fcb108f6998","link_m3u8":"https://vip.opstream12.com/20220609/17850_7a2d3c87/index.m3u8"},{"name":"49A","slug":"49a","filename":"van-tich-truyen-legend-of-yunxi-tap-49A","link_embed":"https://vip.opstream12.com/share/eed4fcc4a61a4e979a44eebcc5adbe1c","link_m3u8":"https://vip.opstream12.com/20220609/17855_070d8068/index.m3u8"},{"name":"49B","slug":"49b","filename":"van-tich-truyen-legend-of-yunxi-tap-49B","link_embed":"https://vip.opstream12.com/share/fb28d4e4592a5b2aa55fe8157c6e5616","link_m3u8":"https://vip.opstream12.com/20220609/17854_70a967a8/index.m3u8"},{"name":"50A","slug":"50a","filename":"van-tich-truyen-legend-of-yunxi-tap-50A","link_embed":"https://vip.opstream12.com/share/637386e85513e2141b4318825669d5a6","link_m3u8":"https://vip.opstream12.com/20220609/17853_98ec60b9/index.m3u8"},{"name":"50B","slug":"50b","filename":"van-tich-truyen-legend-of-yunxi-tap-50B","link_embed":"https://vip.opstream12.com/share/d3b8cc3e6c9693062cdfde1a234f8fcc","link_m3u8":"https://vip.opstream12.com/20220609/17857_5286f71e/index.m3u8"}]}],"time":"45 phút","description":"<p>Bộ phim Vân Tịch Truyện (Legend Of Yunxi) là câu chuyện kể về cuộc đời Hàn Vân Tịch (Cúc Tịnh Y), một cô gái tinh thông độc thuật. Do có sẹo độc trên mặt nên Hàn Vân Tịch luôn bị mọi người xa lánh, chê bai. Trong một cơ duyên, vì muốn tìm lại mẹ của mình, Vân Tịch nghe lệnh Thái hậu và Thiên Huy đế gả vào phủ Tần Vương, làm Tần Vương phi để thám thính tình hình của Tần Vương - Long Phi Dạ (Trương Triết Hạn). Hàn Vân Tịch cũng khiến Cố Thất Thiếu (Mễ Nhiệt) động lòng với cô, luôn ra tay giúp đỡ, bảo vệ mỗi khi Vân Tịch gặp nguy hiểm. Trải qua nhiều biến cố, Hàn Vân Tịch động chân tình với Tần Vương, trợ giúp Long Phi Dạ phá giải các âm mưu của Hoàng thất Thiên Ninh quốc, Bắc Lệ và Tây Khâu. Sau này Hàn Vân Tịch vì muốn giải Độc cổ cho Long Phi Dạ đã hi sinh bản thân mình. Nhờ vào năng lực thần kì của chiếc vòng tay, Hàn Vân Tịch đã sống lại và cùng Long Phi Dạ quy ẩn núi rừng, sống một cuộc đời an ổn, bạc đầu giai lão, không chia không lìa.</p>","tmdb":{"type":"tv","id":"80455","season":1,"vote_average":8.5,"vote_count":11},"modified":"2023-04-10T13:19:27.000Z","cast":["Cúc Tịnh Y","Trương Triết Hạn","Mễ Nhiệt","Hồ Binh","Lâm Tư Ý","Hứa Giai Kỳ","Vương Hữu Thạc","Chen Jiayi","Qin Xiaoxuan","Hu Yuansong","Triệu nghị Tân"],"director":["Lưu Trấn Minh"],"cast_meta":[{"name":"Cúc Tịnh Y","name_vi":"Cúc Tịnh Y","name_original":"Ju Jingyi","tmdb_id":1686990,"profile":"https://image.tmdb.org/t/p/w500/xbyH30PEsDMFf1JP3BNYCegkDLP.jpg","tmdb_url":"https://www.themoviedb.org/person/1686990"},{"name":"Trương Triết Hạn","name_vi":"Trương Triết Hạn","name_original":"Zhang Zhehan","tmdb_id":1940475,"profile":"https://image.tmdb.org/t/p/w500/t6wqEQsktu9ojCoQv3YmmklpeTM.jpg","tmdb_url":"https://www.themoviedb.org/person/1940475"},{"name":"Mễ Nhiệt","name_vi":"Mễ Nhiệt","name_original":"Merxat","tmdb_id":1982964,"profile":"https://image.tmdb.org/t/p/w500/y7lTmzX6rWBlMBfF6zep0FFDV9Y.jpg","tmdb_url":"https://www.themoviedb.org/person/1982964"},{"name":"Hồ Binh","name_vi":"Hồ Binh","name_original":"Hu Bing","tmdb_id":1198949,"profile":"https://image.tmdb.org/t/p/w500/fRA80ZETo1l7d6nUcIoNq90PxtF.jpg","tmdb_url":"https://www.themoviedb.org/person/1198949"},{"name":"Lâm Tư Ý","name_vi":"Lâm Tư Ý","name_original":"Lin Siyi","tmdb_id":1860408,"profile":"https://image.tmdb.org/t/p/w500/y2swnPwZhqU9RnyQNyIabX6olLA.jpg","tmdb_url":"https://www.themoviedb.org/person/1860408"},{"name":"Hứa Giai Kỳ","name_vi