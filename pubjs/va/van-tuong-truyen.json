a về một thảm án, Vân Tương tìm ra sự thật kinh hoàng có liên quan đến Vân Đài và quyết định đứng lên bảo vệ chính nghĩa bằng cả trái tim mình, ngay cả khi phải trả giá bằng cả tính mạng.\\nBộ phim sẽ được phát sóng trực tuyến trên iQiyi Quốc tế (iq.com).","tmdb_id":138288,"cast":["Trần Hiểu","Mao Hiểu Đồng","Đường Hiểu Thiên","Hứa Linh Nguyệt","Lưu Quán Lân","Tần Lam","Vương Kính Tùng","Huệ Anh Hồng","Huỳnh Hải Băng","Peng Bo","Vương Tử Duệ","Liu Di","Ning Xin","Feng Jianyu"],"director":["You Da Zhi"],"keywords":[],"tmdb":{"type":"tv","id":"138288","season":1,"vote_average":8,"vote_count":5},"cast_meta":[{"name":"Trần Hiểu","name_vi":"Trần Hiểu","name_original":"Chen Xiao","tmdb_id":1192909,"profile":"https://image.tmdb.org/t/p/w500/6D4YFXfukHzD03IlHtUN67yTwHF.jpg","tmdb_url":"https://www.themoviedb.org/person/1192909"},{"name":"Mao Hiểu Đồng","name_vi":"Mao Hiểu Đồng","name_original":"Mao Xiaotong","tmdb_id":1697058,"profile":"https://image.tmdb.org/t/p/w500/zOrbXf5SInGL06eYi56Z0jxI99G.jpg","tmdb_url":"https://www.themoviedb.org/person/1697058"},{"name":"Đường Hiểu Thiên","name_vi":"Đường Hiểu Thiên","name_original":"Tang Xiaotian","tmdb_id":2312401,"profile":"https://image.tmdb.org/t/p/w500/84NlC4nbZqwUJXH0tSNw9O6o3Um.jpg","tmdb_url":"https://www.themoviedb.org/person/2312401"},{"name":"Hứa Linh Nguyệt","name_vi":"Hứa Linh Nguyệt","name_original":"Amelie Xu","tmdb_id":1803093,"profile":"https://image.tmdb.org/t/p/w500/rqHrZ4gxFaIuB9MHCz3EaJIZQBL.jpg","tmdb_url":"https://www.themoviedb.org/person/1803093"},{"name":"Lưu Quán Lân","name_vi":"Lưu Quán Lân","name_original":"Liu Guanlin","tmdb_id":2178031,"profile":"https://image.tmdb.org/t/p/w500/9V1bgjKnp83ptaFNK17ba6MW4Cf.jpg","tmdb_url":"https://www.themoviedb.org/person/2178031"},{"name":"Tần Lam","name_vi":"Tần Lam","name_original":"Qin Lan","tmdb_id":1018709,"profile":"https://image.tmdb.org/t/p/w500/yYylpCfEYYrXtEjf82ItvCWXSPh.jpg","tmdb_url":"https://www.themoviedb.org/person/1018709"},{"name":"Vương Kính Tùng