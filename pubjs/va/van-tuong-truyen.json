án, Vân Tương tìm ra sự thật kinh hoàng có liên quan đến Vân Đài và quyết định đứng lên bảo vệ chính nghĩa bằng cả trái tim mình, ngay cả khi phải trả giá bằng cả tính mạng.\\nBộ phim sẽ được phát sóng trực tuyến trên iQiyi Quốc tế (iq.com).","tmdb_id":138288,"cast":[],"director":[],"keywords":[],"tmdb":{"id":138288},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/va/van-tuong-truyen.json"}