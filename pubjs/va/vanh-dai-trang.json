{"id":"64c08055f9e5c68186f8c033","title":"Vành Đai Trắng","origin_name":"No Man's Land","slug":"vanh-dai-trang","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/va/vanh-dai-trang.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/va/vanh-dai-trang.webp","year":2001,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"},{"id":"620a2370e0fc277084dfd91e","name":"Anh","slug":"anh"},{"id":"620a2378e0fc277084dfd972","name":"Pháp","slug":"phap"},{"id":"621674a770b58bba6858b852","name":"Ý","slug":"y"},{"id":"6246acafc78eb57bbfe35df6","name":"Bỉ","slug":"bi"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"No Man's Land - Vành Đai Trắng - 2001","link_embed":"https://vip.opstream14.com/share/88b3febc5798a734026c82c1012408f5","link_m3u8":"https://vip.opstream14.com/20230725/38771_1e016659/index.m3u8"}]}],"time":"98 Phút","description":"No Man's Land - Ničija zemlja (Vành Đai Trắng) là một phim chiến tranh bi hài về cuộc chiến tranh Bosnia năm 1993. Đây là phim đầu tay của nhà biên kịch kiêm đạo diễn Danis Tanović, do các hãng phim của Ý, Pháp, Bỉ, Slovenia, Vương quốc Anh và Bosnia & Hercegovina hợp tác sản xuất. Hai người lính bị thương, một người Bosnia (Čiki) và một người Serb (Nino) nói chuyện với nhau giữa hai chiến tuyến trong khu vành đai trắng, khi họ đấu tranh để sống còn. Hai người lính này đối mặt nhau trong chiến hào của mình, và chờ đợi đêm tối. Họ nguyền rủa và cùng tìm thấy một số điểm chung. Tình thế càng rắc rối hơn, vì có thêm một người lính Bosna khác bị thương nữa (Cera) vừa tỉnh dậy sau khi bị hôn mê. Một quả mìn do quân đội Serb chôn bên dưới anh ta, khiến anh ta không thể di chuyển đi nơi khác được...","tmdb":{"type":"movie","id":"8342","season":null,"vote_average":7.493,"vote_count":479},"modified":"2023-07-26T09:09:26.000Z","cast":["Branko Đurić","Rene Bitorajac","Filip Šovagović","Georges Siatidis","Sacha Kremer","Alain Eloy","Katrin Cartlidge","Serge-Henri Valcke","Simon Callow","Tanja Ribič","Branko Završan","Bogdan Diklić","Mustafa Nadarević"],"director":["Danis Tanović"],"cast_meta":[{"name":"Branko Đurić","name_vi":null,"name_original":"Branko Đurić","tmdb_id":54620,"profile":"https://image.tmdb.org/t/p/w500/7AauDZUo39COLQmFxHJoAoUoX4O.jpg","tmdb_url":"https://www.themoviedb.org/person/54620"},{"name":"Rene Bitorajac","name_vi":null,"name_original":"Rene Bitorajac","tmdb_id":54621,"profile":"https://image.tmdb.org/t/p/w500/zM73IREObsmzrnXE01DMAYquIdb.jpg","tmdb_url":"https://www.themoviedb.org/person/54621"},{"name":"Filip Šovagović","name_vi":null,"name_original":"Filip Šovagović","tmdb_id":54622,"profile":"https://image.tmdb.org/t/p/w500/8dgvGgshF9XYbty8LkAbypMGfOU.jpg","tmdb_url":"https://www.themoviedb.org/person/54622"},{"name":"Georges Siatidis","name_vi":null,"name_original":"Georges Siatidis","tmdb_id":54623,"profile":"https://image.tmdb.org/t/p/w500/4rY0awV2NSZ2CcOdSU2fnsCBolp.jpg","tmdb_url":"https://www.themoviedb.org/person/54623"},{"name":"Sacha Kremer","name_vi":null,"name_original":"Sacha Kremer","tmdb_id":54625,"profile":"https://image.tmdb.org/t/p/w500/fa4nkMHJRvlHulwAqoz5q8QXjTa.jpg","tmdb_url":"https://www.themoviedb.org/person/54625"},{"name":"Alain Eloy","name_vi":null,"name_original":"Alain Eloy","tmdb_id":54626,"profile":"https://image.tmdb.org/t/p/w500/ugmjldocu7iMKJVFMxmvRO8Xygn.jpg","tmdb_url":"https://www.themoviedb.org/person/54626"},{"name":"Katrin Cartlidge","name_vi":null,"name_original":"Katrin Cartlidge","tmdb_id":1641,"profile":"https://image.tmdb.org/t/p/w500/cAG4WHKsLV2g08hnuZncy94HGOK.jpg","tmdb