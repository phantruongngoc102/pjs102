/share/47267ca39f652c0de27a4b27c5e11c40","link_m3u8":"https://vip.opstream17.com/20240509/7116_4f672a2b/index.m3u8"},{"name":"04","slug":"","filename":"Ve Si 04","link_embed":"https://vip.opstream17.com/share/5301c4d888f5204274439e6dcf5fdb54","link_m3u8":"https://vip.opstream17.com/20240509/7115_b18bd672/index.m3u8"},{"name":"03","slug":"","filename":"Ve Si 03","link_embed":"https://vip.opstream17.com/share/3501672ebc68a5524629080e3ef60aef","link_m3u8":"https://vip.opstream17.com/20240509/7113_2791e64a/index.m3u8"},{"name":"02","slug":"","filename":"Ve Si 02","link_embed":"https://vip.opstream17.com/share/ba7609ee5789cc4dff171045a693a65f","link_m3u8":"https://vip.opstream17.com/20240509/7112_31a7ef87/index.m3u8"},{"name":"01","slug":"","filename":"Ve Si 01","link_embed":"https://vip.opstream17.com/share/1ab60b5e8bd4eac8a7537abb5936aadc","link_m3u8":"https://vip.opstream17.com/20240509/7111_0b1f2e3e/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><i>Phim Vệ Sĩ nói về anh chàng vệ sĩ quá vợ tên Thiên Bảo đang làm việc cho công ty chuyên cung cấp vệ sĩ. Anh là một vệ sĩ xuất sắc nên được giao nhiệm vụ bảo vệ cho con trai của một ông chủ lớn tên là Ngạn Tổ. Thế nhưng vào một ngày nọ cả hai cha con của họ điều bị bắt cóc nên anh phải điều tra để cứu họ. Phim Vệ Sĩ cũng nói lên quá trình điều tra của Thiên Bảo, anh vô tình phát hiện ra nhiều bí mật mà trước giờ anh không hề hay biết. Thiên bảo vô tình biết được nguyên nhân cái chết của vợ mình và sự bán đứng của người bên cạnh anh. Thế ai là người đã gây ra cái chết cho vợ anh và người bán đứng anh là ai? Hãy xem 20 tập phim Vệ Sĩ để tìm ra câu trả lời nha.</i></p>","tmdb":{"type":"tv","id":"44599","season":1,"vote_average":0,"vote_count":0},"modified":"2025-01-12T10:02:33.000Z","cast":["Lâm Bảo Di","Trần Diệu Anh","Trương Triệu Huy","Mã Tuấn Vỹ","Trương Tuệ Nghi","Elaine Ng Yee-Lei","Tăng Giang","Florence Kwok Siu-Wan","Pang Chi-Ching","Hứa Thiệu Hùng","Mannor Chan Man-Na","La Lạc Lâm","Timothy Shaw Chun-Yung","Le