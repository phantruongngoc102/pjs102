k_embed":"https://vip.opstream13.com/share/21476eebfe7a3e15bee9713c94b8a6c4","link_m3u8":"https://vip.opstream13.com/20251108/17642_21476eeb/index.m3u8"},{"name":"19","slug":"19","filename":"TVB lồng tiếng Về Với Nhân Gian (A Smiling Ghost Story) 19#20 # Quách Tấn An, Trương Khả Di # 1999","link_embed":"https://vip.opstream13.com/share/0e9f1b15c7f9b9f6a72a4e9a51b35862","link_m3u8":"https://vip.opstream13.com/20251108/17643_0e9f1b15/index.m3u8"},{"name":"20","slug":"20","filename":"TVB lồng tiếng Về Với Nhân Gian (A Smiling Ghost Story) 20#20 # Quách Tấn An, Trương Khả Di # 1999","link_embed":"https://vip.opstream13.com/share/66b8d6392a59b5ce703c28340d8b3565","link_m3u8":"https://vip.opstream13.com/20251108/17644_66b8d639/index.m3u8"}]}],"time":"40 phút/tập","description":"<p>Lam Ka Yi là một cô gái tốt bụng, bị điện giật chết khi đang cứu một đứa trẻ khỏi biển hiệu rơi xuống. Một người qua đường tên là Ku Dak Ming đã cố gắng hồi sức cho cô bằng cách hô hấp nhân tạo, nhưng không thành công. Tuy nhiên, sự việc này đã khiến linh hồn của Ka Yi và Dak Ming có một mối liên kết đặc biệt. Vì vậy, khi Ka Yi biết rằng cha mẹ tương lai của cô thực chất là anh họ Man Siu Ying và bạn thân của Dak Ming là Fong Chi Lung, hai người vốn bất hòa với nhau, cô đã cố gắng nhờ Dak Ming giúp họ đến với nhau, khiến anh vô cùng thất vọng. Tuy nhiên, Ka Yi và Dak Ming dần dần nảy sinh tình cảm; nhưng liệu mối quan hệ giữa ma và người có thể thành công?</p>","tmdb":{"type":"tv","id":"101334","season":1,"vote_average":5,"vote_count":1},"modified":"2025-11-10T18:18:42.000Z","cast":["Trương Khả Di","Quách Tấn An","Trần Pháp Dung","Trương Gia Huy","Lâm Hiểu Phong","Lạc Ứng Quân","Huệ Anh Hồng","Wong Hoi-Yan","Lý Long Cơ","Hạ Bình","Fiona Yuen Choi-Wan","Helen Ma Hoi-Lun","La Mãng","La Quân Tả","Raymond Lee"],"director":[],"cast_meta":[{"name":"Trương Khả Di","name_vi":"Trương Khả Di","name_original":"Maggie Cheung Ho-Yee","tmdb_id":125882,"profile":"https://image.tmdb.org/t/p/w500/2c4ILgnK12OMAGn