 Min","Park Ha-seon","Kim Ji-eun","Kim Byeong-gi","Lee Kyung-young","Jang Young-nam","Yu Oh-seong","Kim Jong-tae","Kim Min-sang","Kim Do-hyun","Kwon So-hyun","Jung Moon-sung","Hwang Hee","Jo Bok-rae","Park Jin-woo"],"director":["Kim Sung Yong"],"keywords":[],"tmdb":{"type":"tv","id":"127358","season":1,"vote_average":8,"vote_count":45},"cast_meta":[{"name":"Namkoong Min","name_vi":null,"name_original":"Namkoong Min","tmdb_id":1239247,"profile":"https://image.tmdb.org/t/p/w500/aQ6AzP9dEyhml9bhQCr0vvEGkrk.jpg","tmdb_url":"https://www.themoviedb.org/person/1239247"},{"name":"Park Ha-seon","name_vi":null,"name_original":"Park Ha-seon","tmdb_id":125730,"profile":"https://image.tmdb.org/t/p/w500/A4fj22gXYZOv5aLpSdJldY3FLLq.jpg","tmdb_url":"https://www.themoviedb.org/person/125730"},{"name":"Kim Ji-eun","name_vi":null,"name_original":"Kim Ji-eun","tmdb_id":2334143,"profile":"https://image.tmdb.org/t/p/w500/eKDb8JtrO4SPySd0OwzttW1uvVw.jpg","tmdb_url":"https://www.themoviedb.org/person/2334143"},{"name":"Kim Byeong-gi","name_vi":null,"name_original":"Kim Byeong-gi","tmdb_id":3157385,"profile":"https://image.tmdb.org/t/p/w500/A0lxvyDZJJ8U4p8rQvm4BehZTYv.jpg","tmdb_url":"https://www.themoviedb.org/person/3157385"},{"name":"Lee Kyung-young","name_vi":null,"name_original":"Lee Kyung-young","tmdb_id":231476,"profile":"https://image.tmdb.org/t/p/w500/aDNcLCWs7KHToiXxfG7ACwvne3l.jpg","tmdb_url":"https://www.themoviedb.org/person/231476"},{"name":"Jang Young-nam","name_vi":null,"name_original":"Jang Young-nam","tmdb_id":93996,"profile":"https://image.tmdb.org/t/p/w500/u0hl8WSswFhKVaKwaMAERU0xUJk.jpg","tmdb_url":"https://www.themoviedb.org/person/93996"},{"name":"Yu Oh-seong","name_vi":null,"name_original":"Yu Oh-seong","tmdb_id":80654,"profile":"https://image.tmdb.org/t/p/w500/iNqbeyp8Qoi0Sw2rlKgvwu5rSV2.jpg","tmdb_url":"https://www.themoviedb.org/person/80654"},{"name":"Kim Jong-tae","name_vi":null,"name_original":"Kim Jong-tae","tmdb_id":3134668,"profile":"https://image.tmdb.org/t