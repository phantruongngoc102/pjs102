7a320079/index.m3u8"},{"name":"26","slug":"26","filename":"Kalp Yarasi 26","link_embed":"https://vip.opstream10.com/share/9aa3268dd5254fd709384d2b61d2a3a5","link_m3u8":"https://vip.opstream10.com/20230301/26440_dc80d229/index.m3u8"},{"name":"27","slug":"27","filename":"Kalp Yarasi 27","link_embed":"https://vip.opstream10.com/share/5b8b532425202aabea874712edabd2ac","link_m3u8":"https://vip.opstream10.com/20230303/26452_6f96d3b2/index.m3u8"},{"name":"28","slug":"28","filename":"Kalp Yarasi 28","link_embed":"https://vip.opstream10.com/share/b6034e2aec7cf857f86ec2322eee1180","link_m3u8":"https://vip.opstream10.com/20230304/26463_ecfae209/index.m3u8"},{"name":"29","slug":"29","filename":"Kalp Yarasi 29","link_embed":"https://vip.opstream10.com/share/a66dbabd793deed367030aadfcfc59b9","link_m3u8":"https://vip.opstream10.com/20230308/26497_a2eb8987/index.m3u8"},{"name":"30","slug":"30","filename":"Kalp Yarasi 30","link_embed":"https://vip.opstream10.com/share/9a8d909d7652448b2dc301613a123aab","link_m3u8":"https://vip.opstream10.com/20230310/26508_b6bb28e3/index.m3u8"},{"name":"31","slug":"31","filename":"Kalp Yarasi 31","link_embed":"https://vip.opstream10.com/share/6d0ca152a941f960431082ec429f6f11","link_m3u8":"https://vip.opstream10.com/20230313/26548_195c7037/index.m3u8"},{"name":"32","slug":"32","filename":"Kalp Yarasi 32","link_embed":"https://vip.opstream10.com/share/dabec13d9ab3d2f9054e435162755ff8","link_m3u8":"https://vip.opstream10.com/20230315/26589_7707c33a/index.m3u8"}]}],"time":"2h/tập","description":"<p>Ferit (Gokhan Alkan) là một chàng trai trẻ xuất thân từ một gia đình giàu có và nổi tiếng ở Sancakzade. Anh ấy sống ở Antakya và làm việc tại cơ sở kinh doanh của gia đình thay vì trở thành luật sư sau khi tốt nghiệp trường luật.</p><p>Ferit chuẩn bị kết hôn với Hande (Merve Cagiran), cũng xuất thân từ một gia đình giàu có. Ferit và Hande quen nhau từ thuở nhỏ và quyết định kết hôn sau khi được sự đồng ý của cha mẹ.</p><p>3 ngày trước hôn lễ, cuộc sống của Ferit bị đảo lộn. Anh ấy nhìn thấy người bạn thời thơ ấu của mình là Yaman (Toprak Can Adiguzel) đang hôn vợ sắp cưới của mình là Hande. Ferit rung động trước sự phản bội của người yêu và người bạn thời thơ ấu.</p><p>Ferit không thể làm gì khác ngoài việc rời khỏi thành phố càng sớm càng tốt. Anh ấy đến Istanbul để có thời gian một mình. Ferit không thể chấp nhận sự thật rằng anh ta đã bị phản bội bởi những người mà anh ta đã biết từ thời thơ ấu.</p>","tmdb":{"type":"tv","id":"126248","season":1,"vote_average":8.286,"vote_count":14},"modified":"2023-09-05T02:40:32.000Z","cast":["Gökhan Alkan","Yağmur Tanrısevsin","Merve Çağıran","Toprak Can Adıgüzel","Şenay Gürler","İnanç Konukçu","Yonca Şahinbaş","Rıza Akın","Burçin Abdullah","Naz Sayıner"],"director":["Yildiz Hulya Bilban"],"cast_meta":[{"name":"Gökhan Alkan","name_vi":null,"name_original":"Gökhan Alkan","tmdb_id":2022326,"profile":"https://image.tmdb.org/t/p/w500/Alb5j1X93yM2J9ZTlg0SkENPjOP.jpg","tmdb_url":"https://www.themoviedb.org/person/2022326"},{"name":"Yağmur Tanrısevsin","name_vi":null,"name_original":"Yağmur Tanrısevsin","tmdb_id":1419823,"profile":"https://image.tmdb.org/t/p/w500/tNwEK3fQGRTJZeAC3qT29i2hrjF.jpg","tmdb_url":"https://www.themoviedb.org/person/1419823"},{"name":"Merve Çağıran","name_vi":null,"name_original":"Merve Çağıran","tmdb_id":1584276,"profile":"https://image.tmdb.org/t/p/w500/p9m1qeLtwChkZOmG77FzSVbuHjN.jpg","tmdb_url":"https://www.themoviedb.org/person/1584276"},{"name":"Toprak Can Adıgüzel","name_vi":null,"name_original":"Toprak Can Adıgüzel","tmdb_id":2812444,"profile":"https://image.tmdb.org/t/p/w500/6cx0ibzRuxIZU28cfXKNDFPD2aZ.jpg","tmdb_url":"https://www.themoviedb.org/person/2812444"},{"name":"Şenay Gürler","name_vi":null,"name_original":"Şenay Gürler","tmdb_id":236892,"profile":"https://image.tmdb.org/t/p/w500/5FqFZfj1O24wUruv48jfAJRP1ND.jpg","tmdb_url":"https://www.themoviedb.org/person/236892"},{"name":"İnanç Konukçu","name_vi":null,"name_original":"İnanç Konukçu","tmdb_id":1