a Hongo","Fumiyo Kohinata","Nijirou Murakami"],"director":["Norihiro Naganuma"],"keywords":[],"time":"","tmdb":{"type":"tv","id":"73946","season":1,"vote_average":8.027,"vote_count":301},"cast_meta":[{"name":"Kanata Hongo","name_vi":null,"name_original":"Kanata Hongo"},{"name":"Fumiyo Kohinata","name_vi":null,"name_original":"Fumiyo Kohinata"},{"name":"Nijirou Murakami","name_vi":null,"name_original":"Nijirou Murakami"}],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/vi/vi-anh-hung-cuoi-cung.json"}