hưng trong lòng luôn có tham vọng được vào Kim Lũ Các và muốn giành chức trưởng thêu tại đây.</p>","tmdb_id":82523,"cast":["Tôn Di","Đặng Luân","Wu You","Đại Siêu","Pan Yi-chun","Lưu Mẫn Đào","Kelvin Lee","Xia Zhiqing"],"director":["Chu Hiểu Bằng"],"keywords":[],"tmdb":{"type":"tv","id":"82523","season":1,"vote_average":7,"vote_count":3},"cast_meta":[{"name":"Tôn Di","name_vi":"Tôn Di","name_original":"Sun Yi","tmdb_id":1689011,"profile":"https://image.tmdb.org/t/p/w500/tjHXyyR41IMJrw6wGZbFoJVhHDr.jpg","tmdb_url":"https://www.themoviedb.org/person/1689011"},{"name":"Đặng Luân","name_vi":"Đặng Luân","name_original":"Deng Lun","tmdb_id":1826898,"profile":"https://image.tmdb.org/t/p/w500/wRFsh37qJq0lcAQRADBVBPRKKw.jpg","tmdb_url":"https://www.themoviedb.org/person/1826898"},{"name":"Wu You","name_vi":null,"name_original":"Wu You","tmdb_id":2131224,"profile":"https://image.tmdb.org/t/p/w500/7PUzF89kFtJ57V6rePeXsKIvfdn.jpg","tmdb_url":"https://www.themoviedb.org/person/2131224"},{"name":"Đại Siêu","name_vi":"Đại Siêu","name_original":"Dai Chao","tmdb_id":2133083,"profile":"https://image.tmdb.org/t/p/w500/uZPt9b9Ktd4sEVKdJBUW8tDsy7p.jpg","tmdb_url":"https://www.themoviedb.org/person/2133083"},{"name":"Pan Yi-chun","name_vi":null,"name_original":"Pan Yi-chun","tmdb_id":1429675,"profile":"https://image.tmdb.org/t/p/w500/dETTclDzjrPQh35VqtwMEz5AMdV.jpg","tmdb_url":"https://www.themoviedb.org/person/1429675"},{"name":"Lưu Mẫn Đào","name_vi":"Lưu Mẫn Đào","name_original":"Liu Mintao","tmdb_id":1079119,"profile":"https://image.tmdb.org/t/p/w500/32bnuj7u6P3LGs7iEAUax3JSW6E.jpg","tmdb_url":"https://www.themoviedb.org/person/1079119"},{"name":"Kelvin Lee","name_vi":null,"name_original":"Kelvin Lee","tmdb_id":1277360,"profile":"https://image.tmdb.org/t/p/w500/87EQycQGIvcjnsiBIm68wIgcyit.jpg","tmdb_url":"https://www.themoviedb.org/person/1277360"},{"name":"Xia Zhiqing","name_vi":null,"name_original":"Xia Zhiqing","tmdb_id":1975521,"profile":"https://image.tmdb.org/t/p/w500/iLmBu4F2U