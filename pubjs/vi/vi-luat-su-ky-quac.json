b03351eb1742f","link_m3u8":"https://vip.opstream11.com/20220325/4855_2327d7d0/index.m3u8"},{"name":"39","slug":"39","filename":"Vị Luật Sư Kỳ Quặc - My Lawyer Mr Joe 2 - Tập 39","link_embed":"https://vip.opstream11.com/share/0c6b6f19684ed9b6ff07575fcf81c98d","link_m3u8":"https://vip.opstream11.com/20220325/4854_cd81a0c2/index.m3u8"},{"name":"40","slug":"40","filename":"Vị Luật Sư Kỳ Quặc - My Lawyer Mr Joe 2 - Tập 40","link_embed":"https://vip.opstream11.com/share/06f7c042b76e4b04f698c75b7b2777ea","link_m3u8":"https://vip.opstream11.com/20220325/4856_dd867142/index.m3u8"}]}],"time":"35 phút/tập","description":"<p>Vị Luật Sư Kỳ Quặc - My Lawyer Mr Joe 2 kể về nhân vật Jo Deul-Ho xuất thân từ một gia đình nghèo, bằng nỗ lực của mình anh đã trở thành một công tố viên đầy hứa hẹn. Thế nhưng, với môi trường công việc đầy rẫy sự cạnh tranh, bất công, anh đã không thể làm ngơ trước những việc này và mất tất cả mọi thứ. Jo Deul-Ho sau đó làm việc để trở thành một luật sư với mong muốn có thể bảo vệ công bằng cho những người bị hại. Trong phần 2, Jo Deul-Ho là nhân vật đem đến nhiều tình tiết tươi mới và ly kỳ cho khán giả. Kẻ thù của Deul-Ho được nâng cấp và mạnh hơn bao giờ hết. Liệu anh có thể đối mặt và chiến thắng cái ác?</p>","tmdb":{"type":"tv","id":"65895","season":1,"vote_average":5.2,"vote_count":19},"modified":"2023-06-06T20:08:34.000Z","cast":["Park Shin-yang","Ko Hyun-jung","Lee Min-ji","Byun Hee-bong","Jo Dal-hwan","Lee Mi-do","Jung Jun-won","Moon Soo-bin","Seo Yi-sook","Jeon Bae-soo","Ju Jin-mo","Son Byung-ho","Hong Kyung","Choi Seung-kyung","Choi Gwang-il"],"director":["Han Sang-Woo"],"cast_meta":[{"name":"Park Shin-yang","name_vi":null,"name_original":"Park Shin-yang","tmdb_id":1244787,"profile":"https://image.tmdb.org/t/p/w500/gruS0gJcCDYBwVOjP5Vzngcfiw4.jpg","tmdb_url":"https://www.themoviedb.org/person/1244787"},{"name":"Ko Hyun-jung","name_vi":null,"name_original":"Ko Hyun-jung","tmdb_id":1245069,"profile":"https://image.tmdb.org/t/p/w500/fXtGYhd6bQy01NP