0230209/42485_f529b66a/index.m3u8"},{"name":"6","slug":"6","link_embed":"https://vip.opstream11.com/share/4de20dd98d2ca78fd643bdc4f0a6359b","link_m3u8":"https://vip.opstream11.com/20230216/42824_57ccbec1/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream11.com/share/02e2e87d009913683aabb4d2bfb3b127","link_m3u8":"https://vip.opstream11.com/20230309/43006_3a03bfeb/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream11.com/share/612dc8387f092f8c04c5c475993f26ae","link_m3u8":"https://vip.opstream11.com/20230316/43078_72bf913b/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream11.com/share/4077e51c9161eba27b433da8a62bd9cd","link_m3u8":"https://vip.opstream11.com/20230323/43119_bf82d220/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream11.com/share/9b46cae14639ee92bc8477140c8cf2f1","link_m3u8":"https://vip.opstream11.com/20230330/43168_ffb933bd/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream11.com/share/1d7ae90599d59350ada989519870b0e6","link_m3u8":"https://vip.opstream11.com/20230413/43212_e5efb6cf/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream11.com/share/5d347461fef2060cacfa445eb828b790","link_m3u8":"https://vip.opstream11.com/20230420/43245_438ccbeb/index.m3u8"}]}],"description":"<p>Sau lời mời nhiệt tình từ người bạn của mình, Kaede Honjou miễn cưỡng đồng ý chơi thử New World Online: một VRMMO rất nổi tiếng được chơi bởi hàng nghìn người trên khắp Nhật Bản. Đặt tên cho nhân vật trong trò chơi của mình là Maple, cô ấy bắt đầu cuộc hành trình của mình. Là một người hoàn toàn mới làm quen với những trò chơi như vậy, cô ấy phân bổ tất cả các điểm chỉ số của mình vào sức sống, mong muốn không bị thương. Không có một điểm nào trong bất kỳ chỉ số nào khác, Maple có khả năng phòng thủ cực cao, nhưng cô ấy không thể di chuyển nhanh hay đánh mạnh. Mặc dù có tính cách mạnh mẽ, Kaede vẫn còn nhiều điều phải học. Khi hoàn thành trò chơi, cô ấy gặp gỡ những người bạn và người quen mới, giúp cô ấy hoàn thành các cấp độ và sự kiện mới. Thông qua tất cả các cuộc phiêu lưu của mình, cô ấy thậm chí có thể học được một số kỹ năng điên rồ khác vượt quá mọi mong đợi.</p>","tmdb_id":96402,"cast":["Kaede Hondo","Ruriko Noguchi","Saori Hayami","Satomi Arai","Ai Kakuma","Nanaka Suwa","Noriaki Sugiyama","Satomi Sato","Kensho Ono","Takumi Yamazaki","Ayana Taketatsu","Nobutoshi Canna","Rina Sato","Kappei Yamaguchi","Akira Ishida"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"96402","season":1,"vote_average":7.4,"vote_count":144},"cast_meta":[{"name":"Kaede Hondo","name_vi":null,"name_original":"Kaede Hondo","tmdb_id":1779027,"profile":"https://image.tmdb.org/t/p/w500/11BcHnuJYrOZhIftgUiQqfm7TK6.jpg","tmdb_url":"https://www.themoviedb.org/person/1779027"},{"name":"Ruriko Noguchi","name_vi":null,"name_original":"Ruriko Noguchi","tmdb_id":2415366,"profile":"https://image.tmdb.org/t/p/w500/zbuz55p5GCeHWu4ez17Phk4mLui.jpg","tmdb_url":"https://www.themoviedb.org/person/2415366"},{"name":"Saori Hayami","name_vi":null,"name_original":"Saori Hayami","tmdb_id":221773,"profile":"https://image.tmdb.org/t/p/w500/gLv9lO7dlUbIsmyJUvgegqAAXki.jpg","tmdb_url":"https://www.themoviedb.org/person/221773"},{"name":"Satomi Arai","name_vi":null,"name_original":"Satomi Arai","tmdb_id":219563,"profile":"https://image.tmdb.org/t/p/w500/v95wU1gpSLAOJS5yKFTxyheXAW2.jpg","tmdb_url":"https://www.themoviedb.org/person/219563"},{"name":"Ai Kakuma","name_vi":null,"name_original":"Ai Kakuma","tmdb_id":1324646,"profile":"https://image.tmdb.org/t/p/w500/o3tQSeeJAeafJNvQs2IKvpKY7av.jpg","tmdb_url":"https://www.themoviedb.org/person/1324646"},{"name":"Nanaka Suwa","name_vi":null,"name_original":"Nanaka Suwa","tmdb_id":2072870,"profile":"https://image.tmdb.org/t/p/w500/lGuWJn7DPX3alblakB5WZE23LX2.jpg","tmdb_url":"https://www.themoviedb.org/person/2072870"},{"name":"Noriaki Sugiyama","name_vi":null,"name_original":"Noriaki Sugiyama","tmdb_id":82056,"profile":