m12.com/share/e7308d3f1c68503c7b5247a10d8a2afe","link_m3u8":"https://vip.opstream12.com/20220423/11948_6c9a5c29/index.m3u8"},{"name":"35B","slug":"35b","filename":"vien-det-hoang-cung-a-weaver-on-the-horizon-tap-35B","link_embed":"https://vip.opstream12.com/share/3463ba87bdc01378649630ed94f57eef","link_m3u8":"https://vip.opstream12.com/20220423/11949_c824619a/index.m3u8"},{"name":"36A","slug":"36a","filename":"vien-det-hoang-cung-a-weaver-on-the-horizon-tap-36A","link_embed":"https://vip.opstream12.com/share/3d816b6235b7f8751305f990bdb8c887","link_m3u8":"https://vip.opstream12.com/20220423/11950_53fa4e11/index.m3u8"},{"name":"36B","slug":"36b","filename":"vien-det-hoang-cung-a-weaver-on-the-horizon-tap-36B","link_embed":"https://vip.opstream12.com/share/20858f1e658fbbcfd3f79a73df858e81","link_m3u8":"https://vip.opstream12.com/20220423/11951_6da8c651/index.m3u8"}]}],"time":"45 phút","description":"<p>Viện Dệt Hoàng Cung là bộ phim nói về cuộc đời truyền kỳ của Hoàng Xảo Nhi (Hoàng Đạo Bà), được xem là người đã khai sáng ra thời kỳ mới cho nghề dệt Trung Hoa. Đây là người đã cải tiến kỹ thuật dệt vải của Trung Quốc, nâng nó lên tầm cao mới.Trong phim, Lưu Thi Thi vào vai công chúa bướng bỉnh Gia Nghi. Cô yêu tướng quân Lâm Mộ Phi, nhưng anh lại động lòng với người bạn thân thiết của cô trong cung cấm. Sau nhiều biến cố trong cuộc sống, người con gái Mộ Phi yêu cũng lấy chồng để thành toàn cho Gia Nghi và anh, nhưng cuộc sống hôn nhân của cô không hạnh phúc. Vì vậy, anh chỉ còn biết cách dồn tâm sức vào đại nghiệp khuông phò Nam Tống, còn Gia Nghi lại cam tâm tình nguyện cùng anh đi khắp chân trời góc biển, làm mọi cách để anh phải động lòng.</p>","tmdb":{"type":"tv","id":"106507","season":1,"vote_average":0,"vote_count":0},"modified":"2023-06-29T18:32:20.000Z","cast":["Trương Quân Ninh","Lưu Thi Thi","Edwin Siu","Yuan Hong","Trình Phối Phối","Lưu Tùng Nhân","Quách Hiểu Đình"],"director":["Lý Quốc Lập"],"cast_meta":[{"name":"Trương Quân Ninh","name_vi":"Trương Quân Ninh","name_original":"Janine Chang Chun-Ning","tmdb_id":564891,"profile":"https://image.tmdb.org/t/p/w500/xNov6ffJ8dZCPUxO6g1nWnmdXM2.jpg","tmdb_url":"https://www.themoviedb.org/person/564891"},{"name":"Lưu Thi Thi","name_vi":"Lưu Thi Thi","name_original":"Liu Shishi","tmdb_id":1185786,"profile":"https://image.tmdb.org/t/p/w500/yPyMTroHKKpK2g24o7920erAa3L.jpg","tmdb_url":"https://www.themoviedb.org/person/1185786"},{"name":"Edwin Siu","name_vi":null,"name_original":"Edwin Siu","tmdb_id":2723231,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2723231"},{"name":"Yuan Hong","name_vi":null,"name_original":"Yuan Hong","tmdb_id":1254212,"profile":"https://image.tmdb.org/t/p/w500/wpazHcgVmxzlvX1zBkSflJ40imp.jpg","tmdb_url":"https://www.themoviedb.org/person/1254212"},{"name":"Trình Phối Phối","name_vi":"Trình Phối Phối","name_original":"Cheng Pei-Pei","tmdb_id":1624,"profile":"https://image.tmdb.org/t/p/w500/jp33KMCMjy08FQWAtxhvJS2tHnn.jpg","tmdb_url":"https://www.themoviedb.org/person/1624"},{"name":"Lưu Tùng Nhân","name_vi":"Lưu Tùng Nhân","name_original":"Damian Lau Chung-Yan","tmdb_id":83624,"profile":"https://image.tmdb.org/t/p/w500/68XKvV0tjeZOnNM1OyenbAR50Xl.jpg","tmdb_url":"https://www.themoviedb.org/person/83624"},{"name":"Quách Hiểu Đình","name_vi":"Quách Hiểu Đình","name_original":"Guo Xiaoting","tmdb_id":1513376,"profile":"https://image.tmdb.org/t/p/w500/3u7cgGNe0s35FhjuOnNfytiJ0Z8.jpg","tmdb_url":"https://www.themoviedb.org/person/1513376"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/vi/vien-det-hoang-cung.json"}