2/22376_714c846c/index.m3u8"},{"name":"91","slug":"91","link_embed":"https://vip.opstream-short.com/share/9e5085b1a8633688490ba0fe7fe2862f","link_m3u8":"https://vip.opstream-short.com/20251112/22377_9e5085b1/index.m3u8"},{"name":"92","slug":"92","link_embed":"https://vip.opstream-short.com/share/2797fe1cc41844ef473a623bab9d32b0","link_m3u8":"https://vip.opstream-short.com/20251112/22378_2797fe1c/index.m3u8"},{"name":"93","slug":"93","link_embed":"https://vip.opstream-short.com/share/7f349530eb0d119150526e8efe0fc845","link_m3u8":"https://vip.opstream-short.com/20251112/22379_7f349530/index.m3u8"},{"name":"94","slug":"94","link_embed":"https://vip.opstream-short.com/share/24402d5ee440a37f41903da55be81848","link_m3u8":"https://vip.opstream-short.com/20251112/22380_24402d5e/index.m3u8"},{"name":"95","slug":"95","link_embed":"https://vip.opstream-short.com/share/e75a009b8a15aad6fb355cf2b5883272","link_m3u8":"https://vip.opstream-short.com/20251112/22381_e75a009b/index.m3u8"}]}],"description":"<p>Lý Cảnh Lăng, người thừa kế gia tộc giàu có, bị đối thủ làm tổn thương và được Nghiêm Uyển Uyển, người bán thịt heo cứu. Bị thu hút bởi lòng tốt và sự chân thành của cô, anh che giấu danh tính khi ở bên cô. Sau khi danh tính bị lộ, anh đưa cô về nhà họ Lý. Để thực hiện di nguyện của bà nội sắp qua đời, họ kết hôn theo thỏa thuận. Sau kết hôn, Nghiêm Uyển Uyển phải đối mặt với sự quấy rối từ họ hàng kỳ quặc, sự từ chối của gia đình Lý, và sự bắt nạt từ những phụ nữ ngưỡng mộ Lý Cảnh Lăng. Với sự bảo vệ và thiên vị của Lý Cảnh Lăng, cô vượt qua từng thử thách, được gia đình chấp nhận, và họ phát triển tình cảm chân thật để trở thành cặp vợ chồng thực sự.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/vo/vo-ban-thit-cua-tong-giam-doc-short-drama.json","tmdb_checked":false}