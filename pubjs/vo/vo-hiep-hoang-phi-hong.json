om/share/dc912a253d1e9ba40e2c597ed2376640","link_m3u8":"https://vip.opstream17.com/20240201/385_40d8f075/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream17.com/share/0584ce565c824b7b7f50282d9a19945b","link_m3u8":"https://vip.opstream17.com/20240201/384_7de9eee3/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream17.com/share/beed13602b9b0e6ecb5b568ff5058f07","link_m3u8":"https://vip.opstream17.com/20240201/383_8926a0cd/index.m3u8"}]}],"description":"<p><i>Xoay quanh đệ tử “ruột” của Hoàng Phi Hồng là Lâm Thế Vinh (Lưu Đức Hoa). Một lần, anh ta và Lương Khoan (Đồng Vỹ) tranh đoạt bài biện “Chiêu Phúc Bài” trong lúc chúc lễ và hai người tay chân cũng lanh lẹ nên được Hoàng Phi Hồng khen thưởng, từ đó nhận cả 2 người làm đệ tử. Thế Vinh lúc này đang có một cô người yêu xinh đẹp tên là Âu Dương Thanh Thanh (Lam Khiết Anh), tuy nhiên vì quá chú tâm vào việc tập võ mà bỏ quên cô nàng, vì thế bị anh chàng Mãn thanh tên Nạp Lan Chánh Đức (Thang Trấn Nghiệp) thừa cơ tiếp cận Thanh Thanh, không lâu sau, cô nàng vốn thiếu thốn sự quan tâm của Thế Vinh đã ngã vào vòng tay của Chánh Đức.</i><br><i>Trong khi đó, sư phụ của Chánh Đức là Đòan Bá Thiên cấu kết người Pháp và muốn giết Lưu Vĩnh Phước, hiện đang là Hắc Cơ Tướng Quân tại Quảng Tây. Nhưng lần nào cũng bị đệ tử của Hoàng Phi Hồng phát hiện được ý đồ trong sự tình cờ, sau này tên Bá Thiên kéo luôn tên giáo đầu di cự tại Quảng Châu là Thạch Chấn Nhạc để đối phó với Hoàng Phi Hồng. Thế Vinh sau khi biết tin Thanh Thanh kết hôn với Chánh Đức thì hết sức buồn bã và tuyệt vọng, từ đó dẫn tới việc anh dễ dàng bị sa vào bẫy của Bá Thiên. May được sự giúp đỡ của Thanh Thanh nên anh trốn đi Hồng Kồng. Chánh Đức biết được chuyện này sanh ra ghen tuông muốn giết Thế Vinh, y thực hiện bằng được kế hoạch của mình, nhưng rồi giết nhầm con của Hoàng Phi Hồng là Tuấn Nghi. Chuyện này bị Bá Thiên bắt gặp và uy hiếp Chánh Đức phải làm theo lời ông ta, trong khi Thế Vinh vì muốn trả thù cho cái chết của Tuấn Nghi đã lén về Quảng Châu để tìm hiểu sự thật.</i></p>","tmdb_id":107937,"cast":["Yammie Lam Kit-Ying","Lưu Đức Hoa","Liu Wai-Hung"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"107937","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Yammie Lam Kit-Ying","name_vi":null,"name_original":"Yammie Lam Kit-Ying","tmdb_id":87945,"profile":"https://image.tmdb.org/t/p/w500/o2B9BUelQVAvaRipDwJRJLU7dHk.jpg","tmdb_url":"https://www.themoviedb.org/person/87945"},{"name":"Lưu Đức Hoa","name_vi":"Lưu Đức Hoa","name_original":"Andy Lau","tmdb_id":25246,"profile":"https://image.tmdb.org/t/p/w500/z9R2yerjfgxwDWIH8sjiS0hhcre.jpg","tmdb_url":"https://www.themoviedb.org/person/25246"},{"name":"Liu Wai-Hung","name_vi":null,"name_original":"Liu Wai-Hung","tmdb_id":998678,"profile":"https://image.tmdb.org/t/p/w500/ardsrPTdd2qQsm0tW5WqEDu0hNl.jpg","tmdb_url":"https://www.themoviedb.org/person/998678"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/vo/vo-hiep-hoang-phi-hong.json"}