am11.com/20241108/56997_39bca3c0/index.m3u8"},{"name":"16","slug":"16","filename":"VoLamTheGia16","link_embed":"https://vip.opstream11.com/share/0b9d44c334c70e51b392ed9d5350893a","link_m3u8":"https://vip.opstream11.com/20241108/56998_0b9d44c3/index.m3u8"},{"name":"17","slug":"17","filename":"VoLamTheGia17","link_embed":"https://vip.opstream11.com/share/399b27116bb2d447f650bd1f82755013","link_m3u8":"https://vip.opstream11.com/20241108/56999_399b2711/index.m3u8"},{"name":"18","slug":"18","filename":"VoLamTheGia18","link_embed":"https://vip.opstream11.com/share/c98dca8930eee464a45ad98e696af10e","link_m3u8":"https://vip.opstream11.com/20241108/57000_c98dca89/index.m3u8"},{"name":"19","slug":"19","filename":"VoLamTheGia19","link_embed":"https://vip.opstream11.com/share/1c476149e6f9cb06fa0ebfbc0dd5e0e9","link_m3u8":"https://vip.opstream11.com/20241108/57001_1c476149/index.m3u8"},{"name":"20","slug":"20","filename":"VoLamTheGia20End","link_embed":"https://vip.opstream11.com/share/b0fef4770f0f1b3044d7bf45ab7fb580","link_m3u8":"https://vip.opstream11.com/20241108/57002_b0fef477/index.m3u8"}]}],"time":"42 phút/tập","description":"<p><i>Cuối đời nhà Minh, gia đình họ Phương nổi tiếng nhất về chế tạo vũ khí. Con cả của gia đình này là Phương Tuấn Nhân biết tin công chúa Đoàn Liễu Nhi (Trương Mạn Ngọc) sắp sửa tới trung nguyên mua binh khí nên sai con riêng của ông là Phương Hạo Thiên (Trương Quốc Vinh) tới giao tiếp. Trong một cuộc tai nạn Hạo Thiên đã cứu mạng Liễu Nhi, nên hai người bắt đầu thương nhau. Họ Phương chiếm đoạt một tiểu trang, vì muốn trả thù họ đã bắt cóc em của Hạo Thiên, được Hạo Thiên xả thân tương cứu. Liễu Nhi bị mất một số vàng và Hại thiên bị chú ba là Tống Trí (Lưu Giang) đổ tội, Hạo Thiên bị Tống Trí ép hại nên Tống Trí đã lặp âm mưu với người thân gia đình mình là nhà họ Khưu để ép hại Hạo Thiên...</i></p>","tmdb":{"type":"tv","id":"100330","season":1,"vote_average":0,"vote_count":0},"modified":"2024-12-17T15:30:52.000Z","cast":["Trương Quốc Vinh","Trương Mạn Ngọc","Tạ Hiền","Yeung Chak-Lam","Âu Dương Chấn Hoa","Lisa Lui Yau-Wai","Mark Cheung Lui","Lưu Thanh Vân","Lưu Giang","Chu Tit-Wo","Danny Poon Wang-Ban","Eddie Kwan Lai-Kit","Hạ Bình","Seung-Goon Yuk","Marylinn Wong Cho-Shut"],"director":["Lý Đình Luân"],"cast_meta":[{"name":"Trương Quốc Vinh","name_vi":"Trương Quốc Vinh","name_original":"Leslie Cheung","tmdb_id":69637,"profile":"https://image.tmdb.org/t/p/w500/xdSUevukGCrayOdLd4Kd6YSJnKR.jpg","tmdb_url":"https://www.themoviedb.org/person/69637"},{"name":"Trương Mạn Ngọc","name_vi":"Trương Mạn Ngọc","name_original":"Maggie Cheung","tmdb_id":1338,"profile":"https://image.tmdb.org/t/p/w500/hre6xmoDbh67YN7wR5nhUazPTlb.jpg","tmdb_url":"https://www.themoviedb.org/person/1338"},{"name":"Tạ Hiền","name_vi":"Tạ Hiền","name_original":"Patrick Tse Yin","tmdb_id":70439,"profile":"https://image.tmdb.org/t/p/w500/kqfgBxSQ8OflEQtWuKcvgjhkteD.jpg","tmdb_url":"https://www.themoviedb.org/person/70439"},{"name":"Yeung Chak-Lam","name_vi":null,"name_original":"Yeung Chak-Lam","tmdb_id":1140550,"profile":"https://image.tmdb.org/t/p/w500/qcRuGyA38BDCPMzv0O6dXp8aXsm.jpg","tmdb_url":"https://www.themoviedb.org/person/1140550"},{"name":"Âu Dương Chấn Hoa","name_vi":"Âu Dương Chấn Hoa","name_original":"Bobby Au-Yeung Tsan-Wah","tmdb_id":552085,"profile":"https://image.tmdb.org/t/p/w500/p1jQSMRoeKxz3Cl8Q4voDZb47mx.jpg","tmdb_url":"https://www.themoviedb.org/person/552085"},{"name":"Lisa Lui Yau-Wai","name_vi":null,"name_original":"Lisa Lui Yau-Wai","tmdb_id":1178955,"profile":"https://image.tmdb.org/t/p/w500/uoqoJmvFeIgQkMKBYy9G04IuclA.jpg","tmdb_url":"https://www.themoviedb.org/person/1178955"},{"name":"Mark Cheung Lui","name_vi":null,"name_original":"Mark Cheung Lui","tmdb_id":1417961,"profile":"https://image.tmdb.org/t/p/w500/qSYj6r8lExfXCu6woOLjToewifN.jpg","tmdb_url":"https://www.themoviedb.org/person/1417961"},{"name":"Lưu Thanh Vân","name_vi":"Lưu Thanh Vân","name_original":"Sean Lau Ching-wan","tmdb_id":940339,"profile":"http