ê để tang anh. Về sau, Triệu Vân tìm Lưu Bị tại Nghiệp Thành và theo phò tá từ đó.","tmdb":{"type":"tv","id":"75021","season":1,"vote_average":6.5,"vote_count":6},"modified":"2024-04-14T09:35:34.000Z","cast":["Lâm Canh Tân","Yoona","Kim Jeong-hoon","Giả Thanh","Godfrey Gao","Guo Dongdong","Mạnh Tử Nghĩa","Cổ Lực Na Trát","Nghiêm Ngật Khoan","Triệu Hàn Anh Tử","Fan Yulin","Trâu Triệu Long"],"director":["Li dong Cheng","Guo Jianyong"],"cast_meta":[{"name":"Lâm Canh Tân","name_vi":"Lâm Canh Tân","name_original":"Lin Gengxin","tmdb_id":1254211,"profile":"https://image.tmdb.org/t/p/w500/71pkSNjj7SUjDkW05sJSiqDgOOn.jpg","tmdb_url":"https://www.themoviedb.org/person/1254211"},{"name":"Yoona","name_vi":null,"name_original":"Yoona","tmdb_id":1252045,"profile":"https://image.tmdb.org/t/p/w500/JzAuAv17bWkLxVtfi9YJvQJhZl.jpg","tmdb_url":"https://www.themoviedb.org/person/1252045"},{"name":"Kim Jeong-hoon","name_vi":null,"name_original":"Kim Jeong-hoon","tmdb_id":1238642,"profile":"https://image.tmdb.org/t/p/w500/t6cSqUwylijdZ6ijPxPXVoRyWo3.jpg","tmdb_url":"https://www.themoviedb.org/person/1238642"},{"name":"Giả Thanh","name_vi":"Giả Thanh","name_original":"Jia Qing","tmdb_id":936435,"profile":"https://image.tmdb.org/t/p/w500/lfKwMwlTBTD6UD6ouP3gcroLCBd.jpg","tmdb_url":"https://www.themoviedb.org/person/936435"},{"name":"Godfrey Gao","name_vi":null,"name_original":"Godfrey Gao","tmdb_id":1192915,"profile":"https://image.tmdb.org/t/p/w500/lLlFkccxrmn0YeKoFw4BQtz5dIP.jpg","tmdb_url":"https://www.themoviedb.org/person/1192915"},{"name":"Guo Dongdong","name_vi":null,"name_original":"Guo Dongdong","tmdb_id":2979666,"profile":"https://image.tmdb.org/t/p/w500/oqXfO9AKKuURdyJp1eYZ9wRd0sl.jpg","tmdb_url":"https://www.themoviedb.org/person/2979666"},{"name":"Mạnh Tử Nghĩa","name_vi":"Mạnh Tử Nghĩa","name_original":"Meng Ziyi","tmdb_id":2128468,"profile":"https://image.tmdb.org/t/p/w500/R1cfuT9TQ2Xc7hsQHWzbzN0sbA.jpg","tmdb_url":"https://www.themoviedb.org/person/2128468"},{"name":"Cổ Lực Na Trát","name_vi":"Cổ Lực Na Trát","name_original":"Gulnezer Bextiyar","tmdb_id":1291460,"profile":"https://image.tmdb.org/t/p/w500/9HZkWl3glcA56J1rWlMU1TKh71q.jpg","tmdb_url":"https://www.themoviedb.org/person/1291460"},{"name":"Nghiêm Ngật Khoan","name_vi":"Nghiêm Ngật Khoan","name_original":"Kevin Yan","tmdb_id":1407599,"profile":"https://image.tmdb.org/t/p/w500/oCUiTeAnwmjc0tof4SFziOExIK7.jpg","tmdb_url":"https://www.themoviedb.org/person/1407599"},{"name":"Triệu Hàn Anh Tử","name_vi":"Triệu Hàn Anh Tử","name_original":"Zhao Yingzi","tmdb_id":2062754,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/2062754"},{"name":"Fan Yulin","name_vi":null,"name_original":"Fan Yulin","tmdb_id":2502601,"profile":"https://image.tmdb.org/t/p/w500/m8CpWRqz3ZB6YcVgIGmwZLD0SBB.jpg","tmdb_url":"https://www.themoviedb.org/person/2502601"},{"name":"Trâu Triệu Long","name_vi":"Trâu Triệu Long","name_original":"Collin Chou","tmdb_id":52908,"profile":"https://image.tmdb.org/t/p/w500/uUZ60sZTVhinijIPORMSCwIt0eg.jpg","tmdb_url":"https://www.themoviedb.org/person/52908"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/vo/vo-than-trieu-tu-long.json"}