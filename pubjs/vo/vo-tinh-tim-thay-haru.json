5bf7e361197a5adb20faa212","link_m3u8":"https://vip.opstream10.com/20220427/10790_e707fabd/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream10.com/share/ec3183a7f107d1b8dbb90cb3c01ea7d5","link_m3u8":"https://vip.opstream10.com/20220427/10791_66408899/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream10.com/share/5fd7cbbc45010f147c06926c44aff0b7","link_m3u8":"https://vip.opstream10.com/20220427/10796_58bec792/index.m3u8"}]}],"description":"<p>Vô Tình Tìm Thấy Haru - Extraordinary You xoay quanh cô nàng Eun Dan O, được sinh ra trong gia đình giàu có, học tại ngôi trường danh giá nhưng cô lại bị bệnh tim. Cô còn có vị hôn phu là Baek Kyung, nhưng anh ta luôn ghét cô. Cô thỉnh thoảng lại bị mất trí nhớ và phát hiện mình đang sống trong truyện tranh nhưng cô lại là nhân vật phụ, và không còn nhiều thời gian nữa là cô sẽ tan biến. Vì thế cô đã tìm kiếm một người có thể giúp được mình trong thế giới này là anh chàng cùng lớp điển trai, và Dan O đã đặt tên anh là Haru. Từ đây cả hai đã cùng nhau thay đổi câu chuyện và nhanh chóng kết thúc nó, không những vậy còn tạo nên câu chuyện tình yêu của riêng mình.</p>","tmdb_id":93657,"cast":["Kim Hye-yoon","Rowoon","Lee Jae-wook","Lee Na-eun","Jung Gun-joo","Kim Young-dae","Lee Tae-ri","Kim Ji-in","Kim Hyeon-mok","Han Chae-kyung","Kim Tae-jeong","Heo Soo-bin","Oh Gi-gwang","Jung Dae-ro","Jung Ji-hyeon"],"director":["Kim Sang-hyeob"],"keywords":[],"tmdb":{"type":"tv","id":"93657","season":1,"vote_average":8.1,"vote_count":197},"cast_meta":[{"name":"Kim Hye-yoon","name_vi":null,"name_original":"Kim Hye-yoon","tmdb_id":2214888,"profile":"https://image.tmdb.org/t/p/w500/ujFBbc3d0UdS4qeioxvO3xRLkdl.jpg","tmdb_url":"https://www.themoviedb.org/person/2214888"},{"name":"Rowoon","name_vi":null,"name_original":"Rowoon","tmdb_id":1613836,"profile":"https://image.tmdb.org/t/p/w500/sWf7wAG4upRgIkWuDfNvUog1UHc.jpg","tmdb_url":"https://www.themoviedb.org/person/1613836"},{"name":"Lee Jae-wook","name_vi"