t.com/share/ec049f278b41470dd0e9ecc9369fc327","link_m3u8":"https://vip.opstream-short.com/20251112/25491_ec049f27/index.m3u8"},{"name":"102","slug":"102","link_embed":"https://vip.opstream-short.com/share/fa61ea37615d26befa7a928b1ffce806","link_m3u8":"https://vip.opstream-short.com/20251112/25492_fa61ea37/index.m3u8"},{"name":"103","slug":"103","link_embed":"https://vip.opstream-short.com/share/8eedf769a83524a00a200373ce900374","link_m3u8":"https://vip.opstream-short.com/20251112/25493_8eedf769/index.m3u8"},{"name":"104","slug":"104","link_embed":"https://vip.opstream-short.com/share/a212e4d731db9b299ac7b07c1b68fcda","link_m3u8":"https://vip.opstream-short.com/20251112/25494_a212e4d7/index.m3u8"}]}],"description":"<p>Lưu Hiên sử dụng trò chơi có tên 'Game Giao Dịch Chồng May Mắn' để chiếm được trái tim Lý Mặc Phi, cô gái anh yêu được ba năm. Hệ thống cho phép anh giao nhiệm vụ hàng ngày như mang bữa sáng, đi tắm suối nóng. Mỗi nhiệm vụ hoàn thành sẽ tăng điểm quyến rũ và mở khóa phần thưởng như da trắng hơn, tài năng ca hát. Theo thời gian, Lưu Hiên có được tình yêu và thành công lớn trong sự nghiệp, thậm chí giành giải Nobel Hòa bình. Câu chuyện chứng minh vợ anh thực sự mang lại may mắn phi thường.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/vo/vo-toi-qua-mang-lai-may-man-short-drama.json"}