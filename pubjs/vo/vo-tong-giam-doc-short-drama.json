/index.m3u8"},{"name":"72","slug":"72","link_embed":"https://vip.opstream-short.com/share/ec217345c687eb83217574d4dccd5551","link_m3u8":"https://vip.opstream-short.com/20251117/31107_ec217345/index.m3u8"},{"name":"73","slug":"73","link_embed":"https://vip.opstream-short.com/share/0251a15528768526c59c138f85525aa8","link_m3u8":"https://vip.opstream-short.com/20251117/31108_0251a155/index.m3u8"},{"name":"74","slug":"74","link_embed":"https://vip.opstream-short.com/share/f16805d9fc37f021a682d86ab3013bb7","link_m3u8":"https://vip.opstream-short.com/20251117/31109_f16805d9/index.m3u8"},{"name":"75","slug":"75","link_embed":"https://vip.opstream-short.com/share/482adb7cad038f014bf906602b347b4c","link_m3u8":"https://vip.opstream-short.com/20251117/31110_482adb7c/index.m3u8"}]}],"description":"<p>Lâm Dương là một nhân viên giao hàng bình thường đang vật lộn với tiền thuê nhà nợ, chi phí y tế của mẹ và những lời phiền trách liên tục từ khách hàng. Cuộc sống anh thay đổi khi nhận được đơn hàng đặc biệt từ Hoàng Thiến, một nữ tổng giám đốc kiêu ngạo và lạnh lùng khiến anh phải chờ đợi hàng giờ. Khi cuối cùng gặp được, cô ta yêu cầu Lâm Dương mang bánh lên tầng, nhưng Lâm Dương từ chối nhượng bộ thái độ của cô. Trong lúc cãi vã, anh nhìn thấy Trần Thi Vũ, một cô gái giàu có đang trốn chạy khỏi cuộc hôn nhân sắp đặt, bị bọn côn đồ đường phố rượt đuổi. Lâm Dương dũng cảm giúp đỡ cô, và cô ấy đã yêu anh từ cái nhìn đầu tiên. Trong khi đó, dù có thái độ kiêu ngạo, tổng giám đốc Hoàng Thiến cũng là một bà mẹ đơn thân bị thu hút bởi sự chính trực của Lâm Dương và cân nhắc việc để anh làm cha của con mình. Giờ đây hai người phụ nữ rất khác nhau - một tổng giám đốc độc đoán và một tiểu thư nhà giàu - đang cạnh tranh vì cùng một người đàn ông. Lâm Dương phải lựa chọn giữa họ khi cuộc sống bình thường của anh có bước ngoặt phi thường.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/vo/vo-tong-giam-doc-short-drama.json","tmdb_checked":false}