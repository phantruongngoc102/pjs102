eam16.com/share/ccdf2c69fadaa5127cbd0c0a7feac280","link_m3u8":"https://vip.opstream16.com/20230417/34035_dca8d822/index.m3u8"}]}],"description":"<p>Nội dung của phim <strong>Vòng Lửa Hoa Hồng</strong> tập trung vào Hải Triều (Ôn Bích Hà), một cô gái xinh đẹp với ý chí kiên cường, luôn sống tích cực và yêu đời. Từ nhỏ đã là một cô nhi nên cô chỉ có thể tâm sự với người nhận nuôi là Phương Hữu Vi thông qua thư từ mà chưa bao giờ gặp mặt. Một ngày nọ, cô gặp lại được mẹ ruột của mình, lúc này Hải Triều mới hay Kiều Vĩnh Phát là người đã khiến gia đình của cô tan rã. Kể từ đó, cô bắt đầu lên kế hoạch trả thù và việc đầu tiên cô làm chính là quyết định chia tay với người yêu Kiều Lập và cặp với người con trai thứ 3 của Phát là Kiều Lịch mặc dù cô còn rất yêu Vi.</p><p><br>&nbsp;</p>","tmdb_id":89723,"cast":["Ôn Bích Hà","Ôn Triệu Luân","La Gia Lương","Bao Fang","Cary Choi","Ga-Bo Tsui","Doãn Dương Minh","Wong Wai"],"director":["Đang cập nhật"],"keywords":[],"tmdb":{"type":"tv","id":"89723","season":1,"vote_average":8,"vote_count":3},"cast_meta":[{"name":"Ôn Bích Hà","name_vi":"Ôn Bích Hà","name_original":"Irene Wan","tmdb_id":227780,"profile":"https://image.tmdb.org/t/p/w500/rmiDWTjYQMkeBjGNKzJJzMkSeDQ.jpg","tmdb_url":"https://www.themoviedb.org/person/227780"},{"name":"Ôn Triệu Luân","name_vi":"Ôn Triệu Luân","name_original":"Deric Wan","tmdb_id":1090949,"profile":"https://image.tmdb.org/t/p/w500/8G36AAt6fAS4CupaFKYnDNFsBtX.jpg","tmdb_url":"https://www.themoviedb.org/person/1090949"},{"name":"La Gia Lương","name_vi":"La Gia Lương","name_original":"Gallen Lo Ka-Leung","tmdb_id":1223043,"profile":"https://image.tmdb.org/t/p/w500/6ZCTOMeRktYL7iTEz7lg7N3XXPc.jpg","tmdb_url":"https://www.themoviedb.org/person/1223043"},{"name":"Bao Fang","name_vi":null,"name_original":"Bao Fang","tmdb_id":1191925,"profile":"https://image.tmdb.org/t/p/w500/rWbJLwyjpWm4eQPgso798ia3Kpj.jpg","tmdb_url":"https://www.themoviedb.org/person/1191925"},{"name":"Cary Choi","name_vi":null,"name_original