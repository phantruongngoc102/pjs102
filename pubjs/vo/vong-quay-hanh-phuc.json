4766182313b6775d","link_m3u8":"https://vip.opstream11.com/20220403/9064_d653fe1d/index.m3u8"},{"name":"41","slug":"41","link_embed":"https://vip.opstream11.com/share/b9b72b29352f3764ea4dec130772bd9d","link_m3u8":"https://vip.opstream11.com/20220403/9065_fc685353/index.m3u8"},{"name":"42","slug":"42","link_embed":"https://vip.opstream11.com/share/8a47481ae534860850adf59f145e6b40","link_m3u8":"https://vip.opstream11.com/20220403/9069_ef3c7dfb/index.m3u8"},{"name":"43","slug":"43","link_embed":"https://vip.opstream11.com/share/5f5d472067f77b5c88f69f1bcfda1e08","link_m3u8":"https://vip.opstream11.com/20220403/9068_f902a352/index.m3u8"},{"name":"44","slug":"44","link_embed":"https://vip.opstream11.com/share/74c4481c34e417ac39d1de6b4f854c4f","link_m3u8":"https://vip.opstream11.com/20220403/9067_da825646/index.m3u8"},{"name":"45","slug":"45","link_embed":"https://vip.opstream11.com/share/79d37fb2893b428f7ea4ed3b07a84096","link_m3u8":"https://vip.opstream11.com/20220403/9066_fc18d2ac/index.m3u8"},{"name":"46","slug":"46","link_embed":"https://vip.opstream11.com/share/7806689d934e610d660caf5536fea0b2","link_m3u8":"https://vip.opstream11.com/20220403/9070_2b236fdd/index.m3u8"}]}],"description":"<p>Bộ phim được chuyển thể từ tiểu thuyết cùng tên, tình tiết trong bộ phim này đã phản ánh lên rất nhiều hiện thực, thậm chí những vấn đề về hỗ trợ dành cho người già. Phim kể về cô gái giỏi giang Tô Minh Ngọc, không được gia đình yêu thương, lớn lên trong sự ghẻ lạnh, bất công của gia đình từ đó trưởng thành đi qua mọi khoảnh khắc cô độc, khó khăn của cuộc đời. Mọi chuyện tưởng chừng cứ tiếp diễn như thế, cho đến ngày người mẹ là Triệu Mĩ Lan qua đời, ba anh em Tô Minh Triết, Tô Minh Thành và Tô Minh Ngọc phải thay nhau chăm sóc cha Tô Đại Cường. Mọi người buộc phải tìm cách để dung hòa các mối quan hệ, để cùng chung sống. Nội dung đề cập đến vấn đề trọng nam khinh nữ vốn đã ăn sâu vào xã hội Trung Quốc nói riêng và châu Á nói chung. Vì vậy, phim dễ dàng nhận được sự đồng cảm và quan tâm của khán giả. Nội dung sâu sắc, diễn xuất xuất thần của dàn diễn viên là điểm nhấn nổi bật của tác phẩm trên.</p>","tmdb_id":89864,"cast":["Lưu Đào","Yang Shuo","Kim Thần","Lưu Đoan Đoan"],"director":["Xuesong Liu"],"keywords":[],"tmdb":{"type":"tv","id":"89864","season":1,"vote_average":6.667,"vote_count":3},"cast_meta":[{"name":"Lưu Đào","name_vi":"Lưu Đào","name_original":"Liu Tao","tmdb_id":1236264,"profile":"https://image.tmdb.org/t/p/w500/gcaeonDiNJyZ9bLIh23ds3TAzeA.jpg","tmdb_url":"https://www.themoviedb.org/person/1236264"},{"name":"Yang Shuo","name_vi":null,"name_original":"Yang Shuo","tmdb_id":1924106,"profile":"https://image.tmdb.org/t/p/w500/bUCUr6k7noDNyMWC637xg1lnRPx.jpg","tmdb_url":"https://www.themoviedb.org/person/1924106"},{"name":"Kim Thần","name_vi":"Kim Thần","name_original":"Jin Chen","tmdb_id":1541648,"profile":"https://image.tmdb.org/t/p/w500/wVsQG1eNFFmCI3HTaje4Rox8SFA.jpg","tmdb_url":"https://www.themoviedb.org/person/1541648"},{"name":"Lưu Đoan Đoan","name_vi":"Lưu Đoan Đoan","name_original":"Liu Duanduan","tmdb_id":2610694,"profile":"https://image.tmdb.org/t/p/w500/9f839TXRckHQnMckQuZbxej77go.jpg","tmdb_url":"https://www.themoviedb.org/person/2610694"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/vo/vong-quay-hanh-phuc.json"}