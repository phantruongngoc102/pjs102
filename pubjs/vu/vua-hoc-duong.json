 nhau xảy ra.</p>","tmdb":{"type":"tv","id":"61543","season":1,"vote_average":7.433,"vote_count":15},"modified":"2024-10-12T10:35:49.000Z","cast":["Seo In-guk","Lee Ha-na","Lee Soo-hyuk","Lee Tae-hwan","Kang Ki-young","Lee Yul-eum","Oh Kwang-rok","Kwon Seong-deok","Cho Han-cheul","Kim Won-hae","Park Soo-young","Lee Ju-seung","Shin Hye-sun","Phillip Choi","Song Young-gyu"],"director":["Yoo Je Won"],"cast_meta":[{"name":"Seo In-guk","name_vi":null,"name_original":"Seo In-guk","tmdb_id":1255411,"profile":"https://image.tmdb.org/t/p/w500/qXsdm6uDD3Je6JW9VfgCdg4FqYq.jpg","tmdb_url":"https://www.themoviedb.org/person/1255411"},{"name":"Lee Ha-na","name_vi":null,"name_original":"Lee Ha-na","tmdb_id":125076,"profile":"https://image.tmdb.org/t/p/w500/1udSVtstHfaPhWO47iEGsSay38v.jpg","tmdb_url":"https://www.themoviedb.org/person/125076"},{"name":"Lee Soo-hyuk","name_vi":null,"name_original":"Lee Soo-hyuk","tmdb_id":1257624,"profile":"https://image.tmdb.org/t/p/w500/drqY2KOm6kcESbVPSNnOj4oa27b.jpg","tmdb_url":"https://www.themoviedb.org/person/1257624"},{"name":"Lee Tae-hwan","name_vi":null,"name_original":"Lee Tae-hwan","tmdb_id":1407750,"profile":"https://image.tmdb.org/t/p/w500/gG3aMwf9OX6eqEtMUODlKU5MqtR.jpg","tmdb_url":"https://www.themoviedb.org/person/1407750"},{"name":"Kang Ki-young","name_vi":null,"name_original":"Kang Ki-young","tmdb_id":1648169,"profile":"https://image.tmdb.org/t/p/w500/bZKB6fXWS7mBWoOBsXlLx0P36hJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1648169"},{"name":"Lee Yul-eum","name_vi":null,"name_original":"Lee Yul-eum","tmdb_id":1467384,"profile":"https://image.tmdb.org/t/p/w500/1ia6C3jIPBdQ21LmuW5ZPSr8kXC.jpg","tmdb_url":"https://www.themoviedb.org/person/1467384"},{"name":"Oh Kwang-rok","name_vi":null,"name_original":"Oh Kwang-rok","tmdb_id":528339,"profile":"https://image.tmdb.org/t/p/w500/t7Yltcz3OFproWSWcPLav61LgK0.jpg","tmdb_url":"https://www.themoviedb.org/person/528339"},{"name":"Kwon Seong-deok","name_vi":null,"name_original":"Kwon Seon