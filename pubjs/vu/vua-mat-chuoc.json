{"id":"683a7e5e743fbee271896d13","title":"Vua Mạt Chược","origin_name":"King of Mahjong","slug":"vua-mat-chuoc","thumb":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/thumbs/vu/vua-mat-chuoc.webp","poster":"https://cdn.jsdelivr.net/gh/phantruongngoc102/goimg102@main/public/posters/vu/vua-mat-chuoc.webp","year":2015,"type":"single","genre":[{"id":"620a221de0fc277084dfd1c1","name":"Hài Hước","slug":"hai-huoc"}],"country":[{"id":"62093063196e9f4ab6b448b8","name":"Trung Quốc","slug":"trung-quoc"},{"id":"620a2335e0fc277084dfd822","name":"Đài Loan","slug":"dai-loan"},{"id":"620a2347e0fc277084dfd876","name":"Hồng Kông","slug":"hong-kong"},{"id":"62159af71f1609c9d934824e","name":"Malaysia","slug":"malaysia"},{"id":"644f3b0ed95ac616c32b79ee","name":"Singapore","slug":"singapore"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"Vua Mạt Chược - Tập Full","link_embed":"https://vip.opstream16.com/share/9048aba49cde23c37ed446f1881d8b90","link_m3u8":"https://vip.opstream16.com/20250530/43365_9048aba4/index.m3u8"}]}],"time":"110 Phút","description":"<p>King of Mahjong tập trung vào mối thù kéo dài hàng thập kỷ và cuộc hội ngộ cuối cùng của Wong Tin Ba và Ah Fatt. 20 năm sau, Wong Tin Ba, hiện là nhà vô địch mạt chược và ông trùm được ca ngợi trên toàn thế giới, xuất hiện ở Ipoh để thách đấu Fatt trong trận chiến cuối cùng - Giải vô địch mạt chược thế giới. Bất chấp sự khăng khăng của Wong, Fatt từ chối tham gia cuộc thi vì anh quyết tâm và hài lòng với cuộc sống của một thường dân. Trong nỗ lực buộc Fatt phải tham gia trận chiến, Wong bắt cóc vợ của Fatt, Ramona, và đe dọa cô sẽ tham gia liên minh của anh. Fatt không còn lựa chọn nào khác ngoài việc tham gia giải vô địch khi Wong bắt vợ anh làm con tin. Trên bàn mạt chược, Fatt và Wong cạnh tranh với tư cách là những người vào chung kết; nước đi mạt chược huyền thoại bí mật của Master Ru và sự thật được đưa ra ánh sáng khi người chiến thắng xuất hiện...</p>","tmdb":{"type":"movie","id":"341777","season":null,"vote_average":5.7,"vote_count":3},"modified":"2025-05-31T10:58:22.000Z","cast":["Đỗ Vấn Trạch","Mark Lee","Diệp Tuyền","Vương Mẫn Dịch","Adrian Tan","Cheronna Ng","Richard Low","Patricia Mok","Dennis Chew","Tăng Chí Vĩ","Lư Hải Bằng","Susan Shaw Yam-Yam","Mimi Chu Mai-Mai","Uyển Quỳnh Đan","Hayley Woo"],"director":["Adrian Teh"],"cast_meta":[{"name":"Đỗ Vấn Trạch","name_vi":"Đỗ Vấn Trạch","name_original":"Chapman To Man-Chat","tmdb_id":118742,"profile":"https://image.tmdb.org/t/p/w500/deb2iBGpzwvkEwlTvLA3rX2HOiY.jpg","tmdb_url":"https://www.themoviedb.org/person/118742"},{"name":"Mark Lee","name_vi":null,"name_original":"Mark Lee","tmdb_id":570522,"profile":"https://image.tmdb.org/t/p/w500/9HlO3yUCaW4wClB6245MAamjc4D.jpg","tmdb_url":"https://www.themoviedb.org/person/570522"},{"name":"Diệp Tuyền","name_vi":"Diệp Tuyền","name_original":"Michelle Ye Xuan","tmdb_id":93990,"profile":"https://image.tmdb.org/t/p/w500/9mUtU7rYbYYEBytDv98tXHTGVrN.jpg","tmdb_url":"https://www.themoviedb.org/person/93990"},{"name":"Vương Mẫn Dịch","name_vi":"Vương Mẫn Dịch","name_original":"Venus Wong Man-Yik","tmdb_id":937492,"profile":"https://image.tmdb.org/t/p/w500/ySEEfNsEIFj8mPb84lnyVVbfSB0.jpg","tmdb_url":"https://www.themoviedb.org/person/937492"},{"name":"Adrian Tan","name_vi":null,"name_original":"Adrian Tan","tmdb_id":135809,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/135809"},{"name":"Cheronna Ng","name_vi":null,"name_original":"Cheronna Ng","tmdb_id":1470569,"profile":"https://image.tmdb.org/t/p/w500/zAeni6WGr1WmrbUTEG0IItM1ue6.jpg","tmdb_url":"https://www.themoviedb.org/person/1470569"},{"name":"Richard Low","name_vi":null,"name_original":"Richard Low","tmdb_id":225059,"profile":"https://image.tmdb.org/t/p/w500/lWyJPDSnHvVGGyU5o4HZcfI