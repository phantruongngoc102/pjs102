,"filename":"The Youth Memories EP33","link_embed":"https://vip.opstream14.com/share/ca75de9a5fde50bc6a0ba910b1b1d908","link_m3u8":"https://vip.opstream14.com/20230616/37893_3e53b525/index.m3u8"},{"name":"34","slug":"34","filename":"The Youth Memories EP34","link_embed":"https://vip.opstream14.com/share/28ccee6fd479a8719fa96fc5a959362f","link_m3u8":"https://vip.opstream14.com/20230616/37894_1e8c4540/index.m3u8"},{"name":"35","slug":"35","filename":"The Youth Memories EP35","link_embed":"https://vip.opstream15.com/share/a8a2ab1b683dd9cfe2de7ff7522cdf7a","link_m3u8":"https://vip.opstream15.com/20230617/39899_c02c501c/index.m3u8"},{"name":"36","slug":"36","filename":"The Youth Memories EP36","link_embed":"https://vip.opstream15.com/share/be8f254ef25c5a40ac8b395ed4fc6033","link_m3u8":"https://vip.opstream15.com/20230617/39900_9dd1c274/index.m3u8"},{"name":"37","slug":"37","filename":"The Youth Memories EP37","link_embed":"https://vip.opstream15.com/share/13c5dfa246046c0beea97e100f32a1a9","link_m3u8":"https://vip.opstream15.com/20230618/39914_22857e4e/index.m3u8"},{"name":"38","slug":"38","filename":"The Youth Memories EP38","link_embed":"https://vip.opstream15.com/share/220d17b28d99d88de80afcdad211b06a","link_m3u8":"https://vip.opstream15.com/20230618/39915_8df9e0c9/index.m3u8"}]}],"time":"45 phút/tập","description":"Bộ phim lấy bối cảnh về những năm 70 ở Bắc Kinh, là câu chuyện sinh động về quá trình trưởng thành, phấn đấu, theo đuổi ước mơ của một nhóm người trẻ tuổi. Nhân vật chính cùng những người anh em tốt của mình phải trải qua nhiều giai đoạn phát triển trong cuộc đời như thi đại học, vào đời, xây dựng sự nghiệp, ra nước ngoài, bước chân vào quan trường... và cùng nhau tìm ra ý nghĩa của việc cố gắng phấn đấu trong quá trình giúp đỡ lẫn nhau đó. Các nhân vật nữ trong phim cũng phải trải qua đủ mọi gập ghềnh vất vả của cuộc đời, để thấy được những gắn kết đan xen trong vận mệnh đời nhau. Thông qua bối cảnh của cuộc cải cách mở cửa, bộ phim đã miêu tả rõ nét sự trưởng thành và phá kén của các nhân vật, để khắc họa sự phát triển nhanh chóng của đất nước, và thể hiện tình cảm đáng quý giữa người với người, truyền tải đi những nguồn năng lượng tích cực về ý chí vươn lên để phát triển lớn mạnh.","tmdb":{"type":"tv","id":"157240","season":1,"vote_average":6.6,"vote_count":11},"modified":"2023-06-18T19:29:18.000Z","cast":["Tiêu Chiến","Lý Thấm","Zhao Xin","Lenox Lu","Thôi Hàng","Tào Phỉ Nhiên","Zhang Lingxin","Lưu Nhuế Lân","Lưu Hoan"],"director":["Fu Ning"],"cast_meta":[{"name":"Tiêu Chiến","name_vi":"Tiêu Chiến","name_original":"Xiao Zhan","tmdb_id":2084790,"profile":"https://image.tmdb.org/t/p/w500/468n73j2sSJIbfZvsIZvDpvUaS8.jpg","tmdb_url":"https://www.themoviedb.org/person/2084790"},{"name":"Lý Thấm","name_vi":"Lý Thấm","name_original":"Li Qin","tmdb_id":568304,"profile":"https://image.tmdb.org/t/p/w500/thak4pt7jCPbl2xx5HnFhkEE0Tu.jpg","tmdb_url":"https://www.themoviedb.org/person/568304"},{"name":"Zhao Xin","name_vi":null,"name_original":"Zhao Xin","tmdb_id":3156163,"profile":"https://image.tmdb.org/t/p/w500/iLqo4VggpCC7ZK0ngU0H7sfU7sQ.jpg","tmdb_url":"https://www.themoviedb.org/person/3156163"},{"name":"Lenox Lu","name_vi":null,"name_original":"Lenox Lu","tmdb_id":1623183,"profile":"https://image.tmdb.org/t/p/w500/zl5B70VsqIXNsbSOJZhaADiBCBQ.jpg","tmdb_url":"https://www.themoviedb.org/person/1623183"},{"name":"Thôi Hàng","name_vi":"Thôi Hàng","name_original":"Cui Hang","tmdb_id":3157396,"profile":"https://image.tmdb.org/t/p/w500/T3nKzkRohNd4SWGNlEEmTSunn9.jpg","tmdb_url":"https://www.themoviedb.org/person/3157396"},{"name":"Tào Phỉ Nhiên","name_vi":"Tào Phỉ Nhiên","name_original":"Cao Feiran","tmdb_id":3278808,"profile":"https://image.tmdb.org/t/p/w500/pNWkUCshzAP6PM0TymRHL81XbQX.jpg","tmdb_url":"https://www.themoviedb.org/person/3278808"},{"name":"Zhang Lingxin","name_vi":null,"name_original":"Zhang Lingxin","tmdb_id":2314448,"profile":"https://image.tmdb.org/t/p/w500/c7W6C2GLcvsAFqcjIEg1SPm51hm.jpg","tmdb_url":"https://w