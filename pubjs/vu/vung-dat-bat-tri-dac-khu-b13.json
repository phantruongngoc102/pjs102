m, cũng như những bí mật của quận 13...</p>","tmdb":{"type":"movie","id":"10045","season":null,"vote_average":6.806,"vote_count":1944},"modified":"2022-06-18T18:04:00.000Z","cast":["David Belle","Cyril Raffaelli","Tony D'Amario","Dany Verissimo-Petit","Bibi Naceri","Nicolas Woirion","François Chattot","Patrick Olivier","Samir Guesmi","Azad","Turan Bagci","Ludovic Berthillot","Tarik Boucekhine","Grégory Jean","Warren Zavatta"],"director":["Pierre Morel"],"cast_meta":[{"name":"David Belle","name_vi":null,"name_original":"David Belle","tmdb_id":62439,"profile":"https://image.tmdb.org/t/p/w500/1Q6a9NUPE2MPNThLJK5WaY64lro.jpg","tmdb_url":"https://www.themoviedb.org/person/62439"},{"name":"Cyril Raffaelli","name_vi":null,"name_original":"Cyril Raffaelli","tmdb_id":21946,"profile":"https://image.tmdb.org/t/p/w500/lgD5pUltRnirh6WsyQ6Du1jmi7w.jpg","tmdb_url":"https://www.themoviedb.org/person/21946"},{"name":"Tony D'Amario","name_vi":null,"name_original":"Tony D'Amario","tmdb_id":62441,"profile":"https://image.tmdb.org/t/p/w500/mnTawMTQjo5vrwNPmHuJJcubLmw.jpg","tmdb_url":"https://www.themoviedb.org/person/62441"},{"name":"Dany Verissimo-Petit","name_vi":null,"name_original":"Dany Verissimo-Petit","tmdb_id":62443,"profile":"https://image.tmdb.org/t/p/w500/sOIdcNgqOciiByAhOSejtK5dMIZ.jpg","tmdb_url":"https://www.themoviedb.org/person/62443"},{"name":"Bibi Naceri","name_vi":null,"name_original":"Bibi Naceri","tmdb_id":62442,"profile":"https://image.tmdb.org/t/p/w500/7VgVz4gKlrnrJxPYriOUOFtp5wq.jpg","tmdb_url":"https://www.themoviedb.org/person/62442"},{"name":"Nicolas Woirion","name_vi":null,"name_original":"Nicolas Woirion","tmdb_id":62445,"profile":"https://image.tmdb.org/t/p/w500/hqhTF6GDVV8Eg6elB2cWDl4o70p.jpg","tmdb_url":"https://www.themoviedb.org/person/62445"},{"name":"François Chattot","name_vi":null,"name_original":"François Chattot","tmdb_id":62444,"profile":"https://image.tmdb.org/t/p/w500/yexQlUQ01hkLX4juhlFC8rbbmMV.jpg","tmdb_url":"https://www.themoviedb.org/perso