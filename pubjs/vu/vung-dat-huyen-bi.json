":"https://vip.opstream16.com/20220827/21710_a54158b6/index.m3u8"},{"name":"32","slug":"32","filename":"vung-dat-huyen-bi-or-phu-de-tap-32","link_embed":"https://vip.opstream16.com/share/1d73ce2a7a702db385aa9056c7a0ff13","link_m3u8":"https://vip.opstream16.com/20220827/21711_e974600c/index.m3u8"}]}],"time":"45 phút/tập","description":"<p><strong>xoay quanh cô gái xinh đẹp giàu có tên là Pim, vì muốn chữa bệnh cho cha nên đã lên kế hoạch vào rừng Himmapan để tìm một loại thiên thạch đen quý hiếm. Khu rừng này không chỉ là “tử địa” mà còn tồn tại một thế giới huyền thoại song song với thế giới hiện thực. Pim phải thuyết phục và nhờ cậy đến sự giúp đỡ của Krit, một anh chàng thợ săn đã từng có trải nghiệm ở vùng đất có một không hai này. Kể từ đây, hai người bắt đầu đồng hành cùng nhau trong hành trình chinh phục rừng Himmapan đầy thử thách.</strong></p>","tmdb":{"type":"tv","id":"119841","season":1,"vote_average":10,"vote_count":1},"modified":"2022-08-27T03:23:11.000Z","cast":["Louis Scott","Matira Tantiprasut","Khunnarong Pratesrat","Saranya Jumpatip","Suriyont Arunwattanakul","Warit Tipgomut","Chartchai Ngamsan","Daraneenute Pasutanavin","Kirk Schiller","Jakkrit Amarat","Amena Gul","Boonthong Hanchanang","Pai Virasut Hiranbuth","New Narissan Lokavit","Ramida Prapasanobon"],"director":["Kui Taweewat Wanta"],"cast_meta":[{"name":"Louis Scott","name_vi":null,"name_original":"Louis Scott","tmdb_id":1123220,"profile":"https://image.tmdb.org/t/p/w500/zYuAz984TKSp7KWy8nwgGpNckTr.jpg","tmdb_url":"https://www.themoviedb.org/person/1123220"},{"name":"Matira Tantiprasut","name_vi":null,"name_original":"Matira Tantiprasut","tmdb_id":1342181,"profile":"https://image.tmdb.org/t/p/w500/o17sWZ9e98BovplTL7vEzC8xAaD.jpg","tmdb_url":"https://www.themoviedb.org/person/1342181"},{"name":"Khunnarong Pratesrat","name_vi":null,"name_original":"Khunnarong Pratesrat","tmdb_id":3215748,"profile":"https://image.tmdb.org/t/p/w500/3E8AQYKy2VJKRTcXp3rFMHhO2dz.jpg","tmdb_url":"https://www.themovie