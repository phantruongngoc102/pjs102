opstream10.com/share/05af5f0beb11c1a6fdf5983c4a243a0e","link_m3u8":"https://vip.opstream10.com/20251202/31573_05af5f0b/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream10.com/share/47c95199b010148056eda6ac6f961c63","link_m3u8":"https://vip.opstream10.com/20251205/31663_47c95199/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream10.com/share/3218b56a27cc5d3acdac4a6b99195f75","link_m3u8":"https://vip.opstream10.com/20251207/31691_3218b56a/index.m3u8"}]}],"description":"<p><strong>Phần 3 của Fire Country tiếp tục theo chân Bode Donovan, một tù nhân trẻ từng phạm sai lầm, muốn chuộc lỗi và giảm án bằng cách tham gia chương trình chữa cháy dành cho phạm nhân. Bắt đầu với vụ tai nạn máy bay trực thăng xảy ra ngay giữa hôn lễ của Diego&nbsp;và Gabriela (người có mối quan hệ mập mờ với Bode Donovan) vào cuối phần 2, gây ra hỗn loạn và bùng phát một đám cháy lớn, buộc đội lính cứu hỏa phải hành động ngay lập tức để cứu người và dập lửa. Trong phần này, xuất hiện các vụ cháy ngầm \"lửa xác sống\" (zombie fires) đầy nguy hiểm đe dọa nuốt chửng toàn bộ thị trấn, đặt nhóm cứu hỏa và các nhân vật vào thế căng thẳng cùng các thảm họa, nhiệm vụ chết chóc khác vào mỗi tập. Bode Donovan và đồng đội sẽ phải dùng mọi kinh nghiệm và sự dũng cảm để chống lại những thảm họa tự nhiên và nhân tạo. Phần 3 này tiếp tục giữ vững phong độ của loạt phim khi kết hợp hành động cứu hỏa cường độ cao với kịch tính gia đình, cá nhân sâu sắc và nhận được nhiều phản hồi đánh giá tích cực từ giới phê bình phim.</strong></p>","tmdb_id":202297,"cast":["Max Thieriot","Kevin Alejandro","Jordan Calloway","Jules Latimer","Diane Farr"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"202297","season":3,"vote_average":8.155,"vote_count":152},"cast_meta":[{"name":"Max Thieriot","name_vi":null,"name_original":"Max Thieriot","tmdb_id":41883,"profile":"https://image.tmdb.org/t/p/w500/aBiTMI3qB6FPOVhXw7b15pjJkmL.jpg","tmdb_url":"https://www.themoviedb.org/person/41883"