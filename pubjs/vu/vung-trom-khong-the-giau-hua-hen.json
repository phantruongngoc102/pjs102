.opstream90.com/20250702/8069_7cc5a754/index.m3u8"},{"name":"23","slug":"23","filename":"Vụng Trộm Không Thể Giấu - Hứa Hẹn - Tập23","link_embed":"https://vip.opstream90.com/share/d5c8e1ab6fc0bfeb5f29aafa999cdb29","link_m3u8":"https://vip.opstream90.com/20250702/8070_d5c8e1ab/index.m3u8"},{"name":"24","slug":"24","filename":"Vụng Trộm Không Thể Giấu - Hứa Hẹn - Tập24","link_embed":"https://vip.opstream90.com/share/82138b11a724b94d18df2e083d8b7b55","link_m3u8":"https://vip.opstream90.com/20250702/8071_82138b11/index.m3u8"}]}],"time":"11 phút/tập","description":"<p>Đoàn Gia Hứa và Tang Trĩ bén duyên từ một lần Tang Trĩ nhờ người đến trường họp phụ huynh. Từ đó, Đoàn Gia Hứa cũng coi Tang Trĩ như em gái ruột mà yêu thương hết lòng. Sau khi Đoàn Gia Hứa tốt nghiệp đại học, hai người xa cách hai nơi, lại vì một số hiểu lầm mà quan hệ trở nên xa cách. Mãi đến khi Tang Trĩ trưởng thành thi đậu vào thành phố Đoàn Gia Hứa đang ở như ước muốn, hai người mới gặp lại. Qua những lần tiếp xúc ngày càng thân mật, Tang Trĩ dần nhận ra nguồn cơn áp lực bấy lâu nay của Đoàn Gia Hứa. Cô muốn bảo vệ người anh trai luôn đối xử tốt với mình này, tình cảm thầm kín chôn giấu trong lòng lại bùng cháy. Dưới sự đồng hành của Tang Trĩ, Đoàn Gia Hứa dần cởi bỏ khúc mắc trong lòng, anh thật lòng yêu thích Tang Trĩ trưởng thành, mối tình thầm kín thuần khiết cuối cùng cũng đơm hoa kết trái, cùng nhau trải qua quá trình trưởng thành tuổi thanh xuân, khích lệ và giúp đỡ nhau.</p><p>&nbsp;</p>","tmdb":{"type":"tv","id":"294557","season":1,"vote_average":5,"vote_count":1},"modified":"2025-07-13T10:48:39.000Z","cast":["Morpheus Tian","Huang Panpan","Ma Zhe"],"director":["胡星"],"cast_meta":[{"name":"Morpheus Tian","name_vi":null,"name_original":"Morpheus Tian","tmdb_id":4215868,"profile":"https://image.tmdb.org/t/p/w500/9oAN1VVKjFBTjHvhYcsT2bPFfaV.jpg","tmdb_url":"https://www.themoviedb.org/person/4215868"},{"name":"Huang Panpan","name_vi":null,"name_original":"Huang Panpan","tmdb_id":5421017,"profile":