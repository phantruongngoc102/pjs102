ước ngoài. Bốn người vô tình trở thành bạn đồng hành. Trong một năm này, bốn người làm thêm ở rất nhiều nơi như nông trường, quán ăn, quán rượu, khu vui chơi.","tmdb":{"type":"tv","id":"242483","season":1,"vote_average":6,"vote_count":1},"modified":"2024-01-21T11:06:27.000Z","cast":["Trần Học Đông","Tống Dật","Xu Yang","Hàn Đồng Sinh","Wang Shuyi","Wang Jialin","Li Mengmeng","Tara Clance","Pan Ziyan","Yu Yonghai"],"director":["Gu Yunyun"],"cast_meta":[{"name":"Trần Học Đông","name_vi":"Trần Học Đông","name_original":"Chen Xuedong","tmdb_id":1193310,"profile":"https://image.tmdb.org/t/p/w500/pgzMLCxvpsh3CUto5Ag7vcx99PD.jpg","tmdb_url":"https://www.themoviedb.org/person/1193310"},{"name":"Tống Dật","name_vi":"Tống Dật","name_original":"Song Yi","tmdb_id":1877119,"profile":"https://image.tmdb.org/t/p/w500/10IcNNHWQ7WGktAcfDtClJnapUo.jpg","tmdb_url":"https://www.themoviedb.org/person/1877119"},{"name":"Xu Yang","name_vi":null,"name_original":"Xu Yang","tmdb_id":2713782,"profile":"https://image.tmdb.org/t/p/w500/oMFUVH7W3fpa4IhSJpg36pzVPD0.jpg","tmdb_url":"https://www.themoviedb.org/person/2713782"},{"name":"Hàn Đồng Sinh","name_vi":"Hàn Đồng Sinh","name_original":"Han Tongsheng","tmdb_id":1268918,"profile":"https://image.tmdb.org/t/p/w500/j4rUYKbzH1F6EFL6ukXeTMlsL8R.jpg","tmdb_url":"https://www.themoviedb.org/person/1268918"},{"name":"Wang Shuyi","name_vi":null,"name_original":"Wang Shuyi","tmdb_id":3212770,"profile":"https://image.tmdb.org/t/p/w500/8j0mCN12WosQSMKhrYnjSriJslO.jpg","tmdb_url":"https://www.themoviedb.org/person/3212770"},{"name":"Wang Jialin","name_vi":null,"name_original":"Wang Jialin","tmdb_id":4136752,"profile":"https://image.tmdb.org/t/p/w500/8UgFFfoyFIbx87h3Wgg10epyYIr.jpg","tmdb_url":"https://www.themoviedb.org/person/4136752"},{"name":"Li Mengmeng","name_vi":null,"name_original":"Li Mengmeng","tmdb_id":4453672,"profile":"https://image.tmdb.org/t/p/w500/5VSkeVLUN0wFv2wmrkR3LfwnDXU.jpg","tmdb_url":"https://www.themoviedb.org/person/4453672"},{"name"