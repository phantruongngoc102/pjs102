{"id":"68030336dcb71e2a11bb447f","title":"Vượt Ngục: Lần Cuối","origin_name":"Prison Break: The Final Break","slug":"vuot-nguc-lan-cuoi","thumb":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/thumbs/vu/vuot-nguc-lan-cuoi.webp","poster":"https://cdn.jsdelivr.net/gh/gotvtop102/goimg102@main/public/posters/vu/vuot-nguc-lan-cuoi.webp","year":2009,"type":"single","genre":[{"id":"620a21b2e0fc277084dfd0c5","name":"Hành Động","slug":"hanh-dong"},{"id":"620f3d2b91fa4af90ab697fe","name":"Chính kịch","slug":"chinh-kich"}],"country":[{"id":"620a231fe0fc277084dfd7ce","name":"Âu Mỹ","slug":"au-my"}],"lang_key":"Vietsub","episode_current":"Full","quality":"HD","is_4k":false,"is_exclusive":false,"status":"completed","showtimes":"","chieurap":false,"sub_docquyen":false,"episodes":[{"server_name":"Vietsub #1","is_ai":false,"server_data":[{"name":"Full","slug":"full","filename":"(Sub Viet) Prison.Break.the.Final.Break.2009.1080p.BluRay.x264.DTS-ADE","link_embed":"https://vip.opstream12.com/share/818a7cd413218993d9f871449f4e3321","link_m3u8":"https://vip.opstream12.com/20250420/27162_818a7cd4/index.m3u8"}]}],"time":"89 Phút","description":"Bộ phim Cuộc Vượt Ngục Cuối Cùng bắt đầu khi Sara bị bắt ngay trong đám cưới của cô với Michael vì bị tình nghi giết Christina Scofield. Tại nhà giam dành cho nữ, Sara quen một số tù nhân mới. Cô bị trận đòn phủ đầu của các quản giáo tại đây vì vụ vượt ngục tại nhà tù Fox River. Đối diện bên kia sân là nhà tù dành cho nam giới, nơi General Krantz và T-Bag bị giam giữ. Biết tin Sara bị bắt vào tù và đang bị giam tại nhà giam đối diện, Krantz trả 100.000 đô la để thuê người giết cô. Vậy là Sara bị đầu độc nhưng may mắn được chữa trị kịp thời. Vì đang mang thai nên cô bị buộc uống thuốc thúc sinh. Đó sẽ là cú sốc lớn với Sara. Trong lúc đó, Michael tìm hiểu về nhà tù và anh quyết định phải giải thoát Sara ra khỏi đó càng nhanh càng tốt. Và một lần nữa, anh tìm đến sự trợ giúp của Lincoln và Sucre. Đây sẽ là lần vượt ngục khó khăn và nguy hiểm hơn bao giờ hết. Liệu cuộc vượt ngục của họ có thành công hay không.","tmdb":{"type":"movie","id":"176241","season":null,"vote_average":7.5,"vote_count":698},"modified":"2025-04-20T22:04:30.000Z","cast":["Wentworth Miller","Sarah Wayne Callies","Dominic Purcell","Jodi Lyn O'Keefe","Amaury Nolasco","Robert Knepper","William Fichtner","Leon Russom","Amy Aquino","Lori Petty","Kim Coates","Barbara Eve Harris","Chris Bruno","David Starzyk","Aisha Hinds"],"director":["Brad Turner","Kevin Hooks"],"cast_meta":[{"name":"Wentworth Miller","name_vi":null,"name_original":"Wentworth Miller","tmdb_id":3972,"profile":"https://image.tmdb.org/t/p/w500/js09M98qo6rEyyIlTbRMI6XiZJH.jpg","tmdb_url":"https://www.themoviedb.org/person/3972"},{"name":"Sarah Wayne Callies","name_vi":null,"name_original":"Sarah Wayne Callies","tmdb_id":86468,"profile":"https://image.tmdb.org/t/p/w500/uBtFalxNR1O0eARg0lsyLXkoJNG.jpg","tmdb_url":"https://www.themoviedb.org/person/86468"},{"name":"Dominic Purcell","name_vi":null,"name_original":"Dominic Purcell","tmdb_id":10862,"profile":"https://image.tmdb.org/t/p/w500/5GtHSYdnH7o2x5UIm09XqqLoJKO.jpg","tmdb_url":"https://www.themoviedb.org/person/10862"},{"name":"Jodi Lyn O'Keefe","name_vi":null,"name_original":"Jodi Lyn O'Keefe","tmdb_id":58006,"profile":"https://image.tmdb.org/t/p/w500/5F9ESeRIlPrUbUcSYRvmNv6uPFU.jpg","tmdb_url":"https://www.themoviedb.org/person/58006"},{"name":"Amaury Nolasco","name_vi":null,"name_original":"Amaury Nolasco","tmdb_id":17341,"profile":"https://image.tmdb.org/t/p/w500/lziIeEQUtVSotC0qzIiYLWnjELn.jpg","tmdb_url":"https://www.themoviedb.org/person/17341"},{"name":"Robert Knepper","name_vi":null,"name_original":"Robert Knepper","tmdb_id":17343,"profile":"https://image.tmdb.org/t/p/w500/lRncjvgCIm1muIkK94zJSH2i3d6.jpg","tmdb_url":"https://www.themoviedb.org/person/17343"},{"name":"William Fichtner","name_vi":null,"name_original":"William Fichtner","tmdb_id":886,"profile":"https://image.tmdb.org/t/p/w500/wWtJOoaNAwPparpzMNuRBj