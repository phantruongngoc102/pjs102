 số tiền lớn được cất giấu cách đó khá lâu bởi một tù nhân khác. Alexander Mahone - Đặc vụ liên bang được giao nhiệm vụ truy tìm và bắt sống tám tên tù vượt ngục, nhưng bị phát hiện đang làm việc cho Hội Đồng Hành (The Company) - Hội Đồng Hành muốn 8 tên tù phải chết.</p>","tmdb":{"type":"tv","id":"2288","season":2,"vote_average":8.079,"vote_count":5664},"modified":"2022-12-18T11:33:52.000Z","cast":["Wentworth Miller","Dominic Purcell","Sarah Wayne Callies","Paul Adelstein","Rockmond Dunbar","Robert Knepper","Amaury Nolasco","Inbar Lavi","Augustus Prew","Mark Feuerstein","Said Bey"],"director":["Paul Scheuring"],"cast_meta":[{"name":"Wentworth Miller","name_vi":null,"name_original":"Wentworth Miller","tmdb_id":3972,"profile":"https://image.tmdb.org/t/p/w500/js09M98qo6rEyyIlTbRMI6XiZJH.jpg","tmdb_url":"https://www.themoviedb.org/person/3972"},{"name":"Dominic Purcell","name_vi":null,"name_original":"Dominic Purcell","tmdb_id":10862,"profile":"https://image.tmdb.org/t/p/w500/5GtHSYdnH7o2x5UIm09XqqLoJKO.jpg","tmdb_url":"https://www.themoviedb.org/person/10862"},{"name":"Sarah Wayne Callies","name_vi":null,"name_original":"Sarah Wayne Callies","tmdb_id":86468,"profile":"https://image.tmdb.org/t/p/w500/uBtFalxNR1O0eARg0lsyLXkoJNG.jpg","tmdb_url":"https://www.themoviedb.org/person/86468"},{"name":"Paul Adelstein","name_vi":null,"name_original":"Paul Adelstein","tmdb_id":17342,"profile":"https://image.tmdb.org/t/p/w500/9qkGnEWPzGayZg9gaB4xbP8UL4g.jpg","tmdb_url":"https://www.themoviedb.org/person/17342"},{"name":"Rockmond Dunbar","name_vi":null,"name_original":"Rockmond Dunbar","tmdb_id":17345,"profile":"https://image.tmdb.org/t/p/w500/gim7zIrYkbKWsp2Kod7fp74fWyI.jpg","tmdb_url":"https://www.themoviedb.org/person/17345"},{"name":"Robert Knepper","name_vi":null,"name_original":"Robert Knepper","tmdb_id":17343,"profile":"https://image.tmdb.org/t/p/w500/lRncjvgCIm1muIkK94zJSH2i3d6.jpg","tmdb_url":"https://www.themoviedb.org/person/17343"},{"name":"Amaury Nolasco","name_vi":nu