ã tham gia vào các vụ án liên quan đến những tên tội phạm khét tiếng như Yoo Young Chul và Young Nam Gyu.</p>","tmdb_id":146102,"cast":["Kim Nam-gil","Kim So-jin","Jin Sun-kyu","Ryeoun","Lee Dae-yeon","Jung Soon-won","Kim Won-hae","Hong Woo-jin","Jo Young-jin","Lee Haney","Kim Hye-ok","Seo Dong-gab","Kong Seong-ha"],"director":[],"keywords":[],"cast_meta":[{"name":"Kim Nam-gil","name_vi":null,"name_original":"Kim Nam-gil","tmdb_id":110388,"profile":"https://image.tmdb.org/t/p/w500/jTMr4gpGMXfHZUeoPyaa2Rq9ZU4.jpg","tmdb_url":"https://www.themoviedb.org/person/110388"},{"name":"Kim So-jin","name_vi":null,"name_original":"Kim So-jin","tmdb_id":1887382,"profile":"https://image.tmdb.org/t/p/w500/zB52bv23nkkjUALtHV0LmPBbI85.jpg","tmdb_url":"https://www.themoviedb.org/person/1887382"},{"name":"Jin Sun-kyu","name_vi":null,"name_original":"Jin Sun-kyu","tmdb_id":1989290,"profile":"https://image.tmdb.org/t/p/w500/toFCyPac5rSpN58p0fsZ7lbogYc.jpg","tmdb_url":"https://www.themoviedb.org/person/1989290"},{"name":"Ryeoun","name_vi":null,"name_original":"Ryeoun","tmdb_id":2621980,"profile":"https://image.tmdb.org/t/p/w500/y2QVVNdV0PqWfvhuPT0hvdWOouP.jpg","tmdb_url":"https://www.themoviedb.org/person/2621980"},{"name":"Lee Dae-yeon","name_vi":null,"name_original":"Lee Dae-yeon","tmdb_id":39258,"profile":"https://image.tmdb.org/t/p/w500/vv6WMIPEikHNsiYldGJJQ2ty9Zt.jpg","tmdb_url":"https://www.themoviedb.org/person/39258"},{"name":"Jung Soon-won","name_vi":null,"name_original":"Jung Soon-won","tmdb_id":2123796,"profile":"https://image.tmdb.org/t/p/w500/E80fMLgKBeOASTnHLEi4jSuCqo.jpg","tmdb_url":"https://www.themoviedb.org/person/2123796"},{"name":"Kim Won-hae","name_vi":null,"name_original":"Kim Won-hae","tmdb_id":1278160,"profile":"https://image.tmdb.org/t/p/w500/nWZGktRe2Ele7fLxZt8e492oRir.jpg","tmdb_url":"https://www.themoviedb.org/person/1278160"},{"name":"Hong Woo-jin","name_vi":null,"name_original":"Hong Woo-jin","tmdb_id":3247799,"profile":"https://image.tmdb.org/t/p/w500/1pkj2