p bài trùng vô cùng thú vị, vừa hài hước vừa cảm động.</p>","tmdb":{"type":"tv","id":"198178","season":1,"vote_average":7.102,"vote_count":133},"modified":"2026-01-31T15:07:57.000Z","cast":["Yahya Abdul-Mateen II","Arian Moayed","X Mayo","Ben Kingsley"],"director":[],"cast_meta":[{"name":"Yahya Abdul-Mateen II","name_vi":null,"name_original":"Yahya Abdul-Mateen II","tmdb_id":1639847,"profile":"https://image.tmdb.org/t/p/w500/79VdVjUoiYGcgjOT9UmE5XIpoZM.jpg","tmdb_url":"https://www.themoviedb.org/person/1639847"},{"name":"Arian Moayed","name_vi":null,"name_original":"Arian Moayed","tmdb_id":457386,"profile":"https://image.tmdb.org/t/p/w500/ApY4Ql2xGnzy8LeWqcntAbEQHiB.jpg","tmdb_url":"https://www.themoviedb.org/person/457386"},{"name":"X Mayo","name_vi":null,"name_original":"X Mayo","tmdb_id":2267887,"profile":"https://image.tmdb.org/t/p/w500/7rmo3N6EOzsKxvlk78NJLjEboys.jpg","tmdb_url":"https://www.themoviedb.org/person/2267887"},{"name":"Ben Kingsley","name_vi":null,"name_original":"Ben Kingsley","tmdb_id":2282,"profile":"https://image.tmdb.org/t/p/w500/vQtBqpF2HDdzbfXHDzR4u37i1Ac.jpg","tmdb_url":"https://www.themoviedb.org/person/2282"}],"keywords":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/wo/wonder-man.json"}