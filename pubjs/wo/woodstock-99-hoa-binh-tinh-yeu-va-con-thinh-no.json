f867/index.m3u8"},{"name":"6","slug":"6","filename":"Câu Chuyện Âm Nhạc - Tập 6","link_embed":"https://vip.opstream16.com/share/6c795eec1c0467ec2121a73e2132604b","link_m3u8":"https://vip.opstream16.com/20250513/42125_6c795eec/index.m3u8"}]}],"time":"110 Phút","description":"Theo ghi nhận của truyền thông thế giới, Woodstock là lễ hội thảm họa nhất thời đại và đã trở thành một ví dụ điển hình về những sự cố trong quá trình tổ chức sự kiện công chúng.  Woodstock 99 được tổ chức tại một đường băng cũ, không hề có cây cối và nhiệt độ thì lên tới 40 độ C. Người tham dự không được mang thức ăn, nước uống vào bên trong còn giá dịch vụ thì đắt đỏ, lên tới 4 USD cho 1 chai nước nửa lít.  Bên cạnh đó, các cơ sở dịch vụ như bán đồ ăn, uống và vệ sinh cá nhân cũng không thể tải nổi số lượng người quá đông. Nhiều khán giả khi đến lễ hội đã không lường trước được điều này, dẫn tới nhiều sự cố không đáng có.","tmdb":{"type":"movie","id":"848562","season":null,"vote_average":6.431,"vote_count":94},"modified":"2025-05-13T21:18:14.000Z","cast":["Michael Lang","John Scher","Wesley Morris","Maureen Callahan","Steven Hyden","Tariq Trotter","Jonathan Davis","Moby","Jewel","Scott Stapp","Dexter Holland","Kevin ‘Noodles’ Wasserman","Dave Mustaine","Flea","Bill Clinton"],"director":["Garret Price"],"cast_meta":[{"name":"Michael Lang","name_vi":null,"name_original":"Michael Lang","tmdb_id":1448,"profile":"https://image.tmdb.org/t/p/w500/gexMoEHwupMNJ1ehDCICDjzwIQW.jpg","tmdb_url":"https://www.themoviedb.org/person/1448"},{"name":"John Scher","name_vi":null,"name_original":"John Scher","tmdb_id":1242379,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1242379"},{"name":"Wesley Morris","name_vi":null,"name_original":"Wesley Morris","tmdb_id":3032670,"profile":"https://image.tmdb.org/t/p/w500/xlPdVbZXUXwldPN3xeFKzAPx3z8.jpg","tmdb_url":"https://www.themoviedb.org/person/3032670"},{"name":"Maureen Callahan","name_vi":null,"name_original":"Maureen Callahan","tmdb_id":3149456,"profile"