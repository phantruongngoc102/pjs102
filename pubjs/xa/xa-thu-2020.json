escription":"<p>Vào mùa xuân năm 1949, vì loại bỏ tổ chức ám sát bí mật và cố gắng khởi nghĩa , Tô Văn Khiêm cùng với tổ chuyên án phối hợp đối phó với sát thủ Trì Thiết Thành, người mà Tô Văn Khiêm sát cánh nhiều năm. Vì quyết tâm mọi việc để ngăn chặn âm mưu ám sát, hai bậc thầy bắn cùng nhau chiến đấu gay gắt, quyết liệt. Cuối cùng, công lý cũng đánh bại cái ác.</p>","tmdb":{"type":"tv","id":"111226","season":1,"vote_average":6.2,"vote_count":4},"modified":"2022-06-04T20:56:31.000Z","cast":["Hoàng Hiên","Chen He","Yang Caiyu","Sierra Li","Zhang Hongrui"],"director":["Ngũ Bách"],"cast_meta":[{"name":"Hoàng Hiên","name_vi":"Hoàng Hiên","name_original":"Huang Xuan","tmdb_id":1376106,"profile":"https://image.tmdb.org/t/p/w500/dedh0tG92cerVlFOJRX3YRBI3Lk.jpg","tmdb_url":"https://www.themoviedb.org/person/1376106"},{"name":"Chen He","name_vi":null,"name_original":"Chen He","tmdb_id":1397016,"profile":"https://image.tmdb.org/t/p/w500/78V2SYzwekBQOK55F4CmFWTwk34.jpg","tmdb_url":"https://www.themoviedb.org/person/1397016"},{"name":"Yang Caiyu","name_vi":null,"name_original":"Yang Caiyu","tmdb_id":1276628,"profile":"https://image.tmdb.org/t/p/w500/hNIZhvljBtkk19jIxX6nBIwux4K.jpg","tmdb_url":"https://www.themoviedb.org/person/1276628"},{"name":"Sierra Li","name_vi":null,"name_original":"Sierra Li","tmdb_id":1732570,"profile":"https://image.tmdb.org/t/p/w500/e02QoeO2exLQgK1ZjUSuirDWBbz.jpg","tmdb_url":"https://www.themoviedb.org/person/1732570"},{"name":"Zhang Hongrui","name_vi":null,"name_original":"Zhang Hongrui","tmdb_id":2405772,"profile":"https://image.tmdb.org/t/p/w500/kFDuoqIFUPmp51i0LkWCdtEMiSJ.jpg","tmdb_url":"https://www.themoviedb.org/person/2405772"}],"keywords":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/xa/xa-thu-2020.json"}