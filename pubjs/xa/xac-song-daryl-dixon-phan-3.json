u8":"https://vip.opstream10.com/20251013/30610_b757aa8b/index.m3u8"},{"name":"7","slug":"7","link_embed":"https://vip.opstream10.com/share/5ed9dcf3d3d3dd8712866e81ddeaa03d","link_m3u8":"https://vip.opstream10.com/20251020/30695_5ed9dcf3/index.m3u8"}]}],"description":"<p>Mùa 3 của The Walking Dead: Daryl Dixon sẽ đưa khán giả đến một vùng đất hoàn toàn mới - Tây Ban Nha. Sau hành trình đầy gian nan ở Pháp, Daryl và Carol giờ đây phải đối mặt với một thế giới hậu tận thế với những quy tắc riêng biệt mới mẻ. Cốt truyện tập trung vào hành trình trở về nhà đầy chông gai của cả hai, giữa khung cảnh vùng quê đầy cảm hứng điện ảnh của khung cảnh hoang dã Tây Ban Nha. Họ gặp gỡ những nhân vật thú vị như một người Anh hài hước, một người tình mới của Carol, và một cao bồi nữ biểu tượng – Paz. Mùa phim này được đánh giá là “Một trong những mùa hay nhất của cả thương hiệu đình đám The Walking Dead ”, và cái kết mở hứa hẹn một mùa cuối đầy cao trào, kịch tính.</p>","tmdb_id":211684,"cast":["Norman Reedus","Melissa McBride","Eduardo Noriega","Óscar Jaenada","Alexandra Masangkay","Hugo Arbues","Candela Saitta"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"211684","season":3,"vote_average":8.02,"vote_count":810},"cast_meta":[{"name":"Norman Reedus","name_vi":null,"name_original":"Norman Reedus","tmdb_id":4886,"profile":"https://image.tmdb.org/t/p/w500/ozHPdO5jAt7ozzdZUgyRAMNPSDW.jpg","tmdb_url":"https://www.themoviedb.org/person/4886"},{"name":"Melissa McBride","name_vi":null,"name_original":"Melissa McBride","tmdb_id":31535,"profile":"https://image.tmdb.org/t/p/w500/2omPfeMdnicJqqvgKAU2iqVyD4Z.jpg","tmdb_url":"https://www.themoviedb.org/person/31535"},{"name":"Eduardo Noriega","name_vi":null,"name_original":"Eduardo Noriega","tmdb_id":17093,"profile":"https://image.tmdb.org/t/p/w500/wL2pCdw5lNsDrWRor3rxwLaSTQK.jpg","tmdb_url":"https://www.themoviedb.org/person/17093"},{"name":"Óscar Jaenada","name_vi":null,"name_original":"Óscar Jaenada","tmdb_id":59129,"profile":"https:/