iến hình thành xe cứu hỏa, xe cảnh sát, xe cứu thương, thuyền cứu hộ và máy bay để lao đến hiện trường, sử dụng nhiều đạo cụ thú vị để giải quyết khủng hoảng và trả lời các câu hỏi của trẻ em.</p>","tmdb_id":122961,"cast":["金雍淳"],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"122961","season":6,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"金雍淳","name_vi":null,"name_original":"金雍淳","tmdb_id":4740720,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/4740720"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/xe/xe-buyt-bien-hinh-phan-6.json"}