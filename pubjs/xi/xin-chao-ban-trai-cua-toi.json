ps://vip.opstream14.com/20230320/33883_c0a27f2b/index.m3u8"},{"name":"24","slug":"24","filename":"The Girl Who Sees Smells EP24","link_embed":"https://vip.opstream14.com/share/5549f6da5ec3b191b672e682e4735d71","link_m3u8":"https://vip.opstream14.com/20230320/33884_e063923d/index.m3u8"}]}],"time":"30 phút/tập","description":"<p>Lục Phần Phần người đang ở dưới đáy cuộc đời, có tài năng thiên bẩm về hương vị và mơ ước trở thành bậc thầy về rượu, nhưng cô chỉ có thể làm nhân viên quảng cáo rượu trong siêu thị. Tình cờ, cô cứu được Hứa Minh Thần, chủ tịch của An Đạt Group. Một nụ hôn bất ngờ đã mở ra cánh cửa định mệnh cho mối quan hệ giữa hai người - nụ hôn ấy trở thành \"liều thuốc\" duy nhất cho căn bệnh kỳ lạ của Minh Thần. Để chữa khỏi bệnh, Minh Thần đã tiếp cận và theo đuổi Lục Phần Phần bằng nhiều cách khác nhau. Minh Thần dần dần từ chán ghét trở nên thích thú. Những tưởng cuối cùng cũng có một tình yêu viên mãn, nhưng tình yêu giữa hai người vẫn gặp phải nhiều thử thách, sự ngăn cản của người thân trong gia đình, những lời nói dối với động cơ không trong sáng, mâu thuẫn giữa những giấc mơ và sự nghiệp. Cuối cùng trải qua bao khó khăn họ cũng có một tình yêu tuyệt đẹp.</p>","tmdb":{"type":"tv","id":"222671","season":1,"vote_average":6,"vote_count":1},"modified":"2024-12-15T14:36:11.000Z","cast":["Gia Nghệ","Jin Zixuan","Phạm Hiểu Đông","Wu Mingjing","Du Houjia","Gao Kaiyuan"],"director":["Ma Ming"],"cast_meta":[{"name":"Gia Nghệ","name_vi":"Gia Nghệ","name_original":"Jia Yi","tmdb_id":3224532,"profile":"https://image.tmdb.org/t/p/w500/pgZo2p3SjLMbjW2UGcLPMYQpFD4.jpg","tmdb_url":"https://www.themoviedb.org/person/3224532"},{"name":"Jin Zixuan","name_vi":null,"name_original":"Jin Zixuan","tmdb_id":3762661,"profile":"https://image.tmdb.org/t/p/w500/k7ugf26gcCgbuZg6JYdRI7PNjhQ.jpg","tmdb_url":"https://www.themoviedb.org/person/3762661"},{"name":"Phạm Hiểu Đông","name_vi":"Phạm Hiểu Đông","name_original":"Fan Xiaodong","tmdb_id":2493868,"profile":"https://image.tmdb.