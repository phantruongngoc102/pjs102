_embed":"https://vip.opstream16.com/share/82ab631faae192a17db862389778fb2c","link_m3u8":"https://vip.opstream16.com/20250826/47760_82ab631f/index.m3u8"}]}],"time":"43 phút/tập","description":"Trình Gia Ứng (do Thái Tư Bối đóng) tốt nghiệp trung y, cô luôn đạt thành tích xuất sắc từ lúc vào nghề. Ứng thăng tiến làm chủ nhiệm phục vụ trung y của chính phủ.\n\nTrong đó, Cô Thanh Kình là bạn thanh mai trúc mã, cũng là bạn học cùng khóa và là bạn trai cũ của Ứng. 10 năm trước, họ chia tay vì Kình đi làm thiện nguyện ở nước ngoài. Tôn chỉ của Kình là: \"Trước khi người bệnh chưa bị bệnh, thầy thuốc loại bỏ nguồn bệnh mới là thượng sách, cũng tức là chữa chưa bệnh\".\n\nKình làm việc vốn không theo nguyên tắc nên thường xảy ra xung đột với Ứng nhưng họ luôn lấy lợi ích người bệnh làm trọng.","tmdb":{"type":"tv","id":"233863","season":1,"vote_average":0,"vote_count":0},"modified":"2025-08-28T09:30:30.000Z","cast":["Sisley Choi Si-Pui","Hà Quảng Bái","Ngô Vĩ Hào","Kayan Yau","Erica Chan","Danny Hung","Angelina Lo","Susan Tse Suet-Sum","Tiffany Fabienne Kwan","To Yin-Gor","Chang Hong-Sang","Eva Lai","Strawberry Yeung Yuk-Mui","Albert Cheung Miu-Hau","Trần Gia Huy"],"director":["方駿釗"],"cast_meta":[{"name":"Sisley Choi Si-Pui","name_vi":null,"name_original":"Sisley Choi Si-Pui","tmdb_id":1545561,"profile":"https://image.tmdb.org/t/p/w500/kMoFQdV3Do1kIuDMq2dYOYNrMZ2.jpg","tmdb_url":"https://www.themoviedb.org/person/1545561"},{"name":"Hà Quảng Bái","name_vi":"Hà Quảng Bái","name_original":"Matthew Ho","tmdb_id":1773042,"profile":"https://image.tmdb.org/t/p/w500/5u59daffrHmN3AjHQV0e9y7lBxH.jpg","tmdb_url":"https://www.themoviedb.org/person/1773042"},{"name":"Ngô Vĩ Hào","name_vi":"Ngô Vĩ Hào","name_original":"Ricco Ng","tmdb_id":2988173,"profile":"https://image.tmdb.org/t/p/w500/wjIquJhLIFnJ1RAvhNV1JFwslKT.jpg","tmdb_url":"https://www.themoviedb.org/person/2988173"},{"name":"Kayan Yau","name_vi":null,"name_original":"Kayan Yau","tmdb_id":3386076,"profile":"https://image.tmdb.org/