14.com/20221031/27069_42d2dc54/index.m3u8"},{"name":"23B","slug":"23b","filename":"xin-chao-hoa-diem-lam-the-flaming-heart-tap-23B","link_embed":"https://vip.opstream14.com/share/6151ca1f26822034f6b12f142bdfc9db","link_m3u8":"https://vip.opstream14.com/20221031/27071_e4396310/index.m3u8"},{"name":"24A","slug":"24a","filename":"xin-chao-hoa-diem-lam-the-flaming-heart-tap-24A","link_embed":"https://vip.opstream14.com/share/521255db815eb7f2e44d31ce130352c9","link_m3u8":"https://vip.opstream14.com/20221031/27070_6cae26f0/index.m3u8"},{"name":"24B","slug":"24b","filename":"xin-chao-hoa-diem-lam-the-flaming-heart-tap-24B","link_embed":"https://vip.opstream14.com/share/0e6930d35e9a52977d5bd93c414ce3b2","link_m3u8":"https://vip.opstream14.com/20221031/27072_45a1c12b/index.m3u8"}]}],"time":"","description":"<p>Xin Chào, Ngọn Lửa Xanh xoay quanh nhân vật Hoắc Tư Yến (do Cung Tuấn thủ vai). Sau khi Hoắc Tư Yến tốt nghiệp Học viện Dân phòng, anh trở thành đội phó của Đội cứu hỏa. Trong một lần giải cứu người phụ nữ mang thai khỏi xe giao hàng, anh đã tình cờ gặp được Diễm Lam (do Trương Tuệ Văn thủ vai) – một bác sĩ làm việc tại Khoa Cấp cứu của bệnh viện. Công việc của cả hai đều mang yếu tố vô cùng khắc nghiệt có thể hy sinh bất cứ lúc nào, nhiều lần làm nhiệm vụ, cả hai suýt phải mất mạng, họ đối mặt với sự thật tàn khốc của tình huống khẩn cấp nhưng cũng vì thế mà tình cảm càng bền chặt hơn, không gì có thể chia cắt.</p>","tmdb":{"type":"tv","id":"128699","season":1,"vote_average":5.8,"vote_count":5},"modified":"2022-10-31T19:47:39.000Z","cast":["Cung Tuấn","Zhang Huiwen","Pang Hanchen","Zhou Linjia","Luo Yi","Wang Yizhou","Lu Yupeng","Zhang Zhilu","Zhou Yanchen","Wang Ziwei"],"director":["Đang cập nhật"],"cast_meta":[{"name":"Cung Tuấn","name_vi":"Cung Tuấn","name_original":"Gong Jun","tmdb_id":1820070,"profile":"https://image.tmdb.org/t/p/w500/rtjBdEF61NySmDDnoDgAtuclAJJ.jpg","tmdb_url":"https://www.themoviedb.org/person/1820070"},{"name":"Zhang Huiwen","name_vi":null,"na