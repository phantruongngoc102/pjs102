b95c62909d5190a6","link_m3u8":"https://vip.opstream11.com/20220322/3649_aa7b97d3/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream11.com/share/c203e4a1bdef9372cb9864bfc9b511cc","link_m3u8":"https://vip.opstream11.com/20220322/3651_3d385a6b/index.m3u8"}]}],"description":"<p>Xin Chào, Tạm Biệt Mẹ - The Last Goodbye To Mama là câu chuyện cảm động xoay quanh cuộc sống của hai mẹ con đến từ một thị trấn nhỏ ở Tô Bắc. Thanh niên 18 tuổi Ding Xiao Jun được nhận vào một trường đại học ở Bắc Kinh và bắt đầu cuộc sống nổi loạn, ngỗ nghịch. Xiao Jun đã không thể tốt nghiệp đại học nếu như mẹ anh không đến xin nhà trường. Sau khi tốt nghiệp, Ding Xiao Jun bị lừa hết số tiền kiếm được và trở thành một kẻ ăn bám trong nhiều tháng. Bắt đầu hiểu được tất cả những khó khăn mà mẹ đã phải trải qua, Xiao Jun đã cố gắng để được quay về với mẹ. Trong đêm giao thừa, Ding Xiao Jun nhận được tin trúng tuyển vào 1 công ty ở Bắc Kinh, cũng là lúc anh nhận tin mẹ bị chẩn đoán mắc bệnh nan y. Ding Xiao Jun phải đối mặt với hai lựa chọn: tiếp tục xây dựng sự nghiệp ở Bắc Kinh hay về nhà với mẹ trong những ngày cuối đời của bà.</p>","tmdb_id":135354,"cast":["Đổng Khiết","Yin Fang","Lu Fangsheng","Vương Sở Nhiên","Zhao Wei","Cai Lu","Chen Jiawen","Jiang Xueming","Zhang Yao","Ran Xu","Qu Shanshan","Zeng Qi","Gong Lei","Hà Tuyên Lâm","Du Shuangyu"],"director":["Cao Dun","Jing Chong"],"keywords":[],"time":"45 phút/tập","tmdb":{"type":"tv","id":"135354","season":1,"vote_average":5,"vote_count":2},"cast_meta":[{"name":"Đổng Khiết","name_vi":"Đổng Khiết","name_original":"Dong Jie","tmdb_id":12676,"profile":"https://image.tmdb.org/t/p/w500/12X5p7oHzvA598NHLU8EvYsG9oh.jpg","tmdb_url":"https://www.themoviedb.org/person/12676"},{"name":"Yin Fang","name_vi":null,"name_original":"Yin Fang","tmdb_id":2133335,"profile":"https://image.tmdb.org/t/p/w500/hPm30FwwK6QzpJLgJL7wdOLVBL1.jpg","tmdb_url":"https://www.themoviedb.org/person/2133335"},{"name":"Lu Fangsheng","name_vi":null,"name_origin