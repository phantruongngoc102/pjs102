tream11.com/share/856b1cacaea25f6ebbf01b0003030a0b","link_m3u8":"https://vip.opstream11.com/20220409/11900_0873931c/index.m3u8"},{"name":"25","slug":"25","filename":"Xin Lỗi Anh Yêu Em - Tập 25","link_embed":"https://vip.opstream11.com/share/63f35343d6f9681cad0598452a17f0df","link_m3u8":"https://vip.opstream11.com/20220409/11902_43701b4e/index.m3u8"},{"name":"26","slug":"26","filename":"Xin Lỗi Anh Yêu Em - Tập 26","link_embed":"https://vip.opstream11.com/share/a036718538bef589e491d3f0c034f082","link_m3u8":"https://vip.opstream11.com/20220409/11903_586dd4a0/index.m3u8"},{"name":"27","slug":"27","filename":"Xin Lỗi Anh Yêu Em - Tập 27","link_embed":"https://vip.opstream11.com/share/8780a72513a774d87bae314cb01856ba","link_m3u8":"https://vip.opstream11.com/20220409/11904_272161e6/index.m3u8"}]}],"time":"44 phút/tập","description":"<p>Nike bị cha mẹ bỏ rơi và sống nay đây mai đó với \"nghề\" cướp giật. Tanatat là ca sĩ nổi tiếng, anh có nhân viên phục trang là Punch. Một lần lưu diễn, Punch quyết định bỏ về nước trước khi anh lưu diễn xong. Không may, Punch bị 1 toán lang thang giống như Nike cướp toàn bộ hành lý và giấy tờ. Ban đầu Nike định lừa bán Punch để kiếm tiền nhưng anh đã kịp nhận ra Punch là cô bé rất đáng thương. Sáng hôm sau khi Punch tỉnh dậy thì đã thấy hành lý của mình như chưa hề bị cướp... Về phần Nike, anh tham gia lễ cưới của người yêu cũ (đã bỏ anh để chạy theo đồng tiền). Bi kịch xảy ra khi Nike vô tình bị trúng 2 phát đạn vào đầu khi anh cố gắng cứu cô người yêu phản bội thoát khỏi bàn tay kẻ sát nhân. Nike được cứu sống nhưng vẫn còn sót 1 viên đạn trong đầu. Biết mình không còn sống được lâu, Nike trở về quê hương Thái Lan để tìm mẹ ruột đã bỏ rơi mình. Nhưng sự thật quá vô tình khi anh phát hiện ra mẹ mình là diễn viên nổi tiếng cùng cậu con trai Tanatat đang sống trong vinh hoa phú quý. Cũng từ ngày đó Nike gặp lại Punch, tình cảm hai người dần sâu sắc, rồi hàng loạt những biến cố đã xảy ra...</p>","tmdb":{"type":"tv","id":"2265","season":1,"vote_average":8,"vote_count":25},"modified":"2023-06-20T17:54:22.000Z","cast":["Lim Soo-jung","So Ji-sub","Jung Kyung-ho","Choi Yeo-jin","Seo Ji-young","Jeon Hye-jin","Kim Hye-ok","Lee Hye-young","Lee Yeong-ha","Shin Gu","Park Gun-tae"],"director":["Paoon Jansiri"],"cast_meta":[{"name":"Lim Soo-jung","name_vi":null,"name_original":"Lim Soo-jung","tmdb_id":37940,"profile":"https://image.tmdb.org/t/p/w500/vX5teH7vHy7B18vNQCafeML2ZPf.jpg","tmdb_url":"https://www.themoviedb.org/person/37940"},{"name":"So Ji-sub","name_vi":null,"name_original":"So Ji-sub","tmdb_id":932821,"profile":"https://image.tmdb.org/t/p/w500/oEdXNo3ohtldtIW6DMFPpvMYW4g.jpg","tmdb_url":"https://www.themoviedb.org/person/932821"},{"name":"Jung Kyung-ho","name_vi":null,"name_original":"Jung Kyung-ho","tmdb_id":79578,"profile":"https://image.tmdb.org/t/p/w500/fanLZsECF5nDy17HkhcdoLJjPaw.jpg","tmdb_url":"https://www.themoviedb.org/person/79578"},{"name":"Choi Yeo-jin","name_vi":null,"name_original":"Choi Yeo-jin","tmdb_id":64499,"profile":"https://image.tmdb.org/t/p/w500/igCkz4OmkTeS2tSeYSHX9bMNMw8.jpg","tmdb_url":"https://www.themoviedb.org/person/64499"},{"name":"Seo Ji-young","name_vi":null,"name_original":"Seo Ji-young","tmdb_id":1624556,"profile":null,"tmdb_url":"https://www.themoviedb.org/person/1624556"},{"name":"Jeon Hye-jin","name_vi":null,"name_original":"Jeon Hye-jin","tmdb_id":150126,"profile":"https://image.tmdb.org/t/p/w500/7PliJIOzUei41vyE9FaIWvFMNzC.jpg","tmdb_url":"https://www.themoviedb.org/person/150126"},{"name":"Kim Hye-ok","name_vi":null,"name_original":"Kim Hye-ok","tmdb_id":145363,"profile":"https://image.tmdb.org/t/p/w500/e6TtMyr2PQbW6JNAWW7bZoaVhPt.jpg","tmdb_url":"https://www.themoviedb.org/person/145363"},{"name":"Lee Hye-young","name_vi":null,"name_original":"Lee Hye-young","tmdb_id":588209,"profile":"https://image.tmdb.org/t/p/w500/v1Qy0fyn2Iipk51dkRAI4COhwjz.jpg","tmdb_url":"https://www.themoviedb.org/person/588209"},{"name":"Lee Yeong-ha","name_vi":null,"name_original":"Le