/vip.opstream11.com/20220409/11896_54787102/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream11.com/share/b1924e3eaca56a46ac62e8a0fe0fc199","link_m3u8":"https://vip.opstream11.com/20220409/11895_ad27e142/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/a576433ccd77ad5fe21cb70af8011038","link_m3u8":"https://vip.opstream11.com/20220409/11897_b5d6dd7f/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream11.com/share/4cf298280fa338aa99601829a948bf35","link_m3u8":"https://vip.opstream11.com/20220409/11898_c3e117cd/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream11.com/share/fb087773ffbac93b13b4303f3d41de4d","link_m3u8":"https://vip.opstream11.com/20220409/11899_8a044063/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream11.com/share/108f6a48835ed848b3ec66c2d0afd568","link_m3u8":"https://vip.opstream11.com/20220409/11901_6f16d252/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream11.com/share/856b1cacaea25f6ebbf01b0003030a0b","link_m3u8":"https://vip.opstream11.com/20220409/11900_0873931c/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream11.com/share/63f35343d6f9681cad0598452a17f0df","link_m3u8":"https://vip.opstream11.com/20220409/11902_43701b4e/index.m3u8"},{"name":"26","slug":"26","link_embed":"https://vip.opstream11.com/share/a036718538bef589e491d3f0c034f082","link_m3u8":"https://vip.opstream11.com/20220409/11903_586dd4a0/index.m3u8"},{"name":"27","slug":"27","link_embed":"https://vip.opstream11.com/share/8780a72513a774d87bae314cb01856ba","link_m3u8":"https://vip.opstream11.com/20220409/11904_272161e6/index.m3u8"}]}],"description":"<p>Nike bị cha mẹ bỏ rơi và sống nay đây mai đó với \"nghề\" cướp giật. Tanatat là ca sĩ nổi tiếng, anh có nhân viên phục trang là Punch. Một lần lưu diễn, Punch quyết định bỏ về nước trước khi anh lưu diễn xong. Không may, Punch bị 1 toán lang thang giống như Nike cướp toàn bộ hành lý và giấy tờ. Ban đầu Nike định lừa bán Punch để kiếm tiền nhưng anh đã kịp nhận ra Punch là cô bé rất đáng thương. Sáng hôm sau khi Punch tỉnh dậy thì đã thấy hành lý của mình như chưa hề bị cướp... Về phần Nike, anh tham gia lễ cưới của người yêu cũ (đã bỏ anh để chạy theo đồng tiền). Bi kịch xảy ra khi Nike vô tình bị trúng 2 phát đạn vào đầu khi anh cố gắng cứu cô người yêu phản bội thoát khỏi bàn tay kẻ sát nhân. Nike được cứu sống nhưng vẫn còn sót 1 viên đạn trong đầu. Biết mình không còn sống được lâu, Nike trở về quê hương Thái Lan để tìm mẹ ruột đã bỏ rơi mình. Nhưng sự thật quá vô tình khi anh phát hiện ra mẹ mình là diễn viên nổi tiếng cùng cậu con trai Tanatat đang sống trong vinh hoa phú quý. Cũng từ ngày đó Nike gặp lại Punch, tình cảm hai người dần sâu sắc, rồi hàng loạt những biến cố đã xảy ra...</p>","tmdb_id":2265,"cast":[],"director":[],"keywords":[],"tmdb":{"id":2265},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/xi/xin-loi-anh-yeu-em.json"}