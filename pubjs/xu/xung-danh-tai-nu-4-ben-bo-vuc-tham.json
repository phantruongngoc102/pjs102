ừng xuất hiện, hai người vừa tương ái tương sát vừa cùng nhau vượt qua những ải khó khăn... Thất Gia không biết từ lúc nào đã được Thập Thất thay đổi. Vào lúc đó nổ ra cuộc chiến quân phiệt, Thất Gia giúp đỡ đồng bào trong khu vực chiến tranh thoát khỏi biển lửa, đã bị ám sát trúng đạn, rơi vào đáy vực của cuộc đời.</p>","tmdb_id":272968,"cast":["Lê Diệu Tường","Hồ Định Hân","Tiêu Chính Nam","Trần Hiểu Hoa","Joey Law","Lý Thành Xương","Celina Harto","To Yin-Gor","Hải Tuấn Kiệt","Susan Tse Suet-Sum"],"director":["方駿釗"],"keywords":[],"tmdb":{"type":"tv","id":"272968","season":1,"vote_average":10,"vote_count":1},"cast_meta":[{"name":"Lê Diệu Tường","name_vi":"Lê Diệu Tường","name_original":"Wayne Lai Yiu-Cheung","tmdb_id":123654,"profile":"https://image.tmdb.org/t/p/w500/qm3knPxzkZPgq2SVo1ZTru7MkIM.jpg","tmdb_url":"https://www.themoviedb.org/person/123654"},{"name":"Hồ Định Hân","name_vi":"Hồ Định Hân","name_original":"Nancy Wu","tmdb_id":1234856,"profile":"https://image.tmdb.org/t/p/w500/9HPuplvtWO5ODGX0IhNaZsssIi4.jpg","tmdb_url":"https://www.themoviedb.org/person/1234856"},{"name":"Tiêu Chính Nam","name_vi":"Tiêu Chính Nam","name_original":"Edwin Siu","tmdb_id":1059226,"profile":"https://image.tmdb.org/t/p/w500/bPEjnmBPWTZcrWQklkqcT1bUQwb.jpg","tmdb_url":"https://www.themoviedb.org/person/1059226"},{"name":"Trần Hiểu Hoa","name_vi":"Trần Hiểu Hoa","name_original":"Hera Chan","tmdb_id":2705746,"profile":"https://image.tmdb.org/t/p/w500/ntMcYP1NMVxsQcSIcLaGR9JCbtu.jpg","tmdb_url":"https://www.themoviedb.org/person/2705746"},{"name":"Joey Law","name_vi":null,"name_original":"Joey Law","tmdb_id":2392425,"profile":"https://image.tmdb.org/t/p/w500/njwnfhrrhXLZ2ELqasYVCIeQZzO.jpg","tmdb_url":"https://www.themoviedb.org/person/2392425"},{"name":"Lý Thành Xương","name_vi":"Lý Thành Xương","name_original":"Lee Shing-Cheong","tmdb_id":140482,"profile":"https://image.tmdb.org/t/p/w500/mJyeIfXycrUZxJGlubyJ3XzxWmM.jpg","tmdb_url":"https://www.themoviedb.org/person/140482"},{"name