m/share/11bcd3c1d43688891ed23f5677a174ea","link_m3u8":"https://vip.opstream17.com/20240406/3970_9b4504fd/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream17.com/share/f81dee42585b3814de199b2e88757f5c","link_m3u8":"https://vip.opstream17.com/20240406/3969_376f3505/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream17.com/share/0cbed40c0d920b94126eaf5e707be1f5","link_m3u8":"https://vip.opstream17.com/20240406/3968_3980ca5d/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream17.com/share/43d762ca733a839226415450b0dbf9d2","link_m3u8":"https://vip.opstream17.com/20240406/3966_428b809f/index.m3u8"}]}],"description":"<p>Phim Xứng Danh Tài Nữ là câu chuyện trong giữa những năm 1820, thiên tai tấn công thành phố Nam Thông , làm xấu nhất của cánh đồng lúa của thành phố. Chạy ra khỏi nguồn cung cấp thực phẩm, thị trưởng thành phố Hồng Chi-cánh ( Wong Wai Leung ) quyết định sử dụng cung cấp thực phẩm quân sự của thành phố để nuôi người dân. Một vài ngày sau thảm họa, một quan chức từ Bắc Kinh đến thành phố để kiểm tra việc cung cấp quân sự. Khi nhìn thấy một toa xe trống rỗng, ông câu gia đình Hồng cho đến chết. Xem Phim Xung Danh Tai Nu Con gái của ông Hồng Po-yin ( Sheren Tang ) thoát khỏi sự trừng phạt và trở thành một người giúp việc trong biệt thự Hoàng tử Wai, sống dưới cái tên Hồng Po-kei.</p>","tmdb_id":16266,"cast":["Đặng Tụy Văn","Lê Diệu Tường","Nhạc Hoa","Susan Tse Suet-Sum","Huệ Anh Hồng","Thương Thiên Nga","Ngô Trác Hy","Suki Chui","Hồ Định Hân","Trần Vinh Tuấn","Kelvin Leung","Lý Thành Xương","Suet Nei","Helen Ma Hoi-Lun","Quách Phong"],"director":["Lý Chiêm Thắng"],"keywords":[],"tmdb":{"type":"tv","id":"16266","season":2,"vote_average":8.8,"vote_count":6},"cast_meta":[{"name":"Đặng Tụy Văn","name_vi":"Đặng Tụy Văn","name_original":"Sheren Tang Shui-Man","tmdb_id":997296,"profile":"https://image.tmdb.org/t/p/w500/sJ9nrY567ikJ4c2T5wxxuVTB9Ft.jpg","tmdb_url":"https://www.themoviedb.org/person/997296"}