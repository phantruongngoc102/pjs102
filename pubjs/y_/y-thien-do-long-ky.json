ream11.com/share/1686c5ec96f728148f941ab2b0f2cc35","link_m3u8":"https://vip.opstream11.com/20220411/13130_dbf5d1f8/index.m3u8"},{"name":"37","slug":"37","filename":"Ỷ Thiên Đồ Long Ký - The Heaven Sword And Dragon Saber - Tập 37","link_embed":"https://vip.opstream11.com/share/052a1a3c0142ad636571f88ea2506eac","link_m3u8":"https://vip.opstream11.com/20220411/13131_f74acfe5/index.m3u8"},{"name":"38","slug":"38","filename":"Ỷ Thiên Đồ Long Ký - The Heaven Sword And Dragon Saber - Tập 38","link_embed":"https://vip.opstream11.com/share/a868d710aa4ef67a68807ce4fe8bd0da","link_m3u8":"https://vip.opstream11.com/20220411/13132_5d154d4c/index.m3u8"},{"name":"39","slug":"39","filename":"Ỷ Thiên Đồ Long Ký - The Heaven Sword And Dragon Saber - Tập 39","link_embed":"https://vip.opstream11.com/share/7cff4ce87d7f2179d73e7959bf213529","link_m3u8":"https://vip.opstream11.com/20220411/13133_052f8e5b/index.m3u8"},{"name":"40","slug":"40","filename":"Ỷ Thiên Đồ Long Ký - The Heaven Sword And Dragon Saber - Tập 40","link_embed":"https://vip.opstream11.com/share/c2be0c8ff27074343b8218c3b01bb3d0","link_m3u8":"https://vip.opstream11.com/20220411/13134_c1b558c2/index.m3u8"}]}],"time":"48 phút / tập","description":"<p>Ỷ Thiên Đồ Long Ký - The Heaven Sword And Dragon Saber dựa trên một tiểu thuyết võ hiệp của nhà văn Kim Dung, bối cảnh lấy vào cuối thời nhà Nguyên, 80 năm sau sự kiện trên đỉnh Hoa Sơn trong ''Thần Điêu Hiệp Lữ''. Lúc này, nhà Nguyên đang bị suy yếu bởi các cuộc khởi nghĩa và vì sự xa hoa lãng phí của triều đình. Phim xoay quanh Trương Vô Kỵ - với bản tính kiên nhẫn, chất phác và y thuật cao siêu - và mối tình phức tạp với 4 cô gái, bên cạnh đó là những âm mưu thủ đoạn đầy máu tanh trên giang hồ nhằm chiếm đoạt 2 món báu vật là Đồ Long đao và Ỷ Thiên kiếm với lời đồn nếu tìm được bí mật trong đao kiếm sẽ hiệu triệu thiên hạ.</p>","tmdb":{"type":"tv","id":"31952","season":1,"vote_average":7.81,"vote_count":21},"modified":"2023-07-08T16:47:54.000Z","cast":["Tô Hữu Bằng","Giả Tịnh Văn","Cao Viên Viên","Trần Tử Hàm","Trần Tú Lệ","Trương Thiết Lâm","Trương Quốc Lập","Từ Cẩm Giang","Yan Qingyu","Wang Gang","Quách Phi Lệ","Đào Hồng","Thích Tiểu Long","Yan Minqiu","Ji Qilin"],"director":["Lại Thủy Thanh"],"cast_meta":[{"name":"Tô Hữu Bằng","name_vi":"Tô Hữu Bằng","name_original":"Alec Su","tmdb_id":102296,"profile":"https://image.tmdb.org/t/p/w500/sgiYxajhi61gI5DcuVYBloneX4s.jpg","tmdb_url":"https://www.themoviedb.org/person/102296"},{"name":"Giả Tịnh Văn","name_vi":"Giả Tịnh Văn","name_original":"Alyssa Chia","tmdb_id":1251592,"profile":"https://image.tmdb.org/t/p/w500/3xcy2tgo5fLMNBiO5cLCzdUoOI.jpg","tmdb_url":"https://www.themoviedb.org/person/1251592"},{"name":"Cao Viên Viên","name_vi":"Cao Viên Viên","name_original":"Gao Yuanyuan","tmdb_id":74022,"profile":"https://image.tmdb.org/t/p/w500/aotqhWAseCbgq2HYDP3So5j5qg5.jpg","tmdb_url":"https://www.themoviedb.org/person/74022"},{"name":"Trần Tử Hàm","name_vi":"Trần Tử Hàm","name_original":"Chen Zihan","tmdb_id":593166,"profile":"https://image.tmdb.org/t/p/w500/xItbxt0SQa6FlA4w0rrlDRH0ghY.jpg","tmdb_url":"https://www.themoviedb.org/person/593166"},{"name":"Trần Tú Lệ","name_vi":"Trần Tú Lệ","name_original":"Florence Tan","tmdb_id":2041116,"profile":"https://image.tmdb.org/t/p/w500/h3UbEovxIt9NihGt3kFbdtsKmZa.jpg","tmdb_url":"https://www.themoviedb.org/person/2041116"},{"name":"Trương Thiết Lâm","name_vi":"Trương Thiết Lâm","name_original":"Zhang Tielin","tmdb_id":1236261,"profile":"https://image.tmdb.org/t/p/w500/fj8tjQc58Ym0Ujmpfstn24sW0TR.jpg","tmdb_url":"https://www.themoviedb.org/person/1236261"},{"name":"Trương Quốc Lập","name_vi":"Trương Quốc Lập","name_original":"Zhang Guoli","tmdb_id":543178,"profile":"https://image.tmdb.org/t/p/w500/hNNFegPLSulMnqMWrlYtJmuob9k.jpg","tmdb_url":"https://www.themoviedb.org/person/543178"},{"name":"Từ Cẩm Giang","name_vi":"Từ Cẩm Giang","name_original":"Elvis Tsui Kam-Kong","tmdb_id":83631,"profile":"https://image.tmdb.org/t/p/w500/x110WbXYXMQjVNoPjEMoPo7qE