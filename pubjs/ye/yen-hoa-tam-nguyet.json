566d452","link_m3u8":"https://vip.opstream17.com/20240701/14097_761a69ae/index.m3u8"},{"name":"30","slug":"30","link_embed":"https://vip.opstream17.com/share/131632cb7eeb986974e1be59af67e8fe","link_m3u8":"https://vip.opstream17.com/20240701/14098_b911096b/index.m3u8"},{"name":"31","slug":"31","link_embed":"https://vip.opstream17.com/share/5bebd340c511be08c1e9e6536e2d36f4","link_m3u8":"https://vip.opstream17.com/20240701/14099_a9a8ccf3/index.m3u8"},{"name":"32","slug":"32","link_embed":"https://vip.opstream17.com/share/1e2327accf8e3b40ac236b51c966f94a","link_m3u8":"https://vip.opstream17.com/20240701/14100_932043ef/index.m3u8"}]}],"description":"<p><i>Phim nói về cuộc đời của nhà thơ người Mãn, tên Nạp Lan Dung Nhược, và những mối tình của ông, cùng tình bạn giữa Dung Nhược, Khang Hy và Sách Lạp Vượng (con của Sách vương gia) và những sự tranh chấp với vua Khang Hy. Nạp Lan Dung Nhược yêu hai người con gái, một là Khổng Tú Trinh, thê tử trông phần mộ của vua Thuận Trị (cha Khang Hy). Về sau Dung Nhược yêu Thẩm Uyển, con gái của một phạm nhân triều đình và cũng là một người yêu thơ, nhưng Khang Hy cũng yêu Thẩm Uyển và lén thả cha nàng nhưng không dám công khai rửa sạch tội cho ông. Bên cạnh đó, tướng quân Tôn Diên Linh một lòng yêu Tú Trinh nhưng không được nàng đáp lại. Sau ông mưu phản cùng Ngô Tam Quế không thành. Nạp Lan Dung Nhược còn có một người vợ xinh đẹp nhưng bệnh hoạn tên Vũ Thiền, cũng hết lòng yêu anh. Bên cạnh những mối tình này là sự tranh chấp trong triều đình giữa Nạp Lan Minh Châu, cha của Nạp Lan Dung Nhược, và Ngao Bái, sau đó đến Sách vương gia. Tuy là con quan tể tướng nhưng Dung Nhược chưa bao giờ đoái hoài đến những danh phận tiền tài mà cha anh muốn có. Vì tham tiền hối lộ, Minh Châu cấu kết với một phú thương ở Giang Nam, từ đây con gái của phú thương này tên Quan Ánh Tâm đem long yêu Dung Nhược...</i></p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ye/yen-hoa-tam-nguyet.json","tmdb_checked":false}