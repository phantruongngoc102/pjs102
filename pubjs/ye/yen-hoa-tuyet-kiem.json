19","link_embed":"https://vip.opstream11.com/share/cd48aa780bf90bc60d846aa85dde9a7e","link_m3u8":"https://vip.opstream11.com/20241004/54192_cd48aa78/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream11.com/share/06a53c524e02d0e902662cf463a7004f","link_m3u8":"https://vip.opstream11.com/20241004/54193_06a53c52/index.m3u8"}]}],"description":"<p><i>Mở đầu phim với một tay kiếm bí ẩn Nhật Bản Bai Yi Ren (Chan Wai Man), người đã đi đến Trung Quốc để thách thức những bậc thầy võ thuật. Nhiều người đàn ông tuyệt vời đã rơi vào tay thanh kiếm nhanh nhẹn và tàn nhẫn của Bai Yi Ren, bao gồm vị thầy Bai San Kong (Chen Chen Hua). Cháu trai Bảo Er của ông sau đó được đưa về Biển Đông để tìm sự giúp đỡ từ Zi Yi Hou (Wong Wai), người hầu như không chiến thắng được Bai Yi Ren. Tuy nhiên, cuộc đấu tay đôi đã khiến Zi bị thương nghiêm trọng và anh đã qua đời với lời thề của Bai Yi Ren quay trở lại trong bảy năm sau tai. Nhiệm vụ phải đối mặt với Bai Yi Ren trong 7 năm, do đó rơi vào tay của Bảo Er, 13 tuổi, người quyết tâm nghiên cứu võ thuật. Năm năm sau, Bảo Er (Leslie Cheung) trở về từ biển Đông, đúng lúc để bắt đầu cuộc thi tuyệt vời để xác định tay kiếm hàng đầu. Cả hai người được tôn trọng và riff-raff của võ thuật thế giới đã tụ tập ở một nơi để thi đấu.</i></p>","tmdb_id":101575,"cast":["Trương Quốc Vinh","Văn Tuyết Nhi","Trần Huệ Mẫn","Lê Tiểu Điền","Mannor Chan Man-Na","Wong Wai","Pui-chun Yuen","Hứa Thiệu Hùng","Angelina Lo","Kong To","Little Unicorn","Yeung Chak-Lam","Winston Ng Wing-Sum","Mạch Tử Vân","Tam Yat-Ching"],"director":["Tiêu Sinh"],"keywords":[],"tmdb":{"type":"tv","id":"101575","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trương Quốc Vinh","name_vi":"Trương Quốc Vinh","name_original":"Leslie Cheung","tmdb_id":69637,"profile":"https://image.tmdb.org/t/p/w500/xdSUevukGCrayOdLd4Kd6YSJnKR.jpg","tmdb_url":"https://www.themoviedb.org/person/69637"},{"name":"Văn Tuyết Nhi","name_vi":"Văn Tuyết Nhi","name_original":"Candy Man","tmdb_id":240164,"profile":"https://image.tmdb.org/t/p/w500/uEiYm0iTAOnWNJHFNwhnBJ11c0K.jpg","tmdb_url":"https://www.themoviedb.org/person/240164"},{"name":"Trần Huệ Mẫn","name_vi":"Trần Huệ Mẫn","name_original":"Michael Chan Wai-Man","tmdb_id":83358,"profile":"https://image.tmdb.org/t/p/w500/n5zkWo5LFGV0GzW3N2IKss8mcqr.jpg","tmdb_url":"https://www.themoviedb.org/person/83358"},{"name":"Lê Tiểu Điền","name_vi":"Lê Tiểu Điền","name_original":"Michael Lai Siu-Tin","tmdb_id":1178936,"profile":"https://image.tmdb.org/t/p/w500/8A3P7d97n2pcBZPcnTbY3QUZaeL.jpg","tmdb_url":"https://www.themoviedb.org/person/1178936"},{"name":"Mannor Chan Man-Na","name_vi":null,"name_original":"Mannor Chan Man-Na","tmdb_id":1392192,"profile":"https://image.tmdb.org/t/p/w500/t80RDLlDraPOZDp0pzgP1Syo0Ey.jpg","tmdb_url":"https://www.themoviedb.org/person/1392192"},{"name":"Wong Wai","name_vi":null,"name_original":"Wong Wai","tmdb_id":943779,"profile":"https://image.tmdb.org/t/p/w500/mekHAh0mDXYRhg6Z9x4rt88YMzU.jpg","tmdb_url":"https://www.themoviedb.org/person/943779"},{"name":"Pui-chun Yuen","name_vi":null,"name_original":"Pui-chun Yuen","tmdb_id":2826497,"profile":"https://image.tmdb.org/t/p/w500/uIry2FXr1m1DnAzVFSowwgGeXcR.jpg","tmdb_url":"https://www.themoviedb.org/person/2826497"},{"name":"Hứa Thiệu Hùng","name_vi":"Hứa Thiệu Hùng","name_original":"Benz Hui Siu-Hung","tmdb_id":63582,"profile":"https://image.tmdb.org/t/p/w500/bgC8VLG8bBdbQTuiHQtjFlEXo6E.jpg","tmdb_url":"https://www.themoviedb.org/person/63582"},{"name":"Angelina Lo","name_vi":null,"name_original":"Angelina Lo","tmdb_id":1395247,"profile":"https://image.tmdb.org/t/p/w500/i3xgUygPWn3TTFRpFwqTDmxM8T7.jpg","tmdb_url":"https://www.themoviedb.org/person/1395247"},{"name":"Kong To","name_vi":null,"name_original":"Kong To","tmdb_id":3800360,"profile":"https://image.tmdb.org/t/p/w500/m2Pxjjtlx76wQj730WBfsC1oDsx.jpg","tmdb_url":"https://www.themoviedb.org/person/3800360"},{"name":"Little Unicorn","name_vi":null,"name_original":"Lit