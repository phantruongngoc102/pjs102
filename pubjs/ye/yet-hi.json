ream90.com/20260120/22820_69a23c56/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream90.com/share/778d63d69b0812d7d961118992c21da0","link_m3u8":"https://vip.opstream90.com/20260120/22821_778d63d6/index.m3u8"}]}],"description":"<p>Tiêu Trĩ Vũ và Hồ Tu gặp gỡ nhờ một buổi chơi “truy tìm lối thoát” có chủ đề dân quốc. Ở thế giới kịch bản đầy tuyết rơi và những bóng ma gián điệp chập chùng, hai người đánh ra tia lửa định mệnh. Thế nhưng, cuộc tái ngộ bất ngờ ngoài đời thực lại mở ra những bí ẩn về thân phận thật sự của đối phương. Xuyên qua không gian đan xen giữa hiện thực và hư cấu, họ cùng nhau bước hành trình trưởng thành song hành, từ những ràng buộc vượt qua mọi chiều không gian, để hoàn thành bước tiến hóa của tình yêu và chính bản thân mình.</p>","tmdb_id":279136,"cast":["Trần Tinh Húc","Lư Dục Hiểu"],"director":["猫的树"],"keywords":[],"tmdb":{"type":"tv","id":"279136","season":1,"vote_average":7.962,"vote_count":13},"cast_meta":[{"name":"Trần Tinh Húc","name_vi":"Trần Tinh Húc","name_original":"Chen Xingxu","tmdb_id":2243681,"profile":"https://image.tmdb.org/t/p/w500/coASvXYBdg4xTrW7W46ZQmfkwxk.jpg","tmdb_url":"https://www.themoviedb.org/person/2243681"},{"name":"Lư Dục Hiểu","name_vi":"Lư Dục Hiểu","name_original":"Lu Yuxiao","tmdb_id":3503861,"profile":"https://image.tmdb.org/t/p/w500/42fcXOMXCts1iEfJJpOBFPVwMLW.jpg","tmdb_url":"https://www.themoviedb.org/person/3503861"}],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ye/yet-hi.json"}