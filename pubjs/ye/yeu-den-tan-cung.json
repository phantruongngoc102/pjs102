ndex.m3u8"},{"name":"103","slug":"103","filename":"yeu-den-tan-cung-long-tieng-love-to-the-end-tap-103","link_embed":"https://vip.opstream10.com/share/561e7e7d74cece738de9b23c0dd293d2","link_m3u8":"https://vip.opstream10.com/20220427/10908_ed289f91/index.m3u8"},{"name":"104","slug":"104","filename":"yeu-den-tan-cung-long-tieng-love-to-the-end-tap-104","link_embed":"https://vip.opstream10.com/share/481d462e46c2ab976294271a175b8929","link_m3u8":"https://vip.opstream10.com/20220427/10907_7e40381e/index.m3u8"}]}],"time":"35 phút / tập","description":"<p>Nam chính là dạng tổng giám đốc bá đạo, biến thái, tính độc chiếm cao nên khi đọc truyện khá nặng nề, cân nhắc nhảy hố. Truyện là cả quá trình nam chính dần thay đổi bản thân đề phù hợp, để có được tình cảm trọn vẹn của nữ chính. Cả hai người đều có quá khứ riêng. Nữ chính về sau mới bước khỏi bóng đen và đón nhận tình cảm của anh. Cô không phải dạng người yếu đuối, thuộc kiểu người khôn khéo biết xã giao hơn</p>","tmdb":{"type":"tv","id":"81135","season":1,"vote_average":7,"vote_count":3},"modified":"2023-06-28T18:19:05.000Z","cast":["Lee Young-ah","Shim Ji-ho","Jeong Soo-young","Kang Eun-tak","Hong Soo-ah","Park Kwang-hyun","Lee Kyung-jin","Carson Allen","Choi Sung-min"],"director":["Shin Chang-Seok"],"cast_meta":[{"name":"Lee Young-ah","name_vi":null,"name_original":"Lee Young-ah","tmdb_id":1244815,"profile":"https://image.tmdb.org/t/p/w500/vtv57Nb8UxE7hfLJxz1K1KE8NiR.jpg","tmdb_url":"https://www.themoviedb.org/person/1244815"},{"name":"Shim Ji-ho","name_vi":null,"name_original":"Shim Ji-ho","tmdb_id":105612,"profile":"https://image.tmdb.org/t/p/w500/6XjaN7MlRML2Us6cJVjxdxGzX2u.jpg","tmdb_url":"https://www.themoviedb.org/person/105612"},{"name":"Jeong Soo-young","name_vi":null,"name_original":"Jeong Soo-young","tmdb_id":123805,"profile":"https://image.tmdb.org/t/p/w500/jmC39fMlmPyJ0wenKrNZT3BVnDS.jpg","tmdb_url":"https://www.themoviedb.org/person/123805"},{"name":"Kang Eun-tak","name_vi":null,"name_original":"Kang Eun