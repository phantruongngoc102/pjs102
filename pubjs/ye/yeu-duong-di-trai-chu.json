h Ngọc cũng vượt thời gian mà đến, biết mình còn có cơ hội quay về sơn trại, Lâm Loan Loan phải đối mặt quyết định khó khăn.","tmdb_id":230995,"cast":[],"director":[],"keywords":[],"tmdb":{"type":"tv","id":"230995","season":1,"vote_average":0,"vote_count":0},"cast_meta":[],"tmdb_checked":true,"pubjs_url":"https://cdn.jsdelivr.net/gh/phantruongngoc102/pjs102@main/pubjs/ye/yeu-duong-di-trai-chu.json"}