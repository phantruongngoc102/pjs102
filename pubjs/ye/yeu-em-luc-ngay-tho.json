om/share/15b31d721471a77f63036c45b8b63830","link_m3u8":"https://vip.opstream16.com/20221112/25793_96e07a7e/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream16.com/share/78e2010baad1af028423f6b9db642f53","link_m3u8":"https://vip.opstream16.com/20221112/25794_bcbe0389/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream16.com/share/d94c59b53ea6a9eec0a47ae789867098","link_m3u8":"https://vip.opstream16.com/20221112/25795_d8afc583/index.m3u8"}]}],"description":"<p>Đinh Hựu Nghinh (do Trương Chấn Lãng đóng) là người có sức ảnh hưởng trên mạng xã hội. Các đoạn phim dạy trang điểm và bình luận mỹ phẩm của Nghinh thu hút lượng lớn người xem, được cộng đồng mạng đánh giá cao. Trong khi đó, nữ giám đốc điều hành Lôi Tử Đồng (do Cao Hải Ninh đóng) xuất thân danh giá, bá khí ngút trời. Cô tự mình vực dậy nhãn hiệu mỹ phẩm vốn có tiếng nhưng hết thời, với tham vọng vươn tầm thế giới. Nhưng các sản phẩm của Đồng lại bị Nghinh bình luận tiêu cực trên mạng, dẫn đến doanh số sụt giảm nghiêm trọng. Đồng quyết định đích thân đến gặp Nghinh để thay đổi cách nhìn của anh và muốn anh PR cho sản phẩm của mình. Không may, Đồng bất ngờ bị ngã ngay trong nhà Nghinh. Hậu quả, cô trở nên ngớ ngẩn, trí tuệ chỉ như một đứa trẻ lên tám. Cha của Đồng – ông Lôi Trấn Nhạc (do Hồ Phong đóng) cử trợ lý đắc lực của Đồng là Thương Tra Lễ (do Trần Triển Bằng đóng) đến gặp Nghinh trao đổi điều kiện, với mong muốn Nghinh phải giữ bí mật vụ tai nạn, và giả làm chồng sắp cưới của Đồng để chăm sóc cô, giúp cô giữ vững hình tượng nữ giám đốc trước công chúng. Quá trình này khiến Nghinh dần có tình cảm với Đồng. Vì cô, anh khắc phục tính tự phụ, xéo xắt của mình, học cách quan tâm đến người khác. Mối quan hệ giữa Đồng với các thành viên trong gia đình cũng trở nên tốt hơn. Nghinh mong rằng Đồng sẽ mãi như lúc này. Tuy nhiên, tập đoàn của ông Nhạc lâm vào khủng hoảng, cần một Tử Đồng mạnh mẽ gánh vác. Đúng lúc đó, bệnh tình của Đồng tiến triển xấu, cần phẫu thuật. Rất có thể sau phẫu thuật, Đồng sẽ không còn nhớ về khoảng thời gian ở bên Nghinh. Rất có thể cô sẽ trở lại là nữ giám đốc lạnh lùng, ngang tàng như...</p>","tmdb_id":204865,"cast":["Trương Chấn Lãng","Samantha Ko","Trần Triển Bằng","Bowie Wu","Viên Văn Kiệt","Kandy Wong","Carlo Ng Ka-Lok","Nicole Wan See Pui","Derek Wong","Leo Kwan","Văn Tuyết Nhi","Dương Chứng Hoa","Tăng Huệ Vân","Cecilia So Yan-Chee","Aurora Li"],"director":["Liêu Tấn Thạc"],"keywords":[],"tmdb":{"type":"tv","id":"204865","season":1,"vote_average":0,"vote_count":0},"cast_meta":[{"name":"Trương Chấn Lãng","name_vi":"Trương Chấn Lãng","name_original":"Owen Cheung","tmdb_id":1613713,"profile":"https://image.tmdb.org/t/p/w500/xwg4ha6y8nk6P9V8NHQLV0iKRmL.jpg","tmdb_url":"https://www.themoviedb.org/person/1613713"},{"name":"Samantha Ko","name_vi":null,"name_original":"Samantha Ko","tmdb_id":1173598,"profile":"https://image.tmdb.org/t/p/w500/trFirFO6af8zjdwbVNQI4YMpKf6.jpg","tmdb_url":"https://www.themoviedb.org/person/1173598"},{"name":"Trần Triển Bằng","name_vi":"Trần Triển Bằng","name_original":"Ruco Chan","tmdb_id":1238985,"profile":"https://image.tmdb.org/t/p/w500/jD9jx5wiF3Y0XYzvcCNC2oRBrvT.jpg","tmdb_url":"https://www.themoviedb.org/person/1238985"},{"name":"Bowie Wu","name_vi":"Bowie Wu","name_original":"Woo Fung","tmdb_id":102883,"profile":"https://image.tmdb.org/t/p/w500/o5MHNXhT5GUATZoYxuXhw4ts3jK.jpg","tmdb_url":"https://www.themoviedb.org/person/102883"},{"name":"Viên Văn Kiệt","name_vi":"Viên Văn Kiệt","name_original":"Andrew Yuen","tmdb_id":2064589,"profile":"https://image.tmdb.org/t/p/w500/r9UznJQuycGBgy0gSG9jwUQ0DUP.jpg","tmdb_url":"https://www.themoviedb.org/person/2064589"},{"name":"Kandy Wong","name_vi":null,"name_original":"Kandy Wong","tmdb_id":2070063,"profile":"https://image.tmdb.org/t/p/w500/gQ1ak4CR7kloUq8iKjKFIXk5GKT.jpg","tmdb_url":"https://www.themoviedb.org/person/2070063"},{"name":"Carlo Ng Ka-Lok","name_vi":null,"name_original":"Carlo Ng Ka-Lok","tmdb_id":1258593,"profile":"htt