a1f01b8f9688896b65","link_m3u8":"https://vip.opstream12.com/20220624/22031_10738196/index.m3u8"},{"name":"41A","slug":"41a","filename":"yeu-em-nguoi-chua-lanh-vet-thuong-cho-anh-from-survivor-to-healer-tap-41A","link_embed":"https://vip.opstream12.com/share/83f075354ac93f60d1c1ac9a15399196","link_m3u8":"https://vip.opstream12.com/20220624/22035_97a9db29/index.m3u8"},{"name":"41B","slug":"41b","filename":"yeu-em-nguoi-chua-lanh-vet-thuong-cho-anh-from-survivor-to-healer-tap-41B","link_embed":"https://vip.opstream12.com/share/7f6411f044f4af764d78c7f31af15b2c","link_m3u8":"https://vip.opstream12.com/20220624/22032_7b0ac217/index.m3u8"},{"name":"42A","slug":"42a","filename":"yeu-em-nguoi-chua-lanh-vet-thuong-cho-anh-from-survivor-to-healer-tap-42A","link_embed":"https://vip.opstream12.com/share/4cdd31af4e1036bd1d21858cbae5fbe5","link_m3u8":"https://vip.opstream12.com/20220624/22033_906c7551/index.m3u8"},{"name":"42B","slug":"42b","filename":"yeu-em-nguoi-chua-lanh-vet-thuong-cho-anh-from-survivor-to-healer-tap-42B","link_embed":"https://vip.opstream12.com/share/085a2f56bfb27cb2e44ef3c457591b96","link_m3u8":"https://vip.opstream12.com/20220624/22034_bfbac9e3/index.m3u8"}]}],"time":"45 Phút / Tập","description":"<p>Khi Nhan Thư Nhân (Đậu Kiêu) đang học thạc sĩ thì tình cờ gặp gỡ và yêu đương với đàn em Tôn Thụ (Miêu Miêu). Vì biến cố của gia đình, Thư Nhân đòi chia tay không lý do với Tôn Thụ. Thất tình và cũng thất vọng vì nghĩ là bố chết là do mẹ, Tôn Thụ quyết định lựa chọn đi du học Nhật Bản. 5 năm sau, Thư Nhân trở thành bác sĩ khoa tâm thần ở bệnh viện Tư Khang, chuyên chữa trị cho những người bị mắc bệnh trầm cảm nhưng bản thân anh cũng mắc chứng bệnh mất ngủ, lo âu và phiền muôn… Thầy giáo của Thư Nhân và Tôn Thụ là Trần Nguyên Canh (Kim Sĩ Kiệt) lại mời cả Tôn Thụ vào làm bác sĩ tâm lý, cùng khoa với Thư Nhân. Sau khi gặp lại, Thư Nhân lại muốn hàn gắn lại mối quan hệ của hai người nhưng lúc đầu Tôn Thụ khá lạnh nhạt vì vẫn còn hận Thư Nhân. Mãi đến khi mẹ cô phải nằm viện chữa bệnh thì cô mới cảm nhận được Thư nhân vẫn còn yêu mình. Dần dần, trong quá trình làm việc, hai người đã trở lại với nhau. Sau này, khi Thư Nhân vô tình biết rõ hơn về biến cô gia đình của anh mấy năm trước, anh tự trách mình và nghi ngờ luôn chính tay nghề và thành tựu nghề nghiệp của mình. Liệu bác sĩ tâm lý Tôn Thụ có chữa lành được vết thương lòng cho Thư Nhân để cả hai có thể hạnh phúc bên nhau.</p>","tmdb":{"type":"tv","id":"89649","season":1,"vote_average":0,"vote_count":0},"modified":"2023-05-31T18:36:08.000Z","cast":["Đậu Kiêu","Miao Miao","Bành Quán Anh","Pan Hong","Kim Sĩ Kiệt","Johnny Zhang","Gao Ye","Ji Xuefei","Yang Yi"],"director":[],"cast_meta":[{"name":"Đậu Kiêu","name_vi":"Đậu Kiêu","name_original":"Shawn Dou","tmdb_id":145093,"profile":"https://image.tmdb.org/t/p/w500/3SN0FoX3rqFez0A5WrBZhXKsFQm.jpg","tmdb_url":"https://www.themoviedb.org/person/145093"},{"name":"Miao Miao","name_vi":null,"name_original":"Miao Miao","tmdb_id":1414138,"profile":"https://image.tmdb.org/t/p/w500/cKlYo2zrAmkPTPPzDYlOdvr6SFl.jpg","tmdb_url":"https://www.themoviedb.org/person/1414138"},{"name":"Bành Quán Anh","name_vi":"Bành Quán Anh","name_original":"Peng Guanying","tmdb_id":1690592,"profile":"https://image.tmdb.org/t/p/w500/xPWJwXDVHy1biQxVMBYkzSFQm8q.jpg","tmdb_url":"https://www.themoviedb.org/person/1690592"},{"name":"Pan Hong","name_vi":null,"name_original":"Pan Hong","tmdb_id":1172008,"profile":"https://image.tmdb.org/t/p/w500/9G1G3KHQRPvsq4VtwEg6EsTrFFb.jpg","tmdb_url":"https://www.themoviedb.org/person/1172008"},{"name":"Kim Sĩ Kiệt","name_vi":"Kim Sĩ Kiệt","name_original":"King Shih-chieh","tmdb_id":582557,"profile":"https://image.tmdb.org/t/p/w500/pQZBMC8ed97f5MNWb64SOlahxGs.jpg","tmdb_url":"https://www.themoviedb.org/person/582557"},{"name":"Johnny Zhang","name_vi":null,"name_original":"Johnny Zhang","tmdb_id":1737238,"profile":"https://image.tmdb.org/t/p/w500/gwFTUUtl8PExzj3GraOSlWlivox.jpg","tmdb_url":"https://www.themoviedb.org/person/17372