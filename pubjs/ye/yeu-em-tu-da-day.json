https://vip.opstream15.com/20220429/10259_aed435ee/index.m3u8"},{"name":"23","slug":"23","filename":"yeu-em-tu-da-day-thuyet-minh-dating-in-the-kitchen-tap-23","link_embed":"https://vip.opstream15.com/share/83f344600d15cbf1ed5cb005db32f994","link_m3u8":"https://vip.opstream15.com/20220429/10263_5d42c7cc/index.m3u8"},{"name":"24","slug":"24","filename":"yeu-em-tu-da-day-thuyet-minh-dating-in-the-kitchen-tap-24","link_embed":"https://vip.opstream15.com/share/b433da1b32b5ca96c0ba7fcb9edba97d","link_m3u8":"https://vip.opstream15.com/20220429/10268_aa629dc4/index.m3u8"}]}],"time":"43M58S","description":"<p>Điều khó tin nhất trong cuộc đời Cố Thắng Nam tinh ranh, chính là sau khi cô vừa thất tình vừa thất nghiệp đang mòn mỏi đợi chờ bạch mã hoàng tử đến cứu vớt cuộc đời, thì ai mà ngờ được chàng hoàng tử của cô vừa xoi mói vừa lươn lẹo, vừa độc mồm độc miệng, lại vừa tự cao tự đại, là bản update của \\\"Đường Tăng\\\"! Lộ Tấn sành ăn, kiêu ngạo, độc mồm vừa gặp đầu bếp thiên tài Cố Thắng Nam là không ngừng xảy ra sự cố, nhưng lần nào cũng bị tay nghề cao siêu của cô hấp dẫn. Trải qua suốt quá trình gà bay chó chạy, hỗn loạn tung trời này, hai người ngày càng sát lại gần nhau hơn tựa như được số phận sắp đặt.</p>","tmdb":{"type":"tv","id":"109866","season":1,"vote_average":6.8,"vote_count":22},"modified":"2024-09-23T18:08:23.000Z","cast":["Triệu Lộ Tư","Lâm Vũ Thân","Trương Hiểu Khiêm","Phó Gia","Yu Xinhe","Wu Yaheng","Lý Thiến","Henry Luk Yat-Lung"],"director":["Chang Chen"],"cast_meta":[{"name":"Triệu Lộ Tư","name_vi":"Triệu Lộ Tư","name_original":"Zhao Lusi","tmdb_id":2049994,"profile":"https://image.tmdb.org/t/p/w500/y82wmaDqTdXqvtasb4kxAIuT44U.jpg","tmdb_url":"https://www.themoviedb.org/person/2049994"},{"name":"Lâm Vũ Thân","name_vi":"Lâm Vũ Thân","name_original":"Lin Shen","tmdb_id":2296491,"profile":"https://image.tmdb.org/t/p/w500/qDxvfC4GiM0rrEo22oWgxAAwm4a.jpg","tmdb_url":"https://www.themoviedb.org/person/2296491"},{"name":"Trương Hiểu Khiêm","name_vi":"Trương 