ps://vip.opstream13.com/share/02c28f84c46deb0b993010f76fef4c0d","link_m3u8":"https://vip.opstream13.com/20251108/17512_02c28f84/index.m3u8"},{"name":"19","slug":"19","filename":"Phim TVB lồng tiếng Tình Yêu Mù Quáng (Love Is Blind) 19#20 # Châu Hải My, Liêu Vỹ Hùng # 1994","link_embed":"https://vip.opstream13.com/share/5faa4ad014bbddf9ae4006a0f03085e0","link_m3u8":"https://vip.opstream13.com/20251108/17513_5faa4ad0/index.m3u8"},{"name":"20","slug":"20","filename":"Phim TVB lồng tiếng Tình Yêu Mù Quáng (Love Is Blind) 20#20 # Châu Hải My, Liêu Vỹ Hùng # 1994","link_embed":"https://vip.opstream13.com/share/537442dc2f31b1311163fef609949f9c","link_m3u8":"https://vip.opstream13.com/20251108/17514_537442dc/index.m3u8"}]}],"time":"45 phút/tập","description":"<p>Bộ phim hài lãng mạn kể về câu chuyện của Maurin Gong, một người đàn ông trung niên đã trải qua bảy cuộc hẹn hò mù quáng, vụng về và kém hấp dẫn. Anh gặp Leung Lei, một cô gái Philippines xinh đẹp và tốt bụng, nhưng lại chọn cuộc sống làm gái mại dâm. Câu chuyện tình yêu hài hước và lãng mạn của họ khám phá sức mạnh của tình yêu và thách thức các chuẩn mực xã hội. Châu Hải Mỹ vào vai Leung Lei, khác biệt hoàn toàn so với những vai diễn ngây thơ trước đây, mang đến cho màn ảnh một nét quyến rũ gợi cảm và hoang dã.</p>","tmdb":{"type":"tv","id":"109434","season":1,"vote_average":0,"vote_count":0},"modified":"2025-11-10T18:13:28.000Z","cast":["Liu Wai-Hung","Amy Fan","Jimmy Wong Shu-Kei","Châu Hải My","Cutie Mui Siu-Wai","Ga-Bo Tsui","Bao Fang","Lau Sau-Ping"],"director":[],"cast_meta":[{"name":"Liu Wai-Hung","name_vi":null,"name_original":"Liu Wai-Hung","tmdb_id":998678,"profile":"https://image.tmdb.org/t/p/w500/ardsrPTdd2qQsm0tW5WqEDu0hNl.jpg","tmdb_url":"https://www.themoviedb.org/person/998678"},{"name":"Amy Fan","name_vi":null,"name_original":"Amy Fan","tmdb_id":1132172,"profile":"https://image.tmdb.org/t/p/w500/wvKQcymCS4MaHwpfIdq1CauXij1.jpg","tmdb_url":"https://www.themoviedb.org/person/1132172"},{"name":"Jimmy