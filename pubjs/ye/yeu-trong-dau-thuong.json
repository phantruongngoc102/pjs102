389_1b085033/index.m3u8"},{"name":"39","slug":"39","filename":"Yêu Trong Đau Thương - Love In Sadness - Tập 39","link_embed":"https://vip.opstream11.com/share/8a1df180ea2c0d298aa1d739fe720a0c","link_m3u8":"https://vip.opstream11.com/20220413/14390_c65005a8/index.m3u8"},{"name":"40","slug":"40","filename":"Yêu Trong Đau Thương - Love In Sadness - Tập 40","link_embed":"https://vip.opstream11.com/share/3abb5691502cbd522511147519f8a487","link_m3u8":"https://vip.opstream11.com/20220413/14391_0c09fd42/index.m3u8"}]}],"time":"30 phút / tập","description":"<p>Jung Won (Ji Hyun Woo) yêu sâu đậm với Ha Gyung (Park Han Byul), tuy nhiên, Ha Gyung lại không như vậy, cô ngoại tình và muốn chia tay với Jung Won. Khi Jung Won phát hiện ra cũng là lúc Ha Gyung bị tai nạn, hôn mê sâu suốt 5 năm. Vì quá yêu, Jung Won chấp nhận tha thứ, ngày đêm cầu nguyện nhưng Ha Gyung lại ra đi mãi mãi. Một ngày, Jung Won vô tình gặp Ma-ri, người phụ nữ có khuôn mặt giống hệt Ha Gyung. Ma-ri đang sống hạnh phúc cùng chồng là In Wook (Ryu Soo Young) - chủ tịch một tập đoàn lớn, nơi Jung Won đang làm việc. Liệu Jung Won có nhận ra được hiện thực Ma-ri không phải là Ha Hyung không hay anh cứ mãi đắm chìm trong tình yêu của mình, đuổi theo Ma-ri, phá vỡ hạnh phúc gia đình cô?</p>","tmdb":{"type":"tv","id":"87022","season":1,"vote_average":4.5,"vote_count":2},"modified":"2023-05-31T18:53:26.000Z","cast":["Ji Hyun-woo","Park Han-byul","Ryu Soo-young","Wang Bit-na","Moon Hee-kyung","Kim Ye-ryeong","Jung Won-joong","Ahn Jung-hun","Kang Sung-wook","Koh Woo-ri"],"director":["Choi Yi Seob"],"cast_meta":[{"name":"Ji Hyun-woo","name_vi":null,"name_original":"Ji Hyun-woo","tmdb_id":1253552,"profile":"https://image.tmdb.org/t/p/w500/3HW8mIZCQH4qxGb2226dZh3rAM3.jpg","tmdb_url":"https://www.themoviedb.org/person/1253552"},{"name":"Park Han-byul","name_vi":null,"name_original":"Park Han-byul","tmdb_id":1233711,"profile":"https://image.tmdb.org/t/p/w500/xpzU6diEF3lZMxDPRweKWgrbkhE.jpg","tmdb_url":"https://www.themovie