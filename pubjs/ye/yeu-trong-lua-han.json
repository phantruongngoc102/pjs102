95","slug":"95","link_embed":"https://vip.opstream15.com/share/5a85461739094491a96bb30267640454","link_m3u8":"https://vip.opstream15.com/20231103/44025_e679210f/index.m3u8"},{"name":"96","slug":"96","link_embed":"https://vip.opstream15.com/share/47a435a92e85fb6c9acebc449a3bfb6a","link_m3u8":"https://vip.opstream15.com/20231103/44024_6be88b7f/index.m3u8"},{"name":"97","slug":"97","link_embed":"https://vip.opstream15.com/share/214db8cdf991e0ee01c25656e28a4049","link_m3u8":"https://vip.opstream15.com/20231103/44026_88674acf/index.m3u8"},{"name":"98","slug":"98","link_embed":"https://vip.opstream15.com/share/fef6255b484a1dc0dac35fd87bb905ae","link_m3u8":"https://vip.opstream15.com/20231103/44027_fde67e28/index.m3u8"},{"name":"99","slug":"99","link_embed":"https://vip.opstream15.com/share/05b99715f32c973f929cd22735389966","link_m3u8":"https://vip.opstream15.com/20231103/44028_565681f7/index.m3u8"},{"name":"100","slug":"100","link_embed":"https://vip.opstream15.com/share/e7cb3af0459b010c53533157ed3d1110","link_m3u8":"https://vip.opstream15.com/20231103/44030_327bfb0f/index.m3u8"},{"name":"101","slug":"101","link_embed":"https://vip.opstream15.com/share/991ef9a704469ce820a63388e908acc1","link_m3u8":"https://vip.opstream15.com/20231103/44029_1a378892/index.m3u8"}]}],"description":"<p>Tahsin là người đứng đầu gia đình Korludag, sự giàu có và ảnh hưởng lớn trong xã hội khiến anh được mọi người kính sợ và kính trọng. Không có địa điểm hay người nào trong thị trấn mà anh ta không kiểm soát. Tahsin có hai con; Con trai Korhan của ông là một nỗi thất vọng lớn đối với cha ông, nhưng Sühan, cô con gái thông minh và xinh đẹp của ông, lại được ông yêu quý vô cùng. Vợ của Korhan cố gắng mang thai nhưng không thành công. Vì lo sợ rằng Suhan sẽ giao người thừa kế tài sản cho gia đình trước mình nên cô đã cố giết chị dâu của mình. Tuy nhiên, kế hoạch xấu xa của cô đã bị phá sản khi một người lạ đẹp trai bước vào câu chuyện, cứu mạng Suhan, trở thành người yêu của cô và thay thế anh trở thành cậu con trai mà Tahsin hằng mơ ước. Nhưng điều không ai biết là sự trả thù chảy trong huyết quản của người lạ mặt này và không phải ngẫu nhiên mà anh ta lại xuất hiện khi làm vậy. Liệu tình yêu của anh dành cho Sühan có ngăn cản anh tiếp tục kế hoạch trả thù Tahsin hay tất cả chỉ là một phần trong kế hoạch tổng thể của anh…?</p>","tmdb_id":68848,"cast":["Kıvanç Tatlıtuğ","Tuba Büyüküstün","Tamer Levent","Erkan Avcı","Serkan Altunorak","Sezin Akbaşoğulları","Fırat Altunmeşe","Irmak Örnek","Gözde Türkpençe","Müfit Kayacan","Işil Dayioğlu","Zeynep Kızıltan","Cansu Türedi","Devrim Yakut","Nihan Büyükağaç"],"director":["Ali Bilgin"],"keywords":[],"tmdb":{"type":"tv","id":"68848","season":1,"vote_average":8.5,"vote_count":42},"cast_meta":[{"name":"Kıvanç Tatlıtuğ","name_vi":null,"name_original":"Kıvanç Tatlıtuğ","tmdb_id":1078769,"profile":"https://image.tmdb.org/t/p/w500/rs7Z3PKa82UhKGQLrBNAy0JAWV5.jpg","tmdb_url":"https://www.themoviedb.org/person/1078769"},{"name":"Tuba Büyüküstün","name_vi":null,"name_original":"Tuba Büyüküstün","tmdb_id":142855,"profile":"https://image.tmdb.org/t/p/w500/7EgdthwcD5uCSOg0YWivuQ5kyK6.jpg","tmdb_url":"https://www.themoviedb.org/person/142855"},{"name":"Tamer Levent","name_vi":null,"name_original":"Tamer Levent","tmdb_id":1083415,"profile":"https://image.tmdb.org/t/p/w500/bQrGr7zTAdNfeGb18wNgPbXTmle.jpg","tmdb_url":"https://www.themoviedb.org/person/1083415"},{"name":"Erkan Avcı","name_vi":null,"name_original":"Erkan Avcı","tmdb_id":1052797,"profile":"https://image.tmdb.org/t/p/w500/2SQBu38Hx4Yx2PM7OdKgbdz5UCd.jpg","tmdb_url":"https://www.themoviedb.org/person/1052797"},{"name":"Serkan Altunorak","name_vi":null,"name_original":"Serkan Altunorak","tmdb_id":1483880,"profile":"https://image.tmdb.org/t/p/w500/6mZ4mH9GgfMtCeaBJzUt8GfuVir.jpg","tmdb_url":"https://www.themoviedb.org/person/1483880"},{"name":"Sezin Akbaşoğulları","name_vi":null,"name_original":"Sezin Akbaşoğulları","tmdb_id":1398581,"profile":"https://image.tmdb.org/t/p/w500