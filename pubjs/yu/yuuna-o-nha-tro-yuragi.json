e801f3","link_m3u8":"https://vip.opstream16.com/20230407/33713_dac24491/index.m3u8"},{"name":"8","slug":"8","link_embed":"https://vip.opstream16.com/share/4f6e1bfb01ad1e44d8c958c58cd22051","link_m3u8":"https://vip.opstream16.com/20230407/33714_ebb3c507/index.m3u8"},{"name":"9","slug":"9","link_embed":"https://vip.opstream16.com/share/d537ee491b74b6c989edc42876533028","link_m3u8":"https://vip.opstream16.com/20230407/33715_053ea94d/index.m3u8"},{"name":"10","slug":"10","link_embed":"https://vip.opstream16.com/share/b1c22d171a128f2defc188ce786fbbf8","link_m3u8":"https://vip.opstream16.com/20230407/33716_f41b09cb/index.m3u8"},{"name":"11","slug":"11","link_embed":"https://vip.opstream16.com/share/af523c5d4c1038a5f074c4320af0ce78","link_m3u8":"https://vip.opstream16.com/20230407/33717_231ab2bb/index.m3u8"},{"name":"12","slug":"12","link_embed":"https://vip.opstream16.com/share/da7966481086a4e3a2dde7c2ccbc49e3","link_m3u8":"https://vip.opstream16.com/20230407/33718_7c3211f0/index.m3u8"},{"name":"13","slug":"13","link_embed":"https://vip.opstream16.com/share/cfef40996e0de2c0f3fe1031421403fd","link_m3u8":"https://vip.opstream16.com/20230407/33719_8db7c10a/index.m3u8"},{"name":"14","slug":"14","link_embed":"https://vip.opstream16.com/share/ffb51c2a27a66718f1ba1515c250c722","link_m3u8":"https://vip.opstream16.com/20230407/33720_84ba1078/index.m3u8"},{"name":"15","slug":"15","link_embed":"https://vip.opstream16.com/share/015de601ee1e62453e29e4fee1be359a","link_m3u8":"https://vip.opstream16.com/20230407/33721_b0e0d4ad/index.m3u8"}]}],"description":"<p>Từng là một nhà nghỉ suối nước nóng nhưng nay đã trở thành nhà trọ với giá thuê cực kì rẻ, Nhà Trọ Yuragi hầu như bị bỏ hoang và chỉ có vài khách trọ đặc biệt. Nơi đó được đồn đại là bị ma ám nên hầu như chẳng ai dám đến thuê trọ. Nhưng vì thế nên nơi đó lại là lựa chọn hoàn hảo cho Fuyuzora Kogarashi, một nhà ngoại cảm nghèo mạt cần một mái nhà để che thân và những con ma để trục xuất. Kogarashi đã sẵn sàng để đối mặt với con ma được đồn đại nhưng hóa ra con ma đó không hề tà ác như lời đồn mà là Yuuna, một hồn ma thiếu nữ xinh đẹp với mái tóc bạc đã quên hết mọi chuyện trước khi cô chết. Bất ngờ với Kogarashi hơn nữa là những khách trọ khác của Nhà Trọ Yuragi không chỉ cũng nhìn thấy được Yuuna như cậu mà họ đều có những khả năng siêu nhiên của riêng mình. Dù phải đối mặt với nhiều rắc rối vì những bạn trọ đặc biệt của mình, Kogarashi vẫn quyết tâm tìm ra điều nuối tiếc của Yuuna khiến cô chưa thể siêu thoát nhằm giúp cô không trở thành ác ma và bị đày xuống Địa Ngục.</p>","tmdb_id":null,"cast":[],"director":[],"keywords":[],"cast_meta":[],"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/yu/yuuna-o-nha-tro-yuragi.json"}